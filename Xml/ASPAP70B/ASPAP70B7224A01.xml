<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B7224A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
El motor del soplador no funciona
</title>
<diag type = "condition">
<condition>
<ptxt>
El motor del soplador no funciona
</ptxt>
</condition>
<ps>
<ptxt>
Fusible fundido
</ptxt>
</ps>
<action>
<ptxt>
Verifique si hay cortocircuito a masa en los fusibles relacionados.
</ptxt>
</action>
<ps>
<ptxt>
Relé del motor del soplador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el relé del motor del soplador. 
<intxreftitleoff1 refid = "ASPAP70B7226034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Resistor del motor del soplador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el resistor del motor del soplador. 
<intxreftitleoff1 refid = "ASPAP70B7226013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Selector de velocidad del soplador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el selector de velocidad del soplador. 
<intxreftitleoff1 refid = "ASPAP70B7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motor del soplador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el motor del soplador. 
<intxreftitleoff1 refid = "ASPAP70B7226011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado.
</ptxt>
</action>
<ps>
<ptxt>
Presencia de partículas extrañas
</ptxt>
</ps>
<action>
<ptxt>
Retire las partículas extrañas.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
