<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70BA206004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del sensor de temperatura exterior
</title>
<servinfosub id = "ASPAP70BA206004001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el parachoques delantero. 
<intxreftitleoff1 refid = "ASPAP70B9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del sensor de temperatura del aire exterior.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga de la pieza inferior del parachoques delantero el sensor (2) de temperatura del aire exterior.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20018.jpg" width = "88.000mm" height = "67.914mm" ver = "01" gw = "210" gh = "176"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70BA206004002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70BA206005">Inspección del sensor de temperatura exterior</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
