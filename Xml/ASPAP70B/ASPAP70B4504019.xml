<servinfo servinfosgmlid = "ASPAP70B4504019" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1071
</title>
<servinfosub id = "ASPAP70B4504019001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1071: Fallo interno del módulo de control del ABS
</emph>
</ptxt>
<ptxt>
Se ha detectado un fallo interno en el módulo de control del ABS.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Módulo de control del ABS
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70B4504019002">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70B4504019003">
<testgroup id = "ASPAP70B4504019004">
<question>
¿Se realizó la &#34;Inspección del ABS&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70B4504001">Inspección del ABS</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4504019005">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70B4504005">Comprobación del DTC</intxref>
.
</ptxt>
</test1>
<question>
¿Aparece algún otro DTC además del C1071?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización de averías del DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el conjunto de la unidad hidráulica/módulo de control del ABS y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70B4506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
