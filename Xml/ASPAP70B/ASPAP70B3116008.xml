<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B3116008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del cubo de la rueda delantera, pivote de dirección y cojinete de la rueda
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B3116006">Componentes del cubo de la rueda delantera y del pivote de la dirección:Parte delantera</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Al extraer e instalar el pivote de dirección, tenga cuidado de no dañar el guardapolvo del freno delantero de la junta del brazo de suspensión.
</ptxt>
</attention2>
<servinfosub id = "ASPAP70B3116008001">
<title>
Extracción
</title>
<s1>
<ptxt>
Levante el vehículo y retire la rueda delantera. 
<intxreftitleoff1 refid = "ASPAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Quite la tuerca del eje impulsor. 
<intxreftitleoff1 refid = "ASPAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el disco de freno. 
<intxreftitleoff1 refid = "ASPAP70B4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Saque el cubo de rueda (1) con las herramientas especiales.
</ptxt>
<attention3>
<ptxt>
El lado exterior del anillo interior del cojinete de la rueda sale junto con el cubo de la rueda.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3A114">
<s-part>
(A)
</s-part>
<s-number num = "09943-17912">
09943-17912
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A115">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942-15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311016.swf" width = "88.000mm" height = "57.642mm" ver = "01" gw = "181" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte el extremo de la barra de acoplamiento del pivote de la dirección. 
<intxreftitleoff1 refid = "ASPAP70B6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el sensor de velocidad de la rueda del pivote de dirección.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modelos con ABS: 
<intxreftitleoff1 refid = "ASPAP70B4506006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modelo con ESP<sup>&#174;</sup>: 
<intxreftitleoff1 refid = "ASPAP70B4606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga los pernos y tuercas del soporte del puntal. 
<intxreftitleoff1 refid = "ASPAP70B2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte la junta del brazo de suspensión del pivote de dirección. 
<intxreftitleoff1 refid = "ASPAP70B2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el pivote de dirección del eje impulsor.
</ptxt>
</s1>
<s1>
<ptxt>
Retire el calafateado (1) en los cuatro lugares con un cincel o similar.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta guardapolvo del freno delantero (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A311015.swf" width = "88.000mm" height = "63.961mm" ver = "01" gw = "187" gh = "165"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el anillo elástico (1) del pivote de dirección.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Empuje hacia afuera el cojinete de la rueda con las herramientas especiales y la prensa hidráulica (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L3A116">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913-75810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A117">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A311017.swf" width = "88.000mm" height = "46.725mm" ver = "01" gw = "99" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Apalanque un poco el anillo-guía interior exterior (1) del cojinete de la rueda empleando un cincel o similar.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga del cubo de la rueda el anillo-guía interior exterior (1) del cojinete de la rueda con herramientas especiales tal como se muestra en la ilustración.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A118">
<s-part>
(A)
</s-part>
<s-number num = "09913-65810">
09913-65810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A119">
<s-part>
(B)
</s-part>
<s-number num = "09926-37610-003">
09926-37610-003
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311020.swf" width = "88.000mm" height = "78.517mm" ver = "01" gw = "104" gh = "206"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga los pernos del cubo (1) con un martillo de cobre o con la prensa hidráulica si fuera necesario.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A220020.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "166" gh = "128"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B3116008002">
<title>
Instalación
</title>
<s1>
<ptxt>
Inserte un perno (1) de cubo nuevo en el orificio del cubo. Gire lentamente el perno del cubo para que las estrías queden alineadas con las realizadas por el perno original, si se había extraído.
</ptxt>
<figure>
<graphic graphicname = "I2RH01220040.swf" width = "88.000mm" height = "47.317mm" ver = "01" gw = "142" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Coloque el cojinete de la rueda nuevo (1) en el pivote de la dirección (2) con el sello marrón (3) mirando hacia abajo, como se muestra en la ilustración.
</ptxt>
<attention2>
<ptxt>
No reutilice el cojinete de la rueda para evitar ruidos o que quede atascado.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Ajuste a presión el cojinete de rueda en el pivote de dirección (2) utilizando herramientas especiales tal y como se muestra en la ilustración.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A120">
<s-part>
(A)
</s-part>
<s-number num = "09913-75510">
09913-75510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A121">
<s-part>
(B)
</s-part>
<s-number num = "09926-68310">
09926-68310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A122">
<s-part>
(C)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70B311008.swf" width = "88.000mm" height = "71.587mm" ver = "01" gw = "232" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Instale el anillo elástico (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Coloque la nueva cubierta guardapolvo del freno delantero.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Cuando encaje a presión la cubierta guardapolvo del freno delantero, no la deforme.
</ptxt>
</item>
<item>
<ptxt>
Cuando coloque la cubierta guardapolvo del freno delantero, utilice una nueva.
</ptxt>
</item>
</list1>
</attention2>
</s1>
<s1>
<ptxt>
Encaje a presión la cubierta guardapolvo nueva (2) del freno delantero en el pivote de dirección con una prensa hidráulica (1) y herramientas especiales.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A123">
<s-part>
(A)
</s-part>
<s-number num = "09951-17010">
09951-17010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A124">
<s-part>
(B)
</s-part>
<s-number num = "09944-77030">
09944-77030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311018.swf" width = "88.000mm" height = "55.099mm" ver = "01" gw = "203" gh = "140"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.179in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.179in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
13&#176;
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;b&#34;: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
70 mm (2,8 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Calafatee más de 4 lugares con un cortafríos pequeño.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311020.swf" width = "88.000mm" height = "52.911mm" ver = "01" gw = "186" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.086in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Calafateo
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Encaje a presión el cubo de la rueda (1) en el cojinete de la rueda (2) con las herramientas especiales y la prensa hidráulica.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A125">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913-75810
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3A126">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311017.swf" width = "88.000mm" height = "57.910mm" ver = "01" gw = "203" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Conecte el eje impulsor al pivote de la dirección. 
<intxreftitleoff1 refid = "ASPAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Conecte el pivote de la dirección al brazo de la suspensión. 
<intxreftitleoff1 refid = "ASPAP70B2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Coloque los pernos y tuercas del soporte del puntal. 
<intxreftitleoff1 refid = "ASPAP70B2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Coloque el sensor de velocidad de la rueda delantera.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modelos con ABS: 
<intxreftitleoff1 refid = "ASPAP70B4506006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modelo con ESP<sup>&#174;</sup>: 
<intxreftitleoff1 refid = "ASPAP70B4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Conecte el extremo de la barra de acoplamiento al pivote de la dirección. 
<intxreftitleoff1 refid = "ASPAP70B6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Coloque el disco de freno y la pinza de freno. 
<intxreftitleoff1 refid = "ASPAP70B4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Apriete la tuerca nueva el eje impulsor. 
<intxreftitleoff1 refid = "ASPAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Coloque las ruedas delanteras. 
<intxreftitleoff1 refid = "ASPAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Compruebe la alineación de las ruedas delanteras. 
<intxreftitleoff1 refid = "ASPAP70B2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
