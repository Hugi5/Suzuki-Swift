<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B7226036" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la correa de transmisión del compresor 
</title>
<servinfosub id = "ASPAP70B7226036001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Afloje el perno (1) de la polea tensora. 
</ptxt>
</s1>
<s1>
<ptxt>
Afloje la tensión de la correa aflojando el perno (2) de ajuste de la polea tensora. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la correa de transmisión del compresor (3). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A722023.swf" width = "88.000mm" height = "57.807mm" ver = "08" gw = "182" gh = "147"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B7226036002">
<title>
Instalación 
</title>
<s1>
<ptxt>
Instale la correa de transmisión del compresor.
</ptxt>
</s1>
<s1>
<ptxt>
Ajuste la tensión de la correa. 
<intxreftitleoff1 refid = "ASPAP70B7226035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
