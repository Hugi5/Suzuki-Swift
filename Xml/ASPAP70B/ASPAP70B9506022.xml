<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B9506022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del espejo retrovisor exterior
</title>
<servinfosub id = "ASPAP70B9506022001">
<title>
Extracción
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B9506021">Inspección en el vehículo del retrovisor exterior eléctrico</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Extraiga el embellecedor interior del soporte de la ventanilla y del embellecedor de la puerta. 
<intxreftitleoff1 refid = "ASPAP70B9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del retrovisor eléctrico exterior.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las tuercas del retrovisor exterior (1) y el conjunto del retrovisor exterior (2).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el retrovisor exterior (3), la cubierta del visor del espejo (4) y la luz de señal de giro del retrovisor exterior (5) (si el vehículo dispone de ello), si es necesario.
</ptxt>
<figure>
<graphic graphicname = "IAP70B950005.jpg" width = "88.000mm" height = "63.153mm" ver = "01" gw = "199" gh = "163"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.750in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
6.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Garra
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
7.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Conector de la luz de señal de giro del retrovisor exterior (si el vehículo dispone de ello)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B9506022002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Inserte las garras (2) firmemente cuando instale el espejo (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70B950006.jpg" width = "88.000mm" height = "63.153mm" ver = "01" gw = "199" gh = "163"/>
</figure>
</item>
<item>
<ptxt>
Apriete las tuercas del retrovisor exterior en orden (de &#34;1&#34; a &#34;3&#34;) al par especificado.
</ptxt>
<torque>
<torqueitem id = "T9E007">
<t-part>
Tuerca del retrovisor exterior*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950057.jpg" width = "88.000mm" height = "63.396mm" ver = "01" gw = "225" gh = "163"/>
</figure>
</item>
<item>
<ptxt>
Compruebe el funcionamiento del retrovisor exterior tras la instalación.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
