<diag type = "test" id = "ASPAP70B7234018005">
<testgroup id = "ASPAP70B7234018006">
<title>
Comprobación de los parámetros de la herramienta de escaneado
</title>
<test1>
<ptxt>
Compruebe &#34;Sen pos mez aire&#34; con el modo &#34;Lista de Datos&#34; de la herramienta de escaneado SUZUKI. 
<intxreftitleoff1 refid = "ASPAP70B7234007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es la tensión inferior a 0,1 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problema intermitente.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B7234018007">
<title>
Comprobación del circuito de la señal del sensor de posición del actuador de control de temperatura
</title>
<test1>
<ptxt>
Desconecte el conector del actuador de control de temperatura
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPAP70B7234008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se detecta el DTC B1511-H?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el actuador de control de temperatura. 
<intxreftitleoff1 refid = "ASPAP70B7236023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B7234018008">
<title>
Comprobación del circuito de la señal del sensor de posición del actuador de control de temperatura
</title>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</test1>
<test1>
<ptxt>
Mida la tensión entre el terminal del cable &#34;WHT&#34; del conector del actuador de control de temperatura y la conexión a masa.
</ptxt>
</test1>
<question>
¿La tensión es de 5 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B7234018009">
<title>
Comprobación del circuito de la señal del sensor de posición del actuador de control de temperatura
</title>
<test1>
<ptxt>
Desconecte el conector &#34;G20&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistencia del circuito del cable &#34;WHT&#34;: menos de 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Resistencia del circuito del cable &#34;WHT&#34; entre el actuador de control de temperatura y la conexión a masa: infinito
</ptxt>
</item>
</list1>
</test1>
<question>
¿Está la resistencia dentro de los valores especificados?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control HVAC y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70B7236011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el mazo de cables del panel de instrumentos.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B7234018010">
<title>
Comprobación del circuito de la señal del sensor de posición del actuador de control de temperatura
</title>
<test1>
<ptxt>
Compruebe que la resistencia entre el terminal del cable &#34;YEL&#34; y la masa sea infinita.
</ptxt>
</test1>
<question>
¿Coincide la resistencia con las especificaciones?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control HVAC y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70B7236011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el mazo de cables del panel de instrumentos.
</ptxt>
</action>
</testgroup>
