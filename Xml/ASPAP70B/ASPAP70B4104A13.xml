<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B4104A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La luz de advertencia de frenos se mantiene encendida (durante más de 2 seg.) tras arrancar el motor
</title>
<diag type = "condition">
<condition>
<ptxt>
La luz de advertencia de frenos se mantiene encendida (durante más de 2 seg.) tras arrancar el motor
</ptxt>
</condition>
<ps>
<ptxt>
El conector del módulo de control del ABS/ ESP<sup>&#174;</sup> no está conectado de forma correcta
</ptxt>
</ps>
<action>
<ptxt>
Vuelva a conectar el conector del módulo de control del ABS/ESP<sup>&#174;</sup>.
</ptxt>
</action>
<ps>
<ptxt>
Freno de estacionamiento aplicado
</ptxt>
</ps>
<action>
<ptxt>
Suelte el freno de estacionamiento y verifique si la luz de advertencia se apaga.
</ptxt>
</action>
<ps>
<ptxt>
Líquido de frenos insuficiente
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el nivel del líquido de frenos. 
<intxreftitleoff1 refid = "ASPAP70B4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Interruptor del freno de estacionamiento y/o el interruptor de nivel de líquido de freno defectuoso
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Compruebe el interruptor de freno y/o el interruptor de nivel de líquido de freno.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Interruptor del freno de estacionamiento: 
<intxreftitleoff1 refid = "ASPAP70B4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Interruptor de nivel de líquido de freno: 
<intxreftitleoff1 refid = "ASPAP70B4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Avería del sistema de comunicación CAN
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el sistema de comunicación CAN. 
<intxreftitleoff1 refid = "ASPAP70BA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Juego de instrumentos defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el juego de instrumentos. 
<intxreftitleoff1 refid = "ASPAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Módulo de control del ABS / ESP<sup>&#174;</sup> defectuoso
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sustituya el módulo de control del ABS / ESP<sup>&#174;</sup>.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Modelos con ABS: 
<intxreftitleoff1 refid = "ASPAP70B4506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modelo con ESP<sup>&#174;</sup>: 
<intxreftitleoff1 refid = "ASPAP70B4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
