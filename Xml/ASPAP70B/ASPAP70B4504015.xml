<servinfosub id = "ASPAP70B4504015003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70B4504015004">
<testgroup id = "ASPAP70B4504015005">
<question>
¿Se realizó la &#34;Inspección del sistema ABS&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70B4504001">Inspección del ABS</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4504015006">
<title>
 Comprobación de los circuitos de masa del módulo de control del ABS y de alimentación eléctrica de la válvula de solenoide
</title>
<test1>
<ptxt>
Compruebe los circuitos de masa y alimentación eléctrica de la válvula solenoide según 
<intxref refid = "ASPAP70B4504022">Comprobación del circuito de masa y de alimentación eléctrica del módulo de control del ABS</intxref>
.
</ptxt>
</test1>
<question>
¿Son correctos los resultados de la comprobación?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el conjunto de la unidad hidráulica/módulo de control del ABS y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70B4506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso.
</ptxt>
</action>
</testgroup>
</diag>
