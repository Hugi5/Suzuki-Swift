<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B6104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Dureza de la dirección
</title>
<diag type = "condition">
<condition>
<ptxt>
Dureza de la dirección
</ptxt>
</condition>
<ps>
<ptxt>
Presión del neumático insuficiente
</ptxt>
</ps>
<action>
<ptxt>
Ajuste la presión de inflado de los neumáticos.
</ptxt>
</action>
<ps>
<ptxt>
Avería del sistema de servodirección
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione y corrija. 
<intxreftitleoff1 refid = "ASPAP70B6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Junta esférica del extremo de la barra de acoplamiento doblada
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el extremo de la barra de acoplamiento. 
<intxreftitleoff1 refid = "ASPAP70B6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Junta esférica de suspensión doblada
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el brazo de la suspensión. 
<intxreftitleoff1 refid = "ASPAP70B2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Desajuste de la alineación de las ruedas delanteras
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione y ajuste la alineación de las ruedas delanteras. 
<intxreftitleoff1 refid = "ASPAP70B2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Columna de dirección doblada
</ptxt>
</ps>
<action>
<ptxt>
Sustituya la columna de dirección. 
<intxreftitleoff1 refid = "ASPAP70B6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Contacto incorrecto de los dientes entre cremallera y piñón
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Compruebe el par de rotación del eje de cremallera y piñón. 
<intxreftitleoff1 refid = "ASPAP70B6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Si es incorrecto, sustituya el conjunto de la caja de engranajes de dirección. 
<intxreftitleoff1 refid = "ASPAP70B6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
