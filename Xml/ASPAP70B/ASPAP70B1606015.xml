<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B1606015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del radiador
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B1606014">Inspección en el vehículo y limpieza del radiador</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70B1606015001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el conjunto del ventilador de refrigeración. 
<intxreftitleoff1 refid = "ASPAP70B1606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Extraiga el conjunto del condensador del A/C.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modelos con A/C manual: 
<intxreftitleoff1 refid = "ASPAP70B7226006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modelo con A/C automático: 
<intxreftitleoff1 refid = "ASPAP70B7236006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga la manguera de salida del radiador.
</ptxt>
</s1>
<s1>
<ptxt>
En modelos A/T, extraiga las mangueras de entrada y de salida del refrigerador del ATF del radiador.
</ptxt>
</s1>
<s1>
<ptxt>
Quite los soportes (1) superiores del radiador.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el radiador (2) del vehículo.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160007.jpg" width = "88.000mm" height = "62.569mm" ver = "01" gw = "193" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B1606015002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Rellene el sistema de refrigeración con refrigerante. 
<intxreftitleoff1 refid = "ASPAP70B1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verifique si el sistema de refrigeración tiene fugas. 
<intxreftitleoff1 refid = "ASPAP70B1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Para modelos A/T, rellene el transeje con ATF 
<intxreftitleoff1 refid = "ASPAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
En modelos A/T, compruebe si hay fugas de ATF.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
