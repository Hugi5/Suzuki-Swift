<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70BA314001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Comprobación del sistema de control del inmovilizador
</title>
<attention3>
<ptxt>
Antes de realizar la comprobación, asegúrese de leer 
<intxref refid = "ASPAP70BA310002">Medidas de precaución para el sistema del inmovilizador:Modelos con interruptor de encendido</intxref>
.
</ptxt>
</attention3>
<diag type = "test" id = "ASPAP70BA314001001">
<testgroup id = "ASPAP70BA314001002">
<question>
¿Gira el motor para arrancar?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70B1904001">Diagnóstico de síntomas del sistema de arranque</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA314001003">
<title>
Verificación del arranque del motor
</title>
<question>
¿Arranca el motor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA314001007">
<test1>
<ptxt>
Conecte la herramienta de escaneado SUZUKI al DLC.
</ptxt>
</test1>
<question>
¿La herramienta de escaneado SUZUKI permite la comunicación entre el ECM y el BCM?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70BA804001">Inspección de la comunicación CAN</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA314001004">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPAP70BA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se ha detectado algún DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
El sistema de control del inmovilizador está en buen estado.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA314001008">
<test1>
<ptxt>
Conecte la herramienta de escaneado SUZUKI al DLC.
</ptxt>
</test1>
<question>
¿La herramienta de escaneado SUZUKI permite la comunicación entre el ECM y el BCM?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70BA804001">Inspección de la comunicación CAN</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA314001005">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPAP70BA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se ha detectado algún DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 7.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA314001006">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Verifique los DTC relacionados con la comunicación CAN.
</ptxt>
</test1>
<question>
¿Se detecta algún DTC relacionado con la CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías del DTC de CAN.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70B1104009">Inspección básica del motor</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
