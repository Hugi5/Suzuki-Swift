<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B1306019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del sensor CKP
</title>
<servinfosub id = "ASPAP70B1306019001" page = "2">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Quite el generador. 
<intxreftitleoff1 refid = "ASPAP70B1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del sensor CKP.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el sensor CKP (1) del bloque de cilindros.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A131017.jpg" width = "88.000mm" height = "57.392mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</servinfosub>
<servinfosub id = "ASPAP70B1306019002" page = "2">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B1306020">Inspección del sensor CKP</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Aplique aceite de motor a las juntas tóricas del sensor.
</ptxt>
</item>
<item>
<ptxt>
Apriete el perno del sensor CKP al par de apriete especificado.
</ptxt>
<attention2>
<ptxt>
Asegúrese de emplear tornillos nuevos con prerrevestimiento adhesivo. De lo contrario, los pernos podrían aflojarse.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T1C007">
<t-part>
Perno del sensor CKP
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131008.jpg" width = "88.000mm" height = "57.393mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</item>
<item>
<ptxt>
Conecte el conector y fije el mazo de cables firmemente con las abrazaderas.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
