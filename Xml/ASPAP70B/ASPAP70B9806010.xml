<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B9806010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la alfombra del piso
</title>
<servinfosub id = "ASPAP70B9806010001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el asiento.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Asiento delantero: 
<intxreftitleoff1 refid = "ASPAP70B9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Asiento trasero: 
<intxreftitleoff1 refid = "ASPAP70B9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga las siguientes placas protectoras y embellecedores. 
<intxreftitleoff1 refid = "ASPAP70B9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Placas protectoras delanteras interiores del umbral lateral
</ptxt>
</item>
<item>
<ptxt>
Placas protectoras traseras interiores del umbral lateral
</ptxt>
</item>
<item>
<ptxt>
Embellecedores laterales del salpicadero
</ptxt>
</item>
<item>
<ptxt>
Embellecedores inferiores del pilar central
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga la caja delantera/caja trasera de la consola central. 
<intxreftitleoff1 refid = "ASPAP70B9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta de la junta de dirección. 
<intxreftitleoff1 refid = "ASPAP70B6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los 5 clips (1) y el tope del pedal del acelerador (2) y, a continuación, extraiga la alfombra del piso (3).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A980007.jpg" width = "88.000mm" height = "60.725mm" ver = "02" gw = "238" gh = "156"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Parte delantera del vehículo
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
<servinfosub id = "ASPAP70B9806010002">
<title>
Instalación
</title>
<ptxt>
Para la instalación, invierta el procedimiento anterior de desmontaje, teniendo en consideración los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete los pernos de montaje de los asientos al par especificado.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Asiento delantero: 
<intxreftitleoff1 refid = "ASPAP70B9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Asiento trasero: 
<intxreftitleoff1 refid = "ASPAP70B9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
