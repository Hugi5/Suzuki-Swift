<servinfosub id = "ASPAP70BA204010002">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70BA204010003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70BA204010004">
<testgroup id = "ASPAP70BA204010005">
<title>
Nueva comprobación del DTC.
</title>
<test1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el cable negativo (–) a la batería.
</ptxt>
</test1>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70BA204010002">Procedimiento de confirmación del DTC</intxref>
 y vuelva a comprobar el DTC.
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1120?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el BCM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70BA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección.
</ptxt>
</action>
</testgroup>
