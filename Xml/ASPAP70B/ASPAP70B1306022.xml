<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B1306022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del sensor de detonación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B1306021">Inspección en el vehículo del sensor de detonación</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70B1306022001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el colector de admisión. 
<intxreftitleoff1 refid = "ASPAP70B1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del sensor de detonación.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el sensor de detonación (1) del bloque de cilindros.
</ptxt>
<figure>
<graphic graphicname = "IAP70B130003.jpg" width = "88.000mm" height = "58.917mm" ver = "02" gw = "185" gh = "150"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B1306022002">
<title>
Instalación
</title>
<ptxt>
Para la instalación, invierta el procedimiento anterior de desmontaje, teniendo en consideración los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete el perno del sensor de detonación (1) al par de apriete especificado.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1C008">
<t-part>
Perno del sensor de detonación
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70B130004.jpg" width = "88.000mm" height = "49.420mm" ver = "02" gw = "241" gh = "124"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
0 – 45&#176;
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
