<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Desgaste excesivo del neumático
</title>
<diag type = "condition">
<condition>
<ptxt>
Desgaste excesivo del neumático
</ptxt>
</condition>
<ps>
<ptxt>
Muelles helicoidales rotos o hundidos
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Reemplace los muelles helicoidales.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Parte delantera: 
<intxreftitleoff1 refid = "ASPAP70B2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Parte trasera: 
<intxreftitleoff1 refid = "ASPAP70B2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Rueda desequilibrada
</ptxt>
</ps>
<action>
<ptxt>
Ajuste el equilibrado o reemplace el neumático.
</ptxt>
</action>
<ps>
<ptxt>
Alineación de las ruedas desajustada
</ptxt>
</ps>
<action>
<ptxt>
Compruebe y ajuste la alineación de las ruedas. 
<intxreftitleoff1 refid = "ASPAP70B2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Conjunto del puntal delantero defectuoso (amortiguador)
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el conjunto del puntal delantero (amortiguador). 
<intxreftitleoff1 refid = "ASPAP70B2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Conducción difícil
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la carga.
</ptxt>
</action>
<ps>
<ptxt>
Vehículo sobrecargado
</ptxt>
</ps>
<action>
<ptxt>
Reemplace los neumáticos. 
<intxreftitleoff1 refid = "ASPAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neumáticos sin rotar
</ptxt>
</ps>
<action>
<ptxt>
Reemplace o rote los neumáticos.
</ptxt>
</action>
<ps>
<ptxt>
Cojinete de rueda desgastado o flojo
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el cojinete de la rueda. 
<intxreftitleoff1 refid = "ASPAP70B3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
La rueda o el neumático tiembla
</ptxt>
</ps>
<action>
<ptxt>
Reemplace la rueda o el neumático.
</ptxt>
</action>
<ps>
<ptxt>
Los neumáticos no están inflados correctamente
</ptxt>
</ps>
<action>
<ptxt>
Ajuste la presión de inflado de los neumáticos.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
