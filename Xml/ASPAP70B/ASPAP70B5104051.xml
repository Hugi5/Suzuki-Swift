<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B5104051" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
 La luz de advertencia de la transmisión permanece encendida con el encendido en &#34;ON&#34; (modelos no Euro-OBD)
</title>
<servinfosub id = "ASPAP70B5104051001">
<title>
Localización y reparación de averías
</title>
<diag type = "test" id = "ASPAP70B5104051002">
<testgroup id = "ASPAP70B5104051003">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPAP70B5104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Aparece algún DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Reemplace un juego de instrumentos en buen estado y vuelva a realizar la comprobación del funcionamiento de la luz de advertencia de la transmisión. 
<intxreftitleoff1 refid = "ASPAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Si la luz de advertencia de la transmisión permanece encendida, reemplace un módulo de TCM en buen estado y vuelva a realizar la comprobación del funcionamiento de la luz de advertencia de la transmisión. 
<intxreftitleoff1 refid = "ASPAP70B5106030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
