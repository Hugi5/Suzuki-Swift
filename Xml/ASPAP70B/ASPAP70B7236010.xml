<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "3">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B7236010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del Panel del A/C automático
</title>
<servinfosub id = "ASPAP70B7236010001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la caja delantera de la consola del suelo. 
<intxreftitleoff1 refid = "ASPAP70B9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el tablero de instrumentos y la rejilla de ventilación central. 
<intxreftitleoff1 refid = "ASPAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la unidad de sonido o la cubierta del orificio de radio. 
<intxreftitleoff1 refid = "ASPAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el módulo (inflador) del airbag del pasajero. 
<intxreftitleoff1 refid = "ASPAP70B8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las cubiertas laterales centrales. 
<intxreftitleoff1 refid = "ASPAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el panel del A/C automático (1) del panel de instrumentos.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723013.swf" width = "88.000mm" height = "64.865mm" ver = "03" gw = "233" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte el conector del panel del A/C automático.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B7236010002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
