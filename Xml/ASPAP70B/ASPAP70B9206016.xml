<servinfo servinfosgmlid = "ASPAP70B9206016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Instalación y extracción del interruptor de luz de intermitente de emergencia
</title>
<servinfosub id = "ASPAP70B9206016001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga la persiana de ventilación central (1). 
<intxreftitleoff1 refid = "ASPAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector y extraiga el interruptor de luz de intermitente de emergencia (2) de la caja superior central soltando los cierres (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A920023.jpg" width = "88.000mm" height = "65.260mm" ver = "01" gw = "181" gh = "168"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B9206016002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B9206017">Inspección del interruptor de luz de intermitente de emergencia</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
