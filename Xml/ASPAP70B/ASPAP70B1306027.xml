<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B1306027" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Inspección de la OCV
</title>
<list1 type = "unordered">
<item>
<ptxt>
Extraiga la OCV. 
<intxreftitleoff1 refid = "ASPAP70B1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Inspeccione la OCV del siguiente modo.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Compruebe la resistencia entre los terminales del conector OCV (1).
</ptxt>
<ptxt>
Si el resultado de la comprobación no es satisfactorio, sustituya la OCV.
</ptxt>
<spec>
<title>
Resistencia de la OCV
</title>
<ptxt>
6,7 a 7,7 &#937; a 20&#176; C (68&#176;F) 
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9T401132006.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "180" gh = "153"/>
</figure>
</item>
<item>
<ptxt>
Conecte la batería al conector de OCV (1) como se muestra en la imagen y verifique el sonido de funcionamiento emitido por un momento por la válvula de carrete (2).
</ptxt>
<figure>
<graphic graphicname = "I9T401132007.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "193" gh = "153"/>
</figure>
</item>
</list2>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
