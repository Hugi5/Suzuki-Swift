<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B5106061" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Desmontaje y montaje del alojamiento del convertidor de par
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B5106037">Desmontaje del conjunto de la A/T</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASPAP70B5106064">Montaje del conjunto de la A/T</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASPAP70B5106035">Componentes del conjunto de A/T</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70B5106061001">
<title>
Desmontaje
</title>
<s1>
<ptxt>
Extraiga la placa (1) del depósito de líquido y la abrazadera (2) del tubo de lubricación.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510236.swf" width = "88.000mm" height = "50.111mm" ver = "01" gw = "171" gh = "125"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga los tubos de lubricación izquierdo (1) y derecho (2).
</ptxt>
<attention3>
<ptxt>
No doble en exceso el tubo de lubricación.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I2RH0B510237.swf" width = "88.000mm" height = "48.714mm" ver = "01" gw = "187" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el sello de aceite lateral (1) del diferencial empleando un destornillador de punta plana o una herramienta semejante.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510084.swf" width = "88.000mm" height = "49.137mm" ver = "01" gw = "132" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga la copa del cojinete derecho del contraeje con las herramientas especiales.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A053">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944-96011
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A054">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942-15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B510239.swf" width = "88.000mm" height = "47.571mm" ver = "01" gw = "161" gh = "118"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga la copa del cojinete lateral derecho del diferencial utilizando herramientas especiales.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A055">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944-96011
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A056">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942-15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B510240.swf" width = "88.000mm" height = "47.190mm" ver = "01" gw = "147" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga los tapones del alojamiento del convertidor de par (1).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510241.swf" width = "88.000mm" height = "49.011mm" ver = "01" gw = "189" gh = "122"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B5106061002">
<title>
Montaje
</title>
<s1>
<ptxt>
Tras aplicar ATF a los anillos en O nuevos, instálelos en los tapones del alojamiento. Luego, instale los tapones en el alojamiento del convertidor de par.
</ptxt>
<torque>
<torqueitem id = "T5A019">
<t-part>
Tapón del alojamiento del convertidor de par
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,5
</t-value1>
<t-value2>
0,76
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I2RH0B510242.swf" width = "88.000mm" height = "48.884mm" ver = "01" gw = "184" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Con las herramientas especiales, instale la nueva copa del cojinete lateral derecho del diferencial.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A057">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A058">
<s-part>
(B)
</s-part>
<s-number num = "09944-88220">
09944-88220
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I3RM0B510063.swf" width = "88.000mm" height = "44.895mm" ver = "01" gw = "134" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Con la herramienta especial, instale la nueva copa del cojinete derecho del contraeje.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A059">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A060">
<s-part>
(B)
</s-part>
<s-number num = "09944-88220">
09944-88220
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I3RM0B510064.swf" width = "88.000mm" height = "47.694mm" ver = "01" gw = "145" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Utilice herramientas especiales para instalar un nuevo sello de aceite lateral del diferencial en el alojamiento del convertidor de par en la posición especificada uniformemente, tal como se muestra en la ilustración.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A061">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A062">
<s-part>
(B)
</s-part>
<s-number num = "09944-88220">
09944-88220
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Profundidad de instalación del sello de aceite lateral del diferencial
</title>
<ptxt>
&#34;a&#34;: 2,6 – 3,6 mm (0,11 – 0,14 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Aplique grasa al borde del sello de aceite.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease C" id = "M5A004" uid = "23">
<m-part>
</m-part>
<m-desc>
Grasa
</m-desc>
<m-number>
99000-25030
</m-number>
<m-name>
SUZUKI Super Grease C
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A510079.swf" width = "88.000mm" height = "75.173mm" ver = "01" gw = "132" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Instale los tubos de lubricación izquierdo (1) y derecho (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510237.swf" width = "88.000mm" height = "48.714mm" ver = "01" gw = "187" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Instale la placa del depósito de líquido (1) y la abrazadera del tubo de lubricación (2) apretando sus pernos de montaje al par especificado.
</ptxt>
<torque>
<torqueitem id = "T5A020">
<t-part>
Perno de la abrazadera del tubo de lubricación
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
<torqueitem id = "T5A021">
<t-part>
Perno de la placa del depósito de líquido
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I2RH0B510246.swf" width = "88.000mm" height = "50.365mm" ver = "01" gw = "183" gh = "126"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
