<section sectnbr = "6B">
<servcat sctnbr = "06" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B6206018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
 Instalación y extracción del encendido (modelos con interruptor de encendido)
</title>
<servinfosub id = "ASPAP70B6206018001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta inferior y la cubierta superior de la columna de dirección. 
<intxreftitleoff1 refid = "ASPAP70B6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verifique si ha quitado la llave de contacto.
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del interruptor de encendido (2).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los tornillos (4), luego extraiga el interruptor de encendido (2) del bloqueo de la dirección (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A620036.jpg" width = "88.000mm" height = "54.155mm" ver = "05" gw = "237" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B6206018002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B6206019">Inspección del interruptor de encendido (modelos con encendido)</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
