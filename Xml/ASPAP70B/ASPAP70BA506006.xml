<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70BA506006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la antena exterior trasera
</title>
<servinfosub id = "ASPAP70BA506006001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el parachoques trasero. 
<intxreftitleoff1 refid = "ASPAP70B9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) y, a continuación, extraiga la antena exterior trasera (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50025.swf" width = "88.000mm" height = "54.582mm" ver = "01" gw = "176" gh = "138"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70BA506006002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70BA506010">Inspección de la antena</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
