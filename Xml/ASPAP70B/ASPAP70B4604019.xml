<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B4604019" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1024
</title>
<servinfosub id = "ASPAP70B4604019001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.328in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.861in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1024: Rendimiento del circuito del sensor del ángulo de dirección
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
La CPU del sensor del ángulo de dirección detecta un defecto interno.
</ptxt>
</item>
<item>
<ptxt>
La señal del sensor del ángulo de la dirección está fuera de los márgenes especificados.
</ptxt>
</item>
<item>
<ptxt>
La señal del sensor del ángulo de dirección no cambia aunque el vehículo gire a la derecha o a la izquierda.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Sensor del ángulo de dirección
</ptxt>
</item>
<item>
<ptxt>
Módulo de control ESP<sup>&#174;</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70B4604019002">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<attention2>
<ptxt>
La detección del DTC C1024 y C1075 significa una avería interna del sensor del ángulo de dirección. Reemplace el sensor del ángulo de la dirección. 
<intxreftitleoff1 refid = "ASPAP70B6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention2>
<diag type = "test" id = "ASPAP70B4604019003">
<testgroup id = "ASPAP70B4604019004">
<question>
¿Se ha llevado a cabo el procedimiento de &#34;Inspección del sistema ESP<sup>&#174;</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70B4604001">Comprobación del sistema del ESP&#174;</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604019005">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70B4604005">Comprobación del DTC</intxref>
.
</ptxt>
</test1>
<question>
¿Se ha detectado el DTC U0073 y/o U0126?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización de averías del DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604019006">
<question>
¿Se han detectado el DTC C1024 y C1075?
</question>
<result type = "yes"/>
<action>
<ptxt>
Reemplace el sensor del ángulo de la dirección. 
<intxreftitleoff1 refid = "ASPAP70B6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604019007">
<title>
Inspección en el vehículo del sensor del ángulo de dirección
</title>
<test1>
<ptxt>
Inspeccione el sensor del ángulo de dirección. 
<intxreftitleoff1 refid = "ASPAP70B4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70B4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Reemplace el sensor del ángulo de la dirección. 
<intxreftitleoff1 refid = "ASPAP70B4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
