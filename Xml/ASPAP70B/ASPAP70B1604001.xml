<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B1604001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnóstico de síntomas del refrigerante del motor
</title>
<diag type = "condition" id = "ASPAP70B1604001001">
<condition>
<ptxt>
El motor se recalienta (el ventilador del radiador funciona)
</ptxt>
</condition>
<ps>
<ptxt>
Correa de la bomba de agua floja o rota
</ptxt>
</ps>
<action>
<ptxt>
Ajuste o sustituya la correa de la bomba de agua. 
<intxreftitleoff1 refid = "ASPAP70B1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
No hay suficiente refrigerante
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el nivel del refrigerante y añada más si es necesario. 
<intxreftitleoff1 refid = "ASPAP70B1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Termostato defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el conjunto del termostato. 
<intxreftitleoff1 refid = "ASPAP70B1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Bomba de agua defectuosa
</ptxt>
</ps>
<action>
<ptxt>
Sustituya la bomba de agua. 
<intxreftitleoff1 refid = "ASPAP70B1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Aletas del radiador sucias o dobladas
</ptxt>
</ps>
<action>
<ptxt>
Limpie o repare. 
<intxreftitleoff1 refid = "ASPAP70B1606014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fugas de refrigerante en el sistema de refrigeración
</ptxt>
</ps>
<action>
<ptxt>
Verifique si el sistema de refrigeración tiene fugas. 
<intxreftitleoff1 refid = "ASPAP70B1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radiador obstruido
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el radiador. 
<intxreftitleoff1 refid = "ASPAP70B1606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Tapón del radiador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el tapón del radiador. 
<intxreftitleoff1 refid = "ASPAP70B1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Arrastre de los frenos
</ptxt>
</ps>
<action>
<ptxt>
Compruebe los frenos. 
<intxreftitleoff1 refid = "ASPAP70B4104001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Embrague resbaladizo
</ptxt>
</ps>
<action>
<ptxt>
Verifique el embrague. 
<intxreftitleoff1 refid = "ASPAP70B5304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Batería descargada
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione la batería. 
<intxreftitleoff1 refid = "ASPAP70B1A04001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Generación deficiente de electricidad por parte del generador
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el generador. 
<intxreftitleoff1 refid = "ASPAP70B1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensor ECT defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el sensor ECT. 
<intxreftitleoff1 refid = "ASPAP70B1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motor del ventilador de refrigeración del radiador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el motor del ventilador de refrigeración del radiador. 
<intxreftitleoff1 refid = "ASPAP70B1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ECM defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Verifique el ECM y su circuito. 
<intxreftitleoff1 refid = "ASPAP70B1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Relé del ventilador de refrigeración del radiador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el relé del ventilador de refrigeración del radiador. 
<intxreftitleoff1 refid = "ASPAP70B1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado.
</ptxt>
</action>
<ps>
<ptxt>
Demasiados depósitos eléctricos opcionales
</ptxt>
</ps>
<action>
<ptxt>
Extraiga los depósitos eléctricos.
</ptxt>
</action>
<condition>
<ptxt>
El motor se recalienta (el ventilador del radiador no funciona)
</ptxt>
</condition>
<ps>
<ptxt>
Fusible fundido
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el fusible.
</ptxt>
</action>
<ps>
<ptxt>
Relé del ventilador de refrigeración del radiador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el relé del ventilador de refrigeración del radiador. 
<intxreftitleoff1 refid = "ASPAP70B1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensor ECT defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el sensor ECT. 
<intxreftitleoff1 refid = "ASPAP70B1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motor del ventilador de refrigeración del radiador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el motor del ventilador de refrigeración del radiador. 
<intxreftitleoff1 refid = "ASPAP70B1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado.
</ptxt>
</action>
<ps>
<ptxt>
ECM defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Verifique el ECM y su circuito. 
<intxreftitleoff1 refid = "ASPAP70B1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
