<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B5106012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del cable de selección
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B5106011">Componentes del cable de selección</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70B5106012001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable de selección del conjunto de la palanca selectora y, a continuación, despréndalo del soporte. 
<intxreftitleoff1 refid = "ASPAP70B5106005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Retire el clip del cable de selección y desconecte el cable de selección de la palanca selectora manual.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el cable de selección del panel de salpicadero.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B5106012002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Aplique grasa al pasador y a la unión del cable. 
<intxreftitleoff1 refid = "ASPAP70B5106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Utilice clips nuevos.
</ptxt>
</item>
<item>
<ptxt>
Apriete los pernos y las tuercas al par especificado. 
<intxreftitleoff1 refid = "ASPAP70B5106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ajuste el cable de selección. 
<intxreftitleoff1 refid = "ASPAP70B5106013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
