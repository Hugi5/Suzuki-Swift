<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B1A06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del soporte del generador
</title>
<servinfosub id = "ASPAP70B1A06006001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta inferior del motor de la derecha.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la correa de transmisión del generador y de la bomba de agua. 
<intxreftitleoff1 refid = "ASPAP70B1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desmonte la polea de la bomba de agua (1). 
<intxreftitleoff1 refid = "ASPAP70B1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el perno del generador (2).
</ptxt>
</s1>
<s1>
<ptxt>
Retire el soporte (3) del generador.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1007.jpg" width = "88.000mm" height = "70.982mm" ver = "01" gw = "192" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B1A06006002">
<title>
Instalación
</title>
<ptxt>
Para la instalación, invierta el procedimiento anterior de desmontaje, teniendo en consideración los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Instale el soporte del generador siguiendo el procedimiento siguiente.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Coloque el soporte del generador (1).
</ptxt>
</item>
<item>
<ptxt>
Apriete un poco el perno del generador (2) de manera que quede flojo.
</ptxt>
</item>
<item>
<ptxt>
Apriete las tuercas (3) del soporte del generador al par especificado. 
<intxreftitleoff1 refid = "ASPAP70B1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
<figure>
<graphic graphicname = "I9P60A1A1016.swf" width = "88.000mm" height = "68.664mm" ver = "01" gw = "188" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
