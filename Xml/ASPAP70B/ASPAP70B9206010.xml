<servinfo servinfosgmlid = "ASPAP70B9206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
 Extracción e instalación de la luz personal (si el vehículo dispone de ella)
</title>
<servinfosub id = "ASPAP70B9206010001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga la luz personal (1) mientras libera los bloqueos (2).
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector de la luz personal.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920027.jpg" width = "88.000mm" height = "68.223mm" ver = "02" gw = "199" gh = "177"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el portalámparas (1) de la luz personal (2) y extraiga las bombillas.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920015.jpg" width = "88.000mm" height = "57.222mm" ver = "01" gw = "204" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B9206010002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
