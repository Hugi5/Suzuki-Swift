<servinfosub id = "ASPAP70B5106062001">
<title>
Desmontaje
</title>
<s1>
<ptxt>
Extraiga el sello de aceite lateral (1) del diferencial empleando un destornillador de punta plana o una herramienta semejante.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510085.swf" width = "88.000mm" height = "49.011mm" ver = "01" gw = "177" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga la copa del cojinete izquierdo del contraeje y su calce con las herramientas especiales.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A063">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944-96011
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A064">
<s-part>
