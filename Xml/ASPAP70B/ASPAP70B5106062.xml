</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B510248.swf" width = "88.000mm" height = "49.900mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga la copa del cojinete lateral izquierdo del diferencial y su calce con las herramientas especiales.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A065">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944-96011
</s-number>
