<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "3">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B7234A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
No sale aire frío (el embrague magnético no funciona)
</title>
<diag type = "condition">
<condition>
<ptxt>
No sale aire frío (el embrague magnético no funciona)
</ptxt>
</condition>
<ps>
<ptxt>
No hay refrigerante
</ptxt>
</ps>
<action>
<ptxt>
Efectúe la recuperación, vaciado y carga. 
<intxreftitleoff1 refid = "ASPAP70B7236001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fusible fundido
</ptxt>
</ps>
<action>
<ptxt>
Verifique si hay cortocircuito a masa en los fusibles relacionados.
</ptxt>
</action>
<ps>
<ptxt>
Interruptor de A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el interruptor de A/C. 
<intxreftitleoff1 refid = "ASPAP70B7234035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensor de temperatura del evaporador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el sensor de temperatura del evaporador. 
<intxreftitleoff1 refid = "ASPAP70B7236018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensor de presión del refrigerante del A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Examine el sensor de presión del refrigerante del A/C. 
<intxreftitleoff1 refid = "ASPAP70B7236021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado.
</ptxt>
</action>
<ps>
<ptxt>
Termostato defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el termostato. 
<intxreftitleoff1 refid = "ASPAP70B1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</action>
<ps>
<ptxt>
Sensor ECT defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el sensor ECT. 
<intxreftitleoff1 refid = "ASPAP70B1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ECM defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el ECM. 
<intxreftitleoff1 refid = "ASPAP70B7234036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Módulo de control HVAC defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el módulo de control HVAC. 
<intxreftitleoff1 refid = "ASPAP70B7234035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Embrague magnético defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el embrague magnético. 
<intxreftitleoff1 refid = "ASPAP70B7236046"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Correa de transmisión del compresor floja o rota
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la correa de transmisión del compresor. 
<intxreftitleoff1 refid = "ASPAP70B7236042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compresor del A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el compresor del A/C. 
<intxreftitleoff1 refid = "ASPAP70B7236047"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Relé del compresor del A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el relé del compresor del A/C. 
<intxreftitleoff1 refid = "ASPAP70B7236041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
BCM defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el BCM. 
<intxreftitleoff1 refid = "ASPAP70BA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Panel del A/C automático defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el panel del A/C automático. 
<intxreftitleoff1 refid = "ASPAP70B7234034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
