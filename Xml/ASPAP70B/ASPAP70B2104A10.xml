<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B2104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Neumáticos curvados
</title>
<diag type = "condition">
<condition>
<ptxt>
Neumáticos curvados
</ptxt>
</condition>
<ps>
<ptxt>
Alineación de las ruedas desajustada
</ptxt>
</ps>
<action>
<ptxt>
Compruebe y ajuste la alineación de las ruedas. 
<intxreftitleoff1 refid = "ASPAP70B2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Conjunto del puntal delantero defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el conjunto del puntal delantero. 
<intxreftitleoff1 refid = "ASPAP70B2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cojinetes de la rueda desgastados
</ptxt>
</ps>
<action>
<ptxt>
Reemplace los cojinetes de rueda. 
<intxreftitleoff1 refid = "ASPAP70B3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Descentramiento excesivo en el neumático o la rueda
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya la rueda o el neumático.
</ptxt>
</action>
<ps>
<ptxt>
Juntas del brazo de suspensión desgastadas
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el brazo de la suspensión. 
<intxreftitleoff1 refid = "ASPAP70B2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rueda desequilibrada
</ptxt>
</ps>
<action>
<ptxt>
Ajuste el equilibrado o reemplace el neumático.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
