<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70BA314010" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1644
</title>
<servinfosub id = "ASPAP70BA314010001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.166in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.039in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1644: El ID del inmovilizador no coincide
</emph>
</ptxt>
<ptxt>
Error de verificación entre el BCM y el ECM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Llave de contacto
</ptxt>
</item>
<item>
<ptxt>
El código ID del ECM no está registrado en el BCM.
</ptxt>
</item>
<item>
<ptxt>
La llave de encendido no está registrada
</ptxt>
</item>
<item>
<ptxt>
Conector/circuito del módulo de control del inmovilizador
</ptxt>
</item>
<item>
<ptxt>
Módulo de control del inmovilizador
</ptxt>
</item>
<item>
<ptxt>
Circuito a masa/alimentación eléctrica del BCM
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70BA314010002">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<attention3>
<ptxt>
Si el BCM ha sido registrado en otro vehículo (artículo utilizado), no podrá registrar las llaves de contacto. Instale siempre un BCM nuevo cuando la sustitución sea necesaria.
</ptxt>
</attention3>
<diag type = "test" id = "ASPAP70BA314010003">
<testgroup id = "ASPAP70BA314010004">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Compruebe el DTC del BCM. 
<intxreftitleoff1 refid = "ASPAP70BA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se detectan los DTC B1188, B1189 o B1190?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA314010005">
<title>
Verificación del circuito de alimentación y de masa del BCM
</title>
<test1>
<ptxt>
Inspeccione el circuito de alimentación eléctrica y de masa del BCM. 
<intxreftitleoff1 refid = "ASPAP70BA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está en buenas condiciones?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA314010006">
<title>
Registro del ECM
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70BA316003">Registro del ECM:Modelos con interruptor de encendido</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPAP70BA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC P1644?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (No se ha registrado el ECM)
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA314010007">
<title>
Registro de la llave de encendido
</title>
<test1>
<ptxt>
Realice el &#34;Registro de la llave del inmovilizador&#34;. 
<intxreftitleoff1 refid = "ASPAP70BA316002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</test1>
<test1>
<ptxt>
Vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPAP70BA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC P1644?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sustituya el ECM y vuelva a realizar la comprobación de DTC. Si todavía se detecta el DTC P1644, sustituya el BCM y vuelva a realizar la comprobación de DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "ASPAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "ASPAP70BA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (No se ha registrado la llave de encendido.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
