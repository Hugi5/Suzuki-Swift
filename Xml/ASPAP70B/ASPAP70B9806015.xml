<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B9806015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del deflector trasero
</title>
<servinfosub id = "ASPAP70B9806015001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte la manguera del lavador (1) y el conector del mazo de cables de la puerta del maletero (2).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las tapas interiores de la puerta trasera (3) y, a continuación, extraiga las tuercas (4).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las tapas del deflector de la puerta del maletero (5) y, a continuación, extraiga los pernos (6).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el deflector trasero (7).
</ptxt>
<figure>
<graphic graphicname = "IBP70A980005.swf" width = "88.000mm" height = "105.551mm" ver = "02" gw = "209" gh = "283"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B9806015002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Cuando vuelva a colocar el alerón trasero (1), asegúrese de sustituir la cinta adhesiva de doble cara (2) por cinta nueva.
</ptxt>
<figure>
<graphic graphicname = "IBP70A980006.swf" width = "88.000mm" height = "39.726mm" ver = "01" gw = "189" gh = "96"/>
</figure>
</item>
<item>
<ptxt>
Apriete los pernos y las tuercas del alerón del portón trasero al par de apriete especificado.
</ptxt>
<torque>
<torqueitem id = "T9H001">
<t-part>
Back door spoiler bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3.0
</t-value1>
<t-value2>
0.31
</t-value2>
<t-value3>
2.5
</t-value3>
</torqueitem>
<torqueitem id = "T9H002">
<t-part>
Back door spoiler nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A980007.swf" width = "88.000mm" height = "87.856mm" ver = "02" gw = "209" gh = "233"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
