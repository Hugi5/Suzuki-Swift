<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70BA504018" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1161 / B1163
</title>
<servinfosub id = "ASPAP70BA504018001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.802in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.388in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1161: Discrepancia en la información de la unidad de bloqueo de la dirección 
</emph>
</ptxt>
<ptxt>
Error de verificación entre el módulo de control de arranque sin llave y la unidad de bloqueo de la dirección.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Conector/circuito de la unidad de bloqueo de la dirección
</ptxt>
</item>
<item>
<ptxt>
Unidad de bloqueo de la dirección
</ptxt>
</item>
<item>
<ptxt>
Módulo de control de arranque sin llave
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1163: Unidad de bloqueo de la dirección sin registrar 
</emph>
</ptxt>
<ptxt>
No se ha registrado la unidad de bloqueo de la dirección.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70BA504018002">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Abra la puerta del conductor.
</ptxt>
</s1>
<s1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</s1>
<s1>
<ptxt>
Repita los pasos del 2) y 3) varias veces.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70BA504018003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70BA504018004">
<testgroup id = "ASPAP70BA504018005">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPAP70BA504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el encendido (posición “OFF”).
</ptxt>
</test1>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70BA504018002">Procedimiento de confirmación del DTC</intxref>
 y vuelva a comprobar el DTC.
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1161 o B1163?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (Avería intermitente.)
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70BA504018006">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Sustituya la unidad de bloqueo de la dirección. 
<intxreftitleoff1 refid = "ASPAP70B6206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70BA504018002">Procedimiento de confirmación del DTC</intxref>
 y vuelva a comprobar el DTC.
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1161 o B1163?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control de arranque sin llave y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70BA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (La unidad de bloqueo de la dirección estaba defectuosa.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
