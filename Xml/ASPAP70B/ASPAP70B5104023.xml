<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B5104023" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P062F / P1702
</title>
<servinfosub id = "ASPAP70B5104023001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.466in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.738in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P062F: Error de EEPROM del módulo de control interno 
</emph>
</ptxt>
<ptxt>
Fallo interno del TCM (error de EEPROM).
</ptxt>
<ptxt>
(Lógica de detección de 1 ciclos de conducción)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
TCM
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1702: Error en la suma de comprobación de la memoria del módulo de control interno
</emph>
</ptxt>
<ptxt>
Fallo interno del TCM (error de suma de comprobación).
</ptxt>
<ptxt>
(Lógica de detección de 1 ciclos de conducción)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70B5104023002">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B5104023003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70B5104023004">
<testgroup id = "ASPAP70B5104023005">
<question>
¿Se detecta el DTC P062F o P1702 después de efectuar el &#34;Procedimiento de confirmación de DTC&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el TCM por uno en buen estado y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70B5106030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Verifique los problemas intermitentes. 
<intxreftitleoff1 refid = "ASPAP70B0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
