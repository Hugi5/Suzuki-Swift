<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70BA206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del BMC
</title>
<servinfosub id = "ASPAP70BA206003001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desactive el sistema de airbag. 
<intxreftitleoff1 refid = "ASPAP70B8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta del orificio de la columna de dirección según las indicaciones del Paso 4) de la sección 
<intxref refid = "ASPAP70B6206009">Extracción e instalación de la columna de dirección</intxref>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el embellecedor lateral del salpicadero. 
<intxreftitleoff1 refid = "ASPAP70B9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte los conectores (1) y las abrazaderas del bloque de conexiones (2).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las tuercas (3) y, a continuación, el bloque de conexiones.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20016.jpg" width = "88.000mm" height = "78.207mm" ver = "01" gw = "202" gh = "205"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte los conectores (1) del BCM (2).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las tuercas (3) y, a continuación, el BCM.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20017.jpg" width = "88.000mm" height = "82.962mm" ver = "01" gw = "198" gh = "219"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70BA206003002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.	
</ptxt>
</servinfosub>
<list1 type = "unordered">
<item>
<ptxt>
Apriete las tuercas del BCM al par especificado.
</ptxt>
<torque>
<torqueitem id = "T10B001">
<t-part>
Tuerca del BCM
</t-part>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Active el sistema de airbag. 
<intxreftitleoff1 refid = "ASPAP70B8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Si el BCM es sustituido, siga las indicaciones de la sección 
<intxref refid = "ASPAP70BA206002">Registro del BCM (modelos con interruptor de encendido)</intxref>
 .
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
