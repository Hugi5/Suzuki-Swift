<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B7224A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Sólo sale aire frío a alta velocidad
</title>
<diag type = "condition">
<condition>
<ptxt>
Sólo sale aire frío a alta velocidad
</ptxt>
</condition>
<ps>
<ptxt>
Condensador obstruido
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el condensador. 
<intxreftitleoff1 refid = "ASPAP70B7226005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Carga insuficiente del refrigerante
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el nivel de refrigerante y si hay fugas en el sistema.
</ptxt>
</action>
<ps>
<ptxt>
Aire en el sistema de A/C
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el condensador y, a continuación, realice la evacuación y la carga de refrigerante. 
<intxreftitleoff1 refid = "ASPAP70B7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Correa de transmisión del compresor floja
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la correa de transmisión del compresor. 
<intxreftitleoff1 refid = "ASPAP70B7226035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compresor del A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el compresor del A/C.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
