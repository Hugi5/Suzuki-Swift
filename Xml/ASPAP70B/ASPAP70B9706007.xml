<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B9706007" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de los asientos traseros
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B9706006">Componentes del asiento trasero</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70B9706007001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el conjunto del cojín del asiento trasero. 
<intxreftitleoff1 refid = "ASPAP70B9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los conjuntos de respaldos traseros sacando los pernos de la bisagra del asiento trasero. 
<intxreftitleoff1 refid = "ASPAP70B9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desmonte y repare el asiento trasero si es necesario. 
<intxreftitleoff1 refid = "ASPAP70B9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B9706007002">
<title>
Instalación
</title>
<ptxt>
Para la instalación, invierta el procedimiento anterior de desmontaje, teniendo en consideración los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Consulte el par de apriete en 
<intxref refid = "ASPAP70B9706006">Componentes del asiento trasero</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
