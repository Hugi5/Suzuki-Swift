<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B4104A12" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La luz de advertencia del ESP no se coloca en ON después de colocar el encendido en posición &#34;ON&#34;
</title>
<diag type = "condition">
<condition>
<ptxt>
La luz de advertencia del ESP no se coloca en ON después de colocar el encendido en posición &#34;ON&#34;
</ptxt>
</condition>
<ps>
<ptxt>
Circuito de alimentación eléctrica y de a masa del juego de instrumentos defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el juego de instrumentos y su circuito. 
<intxreftitleoff1 refid = "ASPAP70B9304017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Juego de instrumentos defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el juego de instrumentos. 
<intxreftitleoff1 refid = "ASPAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Avería del sistema de comunicación CAN
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el sistema de comunicación CAN. 
<intxreftitleoff1 refid = "ASPAP70BA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fusible fundido
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el fusible &#34;MTR&#34; y el circuito que conduce al fusible &#34;MTR&#34; y sustitúyalo si es necesario.
</ptxt>
</action>
<ps>
<ptxt>
Módulo de control ESP<sup>&#174;</sup> defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el módulo de control de ESP<sup>&#174;</sup>. 
<intxreftitleoff1 refid = "ASPAP70B4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
