<servinfosub id = "ASPAP70B1104044003">
<title>
Procedimiento de confirmación del DTC
</title>
<topic id = "ASPAP70B1104044004">
<title>
P0560: 
</title>
<s1>
<ptxt>
Conecte el encendido (posición “ON”) durante 1 min.
</ptxt>
</s1>
</topic>
<topic id = "ASPAP70B1104044005">
<title>
P0562 / P0563: 
</title>
<s1>
<ptxt>
Haga funcionar el motor a 2.500 rpm o más durante 1 min.
</ptxt>
</s1>
</topic>
</servinfosub>
<servinfosub id = "ASPAP70B1104044006">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70B1104044007">
<testgroup id = "ASPAP70B1104044008">
<question>
¿Se ha realizado la &#34;Inspección del sistema de control del motor y de las emisiones&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70B1104001">Inspección del sistema de control del motor y de las emisiones</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B1104044009">
<title>
Verificación del circuito de masa y de la alimentación del ECM
</title>
<test1>
<ptxt>
Compruebe los circuitos de alimentación eléctrica y el circuito de masa del ECM. 
<intxreftitleoff1 refid = "ASPAP70B1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el ECM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare el circuito de alimentación eléctrica y/o de masa del ECM.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
