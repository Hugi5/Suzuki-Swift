</title>
<servinfosub id = "ASPAP70B6304014001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.495in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.674in"/>
<thead>
