<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B5206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del interruptor de luz de marcha atrás
</title>
<servinfosub id = "ASPAP70B5206007001">
<title>
Extracción
</title>
<s1 page = "2">
<ptxt>
Extraiga el ECM de la bandeja de la batería. 
<intxreftitleoff1 refid = "ASPAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la batería y su bandeja. 
<intxreftitleoff1 refid = "ASPAP70B1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del interruptor de las luces de marcha atrás.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el interruptor de la luz de marcha atrás (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70B520005.jpg" width = "88.000mm" height = "55.911mm" ver = "01" gw = "199" gh = "142"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B5206007002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B5206008">Inspección del interruptor de luz de marcha atrás</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Aplique aceite al anillo en O nuevo (1) y apriete el interruptor (2) de las luces de marcha atrás al par de apriete especificado.
</ptxt>
<torque>
<torqueitem id = "T5B004">
<t-part>
Interruptor de luz de marcha atrás
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I3RH0A520006.swf" width = "88.000mm" height = "31.317mm" ver = "01" gw = "148" gh = "73"/>
</figure>
</s1>
<s1>
<ptxt>
Conecte el conector del interruptor de las luces de marcha atrás.
</ptxt>
</s1>
<s1>
<ptxt>
Instale la bandeja de la batería y la la batería. 
<intxreftitleoff1 refid = "ASPAP70B1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Instale el ECM en la bandeja de la batería. 
<intxreftitleoff1 refid = "ASPAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
