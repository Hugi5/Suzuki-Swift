<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B5106028" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la válvula solenoide
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B5106027">Inspección en el vehículo de la válvula solenoide</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70B5106028001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Levante el vehículo.
</ptxt>
</s1>
<s1>
<ptxt>
Drene el líquido de A/T. 
<intxreftitleoff1 refid = "ASPAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Coloque el tapón de drenaje del ATF. 
<intxreftitleoff1 refid = "ASPAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del colador de aceite y el cárter de aceite de A/T. 
<intxreftitleoff1 refid = "ASPAP70B5106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el sensor de temperatura del ATF (1) de la abrazadera del sensor.
</ptxt>
</s1>
<s1>
<ptxt>
Desenchufe los conectores (2) de las válvulas solenoide.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A510027.swf" width = "88.000mm" height = "59.491mm" ver = "01" gw = "136" gh = "152"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga la válvula solenoide de cambio &#34;A&#34; (1), la válvula solenoide de cambio &#34;B&#34; (2) y la válvula solenoide de distribución (3); para ello, retire sus pernos.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A510028.swf" width = "88.000mm" height = "53.224mm" ver = "01" gw = "110" gh = "135"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del cuerpo de válvula. 
<intxreftitleoff1 refid = "ASPAP70B5106026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B5106028002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B5106029">Inspección de la válvula solenoide</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Instale las válvulas solenoides. 
<intxreftitleoff1 refid = "ASPAP70B5106059"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Instale el conjunto del cuerpo de válvula. 
<intxreftitleoff1 refid = "ASPAP70B5106026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Enchufe los conectores de los solenoides, cuyas posiciones de instalación se identifican por el color de los cables.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.367in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.092in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Acoplador de válvula solenoide
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Color del cable
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "left">
<ptxt>
Válvula solenoide de cambio &#34;A&#34; (2)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Blanco
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "left">
<ptxt>
Válvula solenoide de cambio &#34;B&#34; (3)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Negro
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "left">
<ptxt>
Válvula solenoide de distribución (1)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Amarillo
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "left">
<ptxt>
Válvula solenoide de control de presión del TCC (4)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Verde claro / Marrón
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Válvula solenoide de regulación de presión (5)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Verde / Gris
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</s1>
<s1>
<ptxt>
Instale el sensor de temperatura del ATF (6) y el cable del sensor en la abrazadera.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A510030.swf" width = "88.000mm" height = "59.798mm" ver = "01" gw = "140" gh = "153"/>
</figure>
</s1>
<s1>
<ptxt>
Instale el conjunto del colador de aceite y el cárter de aceite de A/T. 
<intxreftitleoff1 refid = "ASPAP70B5106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Baje el vehículo.
</ptxt>
</s1>
<s1>
<ptxt>
Rellene la cantidad adecuada de ATF especificado. 
<intxreftitleoff1 refid = "ASPAP70B5101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Compruebe el nivel del líquido. 
<intxreftitleoff1 refid = "ASPAP70B5106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
