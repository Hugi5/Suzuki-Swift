<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B4606017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del interruptor ESP&#174; OFF
</title>
<servinfosub id = "ASPAP70B4606017001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el bisel del interruptor con el interruptor del ESP<sup>&#174;</sup> OFF del panel de instrumentos. 
<intxreftitleoff1 refid = "ASPAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del interruptor ESP<sup>&#174;</sup> OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el interruptor ESP<sup>&#174;</sup> OFF (1) del bisel del interruptor.
</ptxt>
<figure>
<graphic graphicname = "IAP70B460006.swf" width = "88.000mm" height = "39.750mm" ver = "01" gw = "134" gh = "96"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B4606017002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B4606018">Inspección del interruptor ESP&#174; OFF</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
