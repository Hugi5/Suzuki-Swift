Modelo con ESP<sup>&#174;</sup>: 
<intxreftitleoff1 refid = "ASPAP70B4604039"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Juego de instrumentos defectuoso
</ptxt>
</ps>
<action>
