<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del generador
</title>
<servinfosub id = "ASPAP70B1A06005001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta inferior del motor de la derecha.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el tubo n&#176; 1 de escape. 
<intxreftitleoff1 refid = "ASPAP70B1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la correa de transmisión del generador y de la bomba de agua. 
<intxreftitleoff1 refid = "ASPAP70B1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el cable del terminal &#34;B&#34; (1) y el conector (2) del generador (3).
</ptxt>
</s1>
<s1>
<ptxt>
Retire el generador (3) y extráigalo del compartimiento del motor entre el miembro de la suspensión delantera y el conjunto del eje propulsor delantero.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1005.jpg" width = "88.000mm" height = "66.800mm" ver = "01" gw = "237" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B1A06005002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete el perno del generador y el perno del pivote del generador al par especificado.
</ptxt>
<torque>
<torqueitem id = "T1J003">
<t-part>
Perno de generador
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1J004">
<t-part>
Perno de pivote del generador
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Conecte el cable (1) al generador tal y como se muestra en la ilustración y, a continuación, apriete la tuerca del terminal &#34;B&#34; al par especificado.
</ptxt>
<torque>
<torqueitem id = "T1J005">
<t-part>
Tuerca del terminal &#34;B&#34;
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1A1006.jpg" width = "88.000mm" height = "61.151mm" ver = "02" gw = "237" gh = "157"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
