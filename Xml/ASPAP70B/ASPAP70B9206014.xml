<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B9206014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del interruptor de la señal de giro y de iluminación
</title>
<servinfosub id = "ASPAP70B9206014001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga la cubierta de la columna de la dirección. 
<intxreftitleoff1 refid = "ASPAP70B6206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del interruptor de la señal de giro y de iluminación (3).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el interruptor de la señal de giro y de iluminación (1) de la columna de dirección mientras presiona la garra (2) en la dirección de la flecha.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920007.jpg" width = "88.000mm" height = "84.623mm" ver = "01" gw = "203" gh = "223"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B9206014002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B9206015">Revisión del interruptor de la señal de giro y de iluminación</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
