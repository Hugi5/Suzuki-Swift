<servinfosub id = "ASPAP70B4604023003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70B4604023004">
<testgroup id = "ASPAP70B4604023005">
<question>
¿Se ha llevado a cabo el procedimiento de &#34;Inspección del sistema ESP<sup>&#174;</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70B4604001">Comprobación del sistema del ESP&#174;</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604023006">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70B4604005">Comprobación del DTC</intxref>
.
</ptxt>
</test1>
<question>
¿Existe algún DTC distinto de C1037, C1038 y C1057?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización de averías del DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604023007">
<title>
Comprobación de DTC para BCM
</title>
<test1>
<ptxt>
Compruebe los DTC para el BCM. 
<intxreftitleoff1 refid = "ASPAP70BA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se ha detectado el DTC U0073, U0121 y/o U0126?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización de averías del DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604023008">
<title>
Inspección del fusible
</title>
<test1>
<ptxt>
Inspeccione el fusible &#34;ABS&#34;.
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el fusible y verifique si se ha producido un cortocircuito a masa.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604023009">
<title>
Comprobación del circuito de alimentación eléctrica del sensor del ángulo de dirección
</title>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el conector del sensor de ángulo de la dirección.
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el conector &#34;G33&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe si la conexión con el sensor del ángulo de dirección es correcta.
</ptxt>
</test1>
<test1>
<ptxt>
Si la conexión es correcta, conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</test1>
<test1>
<ptxt>
Mida la tensión entre el circuito &#34;A1&#34; y la conexión a masa.
</ptxt>
</test1>
<question>
¿Es el valor 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el circuito &#34;A1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604023010">
<title>
Comprobación del circuito de masa del sensor del ángulo de dirección
</title>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</test1>
<test1>
<ptxt>
Mida la resistencia entre el circuito &#34;A2&#34; y la conexión a masa.
</ptxt>
</test1>
<question>
¿Es inferior a 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el circuito &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604023011">
<title>
Comprobación del sensor del ángulo de dirección
</title>
<test1>
<ptxt>
Conecte el conector del sensor de ángulo de dirección.
</ptxt>
</test1>
<test1>
<ptxt>
Inspeccione el sensor del ángulo de dirección. 
<intxreftitleoff1 refid = "ASPAP70B4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70B4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el sensor del ángulo de dirección y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70B4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
