<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B7216007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la unidad de HVAC
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B7216006">Componentes de la unidad de HVAC:Sin A/C</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70B7216007001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desactive el sistema de airbag. 
<intxreftitleoff1 refid = "ASPAP70B8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Drene el refrigerante del motor. 
<intxreftitleoff1 refid = "ASPAP70B1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
A continuación, desconecte las mangueras del calentador de la unidad de HVAC.
</ptxt>
</s1>
<s1>
<ptxt>
Retire el panel de instrumentos de la carrocería del vehículo. 
<intxreftitleoff1 refid = "ASPAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la unidad de HVAC (1) de la carrocería del vehículo quitando las tuercas (2).
</ptxt>
<attention3>
<ptxt>
Al retirar la unidad de HVAC, procure no derramar el refrigerante del motor en el suelo del vehículo.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A721012.swf" width = "88.000mm" height = "80.484mm" ver = "01" gw = "229" gh = "212"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B7216007002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Rellene el sistema de refrigeración con refrigerante. 
<intxreftitleoff1 refid = "ASPAP70B1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ajuste los cables de control. 
<intxreftitleoff1 refid = "ASPAP70B7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
