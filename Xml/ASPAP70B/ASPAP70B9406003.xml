<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B9406003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del motor de limpiaparabrisas
</title>
<servinfosub id = "ASPAP70B9406003001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga los sombreretes (1) del pivote y las tuercas (2) del brazo del limpiaparabrisas y extraiga los brazos (3) del limpiaparabrisas.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el embellecedor (4) superior del cubretableros. 
<intxreftitleoff1 refid = "ASPAP70B9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "IAP70B940019.jpg" width = "88.000mm" height = "60.102mm" ver = "01" gw = "199" gh = "154"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte el conector del motor de limpiaparabrisas (3).
</ptxt>
</s1>
<s1>
<ptxt>
Quite los pernos del motor de limpiaparabrisas (1) y extraiga dicho motor (2) en la dirección que indica la flecha de la ilustración.
</ptxt>
<figure>
<graphic graphicname = "I9P60A940006.jpg" width = "88.000mm" height = "41.842mm" ver = "01" gw = "217" gh = "102"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B9406003002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B9406004">Inspección del funcionamiento del motor del limpiaparabrisas</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete los pernos del motor de limpiaparabrisas en orden numérico (del &#34;1&#34; al &#34;2&#34;) al par de apriete especificado.
</ptxt>
<torque>
<torqueitem id = "T9D002">
<t-part>
Perno del motor de limpiaparabrisas
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A940007.jpg" width = "88.000mm" height = "41.842mm" ver = "02" gw = "217" gh = "102"/>
</figure>
<list1 type = "unordered">
<item>
<ptxt>
Coloque los brazos del limpiaparabrisas (1) en las posiciones que se muestran en la ilustración.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Lado derecho [A]
</ptxt>
<ptxt>
Alinee la punta de la escobilla del limpiaparabrisas (5) con la marca de coincidencia (4).
</ptxt>
</item>
<item>
<ptxt>
Lado izquierdo [B]
</ptxt>
<ptxt>
Alinee la hoja con la línea de cerámica (3).
</ptxt>
</item>
</list2>
<item>
<ptxt>
Apriete las tuercas del brazo del limpiaparabrisas al par de apriete especificado.
</ptxt>
<torque>
<torqueitem id = "T9D003">
<t-part>
Tuerca del brazo de limpiaparabrisas
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1,6
</t-value2>
<t-value3>
12,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940009.swf" width = "88.000mm" height = "77.752mm" ver = "02" gw = "189" gh = "204"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.277in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.708in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Sombrerete del pivote del limpiaparabrisas
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
