<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B1606008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del conjunto del termostato (incorporado al sensor ECT)
</title>
<servinfosub id = "ASPAP70B1606008001">
<title>
Extracción
</title>
<s1>
<ptxt>
Drene el refrigerante. 
<intxreftitleoff1 refid = "ASPAP70B1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del sensor ECT.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el tubo de entrada del radiador (2) y el tubo de entrada del calentador (3) del conjunto del termostato (1).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del termostato (1) de la culata.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160003.swf" width = "88.000mm" height = "50.065mm" ver = "01" gw = "181" gh = "125"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B1606008002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utilice juntas nuevas.
</ptxt>
</item>
<item>
<ptxt>
Rellene el sistema de refrigeración con refrigerante. 
<intxreftitleoff1 refid = "ASPAP70B1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verifique si el sistema de refrigeración tiene fugas. 
<intxreftitleoff1 refid = "ASPAP70B1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
