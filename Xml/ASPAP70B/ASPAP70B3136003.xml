<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "3">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B3136003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del conjunto del cubo de la rueda trasera
</title>
<servinfosub id = "ASPAP70B3136003001">
<title>
Extracción
</title>
<s1>
<ptxt>
Levante el vehículo y extraiga la rueda trasera. 
<intxreftitleoff1 refid = "ASPAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el disco de freno trasero y la pinza de freno trasero. 
<intxreftitleoff1 refid = "ASPAP70B4326005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el sensor de velocidad de la rueda trasera del conjunto del cubo de la rueda trasera.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modelos con ABS: 
<intxreftitleoff1 refid = "ASPAP70B4506008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modelo con ESP<sup>&#174;</sup>: 
<intxreftitleoff1 refid = "ASPAP70B4606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga los pernos (1) del cubo de la rueda trasera y, a continuación, extraiga la cubierta guardapolvo del disco de freno trasero y el cubo de la rueda trasera.
</ptxt>
<figure>
<graphic graphicname = "I9P60A312002.swf" width = "88.000mm" height = "47.897mm" ver = "02" gw = "172" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga los pernos del cubo (1) con una prensa hidráulica si fuera necesario.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312010.jpg" width = "88.000mm" height = "54.842mm" ver = "01" gw = "173" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B3136003002">
<title>
Instalación
</title>
<s1>
<ptxt>
Introduzca los pernos del cubo (1) en los orificios del cubo. Gire lentamente los pernos de cubo para que el estriado quede alineado con el hecho por los pernos originales.
</ptxt>
<figure>
<graphic graphicname = "IAP70B312002.jpg" width = "88.000mm" height = "50.374mm" ver = "03" gw = "171" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Instale el guardapolvo del disco de freno trasero (1) y el conjunto del cubo de la rueda trasera y apriete los pernos del cubo de la rueda trasera nuevo al par especificado.
</ptxt>
<torque>
<torqueitem id = "T3A304">
<t-part>
Perno del cubo de la rueda
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
82
</t-value1>
<t-value2>
8,4
</t-value2>
<t-value3>
60,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A312003.swf" width = "88.000mm" height = "47.897mm" ver = "02" gw = "186" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Instale el sensor de velocidad de la rueda trasera.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modelos con ABS: 
<intxreftitleoff1 refid = "ASPAP70B4506008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modelo con ESP<sup>&#174;</sup>: 
<intxreftitleoff1 refid = "ASPAP70B4606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Instale el disco de freno trasero y la pinza de freno trasero. 
<intxreftitleoff1 refid = "ASPAP70B4326005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Coloque la rueda trasera. 
<intxreftitleoff1 refid = "ASPAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Confirme la alineación de las ruedas traseras. 
<intxreftitleoff1 refid = "ASPAP70B2306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
