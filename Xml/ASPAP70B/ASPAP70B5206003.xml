<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Sustitución del sello de aceite lateral del diferencial
</title>
<s1>
<ptxt>
Levante el vehículo y drene el aceite del transeje.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las piezas siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Eje propulsor delantero: 
<intxreftitleoff1 refid = "ASPAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Eje impulsor intermedio: 
<intxreftitleoff1 refid = "ASPAP70B3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga el sello (1) de aceite con la herramienta especial.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I4RH01520003.swf" width = "88.000mm" height = "47.972mm" ver = "01" gw = "131" gh = "120"/>
</figure>
</s1>
<s1>
<ptxt>
Instale el sello (1) de aceite nuevo utilizando la herramienta especial.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Asegúrese de instalar el lado del muelle del sello de aceite hacia el interior.
</ptxt>
</item>
<item>
<ptxt>
Asegúrese de instalar el sello de aceite en la superficie de la caja del transeje (2) en paralelo.
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
09944-88220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Distancia entre la superficie de la caja y el sello de aceite
</title>
<ptxt>
&#34;a&#34;: 0 – 0,5 mm (0 – 0,02 in.)
</ptxt>
<ptxt>
&#34;b&#34;: 0 – 1,0 mm (0 – 0,04 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Aplique grasa al borde del sello de aceite y compruebe la suavidad del eje impulsor en el lugar donde está en contacto con el sello de aceite.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B004" uid = "22">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasa
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70B520003.swf" width = "88.000mm" height = "49.386mm" ver = "01" gw = "242" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Coloque las piezas siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Eje propulsor delantero: 
<intxreftitleoff1 refid = "ASPAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Eje impulsor intermedio: 
<intxreftitleoff1 refid = "ASPAP70B3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Añada aceite del transeje. 
<intxreftitleoff1 refid = "ASPAP70B5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
