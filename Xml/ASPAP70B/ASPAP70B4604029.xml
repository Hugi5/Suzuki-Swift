<servinfosub id = "ASPAP70B4604029003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70B4604029004">
<testgroup id = "ASPAP70B4604029005">
<question>
¿Se ha llevado a cabo el procedimiento de &#34;Inspección del sistema ESP<sup>&#174;</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70B4604001">Comprobación del sistema del ESP&#174;</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604029006">
<title>
Comprobación de los circuitos de masa y de alimentación eléctrica del módulo de control del ESP&#174;
</title>
<test1>
<ptxt>
Compruebe el circuito de masa y el circuito de alimentación eléctrica del módulo de control del ESP<sup>&#174;</sup>. 
<intxreftitleoff1 refid = "ASPAP70B4604039"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Están en buenas condiciones?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70B4604029007">
<title>
Comprobación de la tensión de alimentación eléctrica del módulo de control del ESP&#174;
</title>
<test1>
<ptxt>
Mida la tensión de la batería con el motor a 3.000 rpm.
</ptxt>
</test1>
<question>
¿La tensión está entre 9,3 V y 16,8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70B4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Inspeccione el sistema de carga. 
<intxreftitleoff1 refid = "ASPAP70B1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
