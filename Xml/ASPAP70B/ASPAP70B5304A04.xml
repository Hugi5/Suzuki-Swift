<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70B5304A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
El embrague hace ruido
</title>
<diag type = "condition">
<condition>
<ptxt>
El embrague hace ruido
</ptxt>
</condition>
<ps>
<ptxt>
Cojinete de desembrague desgastado o roto
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el cojinete de desembrague. 
<intxreftitleoff1 refid = "ASPAP70B5306020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cojinete derecho del eje de entrada desgastado
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el cojinete derecho del eje de entrada. 
<intxreftitleoff1 refid = "ASPAP70B5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vibración excesiva del cubo del disco de embrague
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPAP70B5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disco de embrague con fisuras
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPAP70B5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Claqueteo en el plato de presión y en el muelle del diafragma
</ptxt>
</ps>
<action>
<ptxt>
Reemplace la tapa del embrague. 
<intxreftitleoff1 refid = "ASPAP70B5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
