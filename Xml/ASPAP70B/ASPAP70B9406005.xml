<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70B9406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del limpialunetas trasero
</title>
<servinfosub id = "ASPAP70B9406005001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga la cubierta del brazo del limpialunetas trasero (1), la tuerca del brazo del limpialunetas trasero (2), el conjunto del brazo del limpialunetas trasero con la escobilla (3), el sombrerete del pivote del limpialunetas (4), la tuerca del limpialunetas trasero (5) y el sello del limpialunetas trasero (6).
</ptxt>
<figure>
<graphic graphicname = "I9P60A940013.swf" width = "88.000mm" height = "45.733mm" ver = "01" gw = "174" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el embellecedor de la puerta del maletero. 
<intxreftitleoff1 refid = "ASPAP70B9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el motor del limpialunetas trasero.
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del motor del limpialunetas trasero mediante un destornillador de punta plana (2) como se muestra en la ilustración.
</ptxt>
<figure>
<graphic graphicname = "I7V10A940003.swf" width = "88.000mm" height = "79.003mm" ver = "01" gw = "161" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70B9406005002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70B9406006">Inspección del motor del limpialunetas trasero</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete los pernos del motor del limpialunetas trasero al par de apriete especificado.
</ptxt>
<torque>
<torqueitem id = "T9D004">
<t-part>
Perno del motor del limpialunetas trasero
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I5RW0A940011.swf" width = "88.000mm" height = "56.315mm" ver = "01" gw = "172" gh = "143"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
