<servinfosub id = "AENAP70B8204039003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B8204039004">
<testgroup id = "AENAP70B8204039005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B8204039006">
<title>
Knee air bag (inflator) module check
</title>
<test1>
<ptxt>
Confirm that ignition is in “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G222” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Connect “STEERING WHEEL” (1) of special tools (A), (B) and (C) to “G222” connector.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B069">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B070">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932–78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B071">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932–75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820031.swf" width = "90.000mm" height = "97.092mm" ver = "02" gw = "236" gh = "259"/>
</testfigure>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70B8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1242 indicated?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace knee air bag (inflator) module. 
<intxreftitleoff1 refid = "AENAP70B8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B8204039007">
<title>
Instrument panel harness circuit check
</title>
<test1>
<ptxt>
Disconnect “G11” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector inserting release tool included in special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Check the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “G11-1” and “G11-2” terminals: infinity
</ptxt>
<servicetool>
<servicetoolitem id = "L8B072">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
</item>
</list1>
<testfigure>
<graphic graphicname = "IAW10A820025.swf" width = "90.000mm" height = "58.392mm" ver = "01" gw = "217" gh = "149"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs, referring to 
<intxref refid = "AENAP70B8204006">DTC Clearance</intxref>
 if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENAP70B8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
