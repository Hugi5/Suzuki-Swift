<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B9504A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Rear defogger cannot operate
</title>
<diag type = "condition">
<condition>
<ptxt>
Rear defogger cannot operate
</ptxt>
</condition>
<ps>
<ptxt>
Faulty system circuits (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9501002">Rear End Door Window Defogger System Description</intxref>
 
</ptxt>
</action>
<ps>
<ptxt>
Faulty rear defogger switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506008">Rear Defogger Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty rear defogger
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506007">Rear Defogger Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
“Inspection of BCM and Its Circuits”: in Section 10B.
</ptxt>
<ptxt>
Ignition Switch Model: 
<intxreftitleoff1 refid = "AENAP70BA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Keyless Push Start Model: 
<intxreftitleoff1 refid = "AENAP70BA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
