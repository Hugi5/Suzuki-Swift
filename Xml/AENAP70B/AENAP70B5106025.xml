<servinfo servinfosgmlid = "AENAP70B5106025" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
ATF Temperature Sensor Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106024">ATF Temperature Sensor Removal and Installation</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Remove ATF temperature sensor. 
<intxreftitleoff1 refid = "AENAP70B5106024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check ATF temperature sensor resistance as follows.
</ptxt>
<s2>
<ptxt>
Warm up ATF temperature sensor (2).
</ptxt>
</s2>
<s2>
<ptxt>
Check resistance between terminals of solenoid connector (1). Make sure its resistance decreases as its temperature increases.
</ptxt>
<ptxt>
If measured resistance is out of specified resistance, replace ATF temperature sensor.
</ptxt>
</s2>
</s1>
<spec>
<title>
ATF temperature sensor resistance
</title>
<ptxt>
10 &#176;C (50 &#176;F): 5.62 – 7.31 kΩ
</ptxt>
<ptxt>
110 &#176;C (230 &#176;F): 224 – 271 Ω
</ptxt>
<ptxt>
145 &#176;C (293 &#176;F): 102 – 121 Ω
</ptxt>
</spec>
<figure>
<graphic graphicname = "I8C50B510066.swf" width = "88.000mm" height = "86.801mm" ver = "02" gw = "167" gh = "230"/>
