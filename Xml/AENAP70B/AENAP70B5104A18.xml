<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5104A18" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Poor 3 → 4 shift
</title>
<servinfosub id = "AENAP70B5104017004">
<title>
Trouble Diagnosis 2
</title>
<topic id = "AENAP70B5104017005">
<title>
On-vehicle repair
</title>
<diag type = "condition">
<condition>
<ptxt>
Poor 3 → 4 shift
</ptxt>
</condition>
<ps>
<ptxt>
Malfunction of shift solenoid valve “B”
</ptxt>
</ps>
<action>
<ptxt>
Inspect shift solenoid valve “B”. If NG, replace shift solenoid valve “B”.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of timing solenoid valve
</ptxt>
</ps>
<action>
<ptxt>
Inspect timing solenoid valve. If NG, replace timing solenoid valve.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of output shaft speed sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect output shaft speed sensor. If NG, replace output shaft speed sensor.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of input shaft speed sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect input shaft speed sensor. If NG, replace input shaft speed sensor.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of transmission range sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect transmission range sensor. If NG, replace transmission range sensor.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of ATF temperature sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect ATF temperature sensor. If NG, replace ATF temperature sensor.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of O/D off switch
</ptxt>
</ps>
<action>
<ptxt>
Inspect O/D off switch. If NG, replace select lever assembly.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of ECT sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect ECT sensor. 
<intxreftitleoff1 refid = "AENAP70B1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If NG, replace ECT sensor.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of throttle position sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect throttle position sensor. 
<intxreftitleoff1 refid = "AENAP70B1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If NG, replace throttle body.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of pressure control solenoid valve
</ptxt>
</ps>
<action>
<ptxt>
Inspect pressure control solenoid valve. If NG, replace valve body assembly.
</ptxt>
</action>
<ps>
<ptxt>
Faulty valve body component
</ptxt>
</ps>
<action>
<ptxt>
Replace valve body assembly.
</ptxt>
</action>
</diag>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
