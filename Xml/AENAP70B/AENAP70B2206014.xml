<servinfo servinfosgmlid = "AENAP70B2206014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Stabilizer Bar Bushing Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B2206013">Front Suspension Frame, Stabilizer Bar and Bushing Removal and Installation</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B2206016">Front Stabilizer Bar, Bushing and Joint Check</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B2206014001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove exhaust No.1 pipe and exhaust center pipe. 
<intxreftitleoff1 refid = "AENAP70B1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove stabilizer bar mounting bracket (3) and bolts (5).
</ptxt>
</s1>
<s1>
<ptxt>
Remove stabilizer bar bushings (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A220037.jpg" width = "88.000mm" height = "83.006mm" ver = "03" gw = "240" gh = "215"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "6" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.805in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.970in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.315in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.701in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[f]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Forward
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Stabilizer bar
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Ring
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B2206014002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B2206013">Front Suspension Frame, Stabilizer Bar and Bushing Removal and Installation</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
When installing stabilizer bar bushing and stabilizer bar mounting bracket, refer to steps 1) and 2) of Installation procedure in 
<intxref refid = "AENAP70B2206013">Front Suspension Frame, Stabilizer Bar and Bushing Removal and Installation</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
