<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B4104A14" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Brake warning light does not turn ON after setting ignition to “ON”
</title>
<diag type = "condition">
<condition>
<ptxt>
Brake warning light does not turn ON after setting ignition to “ON”
</ptxt>
</condition>
<ps>
<ptxt>
Faulty combination meter power supply and ground circuit
</ptxt>
</ps>
<action>
<ptxt>
Check combination meter and its circuit. 
<intxreftitleoff1 refid = "AENAP70B9304017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty combination meter
</ptxt>
</ps>
<action>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ABS / ESP<sup>®</sup> control module
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace ABS / ESP<sup>®</sup> control module.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ABS model: 
<intxreftitleoff1 refid = "AENAP70B4506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>®</sup> model: 
<intxreftitleoff1 refid = "AENAP70B4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
