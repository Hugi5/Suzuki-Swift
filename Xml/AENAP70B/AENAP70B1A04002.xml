<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B1A04002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Generator Symptom Diagnosis
</title>
<ptxt>
Trouble in charging system will show up as one or more of the following conditions.
</ptxt>
<servinfosub id = "AENAP70B1A04002001" page = "1">
<title>
Charging Warning Light Operation
</title>
<diag type = "condition" id = "AENAP70B1A04002002">
<condition>
<ptxt>
Charge warning light does not light with ignition ON and engine off
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Replace fuse.
</ptxt>
</action>
<ps>
<ptxt>
Faulty combination meter
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check BCM. 
</ptxt>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENAP70BA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENAP70BA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty CAN communication line
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace CAN communication line. 
<intxreftitleoff1 refid = "AENAP70BA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty IC regulator or field coil
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70B1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Charge warning light does not go out with engine running (battery requires frequent recharging)
</ptxt>
</condition>
<ps>
<ptxt>
Loose or worn drive belt
</ptxt>
</ps>
<action>
<ptxt>
Adjust or replace drive belt. 
<intxreftitleoff1 refid = "AENAP70B1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty combination meter
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Check BCM. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENAP70BA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENAP70BA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Faulty IC regulator or generator
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70B1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace wiring.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AENAP70B1A04002003">
<title>
Battery Charge Failure
</title>
<diag type = "condition" id = "AENAP70B1A04002004">
<condition>
<ptxt>
Undercharged battery
</ptxt>
</condition>
<ps>
<ptxt>
Loose or worn drive belt
</ptxt>
</ps>
<action>
<ptxt>
Adjust or replace drive belt. 
<intxreftitleoff1 refid = "AENAP70B1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose or corroded battery terminal 
</ptxt>
</ps>
<action>
<ptxt>
Tighten battery terminal or replace battery. 
<intxreftitleoff1 refid = "AENAP70B1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty rectifier, rotor and/or IC regulator
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70B1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Overcharged battery
</ptxt>
</condition>
<ps>
<ptxt>
Faulty IC regulator
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70B1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AENAP70B1A04002005">
<title>
Noise
</title>
<diag type = "condition" id = "AENAP70B1A04002006">
<condition>
<ptxt>
Noisy generator
</ptxt>
</condition>
<ps>
<ptxt>
Loose mounting bolts
</ptxt>
</ps>
<action>
<ptxt>
Tighten mounting bolts. 
<intxreftitleoff1 refid = "AENAP70B1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Dirty, worn and/or faulty bearings
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70B1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty rotor, diode and/or stator
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70B1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
