<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B6306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Tie-Rod End Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B6306002">Tie-Rod End Boot On-Vehicle Inspection</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B6306001">Steering Gear Case Assembly Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B6306003001">
<title>
Removal
</title>
<s1>
<ptxt>
Hoist vehicle, and then remove front wheel. 
<intxreftitleoff1 refid = "AENAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove clip (2), and tie-rod end nut (1) from tie-rod end.
</ptxt>
<figure>
<graphic graphicname = "IAP70A630011.jpg" width = "88.000mm" height = "57.647mm" ver = "01" gw = "171" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect tie-rod end (1) from steering knuckle (2) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C003">
<s-part>
(A)
</s-part>
<s-number num = "09913-65210">
09913–65210
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630016.swf" width = "88.000mm" height = "52.953mm" ver = "01" gw = "118" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
For ease of adjustment after installation, make mark (1) of tie-rod end lock nut (2) position on tie-rod end thread. Then, loosen lock nut and remove tie-rod end (3) from tie-rod (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A630017.swf" width = "88.000mm" height = "51.911mm" ver = "02" gw = "108" gh = "131"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B6306003002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B6306004">Tie-Rod End Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install tie-rod end lock nut (2) and tie-rod end (3) to tie-rod (4). Align lock nut with mark (1) on tie-rod thread.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630017.swf" width = "88.000mm" height = "51.911mm" ver = "02" gw = "108" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Connect tie-rod end to steering knuckle. Tighten tie-rod end nut (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T6C001">
<t-part>
Tie-rod end nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4.6
</t-value2>
<t-value3>
33.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Install clip (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A630012.jpg" width = "88.000mm" height = "57.647mm" ver = "01" gw = "171" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Install front wheel. 
<intxreftitleoff1 refid = "AENAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Inspect for toe. 
<intxreftitleoff1 refid = "AENAP70B2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
After confirming that toe is as specified, tighten tie-rod end lock nut to specified torque. 
<intxreftitleoff1 refid = "AENAP70B6306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
