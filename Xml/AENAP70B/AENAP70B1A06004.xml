<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1A06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Water Pump / Generator Drive Belt Removal and Installation
</title>
<servinfosub id = "AENAP70B1A06004001" page = "2">
<title>
Removal
</title>
<s1 page = "2">
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove right engine undercover.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove compressor drive belt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENAP70B7226036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Automatic A/C model: 
<intxreftitleoff1 refid = "AENAP70B7236043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Loosen generator bolt (2) and generator pivot bolt (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Loosen generator adjusting bolt (4), and then remove water pump / generator drive belt (1).
</ptxt>
<figure>
<graphic graphicname = "I7V20A1A1008.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "148" gh = "123"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1A06004002" page = "2">
<title>
Installation
</title>
<s1 page = "2">
<ptxt>
Install water pump / generator drive belt (1) to water pump pulley (2), crankshaft pulley (3) and generator pulley (4).
</ptxt>
<attention3>
<ptxt>
Make sure water pump / generator drive belt is installed in grooves of each pulley correctly.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I7V20A1A1009.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "140" gh = "123"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Adjust belt tension. 
<intxreftitleoff1 refid = "AENAP70B1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install compressor drive belt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENAP70B7226036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Automatic A/C model: 
<intxreftitleoff1 refid = "AENAP70B7236043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Install right engine undercover.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Connect negative (–) cable at battery.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
