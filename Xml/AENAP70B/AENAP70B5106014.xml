<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Transmission Range Sensor Removal and Installation
</title>
<servinfosub id = "AENAP70B5106014001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove select cable clip and disconnect select cable from manual select lever. 
<intxreftitleoff1 refid = "AENAP70B5106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Shift manual select lever (1) to “N” position.
</ptxt>
<figure>
<graphic graphicname = "I9P60A510031.swf" width = "88.000mm" height = "52.913mm" ver = "02" gw = "145" gh = "133"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect transmission range sensor connector (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A510032.swf" width = "88.000mm" height = "52.550mm" ver = "02" gw = "177" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Remove manual select lever nut (1) and manual select lever (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uncaulk lock washer (4) and remove lock nut (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove transmission range sensor mounting bolts (5) and transmission range sensor (6).
</ptxt>
<figure>
<graphic graphicname = "I7V10A510029.swf" width = "88.000mm" height = "50.619mm" ver = "01" gw = "154" gh = "127"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B5106014002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Adjust select cable. 
<intxreftitleoff1 refid = "AENAP70B5106013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten transmission range sensor mounting bolts, lock nut and manual select lever nut to specified torque.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T5A003">
<t-part>
Transmission range sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
<torqueitem id = "T5A004">
<t-part>
Manual select lever lock nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
7.0
</t-value1>
<t-value2>
0.71
</t-value2>
<t-value3>
5.5
</t-value3>
</torqueitem>
<torqueitem id = "T5A005">
<t-part>
Manual select lever nut
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
12
</t-value1>
<t-value2>
1.2
</t-value2>
<t-value3>
9.0
</t-value3>
</torqueitem>
</torque>
<list1 type = "unordered">
<item>
<ptxt>
Use new lock washer (1) and caulk lock washer.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510030.swf" width = "88.000mm" height = "50.443mm" ver = "01" gw = "155" gh = "126"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
