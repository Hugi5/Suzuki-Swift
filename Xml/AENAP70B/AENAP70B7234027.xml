<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "3">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B7234027" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1571
</title>
<servinfosub id = "AENAP70B7234027001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.922in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.288in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1571: Combination Meter Spec Signal Failure
</emph>
</ptxt>
<ptxt>
HVAC control module receives invalid data of combination meter spec signal from Combination meter.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Combination meter
</ptxt>
</item>
<item>
<ptxt>
HVAC control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70B7234027002">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Start engine and operate A/C system.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B7234027003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B7234027004">
<testgroup id = "AENAP70B7234027005">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition to “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “ON” and check DTC.
</ptxt>
</test1>
<question>
Is DTC B1571 still detected?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Substitute a known-good combination meter and/or HVAC control module and recheck DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Combination meter: 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
HVAC control module: 
<intxreftitleoff1 refid = "AENAP70B7236011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
