<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1306005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Electric Throttle Control System Calibration
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
If the service described under 
<intxref refid = "AENAP70B1101007">Description of Electric Throttle Control System Calibration</intxref>
 is performed, calibrate electric throttle control system as follows.
</ptxt>
</item>
<item>
<ptxt>
Check that the following conditions are satisfied when performing this procedure.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
 Ambient temperature &#62; 5 &#176;C (41 &#176;F)
</ptxt>
</item>
<item>
<ptxt>
DTC is not detected.
</ptxt>
</item>
<item>
<ptxt>
Accelerator pedal position: Idle position
</ptxt>
</item>
<item>
<ptxt>
5 &#176;C (41 &#176;F) &#60; ECT &#60; 100 &#176;C (212 &#176;F)
</ptxt>
</item>
<item>
<ptxt>
Battery voltage &#62; 10 V
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Set ignition “ON” for 60 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
After completing this calibration, check that DTC is not detected in ECM.
</ptxt>
<ptxt>
If DTC is detected, go to troubleshooting for applicable DTC.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
