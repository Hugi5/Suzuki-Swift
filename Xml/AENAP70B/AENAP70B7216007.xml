<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B7216007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
HVAC Unit Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B7216006">HVAC Unit Components:Non-A/C</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B7216007001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENAP70B8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Drain engine coolant. 
<intxreftitleoff1 refid = "AENAP70B1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Then disconnect heater hoses from HVAC unit.
</ptxt>
</s1>
<s1>
<ptxt>
Remove instrument panel from vehicle body. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove HVAC unit (1) from vehicle body by removing nuts (2).
</ptxt>
<attention3>
<ptxt>
When removing HVAC unit, be careful not to spill engine coolant on vehicle floor.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A721012.swf" width = "88.000mm" height = "80.484mm" ver = "01" gw = "229" gh = "212"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B7216007002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENAP70B1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Adjust control cables. 
<intxreftitleoff1 refid = "AENAP70B7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
