<servinfosub id = "AENAP70B1104015003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery voltage &#62; 8.5 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Run engine at idle speed for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1104015004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B1104015005">
<testgroup id = "AENAP70B1104015006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104015007">
<title>
HO2S-1 heater power supply circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect HO2S-1 connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to HO2S-1 connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “A1” circuit and ground is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wiring harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104015008">
<title>
HO2S-1 heater drive circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A4” circuit: less than 1Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A4” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A4” circuit terminal and other terminal at HO2S-1 connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A4” circuit: approx. 0 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wiring harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104015009">
<title>
HO2S-1 heater check
</title>
<test1>
<ptxt>
Check HO2S-1 heater. 
<intxreftitleoff1 refid = "AENAP70B1306014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace HO2S-1. 
<intxreftitleoff1 refid = "AENAP70B1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
