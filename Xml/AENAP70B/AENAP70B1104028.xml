<title>
DTC P0137 / P0138 / P0140
</title>
<servinfosub id = "AENAP70B1104028001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.955in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.240in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0137: O2 Sensor Circuit Low Voltage (sensor 2)
</emph>
</ptxt>
<ptxt>
Any of the following conditions is met.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Output voltage of HO2S-2 circuit is lower than 0.09 V for 30 sec. after warming up.
</ptxt>
</item>
<item>
<ptxt>
Output voltage of HO2S-2 circuit stays lower than 0.09 V from cold engine start to engine warmed up.
</ptxt>
</item>
</list1>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
HO2S-2 and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
HO2S-2 heater and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
Exhaust system
</ptxt>
</item>
<item>
<ptxt>
Air intake system
</ptxt>
</item>
<item>
<ptxt>
Fuel system
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0138: O2 Sensor Circuit High Voltage (sensor 2)
</emph>
</ptxt>
<ptxt>
Output voltage of HO2S-2 signal circuit is higher than 1.08 V for 5 sec.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0140: O2 Sensor Circuit No Activity Detected (sensor 2)
</emph>
</ptxt>
<ptxt>
Output voltage of HO2S-2 circuit stays between 0.42 to 0.50 V for 500 sec.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
