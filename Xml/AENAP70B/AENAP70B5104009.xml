<servinfo servinfosgmlid = "AENAP70B5104009" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
A/T Basic Check
</title>
<ptxt>
This check is important for troubleshooting when TCM has detected no DTC and no abnormality has been noted in 
<intxref refid = "AENAP70B5104008">Visual Inspection</intxref>
. Follow the flow carefully.
</ptxt>
<diag type = "test" id = "AENAP70B5104009001">
<testgroup id = "AENAP70B5104009002">
<question>
Was “A/T Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B5104001">A/T Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104009003">
<title>
Road test
</title>
<test1>
<ptxt>
Perform road test. 
<intxreftitleoff1 refid = "AENAP70B5104010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective part.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104009004">
<title>
Manual road test
</title>
<test1>
<ptxt>
