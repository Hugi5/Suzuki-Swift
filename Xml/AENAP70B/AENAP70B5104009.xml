Is it OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective part.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104009005">
<title>
Engine brake test
</title>
<test1>
<ptxt>
Perform engine brake test. 
<intxreftitleoff1 refid = "AENAP70B5104012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it OK?
</question>
<result type = "yes"/>
