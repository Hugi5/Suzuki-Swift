</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104009009">
<ptxt>
Proceed to “Trouble Diagnosis 1” in 
<intxref refid = "AENAP70B5104017">A/T Symptom Diagnosis</intxref>
.
</ptxt>
<question>
Is trouble identified?
</question>
<result type = "yes"/>
<action>
<ptxt>
