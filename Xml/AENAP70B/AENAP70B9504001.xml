<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B9504001" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Power Window System Symptom Diagnosis
</title>
<diag type = "condition" id = "AENAP70B9504001001">
<condition>
<ptxt>
All power windows cannot operate
</ptxt>
</condition>
<ps>
<ptxt>
Faulty wiring
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty power window main switch 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506019">Power Window Main Switch Inspection</intxref>
</ptxt>
</action>
<condition>
<ptxt>
One of the power window cannot operate
</ptxt>
</condition>
<ps>
<ptxt>
Faulty wiring
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty power window regulator and/or motor
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70B9506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70B9506018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty power window main switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506019">Power Window Main Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty power window sub switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506020">Power Window Sub Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Window lock switch is pushed (lock position)
</ptxt>
</ps>
<action>
<ptxt>
Turn off window lock switch.
</ptxt>
</action>
<condition>
<ptxt>
Auto-down function does not operate
</ptxt>
</condition>
<ps>
<ptxt>
Faulty power window main switch 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506019">Power Window Main Switch Inspection</intxref>
</ptxt>
</action>
<condition>
<ptxt>
Abnormal noise
</ptxt>
</condition>
<ps>
<ptxt>
Loose window regulator mounting bolts
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Tighten window regulator mounting bolts.
</ptxt>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70B9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70B9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Worn or broken power window regulator sliding and rotating parts
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace window regulator.
</ptxt>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70B9506012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70B9506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Poor greasing
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Lubricate.
</ptxt>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70B9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70B9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
