<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5306016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Clutch Pedal Assembly Removal and Installation
</title>
<servinfosub id = "AENAP70B5306016001" page = "2">
<title>
Removal
</title>
<s1 page = "2">
<ptxt>
Remove push rod from clutch pedal. 
<intxreftitleoff1 refid = "AENAP70B5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove CPP No.1 switch (if equipped) and CPP No.2 switch (if equipped) from clutch pedal assembly, if necessary.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
CPP No.1 switch: 
<intxreftitleoff1 refid = "AENAP70B5306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
CPP No.2 switch: 
<intxreftitleoff1 refid = "AENAP70B5306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Remove clutch pedal assembly from vehicle body.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B5306016002" page = "2">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten each bolt and nut to specified torque. 
<intxreftitleoff1 refid = "AENAP70B5306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Apply grease to push rod tip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Silicone Grease" id = "M5C002" uid = "21">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25100
</m-number>
<m-name>
SUZUKI Silicone Grease
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
If additional lubrication is required, apply grease to specified position. 
<intxreftitleoff1 refid = "AENAP70B5306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease E" id = "M5C003" uid = "24">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25050
</m-number>
<m-name>
SUZUKI Super Grease E
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
