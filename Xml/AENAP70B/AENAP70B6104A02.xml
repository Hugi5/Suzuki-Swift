<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B6104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Too much play in steering
</title>
<diag type = "condition">
<condition>
<ptxt>
Too much play in steering
</ptxt>
</condition>
<ps>
<ptxt>
Worn wheel bearings
</ptxt>
</ps>
<action>
<ptxt>
Replace wheel bearing. 
<intxreftitleoff1 refid = "AENAP70B3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose steering gear case bolt
</ptxt>
</ps>
<action>
<ptxt>
Tighten steering gear case bolt. 
<intxreftitleoff1 refid = "AENAP70B6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty steering gear case assembly
</ptxt>
</ps>
<action>
<ptxt>
Replace steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70B6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn joint of steering column
</ptxt>
</ps>
<action>
<ptxt>
Replace steering column assembly. 
<intxreftitleoff1 refid = "AENAP70B6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn tie-rod end or tie-rod ball joint
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace tie-rod end or tie-rod.
</ptxt>
<ptxt>
Tie-rod end: 
<intxreftitleoff1 refid = "AENAP70B6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Tie-rod: 
<intxreftitleoff1 refid = "AENAP70B6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Worn suspension arm joint
</ptxt>
</ps>
<action>
<ptxt>
Replace suspension arm. 
<intxreftitleoff1 refid = "AENAP70B2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Improper tooth contact between rack and pinion
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check rack and pinion shaft rotation torque. 
<intxreftitleoff1 refid = "AENAP70B6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If defective, replace steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70B6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
