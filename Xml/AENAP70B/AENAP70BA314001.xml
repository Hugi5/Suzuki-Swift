<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70BA314001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Immobilizer Control System Check
</title>
<attention3>
<ptxt>
Before performing check be sure to read 
<intxref refid = "AENAP70BA310002">Precautions for Immobilizer System:Ignition Switch Model</intxref>
.
</ptxt>
</attention3>
<diag type = "test" id = "AENAP70BA314001001">
<testgroup id = "AENAP70BA314001002">
<question>
Is engine cranked?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B1904001">Cranking System Symptom Diagnosis</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA314001003">
<title>
Engine start check
</title>
<question>
Does engine start?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA314001007">
<test1>
<ptxt>
Connect SUZUKI scan tool to DLC.
</ptxt>
</test1>
<question>
Does SUZUKI scan tool communicate to ECM and BCM?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70BA804001">CAN Communication Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA314001004">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70BA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is there any DTC detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Immobilizer control system is in good condition.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA314001008">
<test1>
<ptxt>
Connect SUZUKI scan tool to DLC.
</ptxt>
</test1>
<question>
Does SUZUKI scan tool communicate to ECM and BCM?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70BA804001">CAN Communication Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA314001005">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70BA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is there any DTC detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA314001006">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC related to CAN communication. 
</ptxt>
</test1>
<question>
Is there any CAN-DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for CAN-DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B1104009">Engine Basic Inspection</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
