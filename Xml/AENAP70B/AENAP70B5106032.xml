<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106032" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Differential Side Oil Seal Replacement
</title>
<s1>
<ptxt>
Hoist vehicle and drain ATF.
</ptxt>
</s1>
<s1>
<ptxt>
Remove intermediate shaft.
</ptxt>
<ptxt>
Refer to 
<intxref refid = "AENAP70B3116005">Drive Intermediate Shaft Assembly Removal and Installation:Front</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove left drive shaft joints from differential gear of transaxle. Refer to 
<intxref refid = "AENAP70B3116003">Front Drive Shaft Assembly Removal and Installation:Front</intxref>
 for procedure to disconnect drive shaft joints.
</ptxt>
<ptxt>
For differential side oil seal removal, it is not necessary to remove drive shafts from steering knuckle.
</ptxt>
</s1>
<s1>
<ptxt>
Remove differential side oil seal (1) by using flat-bladed screwdriver or the like.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510055.swf" width = "88.000mm" height = "104.044mm" ver = "02" gw = "175" gh = "278"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.412in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.052in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Forward
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Apply grease to new differential side oil seal lips.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease C" id = "M5A002" uid = "23">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25030
</m-number>
<m-name>
SUZUKI Super Grease C
</m-name>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Using special tool, install new differential side oil seals (1) at specified position as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A006">
<s-part>
(C)
</s-part>
<s-number num = "09944-88220">
09944–88220
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A007">
<s-part>
(D)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A008">
<s-part>
(E)
</s-part>
<s-number num = "09951-16091">
09951–16091
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Differential side oil seal installing depth
</title>
<ptxt>
Right side “a”: 2.6 – 3.6 mm (0.11 – 0.14 in.)
</ptxt>
<ptxt>
Left side “b”: 3.8 – 4.8 mm (0.15 – 0.18 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A510045.swf" width = "88.000mm" height = "156.876mm" ver = "03" gw = "198" gh = "428"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.801in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.783in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Right side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Left side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install left drive shaft. 
<intxreftitleoff1 refid = "AENAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install intermediate shaft. Refer to 
<intxref refid = "AENAP70B3116005">Drive Intermediate Shaft Assembly Removal and Installation:Front</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Replenish proper amount of ATF. 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check fluid level. 
<intxreftitleoff1 refid = "AENAP70B5106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
