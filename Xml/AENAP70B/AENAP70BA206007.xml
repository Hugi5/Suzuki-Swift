<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70BA206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Keyless Entry Receiver Removal and Installation (Ignition Switch Model)
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove left instrument panel side garnish. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering column hole cover referring to Step 4) of 
<intxref refid = "AENAP70B6206009">Steering Column Removal and Installation</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect keyless entry receiver connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove screw, and then remove keyless entry receiver (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20024.jpg" width = "88.000mm" height = "66.001mm" ver = "01" gw = "204" gh = "171"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
