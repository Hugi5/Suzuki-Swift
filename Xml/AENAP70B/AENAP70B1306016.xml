<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1306016" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "1">
<title>
CMP Sensor On-Vehicle Inspection
</title>
<s1>
<ptxt>
With ignition “OFF”, disconnect CMP sensor connector.
</ptxt>
</s1>
<s1>
<ptxt>
Using service wire, connect connector to CMP sensor.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “ON” and check that output voltage varies depending on position of signal rotor as follows.
</ptxt>
<figure>
<graphic graphicname = "IAP70B130005.jpg" width = "88.000mm" height = "76.551mm" ver = "01" gw = "147" gh = "200"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.871in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Approx. 0 V
</ptxt>
<ptxt>
CMP sensor is opposite to projection of signal rotor.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Approx. 5 V
</ptxt>
<ptxt>
CMP sensor is away from projection of signal rotor.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
