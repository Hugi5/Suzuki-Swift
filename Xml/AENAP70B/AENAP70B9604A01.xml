<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B9604A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Only one door cannot be locked / unlocked
</title>
<diag type = "condition">
<condition>
<ptxt>
Only one door cannot be locked / unlocked
</ptxt>
</condition>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Faulty door lock assembly (including door lock open rod and door lock wires)
</ptxt>
</ps>
<action>
<ptxt>
Replace door lock open rod and door lock wires. 
<intxreftitleoff1 refid = "AENAP70B9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Damaged and deformed inside door handle
</ptxt>
</ps>
<action>
<ptxt>
Replace inside door handle. 
<intxreftitleoff1 refid = "AENAP70B9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
