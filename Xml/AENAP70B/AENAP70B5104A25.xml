<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5104A25" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Unable to run in any range
</title>
<servinfosub id = "AENAP70B5104017007">
<title>
Trouble Diagnosis 3
</title>
<topic id = "AENAP70B5104017008">
<title>
Off-vehicle repair
</title>
<diag type = "condition">
<condition>
<ptxt>
Unable to run in any range
</ptxt>
</condition>
<ps>
<ptxt>
Faulty oil pump
</ptxt>
</ps>
<action>
<ptxt>
Inspect oil pump. If NG, replace oil pump.
</ptxt>
</action>
<ps>
<ptxt>
Seized or broken planetary gear
</ptxt>
</ps>
<action>
<ptxt>
Inspect planetary gear. If NG, replace planetary gear.
</ptxt>
</action>
<ps>
<ptxt>
Faulty one-way clutch No.2
</ptxt>
</ps>
<action>
<ptxt>
Inspect one-way clutch No.2. If NG, replace one-way clutch No.2.
</ptxt>
</action>
<ps>
<ptxt>
Damaged drive plate
</ptxt>
</ps>
<action>
<ptxt>
Inspect drive plate. If NG, replace drive plate.
</ptxt>
</action>
<ps>
<ptxt>
Faulty forward clutch
</ptxt>
</ps>
<action>
<ptxt>
Inspect forward clutch. If NG, replace forward clutch.
</ptxt>
</action>
<ps>
<ptxt>
Faulty reverse clutch
</ptxt>
</ps>
<action>
<ptxt>
Inspect reverse clutch. If NG, replace reverse clutch.
</ptxt>
</action>
<ps>
<ptxt>
Faulty 1st and reverse brake
</ptxt>
</ps>
<action>
<ptxt>
Inspect 1st and reverse brake. If NG, replace 1st and reverse brake.
</ptxt>
</action>
<ps>
<ptxt>
Faulty torque converter
</ptxt>
</ps>
<action>
<ptxt>
Replace torque converter.
</ptxt>
</action>
</diag>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
