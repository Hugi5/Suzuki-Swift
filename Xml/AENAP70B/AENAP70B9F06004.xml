<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B9F06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Radio Antenna Removal and Installation
</title>
<servinfosub id = "AENAP70B9F06004001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove head lining. 
<intxreftitleoff1 refid = "AENAP70B9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect radio antenna connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove radio antenna bolt (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove radio antenna base (3) and radio antenna rod (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0007.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B9F06004002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten antenna bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9O001">
<t-part>
Antenna bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7.0
</t-value1>
<t-value2>
0.7
</t-value2>
<t-value3>
5.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A9F0008.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
