<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B7226042" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Relief Valve Removal and Installation
</title>
<servinfosub id = "AENAP70B7226042001">
<title>
Removal
</title>
<s1>
<ptxt>
Recover refrigerant from the A/C system using recovery and recycling equipment referring to “Recovery” in 
<intxref refid = "AENAP70B7226001">Operation Procedure for Refrigerant Charge:Manual Type</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove right side engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove relief valve (1) from A/C compressor.
</ptxt>
<figure>
<graphic graphicname = "I9P60A722038.swf" width = "88.000mm" height = "48.588mm" ver = "03" gw = "120" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B7226042002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new O-ring.
</ptxt>
</item>
<item>
<ptxt>
Apply compressor oil to O-ring.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B207" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Compressor oil
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Tighten relief valve to the specified torque.
</ptxt>
<torque>
<torqueitem id = "T7B207">
<t-part>
Relief valve
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9.8
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A722039.swf" width = "88.000mm" height = "48.612mm" ver = "05" gw = "120" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Evacuate and charge the A/C system referring to “Evacuation” and “Charge” in 
<intxref refid = "AENAP70B7226001">Operation Procedure for Refrigerant Charge:Manual Type</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
