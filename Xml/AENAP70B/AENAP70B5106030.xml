<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106030" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
TCM Removal and Installation
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
TCM consists of highly precise parts. When handling, be careful not to expose to excessive shock.
</ptxt>
</item>
<item>
<ptxt>
When replacing TCM with used one, all learned contents, which have been stored in TCM memory by learning control, should be initialized after replacement.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENAP70B5106030001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENAP70B8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove glove box. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connectors from TCM (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove TCM with bracket by removing bracket nuts (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A510043.swf" width = "88.000mm" height = "53.338mm" ver = "02" gw = "150" gh = "135"/>
</figure>
</s1>
<s1>
<ptxt>
Remove TCM (1) from bracket (2) by removing TCM mounting bolts (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A510044.jpg" width = "88.000mm" height = "56.722mm" ver = "02" gw = "213" gh = "144"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5106030002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten bolts and nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5A013">
<t-part>
TCM mounting bolt
</t-part>
<t-value1>
8.8
</t-value1>
<t-value2>
0.89
</t-value2>
<t-value3>
6.5
</t-value3>
</torqueitem>
<torqueitem id = "T5A014">
<t-part>
Bracket nut
</t-part>
<t-value1>
14
</t-value1>
<t-value2>
1.4
</t-value2>
<t-value3>
10.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Connect TCM connectors securely.
</ptxt>
</item>
<item>
<ptxt>
Enable air bag system after TCM is back in place. 
<intxreftitleoff1 refid = "AENAP70B8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
