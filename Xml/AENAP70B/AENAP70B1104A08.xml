<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B1104A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Poor fuel mileage
</title>
<ptxt>
Perform troubleshooting referring to the following points when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENAP70B1104008">Visual Inspection</intxref>
 and 
<intxref refid = "AENAP70B1104009">Engine Basic Inspection</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Poor fuel mileage
</ptxt>
</condition>
<ps>
<ptxt>
Faulty spark plug (improper gap, heavy deposits and burned electrodes, etc.)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1806002">Spark Plug Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
High idle speed
</ptxt>
</ps>
<action>
<ptxt>
Condition “Improper engine idling or engine fails to idle”
</ptxt>
</action>
<ps>
<ptxt>
Poor performance of ECT sensor, MAF sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1306012">ECT Sensor Inspection</intxref>
 or 
<intxref refid = "AENAP70B1306026">MAF and IAT Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty electric throttle body assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1306004">Electric Throttle Body Assembly On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty APP sensor assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1306008">APP Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty fuel injector(s)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1704003">Fuel Injector Circuit Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1104070">Inspection of ECM and Its Circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Low compression
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1404001">Compression Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Poor valve seating
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1406028">Valve and Valve Guide Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Dragging brakes
</ptxt>
</ps>
<action>
<ptxt>
Condition “Dragging brakes” in 
<intxref refid = "AENAP70B4104001">Brakes Symptom Diagnosis</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slipping clutch (for M/T model)
</ptxt>
</ps>
<action>
<ptxt>
Condition “Slipping clutch” in 
<intxref refid = "AENAP70B5304001">Clutch System Symptom Diagnosis</intxref>
 for M/T model
</ptxt>
</action>
<ps>
<ptxt>
Thermostat out of order
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1606009">Thermostat Assembly (Incorporating with ECT Sensor) Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Improper tire pressure
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B2401001">Tire Description</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Camshaft position control (VVT) system out of order
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1306027">OCV Inspection</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
