<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B4604028" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1047 / C1048
</title>
<servinfosub id = "AENAP70B4604028001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.814in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.366in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1047: Both-Front Wheel Speed Sensor or Encoder Signal Performance
</emph>
</ptxt>
<ptxt>
Yaw rate estimated by both front wheel speed sensors does not match with yaw rate sensor signal.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Steering angle sensor
</ptxt>
</item>
<item>
<ptxt>
Wheel speed sensor
</ptxt>
</item>
<item>
<ptxt>
Wheel speed sensor circuit
</ptxt>
</item>
<item>
<ptxt>
Wheel speed sensor encoder
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>®</sup> control module
</ptxt>
</item>
</list1>
<ptxt>
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1048: Both-Rear Wheel Speed Sensor or Encoder Signal Performance
</emph>
</ptxt>
<ptxt>
Yaw rate estimated by both rear wheel speed sensors does not match with yaw rate sensor signal.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70B4604028002">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B4604028003">
<testgroup id = "AENAP70B4604028004">
<question>
Was “ESP<sup>®</sup> System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B4604001">ESP® System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B4604028005">
<title>
DTC check
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENAP70B4604005">DTC Check</intxref>
.
</ptxt>
</test1>
<question>
Is there DTC(s) other than C1047 or C1048?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B4604028006">
<title>
Steering angle sensor on-vehicle inspection
</title>
<test1>
<ptxt>
Check steering angle sensor. 
<intxreftitleoff1 refid = "AENAP70B4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Replace steering angle sensor and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AENAP70B4604028007">
<title>
Wheel speed sensor check
</title>
<test1>
<ptxt>
Check applicable wheel speed sensor, wheel speed sensor encoder and/or wheel speed sensor circuit according to 
<intxref refid = "AENAP70B4604018">DTC C1021 / C1022 / C1025 / C1026 / C1031 / C1032 / C1033/ C1035 / C1036</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ESP<sup>®</sup> hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective part.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
