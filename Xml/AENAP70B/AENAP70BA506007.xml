<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70BA506007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Mid Inside Antenna Removal and Installation
</title>
<servinfosub id = "AENAP70BA506007001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove center console box. 
<intxreftitleoff1 refid = "AENAP70B9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector (1), and then remove mid inside antenna (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50026.swf" width = "88.000mm" height = "59.622mm" ver = "01" gw = "196" gh = "153"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70BA506007002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70BA506010">Antenna Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
