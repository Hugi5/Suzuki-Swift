<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1306021" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Knock Sensor On-Vehicle Inspection
</title>
<s1 page = "2">
<ptxt>
Disconnect connector (2) from knock sensor.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Connect oscilloscope (1) as shown in figure.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Check that oscilloscope displays waveform like a one shown below when cylinder block is given a shock by plastic hammer.
</ptxt>
<ptxt>
If faulty condition is found, replace knock sensor. 
<intxreftitleoff1 refid = "AENAP70B1306022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure page = "2">
<graphic graphicname = "I7V20A131018.swf" width = "88.000mm" height = "36.441mm" ver = "01" gw = "110" gh = "87"/>
</figure>
<figure page = "2">
<graphic graphicname = "I9P60A131019.swf" width = "88.000mm" height = "55.784mm" ver = "02" gw = "172" gh = "141"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
