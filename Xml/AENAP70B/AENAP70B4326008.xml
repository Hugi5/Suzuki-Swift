<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4C">
<servcat sctnbr = "04" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B4326008" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Brake Caliper Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B4326001">Rear Brake Components:Disc Brake Model</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B4326007">Rear Brake Caliper Removal and Installation:Disc Brake Model</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Take care not to damage piston and caliper cylinder of rear brake caliper.
</ptxt>
</attention2>
<servinfosub id = "AENAP70B4326008001">
<title>
Disassembly
</title>
<topic id = "AENAP70B4326008002">
<title>
Caliper
</title>
<s1>
<ptxt>
Clean surfaces around cylinder.
</ptxt>
</s1>
<s1>
<ptxt>
Loosen brake piston (1) by turning in arrow direction using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L4C207">
<s-part>
(A)
</s-part>
<s-number num = "09945-16030">
09945–16030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A432029.swf" width = "88.000mm" height = "43.929mm" ver = "01" gw = "141" gh = "108"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.225in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Piston boot
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove piston boot (1) and bleeder plug (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432042.swf" width = "88.000mm" height = "41.550mm" ver = "02" gw = "110" gh = "101"/>
</figure>
</s1>
<s1>
<ptxt>
Remove piston seal (1) from cylinder of rear brake caliper (3) using flat-bladed screwdriver (2) or the like.
</ptxt>
<figure>
<graphic graphicname = "I9P60A432043.swf" width = "88.000mm" height = "55.908mm" ver = "01" gw = "143" gh = "142"/>
</figure>
</s1>
</topic>
<topic id = "AENAP70B4326008003">
<title>
Slide pin
</title>
<ptxt>
Remove slide pins (2) and pin boots (3) from rear brake caliper carrier (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432030.swf" width = "88.000mm" height = "55.219mm" ver = "01" gw = "133" gh = "140"/>
</figure>
</topic>
</servinfosub>
<servinfosub id = "AENAP70B4326008004">
<title>
Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B4326009">Rear Brake Caliper Inspection:Disc Brake Model</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Use specified brake fluid to wash brake parts.
</ptxt>
<ptxt>
Any other fluids or solvents damage rubber parts.
</ptxt>
</attention2>
<topic id = "AENAP70B4326008005">
<title>
Caliper
</title>
<s1>
<ptxt>
Perform the following steps before installing brake piston to rear brake caliper.
</ptxt>
<s2>
<ptxt>
Check entire periphery of brake piston and inside surface of cylinder for rust, corrosion and any other damage. If check result is not OK, replace rear brake caliper.
</ptxt>
</s2>
<s2>
<ptxt>
Apply rubber grease included in piston seal set of supply parts to new piston seal (1), then fit the seal into groove in cylinder taking care not to twist the seal.
</ptxt>
<figure>
<graphic graphicname = "I9P60A432031.swf" width = "88.000mm" height = "55.908mm" ver = "01" gw = "127" gh = "142"/>
</figure>
</s2>
<s2>
<ptxt>
Coat new piston boot (1) with rubber grease included in piston seal set of supply parts, then fit the boot into groove in cylinder as shown below.
</ptxt>
<figure>
<graphic graphicname = "I9P60A432032.swf" width = "88.000mm" height = "42.431mm" ver = "01" gw = "170" gh = "104"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.030in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.002in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Cylinder side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Brake pad side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Expand piston boot (1) and install brake piston (2) into cylinder of rear brake caliper (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432033.swf" width = "88.000mm" height = "47.869mm" ver = "01" gw = "122" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Turn brake piston (1) in direction of arrow using special tool to screw brake piston into cylinder.
</ptxt>
</s1>
<s1>
<ptxt>
Fit piston boot into boot groove of brake piston.
</ptxt>
<attention2>
<ptxt>
Piston boot should not be twisted when installing brake piston.
</ptxt>
</attention2>
<attention3>
<ptxt>
Check that piston boot is completely fitted both in groove in cylinder and groove in brake piston.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L4C208">
<s-part>
(A)
</s-part>
<s-number num = "09945-16030">
09945–16030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A432011.swf" width = "88.000mm" height = "45.775mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Install bleeder plug to rear brake caliper and tighten it to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4C209">
<t-part>
Bleeder plug
</t-part>
<t-value1>
8.3
</t-value1>
<t-value2>
0.85
</t-value2>
<t-value3>
6.5
</t-value3>
</torqueitem>
</torque>
</s1>
</topic>
<topic id = "AENAP70B4326008006">
<title>
Slide pin
</title>
<s1>
<ptxt>
Check the following points before installing slide pins to rear brake caliper carrier.
</ptxt>
<s2>
<ptxt>
Check slide pins for rust, corrosion and other damage and replace them if defective.
</ptxt>
</s2>
<s2>
<ptxt>
Apply rubber grease to inside of new pin boot (1).
</ptxt>
</s2>
<s2>
<ptxt>
Install pin boots (1) to rear brake caliper carrier (2) with their ends directed as shown below.
</ptxt>
<attention3>
<ptxt>
Use rubber grease whose viscosity varies very little even at –40&#176;C (–40&#176;F).
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A432035.swf" width = "88.000mm" height = "46.795mm" ver = "01" gw = "138" gh = "116"/>
</figure>
</s2>
<s2>
<ptxt>
Apply rubber grease to slide pins (1).
</ptxt>
<attention3>
<ptxt>
Use rubber grease whose viscosity varies very little even at –40&#176;C (–40&#176;F).
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A432036.swf" width = "88.000mm" height = "37.816mm" ver = "01" gw = "76" gh = "91"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Install slide pin (1) with three grooves into rear side and slide pin (2) without groove into front side of rear brake caliper carrier (3) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60A432037.swf" width = "88.000mm" height = "40.813mm" ver = "01" gw = "136" gh = "99"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.213in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Rear
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
