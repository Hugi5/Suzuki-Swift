<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5206014" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Fifth Gear Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5206010">Manual Transaxle Unit Dismounting and Remounting</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5206013">Manual Transaxle Assembly Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5206014001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove gear shift &#38; select shaft assembly. 
<intxreftitleoff1 refid = "AENAP70B5206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove side cover bolts and take off transaxle side cover (1) using special tool.
</ptxt>
<attention2>
<ptxt>
Be sure not to distort side cover when it is removed from transaxle left case.
</ptxt>
</attention2>
<servicetool>
<servicetoolitem id = "L5B004">
<s-part>
(A)
</s-part>
<s-number num = "09921-96510">
09921–96510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure page = "2">
<graphic graphicname = "I9P60A522015.jpg" width = "88.000mm" height = "80.796mm" ver = "01" gw = "216" gh = "213"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Using snap ring pliers, remove circlip (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove 5th gear shift fork bolt (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove 5th gear shift fork (3) and 5th gear all together. Use gear puller for removal if spline fitting of hub is tight.
</ptxt>
<figure>
<graphic graphicname = "I4RH01520015.swf" width = "88.000mm" height = "50.320mm" ver = "01" gw = "184" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Unfasten caulking of countershaft nut (2), install input shaft 5th gear (1) and special tool to stop rotation of shafts, and then remove countershaft nut (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L5B005">
<s-part>
(A)
</s-part>
<s-number num = "09927-76060">
09927–76060
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I4RH01520016.swf" width = "88.000mm" height = "44.307mm" ver = "01" gw = "162" gh = "110"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Remove input shaft 5th gear, needle bearing and then countershaft 5th gear (1). Gear puller (2) would be necessary if spline fitting of countershaft 5th gear is tight.
</ptxt>
<figure>
<graphic graphicname = "I9P60A522016.swf" width = "88.000mm" height = "48.631mm" ver = "01" gw = "132" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5206014002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Install countershaft 5th gear (1) to countershaft as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520014.swf" width = "88.000mm" height = "47.995mm" ver = "01" gw = "137" gh = "120"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.370in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.370in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
 Countershaft side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[c]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
 Short flange (Outside)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[b]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
 Long flange (Inside)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Apply transaxle oil to needle bearing (3), and install it to input shaft.
</ptxt>
</s1>
<s1>
<ptxt>
Install input shaft 5th gear (1) to input shaft.
</ptxt>
</s1>
<s1>
<ptxt>
Install special tool to stop shaft rotation.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B006">
<s-part>
(A)
</s-part>
<s-number num = "09927-76060">
09927–76060
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Tighten countershaft nut (2) to specified torque, and caulk nut securely.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to use new countershaft nut.
</ptxt>
</item>
<item>
<ptxt>
Be sure not to crack caulking part (4) of countershaft nut while caulking it. Replace it with new one if it is cracked.
</ptxt>
</item>
</list1>
</attention2>
<torque>
<torqueitem id = "T5B010">
<t-part>
Countershaft nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
100
</t-value1>
<t-value2>
10.2
</t-value2>
<t-value3>
74.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A520015.swf" width = "88.000mm" height = "76.485mm" ver = "01" gw = "206" gh = "200"/>
</figure>
</s1>
<s1>
<ptxt>
Assemble 5th speed synchronizer sleeve (1), 5th speed synchronizer hub (2), 5th speed synchronizer levers (3) and 5th speed synchronizer ring (4) as follows.
</ptxt>
<figure>
<graphic graphicname = "I4RH01520054.swf" width = "88.000mm" height = "58.366mm" ver = "01" gw = "164" gh = "148"/>
</figure>
<s2>
<ptxt>
Install 5th speed synchronizer hub (1) to 5th speed synchronizer sleeve (2) in specified direction as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520016.swf" width = "88.000mm" height = "40.722mm" ver = "02" gw = "199" gh = "99"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.570in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.188in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Chamfered side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[b]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Long boss
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<c-change/>
<s2>
<ptxt>
Fit 5th speed synchronizer levers (1) to 5th speed synchronizer hub (2) by aligning protrusion (3) of 5th speed synchronizer levers (1) with groove of 5th speed synchronizer hub (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A522047.swf" width = "88.000mm" height = "46.997mm" ver = "01" gw = "125" gh = "117"/>
</figure>
</s2>
<s2>
<ptxt>
Install 5th speed synchronizer ring (1) to 5th speed synchronizer hub (2) in specified direction as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I4RH01520055.swf" width = "88.000mm" height = "47.169mm" ver = "01" gw = "83" gh = "118"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Fit 5th gear shift fork (1) to 5th speed synchronizer sleeve (3) and 5th speed synchronizer hub (2) assembly, and install them into input shaft and gear shift shaft by aligning punch mark (4) with matchmark (5) on input shaft.
</ptxt>
<figure>
<graphic graphicname = "I3RH0A520080.swf" width = "88.000mm" height = "105.991mm" ver = "01" gw = "170" gh = "283"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Tighten 5th gear shift fork bolt (2) to specified torque.
</ptxt>
<attention2>
<ptxt>
Be sure to use new 5th gear shift fork bolt with pre-coated adhesive. Otherwise, bolt may loosen.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T5B011">
<t-part>
5th gear shift fork bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Using snap ring pliers, install new circlip (1) to input shaft (3) in specified direction as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60A522050.swf" width = "88.000mm" height = "50.339mm" ver = "02" gw = "232" gh = "126"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.410in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.410in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
5th speed synchronizer hub
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Polished surface
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install side cover (1) to left case as follows.
</ptxt>
<s2>
<ptxt>
Clean mating surfaces of left case and side cover.
</ptxt>
</s2>
<s2>
<ptxt>
Apply specified amount of sealant to side cover as shown in figure.
</ptxt>
</s2>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M5B006" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<spec>
<title>
Sealant amount for side cover
</title>
<ptxt>
“a”: 1.5 mm (0.059 in.)
</ptxt>
</spec>
<s2>
<ptxt>
Mate side cover with left case.
</ptxt>
</s2>
<s2>
<ptxt>
Tighten side cover bolts to specified torque.
</ptxt>
</s2>
<torque>
<torqueitem id = "T5B012">
<t-part>
Side cover bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A520017.jpg" width = "88.000mm" height = "40.530mm" ver = "01" gw = "236" gh = "98"/>
</figure>
</s1>
<s1>
<ptxt>
Install gear shift &#38; select shaft assembly. 
<intxreftitleoff1 refid = "AENAP70B5206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
