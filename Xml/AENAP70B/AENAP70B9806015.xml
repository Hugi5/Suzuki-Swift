<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B9806015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1">
<title>
Rear Spoiler Removal and Installation
</title>
<servinfosub id = "AENAP70B9806015001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect washer hose (1) and rear end door harness connector (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove back door inner caps (3) and then remove nuts (4).
</ptxt>
</s1>
<s1>
<ptxt>
Remove back door spoiler caps (5) and then remove bolts (6).
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear spoiler (7).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IBP70A980005.swf" width = "88.000mm" height = "105.551mm" ver = "02" gw = "209" gh = "283"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70B9806015002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
When reinstalling rear spoiler (1), be sure to replace double-sided adhesive tape (2) with new one.
</ptxt>
<figure>
<graphic graphicname = "IBP70A980006.swf" width = "88.000mm" height = "39.726mm" ver = "01" gw = "189" gh = "96"/>
</figure>
</item>
<item>
<ptxt>
Tighten back door spoiler bolts and back door spoiler nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9H001">
<t-part>
Back door spoiler bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3.0
</t-value1>
<t-value2>
0.31
</t-value2>
<t-value3>
2.5
</t-value3>
</torqueitem>
<torqueitem id = "T9H002">
<t-part>
Back door spoiler nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A980007.swf" width = "88.000mm" height = "87.856mm" ver = "02" gw = "209" gh = "233"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
