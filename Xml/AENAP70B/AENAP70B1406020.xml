<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1406020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
OCV Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B1406017">Timing Chain Cover Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B1406020001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect OCV connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove OCV (1) from timing chain cover.
</ptxt>
<figure>
<graphic graphicname = "IAP70B140026.jpg" width = "88.000mm" height = "50.704mm" ver = "01" gw = "199" gh = "127"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1406020002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten OCV bolt to specified torque.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1D012">
<t-part>
OCV bolt
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
