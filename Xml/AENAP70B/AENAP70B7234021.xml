</servinfosub>
<servinfosub id = "AENAP70B7234021004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B7234021005">
<testgroup id = "AENAP70B7234021006">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition to “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “ON” and check DTC.
</ptxt>
</test1>
<question>
Is DTC B1541 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B7234021007">
<title>
Fuse check
</title>
<test1>
<ptxt>
Check “MTR” fuse.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace “MTR” fuse and check for short circuit to ground.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B7234021008">
<title>
Battery voltage supply circuit check
</title>
<test1>
<ptxt>
Disconnect “G20” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Measure voltage between “WHT/RED” wire terminal of “G20” connector and ground.
</ptxt>
</test1>
<question>
Is voltage 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace HVAC control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B7236011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
