<servinfosub id = "AENAP70B7234021003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition to “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition to “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition to “ON”.
