<servinfosub id = "AENAP70BA804003004">
<title>
Troubleshooting
</title>
<topic id = "AENAP70BA804003005">
<title>
Diagnosis flow: [a]
</title>
<diag type = "test" id = "AENAP70BA804003006">
<testgroup id = "AENAP70BA804003007">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to DLC and combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check CAN communication circuit [a] between DLC and combination meter connector for open circuit.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA804003008">
<title>
Combination meter terminating resistance check
</title>
<test1>
<ptxt>
Connect combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect ECM connector “E01”.
</ptxt>
</test1>
<test1>
<ptxt>
Measure resistance between “G211-11” and “G211-3” terminals of DLC.
</ptxt>
</test1>
<question>
Is resistance 114 – 134 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70BA804004">Troubleshooting for Communication Bus Off</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace combination meter and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</topic>
<topic id = "AENAP70BA804003009">
<title>
Diagnosis flow: [b]
</title>
<diag type = "test" id = "AENAP70BA804003010">
<testgroup id = "AENAP70BA804003011">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect combination meter connector and P/S control module connector “G50”.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check CAN communication circuit [b] between combination meter connector and P/S control module connector for open circuit.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace combination meter and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Repair or replace the following defective part.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
CAN communication circuit [b] is faulty between combination meter and J/C
</ptxt>
</item>
<item>
<ptxt>
J/C “G308” is faulty
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
</diag>
</topic>
<topic id = "AENAP70BA804003012">
<title>
Diagnosis flow: [c]
</title>
<diag type = "test" id = "AENAP70BA804003013">
<testgroup id = "AENAP70BA804003014">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect P/S control module connector “G50” and combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to P/S control module connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check CAN communication circuit [c] between P/S control module connector and combination meter connector for open circuit.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace P/S control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Repair or replace the following defective part.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
CAN communication circuit [c] is faulty between P/S control module and J/C
</ptxt>
</item>
