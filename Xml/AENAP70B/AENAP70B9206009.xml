<servinfo servinfosgmlid = "AENAP70B9206009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
High Mount Stop Light Removal and Installation
</title>
<servinfosub id = "AENAP70B9206009001">
<title>
Removal
</title>
<topic id = "AENAP70B9206009003">
<title>
Without rear spoiler
</title>
<s1>
<ptxt>
Remove high mount stop light nuts (1) and rear washer hose (2), and then remove high mount stop light.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect high mount stop light connector.
</ptxt>
</s1>
<s1>
<ptxt>
If necessary, remove bulbs (3).
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A920014.swf" width = "88.000mm" height = "58.134mm" ver = "02" gw = "210" gh = "148"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.210in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.613in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.219in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.153in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Rear washer nozzle
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Bulb housing
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</topic>
<topic id = "AENAP70B9206009004">
<title>
With rear spoiler
</title>
<attention3>
<ptxt>
High mount stop light bulb is LED.
</ptxt>
<ptxt>
High mount stop light bulb is an integral part of high mount stop light assembly. Replace high mount stop light assembly if high mount stop light bulb is defective.
</ptxt>
</attention3>
<s1>
<ptxt>
Remove rear spoiler. 
<intxreftitleoff1 refid = "AENAP70B9806015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove high mount stop light screws (1), and then remove high mount stop light (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B920014.swf" width = "88.000mm" height = "50.694mm" ver = "01" gw = "226" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect high mount stop light connector (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B920015.swf" width = "88.000mm" height = "50.065mm" ver = "01" gw = "226" gh = "125"/>
</figure>
</s1>
</topic>
</servinfosub>
<servinfosub id = "AENAP70B9206009002">
<title>
Installation
</title>
<topic id = "AENAP70B9206009005">
<title>
Without rear spoiler
</title>
<ptxt>
Reverse removal procedure nothing the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten high mount stop light nuts to specified torque.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9B002">
<t-part>
High mount stop light nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
2.0
</t-value1>
<t-value2>
0.20
</t-value2>
<t-value3>
1.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A920004.swf" width = "88.000mm" height = "57.133mm" ver = "01" gw = "210" gh = "145"/>
</figure>
</topic>
<topic id = "AENAP70B9206009006">
<title>
With rear spoiler
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
