<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B7224A19" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Large rattling noise is heard at idle or sudden acceleration
</title>
<servinfosub id = "AENAP70B7224004009">
<title>
Abnormal Noise from Crankshaft Pulley
</title>
<diag type = "condition">
<condition>
<ptxt>
Large rattling noise is heard at idle or sudden acceleration
</ptxt>
</condition>
<ps>
<ptxt>
Loosen crankshaft pulley bolt
</ptxt>
</ps>
<action>
<ptxt>
Retighten crankshaft pulley bolt. 
<intxreftitleoff1 refid = "AENAP70B1406017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
