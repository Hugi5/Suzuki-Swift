<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B3126003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Wheel Hub Assembly Removal and Installation
</title>
<servinfosub id = "AENAP70B3126003001">
<title>
Removal
</title>
<s1>
<ptxt>
Hoist vehicle and remove rear wheel. 
<intxreftitleoff1 refid = "AENAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear brake drum. 
<intxreftitleoff1 refid = "AENAP70B4316003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear wheel speed sensor from rear wheel hub assembly.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
ABS model: 
<intxreftitleoff1 refid = "AENAP70B4506008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup> model: 
<intxreftitleoff1 refid = "AENAP70B4606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove rear wheel hub bolts (1), then remove rear brake shoe assembly and rear wheel hub.
</ptxt>
<attention2>
<ptxt>
To prevent deformation of brake pipe, hang removed rear brake shoe assembly using wire.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I9P60A312002.swf" width = "88.000mm" height = "47.897mm" ver = "02" gw = "172" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Remove hub bolts (1) with hydraulic press, if necessary.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312010.jpg" width = "88.000mm" height = "54.842mm" ver = "01" gw = "173" gh = "139"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B3126003002">
<title>
Installation
</title>
<s1>
<ptxt>
Insert hub bolts (1) in hub holes. Rotate hub bolts slowly to assure that serrations are aligned with those made by original bolts.
</ptxt>
<figure>
<graphic graphicname = "IAP70B312002.jpg" width = "88.000mm" height = "50.374mm" ver = "03" gw = "171" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Install rear brake shoe assembly (1) and rear wheel hub assembly and tighten new rear wheel hub bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T3A203">
<t-part>
Wheel hub bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
82
</t-value1>
<t-value2>
8.4
</t-value2>
<t-value3>
60.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A312003.swf" width = "88.000mm" height = "47.897mm" ver = "02" gw = "186" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Install rear wheel speed sensor.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
ABS model: 
<intxreftitleoff1 refid = "AENAP70B4506008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup> model: 
<intxreftitleoff1 refid = "AENAP70B4606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Install rear brake drum. 
<intxreftitleoff1 refid = "AENAP70B4316003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install rear wheel. 
<intxreftitleoff1 refid = "AENAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Confirm rear wheel alignment. 
<intxreftitleoff1 refid = "AENAP70B2306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
