<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B6306010" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pinion Shaft Rotation Torque Adjustment
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Perform pinion shaft rotation torque adjustment with rack stroke position is centered (steering wheel is at straight-ahead position).
</ptxt>
</item>
<item>
<ptxt>
Do not remove rack damper screw lock nut (1) and rack damper screw (2) so as to prevent damage to rack damper screw lock nut (1) and rack damper screw (2).
</ptxt>
</item>
<item>
<ptxt>
Rack damper screw and rack damper screw lock nut are not individually supplied as spare parts. Be careful not to damage or lose them.
</ptxt>
</item>
</list1>
</attention2>
<s1>
<ptxt>
Remove steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70B6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering rack boots. 
<intxreftitleoff1 refid = "AENAP70B6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Loosen rack damper screw lock nut (1).
</ptxt>
</s1>
<s1>
<ptxt>
Loosen rack damper screw (2).
</ptxt>
</s1>
<s1>
<ptxt>
Apply sealant “A” to rack damper screw (2) and then tighten them as follows.
</ptxt>
<s2>
<ptxt>
Tighten rack damper screw to 25 N&#183;m (2.5 kgf-m, 18.5 lbf-ft).
</ptxt>
</s2>
<s2>
<ptxt>
Loosen rack damper screw until 0 N&#183;m (0 kgf-m, 0 lbf-ft).
</ptxt>
</s2>
<s2>
<ptxt>
Retighten rack damper screw to 12 N&#183;m (1.2 kgf-m, 9.0 lbf-ft).
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1215" id = "M6C002" uid = "27">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31110
</m-number>
<m-name>
SUZUKI Bond No.1215
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<torque>
<torqueitem id = "T6C004">
<t-part>
Rack damper screw*
</t-part>
<t-part1>
a
</t-part1>
<t-note>
Tighten 25 N&#183;m (2.5 kgf-m, 18.5 lbf-ft) &#8594; 0 N&#183;m (0 kgf-m, 0 lbf-ft) &#8594; 12 N&#183;m (1.2 kgf-m, 9.0 lbf-ft)
</t-note>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70B630005.swf" width = "88.000mm" height = "56.968mm" ver = "01" gw = "120" gh = "145"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Tighten or loosen rack damper screw so as to adjust pinion rotation torque to specified torque using special tool. 
<intxreftitleoff1 refid = "AENAP70B6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Tighten rack damper screw lock nut.
</ptxt>
<torque>
<torqueitem id = "T6C005">
<t-part>
Rack damper screw lock nut
</t-part>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Recheck pinion rotation torque is as specified. 
<intxreftitleoff1 refid = "AENAP70B6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install steering rack boots. 
<intxreftitleoff1 refid = "AENAP70B6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70B6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
