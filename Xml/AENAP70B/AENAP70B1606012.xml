<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Radiator Cooling Fan Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B1606010">Radiator Cooling Fan Assembly On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B1606012001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENAP70B1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect radiator cooling fan motor connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove reservoir (2).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect radiator inlet hose (3) from radiator.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160005.swf" width = "88.000mm" height = "70.920mm" ver = "01" gw = "221" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Remove radiator cooling fan assembly from radiator.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B1606012002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENAP70B1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check cooling system for leakage. 
<intxreftitleoff1 refid = "AENAP70B1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
