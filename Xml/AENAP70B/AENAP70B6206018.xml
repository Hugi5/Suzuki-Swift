<section sectnbr = "6B">
<servcat sctnbr = "06" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B6206018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Ignition Switch Removal and Installation (Ignition Switch Model)
</title>
<servinfosub id = "AENAP70B6206018001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering column upper cover and lower cover. 
<intxreftitleoff1 refid = "AENAP70B6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Confirm that ignition key is removed.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector (1) from ignition switch (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (4), then remove ignition switch (2) from steering lock (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A620036.jpg" width = "88.000mm" height = "54.155mm" ver = "05" gw = "237" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B6206018002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B6206019">Ignition Switch Inspection (Ignition Switch Model)</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
