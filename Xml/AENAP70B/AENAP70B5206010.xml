<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Manual Transaxle Unit Dismounting and Remounting
</title>
<servinfosub id = "AENAP70B5206010001" page = "2">
<title>
Dismounting
</title>
<s1>
<ptxt>
Open engine hood as wide as possible and hold it using rope.
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery and battery tray with ECM. 
<intxreftitleoff1 refid = "AENAP70B1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENAP70B1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect back up light switch connector and release wiring harness clamps. 
<intxreftitleoff1 refid = "AENAP70B5206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect gear shift and gear select control cables from transaxle. 
<intxreftitleoff1 refid = "AENAP70B5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove clutch operating cylinder. 
<intxreftitleoff1 refid = "AENAP70B5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove ground cable from transaxle.
</ptxt>
</s1>
<s1>
<ptxt>
Remove left side engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Drain transaxle oil. 
<intxreftitleoff1 refid = "AENAP70B5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove the following parts.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front Drive Shaft: 
<intxreftitleoff1 refid = "AENAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Drive intermediate shaft: 
<intxreftitleoff1 refid = "AENAP70B3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Hang up engine with hoisting devise (1) so that engine does not tilt.
</ptxt>
<figure>
<graphic graphicname = "I9P60A521061.swf" width = "88.000mm" height = "62.506mm" ver = "01" gw = "226" gh = "161"/>
</figure>
</s1>
<s1>
<ptxt>
Support transaxle with transmission jack.
</ptxt>
</s1>
<s1>
<ptxt>
Remove starting motor. 
<intxreftitleoff1 refid = "AENAP70B1906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove transaxle-to-engine bolts (1) of upper side.
</ptxt>
<figure>
<graphic graphicname = "I9P60A521058.swf" width = "88.000mm" height = "68.265mm" ver = "01" gw = "222" gh = "177"/>
</figure>
</s1>
<s1>
<ptxt>
Remove engine left mounting bracket. 
<intxreftitleoff1 refid = "AENAP70B1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove engine rear mounting bolts (3), transaxle-to-engine bolts (1) and nut (2) of lower side, and then lower transaxle.
</ptxt>
<figure>
<graphic graphicname = "I9P60A521062.swf" width = "88.000mm" height = "116.955mm" ver = "02" gw = "235" gh = "315"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.265in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.265in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Right side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Left side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Pull out transaxle from engine so as to disconnect input shaft from clutch disc.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5206010002" page = "2">
<title>
Remounting
</title>
<ptxt>
Reverse dismounting procedure, noting the following points.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Be careful not to damage differential side oil seal and transfer side oil seal while reinstalling drive shafts.
</ptxt>
</item>
<item>
<ptxt>
Do not hit drive shaft joint with hammer when installing it into differential gear and intermediate shaft.
</ptxt>
</item>
</list1>
</attention2>
<list1 type = "unordered">
<item>
<ptxt>
Tighten engine rear mounting bracket bolts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten intermediate support bolts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten front drive shaft nuts to specified torque, and caulk drive shaft nuts. 
<intxreftitleoff1 refid = "AENAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Be sure to use new drive shaft nut.
</ptxt>
</attention2>
<list1 type = "unordered">
<item>
<ptxt>
Tighten suspension arm ball joint bolts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten tie-rod end nuts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten front wheel speed sensor bolts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten exhaust pipe bolts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten wheel nuts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten air cleaner outlet hose band to specified torque. 
<intxreftitleoff1 refid = "AENAP70B1406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Set each clamp for wiring securely.
</ptxt>
</item>
<item>
<ptxt>
Replenish transaxle oil. 
<intxreftitleoff1 refid = "AENAP70B5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bleed air from clutch system. 
<intxreftitleoff1 refid = "AENAP70B5306007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check function of engine, clutch and transaxle.
</ptxt>
</item>
<item>
<ptxt>
Verify that there is no oil leakage, fluid leakage and exhaust gas leakage at each connection.
</ptxt>
</item>
<item>
<ptxt>
Confirm front wheel alignment. 
<intxreftitleoff1 refid = "AENAP70B2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
