<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4C">
<servcat sctnbr = "04" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B4326003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Rear Brake Pad Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B4326001">Rear Brake Components:Disc Brake Model</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B4326002">Rear Brake Pad On-Vehicle Inspection:Disc Brake Model</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Be careful not to damage rear brake flexible hoses.
</ptxt>
</item>
<item>
<ptxt>
Never depress brake pedal during service operation shown below.
</ptxt>
</item>
</list1>
</attention2>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Check for leakage of brake fluid when removing rear brake pads and repair rear brake caliper if leakage is found.
</ptxt>
</item>
<item>
<ptxt>
Replace all rear brake pads at the same time even if only one rear brake pad is defective.
</ptxt>
</item>
</list1>
</attention3>
<servinfosub id = "AENAP70B4326003001">
<title>
Removal
</title>
<s1>
<ptxt>
Release parking brake.
</ptxt>
</s1>
<s1>
<ptxt>
Remove floor console rear box. 
<intxreftitleoff1 refid = "AENAP70B9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear brake caliper pin bolts (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A430003.swf" width = "88.000mm" height = "57.384mm" ver = "01" gw = "162" gh = "146"/>
</figure>
</s1>
<s1>
<ptxt>
Remove rear brake caliper (1) from rear brake caliper carrier (2).
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Hang removed rear brake caliper (1) with a wire hook (4) to prevent rear brake flexible hose from bending, twisting excessively or being pulled.
</ptxt>
</item>
<item>
<ptxt>
Do not operate brake pedal with rear brake pads removed.
</ptxt>
</item>
</list1>
</attention3>
</s1>
<s1>
<ptxt>
Remove rear brake pads with shims (3) and pad springs (5) from rear brake caliper carrier (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A430004.swf" width = "88.000mm" height = "72.122mm" ver = "01" gw = "147" gh = "188"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B4326003002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B4326004">Rear Brake Pad Inspection:Disc Brake Model</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B4326009">Rear Brake Caliper Inspection:Disc Brake Model</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install pad springs (1) to rear brake caliper carrier (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A430005.swf" width = "88.000mm" height = "50.167mm" ver = "01" gw = "146" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Fit shims (1) to rear brake pads (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432009.swf" width = "88.000mm" height = "46.879mm" ver = "01" gw = "215" gh = "116"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.861in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.861in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Inner
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Outer
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install rear brake pads with shims (1) to rear brake caliper carrier (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A430006.swf" width = "88.000mm" height = "72.122mm" ver = "01" gw = "147" gh = "188"/>
</figure>
<attention3>
<ptxt>
Be sure to install inner rear brake pad at inside of caliper carrier with its wear indicator (1) positioned rearward.
</ptxt>
<figure>
<graphic graphicname = "I9P60A432041.swf" width = "88.000mm" height = "28.375mm" ver = "01" gw = "167" gh = "64"/>
</figure>
</attention3>
</s1>
<s1>
<ptxt>
Turn brake piston (1) in arrow direction by a quarter to half turn using special tool to screw brake piston into cylinder.
</ptxt>
<servicetool>
<servicetoolitem id = "L4C203">
<s-part>
(A)
</s-part>
<s-number num = "09945-16030">
09945–16030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A432011.swf" width = "88.000mm" height = "45.775mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Install rear brake caliper while aligning slot of brake piston (2) with protrusion at back of rear brake pad (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432012.swf" width = "88.000mm" height = "52.506mm" ver = "01" gw = "166" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Install rear brake caliper (1) to rear brake caliper carrier and tighten rear brake caliper pin bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4C204">
<t-part>
Rear brake caliper pin bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
26
</t-value1>
<t-value2>
2.7
</t-value2>
<t-value3>
19.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A430007.swf" width = "88.000mm" height = "57.650mm" ver = "01" gw = "162" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Depress brake pedal three times or more with engine running to activate rear brake pad clearance adjustment mechanism so that clearance between rear brake disc and rear brake pad will be appropriate.
</ptxt>
</s1>
<s1>
<ptxt>
Install rear wheel and check that parking brake lever stroke is appropriate and parking brake produces proper braking force. 
<intxreftitleoff1 refid = "AENAP70B4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
