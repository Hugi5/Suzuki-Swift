<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
A/T Oil Strainer Assembly Removal and Installation
</title>
<servinfosub id = "AENAP70B5106022001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Hoist vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Drain A/T fluid. 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove A/T oil pan (1) and oil pan gasket (2).
</ptxt>
<attention3>
<ptxt>
When removing A/T oil pan, tap around it lightly with plastic hammer. Do not force it off by using flat-bladed screwdriver or the like.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Remove oil strainer assembly (3).
</ptxt>
<figure>
<graphic graphicname = "I7V10A510041.swf" width = "88.000mm" height = "99.726mm" ver = "01" gw = "186" gh = "266"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B5106022002">
<title>
Installation 
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106023">A/T Oil Pan and Oil Strainer Assembly Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
When overhauling A/T, replace oil strainer (1) and its gasket with new one.
</ptxt>
</item>
<item>
<ptxt>
Tighten oil strainer bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5A009">
<t-part>
Oil strainer bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V10A510042.swf" width = "88.000mm" height = "48.841mm" ver = "01" gw = "173" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Use new oil pan gasket (1) for A/T oil pan (2).
</ptxt>
</item>
<item>
<ptxt>
Tighten oil pan bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5A010">
<t-part>
Oil pan bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
7.0
</t-value1>
<t-value2>
0.71
</t-value2>
<t-value3>
5.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V10A510043.swf" width = "88.000mm" height = "53.667mm" ver = "01" gw = "185" gh = "135"/>
</figure>
</item>
<item>
<ptxt>
Replenish ATF. 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check fluid level. 
<intxreftitleoff1 refid = "AENAP70B5106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check for fluid leakage after warming up A/T.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
