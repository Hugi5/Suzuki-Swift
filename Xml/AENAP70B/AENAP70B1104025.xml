<servinfosub id = "AENAP70B1104025001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.872in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.303in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0131: O2 Sensor Circuit Low Voltage (sensor 1)
</emph>
</ptxt>
<ptxt>
Any of the following conditions is met. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Output voltage of HO2S-1 circuit stays lower than 0.06 V from cold engine start to engine warmed up.
</ptxt>
</item>
<item>
<ptxt>
Output voltage of HO2S-2 circuit is higher than 0.6 V and output voltage of HO2S-1 circuit is lower than 0.06 V for 15 sec.
</ptxt>
</item>
</list1>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
HO2S-1 and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
P0132: O2 Sensor Circuit High Voltage (sensor 1)
</emph>
</ptxt>
<ptxt>
Output voltage of HO2S-1 circuit is higher than 1.08 V for 5 sec.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
