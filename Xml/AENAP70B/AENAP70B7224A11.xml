<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B7224A11" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Insufficient cool air flow
</title>
<diag type = "condition">
<condition>
<ptxt>
Insufficient cool air flow
</ptxt>
</condition>
<ps>
<ptxt>
Clogged or frosted A/C evaporator
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check A/C evaporator. 
<intxreftitleoff1 refid = "AENAP70B7226014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty evaporator temperature sensor
</ptxt>
</ps>
<action>
<ptxt>
Check evaporator temperature sensor. 
<intxreftitleoff1 refid = "AENAP70B7226016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Air leaking from HVAC unit or air duct
</ptxt>
</ps>
<action>
<ptxt>
Repair HVAC unit or air duct.
</ptxt>
</action>
<ps>
<ptxt>
Faulty blower motor
</ptxt>
</ps>
<action>
<ptxt>
Check blower motor. 
<intxreftitleoff1 refid = "AENAP70B7226011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
