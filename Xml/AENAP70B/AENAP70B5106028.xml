<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106028" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Solenoid Valve Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106027">Solenoid Valve On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5106028001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Hoist vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Drain A/T fluid. 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install ATF drain plug. 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove A/T oil pan and oil strainer assembly. 
<intxreftitleoff1 refid = "AENAP70B5106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove ATF temperature sensor (1) from sensor clamp.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect solenoid connectors (2).
</ptxt>
<figure>
<graphic graphicname = "I4RS0A510027.swf" width = "88.000mm" height = "59.491mm" ver = "01" gw = "136" gh = "152"/>
</figure>
</s1>
<s1>
<ptxt>
Remove shift solenoid valve “A” (1), shift solenoid valve “B” (2) and timing solenoid valve (3) by removing bolts.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A510028.swf" width = "88.000mm" height = "53.224mm" ver = "01" gw = "110" gh = "135"/>
</figure>
</s1>
<s1>
<ptxt>
Remove valve body assembly. 
<intxreftitleoff1 refid = "AENAP70B5106026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B5106028002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106029">Solenoid Valve Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install solenoid valves. 
<intxreftitleoff1 refid = "AENAP70B5106059"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install valve body assembly. 
<intxreftitleoff1 refid = "AENAP70B5106026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect solenoid connectors identifying their installing positions by wire color.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.164in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.309in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Solenoid coupler
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Wire color
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "left">
<ptxt>
Shift solenoid valve “A” (2)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
White
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "left">
<ptxt>
Shift solenoid valve “B” (3)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Black
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "left">
<ptxt>
Timing solenoid valve (1)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Yellow
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "left">
<ptxt>
TCC pressure control solenoid valve (4)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Light green / Brown
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Pressure control solenoid valve (5)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Green / Gray
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</s1>
<s1>
<ptxt>
Install ATF temperature sensor (6) and sensor wire to clamp.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A510030.swf" width = "88.000mm" height = "59.798mm" ver = "01" gw = "140" gh = "153"/>
</figure>
</s1>
<s1>
<ptxt>
Install A/T oil pan and oil strainer assembly. 
<intxreftitleoff1 refid = "AENAP70B5106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Lower vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Replenish proper amount of specified ATF. 
<intxreftitleoff1 refid = "AENAP70B5101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check fluid level. 
<intxreftitleoff1 refid = "AENAP70B5106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<c-change/>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
