<servinfosub id = "AENAP70B5104048002">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENAP70B5104048003">
<testgroup id = "AENAP70B5104048004">
<title>
Back up power supply circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF” and disconnect connectors from TCM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to TCM connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check that voltage between back up power supply circuit (A1) and ground is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104048005">
<title>
A/T relay power supply circuit check
</title>
<test1>
<ptxt>
Remove A/T relay.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection for A/T relay connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check that voltage between A/T relay power supply circuit (switch side) (B1) and ground is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104048006">
<title>
A/T relay power supply circuit check
</title>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between A/T relay power supply circuit (coil side) (B2) and ground is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104048007">
<title>
A/T relay ground circuit check
</title>
<test1>
<ptxt>
Check that voltage between A/T relay power supply circuit (coil side) (B2) and ground circuit (B3) is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104048008">
<title>
A/T relay check
</title>
<test1>
<ptxt>
Check A/T relay. 
<intxreftitleoff1 refid = "AENAP70B5106031"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace A/T relay.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104048009">
<title>
Main power supply circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF” and install A/T relay.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between main power supply circuit (A2) and ground is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104048010">
<title>
TCM ground circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that resistance between each TCM ground circuit 1 (C2) and ground circuit 2 (C2) and ground is less than 1 Ω.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
TCM power and ground circuit is in good condition.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
