<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "3">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B7236023" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Temperature Control Actuator Removal and Installation
</title>
<servinfosub id = "AENAP70B7236023001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENAP70B8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering column hole cover. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove knee air bag (Inflator) module (if equipped). 
<intxreftitleoff1 refid = "AENAP70B8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (1), then remove temperature control actuator (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A722007.jpg" width = "88.000mm" height = "63.150mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B7236023002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B7236024">Temperature Control Actuator Inspection:Automatic Type</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, nothing following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to insert temperature control actuator arm pin (1) into groove (2) of linkage.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722008.swf" width = "88.000mm" height = "63.358mm" ver = "01" gw = "141" gh = "163"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
