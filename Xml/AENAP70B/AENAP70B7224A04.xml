<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B7224A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Warm air does not come out or insufficient heating (Faulty temperature control)
</title>
<diag type = "condition">
<condition>
<ptxt>
Warm air does not come out or insufficient heating (Faulty temperature control)
</ptxt>
</condition>
<ps>
<ptxt>
Broken or bent temperature control cable
</ptxt>
</ps>
<action>
<ptxt>
Check temperature control cable.
</ptxt>
</action>
<ps>
<ptxt>
Faulty temperature selector
</ptxt>
</ps>
<action>
<ptxt>
Check temperature selector.
</ptxt>
</action>
<ps>
<ptxt>
Incorrect installation of temperature control cable
</ptxt>
</ps>
<action>
<ptxt>
Check position of cable and adjust it if necessary.
</ptxt>
</action>
<ps>
<ptxt>
Broken temperature control door assembly
</ptxt>
</ps>
<action>
<ptxt>
Repair temperature control door assembly.
</ptxt>
</action>
<ps>
<ptxt>
Clogged air ducts
</ptxt>
</ps>
<action>
<ptxt>
Repair air ducts.
</ptxt>
</action>
<ps>
<ptxt>
Leaky or clogged heater core
</ptxt>
</ps>
<action>
<ptxt>
Replace heater core.
</ptxt>
</action>
<ps>
<ptxt>
Leaky or clogged heater hoses
</ptxt>
</ps>
<action>
<ptxt>
Replace heater hoses.
</ptxt>
</action>
<ps>
<ptxt>
Faulty thermostat
</ptxt>
</ps>
<action>
<ptxt>
Check thermostat. 
<intxreftitleoff1 refid = "AENAP70B1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECT Sensor
</ptxt>
</ps>
<action>
<ptxt>
Check ECT sensor. 
<intxreftitleoff1 refid = "AENAP70B1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
