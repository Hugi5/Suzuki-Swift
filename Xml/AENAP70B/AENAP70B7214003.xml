<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B7214003" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Heater and Ventilation Symptom Diagnosis
</title>
<diag type = "condition" id = "AENAP70B7214003001">
<condition>
<ptxt>
Blower motor does not operate
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Check related fuses, and then check for short circuit to ground.
</ptxt>
</action>
<ps>
<ptxt>
Faulty blower motor relay
</ptxt>
</ps>
<action>
<ptxt>
Check blower motor relay. 
<intxreftitleoff1 refid = "AENAP70B7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty blower motor resistor
</ptxt>
</ps>
<action>
<ptxt>
Check blower motor resistor. 
<intxreftitleoff1 refid = "AENAP70B7216011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty blower speed selector
</ptxt>
</ps>
<action>
<ptxt>
Check blower speed selector. 
<intxreftitleoff1 refid = "AENAP70B7216023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty blower motor
</ptxt>
</ps>
<action>
<ptxt>
Check blower motor. 
<intxreftitleoff1 refid = "AENAP70B7216009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Foreign material present
</ptxt>
</ps>
<action>
<ptxt>
Remove foreign material.
</ptxt>
</action>
<condition>
<ptxt>
Air outlets do not change or do not agree with air flow selector’s position even if air flow selector is changed
</ptxt>
</condition>
<ps>
<ptxt>
Broken or bent air flow control cable
</ptxt>
</ps>
<action>
<ptxt>
Check air flow control cable.
</ptxt>
</action>
<ps>
<ptxt>
Faulty air flow selector
</ptxt>
</ps>
<action>
<ptxt>
Check air flow selector.
</ptxt>
</action>
<ps>
<ptxt>
Incorrect installation of air flow control cable
</ptxt>
</ps>
<action>
<ptxt>
Check position of cable and adjust it if necessary.
</ptxt>
</action>
<ps>
<ptxt>
Broken air flow control door assembly
</ptxt>
</ps>
<action>
<ptxt>
Repair air flow control door assembly.
</ptxt>
</action>
<ps>
<ptxt>
Leaked or clogged air ducts
</ptxt>
</ps>
<action>
<ptxt>
Repair air ducts.
</ptxt>
</action>
<condition>
<ptxt>
Air intake door does not change even if air intake mode is changed
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Check related fuses and check for short circuit to ground.
</ptxt>
</action>
<ps>
<ptxt>
Broken air intake door
</ptxt>
</ps>
<action>
<ptxt>
Repair air intake door.
</ptxt>
</action>
<ps>
<ptxt>
Faulty air intake control actuator
</ptxt>
</ps>
<action>
<ptxt>
Check air intake control actuator. 
<intxreftitleoff1 refid = "AENAP70B7216028"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty air intake switch
</ptxt>
</ps>
<action>
<ptxt>
Check air intake switch. 
<intxreftitleoff1 refid = "AENAP70B7216026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<condition>
<ptxt>
Warm air does not come out or insufficient heating (Faulty temperature control)
</ptxt>
</condition>
<ps>
<ptxt>
Broken or bent temperature control cable
</ptxt>
</ps>
<action>
<ptxt>
Check temperature control cable.
</ptxt>
</action>
<ps>
<ptxt>
Faulty temperature selector
</ptxt>
</ps>
<action>
<ptxt>
Check temperature selector.
</ptxt>
</action>
<ps>
<ptxt>
Incorrect installation of temperature control cable
</ptxt>
</ps>
<action>
<ptxt>
Check position of cable and adjust it if necessary.
</ptxt>
</action>
<ps>
<ptxt>
Broken temperature control door assembly
</ptxt>
</ps>
<action>
<ptxt>
Repair temperature control door assembly.
</ptxt>
</action>
<ps>
<ptxt>
Clogged air ducts
</ptxt>
</ps>
<action>
<ptxt>
Repair air ducts.
</ptxt>
</action>
<ps>
<ptxt>
Leaky or clogged heater core
</ptxt>
</ps>
<action>
<ptxt>
Replace heater core.
</ptxt>
</action>
<ps>
<ptxt>
Leaky or clogged heater hoses
</ptxt>
</ps>
<action>
<ptxt>
Replace heater hoses.
</ptxt>
</action>
<ps>
<ptxt>
Faulty thermostat
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check thermostat. 
<intxreftitleoff1 refid = "AENAP70B1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
