<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B9404A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Washer malfunctions
</title>
<servinfosub id = "AENAP70B9404002003">
<title>
Rear Wiper and Washer
</title>
<diag type = "condition">
<condition>
<ptxt>
Washer malfunctions
</ptxt>
</condition>
<ps>
<ptxt>
Faulty washer hose (including check valve and connector) or washer nozzle
</ptxt>
</ps>
<action>
<ptxt>
Check washer hose or washer nozzle for clogging and bend.
</ptxt>
</action>
<ps>
<ptxt>
Faulty washer pump
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9406002">Washer Pump Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiper and washer switch (washer switch)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9406008">Wiper and Washer Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
