<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B9604A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
All door cannot be locked / unlocked by only keyless entry transmitter or remote controller
</title>
<diag type = "condition">
<condition>
<ptxt>
All door cannot be locked / unlocked by only keyless entry transmitter or remote controller
</ptxt>
</condition>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Refer to “Inspection of BCM and Its Circuits” in Section 10B.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENAP70BA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENAP70BA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Faulty keyless start control module (Keyless push start model)
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENAP70BA504031">Inspection of Keyless Start Control Module and Its Circuits</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Faulty transmitter (Ignition switch model)
</ptxt>
</ps>
<action>
<ptxt>
Replace battery. 
<intxreftitleoff1 refid = "AENAP70B9606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty remote controller (Keyless push start model)
</ptxt>
</ps>
<action>
<ptxt>
Replace battery. 
<intxreftitleoff1 refid = "AENAP70BA506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty keyless entry receiver
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENAP70B9606016">Keyless Entry Receiver Inspection</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
