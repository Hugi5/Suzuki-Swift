<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5104A12" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Excessive “N” → “D” or “N” → “R” time lag
</title>
<servinfosub id = "AENAP70B5104017001">
<title>
Trouble Diagnosis 1
</title>
<topic id = "AENAP70B5104017002">
<title>
Electrical repair
</title>
<diag type = "condition">
<condition>
<ptxt>
Excessive “N” → “D” or “N” → “R” time lag
</ptxt>
</condition>
<ps>
<ptxt>
Pressure control solenoid valve circuit faulty
</ptxt>
</ps>
<action>
<ptxt>
Inspect pressure control solenoid valve circuit for open, short and intermittent failure. If NG, repair pressure control solenoid valve circuit. 
</ptxt>
</action>
<ps>
<ptxt>
ATF temperature sensor circuit faulty
</ptxt>
</ps>
<action>
<ptxt>
Inspect ATF temperature sensor circuit for open, short and intermittent failure. If NG, repair ATF temperature sensor circuit. 
</ptxt>
</action>
<ps>
<ptxt>
TCM
</ptxt>
</ps>
<action>
<ptxt>
Substitute a known-good TCM and recheck.
</ptxt>
</action>
</diag>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
