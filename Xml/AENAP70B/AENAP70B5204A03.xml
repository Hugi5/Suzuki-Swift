<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5204A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Noise
</title>
<diag type = "condition">
<condition>
<ptxt>
Noise
</ptxt>
</condition>
<ps>
<ptxt>
Inadequate or insufficient lubricant
</ptxt>
</ps>
<action>
<ptxt>
Replenish manual transaxle oil.
</ptxt>
</action>
<ps>
<ptxt>
Damaged or worn bearing(s)
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace bearing.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Counter shaft left bearing:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Inner race: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Outer race: 
<intxreftitleoff1 refid = "AENAP70B5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Counter shaft right bearing:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Inner race: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Outer race: 
<intxreftitleoff1 refid = "AENAP70B5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Input shaft left bearing and right bearing: 
<intxreftitleoff1 refid = "AENAP70B5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Differential side bearing:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Inner race: 
<intxreftitleoff1 refid = "AENAP70B5206025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Right side outer race: 
<intxreftitleoff1 refid = "AENAP70B5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Left side outer race: 
<intxreftitleoff1 refid = "AENAP70B5206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Needle bearing:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Counter shaft 1st gear and 2nd gear: 
<intxreftitleoff1 refid = "AENAP70B5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Input shaft 3rd gear and 4th gear: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5th gear: 
<intxreftitleoff1 refid = "AENAP70B5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
</list1>
</action>
<ps>
<ptxt>
Damaged or worn gear(s)
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace gear.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Counter shaft 1st gear, 2nd gear, 3rd gear and 4th gear: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Input shaft 1st gear, 2nd gear, 3rd gear and 4th gear: 
<intxreftitleoff1 refid = "AENAP70B5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Input shaft 5th gear and counter shaft 5th gear: 
<intxreftitleoff1 refid = "AENAP70B5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Damaged or worn synchronizer parts
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace synchronizer parts.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Low speed synchronizer parts: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
High speed synchronizer parts: 
<intxreftitleoff1 refid = "AENAP70B5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5th speed synchronizer parts: 
<intxreftitleoff1 refid = "AENAP70B5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
