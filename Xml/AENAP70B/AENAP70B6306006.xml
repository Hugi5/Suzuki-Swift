<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B6306006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Steering Gear Case Bushing Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B6306001">Steering Gear Case Assembly Components</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
When replacing steering gear case bushing, also replace bushings on the other side as set.
</ptxt>
</attention2>
<servinfosub id = "AENAP70B6306006001">
<title>
Removal 
</title>
<s1>
<ptxt>
Remove steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70B6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Cut off flange (rubber) part (1) of each steering gear case bushing using knife.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630023.swf" width = "88.000mm" height = "51.406mm" ver = "01" gw = "234" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Push out steering gear case bushing (1) using hydraulic press (2) and special tools.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C004">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943–76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C005">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913–75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630024.swf" width = "88.000mm" height = "49.527mm" ver = "01" gw = "104" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B6306006002">
<title>
Installation
</title>
<s1>
<ptxt>
Press-fit new steering gear case bushing (1) using special tools and hydraulic press (2).
</ptxt>
<attention2>
<ptxt>
Do not reuse steering gear case bushing.
</ptxt>
</attention2>
<servicetool>
<servicetoolitem id = "L6C006">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943–76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C007">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913–75821
</s-number>
</servicetoolitem>
</servicetool>
<attention3>
<ptxt>
Before installing steering gear case bushing, apply soapy water on its circumference to facilitate installation.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A630025.swf" width = "88.000mm" height = "51.452mm" ver = "01" gw = "104" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Press-fit steering gear case bushing (1) so that dimensions “a” and “b” in figure become equal.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Install steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70B6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
