<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0722: Output Speed Sensor Circuit No Signal
</emph>
</ptxt>
<ptxt>
Output shaft speed signal is not input even if input shaft speed signal is input.
</ptxt>
<ptxt>
(1 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Output shaft speed sensor and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
Sensor gear (drive gear)
</ptxt>
</item>
<item>
<ptxt>
TCM
</ptxt>
</item>
</list1>
</entry>
</row>
