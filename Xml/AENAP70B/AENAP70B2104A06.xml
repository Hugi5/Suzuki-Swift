<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B2104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Too low or uneven trim heights
</title>
<diag type = "condition">
<condition>
<ptxt>
Too low or uneven trim heights
</ptxt>
<attention3>
<ptxt>
See NOTE *1.
</ptxt>
</attention3>
</condition>
<ps>
<ptxt>
Broken or sagging coil springs
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace coil springs.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70B2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70B2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Overloaded vehicle
</ptxt>
</ps>
<action>
<ptxt>
Check loading.
</ptxt>
</action>
<ps>
<ptxt>
Incorrect coil springs
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace coil springs.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70B2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70B2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Poorly inflated tires
</ptxt>
</ps>
<action>
<ptxt>
Adjust tire pressure.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
