<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5104A34" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Excessive “N” → “D” time lag
</title>
<servinfosub id = "AENAP70B5104017007">
<title>
Trouble Diagnosis 3
</title>
<topic id = "AENAP70B5104017008">
<title>
Off-vehicle repair
</title>
<diag type = "condition">
<condition>
<ptxt>
Excessive “N” → “D” time lag
</ptxt>
</condition>
<ps>
<ptxt>
Faulty oil pump
</ptxt>
</ps>
<action>
<ptxt>
Inspect oil pump. If NG, replace oil pump.
</ptxt>
</action>
<ps>
<ptxt>
Faulty forward clutch
</ptxt>
</ps>
<action>
<ptxt>
Inspect forward clutch. If NG, replace forward clutch.
</ptxt>
</action>
<ps>
<ptxt>
Faulty one-way clutch No.2
</ptxt>
</ps>
<action>
<ptxt>
Inspect one-way clutch No.2. If NG, replace one-way clutch No.2.
</ptxt>
</action>
<ps>
<ptxt>
Leakage from “D” range fluid pressure circuit
</ptxt>
</ps>
<action>
<ptxt>
Overhaul or replace valve body assembly.
</ptxt>
</action>
</diag>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
