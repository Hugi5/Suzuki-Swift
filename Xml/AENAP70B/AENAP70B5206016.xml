<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5206016" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Transaxle Right Case Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5206010">Manual Transaxle Unit Dismounting and Remounting</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5206013">Manual Transaxle Assembly Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5206016001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove differential side oil seal. 
<intxreftitleoff1 refid = "AENAP70B5206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove differential side bearing outer race (1) using brass bar (2), if necessary.
</ptxt>
<figure>
<graphic graphicname = "I9P60A522034.swf" width = "88.000mm" height = "50.454mm" ver = "01" gw = "161" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Remove input shaft oil seal (1), if necessary.
</ptxt>
<figure>
<graphic graphicname = "IAP70B520016.jpg" width = "88.000mm" height = "60.780mm" ver = "02" gw = "172" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Pull out countershaft right bearing outer race using special tools, if necessary.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B013">
<s-part>
(A)
</s-part>
<s-number num = "09930-30104">
09930–30104
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B014">
<s-part>
(B)
</s-part>
<s-number num = "09941-64511">
09941–64511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A520027.swf" width = "88.000mm" height = "46.995mm" ver = "01" gw = "147" gh = "117"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B5206016002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Install input shaft oil seal (1) facing its spring side upward until it becomes flush with case surface using special tool and hammer. Apply grease to oil seal lip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B008" uid = "22">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
<servicetool>
<servicetoolitem id = "L5B015">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913–84510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70B520017.jpg" width = "88.000mm" height = "52.554mm" ver = "01" gw = "199" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Install countershaft right bearing outer race (1) using special tools and hammer.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B016">
<s-part>
(A)
</s-part>
<s-number num = "09913-75821">
09913–75821
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B017">
<s-part>
(B)
</s-part>
<s-number num = "09924-84510-004">
09924–84510–004
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522037.swf" width = "88.000mm" height = "48.195mm" ver = "01" gw = "195" gh = "120"/>
</figure>
</s1>
<s1>
<ptxt>
Install differential side bearing outer race using special tool and hammer.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B018">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B019">
<s-part>
(B)
</s-part>
<s-number num = "09925-14520">
09925–14520
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522038.swf" width = "88.000mm" height = "45.772mm" ver = "01" gw = "156" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
