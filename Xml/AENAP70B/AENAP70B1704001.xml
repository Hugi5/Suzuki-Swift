<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B1704001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Fuel System Inspection
</title>
<diag type = "test" id = "AENAP70B1704001001">
<testgroup id = "AENAP70B1704001002">
<title>
Fuel pump inspection
</title>
<test1>
<ptxt>
Remove fuel filler cap and set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Confirm that fuel pump operating sound can be heard from fuel filler port for about 2 seconds before stopping.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check fuel pump circuit. 
<intxreftitleoff1 refid = "AENAP70B1704004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1704001003">
<title>
Fuel pressure check
</title>
<test1>
<ptxt>
Check fuel pressure. 
<intxreftitleoff1 refid = "AENAP70B1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair defective part.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1704001004">
<title>
Power balance test
</title>
<test1>
<ptxt>
Check power balance. 
<intxreftitleoff1 refid = "AENAP70B1704002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fuel system is in good condition.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1704001005">
<title>
Fuel injector circuit check
</title>
<test1>
<ptxt>
Check fuel injector circuit. 
<intxreftitleoff1 refid = "AENAP70B1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair defective part.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1704001006">
<title>
Fuel injector check
</title>
<test1>
<ptxt>
Check fuel injector. 
<intxreftitleoff1 refid = "AENAP70B1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck power balance. 
<intxreftitleoff1 refid = "AENAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace fuel injector. 
<intxreftitleoff1 refid = "AENAP70B1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
