<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5104A17" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Poor 2 → 3 shift
</title>
<servinfosub id = "AENAP70B5104017004">
<title>
Trouble Diagnosis 2
</title>
<topic id = "AENAP70B5104017005">
<title>
On-vehicle repair
</title>
<diag type = "condition">
<condition>
<ptxt>
Poor 2 → 3 shift
</ptxt>
</condition>
<ps>
<ptxt>
Malfunction of shift solenoid valve “A”
</ptxt>
</ps>
<action>
<ptxt>
Inspect shift solenoid valve “A”. If NG, replace shift solenoid valve “A”.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of output shaft speed sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect output shaft speed sensor. If NG, replace output shaft speed sensor.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of transmission range sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect transmission range sensor. If NG, replace transmission range sensor.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of throttle position sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect throttle position sensor. 
<intxreftitleoff1 refid = "AENAP70B1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If NG, replace throttle body.
</ptxt>
</action>
<ps>
<ptxt>
Faulty valve body component
</ptxt>
</ps>
<action>
<ptxt>
Replace valve body assembly.
</ptxt>
</action>
</diag>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
