<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B7216027" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Air Intake Control Actuator Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B7216006">HVAC Unit Components:Non-A/C</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B7216027001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove instrument panel from vehicle body. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect air intake control actuator connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove air intake control actuator (2) from HVAC unit.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721028.jpg" width = "88.000mm" height = "68.236mm" ver = "01" gw = "142" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B7216027002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B7216028">Air Intake Control Actuator Inspection:Non-A/C</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to insert linkage pin (1) into groove (2) of air intake control actuator.
</ptxt>
<figure>
<graphic graphicname = "IAP70B721005.swf" width = "88.000mm" height = "54.558mm" ver = "01" gw = "201" gh = "138"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
