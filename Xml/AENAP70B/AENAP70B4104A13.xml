<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B4104A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Brake warning light remains ON (for more than 2 sec) after starting engine
</title>
<diag type = "condition">
<condition>
<ptxt>
Brake warning light remains ON (for more than 2 sec) after starting engine
</ptxt>
</condition>
<ps>
<ptxt>
ABS / ESP<sup>®</sup> control module connector is not connected properly
</ptxt>
</ps>
<action>
<ptxt>
Connect ABS / ESP<sup>®</sup> control module connector again.
</ptxt>
</action>
<ps>
<ptxt>
Parking brake is applied
</ptxt>
</ps>
<action>
<ptxt>
Release parking brake and check that warning lamp goes off.
</ptxt>
</action>
<ps>
<ptxt>
Insufficient amount of brake fluid
</ptxt>
</ps>
<action>
<ptxt>
Check brake fluid level. 
<intxreftitleoff1 refid = "AENAP70B4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty parking brake switch and/or brake fluid level switch
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Check brake switch and/or brake fluid level switch.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Parking brake switch: 
<intxreftitleoff1 refid = "AENAP70B4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Brake fluid level switch: 
<intxreftitleoff1 refid = "AENAP70B4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Malfunctioning CAN communication system
</ptxt>
</ps>
<action>
<ptxt>
Check CAN communication system. 
<intxreftitleoff1 refid = "AENAP70BA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty combination meter
</ptxt>
</ps>
<action>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ABS / ESP<sup>®</sup> control module
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace ABS / ESP<sup>®</sup> control module.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ABS model: 
<intxreftitleoff1 refid = "AENAP70B4506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>®</sup> model: 
<intxreftitleoff1 refid = "AENAP70B4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
