<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1606007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Cooling Water Pipe or Hose Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B1606001">Cooling System Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B1606009">Thermostat Assembly (Incorporating with ECT Sensor) Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B1606007001">
<title>
Removal
</title>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENAP70B1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
To remove cooling water pipes or hoses, loosen clamp on each hose and pull hose end off.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1606007002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten each clamp securely and in proper direction. 
<intxreftitleoff1 refid = "AENAP70B1606001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENAP70B1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check cooling system for leakage. 
<intxreftitleoff1 refid = "AENAP70B1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
