<servinfosub id = "AENAP70BA204015003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70BA204015004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70BA204015005">
<testgroup id = "AENAP70BA204015009">
<title>
Parameter check
</title>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check “A/C Evaporator Temp” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENAP70BA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA204015007">
<title>
Evaporator temperature sensor circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect evaporator temperature sensor and following connectors.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ignition switch model: “G04” connector
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: “G05” connector
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to evaporator temperature sensor and following connectors.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ignition switch model: “G04” connector
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: “G05” connector
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” and “A2” circuits: less than 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” and “A2” circuit terminals at outside air temperature sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A1” and “A2” circuits: approx. 0 V (when ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA204015008">
<title>
Evaporator temperature sensor check
</title>
<test1>
<ptxt>
Check evaporator temperature sensor. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENAP70B7226016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C model: 
<intxreftitleoff1 refid = "AENAP70B7236018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace evaporator temperature sensor.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENAP70B7226015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C model: 
<intxreftitleoff1 refid = "AENAP70B7236017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
<testgroup id = "AENAP70BA204015010">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Connect evaporator temperature sensor and following connectors.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ignition switch model: “E04” connector
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: “E05” connector
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70BA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is current DTC B1145 or B1146 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace BCM and recheck DTC.	 
<intxreftitleoff1 refid = "AENAP70BA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
