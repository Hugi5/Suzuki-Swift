<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1145: A/C Evaporator Temperature Sensor Circuit High
</emph>
</ptxt>
<ptxt>
Evaporator temperature sensor signal circuit voltage is higher than 4.85 V for specified time continuously.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
	Evaporator temperature sensor circuit / connector
</ptxt>
</item>
<item>
<ptxt>
Evaporator temperature sensor
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1146: A/C Evaporator Temperature Sensor Circuit Low
</emph>
</ptxt>
<ptxt>
Evaporator temperature sensor signal circuit voltage is lower than 0.15 V for specified time continuously.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
