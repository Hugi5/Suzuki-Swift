<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Slipping
</title>
<diag type = "condition">
<condition>
<ptxt>
Slipping
</ptxt>
</condition>
<ps>
<ptxt>
Improper clutch pedal free travel
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace clutch pedal arm and/or clutch master cylinder.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Clutch pedal arm: 
<intxreftitleoff1 refid = "AENAP70B5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Clutch master cylinder: 
<intxreftitleoff1 refid = "AENAP70B5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Worn or oily clutch disc facing
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENAP70B5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Warped disc, pressure plate or flywheel surface
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace clutch disc, cover or flywheel.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Clutch disc and cover: 
<intxreftitleoff1 refid = "AENAP70B5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Flywheel: 
<intxreftitleoff1 refid = "AENAP70B1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Weakened diaphragm spring
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch cover. 
<intxreftitleoff1 refid = "AENAP70B5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Master cylinder piston or seal cup not returning
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch master cylinder. 
<intxreftitleoff1 refid = "AENAP70B5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
