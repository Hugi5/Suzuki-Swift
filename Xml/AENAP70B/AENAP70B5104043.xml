<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P2763: Torque Converter Clutch Pressure Control Solenoid Control Circuit High
</emph>
</ptxt>
<ptxt>
Output voltage of TCC solenoid control circuit is higher than specified value.
</ptxt>
<ptxt>
(1 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
TCC solenoid valve and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
TCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
