<servinfosub id = "AENAP70B5104043003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Warm up engine to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Run engine at idle speed for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5104043004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B5104043005">
<testgroup id = "AENAP70B5104043006">
<question>
Was “A/T Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B5104001">A/T Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104043007">
<title>
TCC solenoid drive circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF” and disconnect TCM and solenoid connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to TCM and solenoid connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check that each TCC solenoid drive circuit (A1, A2) is as follows.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Insulation resistance of wire harness is infinity between each TCC solenoid drive circuit terminal and each terminal at solenoid connector.
</ptxt>
</item>
<item>
<ptxt>
Circuit voltage of each TCC solenoid drive circuit is approx. 0 V with ignition “ON”.
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104043008">
<title>
TCC solenoid valve circuit check
</title>
<test1>
<ptxt>
Check resistance of TCC solenoid valve circuit. 
<intxreftitleoff1 refid = "AENAP70B5106027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B5106030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104043009">
<title>
TCC solenoid valve check
</title>
<test1>
<ptxt>
Check TCC solenoid valve. 
<intxreftitleoff1 refid = "AENAP70B5106029"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace solenoid harness.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace TCC solenoid valve. 
<intxreftitleoff1 refid = "AENAP70B5106028"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
