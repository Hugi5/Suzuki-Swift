<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106024" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
ATF Temperature Sensor Removal and Installation
</title>
<servinfosub id = "AENAP70B5106024001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Hoist vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Drain A/T fluid. 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install ATF drain plug. 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove A/T oil pan and oil strainer assembly. 
<intxreftitleoff1 refid = "AENAP70B5106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove valve body assembly. 
<intxreftitleoff1 refid = "AENAP70B5106026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Lower vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery tray. 
<intxreftitleoff1 refid = "AENAP70B1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove solenoid connector (1) with solenoid harness (2).
</ptxt>
<attention2>
<ptxt>
When pulling solenoid harness out of transaxle case, take care not to damage ATF temperature sensor at narrow exit of case.
</ptxt>
<ptxt>
Careless sensor treatment might cause sensor malfunction.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I9P60A510040.swf" width = "88.000mm" height = "84.867mm" ver = "03" gw = "156" gh = "224"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5106024002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106025">ATF Temperature Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
For details of valve body assembly and their connectors installation, refer to 
<intxref refid = "AENAP70B5106026">Valve Body Assembly Removal and Installation</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
For details of A/T oil pan installation, refer to 
<intxref refid = "AENAP70B5106022">A/T Oil Strainer Assembly Removal and Installation</intxref>
.
</ptxt>
<ptxt>
Use new oil pan gasket.
</ptxt>
</item>
<item>
<ptxt>
Apply ATF to new solenoid harness O-ring.
</ptxt>
</item>
<item>
<ptxt>
Tighten solenoid connector bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5A011">
<t-part>
Solenoid connector bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A510041.swf" width = "88.000mm" height = "39.439mm" ver = "02" gw = "155" gh = "95"/>
</figure>
</item>
<item>
<ptxt>
Replenish ATF and check fluid level. 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check for fluid leakage after warming up A/T.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
