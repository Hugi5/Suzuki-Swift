<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5104050" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
Transmission Warning Light Does Not Come ON with Ignition “ON” (Non-Euro-OBD Model)
</title>
<servinfosub id = "AENAP70B5104050001">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENAP70B5104050002">
<testgroup id = "AENAP70B5104050003">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC related to CAN communication.
</ptxt>
</test1>
<question>
Is there CAN-DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104050004">
<title>
DTC check
</title>
<test1>
<ptxt>
Check combination meter for DTC.
</ptxt>
</test1>
<question>
Is there any DTC(s)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck transmission warning light operation. 
<intxreftitleoff1 refid = "AENAP70B5106030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
