<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106058" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Differential Assembly Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106057">Differential Assembly Disassembly and Reassembly</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Hold differential case subassembly with soft jawed vice and set special tools as shown.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A051">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900–20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A052">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900–20701
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Measure differential gear thrust play.
</ptxt>
<spec>
<title>
Differential gear thrust play
</title>
<ptxt>
Standard: 0.06 – 0.22 mm (0.0024 – 0.0087 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I2RH0B510235.swf" width = "88.000mm" height = "48.333mm" ver = "01" gw = "165" gh = "120"/>
</figure>
</s1>
<s1>
<ptxt>
If check result is not as specification, replace differential case subassembly.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
