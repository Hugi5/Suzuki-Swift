<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106042" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Direct Clutch Assembly Preliminary Check
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106037">A/T Assembly Disassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106064">A/T Assembly Reassembly</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install direct clutch assembly (1) to oil pump assembly (2).
</ptxt>
</s1>
<s1>
<ptxt>
Install special tools to upper surface of direct clutch piston. Blow in air (400 – 800 kPa, 4.1 – 8.1 kgf/cm<sup>2</sup>, 58.1 – 116 psi) through oil hole (3) of oil pump assembly, and measure piston stroke of direct clutch.
</ptxt>
<ptxt>
If piston stroke exceeds specified value, disassemble, inspect and replace inner parts.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A017">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900–20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A018">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900–20701
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Direct clutch piston stroke
</title>
<ptxt>
0.4 – 0.7 mm (0.016 – 0.028 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I2RH0B510161.swf" width = "88.000mm" height = "54.810mm" ver = "01" gw = "189" gh = "138"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
