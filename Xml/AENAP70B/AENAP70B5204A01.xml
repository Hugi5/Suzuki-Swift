<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Gears slipping out of mesh
</title>
<diag type = "condition">
<condition>
<ptxt>
Gears slipping out of mesh
</ptxt>
</condition>
<ps>
<ptxt>
Worn shift fork shaft
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace shift fork or shift shaft.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Low speed gear shift shaft: 
<intxreftitleoff1 refid = "AENAP70B5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
High speed gear shift shaft: 
<intxreftitleoff1 refid = "AENAP70B5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5th gear shift fork: 
<intxreftitleoff1 refid = "AENAP70B5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Worn shift fork or synchronizer sleeve
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace shift fork, shift shaft or synchronizer sleeve &#38; hub.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Low speed gear shift shaft: 
<intxreftitleoff1 refid = "AENAP70B5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
High speed gear shift shaft: 
<intxreftitleoff1 refid = "AENAP70B5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5th gear shift fork: 
<intxreftitleoff1 refid = "AENAP70B5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Low speed synchronizer sleeve &#38; hub: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
High speed synchronizer sleeve &#38; hub: 
<intxreftitleoff1 refid = "AENAP70B5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5th speed synchronizer sleeve &#38; hub: 
<intxreftitleoff1 refid = "AENAP70B5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Weak or damaged locating springs
</ptxt>
</ps>
<action>
<ptxt>
Replace gear shift &#38; select shaft assembly. 
<intxreftitleoff1 refid = "AENAP70B5206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn bearings on input shaft or countershaft
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace input shaft bearing or output shaft bearing.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Counter shaft left bearing:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Inner race: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Outer race: 
<intxreftitleoff1 refid = "AENAP70B5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Counter shaft right bearing:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Inner race: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Outer race: 
<intxreftitleoff1 refid = "AENAP70B5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Input shaft left bearing and right bearing: 
<intxreftitleoff1 refid = "AENAP70B5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Worn chamfered tooth on sleeve and gear
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace synchronizer sleeve &#38; hub and gear.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Counter shaft 1st gear and 2nd gear: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Input shaft 3rd gear and 4th gear: 
<intxreftitleoff1 refid = "AENAP70B5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Input shaft 5th gear: 
<intxreftitleoff1 refid = "AENAP70B5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Low speed synchronizer sleeve &#38; hub: 
<intxreftitleoff1 refid = "AENAP70B5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
High speed synchronizer sleeve &#38; hub: 
<intxreftitleoff1 refid = "AENAP70B5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5th speed synchronizer sleeve &#38; hub: 
<intxreftitleoff1 refid = "AENAP70B5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
