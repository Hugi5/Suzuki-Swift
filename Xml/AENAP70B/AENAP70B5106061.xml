<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106061" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Torque Converter Housing Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106037">A/T Assembly Disassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106064">A/T Assembly Reassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106035">A/T Assembly Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5106061001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove fluid reservoir plate (1) and lubrication tube clamp (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510236.swf" width = "88.000mm" height = "50.111mm" ver = "01" gw = "171" gh = "125"/>
</figure>
</s1>
<s1>
<ptxt>
Remove lubrication left tube (1) and right tube (2).
</ptxt>
<attention3>
<ptxt>
Do not bend lubrication tube with excessive force.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I2RH0B510237.swf" width = "88.000mm" height = "48.714mm" ver = "01" gw = "187" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Remove differential side oil seal (1) using a flat-bladed screwdriver or the like.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510084.swf" width = "88.000mm" height = "49.137mm" ver = "01" gw = "132" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Remove countershaft right bearing cup using special tools.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A053">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944–96011
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A054">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942–15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B510239.swf" width = "88.000mm" height = "47.571mm" ver = "01" gw = "161" gh = "118"/>
</figure>
</s1>
<s1>
<ptxt>
Remove differential side right bearing cup using special tools.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A055">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944–96011
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A056">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942–15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B510240.swf" width = "88.000mm" height = "47.190mm" ver = "01" gw = "147" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Remove torque converter housing plugs (1).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510241.swf" width = "88.000mm" height = "49.011mm" ver = "01" gw = "189" gh = "122"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5106061002">
<title>
Reassembly
</title>
<s1>
<ptxt>
After applying ATF to new O-rings, fit them to housing plugs. Then install plugs to torque converter housing.
</ptxt>
<torque>
<torqueitem id = "T5A019">
<t-part>
Torque converter housing plug
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7.5
</t-value1>
<t-value2>
0.76
</t-value2>
<t-value3>
5.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I2RH0B510242.swf" width = "88.000mm" height = "48.884mm" ver = "01" gw = "184" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Using special tools, install new differential side right bearing cup.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A057">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A058">
<s-part>
(B)
</s-part>
<s-number num = "09944-88220">
09944–88220
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I3RM0B510063.swf" width = "88.000mm" height = "44.895mm" ver = "01" gw = "134" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Using special tool, install new countershaft right bearing cup.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A059">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A060">
<s-part>
(B)
</s-part>
<s-number num = "09944-88220">
09944–88220
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I3RM0B510064.swf" width = "88.000mm" height = "47.694mm" ver = "01" gw = "145" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Using special tools, install new differential side oil seal to torque converter housing evenly at specified position shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A061">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A062">
<s-part>
(B)
</s-part>
<s-number num = "09944-88220">
09944–88220
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Differential side oil seal installing depth
</title>
<ptxt>
“a”: 2.6 – 3.6 mm (0.11 – 0.14 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Apply grease to oil seal lip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease C" id = "M5A004" uid = "23">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25030
</m-number>
<m-name>
SUZUKI Super Grease C
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A510079.swf" width = "88.000mm" height = "75.173mm" ver = "01" gw = "132" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Install lubrication left tube (1) and right tube (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510237.swf" width = "88.000mm" height = "48.714mm" ver = "01" gw = "187" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Install fluid reservoir plate (1) and lubrication tube clamp (2) by tightening their mounting bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5A020">
<t-part>
Lubrication tube clamp bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
<torqueitem id = "T5A021">
<t-part>
Fluid reservoir plate bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I2RH0B510246.swf" width = "88.000mm" height = "50.365mm" ver = "01" gw = "183" gh = "126"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
