<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B9906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Sun Roof Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B9906001">Sun Roof Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B9906002001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove roof lining. 
<intxreftitleoff1 refid = "AENAP70B9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove sun roof glass. 
<intxreftitleoff1 refid = "AENAP70B9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect drain hoses (1) connected to sun roof assembly at 4 locations.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990005.jpg" width = "88.000mm" height = "75.169mm" ver = "01" gw = "227" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect sun roof motor connector (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990006.jpg" width = "88.000mm" height = "69.556mm" ver = "01" gw = "225" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Detach clamps (1) and sun roof harness (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990007.jpg" width = "88.000mm" height = "61.392mm" ver = "01" gw = "227" gh = "158"/>
</figure>
</s1>
<s1>
<ptxt>
Remove sun roof housing nuts (1), and then remove sun roof assembly (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990008.jpg" width = "88.000mm" height = "83.554mm" ver = "01" gw = "227" gh = "220"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B9906002002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten each part to specified torque referring to 
<intxref refid = "AENAP70B9906001">Sun Roof Components</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Tighten sun roof housing nuts (1) in order (“1” to “4”) shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990009.jpg" width = "88.000mm" height = "82.828mm" ver = "01" gw = "227" gh = "218"/>
</figure>
</item>
<item>
<ptxt>
Connect drain hoses (1) to sun roof assembly at 4 locations. Clamp drain hoses by clamps (2) securely.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990010.jpg" width = "88.000mm" height = "75.168mm" ver = "01" gw = "227" gh = "197"/>
</figure>
<figure>
<title>
Front pillar
</title>
<graphic graphicname = "I9P60A990011.swf" width = "88.000mm" height = "95.842mm" ver = "02" gw = "210" gh = "255"/>
</figure>
<figure>
<title>
Quarter panel
</title>
<graphic graphicname = "I9P60A990013.swf" width = "88.000mm" height = "94.869mm" ver = "03" gw = "225" gh = "252"/>
</figure>
</item>
<item>
<ptxt>
Initialize sun roof motor. 
<intxreftitleoff1 refid = "AENAP70B9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
After reinstalling sun roof assembly, be sure to perform glass adjustment. 
<intxreftitleoff1 refid = "AENAP70B9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
