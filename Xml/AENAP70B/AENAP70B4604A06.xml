<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B4604A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
EBD warning light (Brake warning light) does not turn ON after setting ignition “ON”
</title>
<diag type = "condition">
<condition>
<ptxt>
EBD warning light (Brake warning light) does not turn ON after setting ignition “ON”
</ptxt>
</condition>
<ps>
<ptxt>
Malfunctioning ESP<sup>®</sup> function
</ptxt>
</ps>
<action>
<ptxt>
Perform ESP<sup>®</sup> system check. 
<intxreftitleoff1 refid = "AENAP70B4604001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Malfunctioning CAN communication system
</ptxt>
</ps>
<action>
<ptxt>
Check CAN communication system. 
<intxreftitleoff1 refid = "AENAP70BA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Malfunctioning EBD warning light circuit
</ptxt>
</ps>
<action>
<ptxt>
Check EBD warning light circuit. 
<intxreftitleoff1 refid = "AENAP70B4604014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
