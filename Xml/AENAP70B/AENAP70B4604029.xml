<servinfosub id = "AENAP70B4604029003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B4604029004">
<testgroup id = "AENAP70B4604029005">
<question>
Was “ESP<sup>®</sup> System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B4604001">ESP® System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B4604029006">
<title>
ESP® control module power supply and ground circuits check
</title>
<test1>
<ptxt>
Check ESP<sup>®</sup> control module power supply circuit and ground circuit. 
<intxreftitleoff1 refid = "AENAP70B4604039"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B4604029007">
<title>
ESP® control module power supply voltage check
</title>
<test1>
<ptxt>
Measure battery voltage with engine running at 3,000 rpm.
</ptxt>
</test1>
<question>
Is voltage between 9.3 V and 16.8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ESP<sup>®</sup> hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Check charging system. 
<intxreftitleoff1 refid = "AENAP70B1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
