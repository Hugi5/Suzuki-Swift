</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B5106026">Valve Body Assembly Removal and Installation</intxref>
.
</ptxt>
</action>
<condition>
<ptxt>
Lower than standard level in each range
</ptxt>
</condition>
<ps>
<ptxt>
Malfunction of pressure control solenoid valve (Low line pressure)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B5106029">Solenoid Valve Inspection</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty valve body component
</ptxt>
</ps>
<action>
<ptxt>
