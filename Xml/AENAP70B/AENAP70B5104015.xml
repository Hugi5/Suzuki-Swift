.
</ptxt>
</action>
<ps>
<ptxt>
Faulty oil pump
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B5106040">Oil Pump Assembly Inspection</intxref>
.
</ptxt>
</action>
<condition>
<ptxt>
Lower than standard level only in “D” range
</ptxt>
</condition>
<ps>
<ptxt>
Faulty valve body component
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B5106026">Valve Body Assembly Removal and Installation</intxref>
.
</ptxt>
</action>
<condition>
<ptxt>
Lower than standard level only in “R” range
</ptxt>
</condition>
<ps>
<ptxt>
Faulty valve body component
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B5106026">Valve Body Assembly Removal and Installation</intxref>
