<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106039" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Oil Pump Assembly Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106037">A/T Assembly Disassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106064">A/T Assembly Reassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106038">Oil Pump Assembly Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5106039001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove O-ring from oil pump body.
</ptxt>
</s1>
<s1>
<ptxt>
Remove stator shaft assembly (2) by removing oil pump subassembly bolts (1).
</ptxt>
<figure>
<graphic graphicname = "I4RS0A510041.swf" width = "88.000mm" height = "48.670mm" ver = "01" gw = "151" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Remove oil seal (1) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A013">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913–50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B510150.swf" width = "88.000mm" height = "46.682mm" ver = "01" gw = "172" gh = "115"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.214in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Oil pump body
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5106039002">
<title>
Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106040">Oil Pump Assembly Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install new oil seal (1) to oil pump body (2).
</ptxt>
<ptxt>
Use special tool and hammer to install it, and then apply grease to its lip portion.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A014">
<s-part>
(A)
</s-part>
<s-number num = "09913-85210">
09913–85210
</s-number>
</servicetoolitem>
</servicetool>
<materials>
<materialitem name = "SUZUKI Super Grease C" id = "M5A003" uid = "23">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25030
</m-number>
<m-name>
SUZUKI Super Grease C
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I2RH0B510151.swf" width = "88.000mm" height = "47.317mm" ver = "01" gw = "111" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
After applying ATF to driven gear and drive gear, install them to oil pump body.
</ptxt>
</s1>
<s1>
<ptxt>
Install stator shaft assembly to oil pump body and tighten oil pump subassembly bolts (1) to specification.
</ptxt>
<attention2>
<ptxt>
Be careful not to damage oil seal by splines when installing stator shaft assembly.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T5A017">
<t-part>
Oil pump subassembly bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I4RS0A510042.swf" width = "88.000mm" height = "46.671mm" ver = "01" gw = "162" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
After applying ATF to new O-ring, install it to oil pump body.
</ptxt>
</s1>
<s1>
<ptxt>
Check drive gear for smooth rotation by using torque converter (1).
</ptxt>
<figure>
<graphic graphicname = "I4RS0A510043.swf" width = "88.000mm" height = "45.692mm" ver = "01" gw = "106" gh = "114"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
