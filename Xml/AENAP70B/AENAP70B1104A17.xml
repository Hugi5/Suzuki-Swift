<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B1104A17" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Excessive nitrogen oxides (NOx) emission
</title>
<ptxt>
Perform troubleshooting referring to the following points when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENAP70B1104008">Visual Inspection</intxref>
 and 
<intxref refid = "AENAP70B1104009">Engine Basic Inspection</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Excessive nitrogen oxides (NOx) emission
</ptxt>
</condition>
<ps>
<ptxt>
Improper ignition timing
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1806005">Ignition Timing Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Lead contamination of catalytic converter
</ptxt>
</ps>
<action>
<ptxt>
Check for absence of filler neck restructure.
</ptxt>
</action>
<ps>
<ptxt>
Fuel pressure out of specification
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1704005">Fuel Pressure Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty closed-loop system (A/F feedback compensation) (Poor performance of ECT sensor or MAF sensor)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1306012">ECT Sensor Inspection</intxref>
 or 
<intxref refid = "AENAP70B1306026">MAF and IAT Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty electric throttle body assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1306004">Electric Throttle Body Assembly On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty APP sensor assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1306008">APP Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty injector(s)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1704003">Fuel Injector Circuit Check</intxref>
 or 
<intxref refid = "AENAP70B1706009">Fuel Injector Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1104070">Inspection of ECM and Its Circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Camshaft position control (VVT) system out of order
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1306027">OCV Inspection</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
