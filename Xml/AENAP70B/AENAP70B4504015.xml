<servinfosub id = "AENAP70B4504015003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B4504015004">
<testgroup id = "AENAP70B4504015005">
<question>
Was “ABS System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B4504001">ABS Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B4504015006">
<title>
Solenoid valve power supply and ABS control module ground circuits check
</title>
<test1>
<ptxt>
Check solenoid valve power supply and ground circuits under 
<intxref refid = "AENAP70B4504022">ABS Control Module Power Supply and Ground Circuit Check</intxref>
.
</ptxt>
</test1>
<question>
Are check results OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ABS hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B4506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
</diag>
