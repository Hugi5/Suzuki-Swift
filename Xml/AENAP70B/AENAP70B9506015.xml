<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B9506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Door Glass Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B9506014">Rear Door Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B9506015001">
<title>
Removal
</title>
<s1>
<ptxt>
Lower rear door glass fully.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear door inner garnish (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove inside handle cap (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (3) and clips, and then remove door trim (4) by pulling it in arrow direction, and then disconnect connectors of door harness.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950037.jpg" width = "88.000mm" height = "109.011mm" ver = "01" gw = "227" gh = "292"/>
</figure>
</s1>
<s1>
<ptxt>
Remove rear door outer weather-strip (1) by moving it in arrow directions in order (“1” to “2”) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IAP70B950010.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.176in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.176in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Claw
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Rear door outer panel
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove rear door inner weather-strip (1) by pulling it in arrow direction in order (“1” to “2”) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950039.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.905in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Rear door inner panel
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove door trim bracket (1) and door sealing cover (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950040.jpg" width = "88.000mm" height = "91.844mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Turn over glass run (1) and remove rear door sash screw (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear door sash bolts (3) and remove rear door sash (4) and glass run.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950041.jpg" width = "88.000mm" height = "80.089mm" ver = "02" gw = "211" gh = "211"/>
</figure>
</s1>
<s1>
<ptxt>
Turn rear door glass (1) in direction of arrow “1” to remove glass bottom channel (3) from rear window regulator assembly (2) and then remove rear door glass in direction of arrow “2”.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950042.jpg" width = "88.000mm" height = "97.155mm" ver = "01" gw = "227" gh = "259"/>
</figure>
</s1>
<s1>
<ptxt>
Remove glass bottom channel from rear door glass if necessary.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B9506015002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Install glass bottom channel (1) to specified position of rear door glass (2) if it is removed from rear door glass.
</ptxt>
<spec>
<title>
Rear door glass installation position
</title>
<ptxt>
“a”: 17 – 19 mm (0.67 – 0.74 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A950043.jpg" width = "88.000mm" height = "69.916mm" ver = "01" gw = "227" gh = "182"/>
</figure>
</item>
<item>
<ptxt>
Insert rear door glass (3) in direction of arrow “1” and turn in direction of arrow “2” to move glass bottom channel (1) in direction of arrow “3” and fit to rear window regulator assembly (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950044.jpg" width = "88.000mm" height = "97.155mm" ver = "01" gw = "227" gh = "259"/>
</figure>
</item>
<item>
<ptxt>
Tighten rear door sash screw and rear door sash bolts in order of “1” to “3” to specified torques.
</ptxt>
<torque>
<torqueitem id = "T9E004">
<t-part>
Rear door sash screw*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3.0
</t-value1>
<t-value2>
0.31
</t-value2>
<t-value3>
2.5
</t-value3>
</torqueitem>
<torqueitem id = "T9E005">
<t-part>
Rear door sash bolt*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950045.jpg" width = "88.000mm" height = "80.089mm" ver = "04" gw = "227" gh = "211"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.176in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.176in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Rear door sash
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Glass run
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
If glass run is deformed, replace it with new one.
</ptxt>
</item>
<item>
<ptxt>
Fix door sealing cover (1) with butyl tape (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950046.jpg" width = "88.000mm" height = "80.908mm" ver = "01" gw = "185" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
