<servinfosub id = "AENAP70B1104050003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery voltage &#62; 8.5 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Run engine at idle speed for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Set A/C switch to ON for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Set A/C switch to OFF.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1104050004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B1104050005">
<testgroup id = "AENAP70B1104050006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104050007">
<title>
A/C compressor relay power supply circuit (coil side) check
</title>
<test1>
<ptxt>
When ignition is “OFF”, remove A/C compressor relay.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to A/C compressor relay connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “A1” and ground is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104050008">
<title>
A/C compressor relay check
</title>
<test1>
<ptxt>
Check A/C compressor relay.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENAP70B7226034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Automatic A/C model: 
<intxreftitleoff1 refid = "AENAP70B7236041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace A/C compressor relay.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104050009">
<title>
A/C compressor relay drive circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B1” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit terminal and other terminal at A/C compressor relay connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B1” circuit: approx. 0 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
</diag>
