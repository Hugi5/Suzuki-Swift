<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B6304022" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Steering Wheel Play Check
</title>
<list1 type = "unordered">
<item>
<ptxt>
Check steering wheel for looseness or rattle by moving it in axial and lateral directions.
</ptxt>
<ptxt>
If check result is not OK, repair or replace steering wheel.
</ptxt>
</item>
<item>
<ptxt>
Check steering wheel for play, holding vehicle in straight-ahead position on the ground with engine stopped.
</ptxt>
<ptxt>
If steering wheel play is not within specification, inspect following components and replace any of them if found defective.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tie-rod end and tie-rod ball joint for wear
</ptxt>
</item>
<item>
<ptxt>
Suspension arm joint for wear
</ptxt>
</item>
<item>
<ptxt>
Steering shaft joint for wear
</ptxt>
</item>
<item>
<ptxt>
Steering pinion or rack gear for wear or breakage
</ptxt>
</item>
<item>
<ptxt>
Each part for looseness
</ptxt>
</item>
</list2>
</list1>
<spec-sdm>
<sdm-title>
Steering wheel play
</sdm-title>
<sdm-part>
“a”
</sdm-part>
<sdm1>
<sdm-condition>
</sdm-condition>
<sdm-value>
0 – 30 mm (0 – 1.2 in.)
</sdm-value>
</sdm1>
</spec-sdm>
