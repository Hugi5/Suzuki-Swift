<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5104A24" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Excessive “N” → “D” or “N” → “R” time lag
</title>
<servinfosub id = "AENAP70B5104017004">
<title>
Trouble Diagnosis 2
</title>
<topic id = "AENAP70B5104017005">
<title>
On-vehicle repair
</title>
<diag type = "condition">
<condition>
<ptxt>
Excessive “N” → “D” or “N” → “R” time lag
</ptxt>
</condition>
<ps>
<ptxt>
Malfunction of ATF temperature sensor
</ptxt>
</ps>
<action>
<ptxt>
Inspect ATF temperature sensor. If NG, replace ATF temperature sensor.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of pressure control solenoid valve
</ptxt>
</ps>
<action>
<ptxt>
Inspect pressure control solenoid valve. If NG, replace valve body assembly.
</ptxt>
</action>
<ps>
<ptxt>
Clogged oil strainer
</ptxt>
</ps>
<action>
<ptxt>
Replace oil strainer.
</ptxt>
</action>
<ps>
<ptxt>
Faulty valve body component
</ptxt>
</ps>
<action>
<ptxt>
Replace valve body assembly.
</ptxt>
</action>
</diag>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
