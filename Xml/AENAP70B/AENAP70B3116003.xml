<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B3116003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Front Drive Shaft Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B3116001">Front Drive Shaft Components:Front</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B3116002">Front Drive Shaft Assembly On-Vehicle Inspection:Front</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B3116003001">
<title>
Removal
</title>
<attention3>
<ptxt>
Turning drive shaft while pulling out drive shaft may facilitate release of the snap ring fitting of joint spline.
</ptxt>
</attention3>
<s1 page = "2">
<ptxt>
Hoist vehicle and remove front wheel. 
<intxreftitleoff1 refid = "AENAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Release caulking (1) and remove drive shaft nut (2) with brake pedal depressed.
</ptxt>
<figure>
<graphic graphicname = "IAP70P311008.swf" width = "88.000mm" height = "54.100mm" ver = "01" gw = "182" gh = "137"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Drain transaxle oil (M/T model) or A/T fluid (A/T model).
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
M/T model: 
<intxreftitleoff1 refid = "AENAP70B5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
A/T model: 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Remove front wheel speed sensor from steering knuckle.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
ABS model: 
<intxreftitleoff1 refid = "AENAP70B4506006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup> model: 
<intxreftitleoff1 refid = "AENAP70B4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Disconnect suspension arm joint from steering knuckle. 
<intxreftitleoff1 refid = "AENAP70B2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Use tire lever (1) or the like to pull out left side shaft joint (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70B311002.swf" width = "88.000mm" height = "46.280mm" ver = "01" gw = "95" gh = "115"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Use hammer (1) and extension bar (2) to pull out right side shaft joint (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70B311003.swf" width = "88.000mm" height = "58.700mm" ver = "01" gw = "123" gh = "150"/>
</figure>
</s1>
<s1>
<ptxt>
Remove drive shaft assembly.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B3116003002">
<title>
Installation
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Be careful not to damage oil seals and boots when installing drive shaft.
</ptxt>
</item>
<item>
<ptxt>
Do not hit joint boot with hammer. Inserting joint only by hands is allowed.
</ptxt>
</item>
<item>
<ptxt>
Make sure that differential side joint is inserted fully and its circlip is seated as it was installed.
</ptxt>
</item>
<item>
<ptxt>
Before inserting drive shaft (1), confirm that there is no foreign materials around encoder (2) on wheel bearing.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311024.swf" width = "88.000mm" height = "50.139mm" ver = "01" gw = "203" gh = "126"/>
</figure>
</item>
</list1>
</attention2>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new differential side joint circlip.
</ptxt>
</item>
<item>
<ptxt>
Tighten new drive shaft nut (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T3A101">
<t-part>
Drive shaft nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17.8
</t-value2>
<t-value3>
129.0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Caulk drive shaft nut (1) as shown.
</ptxt>
<attention2>
<ptxt>
Be sure not to crack caulking part (2) of drive shaft nut while caulking it. Replace it with new one if it is cracked.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70P311020.swf" width = "88.000mm" height = "54.099mm" ver = "01" gw = "172" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Connect suspension arm joint. 
<intxreftitleoff1 refid = "AENAP70B2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Install front wheel speed sensor.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ABS model: 
<intxreftitleoff1 refid = "AENAP70B4506006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup> model: 
<intxreftitleoff1 refid = "AENAP70B4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Install front wheel. 
<intxreftitleoff1 refid = "AENAP70B2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Fill transaxle with transaxle oil (M/T model) or A/T fluid (A/T model) as specified.
</ptxt>
</item>
<item>
<ptxt>
M/T model: 
<intxreftitleoff1 refid = "AENAP70B5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
A/T model: 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check front wheel alignment. 
<intxreftitleoff1 refid = "AENAP70B2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
