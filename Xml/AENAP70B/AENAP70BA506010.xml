<servinfo servinfosgmlid = "AENAP70BA506010" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Antenna Inspection
</title>
<servinfosub id = "AENAP70BA506010001">
<title>
Using SUZUKI Scan Tool
</title>
<s1>
<ptxt>
Connect SUZUKI scan tool to DLC with ignition “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Select “Keyless Start Antenna” function in “Active Test” mode.
</ptxt>
</s1>
<s1>
<ptxt>
Check that each antenna operates.
</ptxt>
<ptxt>
If check result is not as specified, check applicable circuit for open or short. 
<intxreftitleoff1 refid = "AENAP70BA504031"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If check result is as specified, replace applicable antenna.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Driver / Passenger side outside antenna: 
<intxreftitleoff1 refid = "AENAP70BA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear outside antenna: 
<intxreftitleoff1 refid = "AENAP70BA506006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Mid inside antenna: 
<intxreftitleoff1 refid = "AENAP70BA506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear inside antenna: 
<intxreftitleoff1 refid = "AENAP70BA506008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
</servinfosub>
