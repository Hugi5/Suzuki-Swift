<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B9504002" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Power Door Mirror Control System Symptom Diagnosis
</title>
<diag type = "condition" id = "AENAP70B9504002001">
<condition>
<ptxt>
All power door mirrors do not operate
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Replace fuse and check for short circuit.
</ptxt>
</action>
<ps>
<ptxt>
Faulty power door mirror switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506023">Power Door Mirror Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<condition>
<ptxt>
One of the power door mirrors cannot operate
</ptxt>
</condition>
<ps>
<ptxt>
Faulty power door mirror switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506023">Power Door Mirror Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty power door mirror actuator
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506021">Power Door Mirror On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<condition>
<ptxt>
Power door mirrors cannot move smoothly
</ptxt>
</condition>
<ps>
<ptxt>
Faulty power door mirror actuator
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B9506021">Power Door Mirror On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Some object is pinched in power mirror
</ptxt>
</ps>
<action>
<ptxt>
Remove foreign bodies
</ptxt>
</action>
<ps>
<ptxt>
Mirror comes out of position
</ptxt>
</ps>
<action>
<ptxt>
Install mirror in position. 
<intxreftitleoff1 refid = "AENAP70B9506022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
