<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B4106006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Brake Pedal Assembly Removal and Installation
</title>
<attention2>
<ptxt>
Never disassemble brake pedal assembly equipped with brake pedal foot protection mechanism.
</ptxt>
<ptxt>
To disassemble will spoil its original function. If faulty condition is found, replace it with new one as an assembly.
</ptxt>
</attention2>
<servinfosub id = "AENAP70B4106006001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove combination meter cluster panel. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering column hole cover. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove brake light switch. 
<intxreftitleoff1 refid = "AENAP70B4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering lower shaft. 
<intxreftitleoff1 refid = "AENAP70B6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove clip, clevis pin and brake booster nuts. 
<intxreftitleoff1 refid = "AENAP70B4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove brake pedal bracket nut (1) and cowl upper stiffener bolt (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Remove brake pedal assembly.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B4106006002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B4106022">Brake Booster Removal and Installation</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install brake pedal assembly and install brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
Tighten brake booster nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A001">
<t-part>
Brake booster nut*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410009.swf" width = "88.000mm" height = "63.332mm" ver = "01" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten brake pedal bracket nut to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A002">
<t-part>
Brake pedal bracket nut*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Tighten cowl upper stiffener bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A003">
<t-part>
Cowl upper stiffener bolt*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410010.swf" width = "88.000mm" height = "64.412mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Install clip and clevis. 
<intxreftitleoff1 refid = "AENAP70B4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install steering lower shaft. 
<intxreftitleoff1 refid = "AENAP70B6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Bleed air from brake system. 
<intxreftitleoff1 refid = "AENAP70B4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check brake pedal free height and play.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Brake pedal free height: 
<intxreftitleoff1 refid = "AENAP70B4106007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Brake pedal play: 
<intxreftitleoff1 refid = "AENAP70B4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Install brake light switch. 
<intxreftitleoff1 refid = "AENAP70B4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check all connections for fluid leakage and make sure that brake system operating properly.
</ptxt>
</s1>
<s1>
<ptxt>
Install steering column hole cover. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install combination meter cluster panel. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
