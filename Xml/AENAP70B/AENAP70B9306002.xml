<servinfo servinfosgmlid = "AENAP70B9306002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Horn Removal and Installation
</title>
<servinfosub id = "AENAP70B9306002001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENAP70B9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect horn connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove horn bolt (3) and remove horn (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A930022.jpg" width = "88.000mm" height = "63.673mm" ver = "02" gw = "195" gh = "164"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B9306002002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B9306003">Horn Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
