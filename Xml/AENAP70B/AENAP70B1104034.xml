<servinfosub id = "AENAP70B1104034001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.925in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.272in"/>
<thead>
<row rowsep = "1">
