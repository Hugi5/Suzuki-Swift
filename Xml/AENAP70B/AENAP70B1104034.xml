</servinfosub>
<servinfosub id = "AENAP70B1104034004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B1104034005">
<testgroup id = "AENAP70B1104034006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104034007">
<title>
CMP sensor power supply circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect CMP sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to CMP sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “A1” and “A3” is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104034008">
<title>
CMP sensor ground circuit check
</title>
<test1>
<ptxt>
Check that voltage between “A1” and ground is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Repair “A3” circuit.
</ptxt>
<ptxt>
If this DTC is detected again, replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair “A1” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104034009">
<title>
CMP sensor signal circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A2” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit terminal and other terminal at CMP sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A2” circuit: approx. 0 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104034010">
<title>
CMP sensor and signal rotor check
</title>
<test1>
<ptxt>
Check the following points: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
CMP sensor 
<intxreftitleoff1 refid = "AENAP70B1306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Signal rotor 
<intxreftitleoff1 refid = "AENAP70B1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
</diag>
