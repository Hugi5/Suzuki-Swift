<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B9F06008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
USB Socket Removal and Installation (If Equipped)
</title>
<servinfosub id = "AENAP70B9F06008001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove center console box. 
<intxreftitleoff1 refid = "AENAP70B9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove center side cover. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect USB socket connector (1), and then remove USB socket (2) from instrument panel (3) while releasing the locks (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0014.jpg" width = "88.000mm" height = "55.000mm" ver = "02" gw = "206" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B9F06008002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B9F06009">USB Socket Inspection (If Equipped)</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
