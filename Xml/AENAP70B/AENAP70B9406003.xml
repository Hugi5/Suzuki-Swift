<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B9406003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Windshield Wiper Motor Removal and Installation
</title>
<servinfosub id = "AENAP70B9406003001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove wiper pivot caps (1) and wiper arm nuts (2), and remove windshield wiper arms (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove cowl top garnish (4). 
<intxreftitleoff1 refid = "AENAP70B9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "IAP70B940019.jpg" width = "88.000mm" height = "60.102mm" ver = "01" gw = "199" gh = "154"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect windshield wiper motor connector (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove wiper motor bolts (1) and remove windshield wiper motor (2) in arrow direction as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60A940006.jpg" width = "88.000mm" height = "41.842mm" ver = "01" gw = "217" gh = "102"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B9406003002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B9406004">Windshield Wiper Motor Operation Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten wiper motor bolts in numerical order (“1” through “2”) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9D002">
<t-part>
Wiper motor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8.3
</t-value1>
<t-value2>
0.85
</t-value2>
<t-value3>
6.5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A940007.jpg" width = "88.000mm" height = "41.842mm" ver = "02" gw = "217" gh = "102"/>
</figure>
<list1 type = "unordered">
<item>
<ptxt>
Install windshield wiper arms (1) in positions shown in figure.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Right side [A]
</ptxt>
<ptxt>
Align tip of windshield wiper blade (5) with matchmark (4).
</ptxt>
</item>
<item>
<ptxt>
Left side [B]
</ptxt>
<ptxt>
Align blade with ceramic line (3).
</ptxt>
</item>
</list2>
<item>
<ptxt>
Tighten wiper arm nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9D003">
<t-part>
Wiper arm nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1.6
</t-value2>
<t-value3>
12.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940009.swf" width = "88.000mm" height = "77.752mm" ver = "02" gw = "189" gh = "204"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.277in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.708in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Wiper pivot cap
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
