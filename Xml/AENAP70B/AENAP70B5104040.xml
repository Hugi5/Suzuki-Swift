<title>
DTC P1706
</title>
<servinfosub id = "AENAP70B5104040001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.004in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.174in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1706: Torque Request Communication Error from TCM
</emph>
</ptxt>
<ptxt>
ECM detects abnormality of CAN communication data which TCM transmits.
</ptxt>
<ptxt>
(1 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
TCM
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70B5104040002">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B5104040003">
<testgroup id = "AENAP70B5104040004">
<title>
DTC check
</title>
<question>
Is there any DTC(s) other than P1706?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104040005">
<title>
DTC check of ECM
</title>
<test1>
<ptxt>
Check DTC of ECM.
<intxreftitleoff1 refid = "AENAP70B1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is there any DTC(s)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B5106030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
