<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Input Shaft Speed Sensor Removal and Installation
</title>
<servinfosub id = "AENAP70B5106020001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect input shaft speed sensor connector (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove input shaft speed sensor (1) by removing its bolt.
</ptxt>
<figure>
<graphic graphicname = "I9P60A510037.swf" width = "88.000mm" height = "50.964mm" ver = "02" gw = "170" gh = "128"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5106020002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106021">Input Shaft Speed Sensor Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Apply ATF to new input shaft speed sensor O-ring.
</ptxt>
</s1>
<s1>
<ptxt>
Install input shaft speed sensor (1) to A/T case and tighten bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5A008">
<t-part>
Input shaft speed sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect input shaft speed sensor connector (2) to input shaft speed sensor (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A510038.swf" width = "88.000mm" height = "50.964mm" ver = "02" gw = "170" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Connect negative cable to battery.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
