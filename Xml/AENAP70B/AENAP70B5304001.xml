<title>
Clutch System Symptom Diagnosis
</title>
<diag type = "condition" id = "AENAP70B5304001001">
<condition>
<ptxt>
Slipping
</ptxt>
</condition>
<ps>
<ptxt>
Improper clutch pedal free travel
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace clutch pedal arm and/or clutch master cylinder.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Clutch pedal arm: 
<intxreftitleoff1 refid = "AENAP70B5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Clutch master cylinder: 
<intxreftitleoff1 refid = "AENAP70B5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Worn or oily clutch disc facing
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENAP70B5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
