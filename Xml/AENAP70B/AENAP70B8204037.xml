<servinfosub id = "AENAP70B8204037003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B8204037004">
<testgroup id = "AENAP70B8204037005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B8204037006">
<title>
Floor harness circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is in “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “L04” and “L47” connectors or “L05” and “L48” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” and “A2” circuits (DTC B1083 / B1084): 1 &#937; or less
</ptxt>
</item>
<item>
<ptxt>
Resistance of “A3” and “A4” circuits (DTC B1093 / B1074): 1 &#937; or less
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B061">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820029.swf" width = "90.000mm" height = "52.428mm" ver = "03" gw = "207" gh = "132"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B8204037007">
<title>
Floor harness circuit check
</title>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “L04-9” and “L04-10” terminals (DTC B1083 / B1084): infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “L05-9” and “L05-10” terminals (DTC B1093 / B1094): infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B062">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820139.swf" width = "90.000mm" height = "59.922mm" ver = "01" gw = "206" gh = "153"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B8204037008">
<title>
Floor harness circuit check
</title>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between each of “A1” and “A2” circuits and ground (DTC B1083 / B1084): infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A3” and “A4” circuits and ground (DTC B1093 / B1094): infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B063">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820140.swf" width = "90.000mm" height = "59.922mm" ver = "01" gw = "206" gh = "153"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B8204037009">
<title>
Floor harness circuit check
</title>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voltage between each of “A1” and “A2” circuits and ground (DTC B1083 / B1084): approx. 0 V
</ptxt>
</item>
<item>
<ptxt>
Voltage between each of “A3” and “A4” circuits and ground (DTC B1093 / B1094): approx. 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B064">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820141.swf" width = "90.000mm" height = "59.883mm" ver = "01" gw = "206" gh = "153"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B8204037010">
<title>
Front side-impact sensor check
</title>
<test1>
<ptxt>
Confirm that ignition is in “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Replace front side-impact sensor. 
<intxreftitleoff1 refid = "AENAP70B8206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70B8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs, referring to 
<intxref refid = "AENAP70B8204006">DTC Clearance</intxref>
 if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENAP70B8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
