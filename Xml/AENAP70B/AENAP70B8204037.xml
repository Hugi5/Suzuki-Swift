</title>
<servinfosub id = "AENAP70B8204037001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.597in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.597in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1083: Side Impact Sensor Circuit Shorted to Ground (Driver Side)
</emph>
</ptxt>
<ptxt>
Driver-side front side-impact sensor circuit has been shorted to ground.
</ptxt>
</entry>
<entry colname = "2" morerows = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Driver-side / passenger-side front side-impact sensor circuit
</ptxt>
</item>
<item>
<ptxt>
Driver-side / passenger-side front side-impact sensor
</ptxt>
</item>
<item>
<ptxt>
SDM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1084: Side Impact Sensor Circuit Open (Driver Side)
</emph>
</ptxt>
<ptxt>
Driver-side front side-impact sensor circuit has been shorted to power supply or opened.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1093: Side Impact Sensor Circuit Shorted to Ground (Passenger Side)
</emph>
</ptxt>
<ptxt>
Passenger-side front side-impact sensor circuit has been shorted to ground.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1094: Side Impact Sensor Circuit Open (Passenger Side)
</emph>
</ptxt>
<ptxt>
Passenger-side front side-impact sensor circuit has been shorted to power supply or opened.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
