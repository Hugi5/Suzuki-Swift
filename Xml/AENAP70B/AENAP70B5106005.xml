<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Select Lever Assembly Removal and Installation
</title>
<servinfosub id = "AENAP70B5106005001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove console box. 
<intxreftitleoff1 refid = "AENAP70B9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect adjuster case (select cable end) from select lever assembly. 
<intxreftitleoff1 refid = "AENAP70B5106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect key interlock cable end and detach cable casing cap from select lever assembly (ignition switch model). 
<intxreftitleoff1 refid = "AENAP70B5106016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect select lever connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove select lever assembly from floor panel after removing nuts.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5106005002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten select lever nuts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B5106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
After installing select lever assembly, adjust select cable. 
<intxreftitleoff1 refid = "AENAP70B5106013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
