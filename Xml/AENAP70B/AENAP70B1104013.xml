<ptxt>
<emph etype = "bold">
P0010: “A” Camshaft Position Actuator Circuit / Open
</emph>
</ptxt>
<ptxt>
OCV control circuit is open.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
