<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B7214A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Fluttering noise or large droning noise
</title>
<servinfosub id = "AENAP70B7214004001">
<title>
Abnormal Noise from Blower Motor
</title>
<diag type = "condition">
<condition>
<ptxt>
Fluttering noise or large droning noise
</ptxt>
</condition>
<ps>
<ptxt>
Leaves or other debris introduced from fresh air inlet to blower motor
</ptxt>
</ps>
<action>
<ptxt>
Remove debris and make sure that screen at fresh air inlet is intact.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
