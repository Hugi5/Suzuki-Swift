<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B6306009" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pinion Shaft Rotation Torque Inspection
</title>
<s1>
<ptxt>
Remove steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70B6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering rack boots. 
<intxreftitleoff1 refid = "AENAP70B6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check pinion rotation torque with rack position centered using special tool.
</ptxt>
<ptxt>
Also check that rack as a whole moves smoothly.
</ptxt>
<ptxt>
If check result is not as specified, adjust pinion shaft rotation torque.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C009">
<s-part>
(A)
</s-part>
<s-number num = "09944-16810">
09944–16810
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Rotation torquer specification
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.874in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.592in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Rotation angle
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Rotation torque
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
0&#176; – 45&#176;
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
0.95 – 1.55 N&#183;m (0.1 – 0.2 kgf-m, 1.0 – 1.5 lbf-ft)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
45&#176; – end
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
4.0 N&#183;m (0.4 kgf-m, 3.0 lbf-ft) max
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
