<servinfosub id = "AENAP70BA504023003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “ACC”.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 1) through 3) several times.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70BA504023004">
<title>
DTC Troubleshooting
</title>
<attention3>
<ptxt>
This DTC might be detected when battery is run down or the voltage is very low.
</ptxt>
</attention3>
<diag type = "test" id = "AENAP70BA504023005">
<testgroup id = "AENAP70BA504023012">
<title>
Parameter check
</title>
<test1>
<ptxt>
Connect SUZUKI scan tool to DLC when ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Ignition 1 Relay” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENAP70BA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504023006">
<title>
IG1 relay power supply circuit (switch side) check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Remove IG1 relay.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “A2” circuit terminal of IG1 relay connector and ground is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness and “IGN” fuse.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504023007">
<title>
Fuse check
</title>
<test1>
<ptxt>
Check “MTR” fuse.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504023008">
<title>
IG1 relay signal circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “L10” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “L10” connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “B2” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B2” circuit terminal and each terminal at IG1 relay connector: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace “MTR” fuse and keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70BA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness, and then replace “MTR” fuse.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504023009">
<title>
IG1 relay signal circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “L10” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “L10” connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B2” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B2” circuit terminal and each terminal at IG1 relay connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B2” circuit: approx. 0 V (when ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504023010">
<title>
IG1 relay power supply circuit (coil side) check
</title>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “C2” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “C2” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “C2” circuit terminal and each terminal at IG1 relay connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “C2” circuit: approx. 0 V (when ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504023011">
<title>
IG1 relay check
</title>
<test1>
<ptxt>
Check IG1 relay. 
<intxreftitleoff1 refid = "AENAP70BA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace IG1 relay.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504023013">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Connect “L10” connector and install IG1 relay.
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70BA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is current DTC B1192 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70BA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
