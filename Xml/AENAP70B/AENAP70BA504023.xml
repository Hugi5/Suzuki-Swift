<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1192: Ignition 1 Relay Malfunction
</emph>
</ptxt>
<ptxt>
Inconsistency between input voltage via “MTR” fuse and IG1 relay control condition continuous for longer than specified time.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
IG1 relay circuit / connector
</ptxt>
</item>
<item>
<ptxt>
IG1 relay
</ptxt>
</item>
<item>
<ptxt>
“IGN” fuse
</ptxt>
</item>
<item>
<ptxt>
“MTR” fuse
</ptxt>
</item>
<item>
<ptxt>
Keyless start control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
