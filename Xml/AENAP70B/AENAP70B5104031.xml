<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5104031" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0741 / P0742
</title>
<servinfosub id = "AENAP70B5104031001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.431in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.747in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0741: Torque Converter Clutch Circuit Performance / Stuck Off
</emph>
</ptxt>
<ptxt>
Difference between engine speed and input shaft speed is more than specified value even if TCC solenoid is turned on.
</ptxt>
<ptxt>
(2 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
TCC solenoid valve
</ptxt>
</item>
<item>
<ptxt>
Valve body assembly
</ptxt>
</item>
<item>
<ptxt>
Torque converter clutch
</ptxt>
</item>
<item>
<ptxt>
TCM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0742: Torque Converter Clutch Circuit Stuck On
</emph>
</ptxt>
<ptxt>
Difference between engine speed and input shaft speed is less than specified value even if TCC solenoid is turned off.
</ptxt>
<ptxt>
(2 D/C detection logic)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70B5104031002">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed with two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Warm up engine to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Drive vehicle in “D” range for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Drive vehicle with 4th gear in “D” range and lock-up ON for 20 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Turn O/D off switch ON, and drive vehicle at 40 km/h (25 mile/h) for 20 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Stop vehicle and set ignition “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 2) through 4).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5104031003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B5104031004">
<testgroup id = "AENAP70B5104031005">
<question>
Was “A/T Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B5104001">A/T Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104031006">
<title>
TCC solenoid valve check for operation
</title>
<test1>
<ptxt>
Check TCC solenoid valve for operation. 
<intxreftitleoff1 refid = "AENAP70B5106029"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Clean fluid passage or replace valve body assembly. 
<intxreftitleoff1 refid = "AENAP70B5106026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If DTC P0741 and/or P0742 is still detected, substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B5106030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace TCC solenoid valve. 
<intxreftitleoff1 refid = "AENAP70B5106028"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
