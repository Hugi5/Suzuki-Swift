<servinfosub id = "AENAP70B6304016005">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B6304016006">
<testgroup id = "AENAP70B6304016007">
<question>
Was “P/S System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B6304001">P/S System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B6304016008">
<title>
DTC check
</title>
<test1>
<ptxt>
 Check DTC for ECM. 
<intxreftitleoff1 refid = "AENAP70B6304003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is there any DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC. (ECM-related faulty) 
<intxreftitleoff1 refid = "AENAP70B1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace P/S control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
