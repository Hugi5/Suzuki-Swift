<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B9F06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Front Speaker and Rear Speaker Removal and Installation
</title>
<servinfosub id = "AENAP70B9F06002001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove door trim.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70B9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70B9506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove 3 screws and remove front or rear speaker (1).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect speaker connector.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A9F0005.jpg" width = "88.000mm" height = "65.800mm" ver = "01" gw = "168" gh = "170"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70B9F06002002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
