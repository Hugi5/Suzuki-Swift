<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B9206012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Luggage Compartment Light Removal and Installation
</title>
<servinfosub id = "AENAP70B9206012001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove luggage compartment light (1) pulling it in arrow direction while releasing lock (2).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from luggage compartment light.
</ptxt>
</s1>
<s1>
<ptxt>
If necessary, remove bulb (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A920016.jpg" width = "88.000mm" height = "62.981mm" ver = "04" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B9206012002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
