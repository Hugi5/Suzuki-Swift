<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "3">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B7234A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Blower motor does not operate
</title>
<diag type = "condition">
<condition>
<ptxt>
Blower motor does not operate
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Check related fuses, and then check for short circuit to ground.
</ptxt>
</action>
<ps>
<ptxt>
Faulty blower motor relay
</ptxt>
</ps>
<action>
<ptxt>
Check blower motor relay. 
<intxreftitleoff1 refid = "AENAP70B7236041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty blower motor controller
</ptxt>
</ps>
<action>
<ptxt>
Check blower motor controller. 
<intxreftitleoff1 refid = "AENAP70B7236015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty blower motor
</ptxt>
</ps>
<action>
<ptxt>
Check blower motor. 
<intxreftitleoff1 refid = "AENAP70B7236015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty auto A/C panel
</ptxt>
</ps>
<action>
<ptxt>
Check auto A/C panel. 
<intxreftitleoff1 refid = "AENAP70B7234034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty HVAC control module
</ptxt>
</ps>
<action>
<ptxt>
Check HVAC control module. 
<intxreftitleoff1 refid = "AENAP70B7234035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Foreign material present
</ptxt>
</ps>
<action>
<ptxt>
Remove foreign material.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
