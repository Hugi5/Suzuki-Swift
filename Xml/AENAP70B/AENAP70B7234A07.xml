<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "3">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B7234A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Cool air does not come out only at high speed
</title>
<diag type = "condition">
<condition>
<ptxt>
Cool air does not come out only at high speed
</ptxt>
</condition>
<ps>
<ptxt>
Excessive amount of refrigerant
</ptxt>
</ps>
<action>
<ptxt>
Check the amount of refrigerant.
</ptxt>
</action>
<ps>
<ptxt>
Frosted A/C evaporator
</ptxt>
</ps>
<action>
<ptxt>
Check A/C evaporator. 
<intxreftitleoff1 refid = "AENAP70B7236016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty evaporator temperature sensor
</ptxt>
</ps>
<action>
<ptxt>
Check evaporator temperature sensor. 
<intxreftitleoff1 refid = "AENAP70B7226016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
