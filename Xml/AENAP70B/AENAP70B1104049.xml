<servinfosub id = "AENAP70B1104049001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.842in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.362in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0627: Fuel Pump “A” Control Circuit / Open
</emph>
</ptxt>
<ptxt>
Fuel pump relay drive circuit is open.
</ptxt>
<ptxt>
(3 D/C detection logic but MIL does not light up)
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Fuel pump relay and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0628: Fuel Pump “A” Control Circuit Low
</emph>
</ptxt>
<ptxt>
Fuel pump relay drive circuit is shorted to ground.
</ptxt>
<ptxt>
(3 D/C detection logic but MIL does not light up)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0629: Fuel Pump “A” Control Circuit High
</emph>
</ptxt>
<ptxt>
Fuel pump relay drive circuit is shorted to power supply.
</ptxt>
<ptxt>
(3 D/C detection logic but MIL does not light up)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
