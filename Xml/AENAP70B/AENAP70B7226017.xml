<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B7226017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Expansion Valve Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B7226008">HVAC Unit Components:Manual Type</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B7226017001">
<title>
Removal
</title>
<s1>
<ptxt>
Recover refrigerant from the A/C system with recovery and recycling equipment referring to “Recovery” in 
<intxref refid = "AENAP70B7226008">HVAC Unit Components:Manual Type</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Loosen bolt (1), then remove liquid pipe and suction hose from expansion valve (2).
</ptxt>
</s1>
<s1>
<ptxt>
Loosen bolts (3) and remove expansion valve.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A720028.swf" width = "88.000mm" height = "43.902mm" ver = "01" gw = "173" gh = "109"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B7226017002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B7226018">Expansion Valve Inspection:Manual Type</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply compressor oil to O-ring of expansion valve and pipes.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B204" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Compressor oil
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Tighten expansion valve bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T7B202">
<t-part>
Expansion valve bolt
</t-part>
<t-value1>
7.0
</t-value1>
<t-value2>
0.7
</t-value2>
<t-value3>
5.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Evacuate and charge the A/C system referring to “Evacuation” and “Charge” in 
<intxref refid = "AENAP70B7226001">Operation Procedure for Refrigerant Charge:Manual Type</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
