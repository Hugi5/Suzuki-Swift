<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B5104051" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
Transmission Warning Light Remains ON with Ignition “ON” (Non-Euro-OBD Model)
</title>
<servinfosub id = "AENAP70B5104051001">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENAP70B5104051002">
<testgroup id = "AENAP70B5104051003">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70B5104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is there any DTC(s)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Substitute a known-good combination meter and recheck transmission warning light operation. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If transmission warning light still remains ON, substitute a known-good TCM and recheck transmission warning light operation. 
<intxreftitleoff1 refid = "AENAP70B5106030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
