<servinfo servinfosgmlid = "AENAP70B9F06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Steering Switch (Audio Control Switch and Hands-Free Switch) Removal and Installation (If Equipped)
</title>
<servinfosub id = "AENAP70B9F06006001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove steering wheel referring to 
<intxref refid = "AENAP70B6206002">Steering Wheel Removal and Installation</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws and disconnect connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering wheel cover (2) and hands-free switch (3) (if equipped) from steering wheel.
</ptxt>
</s1>
<s1>
<ptxt>
Remove audio control switch (4) (if equipped) from steering wheel.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70B9F0002.jpg" width = "88.000mm" height = "65.397mm" ver = "02" gw = "190" gh = "169"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70B9F06006002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B9F06007">Steering Switch (Audio Control Switch and Hands-Free Switch) Inspection (If Equipped)</intxrefpoff>
</ptxt>
</servinfosub>
</servinfo>
