<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Select Cable Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106011">Select Cable Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5106012001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect select cable from select lever assembly and then detach from bracket. 
<intxreftitleoff1 refid = "AENAP70B5106005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove select cable clip and disconnect select cable from manual select lever.
</ptxt>
</s1>
<s1>
<ptxt>
Remove select cable from dash panel.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5106012002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply grease to pin and cable joint. 
<intxreftitleoff1 refid = "AENAP70B5106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Use new clip.
</ptxt>
</item>
<item>
<ptxt>
Tighten bolts and nuts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B5106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Adjust select cable. 
<intxreftitleoff1 refid = "AENAP70B5106013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
