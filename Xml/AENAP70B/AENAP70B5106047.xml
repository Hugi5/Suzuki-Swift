<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106047" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Forward and Reverse Clutch Assembly Disassembly and Reassembly
</title>
<ptxt>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106037">A/T Assembly Disassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106064">A/T Assembly Reassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106045">Forward and Reverse Clutch Assembly Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106046">Forward and Reverse Clutch Assembly Preliminary Check</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5106047001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove reverse clutch plate snap ring (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove reverse clutch retaining plates, discs, separator plate and clutch cushion plate from intermediate shaft subassembly.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510075.swf" width = "88.000mm" height = "42.280mm" ver = "01" gw = "190" gh = "103"/>
</figure>
</s1>
<s1>
<ptxt>
Remove forward clutch plate snap ring (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove forward clutch retaining plate, discs and separator plates from forward clutch drum.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510076.swf" width = "88.000mm" height = "44.947mm" ver = "01" gw = "187" gh = "110"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Using special tool and hydraulic press, compress forward clutch balancer (1) and remove balancer snap ring.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A026">
<s-part>
(A)
</s-part>
<s-number num = "09926-97610">
09926–97610
</s-number>
</servicetoolitem>
</servicetool>
<attention2>
<ptxt>
Do not press in forward clutch return spring subassembly more than 1.5 mm (0.059 in.).
</ptxt>
<ptxt>
Excessive compression may cause damage to return spring subassembly and/or balancer.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Remove forward clutch balancer.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510180.swf" width = "88.000mm" height = "52.397mm" ver = "01" gw = "175" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Remove forward clutch return spring subassembly (1) from intermediate shaft subassembly (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510181.swf" width = "88.000mm" height = "49.730mm" ver = "01" gw = "130" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Install intermediate shaft subassembly (1) to transaxle rear cover (2). Apply compressed air (400 – 800 kPa, 4.1 – 8.2 kgf/cm<sup>2</sup>, 58.0 – 116 psi) to oil hole (3) of transaxle rear cover to remove forward clutch piston (4).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510182.swf" width = "88.000mm" height = "51.805mm" ver = "01" gw = "192" gh = "130"/>
</figure>
</s1>
<s1>
<ptxt>
Apply compressed air (400 – 800 kPa, 4.1 – 8.2 kgf/cm<sup>2</sup>, 58.0 – 116 psi) to oil hole (1) of transaxle rear cover to remove forward clutch drum (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510183.swf" width = "88.000mm" height = "51.635mm" ver = "01" gw = "169" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Remove forward clutch piston O-ring (1) from intermediate shaft subassembly (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510184.swf" width = "88.000mm" height = "50.026mm" ver = "01" gw = "169" gh = "125"/>
</figure>
</s1>
<s1>
<ptxt>
Remove forward clutch drum O-ring (1) from forward clutch drum (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510185.swf" width = "88.000mm" height = "49.815mm" ver = "01" gw = "157" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Remove intermediate shaft seal ring (1) from intermediate shaft subassembly (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510186.swf" width = "88.000mm" height = "43.253mm" ver = "01" gw = "171" gh = "106"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5106047002">
<title>
Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106048">Forward and Reverse Clutch Assembly Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse disassembly procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new O-rings and seal ring. Apply ATF before installation.
</ptxt>
</item>
<item>
<ptxt>
Use new balancer snap ring.
</ptxt>
</item>
<item>
<ptxt>
Do not damage forward clutch return spring subassembly and balancer (1) by pressing forward clutch return spring subassembly passing through its original installing position over 1.5 mm (0.059 in.).
</ptxt>
<servicetool>
<servicetoolitem id = "L5A027">
<s-part>
(A)
</s-part>
<s-number num = "09926-97610">
09926–97610
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B510180.swf" width = "88.000mm" height = "52.397mm" ver = "01" gw = "175" gh = "132"/>
</figure>
</item>
<item>
<ptxt>
Apply ATF to forward clutch separator plates (1), discs (2) and retaining plate (3).
</ptxt>
</item>
<item>
<ptxt>
Before assembling discs, soak them in ATF for two hours or more.
</ptxt>
</item>
<item>
<ptxt>
Install forward clutch separator plates, discs and retaining plate, then new forward clutch plate snap ring (4) to forward clutch drum.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510077.swf" width = "88.000mm" height = "47.505mm" ver = "01" gw = "97" gh = "118"/>
</figure>
</item>
<c-change/>
<item>
<ptxt>
Install new forward clutch plate snap ring so that its both ends would be positioned in correct location as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B510188.swf" width = "88.000mm" height = "92.614mm" ver = "01" gw = "171" gh = "246"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.766in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.827in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Correct
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Incorrect
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Measure forward clutch piston stroke. 
<intxreftitleoff1 refid = "AENAP70B5106046"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
When piston stroke is out of specification, select forward clutch retaining plate with suitable thickness from among the following table and replace it.
</ptxt>
<spec>
<title>
Available forward clutch retaining plate thickness
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.731in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.731in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Thickness
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Identification mark
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
