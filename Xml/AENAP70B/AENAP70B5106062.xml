<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106062" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Transaxle Case Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106037">A/T Assembly Disassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106064">A/T Assembly Reassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B5106035">A/T Assembly Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5106062001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove differential side oil seal (1) using a flat-bladed screwdriver or the like.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510085.swf" width = "88.000mm" height = "49.011mm" ver = "01" gw = "177" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Remove countershaft left bearing cup and shim using special tools.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A063">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944–96011
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A064">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942–15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B510248.swf" width = "88.000mm" height = "49.900mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Remove differential side left bearing cup and shim using special tools.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A065">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944–96011
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A066">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942–15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B510249.swf" width = "88.000mm" height = "47.402mm" ver = "01" gw = "148" gh = "117"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B5106062002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Using special tools, assemble shim and differential side left bearing cup.
</ptxt>
<attention3>
<ptxt>
Use shim with the same thickness as removed one.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L5A067">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A068">
<s-part>
(B)
</s-part>
<s-number num = "09944-88220">
09944–88220
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I3RM0B510065.swf" width = "88.000mm" height = "45.898mm" ver = "01" gw = "164" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Using special tools, install shim and countershaft left bearing cup.
</ptxt>
<attention3>
<ptxt>
Use shim with the same thickness as removed one.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L5A069">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A070">
<s-part>
(B)
</s-part>
<s-number num = "09944-88220">
09944–88220
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I3RM0B510066.swf" width = "88.000mm" height = "48.687mm" ver = "01" gw = "161" gh = "122"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Using special tools, install new differential side oil seal to transaxle case evenly at specified position shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A071">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5A072">
<s-part>
(B)
</s-part>
<s-number num = "09951-16091">
09951–16091
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Differential side oil seal installing depth
</title>
<ptxt>
“a”: 3.8 – 4.8 mm (0.15 – 0.18 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Apply grease to oil seal lip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease C" id = "M5A005" uid = "23">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25030
</m-number>
<m-name>
SUZUKI Super Grease C
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A510061.swf" width = "88.000mm" height = "74.792mm" ver = "03" gw = "171" gh = "195"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
