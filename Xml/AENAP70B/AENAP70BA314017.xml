<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70BA314017" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1188
</title>
<servinfosub id = "AENAP70BA314017001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1188: Transponder Communication Error
</emph>
</ptxt>
<ptxt>
Verification error between ignition key and BCM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Ignition key is not registered
</ptxt>
</item>
<item>
<ptxt>
Ignition key 
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70BA314017002">
<title>
DTC Troubleshooting
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Before troubleshooting be sure to read 
<intxref refid = "AENAP70BA310002">Precautions for Immobilizer System:Ignition Switch Model</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
If the BCM is one that was registered with another vehicle (used item), ignition keys cannot be registered. Always install a new BCM when replacement is necessary.
</ptxt>
</item>
</list1>
</attention3>
<diag type = "test" id = "AENAP70BA314017003">
<testgroup id = "AENAP70BA314017004">
<title>
Engine start check
</title>
<test1>
<ptxt>
Start engine using the spare ignition key.
</ptxt>
</test1>
<question>
Does engine start?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Ignition key was not registered)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA314017005">
<title>
Ignition key registration
</title>
<test1>
<ptxt>
Perform “Immobilizer Key Registration”. 
<intxreftitleoff1 refid = "AENAP70BA316002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Recheck DTC. 
<intxreftitleoff1 refid = "AENAP70BA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1188 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace BCM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70BA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Ignition key wad not registered)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
