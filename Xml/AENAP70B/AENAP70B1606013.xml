<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1606013" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Radiator Cooling Fan Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B1606012">Radiator Cooling Fan Assembly Removal and Installation</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B1606013001">
<title>
Disassembly
</title>
<s1 page = "2">
<ptxt>
Remove fan (1) from cooling fan motor (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove cooling fan motor (2) from cooling fan shroud (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P160006.jpg" width = "88.000mm" height = "55.324mm" ver = "01" gw = "207" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1606013002" page = "2">
<title>
Reassembly
</title>
<ptxt>
Reverse disassembly procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten fan nut and radiator cooling fan motor bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1F001">
<t-part>
Fan nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6.0
</t-value1>
<t-value2>
0.61
</t-value2>
<t-value3>
4.5
</t-value3>
</torqueitem>
<torqueitem id = "T1F002">
<t-part>
Radiator cooling fan motor bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
4.0
</t-value1>
<t-value2>
0.41
</t-value2>
<t-value3>
3.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70P160010.jpg" width = "88.000mm" height = "51.127mm" ver = "03" gw = "223" gh = "128"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
