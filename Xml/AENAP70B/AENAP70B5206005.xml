<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5206005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Gear Shift Control Lever and Cable Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5206004">Gear Shift Control Lever and Cable Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5206005001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove ECM from battery tray. 
<intxreftitleoff1 refid = "AENAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery and battery tray. 
<intxreftitleoff1 refid = "AENAP70B1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove floor console front box. 
<intxreftitleoff1 refid = "AENAP70B9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect gear shift and select control cable ends (5) from pivot (6) of gear shift control lever assembly.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect gear shift and select control cables (1) from gear shift control lever assembly (2) while pulling quick joint (4) to arrow direction as shown in figure.
</ptxt>
</s1>
<s1>
<ptxt>
Remove nuts (3) and remove gear shift control lever assembly from floor panel.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520038.swf" width = "88.000mm" height = "74.693mm" ver = "01" gw = "187" gh = "195"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
7.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Pin
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Disconnect gear shift and select control cables from transaxle.
</ptxt>
</s1>
<s1>
<ptxt>
Remove cable grommet bolt, and then remove gear shift and select control cables from floor panel.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5206005002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten each bolts and nuts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Adjust gear select control cable. 
<intxreftitleoff1 refid = "AENAP70B5206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
