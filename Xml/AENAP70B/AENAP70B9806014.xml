</title>
<servinfosub id = "AENAP70B9806014001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove roof lining. 
<intxreftitleoff1 refid = "AENAP70B9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front rib pad (1) and rear rib pad (2).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70B980004.jpg" width = "183.000mm" height = "87.957mm" ver = "01" gw = "508" gh = "233"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70B9806014002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
