<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106001" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
TCM Learning Control Initialization
</title>
<attention2>
<ptxt>
When A/T unit is replaced, initialize learning control.
</ptxt>
</attention2>
<s1>
<ptxt>
With ignition “OFF”, connect SUZUKI scan tool to DLC (1) located on underside of instrument panel at driver’s side.
</ptxt>
<servicetool>
<servicetoolitem id = "L5A005">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI scan tool (SUZUKI-SDT)
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A510018.jpg" width = "88.000mm" height = "67.502mm" ver = "02" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Start engine and shift select lever to “P” range.
</ptxt>
</s1>
<s1>
<ptxt>
Select “Active Test” mode on scan tool.
</ptxt>
</s1>
<s1>
<ptxt>
Perform “AT Learned Initialize” on scan tool.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
