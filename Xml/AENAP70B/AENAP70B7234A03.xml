<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "3">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B7234A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
No cool air comes out (radiator cooling fan motor does not operate)
</title>
<diag type = "condition">
<condition>
<ptxt>
No cool air comes out (radiator cooling fan motor does not operate)
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Check related fuses, and then check for short circuit to ground.
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty radiator cooling fan motor relay
</ptxt>
</ps>
<action>
<ptxt>
Check radiator cooling fan motor relay. 
<intxreftitleoff1 refid = "AENAP70B7236041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty radiator cooling fan motor
</ptxt>
</ps>
<action>
<ptxt>
Check radiator cooling fan motor. 
<intxreftitleoff1 refid = "AENAP70B7236004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
Check ECM. 
<intxreftitleoff1 refid = "AENAP70B7234036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty HVAC control module
</ptxt>
</ps>
<action>
<ptxt>
Check HVAC control module. 
<intxreftitleoff1 refid = "AENAP70B7234035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
