<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106021" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Input Shaft Speed Sensor Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106020">Input Shaft Speed Sensor Removal and Installation</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect input shaft speed sensor connector (2).
</ptxt>
</s1>
<s1>
<ptxt>
Check resistance between input shaft speed sensor (1) terminals.
</ptxt>
<ptxt>
If measured resistance is out of specified resistance, replace input shaft speed sensor.
</ptxt>
<spec>
<title>
Input shaft speed sensor resistance
</title>
<ptxt>
Standard: 560 – 680 Ω at 20 &#176;C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A510039.swf" width = "88.000mm" height = "51.598mm" ver = "02" gw = "214" gh = "130"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
