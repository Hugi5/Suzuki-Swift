<servinfosub id = "AENAP70BA504020003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Push request switch related to DTC.
</ptxt>
</s1>
<s1>
<ptxt>
Release request switch.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 2) and 3) several times.
</ptxt>
</s1>
<s1>
<ptxt>
Keep ignition “ON” for 10 minutes or more.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70BA504020004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70BA504020005">
<testgroup id = "AENAP70BA504020008">
<title>
Parameter check
</title>
<test1>
<ptxt>
Connect SUZUKI scan tool to DLC when ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Driver Request SW”, “Passenger Request SW” or “Rear door/trunk requ SW” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENAP70BA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504020006">
<title>
Door request switch signal circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect request switch and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to door request switch and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check that resistance of “A1”, “A2” and “A3” circuits: less than 1 Ω
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504020007">
<title>
Door request switch check
</title>
<test1>
<ptxt>
Check door request switch. 
<intxreftitleoff1 refid = "AENAP70BA506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace door request switch.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA504020009">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Connect door request switch and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70BA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is current DTC B1180, B1181 or B1182 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70BA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
</testgroup>
</diag>
