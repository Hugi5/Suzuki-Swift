<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B1104A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Engine overheating
</title>
<ptxt>
Perform troubleshooting referring to the following points when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENAP70B1104008">Visual Inspection</intxref>
 and 
<intxref refid = "AENAP70B1104009">Engine Basic Inspection</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Engine overheating
</ptxt>
</condition>
<ps>
<ptxt>
Inoperative thermostat
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1606009">Thermostat Assembly (Incorporating with ECT Sensor) Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Poor water pump performance
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1606017">Water Pump Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Clogged or leaky radiator
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1606014">Radiator On-Vehicle Inspection and Cleaning</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Improper engine oil grade
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B0206004">Engine Oil and Filter Change</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Clogged oil filter or oil strainer
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1504001">Oil Pressure Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Poor oil pump performance
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1504001">Oil Pressure Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty radiator cooling fan control system
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1604002">Radiator Cooling Fan System Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Dragging brakes
</ptxt>
</ps>
<action>
<ptxt>
Condition “Dragging brakes” in 
<intxref refid = "AENAP70B4104001">Brakes Symptom Diagnosis</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slipping clutch (for M/T model)
</ptxt>
</ps>
<action>
<ptxt>
Condition “Slipping clutch” in 
<intxref refid = "AENAP70B5304001">Clutch System Symptom Diagnosis</intxref>
 for M/T model
</ptxt>
</action>
<ps>
<ptxt>
Blown cylinder head gasket
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1406029">Cylinder Head Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Air mixed in cooling system
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70B1606006">Cooling System Refilling</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
