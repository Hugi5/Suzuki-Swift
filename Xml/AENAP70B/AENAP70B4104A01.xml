<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B4104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Not enough braking force
</title>
<diag type = "condition">
<condition>
<ptxt>
Not enough braking force
</ptxt>
</condition>
<ps>
<ptxt>
Brake fluid leakage from brake lines
</ptxt>
</ps>
<action>
<ptxt>
Locate leaking point and repair.
</ptxt>
</action>
<ps>
<ptxt>
Brake disc or pads stained with fluid, grease or other oil
</ptxt>
</ps>
<action>
<ptxt>
Clean or replace.
</ptxt>
</action>
<ps>
<ptxt>
Overheated brakes
</ptxt>
</ps>
<action>
<ptxt>
Determine cause and repair.
</ptxt>
</action>
<ps>
<ptxt>
Poor contact of shoes on brake drum (rear drum brake model)
</ptxt>
</ps>
<action>
<ptxt>
Repair for proper contact.
</ptxt>
</action>
<ps>
<ptxt>
Brake shoe stained with oil or wet with water (rear drum brake model)
</ptxt>
</ps>
<action>
<ptxt>
Replace.
</ptxt>
</action>
<ps>
<ptxt>
Badly worn brake pad and/or shoe
</ptxt>
</ps>
<action>
<ptxt>
Replace.
</ptxt>
</action>
<ps>
<ptxt>
Defective wheel cylinders (rear drum brake model)
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace.
</ptxt>
</action>
<ps>
<ptxt>
Malfunctioning brake caliper assembly
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace.
</ptxt>
</action>
<ps>
<ptxt>
Air in system
</ptxt>
</ps>
<action>
<ptxt>
Bleed air from brake system.
</ptxt>
</action>
<ps>
<ptxt>
Brake booster internal failure
</ptxt>
</ps>
<action>
<ptxt>
Replace brake booster.
</ptxt>
</action>
<ps>
<ptxt>
Negative pressure for brake booster is inadequate
</ptxt>
</ps>
<action>
<ptxt>
Check engine condition and vacuum hose.
</ptxt>
</action>
<ps>
<ptxt>
Malfunctioning ABS / ESP<sup>®</sup>
</ptxt>
</ps>
<action>
<ptxt>
Check system and replace if necessary.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
