<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5306018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Clutch Cover and Clutch Disc Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5306017">Clutch Cover and Clutch Disc Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B5306018001">
<title>
Removal
</title>
<s1>
<ptxt>
Dismount manual transaxle. 
<intxreftitleoff1 refid = "AENAP70B5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Hold flywheel with special tool and remove clutch cover bolts (1), clutch cover (2) and clutch disc.
</ptxt>
<servicetool>
<servicetoolitem id = "L5C001">
<s-part>
(A)
</s-part>
<s-number num = "09924-17811">
09924–17811
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A531018.swf" width = "88.000mm" height = "52.891mm" ver = "01" gw = "157" gh = "133"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70B5306018002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5306019">Clutch Cover and Clutch Disc Inspection</intxrefpoff>
</ptxt>
<attention3>
<ptxt>
Before assembling, make sure that flywheel surface and pressure plate surface have been cleaned and dried thoroughly.
</ptxt>
</attention3>
<s1>
<ptxt>
Hold flywheel with special tool (A).
</ptxt>
<servicetool>
<servicetoolitem id = "L5C002">
<s-part>
(A)
</s-part>
<s-number num = "09924-17811">
09924–17811
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Align clutch disc with crankshaft center using special tool (B) and install clutch cover (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L5C003">
<s-part>
(B)
</s-part>
<s-number num = "09923-36320">
09923–36320
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Install and tighten clutch cover bolts using the following procedure:
</ptxt>
<s2>
<ptxt>
Tighten 3 bolts (3) by hand.
</ptxt>
</s2>
<s2>
<ptxt>
Tighten other 3 bolts (4) evenly and gradually to 5.0 N&#183;m (0.51 kgf-m, 4.0 lbf-ft).
</ptxt>
</s2>
<s2>
<ptxt>
Fully tighten all bolts (3), (4) evenly and gradually to specified torque in numerical order (“1” – “6”) starting from bolt nearby strut plate rivet (2).
</ptxt>
</s2>
<attention3>
<ptxt>
While tightening clutch cover bolts, make sure that clutch disc spline is centered.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T5C005">
<t-part>
Clutch cover bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-note>
5.0 N&#183;m &#8594; 23 N&#183;m (0.51 kgf-m &#8594; 2.3 kgf-m, 4.0 lbf-ft &#8594; 17.0 lbf-ft)
</t-note>
</torqueitem>
<torqueitem id = "T5C006">
<t-part>
Clutch cover bolt*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A531019.swf" width = "88.000mm" height = "78.419mm" ver = "02" gw = "238" gh = "206"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Slightly apply grease to input shaft (1), then join manual transaxle with engine. 
<intxreftitleoff1 refid = "AENAP70B5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease I" id = "M5C004" uid = "26">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25210
</m-number>
<m-name>
SUZUKI Super Grease I
</m-name>
</materialitem>
</materials>
<attention3>
<ptxt>
When inserting transaxle input shaft to clutch disc, turn crankshaft little by little to match the splines.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I4RS0A530018.swf" width = "88.000mm" height = "48.164mm" ver = "01" gw = "167" gh = "120"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
