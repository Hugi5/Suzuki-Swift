<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B7226007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Desiccant Removal and Installation
</title>
<servinfosub id = "AENAP70B7226007001">
<title>
Removal
</title>
<s1>
<ptxt>
Recover refrigerant from A/C system referring to “Recovery” in 
<intxref refid = "AENAP70B7226001">Operation Procedure for Refrigerant Charge:Manual Type</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENAP70B9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front bumper member brace and front bumper lower absorber. 
<intxreftitleoff1 refid = "AENAP70B9806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove filter cap (1) from receiver (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove desiccant (3) and O-rings (4).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A721037.swf" width = "88.000mm" height = "45.459mm" ver = "01" gw = "210" gh = "112"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70B7226007002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Do not take out desiccant out from plastic bag until just before inserting it into receiver.
</ptxt>
</item>
<item>
<ptxt>
Install new desiccant, new O-ring and new filter cap.
</ptxt>
</item>
<item>
<ptxt>
Apply specified compressor oil to O-ring.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B203" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Compressor oil
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Tighten filter cap to specified torque.
</ptxt>
<torque>
<torqueitem id = "T7B201">
<t-part>
Filter cap
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
18
</t-value1>
<t-value2>
1.8
</t-value2>
<t-value3>
13.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Evacuate and charge A/C system referring to “Evacuation” and “Charge” in 
<intxref refid = "AENAP70B7226001">Operation Procedure for Refrigerant Charge:Manual Type</intxref>
.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A721038.swf" width = "88.000mm" height = "40.160mm" ver = "01" gw = "172" gh = "97"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
