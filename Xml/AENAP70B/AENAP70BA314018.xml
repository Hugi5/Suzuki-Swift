<servinfosub id = "AENAP70BA314018003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition “ON” for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70BA314018004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70BA314018005">
<testgroup id = "AENAP70BA314018006">
<title>
Immobilizer control module signal circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G17” and “G04” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “G17” and “G04” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1”, “A2”, “A3” and “A4” circuits: less than 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A1”, “A2”, “A3” and “A4” circuits and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit terminal and other terminals at “G17” connector.
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70BA314018007">
<title>
DTC check
</title>
<test1>
<ptxt>
Replace immobilizer control module. 
<intxreftitleoff1 refid = "AENAP70BA316001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Perform 
<intxref refid = "AENAP70BA314018003">DTC Confirmation Procedure</intxref>
 and then recheck DTC. 
<intxreftitleoff1 refid = "AENAP70BA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1189 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace BCM and recheck DTC.	 
<intxreftitleoff1 refid = "AENAP70BA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Immobilizer control module was faulty)
</ptxt>
</action>
</testgroup>
</diag>
