<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B2104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Cupped tires
</title>
<diag type = "condition">
<condition>
<ptxt>
Cupped tires
</ptxt>
</condition>
<ps>
<ptxt>
Disturbed wheel alignment
</ptxt>
</ps>
<action>
<ptxt>
Check and adjust wheel alignment. 
<intxreftitleoff1 refid = "AENAP70B2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty front strut assembly 
</ptxt>
</ps>
<action>
<ptxt>
Replace front strut assembly. 
<intxreftitleoff1 refid = "AENAP70B2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn wheel bearings
</ptxt>
</ps>
<action>
<ptxt>
Replace wheel bearings. 
<intxreftitleoff1 refid = "AENAP70B3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Excessive tire or wheel run-out
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace tire and/or wheel.
</ptxt>
</action>
<ps>
<ptxt>
Worn suspension arm joints
</ptxt>
</ps>
<action>
<ptxt>
Replace suspension arm. 
<intxreftitleoff1 refid = "AENAP70B2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Wheel out of balance
</ptxt>
</ps>
<action>
<ptxt>
Adjust balance or replace tire.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
