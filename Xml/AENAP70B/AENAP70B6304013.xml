</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B6304013004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B6304013005">
<testgroup id = "AENAP70B6304013006">
<question>
Was “EPS System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B6304001">P/S System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B6304013007">
<title>
P/S motor and P/S motor output circuits check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect P/S motor connector “E12” from P/S control module.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connections to P/S motor connector “E12”.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “A1” and “A2” circuit: approx. 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A1” circuit: approx. 0 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Check P/S motor. 
<intxreftitleoff1 refid = "AENAP70B6306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace P/S control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace P/S motor (Steering column assembly). 
<intxreftitleoff1 refid = "AENAP70B6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
