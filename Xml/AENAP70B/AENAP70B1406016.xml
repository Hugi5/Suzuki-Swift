<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1406016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Engine Assembly Removal and Installation
</title>
<servinfosub id = "AENAP70B1406016001">
<title>
Removal
</title>
<s1>
<ptxt>
Relieve fuel pressure. 
<intxreftitleoff1 refid = "AENAP70B1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery. 
<intxreftitleoff1 refid = "AENAP70B1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect ECM connectors. 
<intxref refid = "AENAP70B1306001">ECM Removal and Installation</intxref>
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery bracket with ECM.
</ptxt>
</s1>
<s1>
<ptxt>
Remove right and left side engine undercovers.
</ptxt>
</s1>
<s1>
<ptxt>
Drain the following oils and fluid if necessary.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Engine oil: 
<intxreftitleoff1 refid = "AENAP70B1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manual transaxle oil (M/T model): 
<intxreftitleoff1 refid = "AENAP70B5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
ATF (A/T model): 
<intxreftitleoff1 refid = "AENAP70B5106003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENAP70B1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENAP70B1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
With hose connected, detach A/C compressor from its bracket. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENAP70B7226037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C model: 
<intxreftitleoff1 refid = "AENAP70B7236006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Suspend removed A/C compressor at a place where no damage will be caused during removal and installation of engine assembly.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Disconnect the following electric wires/connectors and each clamps.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery ground cable (1)
</ptxt>
</item>
<item>
<ptxt>
Connectors (2) in main fuse box
</ptxt>
</item>
<item>
<ptxt>
Electric load current sensor connector (3)
</ptxt>
</item>
<item>
<ptxt>
Connector (4) in individual circuit fuse box No.1
</ptxt>
<figure>
<graphic graphicname = "I9P60A141043.jpg" width = "88.000mm" height = "60.102mm" ver = "01" gw = "199" gh = "154"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
For A/T model, disconnect TCM connectors, and then pull out engine harness to engine compartment.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect the following cables.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Gear select control cable (1) (M/T model)
</ptxt>
</item>
<item>
<ptxt>
Gear shift control cable (2) (M/T model)
</ptxt>
</item>
<item>
<ptxt>
A/T select cable (3) (A/T model)
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
For M/T model, remove clutch operating cylinder assembly (4) from transaxle. 
<intxreftitleoff1 refid = "AENAP70B5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "IAP70B140017.jpg" width = "88.000mm" height = "115.442mm" ver = "01" gw = "199" gh = "311"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.742in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.397in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.772in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
M/T model
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
A/T model
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Disconnect the following hoses.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Brake booster hose (1)
</ptxt>
</item>
<item>
<ptxt>
Radiator inlet and outlet hoses (2)
</ptxt>
</item>
<item>
<ptxt>
Heater inlet and outlet hoses (3)
</ptxt>
</item>
<item>
<ptxt>
Fuel feed hose (4)
</ptxt>
</item>
<item>
<ptxt>
ATF cooler hoses (5) (A/T model)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A141045.jpg" width = "88.000mm" height = "108.927mm" ver = "01" gw = "199" gh = "292"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Disconnect steering lower shaft from pinion shaft. 
<intxreftitleoff1 refid = "AENAP70B6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove stabilizer bar joints from stabilizer bar. 
<intxreftitleoff1 refid = "AENAP70B2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect tie-rod end from steering knuckle. 
<intxreftitleoff1 refid = "AENAP70B6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect right and left drive shaft joints from steering knuckle. 
<intxreftitleoff1 refid = "AENAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust No.1 pipe and exhaust center pipe. 
<intxreftitleoff1 refid = "AENAP70B1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Support front suspension frame (1), transaxle case (2) and cylinder block (3) using jack.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front suspension frame bolts (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141047.jpg" width = "88.000mm" height = "54.937mm" ver = "01" gw = "199" gh = "139"/>
</figure>
</s1>
<s1>
<ptxt>
Remove engine left mounting bracket bolt (1) and nuts (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70B140018.jpg" width = "88.000mm" height = "114.203mm" ver = "01" gw = "199" gh = "307"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.309in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.724in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.253in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.676in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
M/T model
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
A/T model
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove engine right mounting bracket bolt (1) and nuts (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A140006.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1>
<ptxt>
Before removing engine make sure that all hoses, electric wires and cables are disconnected from engine.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Lower engine with transaxle, front suspension frame, drive shafts, P/S gear case assembly all together.
</ptxt>
<attention2>
<ptxt>
Before lowering engine, in order to avoid damage to A/C compressor, make clearance between A/C compressor and engine by suspending A/C compressor.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Disconnect engine harness from engine and transaxle, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front drive shaft assembly, if necessary. 
<intxreftitleoff1 refid = "AENAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove drive intermediate shaft assembly, if necessary. 
<intxreftitleoff1 refid = "AENAP70B3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front suspension frame, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect transaxle from engine, if necessary.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
M/T model: 
<intxreftitleoff1 refid = "AENAP70B5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
A/T model: 
<intxreftitleoff1 refid = "AENAP70B5106036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove clutch cover and clutch disc, if necessary. 
<intxreftitleoff1 refid = "AENAP70B5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, remove flywheel, if necessary. 
<intxreftitleoff1 refid = "AENAP70B1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
For A/T model, remove drive plate, if necessary. 
<intxreftitleoff1 refid = "AENAP70B1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1406016002" page = "2">
<title>
Installation
</title>
<s1>
<ptxt>
For M/T model, install flywheel, if removed. 
<intxreftitleoff1 refid = "AENAP70B1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
For A/T model, install drive plate, if removed. 
<intxreftitleoff1 refid = "AENAP70B1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
For M/T model, install clutch cover and clutch disc, if removed. 
<intxreftitleoff1 refid = "AENAP70B5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install transaxle to engine, if removed.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
M/T model: 
<intxreftitleoff1 refid = "AENAP70B5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
A/T model: 
<intxreftitleoff1 refid = "AENAP70B5106036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Install front suspension frame, if removed. 
<intxreftitleoff1 refid = "AENAP70B1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install drive intermediate shaft assembly, if removed. 
<intxreftitleoff1 refid = "AENAP70B3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install front drive shaft assembly, if removed. 
<intxreftitleoff1 refid = "AENAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install engine harness to engine and transaxle and then tighten engine harness ground bolt (1) to specified torque, if removed.
</ptxt>
<torque>
<torqueitem id = "T1D007">
<t-part>
Engine harness ground bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141049.jpg" width = "88.000mm" height = "55.192mm" ver = "01" gw = "199" gh = "140"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Lift up engine with transaxle, front suspension frame, drive shafts, P/S gear case assembly all together.
</ptxt>
<attention2>
<ptxt>
Before lifting engine, in order to avoid damage to A/C compressor, make clearance between A/C compressor and engine by suspending A/C compressor.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Tighten engine right mounting bracket bolt (1) and nuts (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D008">
<t-part>
Engine right mounting bracket bolt and nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140008.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Tighten engine left mounting bracket bolt (1) and nuts (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D009">
<t-part>
Engine left mounting bracket bolt and nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70B140020.jpg" width = "88.000mm" height = "114.203mm" ver = "01" gw = "199" gh = "307"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.428in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.662in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.363in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.712in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
M/T model
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
A/T model
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Tighten suspension frame bolts to specified torque. 
<intxreftitleoff1 refid = "AENAP70B2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install exhaust No.1 pipe and exhaust center pipe. 
<intxreftitleoff1 refid = "AENAP70B1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect right and left drive shaft joints to steering knuckle. 
<intxreftitleoff1 refid = "AENAP70B3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect tie-rod end from steering knuckle. 
<intxreftitleoff1 refid = "AENAP70B6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install stabilizer bar joints to stabilizer bar. 
<intxreftitleoff1 refid = "AENAP70B2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Connect steering lower shaft from pinion shaft. 
<intxreftitleoff1 refid = "AENAP70B6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install all other removed electric wires, connectors and hoses to original locations.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Tighten battery ground terminal bolt (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141052.jpg" width = "88.000mm" height = "60.441mm" ver = "02" gw = "199" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
For M/T model, install clutch operating cylinder assembly. 
<intxreftitleoff1 refid = "AENAP70B5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, connect gear shift control cable. 
<intxreftitleoff1 refid = "AENAP70B5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
For A/T model, connect A/T select cable. 
<intxreftitleoff1 refid = "AENAP70B5106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install A/C compressor to its bracket. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model 
<intxreftitleoff1 refid = "AENAP70B7226037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C model 
<intxreftitleoff1 refid = "AENAP70B7236044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Install A/C compressor drive belt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENAP70B7226036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C model: 
<intxreftitleoff1 refid = "AENAP70B7236043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Install air cleaner assembly. 
<intxreftitleoff1 refid = "AENAP70B1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
