<servinfosub id = "AENAP70B5104027003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Warm up engine to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Run engine at idle speed for 1 min.
</ptxt>
</s1>
</servinfosub>
<p-change/>
<servinfosub id = "AENAP70B5104027004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B5104027005">
<testgroup id = "AENAP70B5104027006">
<question>
Was “A/T Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B5104001">A/T Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104027007">
<title>
ATF temperature sensor circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF” and disconnect TCM and solenoid connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to TCM and solenoid connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check that ATF temperature sensor signal circuit (A1) is as follows.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Insulation resistance of ATF temperature sensor signal circuit is infinity between solenoid connector and ground.
</ptxt>
</item>
<item>
<ptxt>
Insulation resistance of wire harness is infinity between ATF temperature sensor signal circuit terminal and each terminal at solenoid connector.
</ptxt>
</item>
</list1>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B5104027008">
<title>
ATF temperature sensor check
</title>
<test1>
<ptxt>
Check ATF temperature sensor. 
<intxreftitleoff1 refid = "AENAP70B5106025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B5106030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace ATF temperature sensor. 
<intxreftitleoff1 refid = "AENAP70B5106024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
