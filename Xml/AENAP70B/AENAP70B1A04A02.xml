<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70B1A04A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Charge warning light does not go out with engine running (battery requires frequent recharging)
</title>
<ptxt>
Trouble in charging system will show up as one or more of the following conditions.
</ptxt>
<servinfosub id = "AENAP70B1A04002001" page = "1">
<title>
Charging Warning Light Operation
</title>
<diag type = "condition">
<condition>
<ptxt>
Charge warning light does not go out with engine running (battery requires frequent recharging)
</ptxt>
</condition>
<ps>
<ptxt>
Loose or worn drive belt
</ptxt>
</ps>
<action>
<ptxt>
Adjust or replace drive belt. 
<intxreftitleoff1 refid = "AENAP70B1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty combination meter
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Check BCM. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENAP70BA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENAP70BA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Faulty IC regulator or generator
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70B1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace wiring.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
