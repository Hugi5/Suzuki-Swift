<servinfosub id = "AENAP70B1104073003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed by two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<ptxt>
Check to make sure that the following conditions are satisfied when using this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery voltage &#62; 11 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Warm up engine to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Drive vehicle at 60 to 80 km/h (37 to 50 mile/h) constantly for 1 min. or more.
</ptxt>
</s1>
<s1>
<ptxt>
Release accelerator pedal, and keep vehicle coasting for 15 sec. with engine braking applied (fuel cut condition).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1104073004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70B1104073005">
<testgroup id = "AENAP70B1104073006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70B1104001">Engine and Emission Control System Check</intxref>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104073012">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC.
</ptxt>
</test1>
<question>
Is there DTC(s) detected other than P0130?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104073007">
<title>
HO2S-1 heater, HO2S-1 circuit and HO2S-1 heater circuit check
</title>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
HO2S-1 heater: 
<intxreftitleoff1 refid = "AENAP70B1306014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
HO2S-1 circuit: Step 3 under 
<intxref refid = "AENAP70B1104025">DTC P0131 / P0132</intxref>
</ptxt>
</item>
<item>
<ptxt>
HO2S-1 heater circuit: Step 2 through 3 under 
<intxref refid = "AENAP70B1104015">DTC P0030 / P0031 / P0032</intxref>
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104073008">
<title>
HO2S-2 heater, HO2S-2 circuit and HO2S-2 heater circuit check
</title>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
HO2S-2 heater: 
<intxreftitleoff1 refid = "AENAP70B1306014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
HO2S-2 circuit: Step 3 under 
<intxref refid = "AENAP70B1104028">DTC P0137 / P0138 / P0140</intxref>
</ptxt>
</item>
<item>
<ptxt>
HO2S-2 heater circuit: Step 2 through 3 under 
<intxref refid = "AENAP70B1104016">DTC P0036 / P0037 / P0038</intxref>
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104073009">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Replace HO2S-1.
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure, and check DTC.
</ptxt>
</test1>
<question>
Is DTC P0130 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
END.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B1104073010">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Replace HO2S-2.
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure, and check DTC.
</ptxt>
</test1>
<question>
Is DTC P0130 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
END.
</ptxt>
</action>
</testgroup>
</diag>
