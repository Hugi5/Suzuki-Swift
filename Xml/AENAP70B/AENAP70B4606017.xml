<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B4606017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
ESP® OFF Switch Removal and Installation
</title>
<servinfosub id = "AENAP70B4606017001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove switch bezel with ESP<sup>®</sup> OFF switch from instrument panel. 
<intxreftitleoff1 refid = "AENAP70B9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from ESP<sup>®</sup> OFF switch.
</ptxt>
</s1>
<s1>
<ptxt>
Remove ESP<sup>®</sup> OFF switch (1) from switch bezel.
</ptxt>
<figure>
<graphic graphicname = "IAP70B460006.swf" width = "88.000mm" height = "39.750mm" ver = "01" gw = "134" gh = "96"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B4606017002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B4606018">ESP® OFF Switch Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
