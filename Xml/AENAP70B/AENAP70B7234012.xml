<servinfosub id = "AENAP70B7234012004">
<title>
DTC Troubleshooting
</title>
<attention3>
<ptxt>
When DTC B1504-H is indicated together, it is possible that sensor ground circuit is open.
</ptxt>
</attention3>
<diag type = "test" id = "AENAP70B7234012005">
<testgroup id = "AENAP70B7234012006">
<title>
Scan tool parameter check
</title>
<test1>
<ptxt>
Check “Cabin Temperature” using “Data list” mode on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENAP70B7234007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is temperature below –40 °C (–40 °F) (Inside air temperature sensor signal voltage is higher than 4.9 V)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B7234012007">
<title>
Inside air temperature sensor signal circuit check
</title>
<test1>
<ptxt>
Disconnect inside air temperature sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Connect “PNK/BLK” and “YEL/BLK” wire terminals of inside air temperature sensor connector using service wire.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70B7234008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1502-L detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace inside air temperature sensor. 
<intxreftitleoff1 refid = "AENAP70B7236034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70B7234012008">
<title>
Inside air temperature sensor signal circuit check
</title>
<test1>
<ptxt>
Connect “PNK/BLK” and “YEL/BLK” wire terminals of “G20” connector using service wire.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. (DTC Check): 
<intxreftitleoff1 refid = "AENAP70B7234008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1502-L detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace HVAC control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70B7236011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
