<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1406026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Valve and Cylinder Head Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B1406025">Valve and Cylinder Head Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B1406026001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove engine assembly from vehicle. 
<intxreftitleoff1 refid = "AENAP70B1406016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove Intake manifold. 
<intxreftitleoff1 refid = "AENAP70B1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove cooling water pipe. 
<intxreftitleoff1 refid = "AENAP70B1606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil pan. 
<intxreftitleoff1 refid = "AENAP70B1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove cylinder head cover. 
<intxreftitleoff1 refid = "AENAP70B1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove timing chain cover. 
<intxreftitleoff1 refid = "AENAP70B1406018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove timing chain. 
<intxreftitleoff1 refid = "AENAP70B1406023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove intake and exhaust camshafts. 
<intxreftitleoff1 refid = "AENAP70B1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove camshaft bearings.
</ptxt>
</s1>
<s1>
<ptxt>
Loosen cylinder head bolts in such order as indicated in figure using a 12-point socket wrenches and remove them.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141002.swf" width = "88.000mm" height = "51.080mm" ver = "01" gw = "189" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Check all around cylinder head for any other parts required to be removed or disconnected and remove or disconnect whatever necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Remove cylinder head with exhaust manifold. Use lifting device, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Remove following components of cylinder head if necessary.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Exhaust manifold: 
<intxreftitleoff1 refid = "AENAP70B1B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Fuel injector: 
<intxreftitleoff1 refid = "AENAP70B1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Oil venturi plug: 
<intxreftitleoff1 refid = "AENAP70B1406027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Thermostat assembly: 
<intxreftitleoff1 refid = "AENAP70B1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1406026002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B1406027">Valve and Cylinder Head Disassembly and Reassembly</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Clean mating surface of cylinder head and cylinder block. Remove oil, old gasket and dust from mating surface.
</ptxt>
</s1>
<s1>
<ptxt>
Install knock pins (1) to cylinder block.
</ptxt>
</s1>
<s1>
<ptxt>
Install new cylinder head gasket (2) to cylinder block.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141004.swf" width = "88.000mm" height = "43.930mm" ver = "01" gw = "150" gh = "108"/>
</figure>
</s1>
<s1>
<ptxt>
Install cylinder head to cylinder block as follows.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Before placing cylinder head, position crankshaft within “a” range indicated in figure.
</ptxt>
</item>
<item>
<ptxt>
Before tightening cylinder head bolts, turning crankshaft counterclockwise 30&#176; – 90&#176; as shown in figure.
</ptxt>
</item>
<item>
<ptxt>
If cylinder head bolt is reused, make sure to check bolt for deformation. 
<intxreftitleoff1 refid = "AENAP70B1406030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I7V20A141058.swf" width = "88.000mm" height = "37.283mm" ver = "01" gw = "129" gh = "89"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "6" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.519in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.498in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.315in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.567in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
30&#176;
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“b”:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
90&#176;
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Key
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
<s2>
<ptxt>
Apply engine oil to new cylinder head bolts.
</ptxt>
</s2>
<s2>
<ptxt>
Tighten cylinder head bolts (“1” – “10”) to 20 N&#183;m (2.0 kgf-m, 15.0 lbf-ft) according to numerical order as shown using a 12-point socket wrenches.
</ptxt>
</s2>
<s2>
<ptxt>
In the same manner as in Step b), tighten them to 40 N&#183;m (4.1 kgf-m, 29.5 lbf-ft).
</ptxt>
</s2>
<s2>
<ptxt>
Turn all bolts 60&#176; according to numerical order in figure.
</ptxt>
</s2>
<s2>
<ptxt>
Repeat Step d).
</ptxt>
<torque>
<torqueitem id = "T1D017">
<t-part>
Cylinder head bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-note>
20 N&#183;m → 40 N&#183;m → +60&#176; → +60&#176; (2.0 kgf-m → 4.0 kgf-m → +60&#176; → +60&#176;, 14.5 lbf-ft → 29.0 lbf-ft → +60&#176; →+60&#176;)
</t-note>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141005.swf" width = "88.000mm" height = "50.647mm" ver = "02" gw = "177" gh = "127"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Install camshafts and tappet referring to Step 2) through 8) of “Installation” under 
<intxref refid = "AENAP70B1406013">Camshaft and Tappet Removal and Installation</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Install timing chain. 
<intxreftitleoff1 refid = "AENAP70B1406023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install timing chain cover. 
<intxreftitleoff1 refid = "AENAP70B1406018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install cylinder head cover. 
<intxreftitleoff1 refid = "AENAP70B1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install oil pan. 
<intxreftitleoff1 refid = "AENAP70B1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
