<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B9506012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Front Window Regulator Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B9506010">Front Door Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70B9506012001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove front door glass. 
<intxreftitleoff1 refid = "AENAP70B9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect power window motor connector (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove front window regulator nuts (1) and remove front window regulator assembly (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950032.jpg" width = "88.000mm" height = "64.165mm" ver = "03" gw = "225" gh = "165"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B9506012002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B9506013">Front Window Regulator Assembly Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply grease to sliding parts of front window regulator assembly.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E001" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Tighten front window regulator nuts in order (“1” to “6”) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9E003">
<t-part>
Front window regulator nut*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8.4
</t-value1>
<t-value2>
0.86
</t-value2>
<t-value3>
6.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950033.jpg" width = "88.000mm" height = "70.187mm" ver = "02" gw = "225" gh = "182"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
