<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5A">
<servcat sctnbr = "05" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B5106018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Output Shaft Speed Sensor Removal and Installation
</title>
<servinfosub id = "AENAP70B5106018001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect output shaft speed sensor connector (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove output shaft speed sensor (1) by removing its bolt.
</ptxt>
<figure>
<graphic graphicname = "I7V10A510035.swf" width = "88.000mm" height = "55.574mm" ver = "01" gw = "175" gh = "141"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B5106018002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B5106019">Output Shaft Speed Sensor Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Apply ATF to new output shaft speed sensor O-ring.
</ptxt>
</s1>
<s1>
<ptxt>
Install output shaft speed sensor (1) to A/T case and tighten bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5A007">
<t-part>
Output shaft speed sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect output shaft speed sensor connector (2) to output shaft speed sensor (1).
</ptxt>
<figure>
<graphic graphicname = "I7V10A510036.swf" width = "88.000mm" height = "55.754mm" ver = "01" gw = "175" gh = "142"/>
</figure>
</s1>
<s1>
<ptxt>
Connect negative (–) cable to battery.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
