<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B1406007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Electric Throttle Body Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B1406005">Throttle Body and Intake Manifold Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70B1406006">Throttle Body On-Vehicle Inspection</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Never disassemble electric throttle body. If it is found faulty, replace it with new one.
</ptxt>
</attention2>
<servinfosub id = "AENAP70B1406007001" page = "2">
<title>
Removal
</title>
<s1 page = "2">
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENAP70B1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENAP70B1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Disconnect engine coolant hoses (1) and connector (2) from electric throttle body assembly (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove electric throttle body assembly and air cleaner bracket (4) from intake manifold.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B1406007002" page = "2">
<title>
Installation
</title>
<s1 page = "2">
<ptxt>
Clean mating surfaces and install new throttle body gasket (1) to intake manifold.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141038.swf" width = "88.000mm" height = "58.059mm" ver = "01" gw = "212" gh = "148"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Install electric throttle body assembly (3) and air cleaner bracket (4) to intake manifold.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Connect connector (2) and coolant hoses (1) to electric throttle body assembly (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Install air cleaner assembly. 
<intxreftitleoff1 refid = "AENAP70B1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Connect negative (–) cable at battery.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Refill coolant. 
<intxreftitleoff1 refid = "AENAP70B1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check for coolant leakage. 
<intxreftitleoff1 refid = "AENAP70B1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
