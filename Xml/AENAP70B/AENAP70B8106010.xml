<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70B8106010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Center Seat Belt Removal and Installation
</title>
<servinfosub id = "AENAP70B8106010001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear seatback cushion. 
<intxreftitleoff1 refid = "AENAP70B9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove bolt and nut then remove rear center seat belt assembly. 
<intxreftitleoff1 refid = "AENAP70B8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70B8106010002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70B8106003">Front Seat Belt Assembly Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check that pin (3) on seatback frame are inserted in long hole (2) on retractor (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A810016.swf" width = "88.000mm" height = "77.820mm" ver = "02" gw = "236" gh = "204"/>
</figure>
</item>
<item>
<ptxt>
Tighten bolts of rear center seat belt to specified torque. 
<intxreftitleoff1 refid = "AENAP70B8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Do not step on vehicle bead (2) when installing anchor plate (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A810017.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
