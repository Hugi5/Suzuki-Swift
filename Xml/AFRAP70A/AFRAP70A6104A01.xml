<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A6104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Direction dure 
</title>
<diag type = "condition">
<condition>
<ptxt>
Direction dure 
</ptxt>
</condition>
<ps>
<ptxt>
Pression des pneus insuffisante 
</ptxt>
</ps>
<action>
<ptxt>
Régler la pression des pneus. 
</ptxt>
</action>
<ps>
<ptxt>
Dysfonctionnement du système de direction assistée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et corriger. 
<intxreftitleoff1 refid = "AFRAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pincement du joint à rotule d&#39;embout de barre d&#39;accouplement 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;embout de barre d&#39;accouplement. 
<intxreftitleoff1 refid = "AFRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pincement du joint à rotule de bras de suspension 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le bras de suspension. 
<intxreftitleoff1 refid = "AFRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Géométrie des roues avant déréglée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et régler la géométrie des roues avant. 
<intxreftitleoff1 refid = "AFRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pincement de la colonne de direction 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer la colonne de direction. 
<intxreftitleoff1 refid = "AFRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Contact entre-dents incorrect entre crémaillière et pignon 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vérifier le couple de rotation d&#39;axe de crémaillière et pignon. 
<intxreftitleoff1 refid = "AFRAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
En cas de défaut, remplacer l&#39;ensemble de carter de mécanisme de direction. 
<intxreftitleoff1 refid = "AFRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
