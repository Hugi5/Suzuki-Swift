<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0117: Entrée faible du circuit de capteur 1 de température de liquide de refroidissement du moteur 
</emph>
</ptxt>
<ptxt>
La tension de sortie du circuit de signal de capteur ECT est inférieure à 0,01 V pendant 2 s
</ptxt>
<ptxt>
(logique de détection sur 3 D/C) 
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
