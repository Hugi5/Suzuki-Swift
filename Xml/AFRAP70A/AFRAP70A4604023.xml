<servinfosub id = "AFRAP70A4604023003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A4604023004">
<testgroup id = "AFRAP70A4604023005">
<question>
La &#34;Vérification du système ESP<sup>&#174;</sup>&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A4604001">Vérification du système ESP&#174;</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604023006">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70A4604005">Vérification des DTC</intxref>
. 
</ptxt>
</test1>
<question>
Y a-t-il d&#39;autres DTC que C1037, C1038 et C1057? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604023007">
<title>
Vérification des DTC du BCM 
</title>
<test1>
<ptxt>
Vérifier les DTC dans le BCM. 
<intxreftitleoff1 refid = "AFRAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;un des DTC U0073, U0121 et/ou U0126 est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604023008">
<title>
Vérification du fusible 
</title>
<test1>
<ptxt>
Vérifier le fusible &#34;ABS&#34;. 
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le fusible et rechercher les courts-circuits à la masse. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604023009">
<title>
Vérification du circuit d&#39;alimentation électrique de capteur d&#39;angle de braquage 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur du capteur d&#39;angle de braquage. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;G33&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement au capteur d&#39;angle de braquage. 
</ptxt>
</test1>
<test1>
<ptxt>
Si le branchement est correct, mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la tension entre le circuit &#34;A1&#34; et la masse. 
</ptxt>
</test1>
<question>
Est-ce 10 – 14 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 6. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le circuit &#34;A1&#34;. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604023010">
<title>
Vérification du circuit de mise à la masse de capteur d&#39;angle de braquage 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la résistance entre le circuit &#34;A2&#34; et la masse. 
</ptxt>
</test1>
<question>
La résistance est-elle de 2 &#937; maximum? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 7. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le circuit &#34;A2&#34;. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604023011">
<title>
Vérification du capteur d&#39;angle de braquage 
</title>
<test1>
<ptxt>
Brancher le connecteur du capteur d&#39;angle de braquage. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le capteur d&#39;angle de braquage. 
<intxreftitleoff1 refid = "AFRAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le capteur d&#39;angle de braquage et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
