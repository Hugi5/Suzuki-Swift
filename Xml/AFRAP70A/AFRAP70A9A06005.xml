<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;aile avant 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9A06004">Pièces constitutives de l&#39;aile avant</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A9A06005001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer le pare-chocs avant et le support de pare-chocs avant. 
<intxreftitleoff1 refid = "AFRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le garnissage de dessus d&#39;auvent et le garnissage latéral de dessus d&#39;auvent. 
<intxreftitleoff1 refid = "AFRAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le module de phare. 
<intxreftitleoff1 refid = "AFRAP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le clignotant latéral droit. 
<intxreftitleoff1 refid = "AFRAP70A9206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le garde-boue de seuil latéral. 
<intxreftitleoff1 refid = "AFRAP70A9806007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la garniture d&#39;aile avant. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;aile avant et le cache d&#39;aile avant. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9A06005002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Régler de jeu du panneau d&#39;aile avant. 
<intxreftitleoff1 refid = "AFRAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Si de la peinture s&#39;est détachée des boulons d&#39;aile avant, appliquer une nouvelle couche de peinture pour les empêcher de rouiller. 
</ptxt>
</item>
<item>
<ptxt>
Après la pose, régler la portée des phares. 
<intxreftitleoff1 refid = "AFRAP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
