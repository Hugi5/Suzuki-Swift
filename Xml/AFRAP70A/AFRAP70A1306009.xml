<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1306009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du capteur MAP
</title>
<servinfosub id = "AFRAP70A1306009001">
<title>
Dépose
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie.
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur du capteur MAP.
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le capteur MAP (1) du collecteur d&#39;admission (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A131003.jpg" width = "88.000mm" height = "51.551mm" ver = "01" gw = "185" gh = "130"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1306009002">
<title>
Repose
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1306010">Vérification du capteur MAP</intxrefpoff>
</ptxt>
<ptxt>
Pour la repose, procéder dans l&#39;ordre inverse de la dépose en tenant compte des points suivants.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
S&#39;assurer que le joint torique ne présente aucune détérioration.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
