<servinfosub id = "AFRAP70A4604029003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A4604029004">
<testgroup id = "AFRAP70A4604029005">
<question>
La &#34;Vérification du système ESP<sup>&#174;</sup>&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A4604001">Vérification du système ESP&#174;</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604029006">
<title>
Vérification des circuits d&#39;alimentation électrique et de mise à la masse du module de commande ESP&#174;
</title>
<test1>
<ptxt>
Vérifier le circuit d&#39;alimentation électrique et le circuit de mise à la masse du module de commande ESP<sup>&#174;</sup>. 
<intxreftitleoff1 refid = "AFRAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604029007">
<title>
Vérification de la tension d&#39;alimentation électrique du module de commande ESP&#174;
</title>
<test1>
<ptxt>
Mesurer la tension de batterie lorsque le moteur tourne à 3.000 tr/min. 
</ptxt>
</test1>
<question>
La tension est-elle entre 9,3 V et 16,8 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Vérifier le système de charge. 
<intxreftitleoff1 refid = "AFRAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
