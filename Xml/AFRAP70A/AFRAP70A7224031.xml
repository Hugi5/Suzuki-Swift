<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1580: Erreur EEPROM 
</emph>
</ptxt>
<ptxt>
Une erreur EEPROM est survenue dans le module de commande HVAC.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Module de commande HVAC
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1902: Erreur de programmation du module de commande
</emph>
</ptxt>
<ptxt>
Une erreur s&#39;est produite dans le programme du module de commande HVAC.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70A7224031006">
<title>
Procédure de confirmation de DTC
</title>
<s1>
<ptxt>
Démarrer le moteur et activer le système A/C.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7224031002">
<title>
Recherche de pannes à partir de DTC
</title>
<diag type = "test" id = "AFRAP70A7224031003">
<testgroup id = "AFRAP70A7234024004">
<title>
Vérification de DTC
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34; et vérifier les DTC.
</ptxt>
</test1>
<question>
Le DTC B1580 ou B1902 est-il toujours détecté?
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande HVAC et revérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problème intermittent.
</ptxt>
</action>
