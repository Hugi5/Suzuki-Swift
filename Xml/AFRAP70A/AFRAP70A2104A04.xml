<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Shimmy, secousses ou vibrations 
</title>
<diag type = "condition">
<condition>
<ptxt>
Shimmy, secousses ou vibrations 
</ptxt>
</condition>
<ps>
<ptxt>
Balourd de la roue 
</ptxt>
</ps>
<action>
<ptxt>
Equilibrer ou remplacer le(s) pneu(s) et/ou la/les roue(s). 
</ptxt>
</action>
<ps>
<ptxt>
Roulements de roue desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les roulements de roue. 
<intxreftitleoff1 refid = "AFRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Embouts de barre d&#39;accouplement usés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les embouts de barre d&#39;accouplement. 
<intxreftitleoff1 refid = "AFRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Joints de bras de suspension usés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le bras de suspension. 
<intxreftitleoff1 refid = "AFRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ovalisation excessive du pneu ou de la roue 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer la roue et/ou le pneu. 
</ptxt>
</action>
<ps>
<ptxt>
Boursouflure ou protubérance sur le pneu 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le pneu. 
<intxreftitleoff1 refid = "AFRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ovalisation radiale excessive de l&#39;ensemble pneu / roue 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le pneu ou la roue. 
</ptxt>
</action>
<ps>
<ptxt>
Géométrie des roues déréglée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et régler la géométrie des roues. 
<intxreftitleoff1 refid = "AFRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Tringlerie de direction desserrée ou usée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le système de direction. 
<intxreftitleoff1 refid = "AFRAP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Boulons du carter de mécanisme de direction desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Serrer les boulons du carter de mécanisme de direction. 
<intxreftitleoff1 refid = "AFRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
