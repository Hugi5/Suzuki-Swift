<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A7216009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du moteur de soufflante 
</title>
<servinfosub id = "AFRAP70A7216009001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur (1) du moteur de soufflante (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les vis (3). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le moteur de soufflante (2) de l&#39;unité HVAC. 
</ptxt>
<figure>
<graphic graphicname = "I4RS0B710005.swf" width = "88.000mm" height = "53.250mm" ver = "01" gw = "169" gh = "134"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7216009002">
<title>
Repose 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
