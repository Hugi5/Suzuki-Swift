<diag type = "test" id = "AFRAP70A6304011003">
<testgroup id = "AFRAP70A6304011004">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Démarrer le moteur et vérifier à nouveau le DTC du module de commande P/S. 
</ptxt>
</test1>
<question>
Un ou plusieurs DTC sont-ils signalés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70A6304003">Vérification des DTC</intxref>
. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304011005">
<title>
Vérification du combiné d&#39;instruments 
</title>
<test1>
<ptxt>
Remplacer le combiné d&#39;instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<question>
Le témoin P/S reste-t-il allumé? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande P/S et revérifier. 
<intxreftitleoff1 refid = "AFRAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. 
</ptxt>
</action>
</testgroup>
