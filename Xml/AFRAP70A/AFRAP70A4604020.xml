<servinfosub id = "AFRAP70A4604020003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A4604020004">
<testgroup id = "AFRAP70A4604020005">
<question>
La &#34;Vérification du système ESP<sup>&#174;</sup>&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A4604001">Vérification du système ESP&#174;</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604020006">
<title>
Vérification du contacteur ESP&#174; OFF 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Déposer le contacteur ESP<sup>&#174;</sup> OFF. 
<intxreftitleoff1 refid = "AFRAP70A4606017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier si le branchement est correct à chaque borne du contacteur ESP<sup>&#174;</sup> OFF. 
</ptxt>
</test1>
<test1>
<ptxt>
Si les branchements sont corrects, vérifier le contacteur ESP<sup>&#174;</sup> OFF. 
<intxreftitleoff1 refid = "AFRAP70A4606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le contacteur ESP<sup>&#174;</sup> OFF. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604020007">
<title>
Vérification du circuit de contacteur ESP&#174; OFF 
</title>
<test1>
<ptxt>
Débrancher le connecteur &#34;E24&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
S&#39;assurer que le branchement sur la borne &#34;E24-38&#34; est correct. 
</ptxt>
</test1>
<test1>
<ptxt>
Si le branchement est correct, vérifier la résistance entre la borne &#34;E24-38&#34; et la masse. 
</ptxt>
</test1>
<question>
La résistance est-elle égale à l&#39;infini? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le circuit &#34;A1&#34; en court-circuit. 
</ptxt>
</action>
</testgroup>
</diag>
