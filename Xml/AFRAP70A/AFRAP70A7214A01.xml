<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A7214A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Le moteur de soufflante ne fonctionne pas 
</title>
<diag type = "condition">
<condition>
<ptxt>
Le moteur de soufflante ne fonctionne pas 
</ptxt>
</condition>
<ps>
<ptxt>
Fusible grillé 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier les fusibles concernés puis rechercher un éventuel court-circuit à la masse. 
</ptxt>
</action>
<ps>
<ptxt>
Relais de moteur de soufflante défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le relais de moteur de soufflante. 
<intxreftitleoff1 refid = "AFRAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Résistance de moteur de soufflante défectueuse 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier la résistance de moteur de soufflante. 
<intxreftitleoff1 refid = "AFRAP70A7216012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sélecteur de vitesse de soufflante défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le sélecteur de vitesse de soufflante. 
<intxreftitleoff1 refid = "AFRAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Câblage ou mise à la masse défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer le câblage. 
</ptxt>
</action>
<ps>
<ptxt>
Moteur de soufflante défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le moteur de soufflante. 
<intxreftitleoff1 refid = "AFRAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Présence de corps étrangers 
</ptxt>
</ps>
<action>
<ptxt>
Eliminer les corps étrangers. 
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
