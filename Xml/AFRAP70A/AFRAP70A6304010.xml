<servinfosub id = "AFRAP70A6304010002">
<title>
Recherche de pannes 
</title>
<diag type = "test" id = "AFRAP70A6304010003">
<testgroup id = "AFRAP70A6304010004">
<title>
Vérification du témoin &#34;P/S&#34; 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<question>
D&#39;autres témoins s&#39;allument-ils? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304010005">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70A6304003">Vérification des DTC</intxref>
. 
</ptxt>
</test1>
<question>
Le DTC U0073 ou U0155 est-il présent? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70AA804002">Tableau des DTC CAN (perte de communication et bus de communication OFF)</intxref>
. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304010006">
<title>
Vérification du combiné d&#39;instruments 
</title>
<test1>
<ptxt>
Remplacer le combiné d&#39;instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<question>
Le témoin P/S reste-t-il éteint? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module commande P/S. 
<intxreftitleoff1 refid = "AFRAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304010007">
<title>
Vérification du fusible 
</title>
<question>
Le fusible du circuit du combiné d&#39;instruments est-il en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Remplacer le fusible et rechercher les courts-circuits à la masse. 
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304010008">
<title>
Vérification du circuit de communication CAN 
</title>
<test1>
<ptxt>
Vérifier le circuit de communication CAN entre le combiné d&#39;instruments et le module de commande P/S. 
<intxreftitleoff1 refid = "AFRAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Tous les circuits de communication CAN sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 6. 
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Réparer ou remplacer. 
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304010009">
<title>
Vérification du circuit d&#39;alimentation électrique du combiné d&#39;instruments 
</title>
<test1>
<ptxt>
Déposer le combiné des instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement du connecteur de combinaison d&#39;instruments. 
</ptxt>
</test1>
<test1>
<ptxt>
Si le résultat de la vérification est satisfaisant, mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
S&#39;assurer que la tension entre la borne &#34;G240-3&#34; et la borne &#34;G240-5&#34; correspond à la tension de batterie. 
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le combiné d&#39;instruments et revérifier. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 7. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304010010">
<title>
Vérification du circuit de mise à la masse du combiné d&#39;instruments 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
S&#39;assurer que la résistance entre la borne &#34;G240-5&#34; et la masse est de 1 &#937; maximum. 
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Réparer ou remplacer le circuit &#34;A1&#34;. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le circuit &#34;A2&#34;. 
</ptxt>
</action>
</testgroup>
</diag>
