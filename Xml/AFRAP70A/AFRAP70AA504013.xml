<servinfosub id = "AFRAP70AA504013005">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Enfoncer complètement la pédale d&#39;embrayage pendant au moins 3 secondes. 
</ptxt>
</s1>
<s1>
<ptxt>
Relâcher la pédale d&#39;embrayage pendant au moins 3 secondes. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA504013008">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA504013018">
<testgroup id = "AFRAP70AA504013019">
<title>
Vérification de DTC 
</title>
<question>
Un autre DTC que B1125 est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504013003">
<title>
Vérification des paramètres 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le &#34;Contacteur de position P / CPP2 &#34; et le &#34;Contacteur d&#39;embrayage / de changement de vitesses&#34; affichés sur l&#39;outil de balayage SUZUKI. 
<intxreftitleoff1 refid = "AFRAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504013020">
<title>
Vérification de circuit de signal de contacteur CPP n&#176; 1 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le contacteur CPP n&#176; 1, les connecteurs &#34;C01&#34;, &#34;E01&#34;, &#34;E25&#34; et &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement de borne sur le contacteur CPP n&#176; 1, les connecteurs &#34;C01&#34;, &#34;E01&#34;, &#34;E25&#34; et &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Si les branchements sont corrects, vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance du circuit &#34;A1&#34;: en dessous de 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance entre le circuit &#34;A1&#34; et la masse: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne de circuit &#34;A1&#34; et chaque borne de connecteur de contacteur CPP n&#176; 1: infinie 
</ptxt>
</item>
</list1>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504013021">
<title>
Vérification de circuit de signal de contacteur CPP n&#176; 2 
</title>
<test1>
<ptxt>
Débrancher le connecteur de contacteur CPP n&#176; 2. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement de borne sur le contacteur CPP n&#176; 2, les connecteurs &#34;E25&#34; et &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Si les branchements sont corrects, vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance du circuit &#34;A2&#34;: en dessous de 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance entre le circuit &#34;A2&#34; et la masse: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne de circuit &#34;A2&#34; et chaque borne de connecteur de contacteur CPP n&#176; 2: infinie 
</ptxt>
</item>
</list1>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504013022">
<title>
Vérification de contacteur CPP n&#176; 1 
</title>
<test1>
<ptxt>
Vérifier le contacteur CPP n&#176; 1. 
<intxreftitleoff1 refid = "AFRAP70A5306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 6. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le contacteur CPP n&#176; 1. 
<intxreftitleoff1 refid = "AFRAP70A5306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504013023">
<title>
Vérification de contacteur CPP n&#176; 2 
</title>
<test1>
<ptxt>
Vérifier le contacteur CPP n&#176; 2. 
<intxreftitleoff1 refid = "AFRAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 7. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le contacteur CPP n&#176; 2. 
<intxreftitleoff1 refid = "AFRAP70A5306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504013006">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Brancher le contacteur CPP n&#176; 1, le contacteur CPP n&#176; 2, les connecteurs &#34;C01&#34;, &#34;E01&#34;, &#34;E25&#34; et &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. (vérification des DTC): 
</ptxt>
</test1>
<question>
Le DTC B1125 actuel est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande de démarrage sans clé et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
</testgroup>
</diag>
