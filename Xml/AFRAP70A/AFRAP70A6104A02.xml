<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A6104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Trop de jeu dans la direction 
</title>
<diag type = "condition">
<condition>
<ptxt>
Trop de jeu dans la direction 
</ptxt>
</condition>
<ps>
<ptxt>
Roulements de roue usés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le roulement de roue. 
<intxreftitleoff1 refid = "AFRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Boulon de carter de mécanisme de direction desserré 
</ptxt>
</ps>
<action>
<ptxt>
Serrer le boulon de carter de mécanisme de direction. 
<intxreftitleoff1 refid = "AFRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ensemble de carter de mécanisme de direction défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de carter de mécanisme de direction. 
<intxreftitleoff1 refid = "AFRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Joint usé de colonne de direction 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de colonne de direction. 
<intxreftitleoff1 refid = "AFRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Embout de barre d&#39;accouplement ou joint à rotule de barre d&#39;accouplement usé 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Remplacer l&#39;embout de barre d&#39;accouplement ou la barre d&#39;accouplement. 
</ptxt>
<ptxt>
Embout de barre d&#39;accouplement: 
<intxreftitleoff1 refid = "AFRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Barre d&#39;accouplement: 
<intxreftitleoff1 refid = "AFRAP70A6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Joint de bras de suspension usé 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le bras de suspension. 
<intxreftitleoff1 refid = "AFRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Contact entre-dents incorrect entre crémaillière et pignon 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vérifier le couple de rotation d&#39;axe de crémaillière et pignon. 
<intxreftitleoff1 refid = "AFRAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
En cas de défaut, remplacer l&#39;ensemble de carter de mécanisme de direction. 
<intxreftitleoff1 refid = "AFRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
