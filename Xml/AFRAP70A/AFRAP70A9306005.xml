<section sectnbr = "9C">
<servcat sctnbr = "09" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9306005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose des radars de stationnement (si le véhicule en est équipé) 
</title>
<servinfosub id = "AFRAP70A9306005001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer le pare-chocs arrière. 
<intxreftitleoff1 refid = "AFRAP70A9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur de radar de stationnement. 
</ptxt>
</s1>
<s1>
<ptxt>
Détacher le couvercle de radar de stationnement (1) comme indiqué sur le schéma. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A930025.jpg" width = "88.000mm" height = "106.836mm" ver = "01" gw = "208" gh = "286"/>
</figure>
</s1>
<s1>
<ptxt>
Ouvrir les griffes (1) et déposer le radar de stationnement (2) comme indiqué sur le schéma. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A930026.jpg" width = "88.000mm" height = "63.752mm" ver = "01" gw = "196" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Si nécessaire, déposer le support de capteur. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9306005002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9306006">Vérification des radars de stationnement (si le véhicule en est équipé)</intxrefpoff>
</ptxt>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Nettoyer et dégraisser la surface où le support de radar (1) doit être posé. 
</ptxt>
</item>
<item>
<ptxt>
Appliquer l&#39;apprêt (équivalent au SUMITOMO 3M K-520 ou 4298UV) sur la surface où le support de radar doit être posé. 
</ptxt>
</item>
<item>
<ptxt>
Poser le support de capteur dans le sens indiqué sur le schéma. 
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A930039.jpg" width = "88.000mm" height = "98.016mm" ver = "01" gw = "199" gh = "261"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
