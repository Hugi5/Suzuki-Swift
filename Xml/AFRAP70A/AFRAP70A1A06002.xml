<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1A06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de la batterie 
</title>
<servinfosub id = "AFRAP70A1A06002001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) (1) de la batterie (4). 
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le câble positif (+) (2) de la batterie (4). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le dispositif de fixation (3). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la batterie (4). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0001.swf" width = "88.000mm" height = "71.286mm" ver = "01" gw = "171" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer le socle de batterie (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;ECM (2). 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le support de batterie (3) si nécessaire. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0002.jpg" width = "88.000mm" height = "55.738mm" ver = "02" gw = "199" gh = "141"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1A06002002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer fermement les câbles de batterie. 
</ptxt>
</item>
<item>
<ptxt>
Initialiser les appareils électriques si nécessaire. 
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
