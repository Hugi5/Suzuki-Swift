<title>
Bruit 
</title>
<diag type = "condition">
<condition>
<ptxt>
Bruit 
</ptxt>
</condition>
<ps>
<ptxt>
Lubrifiant de type inadéquat ou en quantité insuffisante 
</ptxt>
</ps>
<action>
<ptxt>
Faire l&#39;appoint d&#39;huile de boîte-pont manuelle. 
</ptxt>
</action>
<ps>
<ptxt>
Roulement(s) endommagé(s) ou usé(s) 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le roulement. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Roulement gauche d&#39;arbre intermédiaire: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Chemin intérieur: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Chemin extérieur: 
<intxreftitleoff1 refid = "AFRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Roulement droit d&#39;arbre intermédiaire: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Chemin intérieur: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Chemin extérieur: 
<intxreftitleoff1 refid = "AFRAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
