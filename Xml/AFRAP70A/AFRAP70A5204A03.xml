<list3 type = "unordered">
<item>
<ptxt>
Chemin intérieur: 
<intxreftitleoff1 refid = "AFRAP70A5206025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Chemin extérieur côté droit: 
<intxreftitleoff1 refid = "AFRAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
