<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70AA504018" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1161 / B1163 
</title>
<servinfosub id = "AFRAP70AA504018001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.816in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.388in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1161: Non concordance des informations de l&#39;unité de verrouillage de direction 
</emph>
</ptxt>
<ptxt>
Erreur de vérification entre le module de commande de démarrage sans clé et l&#39;unité de verrouillage de direction. 
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Circuit / connecteur de l&#39;unité de verrouillage de direction 
</ptxt>
</item>
<item>
<ptxt>
Unité de verrouillage de direction 
</ptxt>
</item>
<item>
<ptxt>
Module de commande de démarrage sans clé 
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1163: Non enregistrement de l&#39;unité de verrouillage de direction 
</emph>
</ptxt>
<ptxt>
Pas d&#39;enregistrement de l&#39;unité de verrouillage de direction. 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70AA504018002">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Répéter les étapes 1) et 2) à plusieurs reprises. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA504018003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA504018004">
<testgroup id = "AFRAP70AA504018005">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Effacer le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Effectuer le point 
<intxref refid = "AFRAP70AA504018002">Procédure de confirmation de DTC </intxref>
, puis vérifier de nouveau le DTC. 
</ptxt>
</test1>
<question>
Le DTC B1161 ou B1163 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504018006">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Remplacer l&#39;unité de verrouillage de direction. 
<intxreftitleoff1 refid = "AFRAP70A6206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Effectuer le point 
<intxref refid = "AFRAP70AA504018002">Procédure de confirmation de DTC </intxref>
, puis vérifier de nouveau le DTC. 
</ptxt>
</test1>
<question>
Le DTC B1161 ou B1163 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande de démarrage sans clé et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (unité de verrouillage de direction défectueuse). 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
