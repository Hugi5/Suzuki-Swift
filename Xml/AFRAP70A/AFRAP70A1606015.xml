<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1606015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du radiateur 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1606014">Vérification et nettoyage du radiateur sur le véhicule</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A1606015001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer l&#39;ensemble de ventilateur de refroidissement. 
<intxreftitleoff1 refid = "AFRAP70A1606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Déposer l&#39;ensemble de condenseur A/C. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modèle avec A/C manuelle: 
<intxreftitleoff1 refid = "AFRAP70A7216006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modèle à A/C automatique: 
<intxreftitleoff1 refid = "AFRAP70A7226006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Déposer la durite de sortie de radiateur du radiateur. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les supports supérieurs de radiateur (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le radiateur (2) du véhicule. 
</ptxt>
<figure>
<graphic graphicname = "IAP70P160007.jpg" width = "88.000mm" height = "62.569mm" ver = "01" gw = "193" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1606015002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Remplir le système de refroidissement de liquide de refroidissement. 
<intxreftitleoff1 refid = "AFRAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rechercher d&#39;éventuelles fuites au niveau du système de refroidissement. 
<intxreftitleoff1 refid = "AFRAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
