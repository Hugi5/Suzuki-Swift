<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A9604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Impossible de verrouiller / déverrouiller toutes les portes 
</title>
<diag type = "condition">
<condition>
<ptxt>
Impossible de verrouiller / déverrouiller toutes les portes 
</ptxt>
</condition>
<ps>
<ptxt>
BCM défectueux 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Se reporter à &#34;Vérification du BCM et de ses circuits&#34; dans la section 10B. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Modèle à contacteur d&#39;allumage: 
<intxreftitleoff1 refid = "AFRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modèle à démarrage sans clé: 
<intxreftitleoff1 refid = "AFRAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Module de commande de démarrage sans clé défectueux (modèle à démarrage sans clé) 
</ptxt>
</ps>
<action>
<ptxt>
Se reporter au point 
<intxref refid = "AFRAP70AA504031">Vérification du module de commande de démarrage sans clé et de ses circuits</intxref>
. 
</ptxt>
</action>
<ps>
<ptxt>
Circuit du système défectueux (y compris les relais et les fusibles) 
</ptxt>
</ps>
<action>
<ptxt>
— 
</ptxt>
</action>
<ps>
<ptxt>
Contacteur de verrouillage centralisé des portes défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Se reporter au point 
<intxref refid = "AFRAP70A9606009">Vérification du contacteur de verrouillage centralisé des portes</intxref>
. 
</ptxt>
</action>
<ps>
<ptxt>
Barillet de serrure défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le barillet de serrure. 
<intxreftitleoff1 refid = "AFRAP70A9606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
