<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A7214A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Un bruit de cliquetis se fait entendre lorsque le compresseur fonctionne 
</title>
<servinfosub id = "AFRAP70A7214004003">
<title>
Bruit anormal produit par l&#39;embrayage magnétique 
</title>
<diag type = "condition">
<condition>
<ptxt>
Un bruit de cliquetis se fait entendre lorsque le compresseur fonctionne 
</ptxt>
</condition>
<ps>
<ptxt>
Jeu d&#39;embrayage magnétique incorrect (jeu excessif) 
</ptxt>
</ps>
<action>
<ptxt>
Régler le jeu d&#39;embrayage magnétique. 
<intxreftitleoff1 refid = "AFRAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Surface de frottement d&#39;embrayage magnétique usée 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble d&#39;embrayage magnétique. 
<intxreftitleoff1 refid = "AFRAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fuite d&#39;huile de compresseur au niveau du joint d&#39;étanchéité de l&#39;arbre, qui se répand sur la surface de frottement 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de corps de compresseur. 
<intxreftitleoff1 refid = "AFRAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
