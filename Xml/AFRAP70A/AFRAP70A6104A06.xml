<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A6104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Direction erratique lors du freinage 
</title>
<diag type = "condition">
<condition>
<ptxt>
Direction erratique lors du freinage 
</ptxt>
</condition>
<ps>
<ptxt>
Roulement(s) de roue usé(s). 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le(s) roulement(s) de roue. 
<intxreftitleoff1 refid = "AFRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ressort hélicoïdal cassé ou détendu 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le ressort hélicoïdal. 
<intxreftitleoff1 refid = "AFRAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ensemble de jambe avant défectueux (amortisseur) 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de jambe avant (amortisseur). 
<intxreftitleoff1 refid = "AFRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pression des pneus irrégulière 
</ptxt>
</ps>
<action>
<ptxt>
Régler la pression des pneus. 
</ptxt>
</action>
<ps>
<ptxt>
Géométrie des roues avant déréglée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et régler la géométrie des roues avant. 
<intxreftitleoff1 refid = "AFRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Les freins ne fonctionnent pas à l&#39;unisson 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et réparer le système de freinage. 
<intxreftitleoff1 refid = "AFRAP70A4101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disque de frein avant recouvert de liquide de frein 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le disque de frein avant. 
<intxreftitleoff1 refid = "AFRAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disque de frein voilé 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le disque de frein avant. 
<intxreftitleoff1 refid = "AFRAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Plaquette de frein complètement usée 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer la plaquette de frein avant. 
<intxreftitleoff1 refid = "AFRAP70A4206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
