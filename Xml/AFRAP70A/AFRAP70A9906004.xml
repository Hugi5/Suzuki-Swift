<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9906004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de la vitre de toit ouvrant 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9906001">Pièces constitutives du toit ouvrant</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A9906004001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Ouvrir complètement le pare-soleil (1) et incliner le toit ouvrant vers le haut. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990022.swf" width = "88.000mm" height = "43.115mm" ver = "01" gw = "138" gh = "106"/>
</figure>
</s1>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la vitre de toit ouvrant en déposant les boulons de fixation de vitre de toit ouvrant (TORX<sup>&#174;</sup> T25) (1). 
</ptxt>
<figure>
<graphic graphicname = "I5JB0A990003.swf" width = "88.000mm" height = "45.253mm" ver = "01" gw = "185" gh = "112"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9906004002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les boulons de fixation de toit ouvrant aux couples prescrits. 
<intxreftitleoff1 refid = "AFRAP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Régler la position de montage de la vitre de toit ouvrant. 
<intxreftitleoff1 refid = "AFRAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Initialiser le moteur de toit ouvrant. 
<intxreftitleoff1 refid = "AFRAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
