<ptxt>
Forer des points de soudage. 
</ptxt>
</s1>
<s1 page = "1">
<ptxt>
Dévisser les 2 boulons et déposer le prolongement supérieur de montant avant. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0048.jpg" width = "183.000mm" height = "141.890mm" ver = "03" gw = "470" gh = "386"/>
</figure>
</s1>
