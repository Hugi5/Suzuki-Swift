</figure>
</s1>
<s1>
<ptxt>
Forer des points de soudage. 
</ptxt>
</s1>
<s1>
<ptxt>
Dévisser les 3 boulons et déposer le panneau latéral de tableau de bord. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0069.jpg" width = "183.000mm" height = "140.497mm" ver = "06" gw = "491" gh = "382"/>
<callout>
