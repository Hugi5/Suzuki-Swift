<servinfosub id = "AFRAP70A8204022003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A8204022004">
<testgroup id = "AFRAP70A8204022005">
<question>
La &#34;vérification du système de diagnostic d&#39;airbag&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204022006">
<title>
Vérification du module (dispositif de gonflage) d&#39;airbag du passager 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement correct au connecteur &#34;G259&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;G259&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Brancher &#34;STEERING WHEEL&#34; (1) de l&#39;outil spécial (A), (B) et (C) sur le connecteur &#34;G259&#34;. 
</ptxt>
<servicetool>
<servicetoolitem id = "L8B018">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B019">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
 09932-78310 
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B020">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
 09932-75010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820021.swf" width = "90.000mm" height = "75.690mm" ver = "03" gw = "211" gh = "198"/>
</testfigure>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1041 est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le module (dispositif de gonflage) d&#39;airbag du passager. 
<intxreftitleoff1 refid = "AFRAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204022007">
<title>
Vérification du circuit du module (dispositif de gonflage) d&#39;airbag du passager 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement correct au connecteur &#34;G11&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;G11&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Relâcher la barre de court-circuit dans le connecteur du SDM en insérant l&#39;outil de relâchement inclus dans l&#39;outil spécial (A). 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance entre les bornes &#34;G11-19&#34; et &#34;G259-1&#34;: 1 &#937; maximum 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre les bornes &#34;G11-18&#34; et &#34;G259-2&#34;: 1 &#937; maximum 
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B021">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820009.swf" width = "90.000mm" height = "95.480mm" ver = "01" gw = "227" gh = "254"/>
</testfigure>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le SDM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204022008">
<title>
Vérification du circuit de faisceau de câble de tableau de bord 
</title>
<test1>
<ptxt>
Vérifier le branchement correct au connecteur &#34;G372&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;G372&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Relâcher la barre de court-circuit dans le connecteur du SDM en insérant l&#39;outil de relâchement inclus dans l&#39;outil spécial (A). 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le point suivant. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance des circuits &#34;A3&#34; et &#34;A4&#34;: 1 &#937; maximum 
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B022">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820023.swf" width = "90.000mm" height = "53.433mm" ver = "03" gw = "201" gh = "135"/>
</testfigure>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le faisceau de câbles du module (dispositif de gonflage) d&#39;airbag du passager. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Une fois la vérification et les réparations terminées, effectuer les opérations suivantes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Raccorder toutes les pièces constitutives du système d&#39;airbag et s&#39;assurer qu&#39;elles sont toutes correctement montées. 
</ptxt>
</item>
<item>
<ptxt>
Supprimer les DTC éventuels en se reportant au point 
<intxref refid = "AFRAP70A8204006">Suppression des DTC</intxref>
. 
</ptxt>
</item>
<item>
<ptxt>
Effectuer à nouveau 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
 pour confirmer que le problème a été résolu. 
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
