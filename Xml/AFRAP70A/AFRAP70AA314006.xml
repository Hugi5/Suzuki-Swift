</servinfosub>
<servinfosub id = "AFRAP70AA314006002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA314006003">
<testgroup id = "AFRAP70AA314006005">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Vérifier les DTC du BCM. 
<intxreftitleoff1 refid = "AFRAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1173, B1175 ou B1176 est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA314006004">
<title>
Enregistrement de l&#39;ECM 
</title>
<test1>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70AA316003">Enregistrement de l&#39;ECM:Modèle à contacteur d&#39;allumage</intxref>
. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC P1610 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (l&#39;ECM n&#39;a pas été enregistré) 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA314006006">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Vérifier les DTC associés à la communication CAN. 
</ptxt>
</test1>
<question>
Un ou plusieurs DTC CAN sont-ils détectés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer l&#39;ECM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
