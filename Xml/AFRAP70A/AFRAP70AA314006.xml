<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Le code ID d&#39;ECM n&#39;est pas enregistré dans le BCM 
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Circuit / connecteur de communication CAN 
</ptxt>
</item>
<item>
<ptxt>
Module de commande connecté à la ligne de communication CAN 
</ptxt>
</item>
</list1>
