<diag type = "test" id = "AFRAP70A8204053003">
<testgroup id = "AFRAP70A8204053004">
<title>
Vérification du circuit du module (dispositif de gonflage) d&#39;airbag du conducteur 
</title>
<test1>
<ptxt>
Déposer module d&#39;airbag (dispositif de gonflage) du conducteur de la colonne de direction. 
<intxreftitleoff1 refid = "AFRAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;G11&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Relâcher la barre de court-circuit dans le connecteur du SDM en insérant l&#39;outil de relâchement inclus dans l&#39;outil spécial (A). 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le point suivant. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance entre les bornes &#34;G11-5&#34; et &#34;G11-6&#34;: infinie 
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B097">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820030.swf" width = "90.000mm" height = "60.504mm" ver = "01" gw = "212" gh = "155"/>
</testfigure>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Rechercher un faisceau de câbles défectueux. Si les résultats de la vérification ne sont pas conformes aux spécifications, remplacer l&#39;ensemble de bobine de contact. 
<intxreftitleoff1 refid = "AFRAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204053005">
<title>
Vérification du circuit de bobine de contact (circuit de module (dispositif de gonflage) d&#39;airbag du conducteur) 
</title>
<test1>
<ptxt>
Déposer l&#39;ensemble de bobine de contact. 
<intxreftitleoff1 refid = "AFRAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le point suivant. 
</ptxt>
<ptxt>
Modèle à contacteur d&#39;allumage: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Mesurer la résistance entre les bornes &#34;S121-1&#34; à &#34;S172-2&#34; et &#34;S121-2&#34; à &#34;S172-1&#34;. 
</ptxt>
</item>
</list1>
<ptxt>
Modèle à démarrage sans clé: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Mesurer la résistance entre les bornes &#34;S121 –1&#34; à &#34;S174-2&#34; et &#34;S121-2&#34; à &#34;S174-1&#34;. 
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B098">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820018.swf" width = "90.000mm" height = "70.672mm" ver = "02" gw = "196" gh = "184"/>
</testfigure>
</test1>
<question>
La résistance est-elle de 1 &#937; maximum? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de bobine de contact. 
<intxreftitleoff1 refid = "AFRAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204053006">
<title>
Vérification du circuit de bobine de contact (circuit de klaxon) 
</title>
<test1>
<ptxt>
