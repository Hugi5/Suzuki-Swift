<servinfosub id = "AFRAP70A1804001002">
<title>
Recherche de pannes 
</title>
<diag type = "test" id = "AFRAP70A1804001003">
<testgroup id = "AFRAP70A1804001004">
<question>
La procédure de &#34;Vérification du système de commande du moteur et des émissions&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A1104001">Vérification du système de régulation des émissions et de commande du moteur</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1804001005">
<title>
Essai d&#39;étincelle d&#39;allumage 1 
</title>
<test1>
<ptxt>
Effectuer l&#39;essai d&#39;étincelle d&#39;allumage. 
<intxreftitleoff1 refid = "AFRAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat du test est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1804001006">
<title>
Vérification de l&#39;avance à l&#39;allumage 
</title>
<test1>
<ptxt>
Vérifier l&#39;avance à l&#39;allumage. 
<intxreftitleoff1 refid = "AFRAP70A1806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Le système d&#39;allumage est en bon état. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer la pièce défectueuse. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1804001007">
<title>
Confirmation de cylindre défectueux 
</title>
<test1>
<ptxt>
Confirmer quel(s) cylindre(s) a échoué au test d&#39;étincelle d&#39;allumage. 
</ptxt>
</test1>
<question>
Tous les cylindres? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 7. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1804001008">
<title>
Essai d&#39;étincelle d&#39;allumage 2 
</title>
<test1>
<ptxt>
Remplacer la bougie d&#39;allumage de chaque cylindre défectueux par celle d&#39;un cylindre normal. 
</ptxt>
</test1>
<test1>
<ptxt>
Effectuer l&#39;essai d&#39;étincelle d&#39;allumage. 
<intxreftitleoff1 refid = "AFRAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat du test est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer la bougie d&#39;allumage. 
<intxreftitleoff1 refid = "AFRAP70A1806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 6. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1804001009">
<title>
Essai d&#39;étincelle d&#39;allumage 3 
</title>
<test1>
<ptxt>
Remplacer la bobine d&#39;allumage de chaque cylindre défectueux par celle d&#39;un cylindre normal. 
</ptxt>
</test1>
<test1>
<ptxt>
Effectuer l&#39;essai d&#39;étincelle d&#39;allumage. 
<intxreftitleoff1 refid = "AFRAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat du test est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer la bobine d&#39;allumage. 
<intxreftitleoff1 refid = "AFRAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Passer à l&#39;étape 7. 
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AFRAP70A1804001010">
<title>
Vérification des circuits d&#39;alimentation électrique et de mise à la masse de l&#39;ensemble de bobine d&#39;allumage 
</title>
<test1>
<ptxt>
Lorsque l&#39;allumage est sur &#34;OFF&#34;, débrancher les connecteurs &#34;C01&#34; et &#34;E01&#34; de l&#39;ECM et les connecteurs de la bobine d&#39;allumage. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier que la borne correcte est branchée sur les connecteurs de bobine d&#39;allumage. 
</ptxt>
</test1>
<test1>
<ptxt>
Si les branchements sont corrects, vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance des circuits &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;, &#34;A4&#34;, &#34;C1&#34;, &#34;C2&#34;, &#34;C3&#34; et &#34;C4&#34;: en dessous de 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance entre chacun des circuits &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;, &#34;A4&#34;, &#34;C1&#34;, &#34;C2&#34;, &#34;C3&#34; et &#34;C4&#34; et la masse: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;A1&#34; et l&#39;autre borne au niveau du connecteur de bobine d&#39;allumage: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;A2&#34; et l&#39;autre borne au niveau du connecteur de bobine d&#39;allumage: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;A3&#34; et l&#39;autre borne au niveau du connecteur de bobine d&#39;allumage: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;A4&#34; et l&#39;autre borne au niveau du connecteur de bobine d&#39;allumage: infinie 
</ptxt>
</item>
<item>
<ptxt>
Tension des circuits &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;, &#34;A4&#34;, &#34;C1&#34;, &#34;C2&#34;, &#34;C3&#34; et &#34;C4&#34;: 0 à 1 V(Lorsque l&#39;allumage est sur &#34;ON&#34;) 
</ptxt>
</item>
</list1>
</test1>
<question>
Les résultats de la vérification sont-ils corrects? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 8. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer la pièce défectueuse. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1804001011">
<title>
Vérification des circuits d&#39;entraînement d&#39;ensemble de bobine d&#39;allumage 
</title>
<test1>
<ptxt>
Lorsque l&#39;allumage est sur &#34;OFF&#34;, vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance des circuits &#34;B1&#34;, &#34;B2&#34;, &#34;B3&#34; et &#34;B4&#34;: en dessous de 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance entre chacun des circuits &#34;B1&#34;, &#34;B2&#34;, &#34;B3&#34; et &#34;B4&#34; et la masse: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;B1&#34; et l&#39;autre borne au niveau du connecteur de bobine d&#39;allumage: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;B2&#34; et l&#39;autre borne au niveau du connecteur de bobine d&#39;allumage: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;B3&#34; et l&#39;autre borne au niveau du connecteur de bobine d&#39;allumage: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;B4&#34; et l&#39;autre borne au niveau du connecteur de bobine d&#39;allumage: infinie 
</ptxt>
</item>
<item>
<ptxt>
Tension des circuits &#34;B1&#34;, &#34;B2&#34;, &#34;B3&#34; et &#34;B4&#34;: 0 à 1 V(Lorsque l&#39;allumage est sur &#34;ON&#34;) 
</ptxt>
</item>
</list1>
</test1>
<question>
Les résultats de la vérification sont-ils corrects? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 9. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer la pièce défectueuse. 
</ptxt>
</action>
</testgroup>
