<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A7214A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
L&#39;air froid n&#39;est pas diffusé ou le refroidissement est insuffisant (l&#39;embrayage magnétique fonctionne normalement) 
</title>
<diag type = "condition">
<condition>
<ptxt>
L&#39;air froid n&#39;est pas diffusé ou le refroidissement est insuffisant (l&#39;embrayage magnétique fonctionne normalement) 
</ptxt>
</condition>
<ps>
<ptxt>
Quantité de réfrigérant insuffisante ou excessive 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier la quantité de réfrigérant et rechercher toute trace de fuite dans le système. 
</ptxt>
</action>
<ps>
<ptxt>
Condensateur obstrué 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le condenseur. 
<intxreftitleoff1 refid = "AFRAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Evaporateur A/C obstrué ou givré 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vérifier l&#39;évaporateur A/C et le capteur de température d&#39;évaporateur. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Evaporateur A/C: 
<intxreftitleoff1 refid = "AFRAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Capteur de température d&#39;évaporateur: 
<intxreftitleoff1 refid = "AFRAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Capteur de température d&#39;évaporateur défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le capteur de température d&#39;évaporateur. 
<intxreftitleoff1 refid = "AFRAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Détendeur défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le détendeur. 
<intxreftitleoff1 refid = "AFRAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Courroie d&#39;entraînement de compresseur détendue ou cassée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier la courroie d&#39;entraînement de compresseur. 
<intxreftitleoff1 refid = "AFRAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Patinage de l&#39;embrayage magnétique 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier l&#39;embrayage magnétique. 
<intxreftitleoff1 refid = "AFRAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compresseur défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le compresseur. 
</ptxt>
</action>
<ps>
<ptxt>
Présence d&#39;air dans le système de la climatisation 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le condenseur puis, procéder à la purge et à la recharge de réfrigérant. 
<intxreftitleoff1 refid = "AFRAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fuite d&#39;air dans l&#39;unité HVAC ou la conduite d&#39;air 
</ptxt>
</ps>
<action>
<ptxt>
Réparer l&#39;unité HVAC ou la conduite d&#39;air. 
</ptxt>
</action>
<ps>
<ptxt>
Chauffage et système de ventilation défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier l&#39;unité HVAC. 
</ptxt>
</action>
<ps>
<ptxt>
Moteur de soufflante défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le moteur de soufflante. 
<intxreftitleoff1 refid = "AFRAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Quantité excessive d&#39;huile de compresseur dans le système A/C 
</ptxt>
</ps>
<action>
<ptxt>
Vidanger l&#39;excès d&#39;huile de compresseur dans le circuit et le compresseur du système A/C. 
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
