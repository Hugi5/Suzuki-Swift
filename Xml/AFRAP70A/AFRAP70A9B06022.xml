<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9B06022" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Dépose et repose du panneau arrière de plancher arrière 
</title>
<attention3>
<ptxt>
Les schémas ci-dessous indiquent dans quelle condition les pièces suivantes sont déposées. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Aile avant 
<intxreftitleoff1 refid = "AFRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Panneau arrière 
<intxreftitleoff1 refid = "AFRAP70A9B06021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0166.jpg" width = "88.000mm" height = "48.926mm" ver = "02" gw = "227" gh = "122"/>
</figure>
<servinfosub id = "AFRAP70A9B06022001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Percer les points de soudure et déposer le panneau arrière de plancher arrière. 
</ptxt>
<attention3>
<ptxt>
Déplier les deux extrémités du flasque de panneau central de plancher arrière, si nécessaire. 
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A9B0018.jpg" width = "183.000mm" height = "184.007mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9B06022002">
<title>
Repose 
</title>
<attention3>
<ptxt>
Avant toute soudure, vérifier la position et la condition de pose de la pièce/des pièces de pose. 
<intxreftitleoff1 refid = "AFRAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1 page = "1">
<ptxt>
Reposer le support de roue de secours et le support de boîte à outils. 
</ptxt>
</s1>
<s1 page = "1">
<ptxt>
Procéder à la soudure par points de résistance. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0168.jpg" width = "183.000mm" height = "100.573mm" ver = "01" gw = "495" gh = "269"/>
</figure>
</s1>
<s1 page = "1">
<ptxt>
Reposer le panneau arrière de plancher arrière. 
</ptxt>
<attention3>
<ptxt>
Replier les deux extrémités du flasque de panneau central de plancher arrière, si nécessaire. 
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Procéder à la soudure par points de résistance et à la soudure en bouchon. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0019.jpg" width = "183.000mm" height = "183.872mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
