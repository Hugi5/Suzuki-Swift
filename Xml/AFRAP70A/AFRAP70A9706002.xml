<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9706002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du siège avant 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9706001">Pièces constitutives du siège avant</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A9706002001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Désactiver le système d&#39;airbag. 
<intxreftitleoff1 refid = "AFRAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher les connecteurs du siège avant. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les 4 boulons de fixation et déposer l&#39;ensemble de siège. 
</ptxt>
</s1>
<s1>
<ptxt>
Démonter et réparer les pièces si nécessaire. 
<intxreftitleoff1 refid = "AFRAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9706002002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Se référer au point 
<intxref refid = "AFRAP70A9706001">Pièces constitutives du siège avant</intxref>
 pour le couple de serrage. 
</ptxt>
</item>
<item>
<ptxt>
Activer le système d&#39;airbag. 
<intxreftitleoff1 refid = "AFRAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
