<servinfosub id = "AFRAP70AA504021003">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Répéter les étapes 1) et 2) à plusieurs reprises. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA504021004">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA504021005">
<testgroup id = "AFRAP70AA504021008">
<title>
Vérification des paramètres 
</title>
<test1>
<ptxt>
Brancher l&#39;outil de balayage SUZUKI sur le DLC, allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le &#34;Bouton-poussoir1&#34; et le &#34;Bouton-poussoir2&#34; affichés sur l&#39;outil de balayage SUZUKI. 
<intxreftitleoff1 refid = "AFRAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504021006">
<title>
Vérification du circuit de signal de bouton-poussoir et du circuit de mise à la masse du bouton-poussoir 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher les connecteurs de contacteur du moteur et &#34;G28&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement de borne sur les connecteurs de contacteur du moteur et &#34;G28&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Si les branchements sont corrects, vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance des circuits &#34;A1&#34;, &#34;A2&#34; et &#34;B1&#34;: en dessous de 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance entre chacun des circuits &#34;A1&#34; et &#34;A2&#34; et la masse: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre chaque borne des circuits &#34;A1&#34; et &#34;A2&#34; et chaque borne au niveau du connecteur de contacteur du moteur: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;B1&#34; et chaque borne du connecteur du contacteur du moteur: infinie 
</ptxt>
</item>
</list1>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504021007">
<title>
Vérification du contacteur du moteur 
</title>
<test1>
<ptxt>
Vérifier le contacteur du moteur. 
<intxreftitleoff1 refid = "AFRAP70AA506016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le contacteur du moteur. 
<intxreftitleoff1 refid = "AFRAP70AA506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504021009">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Brancher les connecteurs de contacteur du moteur et &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1190 actuel est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande de démarrage sans clé et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
</testgroup>
</diag>
