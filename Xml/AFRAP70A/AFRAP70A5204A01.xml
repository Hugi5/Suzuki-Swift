<servinfo servinfosgmlid = "AFRAP70A5204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Les rapports sautent 
</title>
<diag type = "condition">
<condition>
<ptxt>
Les rapports sautent 
</ptxt>
</condition>
<ps>
<ptxt>
Usure de l&#39;axe de fourchette de sélection 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer la fourchette ou l&#39;axe de changement de vitesses. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Arbre de changement de vitesses court: 
<intxreftitleoff1 refid = "AFRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Arbre de changement de vitesses de rapport haut: 
<intxreftitleoff1 refid = "AFRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Fourchette de changement de vitesses de 5ème: 
<intxreftitleoff1 refid = "AFRAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Usure de la fourchette de sélection ou du manchon de synchronisation 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer la fourchette de changement de vitesses, l&#39;axe de changement de vitesses ou le manchon et moyeu de synchroniseur. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Arbre de changement de vitesses court: 
<intxreftitleoff1 refid = "AFRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Arbre de changement de vitesses de rapport haut: 
<intxreftitleoff1 refid = "AFRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Fourchette de changement de vitesses de 5ème: 
<intxreftitleoff1 refid = "AFRAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manchon et moyeu de synchroniseur de rapport court: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manchon et moyeu de synchroniseur de rapport haut: 
<intxreftitleoff1 refid = "AFRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manchon et moyeu de synchroniseur de 5ème: 
<intxreftitleoff1 refid = "AFRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Ressorts de positionnement affaiblis ou endommagés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le ressort de positionnement. 
<intxreftitleoff1 refid = "AFRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Usure des roulements de l&#39;arbre d&#39;entrée ou de l&#39;arbre intermédiaire 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le roulement d&#39;arbre d&#39;entrée ou le roulement d&#39;arbre de sortie. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Roulement gauche d&#39;arbre intermédiaire: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Chemin intérieur: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Chemin extérieur: 
<intxreftitleoff1 refid = "AFRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Roulement droit d&#39;arbre intermédiaire: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Chemin intérieur: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Chemin extérieur: 
<intxreftitleoff1 refid = "AFRAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Roulement gauche et roulement droit d&#39;arbre d&#39;entrée: 
<intxreftitleoff1 refid = "AFRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Dent chanfreinée du manchon et du pignon usée 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le manchon, le moyeu et le pignon de synchroniseur. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Pignon de 1ère et pignon de 2ème d&#39;arbre intermédiaire: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pignon de 3ème et pignon de 4ème d&#39;arbre d&#39;entrée: 
<intxreftitleoff1 refid = "AFRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pignon de 5ème d&#39;arbre d&#39;entrée: 
<intxreftitleoff1 refid = "AFRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manchon et moyeu de synchroniseur de rapport court: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manchon et moyeu de synchroniseur de rapport haut: 
<intxreftitleoff1 refid = "AFRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manchon et moyeu de synchroniseur de 5ème: 
<intxreftitleoff1 refid = "AFRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
