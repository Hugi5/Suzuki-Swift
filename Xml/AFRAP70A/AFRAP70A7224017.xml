<servinfosub id = "AFRAP70A7224017003">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
Démarrer le moteur et activer le système A/C. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7224017004">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A7224017005">
<testgroup id = "AFRAP70A7224017006">
<title>
Vérification des paramètres de l&#39;outil de balayage 
</title>
<test1>
<ptxt>
Vérifier la valeur &#34;Charge Soleil&#34; à l&#39;aide du mode &#34;Liste de données&#34; de l&#39;outil de balayage SUZUKI. 
<intxreftitleoff1 refid = "AFRAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
La valeur &#34;Charge Soleil&#34; est-elle supérieure à 2440 W/m<sup>2</sup> (la tension de signal de capteur d&#39;ensoleillement est inférieur à la valeur spécifiée 0,1 V)? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problème intermittent. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224017007">
<title>
Vérification de circuit de signal de capteur de puissance de rayonnement solaire 
</title>
<test1>
<ptxt>
Débrancher le connecteur du capteur d&#39;ensoleillement. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1504-H est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le capteur de puissance de rayonnement solaire 
<intxreftitleoff1 refid = "AFRAP70A7226031"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224017008">
<title>
Vérification de circuit de signal de capteur de puissance de rayonnement solaire 
</title>
<test1>
<ptxt>
Débrancher le connecteur &#34;G20&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier si la tension entre les bornes de câble &#34;PNK&#34; et la masse est de 0 – 1 V avec l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<question>
La tension est-elle conforme aux spécifications? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande HVAC et revérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
