<servinfosub id = "AFRAP70A4604027003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A4604027004">
<testgroup id = "AFRAP70A4604027005">
<question>
La &#34;Vérification du système ESP<sup>&#174;</sup>&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A4604001">Vérification du système ESP&#174;</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604027006">
<title>
Vérification des circuits de mise à la masse du module de commande ESP&#174; et d&#39;alimentation électrique d&#39;électrovanne 
</title>
<test1>
<ptxt>
Vérifier les circuits d&#39;alimentation électrique et de mise à la masse d&#39;électrovanne dans 
<intxref refid = "AFRAP70A4604042">Vérification du circuit d&#39;alimentation électrique et de mise à la masse du module de commande ESP&#174;</intxref>
. 
</ptxt>
</test1>
<question>
Les résultats de la vérification sont-ils corrects? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
</diag>
