<servinfosub id = "AFRAP70A8204042003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A8204042004">
<testgroup id = "AFRAP70A8204042005">
<question>
La &#34;vérification du système de diagnostic d&#39;airbag&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204042006">
<title>
Vérification du contacteur de désactivation d&#39;airbag du passager 
</title>
<test1>
<ptxt>
Déposer le contacteur de désactivation d&#39;airbag du passager. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement correct du connecteur &#34;G168&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le contacteur de désactivation d&#39;airbag du passager. 
<intxreftitleoff1 refid = "AFRAP70A8206027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le contacteur de désactivation d&#39;airbag du passager est-il en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le contacteur de désactivation d&#39;airbag du passager. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204042007">
<title>
Vérification du circuit du contacteur de désactivation d&#39;airbag du passager 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;G11&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement correct à &#34;G11-16&#34; et &#34;G11-17&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la résistance entre &#34;G11-16&#34; et &#34;G168-1&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la résistance entre &#34;G11-17&#34; et &#34;G168-2&#34;. 
</ptxt>
<servicetool>
<servicetoolitem id = "L8B078">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820029.swf" width = "90.000mm" height = "56.862mm" ver = "01" gw = "217" gh = "145"/>
</testfigure>
</test1>
<question>
La résistance mesurée est-elle de 1 &#937; maximum? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204042008">
<title>
Vérification du circuit du contacteur de désactivation d&#39;airbag du passager 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le point suivant. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tension entre chacune des bornes &#34;G11-16&#34; et &#34;G11-17&#34; et la masse : environ 0 V
</ptxt>
<servicetool>
<servicetoolitem id = "L8B079">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820056.swf" width = "90.000mm" height = "55.764mm" ver = "01" gw = "203" gh = "142"/>
</testfigure>
</item>
</list1>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le SDM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Une fois la vérification et les réparations terminées, effectuer les opérations suivantes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Raccorder toutes les pièces constitutives du système d&#39;airbag et s&#39;assurer qu&#39;elles sont toutes correctement montées. 
</ptxt>
</item>
<item>
<ptxt>
Supprimer les DTC éventuels en se reportant au point 
<intxref refid = "AFRAP70A8204006">Suppression des DTC</intxref>
. 
</ptxt>
</item>
<item>
<ptxt>
Effectuer à nouveau 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
 pour confirmer que le problème a été résolu. 
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
