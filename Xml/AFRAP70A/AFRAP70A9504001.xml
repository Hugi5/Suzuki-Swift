<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A9504001" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Diagnostic des symptômes du système de vitre électrique 
</title>
<diag type = "condition" id = "AFRAP70A9504001001">
<condition>
<ptxt>
Aucune des vitres électriques ne fonctionne 
</ptxt>
</condition>
<ps>
<ptxt>
Câblage défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer le câblage. 
</ptxt>
</action>
<ps>
<ptxt>
Contacteur principal de vitre électrique défectueux 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AFRAP70A9506019">Vérification du contacteur principal de vitre électrique</intxref>
</ptxt>
</action>
<condition>
<ptxt>
Une des vitres électriques ne fonctionne pas 
</ptxt>
</condition>
<ps>
<ptxt>
Câblage défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer le câblage. 
</ptxt>
</action>
<ps>
<ptxt>
Lève-vitre et/ou moteur de vitre électrique défectueux 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Avant: 
<intxreftitleoff1 refid = "AFRAP70A9506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Arrière: 
<intxreftitleoff1 refid = "AFRAP70A9506018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Contacteur principal de vitre électrique défectueux 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AFRAP70A9506019">Vérification du contacteur principal de vitre électrique</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Contacteur secondaire de vitre électrique défectueux 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AFRAP70A9506020">Vérification du contacteur secondaire de vitre électrique</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Le contacteur de verrouillage de vitre est enfoncé (position de verrouillage) 
</ptxt>
</ps>
<action>
<ptxt>
Mettre le contacteur de verrouillage de vitre en position OFF. 
</ptxt>
</action>
<condition>
<ptxt>
La fonction d&#39;ouverture automatique ne fonctionne pas 
</ptxt>
</condition>
<ps>
<ptxt>
Contacteur principal de vitre électrique défectueux 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AFRAP70A9506019">Vérification du contacteur principal de vitre électrique</intxref>
</ptxt>
</action>
<condition>
<ptxt>
Bruit anormal 
</ptxt>
</condition>
<ps>
<ptxt>
Boulons de fixation de lève-vitre desserrés 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Serrer les boulons de fixation de lève-vitre. 
</ptxt>
<ptxt>
Avant: 
<intxreftitleoff1 refid = "AFRAP70A9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Arrière: 
<intxreftitleoff1 refid = "AFRAP70A9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Usure ou rupture des pièces coulissantes et rotatives de lève-vitre électrique 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vérifier le lève-vitre. 
</ptxt>
<ptxt>
Avant: 
<intxreftitleoff1 refid = "AFRAP70A9506012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Arrière: 
<intxreftitleoff1 refid = "AFRAP70A9506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Graissage insuffisant 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Lubrifier. 
</ptxt>
<ptxt>
Avant: 
<intxreftitleoff1 refid = "AFRAP70A9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Arrière: 
<intxreftitleoff1 refid = "AFRAP70A9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
