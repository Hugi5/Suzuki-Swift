<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A4104A12" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Le témoin ESP&#174; ne s&#39;allume pas après avoir mis l&#39;allumage en position &#34;ON&#34; 
</title>
<diag type = "condition">
<condition>
<ptxt>
Le témoin ESP<sup>&#174;</sup> ne s&#39;allume pas après avoir mis l&#39;allumage en position &#34;ON&#34; 
</ptxt>
</condition>
<ps>
<ptxt>
Circuit d&#39;alimentation électrique et de mise à la masse du combiné d&#39;instruments défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le combiné d&#39;instruments et son circuit. 
<intxreftitleoff1 refid = "AFRAP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Combiné d&#39;instruments défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le combiné d&#39;instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Système de communication CAN défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier la ligne de communication CAN. 
<intxreftitleoff1 refid = "AFRAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fusible grillé 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le fusible &#34;MTR&#34; et le circuit alimentant le fusible &#34;MTR&#34;, et remplacer si nécessaire. 
</ptxt>
</action>
<ps>
<ptxt>
Groupe hydraulique / module de commande ESP<sup>&#174;</sup> défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le groupe hydraulique / module de commande ESP<sup>&#174;</sup>
<intxreftitleoff1 refid = "AFRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
