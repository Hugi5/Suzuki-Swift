<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A7216030" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de la grille de ventilation latérale 
</title>
<servinfosub id = "AFRAP70A7216030001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Côté conducteur: Déposer le panneau de combiné d&#39;instruments du tableau de bord. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Côté passager: Déposer la trappe d&#39;airbag du passager. 
<intxreftitleoff1 refid = "AFRAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la grille de ventilation latérale. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Relâcher les tuyaux (1) puis détacher la grille de ventilation latérale (2) du garnissage latéral de tableau de bord (3). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A721039.swf" width = "88.000mm" height = "68.687mm" ver = "01" gw = "177" gh = "178"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7216030002">
<title>
Repose 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
