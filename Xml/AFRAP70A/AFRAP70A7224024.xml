<servinfosub id = "AFRAP70A7224024004">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A7224024005">
<testgroup id = "AFRAP70A7224024006">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34; et vérifier les DTC. 
</ptxt>
</test1>
<question>
Le DTC B1541 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problème intermittent. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224024008">
<title>
Vérification du fusible 
</title>
<test1>
<ptxt>
Vérifier le fusible &#34;MTR&#34;. 
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le fusible &#34;MTR&#34; et rechercher un éventuel court-circuit à la masse. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224024007">
<title>
Vérification du circuit d&#39;alimentation électrique de tension de la batterie 
</title>
<test1>
<ptxt>
Débrancher le connecteur &#34;G20&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la tension entre la borne de câble &#34;WHT/RED&#34; du connecteur &#34;G20&#34; et la masse. 
</ptxt>
</test1>
<question>
La tension est-elle de 10 – 14 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande HVAC et revérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
