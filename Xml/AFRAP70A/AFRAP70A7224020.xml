<diag type = "test" id = "AFRAP70A7224020007">
<testgroup id = "AFRAP70A7224020008">
<title>
Vérification des paramètres de l&#39;outil de balayage 
</title>
<test1>
<ptxt>
Vérifier la valeur &#34;Capt pos mélange air&#34; à l&#39;aide du mode &#34;Liste de données&#34; de l&#39;outil de balayage SUZUKI. 
<intxreftitleoff1 refid = "AFRAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Problème intermittent. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224020009">
<title>
Vérification du circuit d&#39;actionneur de commande de température 
</title>
<test1>
<ptxt>
Débrancher les connecteurs &#34;G20&#34; et d&#39;actionneur de commande de température. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance des circuits de câble &#34;GRY&#34; et &#34;LT BLU&#34;: en dessous de 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance des circuits de câble &#34;GRY&#34; et &#34;LT BLU&#34; entre l&#39;actionneur de commande de température et la masse: infinie 
</ptxt>
</item>
</list1>
</test1>
<question>
Les valeurs de résistance sont-elles conformes aux spécifications? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224020010">
<title>
Vérification de l&#39;actionneur de commande de température 
</title>
<test1>
<ptxt>
Vérifier l&#39;actionneur de commande de température. 
<intxreftitleoff1 refid = "AFRAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;actionneur est-il en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande HVAC et revérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer l&#39;actionneur de commande de température. 
<intxreftitleoff1 refid = "AFRAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
