<servinfo servinfosgmlid = "AFRAP70AA314015" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1173
</title>
<servinfosub id = "AFRAP70AA314015001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1173: Transpondeur non enregistré 
</emph>
</ptxt>
<ptxt>
Le code de transpondeur dans le transpondeur intégré à la clé de contact n&#39;a pas été enregistré. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
La clé de contact n&#39;est pas enregistrée 
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70AA314015002">
<title>
Recherche de pannes à partir de DTC 
</title>
<attention3>
<ptxt>
Le dysfonctionnement de la clé de contact peut empêcher l&#39;enregistrer normal du dispositif antidémarrage. 
</ptxt>
</attention3>
</servinfosub>
<diag type = "test" id = "AFRAP70AA314015003">
<testgroup id = "AFRAP70AA314015005">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Vérifier les DTC du BCM. 
<intxreftitleoff1 refid = "AFRAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Un ou plusieurs DTC CAN sont-ils détectés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA314015006">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Vérifier les DTC associés à la communication CAN. 
</ptxt>
</test1>
<question>
Un ou plusieurs DTC CAN sont-ils détectés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA314015004">
<title>
Enregistrement de la clé de contact 
</title>
<test1>
<ptxt>
Effectuer l&#39;&#34;Enregistrement de clé du dispositif antidémarrage&#34;. 
<intxreftitleoff1 refid = "AFRAP70AA316002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1173 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le BCM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (la clé de contact n&#39;a pas été enregistrée) 
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
