<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A7216043" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de la soupape de décharge 
</title>
<servinfosub id = "AFRAP70A7216043001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Récupérer le réfrigérant du circuit de climatisation à l&#39;aide d&#39;un appareil de récupération et recyclage en se reportant &#34;Récupération&#34; du point 
<intxref refid = "AFRAP70A7216001">Procédure de remplissage de réfrigérant:Type manuel</intxref>
. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le sabot droit de protection du moteur. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la soupape de décharge (1) du compresseur. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A722038.swf" width = "88.000mm" height = "48.588mm" ver = "03" gw = "120" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7216043002">
<title>
Repose 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utiliser un joint torique neuf. 
</ptxt>
</item>
<item>
<ptxt>
Appliquer de l&#39;huile de compresseur sur le joint torique. 
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B107" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Huile de compresseur
</m-desc>
<m-number>
99000-99095-00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Serrer la soupape de décharge au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T7B107">
<t-part>
 Soupape de décharge 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,8
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A722039.swf" width = "88.000mm" height = "48.612mm" ver = "05" gw = "120" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Purger et remplir le système A/C en se reportant à &#34;Purge&#34; et &#34;Remplissage&#34; au point 
<intxref refid = "AFRAP70A7216001">Procédure de remplissage de réfrigérant:Type manuel</intxref>
. 
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
