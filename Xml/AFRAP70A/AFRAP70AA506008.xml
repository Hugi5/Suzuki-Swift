<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70AA506008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;antenne intérieure arrière 
</title>
<servinfosub id = "AFRAP70AA506008001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;habillage arrière. 
<intxreftitleoff1 refid = "AFRAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur d&#39;antenne intérieure arrière (1), puis déposer l&#39;antenne intérieure arrière (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50027.swf" width = "88.000mm" height = "59.203mm" ver = "01" gw = "175" gh = "151"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA506008002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70AA506010">Vérification de l&#39;antenne</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
