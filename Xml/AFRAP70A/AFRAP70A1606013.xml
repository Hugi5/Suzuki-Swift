<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1606013" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Démontage et remontage du ventilateur de refroidissement de radiateur 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1606012">Dépose et repose de l&#39;ensemble de ventilateur de refroidissement de radiateur</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A1606013001">
<title>
Démontage 
</title>
<s1 page = "2">
<ptxt>
Déposer le ventilateur (1) du moteur de ventilateur de refroidissement (2). 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Déposer le moteur de ventilateur (2) du carénage de ventilateur de refroidissement (3). 
</ptxt>
<figure>
<graphic graphicname = "IAP70P160006.jpg" width = "88.000mm" height = "55.324mm" ver = "01" gw = "207" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1606013002" page = "2">
<title>
Remontage 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la procédure de démontage. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer l&#39;écrou de ventilateur et les boulons de moteur de ventilateur de refroidissement de radiateur au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T1F001">
<t-part>
 Ecrou de ventilateur 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
<torqueitem id = "T1F002">
<t-part>
 Boulon de moteur de ventilateur de refroidissement de radiateur 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
4,0
</t-value1>
<t-value2>
0,41
</t-value2>
<t-value3>
3,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70P160010.jpg" width = "88.000mm" height = "51.127mm" ver = "03" gw = "223" gh = "128"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
