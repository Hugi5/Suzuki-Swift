<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70AA504010" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1120 / B1170
</title>
<servinfosub id = "AFRAP70AA504010001">
<title>
Condition de détection du DTC et organe incriminé
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.118in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.087in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1120: Défaut interne du module de commande de démarrage sans clé 
</emph>
</ptxt>
<ptxt>
Dysfonctionnement interne du module de commande de démarrage sans clé.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Module de commande de démarrage sans clé
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1170: Erreur d&#39;accès EEPROM
</emph>
</ptxt>
<ptxt>
Dysfonctionnement interne du module de commande de démarrage sans clé. (erreur EEPROM)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70AA504010002">
<title>
Procédure de confirmation de DTC
</title>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA504010003">
<title>
Recherche de pannes à partir de DTC
</title>
<diag type = "test" id = "AFRAP70AA504010004">
<testgroup id = "AFRAP70AA504009005">
<title>
Nouvelle vérification de DTC
</title>
<test1>
<ptxt>
Effacer le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Effectuer le point 
<intxref refid = "AFRAP70AA504010002">Procédure de confirmation de DTC</intxref>
, puis vérifier de nouveau le DTC.
</ptxt>
</test1>
<question>
Le DTC B1120 ou B1170 est-il toujours détecté?
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande de démarrage sans clé et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
