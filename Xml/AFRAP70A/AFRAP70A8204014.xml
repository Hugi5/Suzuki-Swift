<servinfosub id = "AFRAP70A8204014003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A8204014004">
<testgroup id = "AFRAP70A8204014005">
<question>
La &#34;vérification du système de diagnostic d&#39;airbag&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204014006">
<title>
Vérification du circuit du témoin de désactivation d&#39;airbag du passager 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier si le branchement au connecteur &#34;G153&#34; est correct. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;G153&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la tension entre la borne &#34;G153-9&#34; et la masse. 
</ptxt>
<servicetool>
<servicetoolitem id = "L8B004">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820109.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</test1>
<question>
La tension mesurée est-elle de 10 – 14 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204014007">
<title>
Vérification du circuit du témoin de désactivation d&#39;airbag du passager 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier si le branchement au connecteur &#34;G11&#34; est correct. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;G11&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la résistance entre la borne &#34;G153-10&#34; et la borne &#34;G11-15&#34;. 
</ptxt>
<servicetool>
<servicetoolitem id = "L8B005">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820110.swf" width = "90.000mm" height = "48.716mm" ver = "01" gw = "188" gh = "122"/>
</testfigure>
</test1>
<question>
La résistance mesurée est-elle de 1 &#937; maximum? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204014008">
<title>
Vérification du circuit du témoin de désactivation d&#39;airbag du passager 
</title>
<test1>
<ptxt>
Vérifier le point suivant. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance entre la masse de borne &#34;G153-10&#34;. 
</ptxt>
<servicetool>
<servicetoolitem id = "L8B006">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820111.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</item>
</list1>
</test1>
<question>
La résistance mesurée est-elle égale à l&#39;infini? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204014009">
<title>
Vérification du témoin de désactivation d&#39;airbag du passager 
</title>
<test1>
<ptxt>
Vérifier le témoin de désactivation d&#39;airbag de passager. 
<intxreftitleoff1 refid = "AFRAP70A8206029"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le SDM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le contacteur des feux de détresse. 
<intxreftitleoff1 refid = "AFRAP70A9206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Une fois la vérification et les réparations terminées, effectuer les opérations suivantes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Raccorder toutes les pièces constitutives du système d&#39;airbag et s&#39;assurer qu&#39;elles sont toutes correctement montées. 
</ptxt>
</item>
<item>
<ptxt>
Supprimer les DTC éventuels en se reportant au point 
<intxref refid = "AFRAP70A8204006">Suppression des DTC</intxref>
. 
</ptxt>
</item>
<item>
<ptxt>
Effectuer à nouveau 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
 pour confirmer que le problème a été résolu. 
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
