<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9706007" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Dépose et repose du siège arrière 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9706006">Pièces constitutives du siège arrière</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A9706007001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer l&#39;ensemble d&#39;assise de siège arrière. 
<intxreftitleoff1 refid = "AFRAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les ensembles de dossier de siège arrière en déposant les boulons de charnière de siège arrière. 
<intxreftitleoff1 refid = "AFRAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Démonter et réparer le siège arrière si nécessaire. 
<intxreftitleoff1 refid = "AFRAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9706007002">
<title>
Repose 
</title>
<ptxt>
Pour la repose, procéder dans l&#39;ordre inverse de la dépose en tenant compte des points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Se référer au point 
<intxref refid = "AFRAP70A9706006">Pièces constitutives du siège arrière</intxref>
 pour le couple de serrage. 
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
