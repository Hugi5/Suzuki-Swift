</ptxt>
</action>
<ps>
<ptxt>
Circuit de témoin ESP<sup>&#174;</sup> défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le circuit de témoin ESP<sup>&#174;</sup>. 
<intxreftitleoff1 refid = "AFRAP70A4604010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
