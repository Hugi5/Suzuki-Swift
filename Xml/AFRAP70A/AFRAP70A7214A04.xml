<servinfo servinfosgmlid = "AFRAP70A7214A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
L&#39;air chaud ne sort pas ou la chaleur est insuffisante (commande de température défectueuse) 
</title>
<diag type = "condition">
<condition>
<ptxt>
L&#39;air chaud ne sort pas ou la chaleur est insuffisante (commande de température défectueuse) 
</ptxt>
</condition>
<ps>
<ptxt>
Câble de commande de température cassé ou plié 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le câble de commande de température. 
</ptxt>
</action>
<ps>
<ptxt>
Sélecteur de température défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le sélecteur de température. 
</ptxt>
</action>
<ps>
<ptxt>
Repose incorrecte du câble de commande de température 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier la position du câble et la régler si nécessaire. 
</ptxt>
</action>
<ps>
<ptxt>
Ensemble de trappe de commande de température cassé 
</ptxt>
</ps>
<action>
<ptxt>
Réparer l&#39;ensemble de trappe de commande de température. 
</ptxt>
</action>
<ps>
<ptxt>
Conduites d&#39;air obstruées 
</ptxt>
</ps>
<action>
<ptxt>
Réparer les conduites d&#39;air. 
</ptxt>
</action>
<ps>
<ptxt>
Bloc de chauffe obstrué ou présentant une fuite 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le bloc de chauffe. 
</ptxt>
</action>
<ps>
<ptxt>
Durites de chauffage obstruées ou présentant une fuite 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les durites de chauffage. 
</ptxt>
</action>
<ps>
<ptxt>
Thermostat défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le thermostat. 
<intxreftitleoff1 refid = "AFRAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Capteur ECT défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le capteur ECT. 
<intxreftitleoff1 refid = "AFRAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
