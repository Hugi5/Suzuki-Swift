<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A3204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Bruit d&#39;engrenages 
</title>
<diag type = "condition">
<condition>
<ptxt>
Bruit d&#39;engrenages 
</ptxt>
</condition>
<ps>
<ptxt>
Lubrifiant en mauvais état ou présence d&#39;eau dans le lubrifiant 
</ptxt>
</ps>
<action>
<ptxt>
Rectifier et faire l&#39;appoint. 
<intxreftitleoff1 refid = "AFRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lubrifiant de type inadéquat ou en quantité insuffisante 
</ptxt>
</ps>
<action>
<ptxt>
Rectifier et faire l&#39;appoint. 
<intxreftitleoff1 refid = "AFRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Jeu réactif de denture mal ajusté entre le pignon conique et l&#39;engrenage 
</ptxt>
</ps>
<action>
<ptxt>
Régler de la manière prescrite. 
<intxreftitleoff1 refid = "AFRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Mauvais contact entre-dents dans l&#39;engrènement entre le pignon conique et la couronne 
</ptxt>
</ps>
<action>
<ptxt>
Régler ou remplacer. 
<intxreftitleoff1 refid = "AFRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Boulons de fixation du pignon conique desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer ou resserrer. 
<intxreftitleoff1 refid = "AFRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Planétaire(s) ou satellite(s) de différentiel endommagé(s) 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer. 
<intxreftitleoff1 refid = "AFRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
