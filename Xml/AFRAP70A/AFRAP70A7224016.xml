<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1504-H: Dysfonctionnement du capteur d&#39;ensoleillement et/ou de son circuit
</emph>
</ptxt>
<ptxt>
La tension de signal de capteur d&#39;ensoleillement est constamment supérieure à la valeur prescrite (4,9 V) pendant la durée prescrite. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Circuit du capteur de puissance de rayonnement solaire 
</ptxt>
</item>
<item>
<ptxt>
Capteur d&#39;ensoleillement 
</ptxt>
</item>
<item>
<ptxt>
Module de commande HVAC 
</ptxt>
</item>
</list1>
</entry>
