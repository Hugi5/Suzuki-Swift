<servinfosub id = "AFRAP70A4604011002">
<title>
Description du circuit 
</title>
<ptxt>
Se reporter à la &#34;Description du circuit&#34; au point 
<intxref refid = "AFRAP70A4604010">Le témoin ESP&#174; ne s&#39;allume pas après avoir passé l&#39;allumage en position &#34;ON&#34;</intxref>
. 
</ptxt>
</servinfosub>
<servinfosub id = "AFRAP70A4604011003">
<title>
Recherche de pannes 
</title>
<diag type = "test" id = "AFRAP70A4604011004">
<testgroup id = "AFRAP70A4604011005">
<title>
Vérification du connecteur de module de commande ESP&#174;
</title>
<test1>
<ptxt>
Vérifier le branchement au connecteur de module de commande d&#39;ESP<sup>&#174;</sup>. 
</ptxt>
</test1>
<question>
Le raccordement est-il en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Brancher correctement le connecteur. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604011006">
<title>
Vérifier les DTC de l&#39;ESP&#174;
</title>
<test1>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70A4604005">Vérification des DTC</intxref>
. 
</ptxt>
</test1>
<question>
Un ou plusieurs DTC sont-ils signalés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604011007">
<title>
Vérification du circuit d&#39;alimentation électrique et de mise à la masse du module de commande ESP&#174;
</title>
<test1>
<ptxt>
Vérifier le circuit d&#39;alimentation électrique et le circuit de mise à la masse du module de commande ESP<sup>&#174;</sup>. 
<intxreftitleoff1 refid = "AFRAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Les circuits sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604011008">
<title>
Vérification du combiné d&#39;instruments 
</title>
<test1>
<ptxt>
Remplacer le combiné d&#39;instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<question>
Le témoin reste-t-il allumé? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> et vérifier à nouveau le fonctionnement du témoin. 
<intxreftitleoff1 refid = "AFRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. 
</ptxt>
</action>
</testgroup>
