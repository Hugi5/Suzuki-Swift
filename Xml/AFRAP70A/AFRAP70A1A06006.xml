<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1A06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du support de générateur 
</title>
<servinfosub id = "AFRAP70A1A06006001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le sabot droit de protection du moteur. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la courroie d&#39;entraînement de pompe à eau/générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la poulie de pompe à eau (1). 
<intxreftitleoff1 refid = "AFRAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le boulon de générateur (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le support de générateur (3). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1007.jpg" width = "88.000mm" height = "70.982mm" ver = "01" gw = "192" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1A06006002">
<title>
Repose 
</title>
<ptxt>
Pour la repose, procéder dans l&#39;ordre inverse de la dépose en tenant compte des points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reposer le support de générateur à l&#39;aide de la procédure suivante. 
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Positionner le support de générateur (1). 
</ptxt>
</item>
<item>
<ptxt>
Serrer provisoirement le boulon de générateur (2). 
</ptxt>
</item>
<item>
<ptxt>
Serrer les écrous de support de générateur (3) au couple prescrit. 
<intxreftitleoff1 refid = "AFRAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
<figure>
<graphic graphicname = "I9P60A1A1016.swf" width = "88.000mm" height = "68.664mm" ver = "01" gw = "188" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
