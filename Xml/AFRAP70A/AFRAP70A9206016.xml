<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9206016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du contacteur de feux de détresse 
</title>
<servinfosub id = "AFRAP70A9206016001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer la grille de ventilation centrale (1). 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur, puis déposer le contacteur de feux de détresse (2) du boîtier supérieur central tout en libérant les dispositifs de verrouillage (3). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A920023.jpg" width = "88.000mm" height = "65.260mm" ver = "01" gw = "181" gh = "168"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9206016002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9206017">Vérification du contacteur de feux de détresse</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
