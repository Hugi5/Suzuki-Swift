<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A9204A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Les feux de position, les feux arrière ou l&#39;éclairage de plaque d&#39;immatriculation ne s&#39;allument pas 
</title>
<diag type = "condition">
<condition>
<ptxt>
Les feux de position, les feux arrière ou l&#39;éclairage de plaque d&#39;immatriculation ne s&#39;allument pas 
</ptxt>
</condition>
<ps>
<ptxt>
Circuit du système défectueux (y compris les relais et les fusibles) 
</ptxt>
</ps>
<action>
<ptxt>
Réparer le circuit. 
</ptxt>
</action>
<ps>
<ptxt>
Ampoules grillées 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les ampoules. 
</ptxt>
</action>
<ps>
<ptxt>
Contacteur d&#39;éclairage et de clignotant défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Se reporter au point 
<intxref refid = "AFRAP70A9206015">Vérification du contacteur d&#39;éclairage et de clignotant</intxref>
. 
</ptxt>
</action>
<ps>
<ptxt>
BCM défectueux 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Se reporter à &#34;Vérification du BCM et de ses circuits&#34; dans la section 10B. 
</ptxt>
<ptxt>
Modèle à contacteur d&#39;allumage: 
<intxreftitleoff1 refid = "AFRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modèle à démarrage sans clé: 
<intxreftitleoff1 refid = "AFRAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
