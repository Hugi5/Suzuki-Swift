<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70AA324001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Vérification du système de commande de dispositif antidémarrage 
</title>
<diag type = "test" id = "AFRAP70AA324001001">
<testgroup id = "AFRAP70AA324001003">
<title>
Vérification allumage en position &#34;ON&#34; 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Enfoncer la pédale d&#39;embrayage. 
</ptxt>
</test1>
<question>
Le témoin ON et le témoin PUSH s&#39;allument-ils? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70AA504001">Vérification du système de démarrage sans clé</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA324001004">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Y a-t-il un (des) DTC? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA324001006">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Vérifier les DTC associés à la communication CAN. 
</ptxt>
</test1>
<question>
Un ou plusieurs DTC CAN sont-ils détectés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA324001005">
<question>
Le moteur est-il lancé? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A1904001">Diagnostic des symptômes du système de lancement du moteur</intxref>
&#34;. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA324001002">
<title>
Vérification du démarrage du moteur 
</title>
<question>
Le moteur démarre-t-il? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Le système de commande de dispositif antidémarrage est en bon état. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A1104009">Vérification de base du moteur</intxref>
. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
