<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9506012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;ensemble de lève-vitre avant
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9506010">Composants de porte avant</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A9506012001">
<title>
Dépose
</title>
<s1>
<ptxt>
Déposer la vitre de porte avant. 
<intxreftitleoff1 refid = "AFRAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur de moteur de vitre électrique (3).
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les écrous de lève-vitre avant (1) et déposer l&#39;ensemble de lève-vitre avant (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950032.jpg" width = "88.000mm" height = "64.165mm" ver = "03" gw = "225" gh = "165"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9506012002">
<title>
Repose
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9506013">Vérification de l&#39;ensemble de lève-vitre avant</intxrefpoff>
</ptxt>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Appliquer de la graisse sur les parties coulissantes de l&#39;ensemble de lève-vitre avant.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E001" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Graisse
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Serrer les écrous de lève-vitre avant dans l&#39;ordre (de &#34;1&#34; à &#34;6&#34;) au couple spécifié.
</ptxt>
<torque>
<torqueitem id = "T9E003">
<t-part>
Ecrou de lève-vitre avant*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950033.jpg" width = "88.000mm" height = "70.187mm" ver = "02" gw = "225" gh = "182"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
