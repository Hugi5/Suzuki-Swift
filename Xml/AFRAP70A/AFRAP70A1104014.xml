<ptxt>
Vérification de plaque de capteur: 
<intxreftitleoff1 refid = "AFRAP70A1406042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 7. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer les pièces défectueuses. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1104014012">
