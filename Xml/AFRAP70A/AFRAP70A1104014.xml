<intxreftitleoff1 refid = "AFRAP70A1306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
