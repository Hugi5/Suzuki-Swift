<diag type = "test" id = "AFRAP70A6304021002">
<testgroup id = "AFRAP70A6304021003">
<title>
Vérification du fusible du circuit 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher les connecteurs &#34;E13&#34; et &#34;G50&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement de borne sur les connecteurs &#34;G50&#34; et &#34;E13&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Si les branchements sont corrects, vérifier si les fusibles &#34;P/S&#34; et &#34;IG1 SIG&#34; sont grillés. 
</ptxt>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le(s) fusible(s) et rechercher un éventuel court-circuit à la masse dans les circuits connectés à ce(s) fusible(s). 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304021004">
<title>
Vérification du circuit d&#39;alimentation électrique principale pour le module de commande P/S 
</title>
<test1>
<ptxt>
Vérifier la tension entre la borne &#34;E13-1&#34; et la masse. 
</ptxt>
</test1>
<question>
La tension est-elle de 10 – 14 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Coupure dans le circuit &#34;A1&#34;. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304021005">
<title>
Vérification du circuit d&#39;alimentation électrique IG1 pour le module de commande P/S 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier la tension entre la borne &#34;G50-3&#34; et la masse. 
</ptxt>
</test1>
<question>
La tension est-elle de 10 – 14 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Coupure dans le circuit &#34;A2&#34;. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304021006">
<title>
Vérification de la masse du circuit de module de commande P/S 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier la résistance entre la borne &#34;E13-2&#34; et la masse. 
</ptxt>
</test1>
<question>
La résistance est-elle de 1 &#937; maximum? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Fin. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Coupure ou résistance trop élevée du circuit &#34;A3&#34;. 
</ptxt>
</action>
</testgroup>
