<title>
L&#39;essuie-glace ne fonctionne pas correctement 
</title>
<servinfosub id = "AFRAP70A9404002003">
<title>
Essuie-glace et lave-glace arrière 
</title>
<diag type = "condition">
<condition>
<ptxt>
L&#39;essuie-glace ne fonctionne pas correctement 
</ptxt>
</condition>
<ps>
<ptxt>
Moteur d&#39;essuie-glace arrière défectueux 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AFRAP70A9406006">Vérification du moteur d&#39;essuie-glace arrière</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Contacteur d&#39;essuie-glace et de lave-glace défectueux (contacteur d&#39;essuie-glace) 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AFRAP70A9406008">Vérification du contacteur d&#39;essuie-glace et de lave-glace</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Câblage ou mise à la masse défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer le câblage. 
</ptxt>
</action>
<ps>
<ptxt>
BCM défectueux 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
&#34;Vérification du BCM et de ses circuits&#34; dans la section 10B 
</ptxt>
<ptxt>
Modèle à contacteur d&#39;allumage: 
<intxreftitleoff1 refid = "AFRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modèle à démarrage sans clé: 
<intxreftitleoff1 refid = "AFRAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
