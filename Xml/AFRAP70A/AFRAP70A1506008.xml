<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1506008" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Vérification de la pompe à huile 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1506007">Démontage et remontage de l&#39;ensemble de pompe à huile</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A1506008001">
<title>
Bague d&#39;étanchéité 
</title>
<ptxt>
Vérifier si la lèvre de bague d&#39;étanchéité n&#39;est pas endommagée ou défectueuse. Remplacer en cas de défaut. 
</ptxt>
<figure>
<graphic graphicname = "I2RH0B150023.swf" width = "88.000mm" height = "51.085mm" ver = "01" gw = "184" gh = "128"/>
</figure>
</servinfosub>
<servinfosub id = "AFRAP70A1506008002">
<title>
Pompe à huile 
</title>
<list1 type = "unordered">
<item>
<ptxt>
Rechercher toute trace d&#39;usure excessive ou de détérioration sur les rotors extérieur (1) et intérieur (2), la plaque de rotor et le carter de pompe à huile. 
</ptxt>
<figure>
<graphic graphicname = "I8C50A150028.swf" width = "88.000mm" height = "53.524mm" ver = "01" gw = "134" gh = "135"/>
</figure>
</item>
<item>
<ptxt>
Rechercher toute trace d&#39;usure excessive ou de détérioration sur la soupape de décharge (1) et s&#39;assurer qu&#39;elle bouge librement. 
</ptxt>
<figure>
<graphic graphicname = "I8C50A150029.swf" width = "88.000mm" height = "64.979mm" ver = "01" gw = "112" gh = "168"/>
</figure>
</item>
</list1>
<c-change/>
<topic id = "AFRAP70A1506008003">
<title>
Jeu radial 
</title>
<ptxt>
Vérifier le jeu radial entre le rotor extérieur (1) et le carter (2) à l&#39;aide d&#39;une jauge d&#39;épaisseur. 
</ptxt>
<ptxt>
Si le jeu n&#39;est pas conforme aux spécifications, remplacer l&#39;ensemble de pompe à huile. 
</ptxt>
<spec>
<title>
Jeu radial entre le rotor extérieur et le carter de la pompe à huile 
</title>
<ptxt>
Standard: 0,120 – 0,190 mm (0,0047 – 0,0075 in.)
</ptxt>
<ptxt>
Limite: 0,210 mm (0,0083 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151026.swf" width = "88.000mm" height = "49.550mm" ver = "01" gw = "171" gh = "124"/>
</figure>
</topic>
<topic id = "AFRAP70A1506008004">
<title>
Jeu latéral 
</title>
<ptxt>
A l&#39;aide d&#39;une règle (1) et d&#39;une jauge d&#39;épaisseur (2), mesurer le jeu latéral. 
</ptxt>
<ptxt>
Si le jeu latéral n&#39;est pas conforme aux spécifications, remplacer l&#39;ensemble de pompe à huile. 
</ptxt>
<spec>
<title>
Jeu latéral du rotor intérieur de pompe à huile 
</title>
<ptxt>
Standard: 0,045 – 0,100 mm (0,0018 – 0,0039 in.)
</ptxt>
<ptxt>
Limite: 0,120 mm (0,0047 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151027.swf" width = "88.000mm" height = "52.842mm" ver = "01" gw = "185" gh = "133"/>
</figure>
</topic>
<c-change/>
<topic id = "AFRAP70A1506008005" page = "2">
<title>
Jeu de plaque de rotor 
</title>
<ptxt>
Vérifier le jeu entre le rotor intérieur (1) et la plaque de rotor (2) comme suit. 
</ptxt>
<s1 page = "2">
<ptxt>
Mesurer le diamètre extérieur &#34;a&#34; du rotor intérieur (1) à l&#39;aide d&#39;un micromètre. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Mesurer le diamètre intérieur &#34;b&#34; de la plaque de rotor (2) à l&#39;aide d&#39;un micromètre. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Calculer la différence entre les mesures des étapes 1) et 2). 
</ptxt>
</s1>
<ptxt>
Si le jeu n&#39;est pas conforme aux spécifications, remplacer l&#39;ensemble de pompe à huile. 
</ptxt>
<spec>
<title>
Jeu de plaque de rotor 
</title>
<table frame = "all" colsep = "1" rowsep = "1" page = "2">
<tgroup cols = "2" colsep = "1" rowsep = "1">
