<servinfosub id = "AFRAP70A7224014003">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
Démarrer le moteur et activer le système A/C. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7224014004">
<title>
Recherche de pannes à partir de DTC 
</title>
<p-change/>
<diag type = "test" id = "AFRAP70A7224014005">
<testgroup id = "AFRAP70A7224014006">
<title>
Vérification des paramètres de l&#39;outil de balayage 
</title>
<test1>
<ptxt>
Vérification de la &#34;Temp habitacle&#34; à l&#39;aide du mode &#34;Liste de données&#34; de l&#39;outil de balayage SUZUKI. 
<intxreftitleoff1 refid = "AFRAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
La température est-elle supérieure à 87,5 &#176;C (189,5 &#176;F) (la tension du signal de capteur de température d&#39;air intérieur est inférieure à 0,1 V)? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problème intermittent. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224014007">
<title>
Vérification du capteur de température d&#39;air intérieur 
</title>
<test1>
<ptxt>
Débrancher le connecteur du capteur de température d&#39;air intérieur. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1502-H est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le capteur de température d&#39;air intérieur. 
<intxreftitleoff1 refid = "AFRAP70A7226035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224014008">
<title>
Vérification de circuit de signal de capteur de température d&#39;habitacle 
</title>
<test1>
<ptxt>
Débrancher le connecteur &#34;G20&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier si la résistance entre la borne de câble &#34;PNK/BLK&#34; et la masse est infinie. 
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande HVAC et revérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
