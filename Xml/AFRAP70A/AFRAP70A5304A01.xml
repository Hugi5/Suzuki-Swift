<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Patinage 
</title>
<diag type = "condition">
<condition>
<ptxt>
Patinage 
</ptxt>
</condition>
<ps>
<ptxt>
Course libre de pédale d&#39;embrayage 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le bras de pédale d&#39;embrayage et/ou le maître-cylindre d&#39;embrayage. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Bras de pédale d&#39;embrayage: 
<intxreftitleoff1 refid = "AFRAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Maître-cylindre d&#39;embrayage: 
<intxreftitleoff1 refid = "AFRAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Surface de disque d&#39;embrayage usée ou huileuse 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le disque d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Surface du disque, de la plaque de pression ou du volant moteur voilée 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le disque, le couvercle d&#39;embrayage ou le volant moteur. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Disque et couvercle d&#39;embrayage: 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Volant moteur: 
<intxreftitleoff1 refid = "AFRAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Ressort à diaphragme affaibli 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le couvercle d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Le piston de maître-cylindre ou la coupelle de joint ne revient pas en place. 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le maître-cylindre d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
