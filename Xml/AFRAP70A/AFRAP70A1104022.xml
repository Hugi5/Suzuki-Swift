<servinfosub id = "AFRAP70A1104022003">
<title>
Procédure de confirmation de DTC 
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Effectuer un essai sur route dans un lieu peu fréquenté pour éviter les accidents. 
</ptxt>
</item>
<item>
<ptxt>
L&#39;essai sur route doit être effectué sur une route plane et par deux personnes: un conducteur et un technicien qui procédera aux essais. 
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Confirmer que l&#39;ECT est inférieure à 40 &#176;C (104 &#176;F). 
</ptxt>
</s1>
<s1>
<ptxt>
Mettre le moteur en route et rouler constamment à 60 à 80 km/h (37 à 50 mile/h) pendant 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1104022004">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A1104022005">
<testgroup id = "AFRAP70A1104022006">
<question>
La procédure de &#34;Vérification du système de commande du moteur et des émissions&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A1104001">Vérification du système de régulation des émissions et de commande du moteur</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1104022007">
<title>
Vérification du niveau de liquide de refroidissement 
</title>
<test1>
<ptxt>
Vérifier le niveau de liquide de refroidissement. 
<intxreftitleoff1 refid = "AFRAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Faire l&#39;appoint de liquide de refroidissement et vérifier à nouveau le DTC. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1104022008">
<title>
Vérification du circuit de capteur ECT 
</title>
<test1>
<ptxt>
Vérifier les circuits de capteur ECT en se reportant à l&#39;étape 2 du point 
<intxref refid = "AFRAP70A1104023">DTC P0117 / P0118</intxref>
. 
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1104022009">
<title>
Vérification du capteur ECT 
</title>
<test1>
<ptxt>
Vérifier le capteur ECT. 
<intxreftitleoff1 refid = "AFRAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le capteur ECT. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1104022010">
<title>
Vérification du thermostat 
</title>
<test1>
<ptxt>
Vérifier l&#39;ensemble de thermostat. 
<intxreftitleoff1 refid = "AFRAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ECM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le thermostat. 
</ptxt>
</action>
</testgroup>
