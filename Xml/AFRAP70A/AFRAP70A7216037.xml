<servinfo servinfosgmlid = "AFRAP70A7216037" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de la courroie d&#39;entraînement de compresseur 
</title>
<servinfosub id = "AFRAP70A7216037004">
<title>
Dépose 
</title>
<s1>
<ptxt>
Desserrer le boulon de poulie de tension (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Diminuer la tension de la courroie en desserrant le boulon de réglage de poulie de tension (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la courroie d&#39;entraînement de compresseur (3). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A722023.swf" width = "88.000mm" height = "57.807mm" ver = "08" gw = "182" gh = "147"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7216037001">
<title>
Repose 
</title>
<s1>
<ptxt>
Reposer la courroie d’entraînement du compresseur.
</ptxt>
</s1>
<s1>
<ptxt>
Régler la tension de la courroie. 
<intxreftitleoff1 refid = "AFRAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
