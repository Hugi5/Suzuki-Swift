<s1>
<ptxt>
Emmancher le roulement gauche (2) à l&#39;aide de l&#39;outil spécial et d&#39;une presse hydraulique. 
</ptxt>
<servicetool>
<servicetoolitem id = "L5B024">
<s-part>
(A)
</s-part>
<s-number num = "09913-80113">
 09913-80113 
</s-number>
</servicetoolitem>
</servicetool>
