<s1>
<ptxt>
Reposer solidement un circlip neuf (1) sur la rainure. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Reposer le roulement à aiguilles (2), l&#39;enduire d&#39;huile, puis reposer la bague de synchroniseur (3) et le pignon de 4ème. 
</ptxt>
<figure>
<graphic graphicname = "I2RH01520052.swf" width = "88.000mm" height = "45.751mm" ver = "01" gw = "170" gh = "113"/>
