<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A7224025" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1544
</title>
<servinfosub id = "AFRAP70A7224025001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.118in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.087in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1544: données incorrectes entre le module de commande HVAC et le panneau A/C automatique 
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Le module de commande HVAC envoie un signal incorrect au panneau A/C automatique. 
</ptxt>
</item>
<item>
<ptxt>
Le module de commande HVAC reçoit un signal incorrect du panneau A/C automatique. 
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Panneau A/C automatique 
</ptxt>
</item>
<item>
<ptxt>
Module de commande HVAC 
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70A7224025002">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
Démarrer le moteur et activer le système A/C. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7224025003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A7224025004">
<testgroup id = "AFRAP70A7224025005">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34; et vérifier les DTC. 
</ptxt>
</test1>
<question>
Le DTC B1544 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le module de commande HVAC et/ou le panneau A/C automatique par un élément en bon état et vérifier à nouveau le DTC. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Module de commande HVAC: 
<intxreftitleoff1 refid = "AFRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Panneau A/C automatique: 
<intxreftitleoff1 refid = "AFRAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Problème intermittent. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
