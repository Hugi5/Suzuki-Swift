<servinfosub id = "AFRAP70A9B06021001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Percer les points de soudure et déposer le panneau arrière. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0108.jpg" width = "183.000mm" height = "228.447mm" ver = "04" gw = "492" gh = "631"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
