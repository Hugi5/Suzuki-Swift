<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Oeillet 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout-l>
</figure>
</s1>
<s1>
<ptxt>
Si nécessaire, déposer les ampoules. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9206008002">
<title>
Repose 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
