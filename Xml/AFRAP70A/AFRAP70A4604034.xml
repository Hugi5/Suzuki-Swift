<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A4604034" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1090/C1091/C1094 
</title>
<servinfosub id = "AFRAP70A4604034001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.780in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.399in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1090: Détection par l&#39;ECM d&#39;une défaillance du compteur de rotation du module de commande ESP<sup>&#174;</sup>
</emph>
</ptxt>
<ptxt>
Le module de commande ESP<sup>&#174;</sup> envoie des données CAN incorrectes à l&#39;ECM. 
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Circuit de communication CAN 
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Module de commande ESP<sup>&#174;</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1091: Données CAN incorrectes en provenance de l&#39;ECM 
</emph>
</ptxt>
<ptxt>
Détection d&#39;un DTC associé à l&#39;ECM. 
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1094: Etat de rejet de demande de couple
</emph>
</ptxt>
<ptxt>
Le module de commande ESP<sup>&#174;</sup> reçoit des données CAN incorrectes en provenance de l&#39;ECM (à propos de la commande de couple moteur). 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70A4604034002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A4604034003">
<testgroup id = "AFRAP70A4604034004">
<question>
La &#34;Vérification du système ESP<sup>&#174;</sup>&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A4604001">Vérification du système ESP&#174;</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604034005">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70A4604005">Vérification des DTC</intxref>
. 
</ptxt>
</test1>
<question>
Y a-t-il d&#39;autres DTC que C1090, C1091 ou C1094? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604034006">
<title>
Vérification des DTC de l&#39;ECM 
</title>
<test1>
<ptxt>
Rechercher un éventuel DTC dans l&#39;ECM. 
<intxreftitleoff1 refid = "AFRAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC U0073 ou U0121 est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à 
<intxref refid = "AFRAP70AA804004">Recherche de pannes pour le bus de communication OFF</intxref>
 ou 
<intxref refid = "AFRAP70AA804003">Recherche de pannes pour la perte de communication</intxref>
. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
