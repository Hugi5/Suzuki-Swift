<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du générateur 
</title>
<servinfosub id = "AFRAP70A1A06005001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le sabot droit de protection du moteur. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le tuyau d&#39;échappement n&#176; 1. 
<intxreftitleoff1 refid = "AFRAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la courroie d&#39;entraînement de pompe à eau/générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le câble (1) de la borne &#34;B&#34; et le connecteur (2) du générateur (3). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le générateur (3) et le retirer du compartiment moteur entre la traverse de suspension avant et l&#39;ensemble d&#39;arbre de roue avant. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1005.jpg" width = "88.000mm" height = "66.800mm" ver = "01" gw = "237" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1A06005002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer le boulon de générateur et le boulon de pivot de générateur au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T1J003">
<t-part>
 Boulon de générateur 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 25 
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1J004">
<t-part>
 Boulon du pivot de générateur 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
 45 
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Brancher le câble (1) au générateur comme indiqué sur la figure, puis serrer l&#39;écrou de la borne &#34;B&#34; au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T1J005">
<t-part>
 Ecrou de borne &#34;B&#34; 
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1A1006.jpg" width = "88.000mm" height = "61.151mm" ver = "02" gw = "237" gh = "157"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
