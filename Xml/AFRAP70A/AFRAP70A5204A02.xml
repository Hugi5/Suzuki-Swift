<servinfo servinfosgmlid = "AFRAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Passage difficile 
</title>
<diag type = "condition">
<condition>
<ptxt>
Passage difficile 
</ptxt>
</condition>
<ps>
<ptxt>
Lubrifiant inapproprié 
</ptxt>
</ps>
<action>
<ptxt>
Faire l&#39;appoint d&#39;huile de boîte-pont manuelle. 
</ptxt>
</action>
<ps>
<ptxt>
Course libre de pédale d&#39;embrayage 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le bras de pédale d&#39;embrayage ou le maître-cylindre d&#39;embrayage. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Bras de pédale d&#39;embrayage: 
<intxreftitleoff1 refid = "AFRAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Maître-cylindre d&#39;embrayage: 
<intxreftitleoff1 refid = "AFRAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Disque d&#39;embrayage déformé ou cassé 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le disque d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Plaque de pression d&#39;embrayage endommagée 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le couvercle d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Bague de synchroniseur usée 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer la bague de synchroniseur. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Bague de synchroniseur de rapport court et bague de synchroniseur de 2ème: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bague de synchroniseur de rapport haut: 
<intxreftitleoff1 refid = "AFRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bague de synchroniseur de 5ème: 
<intxreftitleoff1 refid = "AFRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Dent chanfreinée du manchon ou du pignon usée 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le manchon, le moyeu et le pignon de synchroniseur. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Pignon de 1ère et pignon de 2ème d&#39;arbre intermédiaire: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pignon de 3ème et pignon de 4ème d&#39;arbre d&#39;entrée: 
<intxreftitleoff1 refid = "AFRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pignon de 5ème d&#39;arbre d&#39;entrée: 
<intxreftitleoff1 refid = "AFRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manchon et moyeu de synchroniseur de rapport court: 
<intxreftitleoff1 refid = "AFRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manchon et moyeu de synchroniseur de rapport haut: 
<intxreftitleoff1 refid = "AFRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manchon et moyeu de synchroniseur de 5ème: 
<intxreftitleoff1 refid = "AFRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Douille de joint d&#39;axe de commande de changement de vitesses usée 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer la douille de joint d&#39;axe de commande de changement de vitesses. 
<intxreftitleoff1 refid = "AFRAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Axe de changement de vitesses déformé 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer la fourchette ou l&#39;axe de changement de vitesses. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Arbre de changement de vitesses court: 
<intxreftitleoff1 refid = "AFRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Arbre de changement de vitesses de rapport haut: 
<intxreftitleoff1 refid = "AFRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Fourchette de changement de vitesses de 5ème: 
<intxreftitleoff1 refid = "AFRAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Câbles de commande de changement de vitesses/sélection rompus 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le câble de changement de vitesses et de sélection. 
<intxreftitleoff1 refid = "AFRAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
