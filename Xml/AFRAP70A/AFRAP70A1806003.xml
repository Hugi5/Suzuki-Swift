<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1806003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;ensemble de bobine d&#39;allumage 
</title>
<servinfosub id = "AFRAP70A1806003001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;ensemble de filtre à air. 
<intxreftitleoff1 refid = "AFRAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher les connecteurs de bobine d&#39;allumage. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les boulons de bobine d&#39;allumage (1) puis extraire les ensembles de bobine d&#39;allumage (2). 
</ptxt>
<figure>
<graphic graphicname = "I7V20A180004.swf" width = "88.000mm" height = "54.310mm" ver = "01" gw = "212" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1806003002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1806004">Vérification de l&#39;ensemble de bobine d&#39;allumage</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose en notant le point suivant. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer le boulon de bobine d&#39;allumage au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T1H002">
<t-part>
 Boulon de bobine d&#39;allumage 
</t-part>
<t-value1>
 11 
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
