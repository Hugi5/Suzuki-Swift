<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A1104059" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P2228/P2229 
</title>
<servinfosub id = "AFRAP70A1104059001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.143in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.027in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P2228: Entrée faible du circuit &#34;A&#34; de capteur de pression barométrique 
</emph>
</ptxt>
<ptxt>
La tension de sortie du signal de capteur de pression barométrique est inférieure à 0,2 V pendant 5 s
</ptxt>
<ptxt>
(logique de détection sur 3 D/C) 
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Capteur de pression barométrique dans l&#39;ECM 
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P2229: Entrée élevée du circuit &#34;A&#34; de capteur de pression barométrique 
</emph>
</ptxt>
<ptxt>
La tension de sortie du signal de capteur de pression barométrique est supérieure à 4,8 V pendant 5 s
</ptxt>
<ptxt>
(logique de détection sur 3 D/C) 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70A1104059002">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34; pendant 10 s
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1104059003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A1104059004">
<testgroup id = "AFRAP70A1104059005">
<question>
La procédure de &#34;Vérification du système de commande du moteur et des émissions&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A1104001">Vérification du système de régulation des émissions et de commande du moteur</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1104059006">
<title>
Vérification du circuit d&#39;alimentation électrique et de mise à la masse de l&#39;ECM 
</title>
<test1>
<ptxt>
Vérifier les circuits d&#39;alimentation électrique et de mise à la masse de l&#39;ECM. 
<intxreftitleoff1 refid = "AFRAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ECM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer les circuits d&#39;alimentation électrique et de mise à la masse de l&#39;ECM. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
