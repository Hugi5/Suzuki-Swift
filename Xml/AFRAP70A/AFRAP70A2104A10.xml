<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A2104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Pneus bombés 
</title>
<diag type = "condition">
<condition>
<ptxt>
Pneus bombés 
</ptxt>
</condition>
<ps>
<ptxt>
Géométrie des roues déréglée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et régler la géométrie des roues. 
<intxreftitleoff1 refid = "AFRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ensemble de jambe avant défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de jambe avant. 
<intxreftitleoff1 refid = "AFRAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Roulements de roue usés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les roulements de roue. 
<intxreftitleoff1 refid = "AFRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ovalisation excessive du pneu ou de la roue 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le pneu et/ou la roue. 
</ptxt>
</action>
<ps>
<ptxt>
Joints de bras de suspension usés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le bras de suspension. 
<intxreftitleoff1 refid = "AFRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Balourd de la roue 
</ptxt>
</ps>
<action>
<ptxt>
Régler l&#39;équilibre ou remplacer le pneu. 
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
