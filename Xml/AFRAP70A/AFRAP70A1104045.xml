<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A1104045" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0606
</title>
<servinfosub id = "AFRAP70A1104045001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.289in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.901in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0606: Processeur de module de commande 
</emph>
</ptxt>
<ptxt>
Dysfonctionnement du processeur interne de l&#39;ECM. 
</ptxt>
<ptxt>
(logique de détection sur 3 D/C) 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Circuits d&#39;alimentation électrique et/ou de masse de l&#39;ECM 
</ptxt>
</item>
<item>
<ptxt>
Capteur A/F 
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70A1104045002">
<title>
Description du système 
</title>
<ptxt>
Le module de commande interne est situé dans l&#39;ECM. 
</ptxt>
</servinfosub>
<servinfosub id = "AFRAP70A1104045003">
<title>
Procédure de confirmation de DTC 
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Veiller à solutionner tout d&#39;abord les DTC imprévus détectés auparavant au cours de la &#34;Procédure de confirmation des DTC&#34;. 
</ptxt>
</item>
<item>
<ptxt>
S&#39;assurer que les conditions suivantes sont réunies dans le cadre de cette &#34;Procédure de confirmation des DTC&#34;. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tension de batterie &#62; 10,7 V
</ptxt>
</item>
<item>
<ptxt>
DTC P0030, P0031, P0032, P0131 ou P0132 non détecté. 
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Faire tourner le moteur au ralenti pendant 1 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1104045004">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A1104045005">
<testgroup id = "AFRAP70A1104045006">
<title>
Nouvelle vérification de DTC 
</title>
<test1>
<ptxt>
Effacer le DTC. 
<intxreftitleoff1 refid = "AFRAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Effectuer la procédure de confirmation des DTC et vérifier les DTC. 
</ptxt>
</test1>
<question>
Le DTC P0606 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vérifier les pannes intermittentes. 
<intxreftitleoff1 refid = "AFRAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1104045007">
<title>
Vérification du circuit d&#39;alimentation électrique et de mise à la masse de l&#39;ECM 
</title>
<test1>
<ptxt>
Vérifier les circuits d&#39;alimentation électrique et de mise à la masse de l&#39;ECM. 
<intxreftitleoff1 refid = "AFRAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux.
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1104045008">
<title>
Nouvelle vérification de DTC 
</title>
<test1>
<ptxt>
Remplacer le capteur A/F. 
<intxreftitleoff1 refid = "AFRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Effectuer la procédure de confirmation des DTC et vérifier les DTC. 
</ptxt>
</test1>
<question>
Le DTC P0606 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ECM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
