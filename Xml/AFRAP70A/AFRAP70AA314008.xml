<title>
DTC P1622
</title>
<servinfosub id = "AFRAP70AA314008001">
<title>
Condition de détection du DTC et organe incriminé	 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1622: Erreur d&#39;écriture / lecture EEPROM 
</emph>
</ptxt>
<ptxt>
L&#39;EEPROM dans l&#39;ECM est corrompu. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
ECM
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70AA314008002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA314008003">
<testgroup id = "AFRAP70AA314008004">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC P1622 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ECM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
</testgroup>
