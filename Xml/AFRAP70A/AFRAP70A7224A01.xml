<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A7224A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Le moteur de soufflante ne fonctionne pas 
</title>
<diag type = "condition">
<condition>
<ptxt>
Le moteur de soufflante ne fonctionne pas 
</ptxt>
</condition>
<ps>
<ptxt>
Fusible grillé 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier les fusibles concernés puis rechercher un éventuel court-circuit à la masse. 
</ptxt>
</action>
<ps>
<ptxt>
Dispositif de commande de moteur de soufflante défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le dispositif de commande de moteur de soufflante. 
<intxreftitleoff1 refid = "AFRAP70A7226014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Module de commande HVAC défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le module de commande HVAC. 
<intxreftitleoff1 refid = "AFRAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Câblage ou mise à la masse défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer le câblage. 
</ptxt>
</action>
<ps>
<ptxt>
Moteur de soufflante défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le moteur de soufflante. 
<intxreftitleoff1 refid = "AFRAP70A7226014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Relais de moteur de soufflante défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le relais de moteur de soufflante. 
<intxreftitleoff1 refid = "AFRAP70A7226042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Panneau A/C automatique défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le système A/C automatique. 
<intxreftitleoff1 refid = "AFRAP70A7224037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
