<testgroup id = "AFRAP70AA314020004">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Effacer le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA314004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1190 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande de dispositif antidémarrage et revérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA316001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
