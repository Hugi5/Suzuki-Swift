<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1306017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du capteur CMP 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1306016">Vérification sur véhicule du capteur CMP</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A1306017001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur du capteur CMP d&#39;admission (1) et du capteur CMP d&#39;échappement (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le capteur CMP d&#39;admission (1) et le capteur CMP d&#39;échappement (2) de la culasse. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A131006.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1306017002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1306018">Vérification du capteur CMP</intxrefpoff>
</ptxt>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Appliquer de l&#39;huile moteur sur le joint torique de capteur. 
</ptxt>
</item>
<item>
<ptxt>
Serrer le boulon de capteur CMP au couple prescrit. 
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Veiller à utiliser des boulons neufs pré-enduits d&#39;adhésif. Dans le cas contraire, les boulons risquent de se desserrer. 
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1C005">
<t-part>
 Boulon de capteur CMP d&#39;admission 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 11 
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1C006">
<t-part>
 Boulon de capteur CMP d&#39;échappement 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
 11 
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131007.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
