<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1306019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du capteur CKP 
</title>
<servinfosub id = "AFRAP70A1306019001" page = "2">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur du capteur CKP. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le capteur CKP (1) du bloc-cylindres. 
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A131017.jpg" width = "88.000mm" height = "57.392mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</servinfosub>
<servinfosub id = "AFRAP70A1306019002" page = "2">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1306020">Vérification du capteur CKP</intxrefpoff>
</ptxt>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Appliquer de l&#39;huile moteur sur le joint torique de capteur. 
</ptxt>
</item>
<item>
<ptxt>
Serrer le boulon du capteur CKP au couple spécifié. 
</ptxt>
<attention2>
<ptxt>
Veiller à utiliser des boulons neufs pré-enduits d&#39;adhésif. Dans le cas contraire, les boulons risquent de se desserrer. 
</ptxt>
</attention2>
<torque>
<torqueitem id = "T1C007">
<t-part>
 Boulon du capteur CKP 
</t-part>
<t-value1>
 11 
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131008.jpg" width = "88.000mm" height = "57.393mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</item>
<item>
<ptxt>
Brancher le connecteur et fixer correctement le faisceau de câbles avec une attache. 
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
