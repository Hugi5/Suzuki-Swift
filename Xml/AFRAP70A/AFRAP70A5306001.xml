<servinfo servinfosgmlid = "AFRAP70A5306001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du contacteur CPP n&#176; 1 (si le véhicule en est équipé) 
</title>
<servinfosub id = "AFRAP70A5306001001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le connecteur de contacteur CPP n&#176; 1 (1) avec l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le contacteur CPP n&#176; 1 (1) du support de pédale d&#39;embrayage. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A531003.swf" width = "88.000mm" height = "79.324mm" ver = "01" gw = "104" gh = "208"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A5306001002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A5306002">Vérification et réglage du contacteur CPP n&#176; 1 (si le véhicule en est équipé)</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Reposer le contacteur CPP n&#176; 1 sur le support de pédale d&#39;embrayage. 
</ptxt>
</s1>
<s1>
<ptxt>
Régler la position du contacteur. 
<intxreftitleoff1 refid = "AFRAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Brancher correctement le connecteur sur le contacteur CPP n&#176; 1. 
</ptxt>
</s1>
</servinfosub>
