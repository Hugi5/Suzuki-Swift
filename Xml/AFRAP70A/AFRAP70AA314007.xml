</servinfosub>
<servinfosub id = "AFRAP70AA314007002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA314007003">
<testgroup id = "AFRAP70AA314007004">
<title>
Enregistrement de l&#39;ECM 
</title>
<test1>
<ptxt>
Effectuer 	 
<intxref refid = "AFRAP70AA316003">Enregistrement de l&#39;ECM:Modèle à contacteur d&#39;allumage</intxref>
 . 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC P1611 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer l&#39;ECM et vérifier à nouveau les DTC. Si le DTC P1611 est toujours détecté, remplacer le BCM et vérifier à nouveau le DTC. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "AFRAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (l&#39;ECM n&#39;a pas été enregistré) 
</ptxt>
</action>
</testgroup>
</diag>
