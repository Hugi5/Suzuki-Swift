<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A7216032" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du filtre à air HVAC 
</title>
<servinfosub id = "AFRAP70A7216032001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer la boîte à gants. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le couvercle de filtre à air HVAC (2) de l&#39;unité HVAC. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le filtre à air (1) de l&#39;unité HVAC. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A721033.swf" width = "88.000mm" height = "53.307mm" ver = "01" gw = "219" gh = "135"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7216032002">
<title>
Repose 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose en tenant compte des points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Positionner le filtre à air en orientant son repère fléché vers le haut (1). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A721034.swf" width = "88.000mm" height = "48.728mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
