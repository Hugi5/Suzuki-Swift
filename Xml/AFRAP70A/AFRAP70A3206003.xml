<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A3206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Démontage et remontage de l&#39;ensemble de différentiel arrière 
</title>
<servinfosub id = "AFRAP70A3206003001">
<title>
Démontage 
</title>
<s1>
<ptxt>
Soulever le véhicule et déposer les roues. 
</ptxt>
</s1>
<s1>
<ptxt>
Vidanger l&#39;huile du différentiel arrière, si nécessaire. 
<intxreftitleoff1 refid = "AFRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les arbres de roue arrière. 
<intxreftitleoff1 refid = "AFRAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 . 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;arbre de transmission du différentiel arrière. 
<intxreftitleoff1 refid = "AFRAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 . 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la durite de reniflard (1) du différentiel arrière. 
</ptxt>
</s1>
<s1>
<ptxt>
Placer le cric de sorte que l&#39;ensemble de différentiel ne s&#39;incline pas. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les boulons de bras avant de différentiel (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le boulon de fixation arrière de différentiel (3). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A320007.swf" width = "88.000mm" height = "57.146mm" ver = "02" gw = "186" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Baisser le cric et le différentiel arrière. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A3206003002">
<title>
Remontage 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse du démontage en tenant compte des points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer chaque boulon au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T3B004">
<t-part>
 Boulon de bras avant de différentiel 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 50 
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
<torqueitem id = "T3B005">
<t-part>
 Boulon de fixation arrière de différentiel 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
 80 
</t-value1>
<t-value2>
8,2
</t-value2>
<t-value3>
59,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320008.swf" width = "88.000mm" height = "52.572mm" ver = "02" gw = "186" gh = "133"/>
</figure>
</item>
<item>
<ptxt>
Remplir d&#39;huile le différentiel arrière s&#39;il a été vidangé, 
<intxreftitleoff1 refid = "AFRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
