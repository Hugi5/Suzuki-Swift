<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1A06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de la courroie d&#39;entraînement de générateur / de pompe à eau 
</title>
<servinfosub id = "AFRAP70A1A06004001" page = "2">
<title>
Dépose 
</title>
<s1 page = "2">
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le sabot droit de protection du moteur. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Déposer la courroie d&#39;entraînement de compresseur avant de déposer la courroie d&#39;entraînement de générateur / de pompe à eau (1). 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modèle avec A/C manuelle: 
<intxreftitleoff1 refid = "AFRAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modèle à A/C automatique: 
<intxreftitleoff1 refid = "AFRAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Desserrer le boulon de générateur (2) et le boulon de pivot de générateur (3). 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Desserrer le boulon de réglage de générateur (4) puis déposer la courroie d&#39;entraînement de générateur / de pompe à eau. 
</ptxt>
<figure>
<graphic graphicname = "I7V20A1A1008.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "148" gh = "123"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1A06004002" page = "2">
<title>
repose 
</title>
<s1 page = "2">
<ptxt>
Poser la courroie d&#39;entraînement de générateur / de pompe à eau (1) sur la poulie de pompe à eau (2), la poulie de vilebrequin (3) et la poulie de générateur (4). 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Régler la tension de la courroie. 
<intxreftitleoff1 refid = "AFRAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Poser la courroie d&#39;entraînement de compresseur. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modèle avec A/C manuelle: 
<intxreftitleoff1 refid = "AFRAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modèle à A/C automatique: 
<intxreftitleoff1 refid = "AFRAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
S&#39;assurer que la courroie d&#39;entraînement est bien logée dans les gorges de chaque poulie. 
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I7V20A1A1009.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "140" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Reposer le sabot droit de protection du moteur. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Brancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
