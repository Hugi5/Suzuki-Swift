<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A1704001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Vérification du système de carburant 
</title>
<diag type = "test" id = "AFRAP70A1704001001">
<testgroup id = "AFRAP70A1704001002">
<title>
Vérification de la pompe à carburant 
</title>
<test1>
<ptxt>
Déposer le bouchon de remplissage de carburant et mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Confirmer que le bruit de fonctionnement de la pompe à carburant peut être audible depuis l&#39;orifice de remplissage pendant environ 2 secondes avant de disparaître. 
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vérifier le circuit de pompe à carburant. 
<intxreftitleoff1 refid = "AFRAP70A1704004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1704001003">
<title>
Vérification de la pression de carburant 
</title>
<test1>
<ptxt>
Vérifier la pression de carburant. 
<intxreftitleoff1 refid = "AFRAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer la pièce défectueuse. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1704001004">
<title>
Test d&#39;équilibrage d&#39;alimentation électrique 
</title>
<test1>
<ptxt>
Vérifier l&#39;équilibrage d&#39;alimentation électrique. 
<intxreftitleoff1 refid = "AFRAP70A1704002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Le système de carburant est en bon état. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1704001005">
<title>
Vérification du circuit de l&#39;injecteur de carburant 
</title>
<test1>
<ptxt>
Vérifier le circuit d&#39;injecteur de carburant. 
<intxreftitleoff1 refid = "AFRAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer la pièce défectueuse. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A1704001006">
<title>
Vérification de l&#39;injecteur de carburant 
</title>
<test1>
<ptxt>
Vérifier l&#39;injecteur de carburant. 
<intxreftitleoff1 refid = "AFRAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le résultat de la vérification est-il satisfaisant? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ECM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer l&#39;injecteur de carburant. 
<intxreftitleoff1 refid = "AFRAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
