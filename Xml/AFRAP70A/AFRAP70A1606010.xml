<servinfo servinfosgmlid = "AFRAP70A1606010" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Vérification sur véhicule de l&#39;ensemble de ventilateur de refroidissement de radiateur 
</title>
<servinfosub id = "AFRAP70A1606010001">
<title>
Fonctionnement du ventilateur de refroidissement de radiateur 
</title>
<s1>
<ptxt>
Brancher l&#39;outil de balayage sur le DLC (1) avec l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
<servicetool>
<servicetoolitem id = "L1F001">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
Dispositif de balayage SUZUKI (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60AA20006.jpg" width = "88.000mm" height = "67.502mm" ver = "01" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34; et effacer les DTC. 
<intxreftitleoff1 refid = "AFRAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sélectionner la fonction &#34;Radiator Fan&#34; (ventilateur de radiateur) en mode &#34;Test actif&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Vérifier le fonctionnement à vitesse faible et rapide du ventilateur de refroidissement de radiateur. 
</ptxt>
<ptxt>
En cas d&#39;anomalie, vérifier le système de commande de ventilateur de refroidissement. 
<intxreftitleoff1 refid = "AFRAP70A1604002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<spec>
<title>
Fonctionnement du ventilateur de refroidissement de radiateur 
</title>
