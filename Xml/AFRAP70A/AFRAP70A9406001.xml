<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9406001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de la pompe et du réservoir de lave-glace 
</title>
<servinfosub id = "AFRAP70A9406001001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer le pare-chocs avant. 
<intxreftitleoff1 refid = "AFRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher les attaches de faisceau de câbles (1), les connecteurs de pompe de lave-glace (2) et les durites de lave-glace (3). 
</ptxt>
<figure>
<graphic graphicname = "IAP70P940004.jpg" width = "88.000mm" height = "67.662mm" ver = "01" gw = "209" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer les boulons de réservoir de lave-glace (1) et déposer le réservoir de lave-glace (2). 
</ptxt>
<figure>
<graphic graphicname = "IAP70P940005.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "180" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Extraire la pompe de lave-glace avant (1) et la pompe de lave-glace arrière (2) dans le sens de la flèche pour les déposer du réservoir de lave-glace (3). 
</ptxt>
<figure>
<graphic graphicname = "IAP70P940006.jpg" width = "88.000mm" height = "62.134mm" ver = "01" gw = "161" gh = "160"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9406001002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9406002">Vérification de la pompe de lave-glace</intxrefpoff>
</ptxt>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les boulons du réservoir de lave-glace au couple prescrit. 
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9D001">
<t-part>
 Boulon de réservoir de lave-glace 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A940008.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "201" gh = "174"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
