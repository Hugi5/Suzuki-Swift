<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Usure excessive du pneu 
</title>
<diag type = "condition">
<condition>
<ptxt>
Usure excessive du pneu 
</ptxt>
</condition>
<ps>
<ptxt>
Ressorts hélicoïdaux cassés ou détendus 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Remplacer les ressorts hélicoïdaux. 
</ptxt>
<ptxt>
Avant: 
<intxreftitleoff1 refid = "AFRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Arrière: 
<intxreftitleoff1 refid = "AFRAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Balourd de la roue 
</ptxt>
</ps>
<action>
<ptxt>
Régler l&#39;équilibre ou remplacer le pneu. 
</ptxt>
</action>
<ps>
<ptxt>
Géométrie des roues déréglée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et régler la géométrie des roues. 
<intxreftitleoff1 refid = "AFRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ensemble de jambe avant défectueux (amortisseur) 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de jambe avant (amortisseur). 
<intxreftitleoff1 refid = "AFRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Conduite dure 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les pneus. 
<intxreftitleoff1 refid = "AFRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Véhicule surchargé 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier la charge. 
</ptxt>
</action>
<ps>
<ptxt>
Pas de permutation des pneus 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer ou permuter les pneus. 
</ptxt>
</action>
<ps>
<ptxt>
Roulement de roue usé ou desserré 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le roulement de roue. 
<intxreftitleoff1 refid = "AFRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Oscillation niveau de la roue ou du pneu 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer la roue ou le pneu. 
</ptxt>
</action>
<ps>
<ptxt>
Gonflage des pneus inadéquat 
</ptxt>
</ps>
<action>
<ptxt>
Régler la pression des pneus. 
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
