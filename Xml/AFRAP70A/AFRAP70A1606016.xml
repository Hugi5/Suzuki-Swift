<title>
Dépose et repose de la pompe à eau 
</title>
<servinfosub id = "AFRAP70A1606016001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Vidanger le liquide de refroidissement. 
<intxreftitleoff1 refid = "AFRAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la courroie d&#39;entraînement de pompe à eau/générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la poulie de pompe à eau (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;ensemble de pompe à eau (1) avec le support de générateur (3). 
</ptxt>
<figure>
<graphic graphicname = "I7V20A161014.swf" width = "88.000mm" height = "66.198mm" ver = "01" gw = "211" gh = "171"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AFRAP70A1606016002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1606017">Vérification de la pompe à eau</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Appliquer du produit d&#39;étanchéité sur la surface de contact de la pompe à eau, comme indiqué sur le schéma. 
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1F001" uid = "41">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Produit d&#39;étanchéité
</m-desc>
<m-number>
 99000-31250 
</m-number>
<m-name>
SUZUKI Bond No.1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I7V20A161015.swf" width = "88.000mm" height = "43.075mm" ver = "01" gw = "184" gh = "106"/>
