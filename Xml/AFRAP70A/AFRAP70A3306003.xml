<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A3306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Démontage et remontage de la boîte de transfert 
</title>
<servinfosub id = "AFRAP70A3306003001">
<title>
Démontage 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Vidanger les huiles suivantes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Huile de boîte-pont manuelle: 
<intxreftitleoff1 refid = "AFRAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Huile de boîte de transfert: 
<intxreftitleoff1 refid = "AFRAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Déposer l&#39;ensemble d&#39;arbre de roue côté droit. 
<intxreftitleoff1 refid = "AFRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;arbre de transmission. 
<intxreftitleoff1 refid = "AFRAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le berceau de suspension avant. 
<intxreftitleoff1 refid = "AFRAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la fixation arrière de moteur et le support de fixation arrière de moteur. 
<intxreftitleoff1 refid = "AFRAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les boulons de raidisseur de boîte de transfert (2) et de boîte de transfert. 
</ptxt>
</s1>
<s1>
<ptxt>
Séparer la boîte de transfert (1) de la boîte-pont. 
</ptxt>
<attention1>
<ptxt>
Lors de la dépose de la boîte de transfert, veillez à ne pas la faire tomber. Cela pourrait entraîner des dégâts sur la boîte de transfert ou des blessures. 
</ptxt>
</attention1>
<figure>
<graphic graphicname = "IAP70A330004.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "213" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer le joint torique (1) et la goupille de positionnement (2). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A330005.jpg" width = "88.000mm" height = "52.680mm" ver = "01" gw = "213" gh = "133"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AFRAP70A3306003002">
<title>
Remontage 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse du démontage en tenant compte des points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utiliser un joint torique et un écrou d&#39;arbre de roue neufs. 
</ptxt>
</item>
<item>
<ptxt>
Appliquer de la graisse sur le joint torique (1). 
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C004" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Graisse
</m-desc>
<m-number>
 99000-25011 
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A330006.jpg" width = "88.000mm" height = "50.958mm" ver = "02" gw = "213" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Serrer les boulons de boîte de transfert au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T3C004">
<t-part>
 Boulon de boîte de transfert 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 88 
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Serrer les boulons de raidisseur de boîte de transfert comme suit. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Serrer les boulons de raidisseur de boîte de transfert &#34;2&#34; et &#34;3&#34; à la main. 
</ptxt>
</item>
<item>
<ptxt>
Enfoncer le raidisseur de boîte de transfert sur la boîte de transfert, puis serrer les boulons de raidisseur de boîte de transfert au couple prescrit dans l&#39;ordre numérique (&#34;1&#34; – &#34;5&#34;), régulièrement et progressivement. 
</ptxt>
<torque>
<torqueitem id = "T3C005">
<t-part>
 Boulon de raidisseur de boîte de transfert* 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
 55 
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330007.jpg" width = "88.000mm" height = "56.283mm" ver = "01" gw = "213" gh = "143"/>
</figure>
<figure>
<graphic graphicname = "IAP70A330008.jpg" width = "88.000mm" height = "55.083mm" ver = "01" gw = "202" gh = "140"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Serrer les boulons et les écrous suivants au couple spécifié. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Boulon de fixation arrière du moteur et boulon de support: 
<intxreftitleoff1 refid = "AFRAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Boulon de fixation de cadre de suspension avant: 
<intxreftitleoff1 refid = "AFRAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Veiller à utiliser un boulon de fixation de berceau de suspension neuf. 
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Ecrou de joint de barre stabilisatrice: 
<intxreftitleoff1 refid = "AFRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Boulon de joint à rotule de bras de suspension: 
<intxreftitleoff1 refid = "AFRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ecrou d&#39;embout de barre d&#39;accouplement: 
<intxreftitleoff1 refid = "AFRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Boulon de capteur de vitesse de roue avant: 
<intxreftitleoff1 refid = "AFRAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Boulon d&#39;arbre de transmission: 
<intxreftitleoff1 refid = "AFRAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ecrou de support central: 
<intxreftitleoff1 refid = "AFRAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Boulon de tuyau d&#39;échappement: 
<intxreftitleoff1 refid = "AFRAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Boulon de raidisseur de tuyau d&#39;échappement n&#176; 1: 
<intxreftitleoff1 refid = "AFRAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ecrou d&#39;arbre de roue: 
<intxreftitleoff1 refid = "AFRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Veiller à utiliser un écrou d&#39;arbre de roue neuf. 
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Ecrou de roue: 
<intxreftitleoff1 refid = "AFRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Mater l&#39;écrou d&#39;arbre de roue. 
<intxreftitleoff1 refid = "AFRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Faire l&#39;appoint des huiles suivantes. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Huile de boîte-pont manuelle: 
<intxreftitleoff1 refid = "AFRAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
	Huile de boîte de transfert: 
<intxreftitleoff1 refid = "AFRAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
S&#39;assurer de l&#39;absence de fuites d&#39;huile et de gaz d&#39;échappement au niveau de chaque raccord. 
</ptxt>
</item>
<item>
<ptxt>
Vérifier la géométrie des roues avant. 
<intxreftitleoff1 refid = "AFRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
