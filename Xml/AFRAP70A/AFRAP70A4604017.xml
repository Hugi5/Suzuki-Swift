<servinfosub id = "AFRAP70A4604017003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A4604017004">
<testgroup id = "AFRAP70A4604017005">
<question>
La &#34;Vérification du système ESP<sup>&#174;</sup>&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A4604001">Vérification du système ESP&#174;</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604017006">
<title>
Vérification des DTC de l&#39;ESP&#174;
</title>
<test1>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70A4604005">Vérification des DTC</intxref>
. 
</ptxt>
</test1>
<question>
Les DTC U0073 et/ou U0100 sont-il détectés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604017007">
<title>
Vérification du circuit et du contacteur de feux stop 
</title>
<test1>
<ptxt>
Vérifier le contacteur de feux stop et son circuit en se reportant aux étapes 2 à 4 du point 
<intxref refid = "AFRAP70A1104040">DTC P0504</intxref>
. 
</ptxt>
</test1>
<question>
Les résultats de la vérification sont-ils corrects? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer. 
</ptxt>
</action>
</testgroup>
