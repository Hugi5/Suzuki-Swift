<servinfo servinfosgmlid = "AFRAP70A9206012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;éclairage de compartiment à bagages 
</title>
<servinfosub id = "AFRAP70A9206012001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer l&#39;éclairage de compartiment à bagages (1) en le tirant dans le sens de la flèche tout en libérant le verrouillage (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur de l&#39;éclairage de compartiment à bagages. 
</ptxt>
</s1>
<s1>
<ptxt>
Si nécessaire, déposer l&#39;ampoule (3). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A920016.jpg" width = "88.000mm" height = "62.981mm" ver = "04" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9206012002">
<title>
Repose 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
