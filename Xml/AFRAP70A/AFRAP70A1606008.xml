<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1606008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;ensemble de thermostat (intégré au capteur ECT) 
</title>
<servinfosub id = "AFRAP70A1606008001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Vidanger le liquide de refroidissement. 
<intxreftitleoff1 refid = "AFRAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le capteur CMP d&#39;échappement. 
<intxreftitleoff1 refid = "AFRAP70A1306017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur de capteur ECT. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la durite d&#39;entrée de radiateur (2) et la durite d&#39;entrée de chauffage (3) de l&#39;ensemble de thermostat (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;ensemble de thermostat (1) de la culasse. 
</ptxt>
<figure>
<graphic graphicname = "IAP70P160003.swf" width = "88.000mm" height = "50.065mm" ver = "01" gw = "181" gh = "125"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1606008002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utiliser un joint d&#39;étanchéité neuf. 
</ptxt>
</item>
<item>
<ptxt>
Remplir le système de refroidissement de liquide de refroidissement. 
<intxreftitleoff1 refid = "AFRAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rechercher d&#39;éventuelles fuites au niveau du système de refroidissement. 
<intxreftitleoff1 refid = "AFRAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rechercher d&#39;éventuelles fuites d&#39;huile au niveau du capteur CMP d&#39;échappement. 
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
