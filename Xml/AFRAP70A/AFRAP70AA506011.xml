<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70AA506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du récepteur d&#39;ouverture sans clé 
</title>
<servinfosub id = "AFRAP70AA506011001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le boîtier de console centrale. 
<intxreftitleoff1 refid = "AFRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur de récepteur d&#39;ouverture sans clé (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la vis (3), puis déposer le récepteur d&#39;ouverture sans clé (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50030.swf" width = "88.000mm" height = "77.203mm" ver = "01" gw = "202" gh = "202"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA506011002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70AA506012">Vérification du récepteur d&#39;ouverture sans clé</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
