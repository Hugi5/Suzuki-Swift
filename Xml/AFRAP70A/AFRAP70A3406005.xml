<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A3406005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Démontage et remontage de l&#39;accouplement 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A3406004">Démontage et remontage de l&#39;ensemble d&#39;arbre de transmission</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A3406005001">
<title>
Démontage 
</title>
<s1>
<ptxt>
Déposer le circlip de l&#39;arbre d&#39;accouplement à l&#39;aide d&#39;une pince pour anneau élastique. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le viscocoupleur (1) de l&#39;arbre d&#39;accouplement (2) à l&#39;aide d&#39;une presse hydraulique (3) et d&#39;un extracteur (4). 
</ptxt>
<figure>
<graphic graphicname = "I5RS0D340007.swf" width = "88.000mm" height = "49.401mm" ver = "01" gw = "114" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A3406005002">
<title>
Remontage 
</title>
<s1>
<ptxt>
Reposer le viscocoupleur (1) sur l&#39;arbre d&#39;accouplement (2) à l&#39;aide d&#39;un outil spécial et d&#39;une presse hydraulique. 
</ptxt>
<servicetool>
<servicetoolitem id = "L3D001">
<s-part>
(A)
</s-part>
<s-number num = "09922-55131">
 09922-55131 
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A340010.swf" width = "88.000mm" height = "50.636mm" ver = "01" gw = "94" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Poser un nouveau circlip sur l&#39;arbre central à l&#39;aide d&#39;une pince pour anneau élastique. 
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
