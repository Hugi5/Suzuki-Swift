<servinfo servinfosgmlid = "AFRAP70A1406020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose d&#39;OCV 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1406017">Pièces constitutives du carter de chaîne de distribution</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A1406020001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déconnecter le connecteur OCV d&#39;admission (noir) (1) et le connecteur OCV d&#39;échappement (bleu) (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;OCV d&#39;admission (3), l&#39;OCV d&#39;échappement (4) du carter de chaîne de distribution. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A141060.jpg" width = "88.000mm" height = "58.155mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A1406020002">
<title>
Repose 
</title>
<ptxt>
Procéder à l&#39;inverse de la procédure de dépose en notant le point suivant: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les boulons OCV au couple prescrit. 
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1D013">
<t-part>
 Boulon d&#39;OCV 
</t-part>
<t-value1>
 11 
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
