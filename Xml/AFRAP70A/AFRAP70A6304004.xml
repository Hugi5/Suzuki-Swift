<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A6304004" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Suppression des DTC 
</title>
<s1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Brancher l&#39;outil de balayage SUZUKI sur le DLC (1) situé à proximité de la partie inférieure du tableau de bord côté siège du conducteur. 
</ptxt>
<servicetool>
<servicetoolitem id = "L6C002">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
Dispositif de balayage SUZUKI (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630006.jpg" width = "88.000mm" height = "67.502mm" ver = "03" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Effacer le code conformément aux instructions affichées par l&#39;outil de balayage SUZUKI. Pour plus de détails, se reporter au manuel d&#39;utilisation de l&#39;outil de balayage SUZUKI. 
</ptxt>
</s1>
<s1>
<ptxt>
Allumage en position &#34;OFF&#34;, débrancher l&#39;outil de balayage SUZUKI du DLC une fois l&#39;effacement terminé. 
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
