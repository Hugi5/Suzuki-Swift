<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "1">
<servinfo servinfosgmlid = "AFRAP70A9601004" svcinfotypenbr = "03" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Description du fonctionnement du verrouillage de porte électrique
</title>
<ptxt>
Le verrouillage / déverrouillage des portes est réalisé en actionnant les éléments indiqués dans le tableau suivant.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.883in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.763in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.602in"/>
<colspec colnum = "4" colname = "4" colwidth = "4.965in"/>
<thead>
<row rowsep = "1">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Elément
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Verrouillage de(s) porte(s) activé(s)
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry namest = "1" nameend = "3" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Dispositif de commande à distance ou émetteur
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Appuyer sur le bouton LOCK une fois et toutes les portes sont verrouillées
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Appuyer sur le bouton UNLOCK une fois et la porte du conducteur est déverrouillée
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Appuyer sur le bouton UNLOCK deux fois et toutes les portes sont déverrouillées
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Contacteur de demande de porte
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Fonctionnement
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Verrouiller
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Appuyer sur le contacteur de demande une fois et toutes les portes sont verrouillées
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "3" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Déverrouillage
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Appuyer sur le contacteur de demande une fois et toutes les portes utilisées sont déverrouillées
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Appuyer sur le contacteur de demande deux fois et toutes les portes sont déverrouillées
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Contacteur de serrure électrique de porte du conducteur
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Toutes les portes
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "3" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Barillet de serrure
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Tourner le barillet de serrure en position LOCK une fois et toutes les portes sont verrouillées
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Tourner le barillet de serrure en position UNLOCK une fois et la porte côté conducteur est déverrouillée
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Tourner le barillet de serrure en position UNLOCK deux fois et toutes les portes sont déverrouillées
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Levier de verrouillage de porte
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Actionne toutes les portes
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
