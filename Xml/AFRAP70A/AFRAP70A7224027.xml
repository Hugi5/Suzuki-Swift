<servinfosub id = "AFRAP70A7224027003">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
Démarrer le moteur et activer le système A/C. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7224027004">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A7224027005">
<testgroup id = "AFRAP70A7224027006">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34; et vérifier les DTC. 
</ptxt>
</test1>
<question>
Le DTC B1550-H ou B1550-L est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problème intermittent. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224027007">
<title>
Vérification du circuit de communication 
</title>
<test1>
<ptxt>
Débrancher les connecteurs &#34;G20&#34; et &#34;G227&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance du circuit de câble &#34;PNK/BLU&#34;: en dessous de 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance du circuit de câble &#34;PNK/BLU&#34; entre le panneau A/C automatique et la masse: infinie 
</ptxt>
</item>
</list1>
</test1>
<question>
Les valeurs de résistance sont-elles conformes aux spécifications? 
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le module de commande HVAC et/ou le panneau A/C automatique par un élément en bon état et vérifier à nouveau le DTC. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Module de commande HVAC: 
<intxreftitleoff1 refid = "AFRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Panneau A/C automatique: 
<intxreftitleoff1 refid = "AFRAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
