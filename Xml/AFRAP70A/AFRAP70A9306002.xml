<title>
Dépose et repose du klaxon 
</title>
<servinfosub id = "AFRAP70A9306002001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer le pare-chocs avant. 
<intxreftitleoff1 refid = "AFRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur de klaxon (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le boulon de klaxon (3) et déposer le klaxon (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A930022.jpg" width = "88.000mm" height = "63.673mm" ver = "02" gw = "195" gh = "164"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9306002002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9306003">Vérification du klaxon</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
