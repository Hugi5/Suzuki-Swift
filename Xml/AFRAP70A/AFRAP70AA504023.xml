<servinfosub id = "AFRAP70AA504023003">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ACC&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Répéter les étapes 1) à 3) à plusieurs reprises. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA504023004">
<title>
Recherche de pannes à partir de DTC 
</title>
<attention3>
<ptxt>
Ce DTC peut être détecté lorsque la batterie est déchargée ou la tension très faible. 
</ptxt>
</attention3>
<diag type = "test" id = "AFRAP70AA504023005">
<testgroup id = "AFRAP70AA504023012">
<title>
Vérification des paramètres 
</title>
<test1>
<ptxt>
Brancher l&#39;outil de balayage SUZUKI sur le DLC, allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le &#34;Relais d&#39;allumage 1&#34; affiché sur l&#39;outil de balayage SUZUKI. 
<intxreftitleoff1 refid = "AFRAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504023006">
<title>
Vérification du circuit d&#39;alimentation électrique de relais IG1 (côté contacteur) 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Déposer le relais IG1. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier que la tension entre la borne de circuit &#34;A2&#34; du connecteur de relais IG1 et la masse correspond à la tension de batterie. 
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux et le fusible &#34;IGN&#34;. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504023007">
<title>
Vérification du fusible 
</title>
<test1>
<ptxt>
Vérifier le fusible &#34;MTR&#34;. 
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504023008">
<title>
Vérification du circuit de signal de relais IG1 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement de borne sur le connecteur &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Si les branchements sont corrects, vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance entre le circuit &#34;B2&#34; et la masse: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;B2&#34; et chaque borne du connecteur de relais IG1: infinie 
</ptxt>
</item>
</list1>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le fusible &#34;MTR&#34;, le module de commande de démarrage sans clé et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux, puis remplacer le fusible &#34;MTR&#34;. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504023009">
<title>
Vérification du circuit de signal de relais IG1 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement de borne sur le connecteur &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Si les branchements sont corrects, vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance du circuit &#34;B2&#34;: en dessous de 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;B2&#34; et chaque borne du connecteur de relais IG1: infinie 
</ptxt>
</item>
<item>
<ptxt>
Tension du circuit &#34;B2&#34;: 0 – 1 V (lorsque l&#39;allumage est sur &#34;ON&#34;) 
</ptxt>
</item>
</list1>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 6. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504023010">
<title>
Vérification du circuit d&#39;alimentation électrique de relais IG1 (côté bobine) 
</title>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance du circuit &#34;C2&#34;: en dessous de 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance entre le circuit &#34;C2&#34; et la masse: infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre la borne du circuit &#34;C2&#34; et chaque borne du connecteur de relais IG1: infinie 
</ptxt>
</item>
<item>
<ptxt>
Tension du circuit &#34;C2&#34;: 0 – 1 V (lorsque l&#39;allumage est sur &#34;ON&#34;) 
</ptxt>
</item>
</list1>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 7. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504023011">
<title>
Vérification du relais IG1 
</title>
<test1>
<ptxt>
Vérifier le relais IG1. 
<intxreftitleoff1 refid = "AFRAP70AA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 8. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le relais IG1. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504023013">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Brancher le connecteur &#34;L10&#34; et reposer le relais IG1. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1192 actuel est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande de démarrage sans clé et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
</testgroup>
