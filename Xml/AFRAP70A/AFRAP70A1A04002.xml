<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A1A04002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Diagnostic des symptômes du générateur 
</title>
<ptxt>
Une anomalie du système de charge sera mise en évidence par une ou plusieurs des conditions suivantes. 
</ptxt>
<servinfosub id = "AFRAP70A1A04002001" page = "1">
<title>
Fonctionnement du témoin de charge 
</title>
<diag type = "condition" id = "AFRAP70A1A04002002">
<condition>
<ptxt>
Le témoin de charge ne s&#39;allume pas alors que l&#39;allumage est activé et le moteur coupé 
</ptxt>
</condition>
<ps>
<ptxt>
Fusible grillé 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le fusible. 
</ptxt>
</action>
<ps>
<ptxt>
Combiné d&#39;instruments défectueux 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Remplacer le combiné d&#39;instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM défectueux 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vérifier le BCM. 
</ptxt>
<ptxt>
Modèle à contacteur d&#39;allumage: 
<intxreftitleoff1 refid = "AFRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modèle à démarrage sans clé: 
<intxreftitleoff1 refid = "AFRAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Ligne de communication CAN défectueuse 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer la ligne de communication CAN. 
<intxreftitleoff1 refid = "AFRAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Câblage défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le câblage. 
</ptxt>
</action>
<ps>
<ptxt>
Régulateur IC ou bobine d&#39;induction défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Le témoin de charge ne s&#39;éteint pas alors que le moteur tourne (la batterie nécessite des recharges fréquentes) 
</ptxt>
</condition>
<ps>
<ptxt>
Courroie d&#39;entraînement détendue ou usée 
</ptxt>
</ps>
<action>
<ptxt>
Régler ou remplacer la courroie d&#39;entraînement. 
<intxreftitleoff1 refid = "AFRAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Combiné d&#39;instruments défectueux 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Remplacer le combiné d&#39;instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM défectueux 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vérifier le BCM. 
</ptxt>
<ptxt>
Modèle à contacteur d&#39;allumage: 
<intxreftitleoff1 refid = "AFRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modèle à démarrage sans clé: 
<intxreftitleoff1 refid = "AFRAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Régulateur IC ou générateur défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Câblage défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le câblage. 
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AFRAP70A1A04002003">
<title>
Echec de charge de la batterie 
</title>
<diag type = "condition" id = "AFRAP70A1A04002004">
<condition>
<ptxt>
Batterie déchargée 
</ptxt>
</condition>
<ps>
<ptxt>
Courroie d&#39;entraînement détendue ou usée 
</ptxt>
</ps>
<action>
<ptxt>
Régler ou remplacer la courroie d&#39;entraînement. 
<intxreftitleoff1 refid = "AFRAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Borne de batterie desserrée ou rouillée 
</ptxt>
</ps>
<action>
<ptxt>
Serrer la borne de batterie ou remplacer la batterie. 
<intxreftitleoff1 refid = "AFRAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Redresseur, rotor et/ou régulateur IC défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Batterie surchargée 
</ptxt>
</condition>
<ps>
<ptxt>
Régulateur IC défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AFRAP70A1A04002005">
<title>
Bruit 
</title>
<diag type = "condition" id = "AFRAP70A1A04002006">
<condition>
<ptxt>
Générateur bruyant 
</ptxt>
</condition>
<ps>
<ptxt>
Boulons de fixation desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Serrer les boulons de fixation. 
<intxreftitleoff1 refid = "AFRAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Roulements sales, usés et/ou défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rotor, diode et/ou stator défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le générateur. 
<intxreftitleoff1 refid = "AFRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
