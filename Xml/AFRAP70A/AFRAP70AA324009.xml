<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70AA324009" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1642 / P1646 
</title>
<servinfosub id = "AFRAP70AA324009001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.406in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.789in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1642: Erreur de ligne de communication de dispositif antidémarrage
</emph>
</ptxt>
<ptxt>
Erreur de communication avec le module de commande de démarrage sans clé. 
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Circuit / connecteur de communication CAN 
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Module de commande connecté à la ligne de communication CAN 
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Module de commande de démarrage sans clé 
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1646: Code ID incorrect 
</emph>
</ptxt>
<ptxt>
Erreur de communication CAN. 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70AA324009002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA324009003">
<testgroup id = "AFRAP70AA324009004">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Vérifier les DTC associés à la communication CAN. 
</ptxt>
</test1>
<question>
Un ou plusieurs DTC CAN sont-ils détectés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA324009005">
<title>
Vérification du circuit de communication CAN 
</title>
<test1>
<ptxt>
Vérifier le circuit de communication CAN en se reportant au point &#34;Procédure de diagnostic&#34; dans 
<intxref refid = "AFRAP70AA804004">Recherche de pannes pour le bus de communication OFF</intxref>
. 
</ptxt>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer l&#39;ECM et vérifier à nouveau les DTC. Si le DTC P1642 est toujours détecté, remplacer le module de commande de démarrage sans clé et vérifier à nouveau le DTC. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Module de commande de démarrage sans clé: 
<intxreftitleoff1 refid = "AFRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
