<servinfo servinfosgmlid = "AFRAP70A9806010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et Repose de la moquette 
</title>
<servinfosub id = "AFRAP70A9806010001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer le siège. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Siège avant: 
<intxreftitleoff1 refid = "AFRAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Siège arrière: 
<intxreftitleoff1 refid = "AFRAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Déposer les seuils et habillages suivants. 
<intxreftitleoff1 refid = "AFRAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Seuils intérieurs de porte avant 
</ptxt>
</item>
<item>
<ptxt>
Seuils intérieurs latéraux arrière 
</ptxt>
</item>
<item>
<ptxt>
Habillages latéraux de tableau de bord 
</ptxt>
</item>
<item>
<ptxt>
Habillages inférieurs de montant central 
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Déposer le boîtier avant / boîtier arrière de console centrale. 
<intxreftitleoff1 refid = "AFRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le couvercle de joint de direction. 
<intxreftitleoff1 refid = "AFRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les 5 agrafes (1) et la butée de pédale d&#39;accélérateur (2) puis, déposer la moquette (3). 
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A980007.jpg" width = "88.000mm" height = "60.725mm" ver = "02" gw = "238" gh = "156"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Avant du véhicule 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
<servinfosub id = "AFRAP70A9806010002">
<title>
Repose 
</title>
<ptxt>
Pour la repose, procéder dans l&#39;ordre inverse de la dépose en tenant compte des points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les boulons de fixation de chaque siège au couple prescrit. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Siège avant: 
<intxreftitleoff1 refid = "AFRAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Siège arrière: 
<intxreftitleoff1 refid = "AFRAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
