<servinfosub id = "AFRAP70A8204030003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A8204030004">
<testgroup id = "AFRAP70A8204030005">
<question>
La &#34;vérification du système de diagnostic d&#39;airbag&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204030006">
<title>
Vérification du module (dispositif de gonflage) d&#39;airbag latéral 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement correct au connecteur &#34;Q104&#34; ou &#34;Q105&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;Q104&#34; ou &#34;Q105&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Brancher &#34;STEERING WHEEL&#34; (1) de l&#39;outil spécial (A), (B) et (C) sur le connecteur &#34;Q104&#34; ou &#34;Q105&#34;. 
</ptxt>
<servicetool>
<servicetoolitem id = "L8B042">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B043">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
 09932-78310 
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B044">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
 09932-75010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820026.swf" width = "90.000mm" height = "70.285mm" ver = "02" gw = "211" gh = "183"/>
</testfigure>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1061 ou le DTC B1065 est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le module (dispositif de gonflage) d&#39;airbag latéral. 
<intxreftitleoff1 refid = "AFRAP70A8206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204030007">
<title>
Vérification du circuit du module (dispositif de gonflage) d&#39;airbag latéral 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement correct au connecteur &#34;L04&#34; ou &#34;L05&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;L04&#34; ou &#34;L05&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Relâcher la barre de court-circuit dans le connecteur du SDM en insérant l&#39;outil de relâchement inclus dans l&#39;outil spécial (A). 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance entre les bornes &#34;L04-3&#34; et &#34;Q104-1&#34; (DTC B1061): 1 &#937; maximum 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre les bornes &#34;L04-4&#34; et &#34;Q104-2&#34; (DTC B1061): 1 &#937; maximum 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre les bornes &#34;L05-1&#34; et &#34;Q105-1&#34; (DTC B1065): 1 &#937; maximum 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre les bornes &#34;L05-2&#34; et &#34;Q105-2&#34; (DTC B1065): 1 &#937; maximum 
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B045">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820125.swf" width = "90.000mm" height = "108.500mm" ver = "01" gw = "206" gh = "291"/>
</testfigure>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le SDM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204030008">
<title>
Vérification du circuit de faisceau de câbles de plancher 
</title>
<test1>
<ptxt>
Vérifier le branchement correct au connecteur &#34;L384&#34; ou &#34;L385&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;L384&#34; ou &#34;L385&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Relâcher la barre de court-circuit dans le connecteur du SDM en insérant l&#39;outil de relâchement inclus dans l&#39;outil spécial (A). 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance des circuits &#34;A1&#34; et &#34;A2&#34; (DTC B1061): 1 &#937; maximum 
</ptxt>
</item>
<item>
<ptxt>
Résistance des circuits &#34;A3&#34; et &#34;A4&#34; (DTC B1065): 1 &#937; maximum 
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B046">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820027F.swf" width = "90.000mm" height = "106.401mm" ver = "04" gw = "206" gh = "285"/>
</testfigure>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le faisceau de câbles du siège. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de plancher. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Une fois la vérification et les réparations terminées, effectuer les opérations suivantes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Raccorder toutes les pièces constitutives du système d&#39;airbag et s&#39;assurer qu&#39;elles sont toutes correctement montées. 
</ptxt>
</item>
<item>
<ptxt>
Supprimer les DTC éventuels en se reportant au point 
<intxref refid = "AFRAP70A8204006">Suppression des DTC</intxref>
. 
</ptxt>
</item>
<item>
<ptxt>
Effectuer à nouveau 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
 pour confirmer que le problème a été résolu. 
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
