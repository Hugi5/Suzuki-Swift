<servinfosub id = "AFRAP70A6304016005">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A6304016006">
<testgroup id = "AFRAP70A6304016007">
<question>
La &#34;vérification du système P/S&#34; a-t-elle été réalisée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A6304001">Vérification du système P/S</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A6304016008">
<title>
Vérification des DTC 
</title>
<test1>
<ptxt>
Rechercher un éventuel DTC dans l&#39;ECM. 
<intxreftitleoff1 refid = "AFRAP70A6304003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Un ou plusieurs DTC sont-ils détectés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. (défaillance liée à l&#39;ECM) 
<intxreftitleoff1 refid = "AFRAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le module de commande P/S et revérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
