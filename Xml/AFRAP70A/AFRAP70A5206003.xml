<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Remplacement de la bague d&#39;étanchéité côté différentiel 
</title>
<s1>
<ptxt>
Soulever le véhicule et vidanger l&#39;huile de boîte-pont. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;ensemble d&#39;arbre de roue gauche. 
<intxreftitleoff1 refid = "AFRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la bague d&#39;étanchéité (1) à l&#39;aide de l&#39;outil spécial. 
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
 09913-50121 
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522004.swf" width = "88.000mm" height = "48.454mm" ver = "01" gw = "146" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Reposer une nouvelle bague d&#39;étanchéité (1) à l&#39;aide de l&#39;outil spécial. 
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Veiller à reposer la bague d&#39;étanchéité en orientant le côté ressort vers l&#39;intérieur. 
</ptxt>
</item>
<item>
<ptxt>
Veiller à reposer la bague d&#39;étanchéité parallèlement à la surface du carter gauche (2). 
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
 09944-88220 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
 09924-74510 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Distance entre la surface de carter et le joint d&#39;étanchéité 
</title>
<ptxt>
&#34;a&#34;: 0 – 1,0 mm (0 – 0,04 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Appliquer de la graisse sur la lèvre de bague d&#39;étanchéité et vérifier l&#39;arbre moteur au niveau du contact de bague d&#39;étanchéité (rugosité). 
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B004" uid = "22">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Graisse
</m-desc>
<m-number>
 99000-25011 
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A522005.swf" width = "88.000mm" height = "44.718mm" ver = "02" gw = "110" gh = "110"/>
</figure>
</s1>
<s1>
<ptxt>
Insérer l&#39;ensemble d&#39;arbre de roue gauche. 
<intxreftitleoff1 refid = "AFRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Faire l&#39;appoint d&#39;huile de boîte-pont. 
<intxreftitleoff1 refid = "AFRAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
