<title>
DTC B1169
</title>
<servinfosub id = "AFRAP70AA324014001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1169: Erreur d&#39;enregistrement
</emph>
</ptxt>
<ptxt>
Echec de l&#39;enregistrement de l&#39;ECM ou du dispositif de commande à distance. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Circuit / connecteur d&#39;alimentation électrique 
</ptxt>
</item>
<item>
<ptxt>
Circuit / connecteur de communication CAN 
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Module de commande de démarrage sans clé 
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70AA324014002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA324014003">
<testgroup id = "AFRAP70AA324014004">
<title>
Vérification de DTC 
</title>
<question>
Y a-t-il d&#39;autres DTC détectés que B1169? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA324014005">
<title>
Enregistrement de l&#39;ECM 
</title>
<test1>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70AA326003">Enregistrement de l&#39;ECM:Modèle à démarrage sans clé</intxref>
. 
</ptxt>
</test1>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1169 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ECM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. 
</ptxt>
</action>
</testgroup>
</diag>
