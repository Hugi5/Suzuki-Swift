<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.373in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Moteur d&#39;essuie-glace arrière 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Reposer le joint d&#39;essuie-glace arrière (1) et serrer l&#39;écrou d&#39;essuie-glace arrière au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T9D005">
<t-part>
 Ecrou d&#39;essuie-glace arrière 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,3
</t-value1>
<t-value2>
0,54
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940014.swf" width = "88.000mm" height = "34.877mm" ver = "02" gw = "116" gh = "82"/>
