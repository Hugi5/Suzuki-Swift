<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;essuie-glace arrière 
</title>
<servinfosub id = "AFRAP70A9406005001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer le capuchon de bras d&#39;essuie-glace arrière (1), l&#39;écrou de bras d&#39;essuie-glace arrière (2), l&#39;ensemble de bras et balai d&#39;essuie-glace arrière (3), le capuchon de pivot d&#39;essuie-glace (4), l&#39;écrou d&#39;essuie-glace arrière (5) et le joint d&#39;essuie-glace arrière (6). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A940013.swf" width = "88.000mm" height = "45.733mm" ver = "01" gw = "174" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer l&#39;habillage de porte de coffre. 
<intxreftitleoff1 refid = "AFRAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le moteur d&#39;essuie-glace arrière. 
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur (1) du moteur d&#39;essuie-glace arrière à l&#39;aide d&#39;un tournevis à tête plate (2) comme indiqué sur le schéma. 
</ptxt>
<figure>
<graphic graphicname = "I7V10A940003.swf" width = "88.000mm" height = "79.003mm" ver = "01" gw = "161" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9406005002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9406006">Vérification du moteur d&#39;essuie-glace arrière</intxrefpoff>
</ptxt>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les boulons de moteur d&#39;essuie-glace arrière au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T9D004">
<t-part>
 Boulon de moteur d&#39;essuie-glace arrière 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I5RW0A940011.swf" width = "88.000mm" height = "56.315mm" ver = "01" gw = "172" gh = "143"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
