<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;éclairage de plaque d&#39;immatriculation 
</title>
<servinfosub id = "AFRAP70A9206007001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer les vis de garnissage inférieur de porte de coffre (1), puis déposer le garnissage inférieur de porte de coffre (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;éclairage de plaque d&#39;immatriculation (3). 
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur d&#39;éclairage de plaque d&#39;immatriculation. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A920001.jpg" width = "88.000mm" height = "80.485mm" ver = "01" gw = "211" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer l&#39;ampoule. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9206007002">
<title>
Repose 
</title>
<ptxt>
Pour la repose, procéder dans l&#39;ordre inverse de la dépose en tenant compte du point suivant. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les vis de garnissage inférieur de porte de coffre au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T9B001">
<t-part>
 Vis de garnissage inférieur de porte de coffre 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A920002.jpg" width = "88.000mm" height = "80.884mm" ver = "01" gw = "211" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
