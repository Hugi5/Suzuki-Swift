<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A6104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Louvoiement ou instabilité de la direction 
</title>
<diag type = "condition">
<condition>
<ptxt>
Louvoiement ou instabilité de la direction 
</ptxt>
</condition>
<ps>
<ptxt>
Pression des pneus différente ou irrégulière 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer ou régler la pression des pneus. 
<intxreftitleoff1 refid = "AFRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Joint de bras de suspension et embout de barre d&#39;accouplement desserrés 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Remplacer le bras de suspension ou l&#39;embout de barre d&#39;accouplement. 
</ptxt>
<ptxt>
Bras de suspension: 
<intxreftitleoff1 refid = "AFRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Embout de barre d&#39;accouplement: 
<intxreftitleoff1 refid = "AFRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Ensemble de jambe avant ou fixation endommagé 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de jambe avant ou réparer la fixation. 
<intxreftitleoff1 refid = "AFRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Barre stabilisatrice desserrée 
</ptxt>
</ps>
<action>
<ptxt>
Resserrer ou remplacer la barre stabilisatrice ou les coussinets. 
<intxreftitleoff1 refid = "AFRAP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ressort hélicoïdal cassé ou détendu 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le ressort hélicoïdal. 
<intxreftitleoff1 refid = "AFRAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ensemble de jambe avant défectueux (amortisseur) 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de jambe avant (amortisseur). 
<intxreftitleoff1 refid = "AFRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Contact entre-dents incorrect entre crémaillière et pignon 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vérifier le couple de rotation d&#39;axe de crémaillière et pignon. 
<intxreftitleoff1 refid = "AFRAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
En cas de défaut, remplacer l&#39;ensemble de carter de mécanisme de direction. 
<intxreftitleoff1 refid = "AFRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Géométrie des roues avant déréglée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et régler la géométrie des roues avant. 
<intxreftitleoff1 refid = "AFRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ensemble de carter de mécanisme de direction défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de carter de mécanisme de direction. 
<intxreftitleoff1 refid = "AFRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
