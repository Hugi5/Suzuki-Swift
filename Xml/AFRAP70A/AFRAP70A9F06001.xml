<servinfo servinfosgmlid = "AFRAP70A9F06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du bloc audio 
</title>
<servinfosub id = "AFRAP70A9F06001001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la grille de ventilation centrale. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le bloc audio (1) du tableau de bord après avoir déposé les 2 vis de fixation (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher les connecteurs de bloc audio (3). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0004.jpg" width = "88.000mm" height = "63.065mm" ver = "03" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9F06001002">
<title>
Repose 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
