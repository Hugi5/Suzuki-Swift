<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70AA206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du BCM 
</title>
<servinfosub id = "AFRAP70AA206003001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Désactiver le système d&#39;airbag. 
<intxreftitleoff1 refid = "AFRAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le cache d&#39;orifice de colonne de direction en se reportant à l&#39;étape 4) du point 
<intxref refid = "AFRAP70A6206009">Dépose et repose de la colonne de direction</intxref>
 . 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;habillage latéral de tableau de bord. 
<intxreftitleoff1 refid = "AFRAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher les connecteurs (1) et les attaches du J/B (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les écrous (3) puis, déposer le J/B. 
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20016.jpg" width = "88.000mm" height = "78.207mm" ver = "01" gw = "202" gh = "205"/>
</figure>
</s1>
<s1>
<ptxt>
Débrancher les connecteurs (1) du BCM (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les écrous BCM (3) puis, déposer le BCM. 
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20017.jpg" width = "88.000mm" height = "82.962mm" ver = "01" gw = "198" gh = "219"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA206003002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants.	 
</ptxt>
</servinfosub>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les écrous du BCM au couple spécifié. 
</ptxt>
<torque>
<torqueitem id = "T10B001">
<t-part>
 Ecrou de BCM 
</t-part>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Activer le système d&#39;airbag. 
<intxreftitleoff1 refid = "AFRAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Si le BCM est remplacé, effectuer 
<intxref refid = "AFRAP70AA206002">Enregistrement du BCM (modèle avec contacteur d&#39;allumage)</intxref>
 . 
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
