<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A9904A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Le toit ouvrant ne fonctionne pas (le moteur de toit ouvrant ne fonctionne pas)
</title>
<diag type = "condition">
<condition>
<ptxt>
Le toit ouvrant ne fonctionne pas (le moteur de toit ouvrant ne fonctionne pas)
</ptxt>
</condition>
<ps>
<ptxt>
Fusible grillé
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le fusible.
</ptxt>
</action>
<ps>
<ptxt>
Contacteur de toit ouvrant défectueux
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le contacteur de toit ouvrant. 
<intxreftitleoff1 refid = "AFRAP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Câblage ou mise à la masse défectueux
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le circuit. 
<intxreftitleoff1 refid = "AFRAP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AFRAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Moteur de toit ouvrant défectueux
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le moteur de toit ouvrant. 
<intxreftitleoff1 refid = "AFRAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
