<intxreftitleoff1 refid = "AFRAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Câblage ou mise à la masse défectueux 
</ptxt>
</ps>
<action>
<ptxt>
