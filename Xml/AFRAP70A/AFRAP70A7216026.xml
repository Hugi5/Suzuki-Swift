<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A7216026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;actionneur de commande d&#39;admission d&#39;air 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A7216020">Pièces constitutives de l&#39;unité de commande HVAC:Type manuel</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A7216026001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer le boîtier de préchauffage. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la gaine au plancher côté passager. 
<intxreftitleoff1 refid = "AFRAP70A7216011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur de l&#39;actionneur de commande d&#39;admission d&#39;air. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les vis (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;actionneur de commande d&#39;admission d&#39;air (2) de l&#39;unité HVAC. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A721028.jpg" width = "88.000mm" height = "68.236mm" ver = "01" gw = "142" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7216026002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A7216027">Vérification de l&#39;actionneur de commande d&#39;admission d&#39;air:Type manuel</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose en tenant compte des points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Veiller à insérer la goupille de timonerie (1) dans la rainure (2) de l&#39;actionneur de commande d&#39;admission d&#39;air. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A721029.swf" width = "88.000mm" height = "49.668mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
