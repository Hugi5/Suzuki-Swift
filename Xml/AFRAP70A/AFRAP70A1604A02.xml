<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A1604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Le moteur surchauffe (le ventilateur de radiateur ne fonctionne pas) 
</title>
<diag type = "condition">
<condition>
<ptxt>
Le moteur surchauffe (le ventilateur de radiateur ne fonctionne pas) 
</ptxt>
</condition>
<ps>
<ptxt>
Fusible grillé 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le fusible. 
</ptxt>
</action>
<ps>
<ptxt>
Relais de ventilateur de refroidissement de radiateur défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le relais de ventilateur de refroidissement de radiateur. 
<intxreftitleoff1 refid = "AFRAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Capteur ECT défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le capteur ECT. 
<intxreftitleoff1 refid = "AFRAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Moteur de ventilateur de refroidissement de radiateur défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le moteur du ventilateur de refroidissement de radiateur. 
<intxreftitleoff1 refid = "AFRAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Câblage ou mise à la masse défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer le câblage. 
</ptxt>
</action>
<ps>
<ptxt>
ECM défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier l&#39;ECM et son circuit. 
<intxreftitleoff1 refid = "AFRAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
