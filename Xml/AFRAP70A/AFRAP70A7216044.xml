<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A7216044" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du dessiccateur 
</title>
<servinfosub id = "AFRAP70A7216044001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Récupérer le réfrigérant du système A/C en se reportant à la section &#34;Récupération&#34;, au point 
<intxref refid = "AFRAP70A7216001">Procédure de remplissage de réfrigérant:Type manuel</intxref>
. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le pare-chocs avant. 
<intxreftitleoff1 refid = "AFRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le renfort de traverse de pare-chocs avant et l&#39;amortisseur inférieur de pare-choc avant. 
<intxreftitleoff1 refid = "AFRAP70A9806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le bouchon de filtre (1) de l&#39;accumulateur (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le dessiccateur (3) et les joints toriques (4). 
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A721037.swf" width = "88.000mm" height = "45.459mm" ver = "01" gw = "210" gh = "112"/>
</figure>
</servinfosub>
<servinfosub id = "AFRAP70A7216044002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ne retirer le dessiccateur du sac plastique que juste avant de l&#39;introduire dans l&#39;accumulateur. 
</ptxt>
</item>
<item>
<ptxt>
Poser un dessiccateur neuf, un joint torique neuf et un bouchon de filtre neuf. 
</ptxt>
</item>
<item>
<ptxt>
Appliquer de l&#39;huile de compresseur spécifiée sur le joint torique. 
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B103" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Huile de compresseur
</m-desc>
<m-number>
99000-99095-00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Serrer le bouchon de filtre au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T7B101">
<t-part>
 Bouchon de filtre 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 18 
</t-value1>
<t-value2>
1,84
</t-value2>
<t-value3>
1,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Purger et remplir le système A/C en se reportant à &#34;Purge&#34; et &#34;Remplissage&#34; au point 
<intxref refid = "AFRAP70A7216001">Procédure de remplissage de réfrigérant:Type manuel</intxref>
. 
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A721038.swf" width = "88.000mm" height = "40.160mm" ver = "01" gw = "172" gh = "97"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
