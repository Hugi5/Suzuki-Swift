<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de la vitre de porte avant 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9506010">Composants de porte avant</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A9506011001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Abaisser la vitre de porte avant d&#39;environ 150 mm (5,91 in.) du bord inférieur de la vitre. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A950023.jpg" width = "88.000mm" height = "45.882mm" ver = "02" gw = "225" gh = "114"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.331in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.870in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Environ 150 mm (5,91 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le garnissage intérieur de support de joint (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le cache de poignée intérieure (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les vis (3) et l&#39;agrafe (B) et déposer l&#39;habillage de porte (4) en le tirant dans le sens de la flèche. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A950025.jpg" width = "88.000mm" height = "101.074mm" ver = "01" gw = "227" gh = "270"/>
</figure>
</s1>
<s1>
<ptxt>
Débrancher les connecteurs du faisceau de câbles de porte. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le bourrelet extérieur de porte avant (1) en le déplaçant dans le sens des flèches dans l&#39;ordre (de &#34;1&#34; à &#34;2&#34;) comme indiqué sur le schéma. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A950026.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.071in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.783in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Griffe 
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3. 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Panneau extérieur de porte avant 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Déposer le support d&#39;habillage de porte (1) et le couvercle d&#39;étanchéité de porte (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A950027.jpg" width = "88.000mm" height = "91.845mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer les vis (1) et déposer la vitre de porte avant (2) en la déplaçant dans le sens des flèches dans l&#39;ordre (de &#34;1&#34; à &#34;2&#34;) comme indiqué sur le schéma. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A950028.jpg" width = "88.000mm" height = "78.685mm" ver = "02" gw = "225" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9506011002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reposer les supports de vitre de porte (1) dans la position spécifiée de la vitre de porte avant (2) s&#39;ils ont été déposés de la vitre de porte avant. 
</ptxt>
<spec>
<title>
Position de pose de support de vitre de porte avant 
</title>
<ptxt>
&#34;a&#34;: 104 – 106 mm (4,10 – 4,17 in.)
</ptxt>
<ptxt>
&#34;b&#34;: 431,2 – 433,2 mm (16,98 – 17,05 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70P950015.jpg" width = "88.000mm" height = "46.523mm" ver = "01" gw = "191" gh = "115"/>
</figure>
</item>
<item>
<ptxt>
Serrer les vis de vitre de porte avant dans l&#39;ordre (de &#34;1&#34; à &#34;2&#34;) comme indiqué sur le schéma. 
</ptxt>
</item>
<item>
<ptxt>
Serrer les vis de vitre avant au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T9E002">
<t-part>
 Vis de vitre de porte avant* 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950029.jpg" width = "88.000mm" height = "81.655mm" ver = "02" gw = "225" gh = "215"/>
</figure>
</item>
<item>
<ptxt>
Si le coulisseau de vitre est déformé, le réparer ou le remplacer par un élément neuf. 
</ptxt>
</item>
<item>
<ptxt>
Fixer le cache d&#39;étanchéité de porte (1) avec du ruban adhésif en caoutchouc butyle (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A950031.jpg" width = "88.000mm" height = "81.028mm" ver = "01" gw = "215" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
