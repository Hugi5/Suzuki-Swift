<servinfo servinfosgmlid = "AFRAP70A4206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Vérification du disque de frein avant 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A4206005">Dépose et repose du disque de frein avant</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A4206006001" page = "2">
<title>
Disque de frein avant 
</title>
<list1 type = "unordered">
<item>
<ptxt>
Mesurer l&#39;ovalisation du disque à l&#39;aide d&#39;un support magnétique et d&#39;un comparateur à cadran avec produit placé à environ 10 mm (0,39 in.) du bord, vers l&#39;intérieur du disque. Si elle dépasse la limite, réparer ou remplacer le disque de frein avant. 
</ptxt>
<spec-sdm>
<sdm-title>
 Ovalisation du disque de frein avant 
</sdm-title>
<sdm1>
<sdm-condition>
 Limite 
</sdm-condition>
<sdm-value>
0,10 mm (0,004 in.) 
</sdm-value>
</sdm1>
</spec-sdm>
<servicetool>
<servicetoolitem id = "L4B001">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
 09900-20607 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L4B002">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
 09900-20701 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure page = "2">
<graphic graphicname = "IAP70A420010.swf" width = "88.000mm" height = "49.949mm" ver = "02" gw = "133" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Mesurer l&#39;épaisseur du disque de frein avant à l&#39;aide d&#39;un micromètre. Si elle est inférieure à la limite, remplacer le disque de frein avant. 
</ptxt>
<spec-sdm>
<sdm-title>
 Epaisseur de disque de frein avant 
</sdm-title>
<sdm-part>
 &#34;a&#34; 
</sdm-part>
<sdm1>
<sdm-condition>
 Standard 
</sdm-condition>
<sdm-value>
22,0 mm (0,87 in.)
</sdm-value>
</sdm1>
<sdm1>
<sdm-condition>
 Limite 
</sdm-condition>
<sdm-value>
20,0 mm (0,79 in.)
</sdm-value>
</sdm1>
</spec-sdm>
<figure page = "2">
<graphic graphicname = "IAP70A420011.swf" width = "88.000mm" height = "52.057mm" ver = "01" gw = "133" gh = "131"/>
</figure>
</item>
</list1>
