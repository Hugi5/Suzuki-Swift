<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A4106006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose d&#39;ensemble de pédale de frein 
</title>
<attention2>
<ptxt>
Ne jamais démonter un ensemble de pédale de frein équipé du mécanisme de protection de pied de la pédale de frein. 
</ptxt>
<ptxt>
Le démontage nuirait à son fonctionnement. S&#39;il est défectueux, le remplacer par un ensemble neuf. 
</ptxt>
</attention2>
<servinfosub id = "AFRAP70A4106006001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer le panneau du combiné des instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le cache d&#39;orifice de colonne de direction. 
<intxreftitleoff1 refid = "AFRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le contacteur de feux stop. 
<intxreftitleoff1 refid = "AFRAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;arbre inférieur de direction. 
<intxreftitleoff1 refid = "AFRAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;agrafe, la goupille de chape et les écrous de servofrein. 
<intxreftitleoff1 refid = "AFRAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;écrou de support de pédale de frein (1) et les boulons de raidisseur supérieur d&#39;auvent (2). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer l&#39;ensemble de pédale de frein. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A4106006002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A4106022">Dépose et repose du servofrein</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Reposer l&#39;ensemble de pédale de frein et le servofrein. 
</ptxt>
</s1>
<s1>
<ptxt>
Serrer les écrous de servofrein au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T4A001">
<t-part>
 Ecrou de servofrein* 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410009.swf" width = "88.000mm" height = "63.332mm" ver = "01" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Serrer l&#39;écrou de support de pédale de frein au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T4A002">
<t-part>
 Ecrou de support de pédale de frein* 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Serrer le boulon de raidisseur supérieur d&#39;auvent au couple spécifié. 
</ptxt>
<torque>
<torqueitem id = "T4A003">
<t-part>
 Boulon de raidisseur supérieur d&#39;auvent 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410010.swf" width = "88.000mm" height = "64.412mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Reposer l&#39;agrafe et la chape. 
<intxreftitleoff1 refid = "AFRAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Reposer l&#39;arbre inférieur de direction. 
<intxreftitleoff1 refid = "AFRAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Purger l&#39;air du système de freinage. 
<intxreftitleoff1 refid = "AFRAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vérifier la hauteur libre et le jeu de la pédale de frein. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Hauteur libre de la pédale de frein: 
<intxreftitleoff1 refid = "AFRAP70A4106007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Jeu de la pédale de frein: 
<intxreftitleoff1 refid = "AFRAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Reposer le contacteur de feux stop. 
<intxreftitleoff1 refid = "AFRAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rechercher une éventuelle fuite de liquide au niveau des raccords et s&#39;assurer que le système de freinage fonctionne correctement. 
</ptxt>
</s1>
<s1>
<ptxt>
Reposer le cache d&#39;orifice de colonne de direction. 
<intxreftitleoff1 refid = "AFRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Reposer le panneau de combiné d&#39;instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
