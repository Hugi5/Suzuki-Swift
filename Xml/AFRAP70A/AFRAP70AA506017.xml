<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70AA506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;avertisseur sonore extérieur 
</title>
<servinfosub id = "AFRAP70AA506017001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la garniture d&#39;aile avant côté conducteur. 
<intxreftitleoff1 refid = "AFRAP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur (1), puis déposer l&#39;avertisseur sonore extérieur (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50032.jpg" width = "88.000mm" height = "68.823mm" ver = "01" gw = "213" gh = "179"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA506017002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70AA506018">Vérification de l&#39;avertisseur sonore extérieur</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
