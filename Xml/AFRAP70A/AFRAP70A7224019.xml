<diag type = "test" id = "AFRAP70A7224019005">
<testgroup id = "AFRAP70A7224019006">
<title>
Vérification des paramètres de l&#39;outil de balayage 
</title>
<test1>
<ptxt>
Vérifier la valeur &#34;Capt pos mélange air&#34; à l&#39;aide du mode &#34;Liste de données&#34; de l&#39;outil de balayage SUZUKI. 
<intxreftitleoff1 refid = "AFRAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
La tension est-elle inférieure à 0,1 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problème intermittent. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224019007">
<title>
Vérification du circuit de signal de capteur de position d&#39;actionneur de commande de température 
</title>
<test1>
<ptxt>
Débrancher le connecteur de l&#39;actionneur de commande de température. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1511-H est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;actionneur de commande de température. 
<intxreftitleoff1 refid = "AFRAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224019008">
<title>
Vérification du circuit de signal de capteur de position d&#39;actionneur de commande de température 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la tension entre la borne de câble &#34;WHT&#34; du connecteur d&#39;actionneur de commande de température et la masse. 
</ptxt>
</test1>
<question>
La tension est-elle de 5 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224019009">
<title>
Vérification du circuit de signal de capteur de position d&#39;actionneur de commande de température 
</title>
<test1>
<ptxt>
Débrancher le connecteur &#34;G20&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance du circuit de câble &#34;WHT&#34;: en dessous de 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Résistance du circuit de câble &#34;WHT&#34; entre l&#39;actionneur de commande de température et la masse: infinie 
</ptxt>
</item>
</list1>
</test1>
<question>
Les valeurs de résistance sont-elles conformes aux spécifications? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande HVAC et revérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A7224019010">
<title>
Vérification du circuit de signal de capteur de position d&#39;actionneur de commande de température 
</title>
<test1>
<ptxt>
Vérifier si la résistance entre la borne de câble &#34;YEL&#34; et la masse est infinie. 
</ptxt>
</test1>
<question>
La résistance est-elle conforme aux spécifications? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande HVAC et revérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de tableau de bord. 
</ptxt>
</action>
</testgroup>
