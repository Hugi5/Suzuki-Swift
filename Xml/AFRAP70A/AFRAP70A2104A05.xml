<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A2104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Bruit anormal, extrémité avant 
</title>
<diag type = "condition">
<condition>
<ptxt>
Bruit anormal, extrémité avant 
</ptxt>
</condition>
<ps>
<ptxt>
Ensemble de jambe avant (amortisseur) ou fixations endommagés 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer l&#39;ensemble de jambe avant (amortisseur) ou les fixations. 
<intxreftitleoff1 refid = "AFRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Embouts de barres d&#39;accouplement usés, collants ou desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les embouts de barre d&#39;accouplement. 
<intxreftitleoff1 refid = "AFRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Joints de bras de suspension usés ou endommagés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le bras de suspension. 
<intxreftitleoff1 refid = "AFRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Joints à rotule de barre d&#39;accouplement usés, collants ou desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de carter de mécanisme de direction. 
<intxreftitleoff1 refid = "AFRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Joints d&#39;arbre de roue usés, collants ou desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les joints d&#39;arbre de roue. 
<intxreftitleoff1 refid = "AFRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Coussinets avant de bras de suspension usés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les coussinets avant de bras de suspension. 
<intxreftitleoff1 refid = "AFRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Coussinets arrière de bras de suspension usés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le bras de suspension. 
<intxreftitleoff1 refid = "AFRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Barre stabilisatrice desserrée 
</ptxt>
</ps>
<action>
<ptxt>
Serrer les boulons ou les écrous et/ou remplacer les manchons. 
<intxreftitleoff1 refid = "AFRAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ecrous de roue desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Serrer les écrous de roue. 
<intxreftitleoff1 refid = "AFRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Boulons ou écrous de suspension desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Serrer les boulons ou les écrous de suspension. 
<intxreftitleoff1 refid = "AFRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Roulements de roue cassés ou endommagés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les roulements de roue. 
<intxreftitleoff1 refid = "AFRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ressorts hélicoïdaux cassés 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Remplacer les ressorts hélicoïdaux. 
</ptxt>
<ptxt>
Avant: 
<intxreftitleoff1 refid = "AFRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Arrière: 
<intxreftitleoff1 refid = "AFRAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Roulements de jambe mal lubrifiés ou usés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les roulements de jambe. 
<intxreftitleoff1 refid = "AFRAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Dysfonctionnement du système de direction assistée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et corriger le dysfonctionnement. 
<intxreftitleoff1 refid = "AFRAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
