<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A3126003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;ensemble d&#39;arbre de roue arrière 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A3126001">Pièces constitutives de l&#39;arbre de roue arrière:Arrière</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AFRAP70A3126002">Vérification sur véhicule de l&#39;ensemble d&#39;arbre de roue arrière:Arrière</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A3126003001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Soulever le véhicule et déposer la roue arrière. 
<intxreftitleoff1 refid = "AFRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Relâcher le matage (1) et déposer l&#39;écrou d&#39;arbre de roue (2) avec la pédale de frein enfoncée. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A312002.swf" width = "88.000mm" height = "53.091mm" ver = "01" gw = "177" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer les écrous de flasque de l&#39;arbre de roue arrière (1) puis déposer l&#39;ensemble d&#39;arbre de roue arrière. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A312003.swf" width = "88.000mm" height = "47.465mm" ver = "01" gw = "177" gh = "118"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A3126003002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer l&#39;écrou d&#39;arbre de roue neuf (1) au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T3A202">
<t-part>
 Ecrou d&#39;arbre de roue 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 175 
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Mâter l&#39;écrou d&#39;arbre de roue (1) comme indiqué sur le schéma. 
</ptxt>
<attention2>
<ptxt>
Veiller à ne pas fissurer la partie matée (2) de l&#39;écrou d&#39;arbre de roue lors du matage. Le remplacer par un élément neuf en cas de fissures. 
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A312004.swf" width = "88.000mm" height = "52.301mm" ver = "01" gw = "159" gh = "132"/>
</figure>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les écrous de flasque d&#39;arbre de roue arrière au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T3A203">
<t-part>
 Ecrou de flasque d&#39;arbre de roue arrière 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 50 
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A312005.swf" width = "88.000mm" height = "49.964mm" ver = "01" gw = "177" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Appliquer de la graisse sur la surface de contact de l&#39;ensemble de moyeu de roue arrière et de l&#39;arbre de roue arrière. 
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A202" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Graisse
</m-desc>
<m-number>
 99000-25011 
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A312006.swf" width = "88.000mm" height = "54.175mm" ver = "02" gw = "227" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Serrer les écrous de roue au couple prescrit. 
<intxreftitleoff1 refid = "AFRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
