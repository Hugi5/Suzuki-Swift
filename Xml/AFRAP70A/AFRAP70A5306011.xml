<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A5306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du maître-cylindre d&#39;embrayage 
</title>
<servinfosub id = "AFRAP70A5306011001">
<title>
Dépose 
</title>
<s1 page = "2">
<ptxt>
Nettoyer le pourtour du bouchon de réservoir de maître-cylindre de frein et extraire le liquide de réservoir de maître-cylindre de frein à l&#39;aide d&#39;une seringue ou d&#39;un outil similaire. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Débrancher le tuyau de liquide d&#39;embrayage du maître-cylindre d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Débrancher la durite de réservoir d&#39;embrayage (1). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A530007.swf" width = "88.000mm" height = "49.059mm" ver = "01" gw = "141" gh = "123"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Déposer la tige de poussée (1) de la pédale d&#39;embrayage (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les écrous de maître-cylindre d&#39;embrayage (3), puis retirer le maître-cylindre d&#39;embrayage (4). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A530008.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A5306011002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A5306012">Vérification du maître-cylindre d&#39;embrayage</intxrefpoff>
</ptxt>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Appliquer de la graisse sur la pointe de la tige de poussée. 
</ptxt>
<materials>
<materialitem name = "SUZUKI Silicone Grease" id = "M5C001" uid = "21">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Graisse
</m-desc>
<m-number>
 99000-25100 
</m-number>
<m-name>
SUZUKI Silicone Grease
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les écrous de maître-cylindre d&#39;embrayage (1) au couple spécifié. 
</ptxt>
<torque>
<torqueitem id = "T5C004">
<t-part>
 Ecrou de maître-cylindre d&#39;embrayage 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A531013.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
