<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A4604024" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1038
</title>
<servinfosub id = "AFRAP70A4604024001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.259in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.896in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1038: Détection par le capteur d&#39;angle de braquage d&#39;une défaillance du compteur de rotation
</emph>
</ptxt>
<ptxt>
Détection par le capteur d&#39;angle de braquage de données CAN incorrectes provenant du module de commande ESP<sup>&#174;</sup>. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Circuit de communication CAN 
</ptxt>
</item>
<item>
<ptxt>
Capteur d&#39;angle de braquage 
</ptxt>
</item>
<item>
<ptxt>
Module de commande ESP<sup>&#174;</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70A4604024002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A4604024003">
<testgroup id = "AFRAP70A4604024004">
<question>
La &#34;Vérification du système ESP<sup>&#174;</sup>&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A4604001">Vérification du système ESP&#174;</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604024005">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70A4604005">Vérification des DTC</intxref>
. 
</ptxt>
</test1>
<question>
Un ou plusieurs DTC autres que C1038 sont-ils détectés? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à la recherche de pannes pour le DTC correspondant. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A4604024006">
<title>
Vérification du capteur d&#39;angle de braquage 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Remplacer le capteur d&#39;angle de braquage. 
<intxreftitleoff1 refid = "AFRAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
</ptxt>
</test1>
<question>
Le DTC C1038 est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
