<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70AA206004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du capteur de température d&#39;air extérieur 
</title>
<servinfosub id = "AFRAP70AA206004001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le pare-chocs avant. 
<intxreftitleoff1 refid = "AFRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur (1) du capteur de température d&#39;air extérieur. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le capteur de température d&#39;air extérieur (2) de la traverse de pare-chocs avant. 
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20018.jpg" width = "88.000mm" height = "67.914mm" ver = "01" gw = "210" gh = "176"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA206004002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70AA206005">Vérification du capteur de température d&#39;air extérieur</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
