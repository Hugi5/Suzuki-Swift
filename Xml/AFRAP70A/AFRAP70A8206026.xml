<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A8206026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du contacteur de désactivation d&#39;airbag du passager 
</title>
<servinfosub id = "AFRAP70A8206026001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer la boîte à gants. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur (1) de contacteur de désactivation d&#39;airbag du passager. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A820078.swf" width = "88.000mm" height = "87.000mm" ver = "01" gw = "231" gh = "230"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer le contacteur de désactivation d&#39;airbag du passager (1) tout en libérant les dispositifs de verrouillage (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A820079.swf" width = "88.000mm" height = "59.573mm" ver = "02" gw = "207" gh = "152"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A8206026002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A8206027">Vérification du contacteur de désactivation d&#39;airbag du passager</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Reposer le contacteur de désactivation d&#39;airbag du passager (1) en alignant sa partie en saillie (2) avec la découpe (3) du tableau de bord. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A820080.swf" width = "88.000mm" height = "64.695mm" ver = "01" gw = "207" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Brancher le connecteur de contacteur de désactivation d&#39;airbag du passager. 
</ptxt>
</s1>
<s1>
<ptxt>
Reposer la boîte à gants. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
