<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1570: Défaillance du signal de type de moteur 
</emph>
</ptxt>
<ptxt>
Le module de commande HVAC reçoit des données incorrectes de signal de type de moteur en provenance de l&#39;ECM. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Module de commande HVAC 
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70A7224029002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A7224029003">
<testgroup id = "AFRAP70A7224029005">
<title>
Vérification des données de l&#39;outil de balayage 
</title>
<test1>
<ptxt>
Brancher l&#39;outil de balayage avec l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34; et sélectionner le mode &#34;LISTE DE DONNEES&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier la valeur &#34;Type moteur&#34; affichée sur l&#39;outil de balayage. 
</ptxt>
</test1>
<question>
Le type de moteur est-il correct, comme indiqué dans les &#34;Données de l&#39;outil de balayage&#34;? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande HVAC par un élément en bon état, et vérifier à nouveau. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer l&#39;ECM par un ECM en bon état et vérifier à nouveau. 
</ptxt>
</action>
</testgroup>
</diag>
