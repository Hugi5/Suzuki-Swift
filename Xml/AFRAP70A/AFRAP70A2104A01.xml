<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A2104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Le véhicule tire d&#39;un côté (dérive) 
</title>
<diag type = "condition">
<condition>
<ptxt>
Le véhicule tire d&#39;un côté (dérive) 
</ptxt>
</condition>
<ps>
<ptxt>
Pneus différents ou usés de façon irrégulière 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer les pneus. 
<intxreftitleoff1 refid = "AFRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gonflage des pneus inadéquat 
</ptxt>
</ps>
<action>
<ptxt>
Régler la pression des pneus. 
</ptxt>
</action>
<ps>
<ptxt>
Ressorts hélicoïdaux cassés ou détendus 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Remplacer les ressorts hélicoïdaux. 
</ptxt>
<ptxt>
Avant: 
<intxreftitleoff1 refid = "AFRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Arrière: 
<intxreftitleoff1 refid = "AFRAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Force latérale anormale créée par un pneu à carcasse radiale 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le pneu. 
<intxreftitleoff1 refid = "AFRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Géométrie des roues déréglée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier et régler la géométrie des roues. 
<intxreftitleoff1 refid = "AFRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Frottement du frein sur une roue 
</ptxt>
</ps>
<action>
<ptxt>
Régler ou réparer les freins. 
</ptxt>
</action>
<ps>
<ptxt>
Pièces de suspension avant ou arrière desserrées, pliées ou cassées 
</ptxt>
</ps>
<action>
<ptxt>
Serrer ou remplacer les pièces de suspension concernées. 
<intxreftitleoff1 refid = "AFRAP70A2106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
