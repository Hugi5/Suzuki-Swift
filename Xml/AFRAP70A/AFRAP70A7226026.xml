<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A7226026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;actionneur de commande de débit d&#39;air 
</title>
<servinfosub id = "AFRAP70A7226026001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Désactiver le système d&#39;airbag. 
<intxreftitleoff1 refid = "AFRAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le cache d&#39;orifice de colonne de direction. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le module (dispositif de gonflage) d&#39;airbag genoux. 
<intxreftitleoff1 refid = "AFRAP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la colonne de direction. 
<intxreftitleoff1 refid = "AFRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;ensemble de pédale de frein. 
<intxreftitleoff1 refid = "AFRAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les vis (1), puis déposer l&#39;actionneur de commande de débit d&#39;air (2). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A722011.jpg" width = "88.000mm" height = "63.150mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7226026002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A7226027">Vérification de l&#39;actionneur de commande de débit d&#39;air:Type automatique</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose en notant le point suivant. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Veiller à insérer la goupille de timonerie (2) dans l&#39;orifice (1) du bras d&#39;actionneur de commande de débit d&#39;air. 
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722012.swf" width = "88.000mm" height = "68.493mm" ver = "02" gw = "234" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
