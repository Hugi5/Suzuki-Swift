<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A6306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du module de commande P/S 
</title>
<servinfosub id = "AFRAP70A6306011001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le panneau d&#39;instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;ensemble de pédale de frein. 
<intxreftitleoff1 refid = "AFRAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher les connecteurs (1) du module de commande P/S (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les boulons de module de commande P/S (3) de la traverse de support de direction. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A630037.swf" width = "88.000mm" height = "94.023mm" ver = "01" gw = "148" gh = "250"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer le module de commande P/S. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A6306011002">
<title>
Repose 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les boulons de l&#39;unité de commande P/S au couple spécifié. 
</ptxt>
<torque>
<torqueitem id = "T6C006">
<t-part>
 Boulon de fixation de module de commande P/S 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,0
</t-value1>
<t-value2>
0,51
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A630034.swf" width = "88.000mm" height = "98.099mm" ver = "02" gw = "148" gh = "262"/>
</figure>
</item>
<item>
<ptxt>
Reposer l&#39;ensemble de pédale de frein. 
<intxreftitleoff1 refid = "AFRAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
