<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9606014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et pose du contacteur de dispositif d&#39;ouverture de porte de coffre 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9606013">Vérification sur véhicule du contacteur de dispositif d&#39;ouverture de porte de coffre</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A9606014001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer l&#39;habillage de porte de coffre. 
<intxreftitleoff1 refid = "AFRAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur de contacteur de dispositif d&#39;ouverture de porte de coffre (1). 
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer la garniture inférieure de porte de coffre. 
<intxreftitleoff1 refid = "AFRAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les vis (1) puis, déposer le contacteur de dispositif d&#39;ouverture de porte de coffre (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A960020.jpg" width = "88.000mm" height = "57.494mm" ver = "01" gw = "194" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9606014002">
<title>
Repose 
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
