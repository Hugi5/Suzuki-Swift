<servinfosub id = "AFRAP70AA324013002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA324013003">
<testgroup id = "AFRAP70AA324013004">
<title>
Saisie du mot de passe du dispositif antidémarrage 
</title>
<test1>
<ptxt>
Saisir à nouveau le mot de passe du dispositif antidémarrage. 
</ptxt>
</test1>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1168 est-il toujours détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vérifier à nouveau le mot de passe du dispositif antidémarrage. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (un mot de passe incorrect a été saisi) 
</ptxt>
</action>
