<servinfosub id = "AFRAP70A8204050003">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A8204050004">
<testgroup id = "AFRAP70A8204050005">
<question>
La &#34;vérification du système de diagnostic d&#39;airbag&#34; a-t-elle été effectuée? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer au point 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204050006">
<title>
Vérification d&#39;une éventuelle coupure du faisceau de câbles de plancher. 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher les connecteurs &#34;L04&#34; et &#34;L49&#34; ou les connecteurs &#34;L05&#34; et &#34;L50&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance des circuits &#34;A1&#34; et &#34;A2&#34; (DTC B1392 / B1393): 1 &#937; maximum 
</ptxt>
</item>
<item>
<ptxt>
Résistance des circuits &#34;A3&#34; et &#34;A4&#34; (DTC B1397 / B1398): 1 &#937; maximum 
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B091">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820036.swf" width = "90.000mm" height = "67.074mm" ver = "02" gw = "214" gh = "174"/>
</testfigure>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de plancher. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204050007">
<title>
Vérification du circuit de faisceau de câbles de plancher 
</title>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance entre les bornes &#34;L04-11&#34; et &#34;L04-12&#34; (DTC B1392 / B1393): infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre les bornes &#34;L05-11&#34; et &#34;L05-12&#34; (DTC B1397 / B1398): infinie 
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B092">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820154.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de plancher. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204050008">
<title>
Vérification du circuit de faisceau de câbles de plancher 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Résistance entre chacun des circuits &#34;A1&#34; et &#34;A2&#34; et la masse (DTC B1392 / B1393): infinie 
</ptxt>
</item>
<item>
<ptxt>
Résistance entre chacun des circuits &#34;A3&#34; et &#34;A4&#34; et la masse (DTC B1397 / B1398): infinie 
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B093">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820155.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de plancher. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204050009">
<title>
Vérification du circuit de faisceau de câbles de plancher 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tension entre chacun des circuits &#34;A1&#34; et &#34;A2&#34; et la masse (DTC B1392 / B1393): environ 0 V
</ptxt>
</item>
<item>
<ptxt>
Tension entre chacun des circuits &#34;A3&#34; et &#34;A4&#34; et la masse (DTC B1397 / B1398): environ 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B094">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820156.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 6. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de plancher. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204050010">
<title>
Vérification du capteur d&#39;impact latéral 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Remplacer le capteur d&#39;impact latéral arrière. 
<intxreftitleoff1 refid = "AFRAP70A8206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Un DTC est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le SDM et vérifier à nouveau les DTC. 
<intxreftitleoff1 refid = "AFRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Une fois la vérification et les réparations terminées, effectuer les opérations suivantes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Raccorder toutes les pièces constitutives du système d&#39;airbag et s&#39;assurer qu&#39;elles sont toutes correctement montées. 
</ptxt>
</item>
<item>
<ptxt>
Supprimer les DTC éventuels en se reportant au point 
<intxref refid = "AFRAP70A8204006">Suppression des DTC</intxref>
. 
</ptxt>
</item>
<item>
<ptxt>
Effectuer à nouveau 
<intxref refid = "AFRAP70A8204001">Vérification du système de diagnostic d&#39;airbag</intxref>
 pour confirmer que le problème a été résolu. 
</ptxt>
</item>
</list1>
</attention3>
