<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A7214A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Pas de sortie d&#39;air froid (l&#39;embrayage magnétique ne fonctionne pas) 
</title>
<diag type = "condition">
<condition>
<ptxt>
Pas de sortie d&#39;air froid (l&#39;embrayage magnétique ne fonctionne pas) 
</ptxt>
</condition>
<ps>
<ptxt>
Pas de réfrigérant 
</ptxt>
</ps>
<action>
<ptxt>
Procéder à la récupération du réfrigérant, à la purge et à la recharge. 
<intxreftitleoff1 refid = "AFRAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fusible grillé 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier les fusibles concernés puis rechercher un éventuel court-circuit à la masse. 
</ptxt>
</action>
<ps>
<ptxt>
Contacteur A/C défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le contacteur A/C. 
<intxreftitleoff1 refid = "AFRAP70A7216034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sélecteur de vitesse de soufflante défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le sélecteur de vitesse de soufflante. 
<intxreftitleoff1 refid = "AFRAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Capteur de température d&#39;évaporateur défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le capteur de température d&#39;évaporateur. 
<intxreftitleoff1 refid = "AFRAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Capteur de pression de réfrigérant A/C défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le capteur de pression de réfrigérant A/C. 
<intxreftitleoff1 refid = "AFRAP70A7216023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Câblage ou mise à la masse défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Réparer le câblage. 
</ptxt>
</action>
<ps>
<ptxt>
L&#39;ECM et son circuit sont défectueux 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vérifier l&#39;ECM. 
<intxreftitleoff1 refid = "AFRAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Embrayage magnétique défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier l&#39;embrayage magnétique. 
<intxreftitleoff1 refid = "AFRAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Courroie d&#39;entraînement de compresseur détendue ou cassée 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier la courroie d&#39;entraînement de compresseur. 
<intxreftitleoff1 refid = "AFRAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compresseur défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le compresseur. 
</ptxt>
</action>
<ps>
<ptxt>
Relais de compresseur défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le relais de compresseur. 
<intxreftitleoff1 refid = "AFRAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
BCM défectueux 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le BCM. 
<intxreftitleoff1 refid = "AFRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
