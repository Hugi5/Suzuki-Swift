<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A5304A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vibration de l&#39;embrayage 
</title>
<diag type = "condition">
<condition>
<ptxt>
Vibration de l&#39;embrayage 
</ptxt>
</condition>
<ps>
<ptxt>
Garnitures d&#39;embrayage glacées (vitrifiées) 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le disque d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Garnitures d&#39;embrayage tachées d&#39;huile 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le disque d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
La butée de débrayage ne glisse pas facilement 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;ensemble de cylindre actionneur d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Flottement du disque d&#39;embrayage ou mauvais contact de garniture 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le disque d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ressorts de torsion affaiblis dans le disque d&#39;embrayage 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le disque d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rivets de disque d&#39;embrayage desserrés 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le disque d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Plaque de pression ou surface de volant moteur déformée 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le couvercle d&#39;embrayage ou le volant moteur. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Disque et couvercle d&#39;embrayage: 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Volant moteur: 
<intxreftitleoff1 refid = "AFRAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Fixation du moteur affaiblie ou boulon(s) et/ou écrou(s) de fixation du moteur desserré(s) 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer la fixation du moteur ou resserrer les boulons et/ou écrous de fixation du moteur. 
<intxreftitleoff1 refid = "AFRAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
