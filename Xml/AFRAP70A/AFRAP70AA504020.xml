<servinfosub id = "AFRAP70AA504020003">
<title>
Procédure de confirmation de DTC 
</title>
<s1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</s1>
<s1>
<ptxt>
Enfoncer le contacteur de demande de porte lié au DTC. 
</ptxt>
</s1>
<s1>
<ptxt>
Relâcher le contacteur de demande de porte. 
</ptxt>
</s1>
<s1>
<ptxt>
Laisser l&#39;allumage en position &#34;ON&#34; pendant 10 minutes minimum. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70AA504020004">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70AA504020005">
<testgroup id = "AFRAP70AA504020008">
<title>
Vérification des paramètres 
</title>
<test1>
<ptxt>
Brancher l&#39;outil de balayage SUZUKI sur le DLC, allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le &#34;Contacteur de demande conducteur &#34;, le &#34;Contacteur de demande passager&#34; ou le &#34;Contacteur de demande de porte arrière / coffre&#34; affichés sur l&#39;outil de balayage SUZUKI. 
<intxreftitleoff1 refid = "AFRAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504020006">
<title>
Vérification du circuit de signal de contacteur de demande de porte 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher les connecteurs de contacteur de demande de porte et &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le branchement de borne sur les connecteurs de contacteur de demande de porte et &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Si les branchements sont corrects, vérifier que la résistance des circuits &#34;A1&#34;, &#34;A2&#34; et &#34;A3&#34; est: en dessous de 3 &#937;
</ptxt>
</test1>
<question>
Sont-ils en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Réparer ou remplacer le faisceau de câbles défectueux. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504020007">
<title>
Vérification du contacteur de demande de porte 
</title>
<test1>
<ptxt>
Vérifier le contacteur de demande de porte. 
<intxreftitleoff1 refid = "AFRAP70AA506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Son état est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le contacteur de demande de porte. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70AA504020009">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Brancher les connecteurs de contacteur de demande de porte et &#34;L10&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier les DTC. 
<intxreftitleoff1 refid = "AFRAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Le DTC B1180, B1181 ou B1182 actuel est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer le module de commande de démarrage sans clé et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. (problème intermittent) 
</ptxt>
</action>
</testgroup>
</diag>
