<title>
Frottement de l&#39;embrayage 
</title>
<diag type = "condition">
<condition>
<ptxt>
Frottement de l&#39;embrayage 
</ptxt>
</condition>
<ps>
<ptxt>
Course libre de pédale d&#39;embrayage 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Remplacer le bras de pédale d&#39;embrayage et/ou le maître-cylindre d&#39;embrayage. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Bras de pédale d&#39;embrayage: 
<intxreftitleoff1 refid = "AFRAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Maître-cylindre d&#39;embrayage: 
<intxreftitleoff1 refid = "AFRAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Ressort à diaphragme affaibli ou extrémité de ressort usée 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le couvercle d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cannelure d&#39;arbre d&#39;entrée rouillée 
</ptxt>
</ps>
<action>
<ptxt>
Lubrifier la cannelure d&#39;arbre d&#39;entrée. 
</ptxt>
</action>
<ps>
<ptxt>
Cannelure d&#39;arbre d&#39;entrée de boîte-pont endommagée ou usée 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer l&#39;arbre d&#39;entrée. 
<intxreftitleoff1 refid = "AFRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Flottement excessif du disque d&#39;embrayage 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le disque d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Garnitures d&#39;embrayage cassées ou tachées d&#39;huile 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le disque d&#39;embrayage. 
<intxreftitleoff1 refid = "AFRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fuite de liquide 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer le système d&#39;embrayage. 
</ptxt>
</action>
</diag>
</servinfo>
