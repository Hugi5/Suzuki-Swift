<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A1906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Dépose et repose du moteur de démarrage 
</title>
<servinfosub id = "AFRAP70A1906002001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher le câble négatif (–) de la batterie. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le collecteur d&#39;admission. 
<intxreftitleoff1 refid = "AFRAP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le support de capteur de cliquetis (1) du bloc-cylindres. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A190003.swf" width = "88.000mm" height = "58.388mm" ver = "01" gw = "172" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Débrancher le câble conducteur de contacteur magnétique (1) et le câble de moteur de démarrage (2) du moteur de démarrage. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer les boulons de fixation de moteur de démarrage (3). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le moteur de démarrage (4). 
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A190005.swf" width = "183.000mm" height = "82.031mm" ver = "02" gw = "405" gh = "216"/>
</figure>
</servinfosub>
<servinfosub id = "AFRAP70A1906002002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A1906009">Vérification du moteur de démarrage</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer les boulons de fixation de moteur de démarrage et l&#39;écrou de câble de moteur de démarrage aux couples prescrits. 
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1I001">
<t-part>
 Ecrou de câble de moteur de démarrage 
</t-part>
<t-value1>
 11 
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1I002">
<t-part>
 Boulon de fixation de moteur de démarrage 
</t-part>
<t-value1>
 45 
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
