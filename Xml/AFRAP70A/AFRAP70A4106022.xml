<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du servofrein 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A4106020">Pièces constitutives du servofrein</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A4106022001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Débrancher les canalisations de frein (1) de l&#39;ensemble de groupe hydraulique/module de commande de système ESP<sup>&#174;</sup> (2) à l&#39;aide de l&#39;outil spécial. 
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
 09950-78220 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410035.swf" width = "88.000mm" height = "45.139mm" ver = "02" gw = "117" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer l&#39;ensemble de maître-cylindre de frein du servofrein. 
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher la durite à dépression du servofrein. 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer l&#39;agrafe (1) et la goupille de chape (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A410036.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer les écrous de servofrein (1) et déposer le servofrein du tableau de bord. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A410037.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A4106022004">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A4106023">Vérification du servofrein</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Desserrer l&#39;écrou de support de pédale de frein (1) et les boulons de raidisseur supérieur d&#39;auvent (2). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Reposer le servofrein sur le tableau de bord. Poser ensuite la chape de tige de poussée (3) sur le bras de la pédale frein avec la goupille de chape (2) et l&#39;agrafe (1). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A410040.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer le panneau du combiné des instruments. 
<intxreftitleoff1 refid = "AFRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Serrer les écrous de servofrein au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T4A006">
<t-part>
 Ecrou de servofrein* 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410041.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Serrer l&#39;écrou de support de pédale de frein au couple prescrit. 
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
 Ecrou de support de pédale de frein 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Serrer le boulon de raidisseur supérieur d&#39;auvent au couple spécifié. 
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
 Boulon de raidisseur supérieur d&#39;auvent 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410042.swf" width = "88.000mm" height = "64.412mm" ver = "02" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Reposer le panneau de combiné d&#39;instruments. 
</ptxt>
</s1>
<s1>
<ptxt>
Brancher la durite à dépression sur le servofrein. 
</ptxt>
</s1>
<s1>
<ptxt>
Poser l&#39;ensemble de maître-cylindre sur le servofrein. 
</ptxt>
</s1>
<s1>
<ptxt>
Brancher les canalisations de frein (1) sur l&#39;ensemble de groupe hydraulique/module de commande de système ESP<sup>&#174;</sup> (2) à l&#39;aide de l&#39;outil spécial. 
</ptxt>
<torque>
<torqueitem id = "T4A009">
<t-part>
 Ecrou évasé de tuyau de frein 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 19 
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
 09950-78220 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410043.swf" width = "88.000mm" height = "46.684mm" ver = "02" gw = "119" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Après la repose, purger le système de freinage. 
<intxreftitleoff1 refid = "AFRAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
S&#39;assurer que les pièces reposées ne présentent aucune fuite de liquide de frein. 
</ptxt>
</s1>
<s1>
<ptxt>
Vérifier le jeu de la pédale de frein. 
<intxreftitleoff1 refid = "AFRAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
S&#39;assurer que le système de freinage fonctionne correctement et qu&#39;il ne présente pas de fuite de liquide de frein. 
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
