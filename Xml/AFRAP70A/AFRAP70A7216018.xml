<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A7216018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du détendeur 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A7216007">Pièces constitutives de l&#39;unité HVAC:Type manuel</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A7216018001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Récupérer le réfrigérant du système A/C à l&#39;aide de l&#39;appareil de récupération et de recyclage en se reportant à &#34;Récupération&#34; au point 
<intxref refid = "AFRAP70A7216007">Pièces constitutives de l&#39;unité HVAC:Type manuel</intxref>
. 
</ptxt>
</s1>
<s1>
<ptxt>
Desserrer le boulon (1) puis déposer le tuyau de liquide et la durite d&#39;aspiration du détendeur (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Desserrer les boulons (3) et déposer le détendeur. 
</ptxt>
<figure>
<graphic graphicname = "I4RS0A720028.swf" width = "88.000mm" height = "43.902mm" ver = "01" gw = "173" gh = "109"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A7216018002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A7216019">Vérification du détendeur:Type manuel</intxrefpoff>
</ptxt>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Enduire d&#39;huile de compresseur le joint torique du détendeur et les tuyaux. 
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B104" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Huile de compresseur
</m-desc>
<m-number>
99000-99095-00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Serrer les boulons du détendeur au couple spécifié. 
</ptxt>
<torque>
<torqueitem id = "T7B102">
<t-part>
 Boulon de détendeur 
</t-part>
<t-value1>
7,0
</t-value1>
<t-value2>
0,7
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Purger et remplir le système A/C en se reportant à &#34;Purge&#34; et &#34;Remplissage&#34; au point 
<intxref refid = "AFRAP70A7216001">Procédure de remplissage de réfrigérant:Type manuel</intxref>
. 
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
