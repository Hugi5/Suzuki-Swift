<title>
Force de freinage insuffisante 
</title>
<diag type = "condition">
<condition>
<ptxt>
Force de freinage insuffisante 
</ptxt>
</condition>
<ps>
<ptxt>
Fuite de liquide de frein des canalisations de frein 
</ptxt>
</ps>
<action>
<ptxt>
Localiser la fuite et réparer. 
</ptxt>
</action>
<ps>
<ptxt>
Disque de frein ou plaquettes tachées de liquide, de graisse ou d&#39;une autre huile 
</ptxt>
</ps>
<action>
<ptxt>
Nettoyer ou remplacer. 
</ptxt>
</action>
<ps>
<ptxt>
Freins surchauffés 
</ptxt>
</ps>
<action>
<ptxt>
Déterminer la cause et réparer. 
</ptxt>
</action>
<ps>
<ptxt>
Plaquette de frein complètement usée 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer. 
</ptxt>
</action>
<ps>
<ptxt>
Dysfonctionnement de l&#39;ensemble d&#39;étrier de frein 
</ptxt>
</ps>
<action>
<ptxt>
Réparer ou remplacer. 
</ptxt>
</action>
<ps>
<ptxt>
Air dans le système 
</ptxt>
</ps>
<action>
<ptxt>
Purger l&#39;air du système de freinage. 
</ptxt>
</action>
<ps>
<ptxt>
Dysfonctionnement interne du servofrein 
</ptxt>
</ps>
<action>
<ptxt>
Remplacer le servofrein. 
</ptxt>
</action>
<ps>
<ptxt>
La pression négative pour le servofrein n&#39;est pas adéquate 
</ptxt>
</ps>
<action>
<ptxt>
Vérifier l&#39;état du moteur et la durite à dépression. 
</ptxt>
</action>
<ps>
<ptxt>
ESP<sup>&#174;</sup> défectueux
</ptxt>
</ps>
<action>
<ptxt>
Vérifier le système et remplacer si nécessaire. 
</ptxt>
</action>
</diag>
