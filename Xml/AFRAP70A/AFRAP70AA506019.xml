<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70AA506019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Remplacement de la batterie de dispositif de commande à distance
</title>
<s1>
<ptxt>
Déposer la clé de secours (4).
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le carter supérieur (1) à l&#39;aide d&#39;un tournevis à tête plate comme indiqué sur le schéma.
</ptxt>
</s1>
<s1>
<ptxt>
Déposer le circuit imprimé (2) du carter inférieur (3).
</ptxt>
<figure>
<graphic graphicname = "IAW101A50043.swf" width = "88.000mm" height = "73.205mm" ver = "01" gw = "163" gh = "191"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.291in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.847in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Chiffon d&#39;atelier
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Déposer la batterie (2) à l&#39;aide d&#39;un tournevis à tête plate (1) comme indiqué sur le schéma.
</ptxt>
<figure>
<graphic graphicname = "IAW101A50044.swf" width = "88.000mm" height = "32.419mm" ver = "01" gw = "169" gh = "75"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.125in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Chiffon d&#39;atelier
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Placer la pile (lithium de type rond CR 2032 ou pile équivalente) (1) en orientant sa borne &#34;–&#34; vers le repère &#34;–&#34; du circuit imprimé (2).
</ptxt>
<figure>
<graphic graphicname = "IAW101A50045.swf" width = "88.000mm" height = "37.223mm" ver = "01" gw = "130" gh = "89"/>
</figure>
</s1>
<s1>
<ptxt>
Reposer le circuit imprimé sur le carter inférieur et fixer ensuite correctement le carter supérieur.
</ptxt>
<attention3>
<ptxt>
Jeter la pile usagée conformément aux lois et règlements en vigueur. Ne pas jeter les piles au lithium avec les ordures ménagères.
</ptxt>
</attention3>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
