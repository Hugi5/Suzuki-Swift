<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9506009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du rétroviseur intérieur 
</title>
<servinfosub id = "AFRAP70A9506009001">
<title>
Dépose 
</title>
<ptxt>
Déposer le boulon de rétroviseur intérieur (TORX<sup>&#174;</sup> T20) (1) et faire glisser le rétroviseur (2) dans le sens de la flèche. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A950021.swf" width = "88.000mm" height = "49.005mm" ver = "01" gw = "227" gh = "122"/>
</figure>
</servinfosub>
<servinfosub id = "AFRAP70A9506009002">
<title>
Repose 
</title>
<ptxt>
Pour la repose, procéder dans l&#39;ordre inverse de la dépose en tenant compte des points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer le boulon de rétroviseur intérieur au couple prescrit. 
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9E001">
<t-part>
 Boulon de rétroviseur intérieur 
</t-part>
<t-value1>
3,5
</t-value1>
<t-value2>
0,36
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
