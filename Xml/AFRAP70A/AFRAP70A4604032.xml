<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AFRAP70A4604032" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1069
</title>
<servinfosub id = "AFRAP70A4604032001">
<title>
Condition de détection du DTC et organe incriminé 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.536in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.635in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition de détection du DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Organe incriminé 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1069: Spécification du capteur d&#39;angle de braquage non enregistrée 
</emph>
</ptxt>
<ptxt>
Le module de commande ESP<sup>&#174;</sup> détecte que le capteur d&#39;angle de braquage qui est posé a été utilisé sur un autre véhicule. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Module de commande ESP<sup>&#174;</sup>
</ptxt>
</item>
<item>
<ptxt>
Capteur d&#39;angle de braquage 
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AFRAP70A4604032002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A4604032003">
<testgroup id = "AFRAP70A4604032004">
<title>
Vérification de DTC 
</title>
<test1>
<ptxt>
Remplacer le capteur d&#39;angle de braquage. 
<intxreftitleoff1 refid = "AFRAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Suivre le point 
<intxref refid = "AFRAP70A4604005">Vérification des DTC</intxref>
. 
</ptxt>
</test1>
<question>
Le DTC C1069 est-il détecté? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Remplacer l&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> et vérifier à nouveau le DTC. 
<intxreftitleoff1 refid = "AFRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
