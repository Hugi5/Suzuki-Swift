<intxreftitleoff1 refid = "AFRAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Combiné d&#39;instruments défectueux 
</ptxt>
</ps>
