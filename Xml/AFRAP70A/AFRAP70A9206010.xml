<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;éclairage local (si le véhicule en est équipé)
</title>
<servinfosub id = "AFRAP70A9206010001">
<title>
Dépose
</title>
<s1>
<ptxt>
Déposer l&#39;éclairage local (1) tout en libérant les dispositifs de verrouillage (2).
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher le connecteur de l&#39;éclairage local.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920027.jpg" width = "88.000mm" height = "68.223mm" ver = "02" gw = "199" gh = "177"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer la douille d&#39;ampoule (1) de l&#39;éclairage local (2), et déposer les ampoules.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920015.jpg" width = "88.000mm" height = "57.222mm" ver = "01" gw = "204" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AFRAP70A9206010002">
<title>
Repose
</title>
<ptxt>
Procéder dans l&#39;ordre inverse de la dépose.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
