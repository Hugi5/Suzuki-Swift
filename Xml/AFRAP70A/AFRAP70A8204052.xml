<servinfosub id = "AFRAP70A8204052002">
<title>
Recherche de pannes à partir de DTC 
</title>
<diag type = "test" id = "AFRAP70A8204052003">
<testgroup id = "AFRAP70A8204052004">
<title>
Vérification de la tension de la batterie 
</title>
<test1>
<ptxt>
Vérifier la tension de la batterie. 
</ptxt>
</test1>
<question>
La tension est-elle de 9 – 16 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vérifier le système de charge et le réparer. 
<intxreftitleoff1 refid = "AFRAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204052005">
<title>
Vérification du branchement du SDM 
</title>
<test1>
<ptxt>
Vérifier le branchement au connecteur SDM. 
</ptxt>
</test1>
<question>
Le raccordement est-il correct? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Problème intermittent. Vérifier les pannes intermittentes. 
<intxreftitleoff1 refid = "AFRAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Si tout est correct, remplacer le SDM par un élément en bon état et vérifier à nouveau le raccordement. 
<intxreftitleoff1 refid = "AFRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204052006">
<title>
Vérification du fusible 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Vérifier le fusible &#34;A/B&#34;. 
</ptxt>
</test1>
<question>
Le fusible &#34;A/B&#34; est-il en bon état? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de plancher puis remplacer le fusible &#34;A/B&#34;. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204052007">
<title>
Vérification du circuit d&#39;alimentation électrique 
</title>
<test1>
<ptxt>
S&#39;assurer que l&#39;allumage est en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Débrancher le connecteur &#34;L04&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;ON&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la tension entre la borne &#34;L04-18&#34; et la masse. 
</ptxt>
<servicetool>
<servicetoolitem id = "L8B095">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820157.swf" width = "90.000mm" height = "34.401mm" ver = "01" gw = "194" gh = "81"/>
</testfigure>
</test1>
<question>
La tension est-elle de 10 – 14 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Passer à l&#39;étape 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de plancher. 
</ptxt>
</action>
</testgroup>
<testgroup id = "AFRAP70A8204052008">
<title>
Vérification du circuit de mise à la masse 
</title>
<test1>
<ptxt>
Mettre l&#39;allumage en position &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Mesurer la résistance entre la borne &#34;L04-23&#34; et la masse. 
</ptxt>
<servicetool>
<servicetoolitem id = "L8B096">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
 09932-76010 
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820158.swf" width = "90.000mm" height = "34.895mm" ver = "01" gw = "193" gh = "82"/>
</testfigure>
</test1>
<question>
La résistance est-elle de 1 &#937; maximum? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Le circuit d&#39;alimentation électrique et le circuit de mise à la masse du SDM sont en bon état. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Remplacer le faisceau de câbles de plancher. 
</ptxt>
</action>
</testgroup>
