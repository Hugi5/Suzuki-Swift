<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose de l&#39;ensemble de toit ouvrant 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9906001">Pièces constitutives du toit ouvrant</intxrefpoff>
</ptxt>
<servinfosub id = "AFRAP70A9906002001">
<title>
Dépose 
</title>
<s1>
<ptxt>
Déposer la garniture de toit. 
<intxreftitleoff1 refid = "AFRAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la vitre de toit ouvrant. 
<intxreftitleoff1 refid = "AFRAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Débrancher les durites de purge (1) branchées en 4 emplacements sur l&#39;ensemble de toit ouvrant. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990005.jpg" width = "88.000mm" height = "75.169mm" ver = "01" gw = "227" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Débrancher le connecteur du moteur de toit ouvrant (1). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990006.jpg" width = "88.000mm" height = "69.556mm" ver = "01" gw = "225" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Détacher les attaches (1) et le faisceau de câbles de toit ouvrant (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990007.jpg" width = "88.000mm" height = "61.392mm" ver = "01" gw = "227" gh = "158"/>
</figure>
</s1>
<s1>
<ptxt>
Déposer les écrous de logement de toit ouvrant (1) puis, déposer l&#39;ensemble de toit ouvrant (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990008.jpg" width = "88.000mm" height = "83.554mm" ver = "01" gw = "227" gh = "220"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AFRAP70A9906002002">
<title>
Repose 
</title>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrer chaque élément au couple spécifié en se reportant au point 
<intxref refid = "AFRAP70A9906001">Pièces constitutives du toit ouvrant</intxref>
. 
</ptxt>
</item>
<item>
<ptxt>
Serrer les écrous de logement de toit ouvrant (1) dans l&#39;ordre (de &#34;1&#34; à &#34;4&#34;) comme indiqué sur le schéma. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990009.jpg" width = "88.000mm" height = "82.828mm" ver = "01" gw = "227" gh = "218"/>
</figure>
</item>
<item>
<ptxt>
Débrancher les durites de purge (1) branchées en 4 emplacements sur l&#39;ensemble de toit ouvrant. Fixer correctement les attaches (2) des durites de purge. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990010.jpg" width = "88.000mm" height = "75.168mm" ver = "01" gw = "227" gh = "197"/>
</figure>
<figure>
<title>
Montant avant 
</title>
<graphic graphicname = "I9P60A990011.swf" width = "88.000mm" height = "95.842mm" ver = "02" gw = "210" gh = "255"/>
</figure>
<figure>
<title>
Panneau de custode 
</title>
<graphic graphicname = "I9P60A990013.swf" width = "88.000mm" height = "94.869mm" ver = "03" gw = "225" gh = "252"/>
</figure>
</item>
<item>
<ptxt>
Initialiser le moteur de toit ouvrant. 
<intxreftitleoff1 refid = "AFRAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Après la repose de l&#39;ensemble de toit ouvrant, ne pas oublier de régler le positionnement de la vitre. 
<intxreftitleoff1 refid = "AFRAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
