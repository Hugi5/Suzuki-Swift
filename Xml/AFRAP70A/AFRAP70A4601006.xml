<servinfo servinfosgmlid = "AFRAP70A4601006" svcinfotypenbr = "03" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Description des conditions de calibrage de capteur 
</title>
<ptxt>
Lorsque les conditions suivantes sont remplies, le calibrage de capteur doit être effectué étant donné que les données de calibrage d&#39;origine sont effacées.<sup></sup>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1" page = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.646in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.558in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Capteur à calibrer 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition exigeant un calibrage 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Capteur d&#39;angle de braquage 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Le capteur d&#39;angle de braquage est remplacé. 
</ptxt>
</item>
<item>
<ptxt>
L&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> est remplacé. 
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Capteur de pression de maître-cylindre de frein 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
L&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> est remplacé. 
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Ensemble capteur d&#39;embardée/G 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
L&#39;ensemble de groupe hydraulique / module de commande ESP<sup>&#174;</sup> est remplacé. 
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
<ptxt>
Effectuer le calibrage de capteur en se reportant au point 
<intxref refid = "AFRAP70A4606002">Calibrage du capteur</intxref>
. 
</ptxt>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
