<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AFRAP70A9A06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Dépose et repose du capot 
</title>
<servinfosub id = "AFRAP70A9A06001001">
<title>
Dépose 
</title>
<attention2>
<ptxt>
Couvrir la carrosserie du véhicule d&#39;un chiffon pour éviter de l&#39;endommager. 
</ptxt>
</attention2>
</servinfosub>
<s1>
<ptxt>
Déposer les 4 boulons de charnière de capot (1) pour détacher le capot (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Déposer la charnière de capot après avoir déposé l&#39;aile avant, si nécessaire. 
<intxreftitleoff1 refid = "AFRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<servinfosub id = "AFRAP70A9A06001002">
<title>
Repose 
</title>
<ptxt>
<intxrefpoff refid = "AFRAP70A9A06002">Vérification et réglage du capot</intxrefpoff>
</ptxt>
<ptxt>
Procéder en ordre inverse de la dépose en notant les points suivants. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Appliquer du produit d&#39;étanchéité sur la surface de contact &#34;A&#34; de la charnière de capot. 
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1215" id = "M9J001" uid = "27">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Produit d&#39;étanchéité
</m-desc>
<m-number>
 99000-31110 
</m-number>
<m-name>
SUZUKI Bond No.1215
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Régler la position de la serrure de capot si nécessaire. 
<intxreftitleoff1 refid = "AFRAP70A9A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Si de la peinture s&#39;est détachée des boulons de charnière de capot, appliquer une nouvelle couche de peinture pour les empêcher de rouiller. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A9A0001.swf" width = "88.000mm" height = "90.826mm" ver = "01" gw = "226" gh = "241"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
