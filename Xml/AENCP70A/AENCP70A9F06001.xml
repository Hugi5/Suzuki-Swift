<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9F06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Audio Unit Removal and Installation (If Equipped)
</title>
<servinfosub id = "AENCP70A9F06001001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove center ventilation louver. 
<intxreftitleoff1 refid = "AENCP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove audio unit (1) from instrument panel by removing 2 mounting screws (2).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect audio unit connectors (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0004.jpg" width = "88.000mm" height = "63.065mm" ver = "03" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9F06001002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
