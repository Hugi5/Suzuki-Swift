<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5206018" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Transaxle Left Case Disassembly and Reassembly
</title>
<servinfosub id = "AENCP70A5206018001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Replace differential side oil seal from transaxle left case, if necessary. 
<intxreftitleoff1 refid = "AENCP70A5206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove input oil gutter (1) and breather plate (2) from transaxle left case, if necessary.
</ptxt>
<figure>
<graphic graphicname = "I9P60A521040.swf" width = "88.000mm" height = "50.244mm" ver = "01" gw = "152" gh = "126"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5206018002">
<title>
Reassembly
</title>
<ptxt>
Reverse disassembly procedure, noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten new oil gutter bolt (1) and new breather plate bolts (2) to specified torque.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T5B021">
<t-part>
Oil gutter bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
<torqueitem id = "T5B022">
<t-part>
Breather plate bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A521041.swf" width = "88.000mm" height = "53.874mm" ver = "01" gw = "152" gh = "136"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
