</ptxt>
</item>
<item>
<ptxt>
Passenger air bag (inflator) module 
<intxreftitleoff1 refid = "AENCP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Seat belt pretensioner 
<intxreftitleoff1 refid = "AENCP70A8106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Side-air bag (inflator) module 
<intxreftitleoff1 refid = "AENCP70A8206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
