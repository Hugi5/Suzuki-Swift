<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear End Door Lock Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A9606010">Rear End Door Lock Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENCP70A9606011">Rear End Door Latch On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A9606012001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear end door trim (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70P960027.jpg" width = "88.000mm" height = "80.582mm" ver = "01" gw = "198" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect rear end door lock connector (1) from rear end door lock assembly (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear end door lock bolts (3) and remove rear end door lock assembly (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A960004.jpg" width = "88.000mm" height = "53.858mm" ver = "01" gw = "142" gh = "136"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9606012002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten rear end door lock bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9F002">
<t-part>
Rear end door lock bolt
</t-part>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Adjust rear end door latch striker as follows if necessary.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Loosen rear end door latch striker screws (1)
</ptxt>
</item>
<item>
<ptxt>
Adjust rear end door latch striker (2) position so that rear end door can be opened and closed smoothly.
</ptxt>
</item>
<item>
<ptxt>
Tighten rear end door latch striker screws to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9F003">
<t-part>
Rear end door latch striker screw
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A960018.jpg" width = "88.000mm" height = "61.730mm" ver = "02" gw = "198" gh = "158"/>
</figure>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
