<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5206020" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "1">
<title>
Input Shaft Assembly Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5206019">Input Shaft and Countershaft Assembly Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENCP70A5206016">Manual Transaxle Assembly Disassembly and Reassembly</intxrefpoff>
</ptxt>
<attention1>
<ptxt>
Using an inappropriate hydraulic press or bearing puller could cause personal injury.
</ptxt>
<ptxt>
Check that both the hydraulic press and bearing puller are capable of safely bearing a load of at least 5 tons (11,000 lbs).
</ptxt>
</attention1>
<attention2>
<ptxt>
Supporting the gear on the concave side of the puller can cause damage to the gear.
</ptxt>
<ptxt>
Support the gear on the flat side of the puller.
</ptxt>
</attention2>
<servinfosub id = "AENCP70A5206020001" page = "2">
<title>
Disassembly
</title>
<s1 page = "2">
<ptxt>
Remove input shaft right bearing (2) from input shaft (1) using bearing puller (3) and hydraulic press.
</ptxt>
<figure>
<graphic graphicname = "IYSY01521048.swf" width = "88.000mm" height = "46.936mm" ver = "01" gw = "136" gh = "116"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove 5th gear spacer (2), left bearing (3) and 4th gear (5) from input shaft (1) using bearing puller (4) and hydraulic press.
</ptxt>
<figure>
<graphic graphicname = "I4RS0B521034.swf" width = "88.000mm" height = "54.967mm" ver = "02" gw = "176" gh = "139"/>
</figure>
</s1>
<s1>
<ptxt>
Remove needle bearing and high speed synchronizer ring.
</ptxt>
</s1>
<s1>
<ptxt>
Using snap ring pliers (2), remove circlip (1).
</ptxt>
<figure>
<graphic graphicname = "I7V20A521025.swf" width = "88.000mm" height = "44.354mm" ver = "01" gw = "130" gh = "109"/>
</figure>
</s1>
<s1>
<ptxt>
Remove high speed synchronizer sleeve &#38; hub assembly (2) together with 3rd gear (3) from input shaft (1) using bearing puller (4) and hydraulic press.
</ptxt>
<figure>
<graphic graphicname = "I4RS0B521035.swf" width = "88.000mm" height = "50.134mm" ver = "01" gw = "177" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Remove 3rd gear needle bearing from shaft.
</ptxt>
</s1>
<s1>
<ptxt>
Disassemble high speed synchronizer sleeve &#38; hub assembly.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5206020002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Clean all components thoroughly, inspect them for any abnormal condition and replace them with new ones if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
To ensure lubrication of input shaft (1), blow air into oil holes (2) as shown in figure and make sure that they are free from any obstruction.
</ptxt>
<figure>
<graphic graphicname = "I2RH01520049.swf" width = "88.000mm" height = "46.047mm" ver = "01" gw = "187" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Fit high speed synchronizer sleeve (4) to hub (3), insert 3 keys (2) in it and then set springs (1) at specified position as shown in figure.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to assemble sleeve and hub in correct direction. (No direction is specified to each key.)
</ptxt>
</item>
<item>
<ptxt>
High speed synchronizer sleeve, hub, keys and springs are between those of low speed and 5th speed ones in size.
</ptxt>
</item>
</list1>
</attention3>
<spec>
<title>
Synchronizer key installation position
</title>
<ptxt>
“a” = “b”
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A521050.swf" width = "88.000mm" height = "91.979mm" ver = "03" gw = "196" gh = "244"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.000in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.098in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
3rd gear side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[C]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Projecting end
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Long flange
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Install right bearing (1) to input shaft (2) using special tool and hydraulic press.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B015">
<s-part>
(A)
</s-part>
<s-number num = "09913-80113">
09913–80113
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I4RS0B521037.swf" width = "88.000mm" height = "46.816mm" ver = "01" gw = "75" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Install 3rd gear needle bearing (4), apply oil to it, then install 3rd gear (1) and synchronizer ring (2).
</ptxt>
</s1>
<s1>
<ptxt>
Install high speed synchronizer sleeve &#38; hub assembly (3) using special tool and hammer, facing long flange side of hub to 3rd gear as shown in figure.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Make sure that synchronizer ring key slots are aligned with keys (5) in sleeve &#38; hub assembly.
</ptxt>
</item>
<item>
<ptxt>
Check free rotation of 3rd gear after press-fitting sleeve &#38; hub assembly.
</ptxt>
</item>
<item>
<ptxt>
Synchronizer rings for 3rd and 4th are identical.
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B016">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913–84510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A521046.swf" width = "88.000mm" height = "99.254mm" ver = "02" gw = "192" gh = "265"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.000in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.014in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
3rd gear side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[C]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Long flange
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Key slots
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[D]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Projecting end
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install new circlip (1) and confirm that circlip is installed in groove securely.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install needle bearing (2), apply oil to it, and then synchronizer ring (3) and 4th gear (4).
</ptxt>
<figure>
<graphic graphicname = "I2RH01520052.swf" width = "88.000mm" height = "45.751mm" ver = "01" gw = "170" gh = "113"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.928in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Input shaft
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Press-fit left bearing (1) using special tool and hydraulic press.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B017">
<s-part>
(A)
</s-part>
<s-number num = "09925-98221">
09925–98221
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I4RS0B521039.swf" width = "88.000mm" height = "46.597mm" ver = "01" gw = "164" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Using the same special tool at Step 9), install 5th gear spacer (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L5B018">
<s-part>
(A)
</s-part>
<s-number num = "09925-98221">
09925–98221
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I4RS0B521040.swf" width = "88.000mm" height = "48.682mm" ver = "01" gw = "149" gh = "121"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
