<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A9904001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Power Sun Roof System Symptom Diagnosis
</title>
<diag type = "condition" id = "AENCP70A9904001001">
<condition>
<ptxt>
Sun roof cannot operate (sun roof motor can operate)
</ptxt>
</condition>
<ps>
<ptxt>
Some object stuck in sun roof rail
</ptxt>
</ps>
<action>
<ptxt>
Remove or clean stuck object.
</ptxt>
</action>
<ps>
<ptxt>
Incorrect installation of sun roof rail
</ptxt>
</ps>
<action>
<ptxt>
Install correctly.
</ptxt>
</action>
<ps>
<ptxt>
Interference of sun roof parts
</ptxt>
</ps>
<action>
<ptxt>
Fix interference.
</ptxt>
</action>
<ps>
<ptxt>
Incorrect installation of sun roof drive cable
</ptxt>
</ps>
<action>
<ptxt>
Install correctly.
</ptxt>
</action>
<condition>
<ptxt>
Auto slide and auto tilt cannot operate (manual operation only)
</ptxt>
</condition>
<ps>
<ptxt>
Initialization is defective
</ptxt>
</ps>
<action>
<ptxt>
Initialize sun roof motor. 
<intxreftitleoff1 refid = "AENCP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Incorrect installation position of sun roof glass
</ptxt>
</ps>
<action>
<ptxt>
Adjust sun roof glass mounting position. 
<intxreftitleoff1 refid = "AENCP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty sliding movement of sun roof unit
</ptxt>
</ps>
<action>
<ptxt>
Replace sun roof unit. 
<intxreftitleoff1 refid = "AENCP70A9906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty sun roof motor
</ptxt>
</ps>
<action>
<ptxt>
Replace sun roof motor. 
<intxreftitleoff1 refid = "AENCP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Sun roof cannot operate (sun roof motor cannot operate)
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Replace fuse.
</ptxt>
</action>
<ps>
<ptxt>
Faulty sun roof switch
</ptxt>
</ps>
<action>
<ptxt>
Check sun roof switch. 
<intxreftitleoff1 refid = "AENCP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Check circuit. 
<intxreftitleoff1 refid = "AENCP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AENCP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty sun roof motor
</ptxt>
</ps>
<action>
<ptxt>
Check sun roof motor. 
<intxreftitleoff1 refid = "AENCP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Rain leakage
</ptxt>
</condition>
<ps>
<ptxt>
Incorrect installation position of the sun roof glass
</ptxt>
</ps>
<action>
<ptxt>
Adjust sun roof glass mounting position. 
<intxreftitleoff1 refid = "AENCP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty sun roof glass
</ptxt>
</ps>
<action>
<ptxt>
Replace sun roof glass. 
<intxreftitleoff1 refid = "AENCP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disconnected or clogged drain hose (front / rear)
</ptxt>
</ps>
<action>
<ptxt>
Check drain hose (front / rear).
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
