<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70AA316001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Immobilizer Control Module Removal and Installation
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
As immobilizer control module consists of precision parts, be careful not to expose it to excessive shock.
</ptxt>
</item>
<item>
<ptxt>
Do not disassemble immobilizer control module.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENCP70AA316001001">
<title>
Removal
</title>
<s1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering column upper and lower covers. 
<intxreftitleoff1 refid = "AENCP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector (1) from immobilizer control module (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove screw (3) from immobilizer control module.
</ptxt>
</s1>
<s1>
<ptxt>
Remove immobilizer control module from steering lock assembly as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA31004.jpg" width = "88.000mm" height = "60.854mm" ver = "01" gw = "197" gh = "156"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70AA316001002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
