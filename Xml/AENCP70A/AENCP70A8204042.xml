<servinfosub id = "AENCP70A8204042003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A8204042004">
<testgroup id = "AENCP70A8204042005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A8204042006">
<title>
Curtain air bag (inflator) module check
</title>
<test1>
<ptxt>
Confirm that ignition is in “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to “L290” or “L291” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “L290” or “L291” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Connect “STEERING WHEEL” (1) of special tools (A), (B) and (C) to “L290” or “L291” connector.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B065">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B066">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932–78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B067">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932–75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820034.swf" width = "90.000mm" height = "73.606mm" ver = "02" gw = "199" gh = "192"/>
</testfigure>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENCP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1361 or DTC B1365 indicated?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace curtain air bag (inflator) module. 
<intxreftitleoff1 refid = "AENCP70A8206018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A8204042007">
<title>
Floor harness circuit check
</title>
<test1>
<ptxt>
Check for proper connection to “L05” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “L05” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector inserting release tool included in special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” and “A2” circuits (DTC B1361): 1 Ω or less
</ptxt>
</item>
<item>
<ptxt>
Resistance of “A3” and “A4” circuits (DTC B1365): 1 Ω or less
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B068">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820112.swf" width = "90.000mm" height = "67.845mm" ver = "01" gw = "219" gh = "176"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs, referring to 
<intxref refid = "AENCP70A8204006">DTC Clearance</intxref>
 if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENCP70A8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
