<servinfo servinfosgmlid = "AENCP70A1806004" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Ignition Coil Assembly Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1806003">Ignition Coil Assembly Removal and Installation</intxrefpoff>
</ptxt>
<ptxt>
Check ignition coil assembly for the following points:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Damage
</ptxt>
</item>
<item>
<ptxt>
Deterioration
</ptxt>
</item>
<item>
<ptxt>
Corrosion on terminals
</ptxt>
</item>
</list1>
<ptxt>
If check result is not OK, replace ignition coil assembly.
</ptxt>
</servinfo>
</servinfotype>
</configtype>
