<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Brake Booster Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4106020">Brake Booster Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A4106022001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect brake pipes (1) from ABS / ESP<sup>®</sup> hydraulic unit/control module assembly using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70B410008.swf" width = "88.000mm" height = "45.709mm" ver = "02" gw = "202" gh = "113"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.909in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.951in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
ABS model
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
ESP<sup>&#174;</sup> model
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove brake master cylinder assembly from booster. 
<intxreftitleoff1 refid = "AENCP70A4106017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For CVT model, disconnect brake booster switch connector from brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect vacuum hose from brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
Remove clip (1) and clevis pin (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70B410009.jpg" width = "88.000mm" height = "65.963mm" ver = "01" gw = "201" gh = "170"/>
</figure>
</s1>
<s1>
<ptxt>
Remove brake booster nuts (1) and remove brake booster from dash panel.
</ptxt>
<figure>
<graphic graphicname = "IAP70P410015.swf" width = "88.000mm" height = "59.821mm" ver = "01" gw = "189" gh = "153"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A4106022004">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4106023">Brake Booster Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Remove combination meter cluster panel. 
<intxreftitleoff1 refid = "AENCP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Loosen brake pedal bracket nut (1) and cowl upper stiffener bolt (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70B410011.swf" width = "88.000mm" height = "50.821mm" ver = "01" gw = "190" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Install brake booster to dash panel. Then connect clevis (3) to brake pedal arm with clevis pin (2) and clip (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70B410012.jpg" width = "88.000mm" height = "65.963mm" ver = "01" gw = "201" gh = "170"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten brake booster nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
Brake booster nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70B410013.swf" width = "88.000mm" height = "59.965mm" ver = "01" gw = "189" gh = "153"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten brake pedal bracket nut to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
Brake pedal bracket nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Tighten cowl upper stiffener bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A009">
<t-part>
Cowl upper stiffener bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70B410014.swf" width = "88.000mm" height = "51.600mm" ver = "01" gw = "190" gh = "130"/>
</figure>
</s1>
<s1>
<ptxt>
Install combination meter cluster panel.
</ptxt>
</s1>
<s1>
<ptxt>
Connect vacuum hose to brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
For CVT model, connect brake booster switch connector to brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
Install brake master cylinder assembly to brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
Connect brake pipes (1) to ABS / ESP<sup>®</sup> hydraulic unit / control module assembly using special tool.
</ptxt>
<torque>
<torqueitem id = "T4A010">
<t-part>
Brake pipe flare nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1.6
</t-value2>
<t-value3>
12.0
</t-value3>
<ptxt>
(ABS model)
</ptxt>
</torqueitem>
<torqueitem id = "T4A011">
<t-part>
Brake pipe flare nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1.9
</t-value2>
<t-value3>
14.0
</t-value3>
<ptxt>
(ESP<sup>&#174;</sup> model)
</ptxt>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70B410010.swf" width = "88.000mm" height = "50.778mm" ver = "02" gw = "211" gh = "127"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.944in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.972in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
ABS model
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
ESP<sup>&#174;</sup> model
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
After installation, bleed brake system. 
<intxreftitleoff1 refid = "AENCP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check installed parts for brake fluid leakage.
</ptxt>
</s1>
<s1>
<ptxt>
Check brake pedal for play. 
<intxreftitleoff1 refid = "AENCP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Make sure that brake system operates properly without brake fluid leakage.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
