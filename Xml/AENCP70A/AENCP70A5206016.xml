<colspec colnum = "2" colname = "2" colwidth = "1.260in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
1.5 mm (0.059 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install new reverse gear shaft bolt (1) with new gasket (2) and tighten it to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5B015">
<t-part>
Reverse gear shaft bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A521020.swf" width = "88.000mm" height = "60.035mm" ver = "01" gw = "144" gh = "154"/>
</figure>
</s1>
<s1>
<ptxt>
Install steel ball (3), locating spring (2) and new washers (4) for respective gear shift shaft and tighten new gear shift locating bolts (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5B016">
<t-part>
Gear shift locating bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A521035.swf" width = "88.000mm" height = "61.118mm" ver = "02" gw = "197" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
To seat countershaft left bearing outer race (1) to bearing cone, tap countershaft left bearing outer race (1) using special tool and plastic hammer (3).
</ptxt>
<servicetool>
<servicetoolitem id = "L5B009">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913–84510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A521036.swf" width = "88.000mm" height = "47.571mm" ver = "02" gw = "142" gh = "118"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
