<s2>
<ptxt>
Turn countershaft (3) 10 times or more.
</ptxt>
<figure>
<graphic graphicname = "I9P60A521066.jpg" width = "88.000mm" height = "71.041mm" ver = "01" gw = "238" gh = "185"/>
