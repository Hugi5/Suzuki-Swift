<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Generator Removal and Installation
</title>
<servinfosub id = "AENCP70A1A06005001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust No.1 pipe. 
<intxreftitleoff1 refid = "AENCP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump / generator drive belt. 
<intxreftitleoff1 refid = "AENCP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect “B” terminal wire (1) and connector (2) from generator (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove generator (3) and take generator out of engine compartment between front suspension member and front drive shaft assembly.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1005.jpg" width = "88.000mm" height = "66.800mm" ver = "01" gw = "237" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1A06005002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten generator bolt and generator pivot bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1J003">
<t-part>
Generator bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
<torqueitem id = "T1J004">
<t-part>
Generator pivot bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4.6
</t-value2>
<t-value3>
33.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Connect wire (1) to generator as shown in figure, and tighten “B” terminal nut to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1J005">
<t-part>
“B” terminal nut
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7.9
</t-value1>
<t-value2>
0.81
</t-value2>
<t-value3>
6.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1A1006.jpg" width = "88.000mm" height = "61.151mm" ver = "02" gw = "237" gh = "157"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
