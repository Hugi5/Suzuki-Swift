<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4106010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Brake Light Switch Removal and Installation
</title>
<servinfosub id = "AENCP70A4106010001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove steering column hole cover. 
<intxreftitleoff1 refid = "AENCP70A6206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect brake light switch connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove brake light switch (2) from brake pedal assembly.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A410013.swf" width = "88.000mm" height = "51.187mm" ver = "01" gw = "167" gh = "129"/>
</figure>
</servinfosub>
<servinfosub id = "AENCP70A4106010002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4106011">Brake Light Switch Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install brake light switch (1) as follows:
</ptxt>
<ptxt>
With brake pedal (2) pulled toward driver&apos;s seat, insert brake light switch into hole of pedal bracket until switch end contacts brake pedal.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410045.swf" width = "88.000mm" height = "51.187mm" ver = "02" gw = "167" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Confirm clearance “a” between brake light switch and brake pedal is within the specified value when brake pedal is free.
</ptxt>
<ptxt>
LHD: 1.0 – 2.0 mm (0.0039 – 0.078 in.)
</ptxt>
<ptxt>
RHD: 1.1 – 2.1 mm (0.0043 – 0.082 in.)
</ptxt>
<figure>
<graphic graphicname = "I9P60A410015.swf" width = "88.000mm" height = "51.402mm" ver = "01" gw = "142" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Connect brake light switch connector.
</ptxt>
</s1>
<s1>
<ptxt>
Install steering column cover. 
<intxreftitleoff1 refid = "AENCP70A6206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
