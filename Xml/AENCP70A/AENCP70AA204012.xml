<servinfosub id = "AENCP70AA204012003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70AA204012004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70AA204012005">
<testgroup id = "AENCP70AA204012006">
<title>
Parameter check
</title>
<test1>
<ptxt>
Connect SUZUKI scan tool to DLC when ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Battery Voltage”, “Ignition 1 Switch” and “ACC Switch” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENCP70AA204008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA204012007">
<title>
Circuit fuse check
</title>
<test1>
<ptxt>
Set ignition is “OFF”, and then remove “DOME” fuse and “HAZ” fuse from J/B.
</ptxt>
</test1>
<test1>
<ptxt>
Check “DOME” fuse and “HAZ” fuse.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace circuit fuse(s).
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA204012008">
<title>
BCM backup power supply circuit check
</title>
<test1>
<ptxt>
Disconnect “E323” and “E324” connectors from junction block.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “E323” and “E324” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voltage of “A1” circuit and ground: Battery voltage
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A2” circuit and ground: Battery voltage
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check “WHT/BLK” or “WHT” wire for open or short.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA204012009">
<title>
BCM back-up power supply circuit check
</title>
<test1>
<ptxt>
Disconnect “E04” connector from BCM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “E04” connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voltage of “A3” circuit and ground: Battery voltage
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A4” circuit and ground: Battery voltage
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace BCM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check “BRN” and/or “BLK/RED” wire(s) for open or short to ground.
</ptxt>
</action>
</testgroup>
</diag>
