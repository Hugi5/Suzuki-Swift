<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A8206002" svcinfotypenbr = "08" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
Enabling Air Bag System
</title>
<s1>
<ptxt>
Make sure that removed components are installed and/or disconnected connectors are connected properly.
</ptxt>
</s1>
<s1>
<ptxt>
Check that ignition is “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Connect negative (–) cable at battery and/or install “A/B” fuse to J/B. 
<intxreftitleoff1 refid = "AENCP70A8200003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Check if “AIR BAG” warning light flashes for about 6 seconds and then comes off.
</ptxt>
</s1>
<s1>
<ptxt>
Perform 
<intxref refid = "AENCP70A8201001">Air Bag System Construction</intxref>
 if defective.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
