<servinfosub id = "AENCP70A5504056002">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENCP70A5504056003">
<testgroup id = "AENCP70A5504056004">
<title>
CVT relay power supply circuit check
</title>
<test1>
<ptxt>
With ignition OFF, remove CVT relay from main fuse box.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to CVT relay connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check that voltage between each of “B1” and “B2” circuit and ground is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504056005">
<title>
CVT relay check
</title>
<test1>
<ptxt>
Check CVT relay. 
<intxreftitleoff1 refid = "AENCP70A5506005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace CVT relay (power integration).
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504056006">
<title>
TCM power supply circuit check
</title>
<test1>
<ptxt>
When ignition is OFF, install CVT relay to main fuse box.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between each of “A1” and “A2” circuit and ground is battery voltage.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504056007">
<title>
CVT relay drive circuit check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “B3” and ground is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504056008">
<title>
TCM power supply circuit 3 check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “A3” and ground is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504056009">
<title>
TCM ground circuit check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Check that resistance between each of “C1” and “C2” circuit and ground are less than 1 Ω.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
TCM power and ground circuit is in good condition.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
</diag>
