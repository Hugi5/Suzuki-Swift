<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1706006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Fuel Pipe Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1706001">Fuel System Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENCP70A1706005">Fuel Lines On-Vehicle Inspection</intxrefpoff>
</ptxt>
<attention1>
<ptxt>
When performing the following procedure, be sure to observe 
<intxref refid = "AENCP70A1700001">Precautions for Fuel System Service</intxref>
 to reduce the risk of fire and personal injury.
</ptxt>
</attention1>
<servinfosub id = "AENCP70A1706006001">
<title>
Removal
</title>
<s1>
<ptxt>
Relieve fuel pressure from fuel feed line. 
<intxreftitleoff1 refid = "AENCP70A1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect fuel hoses (3) from fuel pipes (2) at both front and rear ends of each fuel pipe. 
<intxreftitleoff1 refid = "AENCP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Mark the location of clamps (1) on fuel pipes (2), so that the clamps can be reinstalled to the original position.
</ptxt>
</s1>
<s1>
<ptxt>
Remove clamps (1) from vehicle body and fuel pipes.
</ptxt>
<attention2>
<ptxt>
Be careful not to bend and damage fuel pipes when removing clamp.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Remove fuel pipes (2).
</ptxt>
<figure>
<graphic graphicname = "I4RS0B170007.swf" width = "88.000mm" height = "42.608mm" ver = "01" gw = "173" gh = "104"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1706006002">
<title>
Installation
</title>
<s1>
<ptxt>
Install clamps to marked position on pipes. If clamp is deformed or has bent or broken claws, replace it with new one.
</ptxt>
</s1>
<s1>
<ptxt>
Install pipes with clamp to vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Connect fuel hoses to pipes. 
<intxreftitleoff1 refid = "AENCP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
With engine stopped, set ignition “ON” and check for fuel leaks. 
<intxreftitleoff1 refid = "AENCP70A1706004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
