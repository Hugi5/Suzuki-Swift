<servinfosub id = "AENCP70A1104019003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to troubleshoot first unexpected DTCs previously detected in “DTC Confirmation Procedure”.
</ptxt>
</item>
<item>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0107, P0108, P2119, P2135, P2138, P2228 or P2229 is not detected.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Run engine at idle speed for 30 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1104019004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A1104019005">
<testgroup id = "AENCP70A1104019006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104019007">
<title>
Air intake system check
</title>
<test1>
<ptxt>
Check air intake system for clogging or leakage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace air intake system.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104019008">
<title>
MAP sensor circuit check
</title>
<test1>
<ptxt>
Check MAP sensor circuits according to Steps 2 through 4 under 
<intxref refid = "AENCP70A1104020">DTC P0107 / P0108</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104019009">
<title>
MAP sensor check
</title>
<test1>
<ptxt>
Check MAP sensor. 
<intxreftitleoff1 refid = "AENCP70A1306007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace MAP sensor.
</ptxt>
</action>
</testgroup>
</diag>
