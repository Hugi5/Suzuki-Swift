</title>
<servinfosub id = "AENCP70A1104019001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.217in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.001in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0106: Manifold Absolute Pressure / Barometric Pressure Circuit Range / Performance
</emph>
</ptxt>
<ptxt>
Any of the following conditions is met.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Difference between measured and estimated MAP is out of specification for 5 sec.
</ptxt>
</item>
<item>
<ptxt>
MAP value at engine start is smaller than barometric pressure sensor value by more than specified value.
</ptxt>
</item>
</list1>
<ptxt>
(2 D/C detection logic but MIL does not light up)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
MAP sensor and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
Air intake system
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
