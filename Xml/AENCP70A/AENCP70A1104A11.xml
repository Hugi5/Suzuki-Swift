<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A1104A11" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Engine hesitates – Momentary lack of response as accelerator is depressed. Can occur at all vehicle speeds. Usually most severe when moving out from a stop at stop signal etc.
</title>
<ptxt>
Perform troubleshooting referring to the following points when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENCP70A1104008">Visual Inspection</intxref>
 and 
<intxref refid = "AENCP70A1104009">Engine Basic Inspection</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Engine hesitates – Momentary lack of response as accelerator is depressed. Can occur at all vehicle speeds. Usually most severe when moving out from a stop at stop signal etc.
</ptxt>
</condition>
<ps>
<ptxt>
Spark plug faulty or plug gap out of adjustment
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1806002">Spark Plug Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Fuel pressure out of specification
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1704005">Fuel Pressure Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Poor performance of ECT sensor or MAF sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1306011">ECT Sensor Inspection</intxref>
 or 
<intxref refid = "AENCP70A1306025">MAF and IAT Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty electric throttle body assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1306003">Electric Throttle Body Assembly On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty APP sensor assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1306007">APP Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty fuel injector
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1704003">Fuel Injector Circuit Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1104068">Inspection of ECM and Its Circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Engine overheating
</ptxt>
</ps>
<action>
<ptxt>
Condition “Engine overheating”
</ptxt>
</action>
<ps>
<ptxt>
Low compression
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1404001">Compression Check</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
