<intxref refid = "AENCP70A910A001">Connector Layout Diagram</intxref>
.
</ptxt>
<ptxt>
Refer to 
<intxref refid = "AENCP70A910E001">System Circuit Diagram</intxref>
.
</ptxt>
<ptxt>
