<servinfosub id = "AENCP70A1104058003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following conditions are met in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery voltage &#62; 10 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
IAT &#62; 5 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Set ignition “ON” with accelerator pedal released for 1 min.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1104058004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A1104058005">
<testgroup id = "AENCP70A1104058006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104058007">
<title>
Electric throttle control system calibration
</title>
<test1>
<ptxt>
Perform electric throttle control system calibration. 
<intxreftitleoff1 refid = "AENCP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Recheck DTC.
</ptxt>
</test1>
<question>
Is DTC P2176 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104058008">
<title>
Wire harness check
</title>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
TP sensor circuit (main): Refer to Step 2 through 4 under 
<intxref refid = "AENCP70A1104024">DTC P0122 / P0123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
TP sensor circuit (sub): Refer to Step 2 through 4 under 
<intxref refid = "AENCP70A1104030">DTC P0222 / P0223</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104058009">
<title>
TP sensor check
</title>
<test1>
<ptxt>
Check TP sensor referring to “Throttle Position (TP) Sensor Performance Check” under 
<intxref refid = "AENCP70A1306003">Electric Throttle Body Assembly On-Vehicle Inspection</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace electric throttle body assembly.
</ptxt>
</action>
</testgroup>
