<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1506008" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Oil Pump Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1506007">Oil Pump Assembly Disassembly and Reassembly</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A1506008001">
<title>
Oil Seal
</title>
<ptxt>
Check oil seal lip for defects and damage. Replace if defective.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B150023.swf" width = "88.000mm" height = "51.085mm" ver = "01" gw = "184" gh = "128"/>
</figure>
</servinfosub>
<servinfosub id = "AENCP70A1506008002">
<title>
Oil Pump
</title>
<list1 type = "unordered">
<item>
<ptxt>
Check outer (1) and inner rotors (2), rotor plate and oil pump case for excessive wear or damage.
</ptxt>
<figure>
<graphic graphicname = "I8C50A150028.swf" width = "88.000mm" height = "53.524mm" ver = "01" gw = "134" gh = "135"/>
</figure>
</item>
<item>
<ptxt>
Check that relief valve (1) is not excessively worn or damaged and operates smoothly.
</ptxt>
<figure>
<graphic graphicname = "I8C50A150029.swf" width = "88.000mm" height = "64.979mm" ver = "01" gw = "112" gh = "168"/>
</figure>
</item>
</list1>
<topic id = "AENCP70A1506008003">
<title>
Radial clearance
</title>
<ptxt>
Check radial clearance between outer rotor (1) and case (2) using feeler gauge.
</ptxt>
<ptxt>
If clearance is out of specification, replace oil pump assembly.
</ptxt>
<spec>
<title>
Radial clearance between outer rotor and case of oil pump
</title>
<ptxt>
Standard: 0.120 – 0.190 mm (0.0047 – 0.0075 in.)
</ptxt>
<ptxt>
Limit: 0.210 mm (0.0083 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151026.swf" width = "88.000mm" height = "49.550mm" ver = "01" gw = "171" gh = "124"/>
</figure>
</topic>
<topic id = "AENCP70A1506008004">
<title>
Side clearance
</title>
<ptxt>
Using straightedge (1) and feeler gauge (2), measure side clearance.
</ptxt>
<ptxt>
If side clearance is out of specification, replace oil pump assembly.
</ptxt>
<spec>
<title>
Side clearance of oil pump inner rotor
</title>
<ptxt>
Standard: 0.045 – 0.100 mm (0.0018 – 0.0039 in.)
</ptxt>
<ptxt>
Limit: 0.120 mm (0.0047 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151027.swf" width = "88.000mm" height = "52.842mm" ver = "01" gw = "185" gh = "133"/>
</figure>
</topic>
<topic id = "AENCP70A1506008005" page = "2">
<title>
Rotor plate clearance
</title>
<ptxt>
Check clearance between inner rotor (1) and rotor plate (2) as follows.
</ptxt>
<s1 page = "2">
<ptxt>
Measure outside diameter “a” of inner rotor (1) using micrometer.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Measure inside diameter “b” of rotor plate (2) using micrometer.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Calculate difference between measurements in Step 1) and Step 2).
</ptxt>
</s1>
<ptxt>
If clearance is out of specification, replace oil pump assembly.
</ptxt>
<spec>
<title>
Rotor plate clearance
</title>
<table frame = "all" colsep = "1" rowsep = "1" page = "2">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.806in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.643in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Standard
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Inner rotor outside diameter “a”
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
42.920 – 42.950 mm (1.6900 – 1.6909 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Rotor plate inside diameter “b”
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
43.000 – 43.030 mm (1.6929 – 1.6941 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Clearance “b” – “a”
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
0.050 – 0.110 mm (0.0020 – 0.0043 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<figure page = "2">
<graphic graphicname = "I9P60A151009.swf" width = "88.000mm" height = "95.850mm" ver = "01" gw = "161" gh = "255"/>
</figure>
</topic>
<topic id = "AENCP70A1506008006">
<title>
Relief valve spring free length and load
</title>
<ptxt>
Check free length and load of relief valve spring as shown in figure. If any of measurement is smaller than specification, replace relief valve spring.
</ptxt>
<spec>
<title>
Relief valve spring free length and load
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "3" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.216in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.118in"/>
<colspec colnum = "3" colname = "3" colwidth = "1.098in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Standard
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Limit
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Free length
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
32.7 mm
</ptxt>
<ptxt>
(1.29 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
—
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Load at spring length
</ptxt>
<ptxt>
26.0 mm (1.02 in.)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
52.9 – 56.1 N
</ptxt>
<ptxt>
(5.40 – 57.2 kgf, 11.9 – 12.6 lbf)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
48.3 N
</ptxt>
<ptxt>
(4.9 kgf, 10.9 lbf)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<figure>
<graphic graphicname = "I2RH01150023.swf" width = "88.000mm" height = "59.932mm" ver = "01" gw = "232" gh = "153"/>
</figure>
</topic>
</servinfosub>
</servinfo>
