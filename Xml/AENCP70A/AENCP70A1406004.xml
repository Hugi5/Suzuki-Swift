<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1406004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Air Cleaner Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1406001">Air Cleaner Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A1406004001" page = "2">
<title>
Removal
</title>
<s1 page = "2">
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Disconnect MAF and IAT sensor connector (1).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove EVAP canister purge valve (2).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect engine harness clamps.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Loosen air cleaner outlet hose clamp bolt and remove air cleaner assembly (3) with air suction pipe (4).
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner outlet hose (6) according to the following procedure if necessary.
</ptxt>
<s2>
<ptxt>
Disconnect breather pipe (5) from air cleaner outlet hose.
</ptxt>
</s2>
<s2>
<ptxt>
Remove air cleaner outlet hose.
</ptxt>
</s2>
<figure>
<graphic graphicname = "I9P60A141019.jpg" width = "88.000mm" height = "98.987mm" ver = "01" gw = "199" gh = "264"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1406004002" page = "2">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
