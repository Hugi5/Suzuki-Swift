<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9A06010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Fuel Filler Door Removal and Installation
</title>
<servinfosub id = "AENCP70A9A06010001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove fuel filler cap tether (1) from fuel filler door (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove fuel filler door bolts (3) and remove fuel filler door.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9A0002.swf" width = "88.000mm" height = "55.059mm" ver = "01" gw = "163" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9A06010002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
