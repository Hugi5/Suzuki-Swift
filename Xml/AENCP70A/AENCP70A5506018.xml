<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5506018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
CVT Oil Pan Removal and Installation
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Do not use any fluid other than specified CVT fluid. Use of any fluid other than specified CVT fluid may cause juddering or some other faulty condition to occur.
</ptxt>
</item>
<item>
<ptxt>
Use lint-free paper not cloth rags.
</ptxt>
</item>
<item>
<ptxt>
Do not reuse CVT fluid.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENCP70A5506018001">
<title>
Removal
</title>
<s1>
<ptxt>
Hoist vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Remove left side engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Drain CVT fluid. 
<intxreftitleoff1 refid = "AENCP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove CVT oil pan (1) and oil pan gasket (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove magnets (3) from oil pan.
</ptxt>
<figure>
<graphic graphicname = "IBP70A550061.swf" width = "88.000mm" height = "73.696mm" ver = "02" gw = "212" gh = "192"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5506018002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5506019">CVT Oil Pan Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Clean matching surface of CVT case and CVT oil pan. Remove CVT fluid, old gasket and dust from matching surface.
</ptxt>
</item>
<item>
<ptxt>
Check that no metal particles are attached to magnets. If attached, clean.
</ptxt>
</item>
<item>
<ptxt>
Use new gasket (1) and bolts for CVT oil pan (2).
</ptxt>
</item>
<item>
<ptxt>
Tighten CVT oil pan bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5E008">
<t-part>
CVT oil pan bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7.9
</t-value1>
<t-value2>
0.81
</t-value2>
<t-value3>
6.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A550062.swf" width = "88.000mm" height = "70.439mm" ver = "02" gw = "184" gh = "183"/>
</figure>
</item>
<item>
<ptxt>
Replenish CVT fluid. 
<intxreftitleoff1 refid = "AENCP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check CVT fluid level. 
<intxreftitleoff1 refid = "AENCP70A5506002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check for CVT fluid leakage after warming up CVT.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
