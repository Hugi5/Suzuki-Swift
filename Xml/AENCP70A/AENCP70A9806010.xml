<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9806010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Floor Carpet Removal and Installation
</title>
<servinfosub id = "AENCP70A9806010001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove seat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front seat: 
<intxreftitleoff1 refid = "AENCP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear seat: 
<intxreftitleoff1 refid = "AENCP70A9706004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove the following scuffs and trims. 
<intxreftitleoff1 refid = "AENCP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Side sill inner front scuffs
</ptxt>
</item>
<item>
<ptxt>
Side sill inner rear scuffs
</ptxt>
</item>
<item>
<ptxt>
Dash side trims
</ptxt>
</item>
<item>
<ptxt>
Center pillar lower trims
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove center console front box / rear box. 
<intxreftitleoff1 refid = "AENCP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering joint cover. 
<intxreftitleoff1 refid = "AENCP70A6206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove 5 clips (1) and accelerator pedal stopper (2) and then remove floor carpet (3).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A980007.jpg" width = "88.000mm" height = "60.725mm" ver = "02" gw = "238" gh = "156"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.065in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Vehicle forward
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
<servinfosub id = "AENCP70A9806010002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten mounting bolts of each seat to specified torque.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Front seat: 
<intxreftitleoff1 refid = "AENCP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear seat: 
<intxreftitleoff1 refid = "AENCP70A9706004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
