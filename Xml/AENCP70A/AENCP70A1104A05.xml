<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A1104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Engine noise – Connecting rod noise
</title>
<ptxt>
Perform troubleshooting referring to the following points when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENCP70A1104008">Visual Inspection</intxref>
 and 
<intxref refid = "AENCP70A1104009">Engine Basic Inspection</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<paragroup>
<ptxt>
Engine noise – Connecting rod noise
</ptxt>
<attention3>
<ptxt>
Before checking mechanical noise, make sure that:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Specified spark plug is used.
</ptxt>
</item>
<item>
<ptxt>
Specified fuel is used.
</ptxt>
</item>
</list1>
</attention3>
</paragroup>
</condition>
<ps>
<ptxt>
Worn piston, piston ring and cylinder bore
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1406036">Cylinder, Piston and Piston Ring Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Worn connecting rod bearing
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1406038">Crankshaft Pin and Connecting Rod Bearing Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Worn crankshaft pin
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1406038">Crankshaft Pin and Connecting Rod Bearing Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Loose connecting rod bolts
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1406034">Piston, Piston Ring, Connecting Rod and Cylinder Removal and Installation</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Low oil pressure
</ptxt>
</ps>
<action>
<ptxt>
Condition “Low oil pressure”
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
