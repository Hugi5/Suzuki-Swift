<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A5204001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Manual Transaxle Symptom Diagnosis
</title>
<diag type = "condition" id = "AENCP70A5204001001">
<condition>
<ptxt>
Gears slipping out of mesh
</ptxt>
</condition>
<ps>
<ptxt>
Worn shift fork shaft
</ptxt>
</ps>
<action>
<ptxt>
Replace shift fork shaft. 
<intxreftitleoff1 refid = "AENCP70A5206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn shift fork or synchronizer sleeve
</ptxt>
</ps>
<action>
<ptxt>
Replace shift fork or synchronizer sleeve referring to 
<intxref refid = "AENCP70A5206023">Gear Shift Shaft Components</intxref>
, 
<intxref refid = "AENCP70A5206015">Fifth Gear Disassembly and Reassembly</intxref>
, 
<intxref refid = "AENCP70A5206020">Input Shaft Assembly Disassembly and Reassembly</intxref>
 and/or 
<intxref refid = "AENCP70A5206021">Countershaft Assembly Disassembly and Reassembly</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Weak or damaged locating springs
</ptxt>
</ps>
<action>
<ptxt>
Replace locating spring. 
<intxreftitleoff1 refid = "AENCP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn bearings on input shaft or countershaft
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace input shaft bearing or countershaft bearing.
</ptxt>
<ptxt>
- Input shaft bearing: 
<intxreftitleoff1 refid = "AENCP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Countershaft bearing: 
<intxreftitleoff1 refid = "AENCP70A5206021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Worn chamfered tooth on sleeve and gear
</ptxt>
</ps>
<action>
<ptxt>
Replace synchronizer sleeve and gear.
</ptxt>
</action>
<condition>
<ptxt>
Hard shifting
</ptxt>
</condition>
<ps>
<ptxt>
Inadequate lubricant
</ptxt>
</ps>
<action>
<ptxt>
Replenish manual transaxle oil.
</ptxt>
</action>
<ps>
<ptxt>
Improper clutch pedal free travel
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace clutch pedal arm or clutch master cylinder. 
</ptxt>
<ptxt>
- Clutch pedal arm: 
<intxreftitleoff1 refid = "AENCP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Clutch master cylinder: 
<intxreftitleoff1 refid = "AENCP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Distorted or broken clutch disc
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENCP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Damaged clutch pressure plate
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch cover. 
<intxreftitleoff1 refid = "AENCP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn synchronizer ring
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace synchronizer ring. 
</ptxt>
<ptxt>
- Input shaft bearing: 
<intxreftitleoff1 refid = "AENCP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Countershaft bearing: 
<intxreftitleoff1 refid = "AENCP70A5206021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Worn chamfered tooth on sleeve or gear
</ptxt>
</ps>
<action>
<ptxt>
Replace synchronizer sleeve and gear referring to 
<intxref refid = "AENCP70A5206015">Fifth Gear Disassembly and Reassembly</intxref>
, 
<intxref refid = "AENCP70A5206020">Input Shaft Assembly Disassembly and Reassembly</intxref>
 and/or 
<intxref refid = "AENCP70A5206021">Countershaft Assembly Disassembly and Reassembly</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Worn gear shift control shaft joint bushing
</ptxt>
</ps>
<action>
<ptxt>
Replace shift and select shaft assembly. 
<intxreftitleoff1 refid = "AENCP70A5206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Distorted shift shaft
</ptxt>
</ps>
<action>
<ptxt>
Replace shift shaft. 
<intxreftitleoff1 refid = "AENCP70A5206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Broken gear shift / select control cables
</ptxt>
</ps>
<action>
<ptxt>
Replace gear shift and select cable. 
<intxreftitleoff1 refid = "AENCP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Noise
</ptxt>
</condition>
<ps>
<ptxt>
Inadequate or insufficient lubricant
</ptxt>
</ps>
<action>
<ptxt>
Replenish manual transaxle oil.
</ptxt>
</action>
<ps>
<ptxt>
Damaged or worn bearing(s)
</ptxt>
</ps>
<action>
<ptxt>
Replace bearing referring to 
<intxref refid = "AENCP70A5206015">Fifth Gear Disassembly and Reassembly</intxref>
, 
<intxref refid = "AENCP70A5206020">Input Shaft Assembly Disassembly and Reassembly</intxref>
 and/or 
<intxref refid = "AENCP70A5206021">Countershaft Assembly Disassembly and Reassembly</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Damaged or worn gear(s)
</ptxt>
</ps>
<action>
<ptxt>
Replace gear referring to 
<intxref refid = "AENCP70A5206015">Fifth Gear Disassembly and Reassembly</intxref>
, 
<intxref refid = "AENCP70A5206020">Input Shaft Assembly Disassembly and Reassembly</intxref>
 and/or 
<intxref refid = "AENCP70A5206021">Countershaft Assembly Disassembly and Reassembly</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Damaged or worn synchronizer parts
</ptxt>
</ps>
<action>
<ptxt>
Replace synchronizer parts referring to 
<intxref refid = "AENCP70A5206015">Fifth Gear Disassembly and Reassembly</intxref>
, 
<intxref refid = "AENCP70A5206020">Input Shaft Assembly Disassembly and Reassembly</intxref>
 and/or 
<intxref refid = "AENCP70A5206021">Countershaft Assembly Disassembly and Reassembly</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
