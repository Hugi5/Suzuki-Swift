<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A8206020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Forward Impact Sensor Removal and Installation
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Never repair or disassemble sensor.
</ptxt>
</item>
<item>
<ptxt>
Never drop, strike or shake sensor.
</ptxt>
<ptxt>
If dropped, replace it even if there is no apparent defect.
</ptxt>
<ptxt>
If sensor is deformed or cracked, replace sensor.
</ptxt>
</item>
<item>
<ptxt>
Sensor bolt must be carefully torqued to assure proper operation.
</ptxt>
<ptxt>
Loosely connected sensor may cause improper operation of air bag system.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENCP70A8206020001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENCP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENCP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect forward impact sensor connector (2) as follows.
</ptxt>
<s2>
<ptxt>
Release locking slider (1) by sliding it in direction of arrow “1”.
</ptxt>
</s2>
<s2>
<ptxt>
Disconnect forward impact sensor connector (2) by pulling it in direction of arrow “2”.
</ptxt>
</s2>
</s1>
<s1>
<ptxt>
Remove forward impact sensor bolt (3) and remove forward impact sensor (4) from apron side member outer panel (5).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820072.swf" width = "88.000mm" height = "95.843mm" ver = "01" gw = "238" gh = "255"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A8206020002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A8206021">Forward Impact Sensor Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Check that none of the following faulty conditions exists.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Bend, deformation or rust on apron side member outer panel.
</ptxt>
</item>
<item>
<ptxt>
Foreign material on sensor.
</ptxt>
</item>
<item>
<ptxt>
Direct arrow (1) on forward impact sensor frontward.
</ptxt>
<figure>
<graphic graphicname = "I9W10P821033.swf" width = "88.000mm" height = "48.247mm" ver = "01" gw = "113" gh = "120"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Align mounting pin (1) to mounting hole (2) of vehicle to install forward impact sensor (3).
</ptxt>
</s1>
<s1>
<ptxt>
Tighten forward impact sensor bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T8B006">
<t-part>
Forward impact sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9.0
</t-value1>
<t-value2>
0.92
</t-value2>
<t-value3>
7.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect forward impact sensor connector securely.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820073.swf" width = "88.000mm" height = "71.411mm" ver = "01" gw = "238" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Install front bumper. 
<intxreftitleoff1 refid = "AENCP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Enable air bag system. 
<intxreftitleoff1 refid = "AENCP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
