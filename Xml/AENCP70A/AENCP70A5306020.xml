<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5306020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Clutch Release System Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5306017">Clutch Cover and Clutch Disc Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A5306020001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove release arm by loosening its bolt.
</ptxt>
</s1>
<s1>
<ptxt>
Remove release bearing by turning release shaft (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove No.2 bushing using special tool (A) and hammer. Release shaft seal will also be pushed out.
</ptxt>
<servicetool>
<servicetoolitem id = "L5C004">
<s-part>
(A)
</s-part>
<s-number num = "09922-46010">
09922–46010
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Remove release shaft (1).
</ptxt>
<figure>
<graphic graphicname = "I4RS0A530020.swf" width = "88.000mm" height = "46.005mm" ver = "01" gw = "157" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Remove clutch release shaft No.1 bushing as follows, if necessary.
</ptxt>
<s2>
<ptxt>
Install tap (M16 X 1.5) (1) to clutch release shaft No.1 bushing.
</ptxt>
<figure>
<graphic graphicname = "IYSY01531016.swf" width = "88.000mm" height = "46.936mm" ver = "01" gw = "155" gh = "116"/>
</figure>
</s2>
<s2>
<ptxt>
Pull out No.1 bushing using tap (1) and special tools.
</ptxt>
<servicetool>
<servicetoolitem id = "L5C005">
<s-part>
(B)
</s-part>
<s-number num = "09923-46020">
09923–46020
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5C006">
<s-part>
(C)
</s-part>
<s-number num = "09930-30104">
09930–30104
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IYSY01531017.swf" width = "88.000mm" height = "46.851mm" ver = "01" gw = "190" gh = "116"/>
</figure>
</s2>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5306020002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5306021">Clutch Release System Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install a new No.1 bushing using special tools and hammer, and then apply grease to bushing inside.
</ptxt>
<servicetool>
<servicetoolitem id = "L5C007">
<s-part>
(A)
</s-part>
<s-number num = "09943-88211">
09943–88211
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5C008">
<s-part>
(B)
</s-part>
<s-number num = "09923-46030">
09923–46030
</s-number>
</servicetoolitem>
</servicetool>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5C005" uid = "22">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I3RM0A530016.swf" width = "88.000mm" height = "52.186mm" ver = "01" gw = "172" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Install release shaft.
</ptxt>
</s1>
<s1>
<ptxt>
Apply grease to No.2 bushing (1) inside and press-fit it using the same special tool used for removal.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5C006" uid = "22">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<servicetool>
<servicetoolitem id = "L5C009">
<s-part>
(A)
</s-part>
<s-number num = "09922-46010">
09922–46010
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Apply grease to release shaft seal (2) lip, and then install it till it is flush with case surface. Use special tool for this installation and face seal lip downward (inside).
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5C007" uid = "22">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<servicetool>
<servicetoolitem id = "L5C010">
<s-part>
(B)
</s-part>
<s-number num = "09925-98221">
09925–98221
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Caulk seal at [A] using caulking tool and hammer.
</ptxt>
<figure>
<graphic graphicname = "I9P60A531021.swf" width = "88.000mm" height = "98.684mm" ver = "02" gw = "182" gh = "263"/>
</figure>
</s1>
<s1>
<ptxt>
Apply grease to release bearing inside and release shaft (2), then set release bearing (1).
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5C008" uid = "22">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Apply grease to input shaft (3) spline (0.3 g (0.01 oz)) and front end (0.15 g (0.005 oz)) as well.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease I" id = "M5C009" uid = "26">
<m-part>
“B”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25210
</m-number>
<m-name>
SUZUKI Super Grease I
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I4RS0A530021.swf" width = "88.000mm" height = "92.275mm" ver = "01" gw = "185" gh = "245"/>
</figure>
</s1>
<s1>
<ptxt>
Set release arm (1) to release shaft (2) aligning punch mark (4) of release arm and punch mark (3) of release shaft. Then tighten release arm bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5C007">
<t-part>
Release arm bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A531020.jpg" width = "88.000mm" height = "72.122mm" ver = "01" gw = "238" gh = "188"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
