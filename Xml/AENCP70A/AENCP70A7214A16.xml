<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A7214A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Chattering noise is heard when A/C compressor is in operation
</title>
<servinfosub id = "AENCP70A7214004003">
<title>
Abnormal Noise from Magnetic Clutch
</title>
<diag type = "condition">
<condition>
<ptxt>
Chattering noise is heard when A/C compressor is in operation
</ptxt>
</condition>
<ps>
<ptxt>
Faulty magnet clutch clearance (excessive clearance)
</ptxt>
</ps>
<action>
<ptxt>
Adjust magnet clutch clearance. 
<intxreftitleoff1 refid = "AENCP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn magnet clutch friction surface
</ptxt>
</ps>
<action>
<ptxt>
Replace magnet clutch assembly. 
<intxreftitleoff1 refid = "AENCP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compressor oil leaked from shaft seal, contaminating friction surface
</ptxt>
</ps>
<action>
<ptxt>
Replace A/C compressor body assembly. 
<intxreftitleoff1 refid = "AENCP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
