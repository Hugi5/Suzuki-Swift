<servinfosub id = "AENCP70AA804003004">
<title>
Troubleshooting
</title>
<topic id = "AENCP70AA804003005">
<title>
Diagnosis flow: [a]
</title>
<diag type = "test" id = "AENCP70AA804003006">
<testgroup id = "AENCP70AA804003007">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to DLC and combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check CAN communication circuit [a] between DLC and combination meter connector for open circuit.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA804003008">
<title>
Combination meter terminating resistance check
</title>
<test1>
<ptxt>
Connect combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect ECM connector “E01”.
</ptxt>
</test1>
<test1>
<ptxt>
Measure resistance between “G211-11” and “G211-3” terminals of DLC.
</ptxt>
</test1>
<question>
Is resistance 114 – 134 Ω?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70AA804004">Troubleshooting for Communication Bus Off</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace combination meter and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</topic>
<topic id = "AENCP70AA804003009">
<title>
Diagnosis flow: [b]
</title>
<diag type = "test" id = "AENCP70AA804003010">
<testgroup id = "AENCP70AA804003011">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect combination meter connector and P/S control module connector “G50”.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check CAN communication circuit [b] between combination meter connector and P/S control module connector for open circuit.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace combination meter and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Repair or replace the following defective part.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
CAN communication circuit [b] is faulty between combination meter and J/C
</ptxt>
</item>
<item>
<ptxt>
J/C “G308” is faulty
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
</diag>
</topic>
<topic id = "AENCP70AA804003012">
<title>
Diagnosis flow: [c]
</title>
<diag type = "test" id = "AENCP70AA804003013">
<testgroup id = "AENCP70AA804003014">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect P/S control module connector “G50” and combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to P/S control module connector.
</ptxt>
</test1>
