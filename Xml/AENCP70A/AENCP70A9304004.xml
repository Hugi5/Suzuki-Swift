<servinfosub id = "AENCP70A9304004003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A9304004004">
<testgroup id = "AENCP70A9304004005">
<title>
DTC check
</title>
<test1>
<ptxt>
Clear DTC. 
<intxreftitleoff1 refid = "AENCP70AA204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENCP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1802 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check for intermittent trouble. 
<intxreftitleoff1 refid = "AENCP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A9304004006">
<title>
Combination meter power supply and ground circuits check
</title>
<test1>
<ptxt>
Check combination meter power supply and ground circuits. 
<intxreftitleoff1 refid = "AENCP70A9304009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair defective wire harness.
</ptxt>
</action>
</testgroup>
</diag>
