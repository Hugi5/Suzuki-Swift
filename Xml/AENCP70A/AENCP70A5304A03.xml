<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A5304A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Clutch vibration
</title>
<diag type = "condition">
<condition>
<ptxt>
Clutch vibration
</ptxt>
</condition>
<ps>
<ptxt>
Glazed (glass-like) clutch facings
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace clutch disc. 
<intxreftitleoff1 refid = "AENCP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Clutch facings dirty with oil
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENCP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Release bearing does not side smoothly on input shaft bearing retainer
</ptxt>
</ps>
<action>
<ptxt>
Lubricate input shaft or replace release bearing. 
<intxreftitleoff1 refid = "AENCP70A5306020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Wobbly clutch disc or poor facing contact
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENCP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Weakened torsion springs in clutch disc
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENCP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Clutch disc rivets loose
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENCP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Distorted pressure plate or flywheel surface
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace clutch cover or flywheel.
</ptxt>
<ptxt>
- Clutch disc and cover: 
<intxreftitleoff1 refid = "AENCP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Flywheel: 
<intxreftitleoff1 refid = "AENCP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Weakened engine mounting or loosened engine mounting bolt(s) and/or nut(s)
</ptxt>
</ps>
<action>
<ptxt>
Replace engine mounting or retighten engine mounting bolts and/or nuts. 
<intxreftitleoff1 refid = "AENCP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
