<servinfosub id = "AENCP70A8204023003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A8204023004">
<testgroup id = "AENCP70A8204023005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A8204023006">
<title>
Passenger air bag (inflator) module circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is in “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G259” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G11” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector inserting release tool included in special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Check the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between each of “A3” and “A4” circuits and ground: infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B025">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820018.swf" width = "90.000mm" height = "53.945mm" ver = "02" gw = "214" gh = "136"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A8204023007">
<title>
Instrument panel harness circuit check
</title>
<test1>
<ptxt>
Disconnect “G372” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector using special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Check the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between each of “A3” and “A4” circuits and ground: infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B026">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820018.swf" width = "90.000mm" height = "53.945mm" ver = "02" gw = "214" gh = "136"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace passenger air bag (inflator) module harness.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs, referring to 
<intxref refid = "AENCP70A8204006">DTC Clearance</intxref>
 if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENCP70A8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
