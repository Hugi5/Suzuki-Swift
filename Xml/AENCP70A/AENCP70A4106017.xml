<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4106017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Brake Master Cylinder Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4106015">Brake Master Cylinder Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENCP70A4106016">Brake Master Cylinder Assembly On-Vehicle Inspection</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Never disassemble brake master cylinder. Disassembly will spoil its original performance.
</ptxt>
<ptxt>
If faulty condition is observed, replace brake master cylinder with a new assembly.
</ptxt>
</item>
<item>
<ptxt>
Do not allow brake fluid to get on painted surfaces. Painted surfaces will be damaged by brake fluid. If any fluid is spilled, flush it with water immediately.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENCP70A4106017001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove A/C suction hose and A/C discharge hose from HVAC unit, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Clean external surface of brake master cylinder.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect brake fluid level switch connector (1) on reservoir.
</ptxt>
<figure>
<graphic graphicname = "IAP70B410004.swf" width = "88.000mm" height = "50.054mm" ver = "01" gw = "153" gh = "125"/>
</figure>
</s1>
<s1>
<ptxt>
Drain brake fluid in reservoir.
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, disconnect clutch reservoir hose from reservoir.
</ptxt>
</s1>
<s1>
<ptxt>
Using special tool, loosen flare nuts and disconnect brake pipes (1) from brake master cylinder.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A002">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Remove brake master cylinder fixing nuts (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70B410005.swf" width = "88.000mm" height = "59.376mm" ver = "01" gw = "154" gh = "152"/>
</figure>
</s1>
<s1>
<ptxt>
Remove brake master cylinder (1) and O-ring (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70B410006.swf" width = "88.000mm" height = "42.590mm" ver = "02" gw = "163" gh = "104"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A4106017004">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4106019">Brake Master Cylinder Assembly Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install new O-ring (2) to brake master cylinder assembly (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70B410006.swf" width = "88.000mm" height = "42.590mm" ver = "02" gw = "163" gh = "104"/>
</figure>
</s1>
<s1>
<ptxt>
Install brake master cylinder to brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
Tighten brake master cylinder fixing nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A004">
<t-part>
Brake master cylinder fixing nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
18
</t-value1>
<t-value2>
1.8
</t-value2>
<t-value3>
13.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect brake pipe (1) to brake master cylinder and tighten flare nuts to specified torque using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A003">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T4A005">
<t-part>
Brake pipe flare nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1.6
</t-value2>
<t-value3>
12.0
</t-value3>
<ptxt>
(ABS model)
</ptxt>
</torqueitem>
<torqueitem id = "T4A006">
<t-part>
Brake pipe flare nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1.9
</t-value2>
<t-value3>
14.0
</t-value3>
<ptxt>
(ESP<sup>&#174;</sup> model)
</ptxt>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70B410007.swf" width = "88.000mm" height = "60.191mm" ver = "01" gw = "170" gh = "154"/>
</figure>
</s1>
<s1>
<ptxt>
For M/T model, Connect clutch reservoir hose to reservoir.
</ptxt>
</s1>
<s1>
<ptxt>
Connect brake fluid level switch connector.
</ptxt>
</s1>
<s1>
<ptxt>
Install A/C suction hose and A/C discharge hose to HVAC unit.
</ptxt>
</s1>
<s1>
<ptxt>
After installation, bleed brake system. 
<intxreftitleoff1 refid = "AENCP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check installed parts for brake fluid leakage.
</ptxt>
</s1>
<s1>
<ptxt>
Check brake pedal for play. 
<intxreftitleoff1 refid = "AENCP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Make sure that brake system operates properly without fluid leakage.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
