<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1511-H: Temperature Control Actuator (Position Sensor) and/or Its Circuit Malfunction
</emph>
</ptxt>
<ptxt>
Temperature control actuator position sensor signal voltage is higher than specified value (4.8 V) for specified time continuously.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
