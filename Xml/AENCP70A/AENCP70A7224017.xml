<diag type = "test" id = "AENCP70A7224017005">
<testgroup id = "AENCP70A7224017006">
<title>
Scan tool parameter check
</title>
<test1>
<ptxt>
Check “Air Mix Pos Sen” using “Data list” mode on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENCP70A7224007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is voltage over 4.8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A7224017007">
<title>
Temperature control actuator position sensor signal circuit check
</title>
<test1>
<ptxt>
Disconnect temperature control actuator connector.
</ptxt>
</test1>
<test1>
<ptxt>
Connect the “YEL” and “YEL/RED” wire terminals of temperature control actuator connector using service wire.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENCP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1511-L detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace temperature control actuator. 
<intxreftitleoff1 refid = "AENCP70A7226023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A7224017008">
<title>
Temperature control actuator position sensor signal circuit check
</title>
<test1>
<ptxt>
Connect “YEL” and “YEL/RED” wire terminals of “G20” connector using service wire.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENCP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1511-L detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace HVAC control module and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A7226011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
