<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5506022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Transmission Range Sensor Removal and Installation
</title>
<attention2>
<ptxt>
Do not reuse transmission range sensor.
</ptxt>
<ptxt>
Reusing of transmission range sensor may affect the performance of CVT system.
</ptxt>
</attention2>
<servinfosub id = "AENCP70A5506022001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery and battery tray with ECM. 
<intxreftitleoff1 refid = "AENCP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Shift select lever to N position.
</ptxt>
</s1>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENCP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove coolant reservoir from coolant reservoir bracket.
</ptxt>
</s1>
<s1>
<ptxt>
Remove hose clamps (1) and CVT fluid cooler pipe bolts (2) and then remove CVT fluid cooler pipe (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P550104.swf" width = "88.000mm" height = "92.627mm" ver = "01" gw = "203" gh = "246"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect select cable (1) from manual select lever (2).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect transmission range sensor connector (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P550047.swf" width = "88.000mm" height = "73.645mm" ver = "02" gw = "173" gh = "192"/>
</figure>
</s1>
<s1>
<ptxt>
Remove manual select lever nut (1) and then remove manual select lever (2) and washer (3) from shift shaft.
</ptxt>
</s1>
<s1>
<ptxt>
Remove transmission range sensor (4) by removing mounting bolts (5).
</ptxt>
<figure>
<graphic graphicname = "IBP50A550021.swf" width = "88.000mm" height = "61.898mm" ver = "01" gw = "145" gh = "159"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5506022002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5506020">Transmission Range Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Adjust select cable. 
<intxreftitleoff1 refid = "AENCP70A5506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Use new transmission range sensor (4).
</ptxt>
</item>
<item>
<ptxt>
Use new washer (1).
</ptxt>
</item>
<item>
<ptxt>
Adjust transmission range sensor. 
<intxreftitleoff1 refid = "AENCP70A5506021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten transmission range sensor bolts (2) and new manual select lever nut (3) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5E011">
<t-part>
Transmission range sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.9
</t-value1>
<t-value2>
0.60
</t-value2>
<t-value3>
4.5
</t-value3>
</torqueitem>
<torqueitem id = "T5E012">
<t-part>
Manual select lever nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
17
</t-value1>
<t-value2>
1.7
</t-value2>
<t-value3>
12.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP50A550022.swf" width = "88.000mm" height = "60.487mm" ver = "01" gw = "166" gh = "155"/>
</figure>
</item>
<item>
<ptxt>
Tighten CVT fluid cooler pipe bolts (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5E013">
<t-part>
CVT fluid cooler pipe bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.12
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP50A550023.swf" width = "88.000mm" height = "91.964mm" ver = "01" gw = "179" gh = "244"/>
</figure>
</item>
<item>
<ptxt>
Check transmission range sensor for the following points.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Check that engine starts in P and N ranges but does not start in other than P and N ranges.
</ptxt>
</item>
<item>
<ptxt>
Check that back up light turns on and buzzer operates when shifting select lever to R range.
</ptxt>
</item>
<item>
<ptxt>
Check that shift position indicated in combination meter is consistent with select lever range.
</ptxt>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
