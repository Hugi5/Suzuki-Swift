<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1506004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Oil Pan and Oil Pump Strainer Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1506003">Oil Pan and Oil Pump Strainer Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A1506004001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove oil level gauge.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Drain engine oil by removing drain plug.
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust pipe No.1. 
<intxreftitleoff1 refid = "AENCP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil filter. 
<intxreftitleoff1 refid = "AENCP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove transaxle bolts (1) and oil pan bolts (2).
</ptxt>
<figure>
<graphic graphicname = "I7V20A151012.swf" width = "88.000mm" height = "49.208mm" ver = "01" gw = "227" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Remove oil pan (1) from cylinder block using special tool and hammer.
</ptxt>
<servicetool>
<servicetoolitem id = "L1E005">
<s-part>
(A)
</s-part>
<s-number num = "09921-96510">
09921–96510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A151013.swf" width = "88.000mm" height = "49.206mm" ver = "02" gw = "230" gh = "123"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove oil pump strainer, if necessary.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove oil pan baffle plate and oil pan baffle plate stud bolts, if necessary.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1506004002">
<title>
Installation
</title>
<s1>
<ptxt>
Install oil pan baffle plate stud bolt (1) if removed, and then tighten oil pan baffle plate stud bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E004">
<t-part>
Oil pan baffle plate stud bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Install oil pan baffle plate (2) and then tighten oil pan baffle plate bolts (3) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E005">
<t-part>
Oil pan baffle plate bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure page = "2">
<graphic graphicname = "I9P60A151002.swf" width = "88.000mm" height = "50.955mm" ver = "01" gw = "177" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Apply engine oil to new O-ring (1) and then install O-rings to oil pump strainer (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install oil pump strainer with O-ring to oil pump and tighten bolt (3) first and then nut (4) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E006">
<t-part>
Oil pump strainer bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
<torqueitem id = "T1E007">
<t-part>
Oil pump strainer bracket nut*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151003.jpg" width = "88.000mm" height = "61.290mm" ver = "01" gw = "199" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Install dowel pins (1) to oil pan and cylinder block.
</ptxt>
<figure>
<graphic graphicname = "I9P60A151004.jpg" width = "88.000mm" height = "67.299mm" ver = "01" gw = "207" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Apply engine oil to new O-ring (1) and then install O-ring to position as shown in figure.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Apply sealant to mating surface of oil pan as shown in figure.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Before applying sealant, make sure mating surface is clean and dry.
</ptxt>
</item>
<item>
<ptxt>
Wipe off excessive sealant.
</ptxt>
</item>
<item>
<ptxt>
Install oil pan within 2 minutes after applying sealant.
</ptxt>
</item>
</list1>
</attention3>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1E002" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<spec>
<title>
Sealant amount for oil pan
</title>
<ptxt>
Width “a”: 3 mm (0.12 in.)
</ptxt>
<ptxt>
Height “b”: 2 mm (0.08 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151017.swf" width = "88.000mm" height = "59.875mm" ver = "01" gw = "146" gh = "153"/>
</figure>
</s1>
<s1>
<ptxt>
Install oil pan to cylinder block and then tighten oil pan bolts in numerical order (“1” – “17”) evenly and gradually to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E008">
<t-part>
Oil pan bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151005.swf" width = "88.000mm" height = "63.567mm" ver = "01" gw = "227" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten transaxle bolts (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E009">
<t-part>
Transaxle bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151006.swf" width = "88.000mm" height = "46.039mm" ver = "01" gw = "227" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Install oil filter. 
<intxreftitleoff1 refid = "AENCP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install exhaust pipe No.1. 
<intxreftitleoff1 refid = "AENCP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Install drain plug and refill engine with engine oil. 
<intxreftitleoff1 refid = "AENCP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install oil level gauge.
</ptxt>
</s1>
<s1>
<ptxt>
Verify that there is no engine oil leakage and exhaust gas leakage at each connection.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
