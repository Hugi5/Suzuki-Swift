<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9706004" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Rear Seat Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A9706003">Rear Seat Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A9706004001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear seat cushion assembly. 
<intxreftitleoff1 refid = "AENCP70A9706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear seatback assemblies by removing rear seat hinge bolts. 
<intxreftitleoff1 refid = "AENCP70A9706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disassemble and repair rear seat if necessary. 
<intxreftitleoff1 refid = "AENCP70A9706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9706004002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Refer to 
<intxref refid = "AENCP70A9706003">Rear Seat Components</intxref>
 for tightening torque.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
