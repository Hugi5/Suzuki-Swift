<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A8204005" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
DTC Check
</title>
<s1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Connect SUZUKI scan tool to DLC (1) located on underside of instrument panel at driver’s seat side.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B002">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI scan tool (SUZUKI-SDT)
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A820013.jpg" width = "88.000mm" height = "67.502mm" ver = "02" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Set ignition “ON”. Read DTC according to instructions displayed on SUZUKI scan tool and print it or write it down. Refer to SUZUKI scan tool operators manual further details.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “OFF”, and disconnect SUZUKI scan tool from DLC.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
