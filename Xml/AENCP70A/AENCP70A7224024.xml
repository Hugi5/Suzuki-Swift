<servinfosub id = "AENCP70A7224024003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Start engine and operate A/C system.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A7224024004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A7224024005">
<testgroup id = "AENCP70A7224024006">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition to “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “ON” and check DTC.
</ptxt>
</test1>
<question>
Is DTC B1550-H or B1550-L still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A7224024007">
<title>
Communication circuit check
</title>
<test1>
<ptxt>
Disconnect “G20” and “G227” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “PNK/BLU” wire circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance of “PNK/BLU” wire circuit between auto A/C panel and ground: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are resistance values as specified?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Substitute a known-good HVAC control module and/or auto A/C panel and recheck DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
HVAC control module: 
<intxreftitleoff1 refid = "AENCP70A7226011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C panel: 
<intxreftitleoff1 refid = "AENCP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
