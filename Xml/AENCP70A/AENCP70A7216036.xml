<servinfo servinfosgmlid = "AENCP70A7216036" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Compressor Drive Belt Removal and Installation
</title>
<servinfosub id = "AENCP70A7216036001">
<title>
Removal
</title>
<s1>
<ptxt>
Loosen tension pulley bolt (1).
</ptxt>
</s1>
<s1>
<ptxt>
Loosen belt tension by loosening tension pulley adjusting bolt (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove compressor drive belt (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A722023.swf" width = "88.000mm" height = "57.807mm" ver = "08" gw = "182" gh = "147"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A7216036002">
<title>
Installation
</title>
<s1>
<ptxt>
Install compressor drive belt.
</ptxt>
</s1>
<s1>
<ptxt>
Adjust belt tension. 
<intxreftitleoff1 refid = "AENCP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
