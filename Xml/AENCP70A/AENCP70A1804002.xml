<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A1804002" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Ignition Spark Test
</title>
<attention1>
<ptxt>
Without disconnection of injector connectors, combustible gas may come out from spark plug holes during this test and may get ignited in engine room.
</ptxt>
</attention1>
<s1>
<ptxt>
Remove spark plugs. 
<intxreftitleoff1 refid = "AENCP70A1806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Inspect spark plugs. 
<intxreftitleoff1 refid = "AENCP70A1806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect all injector connectors.
</ptxt>
</s1>
<s1>
<ptxt>
Connect ignition coil connector (1) to ignition coil assembly (3).
</ptxt>
</s1>
<s1>
<ptxt>
Connect spark plug (2) to ignition coil assembly, and ground spark plug.
</ptxt>
<figure>
<graphic graphicname = "I9P60A180004.swf" width = "88.000mm" height = "69.562mm" ver = "01" gw = "185" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Crank engine and check if each spark plug sparks.
</ptxt>
</s1>
<s1>
<ptxt>
If no spark is emitted, inspect the related parts. 
<intxreftitleoff1 refid = "AENCP70A1804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
