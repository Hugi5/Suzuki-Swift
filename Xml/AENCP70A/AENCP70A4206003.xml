<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4B">
<servcat sctnbr = "04" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Front Brake Pad Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4206001">Front Brake Components</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Be careful not to damage front brake flexible hoses.
</ptxt>
</item>
<item>
<ptxt>
Never depress brake pedal during service operation shown below.
</ptxt>
</item>
</list1>
</attention2>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Check for leakage of brake fluid when removing front brake pads and repair front brake caliper if leakage is found.
</ptxt>
</item>
<item>
<ptxt>
Replace all brake pads at the same time even if only one pad is defective.
</ptxt>
</item>
</list1>
</attention3>
<servinfosub id = "AENCP70A4206003001">
<title>
Removal
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4206002">Front Brake Pad On-Vehicle Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Hoist vehicle and remove front wheel. 
<intxreftitleoff1 refid = "AENCP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front brake caliper pin bolts (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A420003.swf" width = "88.000mm" height = "52.270mm" ver = "01" gw = "149" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Remove front brake caliper (1) from front brake caliper carrier (2).
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Hang removed front brake caliper (1) with a wire hook (4) to prevent front brake flexible hose from bending, twisting excessively or being pulled.
</ptxt>
</item>
<item>
<ptxt>
Do not operate brake pedal with front brake pads removed.
</ptxt>
</item>
</list1>
</attention3>
</s1>
<s1>
<ptxt>
Remove front brake pads (3) and pad springs (5) from front brake caliper carrier (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A420004.swf" width = "88.000mm" height = "61.626mm" ver = "01" gw = "158" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A4206003002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4206006">Front Brake Disc Inspection</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENCP70A4206009">Front Brake Caliper Inspection</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Do not twist front brake flexible hose when installing front brake caliper.
</ptxt>
</attention2>
<s1>
<ptxt>
Install pad springs (1) to front brake caliper carrier (2).
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70A420005.swf" width = "88.000mm" height = "51.112mm" ver = "01" gw = "140" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Fit shim(s) (1) to inner front brake pad (2) and outer front brake pad (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70B420002.swf" width = "88.000mm" height = "74.637mm" ver = "01" gw = "225" gh = "195"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.165in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.165in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
14 in. disc brake
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
15 in. disc brake
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install front brake pads (1) with shims to front brake caliper carrier (2) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IAP70A420007.swf" width = "88.000mm" height = "60.961mm" ver = "01" gw = "158" gh = "156"/>
</figure>
<attention3>
<ptxt>
Be sure to install inner front brake pad at inside of caliper carrier with its wear indicator (1) positioned upside.
</ptxt>
<figure>
<graphic graphicname = "I9P60A420024.swf" width = "88.000mm" height = "36.526mm" ver = "03" gw = "162" gh = "87"/>
</figure>
</attention3>
</s1>
<s1>
<ptxt>
Install front brake caliper and tighten caliper pin bolts (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4B001">
<t-part>
Front brake caliper pin bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
26
</t-value1>
<t-value2>
2.7
</t-value2>
<t-value3>
19.5
</t-value3>
</torqueitem>
</torque>
<figure page = "2">
<graphic graphicname = "IAP70A420008.swf" width = "88.000mm" height = "52.270mm" ver = "01" gw = "149" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Install front wheel. 
<intxreftitleoff1 refid = "AENCP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Make sure that brake system operates properly.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
