<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1306026" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "1">
<title>
OCV Inspection
</title>
<list1 type = "unordered">
<item>
<ptxt>
Remove OCVs (intake side and exhaust side). 
<intxreftitleoff1 refid = "AENCP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check OCVs (intake side and exhaust side) as follows.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Check resistance between terminals of OCV connector (1).
</ptxt>
<ptxt>
If check result is not satisfactory, replace OCV.
</ptxt>
<spec>
<title>
OCV resistance
</title>
<ptxt>
6.7 to 7.7 Ω at 20 &#176; C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9T401132006.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "180" gh = "153"/>
</figure>
</item>
<item>
<ptxt>
Connect battery to OCV connector (1) as shown in figure, and check that operating sound caused by movement of spool valve (2).
</ptxt>
<figure>
<graphic graphicname = "I9T401132007.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "193" gh = "153"/>
</figure>
</item>
</list2>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
