<servinfosub id = "AENCP70A4504011002">
<title>
Circuit Description
</title>
<ptxt>
Refer to “Circuit Description” under 
<intxref refid = "AENCP70A4504010">ABS Warning Light Does Not Come ON after Setting Ignition “ON”</intxref>
.
</ptxt>
</servinfosub>
<servinfosub id = "AENCP70A4504011003">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENCP70A4504011004">
<testgroup id = "AENCP70A4504011005">
<title>
ABS control module connector check
</title>
<test1>
<ptxt>
Check for proper connection to ABS control module connector.
</ptxt>
</test1>
<question>
Is connection in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Connect connector securely.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A4504011006">
<title>
DTC check for ABS
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENCP70A4504005">DTC Check</intxref>
.
</ptxt>
</test1>
<question>
Is there any DTC(s)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A4504011007">
<title>
ABS control module power supply and ground circuit check
</title>
<test1>
<ptxt>
Check ABS control module power supply circuit and ground circuit. 
<intxreftitleoff1 refid = "AENCP70A4504023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are the circuits in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A4504011008">
<title>
Combination meter check
</title>
<test1>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENCP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<question>
Does warning light stay on?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ABS hydraulic unit / control module assembly and recheck warning light operation. 
<intxreftitleoff1 refid = "AENCP70A4506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
