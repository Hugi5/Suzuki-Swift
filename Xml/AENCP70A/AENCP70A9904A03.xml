<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A9904A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Sun roof cannot operate (sun roof motor cannot operate)
</title>
<diag type = "condition">
<condition>
<ptxt>
Sun roof cannot operate (sun roof motor cannot operate)
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Replace fuse.
</ptxt>
</action>
<ps>
<ptxt>
Faulty sun roof switch
</ptxt>
</ps>
<action>
<ptxt>
Check sun roof switch. 
<intxreftitleoff1 refid = "AENCP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Check circuit. 
<intxreftitleoff1 refid = "AENCP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AENCP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty sun roof motor
</ptxt>
</ps>
<action>
<ptxt>
Check sun roof motor. 
<intxreftitleoff1 refid = "AENCP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
