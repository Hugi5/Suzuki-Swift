<servinfosub id = "AENCP70A1104039003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed by two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to troubleshoot first unexpected DTCs previously detected in “DTC Confirmation Procedure”.
</ptxt>
</item>
<item>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0117, P0335 or P0336 is not detected.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Warm up engine to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Drive vehicle at 60 to 80 km/h (37 to 50 mile/h) constantly for 1 min. or more.
</ptxt>
</s1>
<s1>
<ptxt>
Release accelerator pedal, and keep vehicle coasting for 10 sec. with engine braking applied (fuel cut condition).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1104039004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A1104039005">
<testgroup id = "AENCP70A1104039006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104039007">
<title>
DTC check
</title>
<question>
Is there any CAN-DTC detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for CAN-DTC. 
<intxreftitleoff1 refid = "AENCP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104039008">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC in ABS control module.
</ptxt>
</test1>
<question>
Is there any DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
