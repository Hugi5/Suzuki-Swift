<item>
<ptxt>
CAN communication line
</ptxt>
</item>
<item>
<ptxt>
Wheel speed sensor
</ptxt>
</item>
<item>
<ptxt>
ABS control module
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
