<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9A06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Hood Removal and Installation
</title>
<servinfosub id = "AENCP70A9A06001001">
<title>
Removal
</title>
<attention2>
<ptxt>
Cover the vehicle body with cloth to prevent any damage.
</ptxt>
</attention2>
</servinfosub>
<s1>
<ptxt>
Remove 4 hood hinge bolts (1) to detach hood (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove hood hinge after removing front fender, if necessary. 
<intxreftitleoff1 refid = "AENCP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<servinfosub id = "AENCP70A9A06001002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A9A06002">Hood Inspection and Adjustment</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply sealant to contact face “A” of hood hinge.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1215" id = "M9J001" uid = "27">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31110
</m-number>
<m-name>
SUZUKI Bond No.1215
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Adjust hood lock position if necessary. 
<intxreftitleoff1 refid = "AENCP70A9A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
If paint on hood hinge bolts is peeled off, be sure to apply paint again to prevent rust.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9A0001.swf" width = "88.000mm" height = "90.826mm" ver = "01" gw = "226" gh = "241"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
