<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9406007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Wiper and Washer Switch Removal and Installation
</title>
<servinfosub id = "AENCP70A9406007001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove steering column cover. 
<intxreftitleoff1 refid = "AENCP70A6206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect wiper and washer switch connector (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove wiper and washer switch (1) from steering column while pushing claw (2) in arrow direction.
</ptxt>
<figure>
<graphic graphicname = "IAP70A940006.jpg" width = "88.000mm" height = "85.417mm" ver = "01" gw = "201" gh = "226"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9406007002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A9406008">Wiper and Washer Switch Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
