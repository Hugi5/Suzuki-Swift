<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4E">
<servcat sctnbr = "04" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A4504020" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "1">
<title>
DTC C1090 / C1091 / C1094
</title>
<servinfosub id = "AENCP70A4504020001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.780in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.399in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1090: ECM Detect Rolling Counter Failure from ABS Control Module
</emph>
</ptxt>
<ptxt>
ABS control module sends invalid CAN data to ECM.
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
CAN communication circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
ABS control module
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1091: CAN Invalid Data from ECM
</emph>
</ptxt>
<ptxt>
DTC concerned with ECM is detected.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1094: Torque Request Reject Status
</emph>
</ptxt>
<ptxt>
ABS control module receives invalid CAN data from ECM (about engine torque control).
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENCP70A4504020002">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A4504020003">
<testgroup id = "AENCP70A4504020004">
<question>
Was “ABS Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A4504001">ABS Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A4504020005">
<title>
DTC check
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENCP70A4504005">DTC Check</intxref>
.
</ptxt>
</test1>
<question>
Is there DTC(s) other than C1090, C1091 or C1094?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A4504020006">
<title>
DTC check for ECM
</title>
<test1>
<ptxt>
Check DTC for ECM. 
<intxreftitleoff1 refid = "AENCP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC U0073 or U0121 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70AA804004">Troubleshooting for Communication Bus Off</intxref>
 or 
<intxref refid = "AENCP70AA804003">Troubleshooting for Lost Communication</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace ABS hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A4506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
