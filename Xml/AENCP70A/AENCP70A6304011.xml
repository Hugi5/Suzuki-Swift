<servinfosub id = "AENCP70A6304011002">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENCP70A6304011003">
<testgroup id = "AENCP70A6304011004">
<title>
DTC check
</title>
<test1>
<ptxt>
Start engine and recheck DTC of P/S control module.
</ptxt>
</test1>
<question>
Is there any DTC(s)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Perform 
<intxref refid = "AENCP70A6304003">DTC Check</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A6304011005">
<title>
Combination meter check
</title>
<test1>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENCP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<question>
Does P/S warning light stay ON?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace P/S control module and recheck. 
<intxreftitleoff1 refid = "AENCP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
