<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4D">
<servcat sctnbr = "04" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4406004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Parking Brake Lever Removal and Installation
</title>
<attention1>
<ptxt>
Make sure of the following conditions before removing parking brake lever.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Work on a flat place.
</ptxt>
</item>
<item>
<ptxt>
Shift gear in “P” range (CVT model) or “1st” gear (M/T model).
</ptxt>
</item>
<item>
<ptxt>
Use block wheels.
</ptxt>
</item>
</list1>
</attention1>
<servinfosub id = "AENCP70A4406004001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove floor console rear box. 
<intxreftitleoff1 refid = "AENCP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect parking brake switch connector from parking brake lever.
</ptxt>
</s1>
<s1>
<ptxt>
Loosen parking brake cable adjusting nut (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A440004.swf" width = "88.000mm" height = "66.682mm" ver = "01" gw = "189" gh = "173"/>
</figure>
</s1>
<s1>
<ptxt>
Remove parking brake lever bolts (1) and then remove parking brake lever (2) together with equalizer (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A440005.swf" width = "88.000mm" height = "80.810mm" ver = "01" gw = "168" gh = "213"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A4406004002">
<title>
Installation
</title>
<s1>
<ptxt>
Tighten parking brake lever bolts (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4D001">
<t-part>
Parking brake lever bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
26
</t-value1>
<t-value2>
2.7
</t-value2>
<t-value3>
19.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A440006.swf" width = "88.000mm" height = "77.351mm" ver = "01" gw = "174" gh = "203"/>
</figure>
</s1>
<s1>
<ptxt>
Connect parking brake cable to equalizer, then adjust parking brake cable. 
<intxreftitleoff1 refid = "AENCP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Make sure that brake system is operating properly.
</ptxt>
</s1>
<s1>
<ptxt>
Connect parking brake switch connector to parking brake lever.
</ptxt>
</s1>
<s1>
<ptxt>
Install floor console rear box. 
<intxreftitleoff1 refid = "AENCP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
