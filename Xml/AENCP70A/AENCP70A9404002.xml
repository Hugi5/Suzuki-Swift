<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A9404002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Wiper and Washer Symptom Diagnosis
</title>
<servinfosub id = "AENCP70A9404002001">
<title>
Windshield Wiper and Washer
</title>
<diag type = "condition" id = "AENCP70A9404002002">
<condition>
<ptxt>
Wiper malfunctions
</ptxt>
</condition>
<ps>
<ptxt>
Faulty windshield wiper motor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406004">Windshield Wiper Motor Operation Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiper and washer switch (wiper switch)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406008">Wiper and Washer Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<condition>
<ptxt>
Washer malfunctions
</ptxt>
</condition>
<ps>
<ptxt>
Faulty washer hose (including check valve and connector) or washer nozzle
</ptxt>
</ps>
<action>
<ptxt>
Check washer hose or washer nozzle for clogging and bend. 
<intxreftitleoff1 refid = "AENCP70A9403001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty washer pump
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406002">Washer Pump Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiper and washer switch (washer switch)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406008">Wiper and Washer Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AENCP70A9404002003">
<title>
Rear Wiper and Washer
</title>
<diag type = "condition" id = "AENCP70A9404002004">
<condition>
<ptxt>
Wiper malfunctions
</ptxt>
</condition>
<ps>
<ptxt>
Faulty rear wiper motor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406006">Rear Wiper Motor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiper and washer switch (wiper switch)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406008">Wiper and Washer Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
“Inspection of BCM and Its Circuits” in Section 10B
</ptxt>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENCP70AA204023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENCP70AA204024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<condition>
<ptxt>
Washer malfunctions
</ptxt>
</condition>
<ps>
<ptxt>
Faulty washer hose (including check valve and connector) or washer nozzle
</ptxt>
</ps>
<action>
<ptxt>
Check washer hose or washer nozzle for clogging and bend.
</ptxt>
</action>
<ps>
<ptxt>
Faulty washer pump
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406002">Washer Pump Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiper and washer switch (washer switch)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406008">Wiper and Washer Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
