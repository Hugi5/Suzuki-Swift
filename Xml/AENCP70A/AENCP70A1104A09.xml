<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A1104A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Excessive engine oil consumption – Oil leakage
</title>
<ptxt>
Perform troubleshooting referring to the following points when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENCP70A1104008">Visual Inspection</intxref>
 and 
<intxref refid = "AENCP70A1104009">Engine Basic Inspection</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Excessive engine oil consumption – Oil leakage
</ptxt>
</condition>
<ps>
<ptxt>
Broken cylinder head gasket
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1406030">Cylinder Head Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Leaky crankshaft pulley oil seal
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1406014">Camshaft and Tappet Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Leaky crankshaft rear oil seal
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1406044">Rear Oil Seal Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Leaky cylinder head cover gasket
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1406010">Cylinder Head Cover Components</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
