<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1306018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
CKP Sensor Removal and Installation
</title>
<servinfosub id = "AENCP70A1306018001" page = "2">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove generator. 
<intxreftitleoff1 refid = "AENCP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from CKP sensor.
</ptxt>
</s1>
<s1>
<ptxt>
Remove CKP sensor (1) from cylinder block.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A131017.jpg" width = "88.000mm" height = "57.392mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</servinfosub>
<servinfosub id = "AENCP70A1306018002" page = "2">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1306019">CKP Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply engine oil to O-ring of sensor.
</ptxt>
</item>
<item>
<ptxt>
Tighten CKP sensor bolt to specified torque.
</ptxt>
<attention2>
<ptxt>
Be sure to use new bolts with pre-coated adhesive. Otherwise, bolts may loosen.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T1C008">
<t-part>
CKP sensor bolt (a)
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131008.jpg" width = "88.000mm" height = "57.393mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</item>
<item>
<ptxt>
Connect connector and fix wire harness with clamp securely.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
