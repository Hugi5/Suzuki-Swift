<servinfosub id = "AENCP70A5504047003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Check that the following condition is satisfied in this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
11 V &#60; Battery voltage &#60; 15 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Set ignition ON for 5 sec. or more.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5504047004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A5504047005">
<testgroup id = "AENCP70A5504047006">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504047007">
<title>
Slope sensor power supply circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “E60” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “E60” connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “A1” and “A3” is approx. 5 V.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504047008">
<title>
Slope sensor ground circuit check
</title>
<test1>
<ptxt>
Check that voltage between “A1” and ground is approx. 5 V.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Repair “A3” circuit.
</ptxt>
<ptxt>
If this DTC is detected again, substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair “A1” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504047009">
<title>
Slope sensor signal circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A2” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit terminal and other terminal at “E60” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A2” circuit: approx. 0 V (When ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504047010">
<title>
Slope sensor check
</title>
<test1>
<ptxt>
Check slope sensor. 
<intxreftitleoff1 refid = "AENCP70A5506035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace slope sensor. 
<intxreftitleoff1 refid = "AENCP70A5506034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
