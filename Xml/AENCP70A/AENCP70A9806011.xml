<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9806011" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Head Lining Removal and Installation
</title>
<servinfosub id = "AENCP70A9806011001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENCP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove sun visors (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove spot light (if equipped) (3) and dome light (2).
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Spot light (if equipped): 
<intxreftitleoff1 refid = "AENCP70A9206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dome light: 
<intxreftitleoff1 refid = "AENCP70A9206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove the following trims. 
<intxreftitleoff1 refid = "AENCP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front pillar trims
</ptxt>
</item>
<item>
<ptxt>
Center pillar upper trims
</ptxt>
</item>
<item>
<ptxt>
Rear quarter inner upper trims
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove assist grips (4) and head lining cap (7) (if equipped).
</ptxt>
</s1>
<s1>
<ptxt>
For sun roof model, remove sun roof trim (5).
</ptxt>
</s1>
<s1>
<ptxt>
Remove clips and remove head lining (6).
</ptxt>
<figure>
<graphic graphicname = "IAP70B980003.jpg" width = "183.000mm" height = "158.326mm" ver = "01" gw = "499" gh = "432"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "8" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.340in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.102in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.340in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.977in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.340in"/>
<colspec colnum = "6" colname = "6" colwidth = "1.234in"/>
<colspec colnum = "7" colname = "7" colwidth = "0.340in"/>
<colspec colnum = "8" colname = "8" colwidth = "1.083in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Without sun roof 
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
With sun roof 
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[C]:
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Without assist grip
</ptxt>
</entry>
<entry colname = "7" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[D]:
</ptxt>
</entry>
<entry colname = "8" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
With assist grip
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9806011002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Enable air bag system. 
<intxreftitleoff1 refid = "AENCP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
