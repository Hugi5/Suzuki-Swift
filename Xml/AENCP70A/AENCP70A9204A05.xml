<servinfo servinfosgmlid = "AENCP70A9204A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Front fog lights do not light up (if equipped)
</title>
<diag type = "condition">
<condition>
<ptxt>
Front fog lights do not light up (if equipped)
</ptxt>
</condition>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
Repair circuit.
</ptxt>
</action>
<ps>
<ptxt>
Blown bulbs
</ptxt>
</ps>
<action>
<ptxt>
Replace bulbs.
</ptxt>
</action>
<ps>
<ptxt>
Faulty front fog light switch
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENCP70A9206020">Front Fog Light Switch Inspection (If Equipped)</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
