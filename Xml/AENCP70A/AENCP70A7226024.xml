<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A7226024" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Temperature Control Actuator Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A7226023">Temperature Control Actuator Removal and Installation:Automatic Type</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Set arm to actuator and check if arm operates smoothly when battery voltage is conducted to terminals of actuator connector (1).
</ptxt>
<figure>
<title>
Temperature control actuator operation
</title>
<graphic graphicname = "IAP70A722009.swf" width = "88.000mm" height = "45.766mm" ver = "01" gw = "197" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Using ohmmeter, measure resistance between “3” terminal and “5” terminal of actuator connector (1) at each arm position.
</ptxt>
<spec>
<title>
Temperature control actuator resistance
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.312in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.147in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Arm position
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Resistance (25 °C (77 °F))
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
MAX COOL [a]
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Approx. 2.4 kΩ
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
MAX HOT [b]
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Approx. 4.8 kΩ
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</s1>
<s1>
<ptxt>
Using ohmmeter, measure resistance between “1” terminal and “3” terminal.
</ptxt>
<ptxt>
If check result is not as specified, replace temperature control actuator.
</ptxt>
<spec>
<title>
Temperature control actuator resistance (Total resistance)
</title>
<ptxt>
6 kΩ
</ptxt>
<figure>
<graphic graphicname = "IAP70A722010.swf" width = "88.000mm" height = "74.781mm" ver = "01" gw = "148" gh = "195"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.629in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.652in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
60°
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Arm
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Temperature control actuator
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</spec>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
