<servinfosub id = "AENCP70A8204050002">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENCP70A8204050003">
<testgroup id = "AENCP70A8204050004">
<title>
Driver air bag (inflator) module circuit check
</title>
<test1>
<ptxt>
Remove driver air bag (inflator) module from steering wheel. 
<intxreftitleoff1 refid = "AENCP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G11” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector inserting release tool included in special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Check the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “G11-5” and “G11-6” terminals: infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B081">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820057.swf" width = "90.000mm" height = "55.937mm" ver = "01" gw = "200" gh = "142"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check for defective wire harness. If check result is OK, replace contact coil assembly. 
<intxreftitleoff1 refid = "AENCP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A8204050005">
<title>
Contact coil circuit (driver air bag (inflator) module circuit) check
</title>
<test1>
<ptxt>
Remove contact coil assembly. 
<intxreftitleoff1 refid = "AENCP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “S121-1” and “S172-2” terminals: 1 Ω or less
</ptxt>
</item>
<item>
<ptxt>
Resistance between “S121-2” and “S172-1” terminals: 1 Ω or less
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B082">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70B820008.swf" width = "90.000mm" height = "70.672mm" ver = "01" gw = "196" gh = "184"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace contact coil assembly. 
<intxreftitleoff1 refid = "AENCP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A8204050006">
<title>
Contact coil circuit (horn circuit) check
</title>
<test1>
<ptxt>
Check if there is continuity between “S61-1” and “S171-1” terminals of contact coil.
</ptxt>
<testfigure>
<graphic graphicname = "IAP70B820009.swf" width = "90.000mm" height = "85.574mm" ver = "01" gw = "214" gh = "226"/>
</testfigure>
</test1>
<question>
Is resistance 1 Ω or less?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace contact coil assembly. 
<intxreftitleoff1 refid = "AENCP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A8204050007">
<title>
Contact coil circuit check
</title>
<test1>
<ptxt>
Measure resistance between each terminal of contact coil and other terminals.
</ptxt>
</test1>
<question>
Is each measured resistance infinite?
</question>
<result type = "yes"/>
<action>
<ptxt>
Contact coil and its circuit are in good condition.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace contact coil assembly. 
<intxreftitleoff1 refid = "AENCP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
