<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5506030" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
CVT Fluid Temperature Sensor On-Vehicle Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5506028">Solenoid Connector Disconnection and Reconnection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect solenoid connector from transaxle 
<intxreftitleoff1 refid = "AENCP70A5506028"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</s1>
<s1>
<ptxt>
Check for proper terminal connection to solenoid connector.
</ptxt>
</s1>
<s1>
<ptxt>
Check resistance of CVT fluid temperature sensor and its circuit between terminals “17” and “22” at connector of transaxle.
</ptxt>
<ptxt>
Replace CVT assembly if defective.
</ptxt>
<spec>
<title>
CVT fluid temperature sensor resistance:
</title>
<ptxt>
20 &#176;C (68 &#176;F): Approx. 6.5 kΩ
</ptxt>
<ptxt>
80 &#176;C (176 &#176;F): Approx. 0.9 kΩ
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP70A550084.swf" width = "88.000mm" height = "49.659mm" ver = "01" gw = "94" gh = "124"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
