<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A3116008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Front Wheel Hub, Steering Knuckle and Wheel Bearing Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A3116006">Front Wheel Hub and Steering Knuckle Components:Front</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
When removing and installing steering knuckle, be careful not to damage front brake dust cover of suspension arm joint.
</ptxt>
</attention2>
<servinfosub id = "AENCP70A3116008001">
<title>
Removal
</title>
<s1>
<ptxt>
Hoist vehicle and remove front wheel. 
<intxreftitleoff1 refid = "AENCP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove drive shaft nut. 
<intxreftitleoff1 refid = "AENCP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove brake disc. 
<intxreftitleoff1 refid = "AENCP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pull out wheel hub (1) with special tools.
</ptxt>
<attention3>
<ptxt>
Outer side of wheel bearing inner race comes out together with wheel hub.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3A104">
<s-part>
(A)
</s-part>
<s-number num = "09943-17912">
09943–17912
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A105">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942–15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311016.swf" width = "88.000mm" height = "57.642mm" ver = "01" gw = "181" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect tie-rod end from steering knuckle. 
<intxreftitleoff1 refid = "AENCP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front wheel speed sensor from steering knuckle. 
<intxreftitleoff1 refid = "AENCP70A4506006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove strut bracket nuts and bolts. 
<intxreftitleoff1 refid = "AENCP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect suspension arm joint from steering knuckle. 
<intxreftitleoff1 refid = "AENCP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering knuckle from drive shaft.
</ptxt>
</s1>
<s1>
<ptxt>
Undo caulking (1) at 4 places with chisel or the like.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front brake dust cover (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A311015.swf" width = "88.000mm" height = "63.961mm" ver = "01" gw = "187" gh = "165"/>
</figure>
</s1>
<s1>
<ptxt>
Remove circlip (1) from steering knuckle.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Using hydraulic press (1) and special tools, push out wheel bearing.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A106">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913–75810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A107">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951–18211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A311017.swf" width = "88.000mm" height = "46.725mm" ver = "01" gw = "99" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Pry wheel bearing outside inner race (1) a little using chisel or the like.
</ptxt>
</s1>
<s1>
<ptxt>
Remove wheel bearing outside inner race (1) from wheel hub using special tools as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A108">
<s-part>
(A)
</s-part>
<s-number num = "09913-65810">
09913–65810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A109">
<s-part>
(B)
</s-part>
<s-number num = "09926-37610-003">
09926–37610–003
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311020.swf" width = "88.000mm" height = "78.517mm" ver = "01" gw = "104" gh = "206"/>
</figure>
</s1>
<s1>
<ptxt>
Remove hub bolts (1) with copper hammer or hydraulic press, if necessary.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A220020.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "166" gh = "128"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A3116008002">
<title>
Installation
</title>
<s1>
<ptxt>
Insert new hub bolt (1) in hub hole. Rotate hub bolt slowly to assure that serrations are aligned with those made by original bolt, if removed.
</ptxt>
<figure>
<graphic graphicname = "I2RH01220040.swf" width = "88.000mm" height = "47.317mm" ver = "01" gw = "142" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Put new wheel bearing (1) on steering knuckle (2) with its brown seal (3) side facing down as shown in figure.
</ptxt>
<attention2>
<ptxt>
Do not reuse wheel bearing to avoid noise or sticking.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Press-fit wheel bearing into steering knuckle (2) using special tools as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A110">
<s-part>
(A)
</s-part>
<s-number num = "09913-75510">
09913–75510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3A111">
<s-part>
(B)
</s-part>
<s-number num = "09926-68310">
09926–68310
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3A112">
<s-part>
(C)
</s-part>
<s-number num = "09951-18211">
09951–18211
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70B311008.swf" width = "88.000mm" height = "71.587mm" ver = "01" gw = "232" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Install circlip (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Set new front brake dust cover.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
When press-fitting front brake dust cover, do not deform it.
</ptxt>
</item>
<item>
<ptxt>
When installing front brake dust cover, use new one.
</ptxt>
</item>
</list1>
</attention2>
</s1>
<s1>
<ptxt>
Press-fit new front brake dust cover (2) into steering knuckle using hydraulic press (1) and special tools.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A113">
<s-part>
(A)
</s-part>
<s-number num = "09951-17010">
09951–17010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A114">
<s-part>
(B)
</s-part>
<s-number num = "09944-77030">
09944–77030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311018.swf" width = "88.000mm" height = "55.099mm" ver = "01" gw = "203" gh = "140"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.630in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.144in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
13&#176;
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“b”:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
70 mm (2.8 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Caulk more than 4 places with a small with a small cold chisel.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311020.swf" width = "88.000mm" height = "52.911mm" ver = "01" gw = "186" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.933in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Caulking
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Using special tools and hydraulic press, press-fit wheel hub (1) into wheel bearing (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L3A115">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913–75810
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3A116">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951–18211
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311017.swf" width = "88.000mm" height = "57.910mm" ver = "01" gw = "203" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Connect drive shaft to steering knuckle. 
<intxreftitleoff1 refid = "AENCP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect steering knuckle to suspension arm. 
<intxreftitleoff1 refid = "AENCP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install strut bracket bolts and nuts. 
<intxreftitleoff1 refid = "AENCP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install front wheel speed sensor. 
<intxreftitleoff1 refid = "AENCP70A4506006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect tie-rod end to steering knuckle. 
<intxreftitleoff1 refid = "AENCP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install brake disc and brake caliper. 
<intxreftitleoff1 refid = "AENCP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Tighten new drive shaft nut. 
<intxreftitleoff1 refid = "AENCP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install front wheel. 
<intxreftitleoff1 refid = "AENCP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Confirm front wheel alignment. 
<intxreftitleoff1 refid = "AENCP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
