<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1406009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Intake Manifold Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1406005">Throttle Body and Intake Manifold Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A1406009001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENCP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
With engine coolant hoses connected, remove electric throttle body assembly from intake manifold.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect MAP sensor connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect the following hoses:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Brake booster hose (2) from brake booster
</ptxt>
</item>
<item>
<ptxt>
PCV hose (3) from PCV valve
</ptxt>
<figure>
<graphic graphicname = "I7V20A141039.swf" width = "88.000mm" height = "53.078mm" ver = "01" gw = "221" gh = "134"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove heater inlet pipe bolt (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141022.jpg" width = "88.000mm" height = "51.297mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Remove intake manifold (1) and its gasket.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141040.swf" width = "88.000mm" height = "57.944mm" ver = "01" gw = "183" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Remove cooling water pipe (1). 
<intxreftitleoff1 refid = "AENCP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove spacer (2) and gasket from cylinder head.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141023.jpg" width = "88.000mm" height = "57.901mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1406009002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new gasket.
</ptxt>
</item>
<item>
<ptxt>
Check to ensure that all removed parts are back in place.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
