<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A9904A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Auto slide and auto tilt cannot operate (manual operation only)
</title>
<diag type = "condition">
<condition>
<ptxt>
Auto slide and auto tilt cannot operate (manual operation only)
</ptxt>
</condition>
<ps>
<ptxt>
Initialization is defective
</ptxt>
</ps>
<action>
<ptxt>
Initialize sun roof motor. 
<intxreftitleoff1 refid = "AENCP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Incorrect installation position of sun roof glass
</ptxt>
</ps>
<action>
<ptxt>
Adjust sun roof glass mounting position. 
<intxreftitleoff1 refid = "AENCP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty sliding movement of sun roof unit
</ptxt>
</ps>
<action>
<ptxt>
Replace sun roof unit. 
<intxreftitleoff1 refid = "AENCP70A9906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty sun roof motor
</ptxt>
</ps>
<action>
<ptxt>
Replace sun roof motor. 
<intxreftitleoff1 refid = "AENCP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
