<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5506037" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Differential Side Oil Seal Replacement
</title>
<s1>
<ptxt>
Hoist vehicle and drain CVT fluid. 
<intxreftitleoff1 refid = "AENCP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front drive shaft assembly. 
<intxreftitleoff1 refid = "AENCP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove differential side oil seal (1) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L5E009">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913–50121
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IBP50A550027.swf" width = "88.000mm" height = "125.206mm" ver = "01" gw = "149" gh = "338"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.698in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.608in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Right side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Left side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Apply grease to new differential side oil seal lip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease C" id = "M5E003" uid = "23">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25030
</m-number>
<m-name>
SUZUKI Super Grease C
</m-name>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Using special tool, install new differential side oil seals (1) at specified position as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L5E010">
<s-part>
(A)
</s-part>
<s-number num = "09926-27910">
09926–27910
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5E011">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Differential side oil seal installing depth
</title>
<ptxt>
Right side “a”: 0 to 0.5 mm (0 to 0.020 in.)
</ptxt>
<ptxt>
Left side “b”: 0.4 to 1.4 mm (0.016 to 0.055 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP50A550028.swf" width = "88.000mm" height = "94.970mm" ver = "01" gw = "226" gh = "253"/>
</figure>
<figure>
<graphic graphicname = "IBP50A550029.swf" width = "88.000mm" height = "93.218mm" ver = "01" gw = "211" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.320in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.706in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.320in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.647in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Right side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Left side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install front drive shaft assembly. 
<intxreftitleoff1 refid = "AENCP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Replenish CVT fluid. 
<intxreftitleoff1 refid = "AENCP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check CVT fluid level. 
<intxreftitleoff1 refid = "AENCP70A5506002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check for fluid leakage.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
