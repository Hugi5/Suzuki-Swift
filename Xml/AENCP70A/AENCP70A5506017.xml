<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
CVT Assembly Dismounting and Remounting
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5506016">CVT Assembly Components</intxrefpoff>
</ptxt>
<attention1>
<ptxt>
Be sure to keep CVT assembly with torque converter horizontal or facing up throughout the work. Torque converter should be tilted to prevent it from falling off. Otherwise, personal injury may occur.
</ptxt>
</attention1>
<attention2>
<ptxt>
When replacing CVT assembly, all learned controls which are stored in TCM memory should be erased after the replacement. 
<intxreftitleoff1 refid = "AENCP70A5506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Neglecting this initialization may cause excessive shift shock.
</ptxt>
</attention2>
<servinfosub id = "AENCP70A5506017001">
<title>
Dismounting
</title>
<s1>
<ptxt>
Dismount CVT assembly with engine. 
<intxreftitleoff1 refid = "AENCP70A1406016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove starting motor. 
<intxreftitleoff1 refid = "AENCP70A1906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove torque converter locating bolt and torque converter bolts as follows.
</ptxt>
<s2>
<ptxt>
Insert flat-bladed screwdriver or the like (2) to hole (1) of CVT assembly as shown in figure.
</ptxt>
</s2>
<s2>
<ptxt>
Lock drive plate (3) by engaging flat-bladed screwdriver or the like with gear of drive plate as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IAP70P550056.swf" width = "88.000mm" height = "91.740mm" ver = "01" gw = "239" gh = "244"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.739in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
CVT case
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
Remove torque converter locating bolt (4) and torque converter bolt (5) through starting motor opening.
</ptxt>
</s2>
<s2>
<ptxt>
Turn crankshaft by 60&#176; by turning crankshaft pulley bolt using wrench.
</ptxt>
</s2>
<s2>
<ptxt>
Repeat step a) through d) 5 times.
</ptxt>
<figure>
<graphic graphicname = "IAP70P550057.swf" width = "88.000mm" height = "71.905mm" ver = "01" gw = "188" gh = "187"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Remove front drive shaft assembly. 
<intxreftitleoff1 refid = "AENCP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove wire harness from CVT assembly.
</ptxt>
</s1>
<s1>
<ptxt>
Remove the following parts. 
<intxreftitleoff1 refid = "AENCP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Engine left mounting bracket
</ptxt>
</item>
<item>
<ptxt>
Engine rear mounting No.2 bracket
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove bolts and nut fastening engine and CVT assembly, and then detach CVT assembly from engine.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5506017002">
<title>
Remounting
</title>
<s1>
<ptxt>
Install torque converter.
</ptxt>
</s1>
<s1>
<ptxt>
Check that distance “a” is within specification.
</ptxt>
<spec>
<title>
Torque converter installing position
</title>
<ptxt>
“a”: More than 29.9 mm (1.18 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP70A550059.swf" width = "88.000mm" height = "55.076mm" ver = "02" gw = "241" gh = "140"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.377in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.803in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Torque converter
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Straightedge
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Torque converter housing
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Apply grease to “A” of torque converter (1).
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5E002" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IBP70A550058.swf" width = "88.000mm" height = "63.032mm" ver = "01" gw = "187" gh = "162"/>
</figure>
</s1>
<s1>
<ptxt>
Attach CVT assembly to engine.
</ptxt>
</s1>
<s1>
<ptxt>
Tighten bolts and nut to specified torque. 
<intxreftitleoff1 refid = "AENCP70A5506016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install the following parts. 
<intxreftitleoff1 refid = "AENCP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Engine left mounting bracket
</ptxt>
</item>
<item>
<ptxt>
Engine rear mounting No.2 bracket
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Tighten torque converter locating bolt and torque converter bolts as follows.
</ptxt>
<attention3>
<ptxt>
Torque converter locating bolt is used for accurate positioning.
</ptxt>
<ptxt>
Tighten converter locating bolt first so that bolt holes for torque converter and drive plate are positioned properly, and that torque converter bolts are tightened securely.
</ptxt>
<ptxt>
One torque converter locating bolt and five torque converter bolts are required to secure torque converter and drive plate.
</ptxt>
</attention3>
<s2>
<ptxt>
Insert flat-bladed screwdriver or the like (2) to hole (1) of CVT assembly as shown in figure.
</ptxt>
</s2>
<s2>
<ptxt>
Lock drive plate (3) by engaging flat-bladed screwdriver or the like with gear of drive plate as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IAP70P550056.swf" width = "88.000mm" height = "91.740mm" ver = "01" gw = "239" gh = "244"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.750in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
CVT case
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
Install torque converter locating bolt (1) to 5 N&#183;m (0.51 kgf-m, 4.0 lbf-ft) through starting motor opening.
</ptxt>
</s2>
<s2>
<ptxt>
Turn crankshaft by 60&#176; by turning crankshaft pulley bolt using wrench.
</ptxt>
</s2>
<s2>
<ptxt>
Tighten torque converter bolt (2) by hand through starting motor opening.
</ptxt>
</s2>
<s2>
<ptxt>
Repeat step d) through e) 4 times.
</ptxt>
</s2>
<s2>
<ptxt>
Tighten torque converter locating bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5E006">
<t-part>
Torque converter locating bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>
Turn crankshaft by 60&#176; and tighten torque converter bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5E007">
<t-part>
Torque converter bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70P550060.swf" width = "88.000mm" height = "71.905mm" ver = "01" gw = "188" gh = "187"/>
</figure>
</s2>
<s2>
<ptxt>
Repeat step h) 4 times.
</ptxt>
</s2>
</s1>
<s1>
<ptxt>
Install starting motor. 
<intxreftitleoff1 refid = "AENCP70A1906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install wire harness to CVT assembly.
</ptxt>
</s1>
<s1>
<ptxt>
Install front drive shaft assembly. 
<intxreftitleoff1 refid = "AENCP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remount engine with CVT assembly to vehicle. 
<intxreftitleoff1 refid = "AENCP70A1406016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Refill CVT fluid. 
<intxreftitleoff1 refid = "AENCP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check CVT fluid level. 
<intxreftitleoff1 refid = "AENCP70A5506002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
After installation, check for CVT fluid leakage at each connection.
</ptxt>
</s1>
<s1>
<ptxt>
When replacing CVT assembly with a new one or a used one, perform learning value initialization. 
<intxreftitleoff1 refid = "AENCP70A5506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
