<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Back Up Light Switch Removal and Installation
</title>
<servinfosub id = "AENCP70A5206007001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove battery and battery tray with ECM. 
<intxreftitleoff1 refid = "AENCP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect back up light switch connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove back up light switch (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A521044.swf" width = "88.000mm" height = "60.005mm" ver = "01" gw = "174" gh = "154"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.970in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Gear shift &#38; select shaft assembly
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5206007002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5206008">Back Up Light Switch Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Apply transaxle oil to new O-ring (1) and tighten back up light switch (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5B004">
<t-part>
Back up light switch
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I3RH0A520006.swf" width = "88.000mm" height = "31.317mm" ver = "01" gw = "148" gh = "73"/>
</figure>
</s1>
<s1>
<ptxt>
Connect back up light switch connector.
</ptxt>
</s1>
<s1>
<ptxt>
Install battery and battery tray, and then install coolant reservoir and ECM to battery tray.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
