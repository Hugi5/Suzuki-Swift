<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5506034" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Slope Sensor Removal and Installation
</title>
<attention2>
<ptxt>
When handling slope sensor, be careful not to drop or otherwise give shock to it. If slope sensor has received shock any way, never attempt its disassembly or repair, but replace the sensor with a new one.
</ptxt>
</attention2>
<attention3>
<ptxt>
Since the slope sensor has been removed or replaced, be sure to perform 
<intxref refid = "AENCP70A5506036">Slope Sensor Calibration</intxref>
. If it is not performed, some controls, including neutral idle control, could not function correctly.
</ptxt>
</attention3>
<servinfosub id = "AENCP70A5506034001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove slope sensor with TCM from vehicle. 
<intxreftitleoff1 refid = "AENCP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove slope sensor (1) from TCM bracket (2).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5506034002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5506035">Slope Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check TCM bracket for deformation.
</ptxt>
</item>
<item>
<ptxt>
Tighten slope sensor nuts (3) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5E017">
<t-part>
Slope sensor nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.7
</t-value1>
<t-value2>
0.58
</t-value2>
<t-value3>
4.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A550087.swf" width = "88.000mm" height = "45.791mm" ver = "01" gw = "79" gh = "113"/>
</figure>
</item>
<item>
<ptxt>
Install slope sensor with TCM to vehicle. 
<intxreftitleoff1 refid = "AENCP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
