<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9906004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Sun Roof Glass Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A9906001">Sun Roof Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A9906004001">
<title>
Removal
</title>
<s1>
<ptxt>
Open sunshade (1) fully and tilt up sun roof.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990022.swf" width = "88.000mm" height = "43.115mm" ver = "01" gw = "138" gh = "106"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove sun roof glass by removing sun roof glass fixing bolts (TORX<sup>®</sup> T25) (1).
</ptxt>
<figure>
<graphic graphicname = "I5JB0A990003.swf" width = "88.000mm" height = "45.253mm" ver = "01" gw = "185" gh = "112"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9906004002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten sun roof glass fixing bolts to specified torques. 
<intxreftitleoff1 refid = "AENCP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Adjust sun roof glass mounting position. 
<intxreftitleoff1 refid = "AENCP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Initialize sun roof motor. 
<intxreftitleoff1 refid = "AENCP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
