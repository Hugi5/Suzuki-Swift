<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A7216025" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Air Intake Control Actuator Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A7216019">HVAC Control Unit Components:Manual Type</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A7216025001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove glove box. 
<intxreftitleoff1 refid = "AENCP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove passenger side foot duct. 
<intxreftitleoff1 refid = "AENCP70A7216012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect air intake control actuator connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove air intake control actuator (2) from HVAC unit.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721028.jpg" width = "88.000mm" height = "68.236mm" ver = "01" gw = "142" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A7216025002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A7216026">Air Intake Control Actuator Inspection:Manual Type</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to insert linkage pin (1) into groove (2) of air intake control actuator.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721029.swf" width = "88.000mm" height = "49.668mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
