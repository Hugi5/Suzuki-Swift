<servinfosub id = "AENCP70A5504020003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Check that the following conditions are satisfied in this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
DTC U0073 or U0100 is not detected.
</ptxt>
</item>
<item>
<ptxt>
11 V &#60; Battery voltage &#60; 15 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Set ignition ON.
</ptxt>
</s1>
<s1>
<ptxt>
Stop vehicle for 2 sec. or more by depressing brake pedal.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5504020004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A5504020005">
<testgroup id = "AENCP70A5504020006">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A5504001">CVT System Check</intxref>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504020007">
<title>
Transmission range sensor circuit check for operation using SUZUKI scan tool
</title>
<test1>
<ptxt>
With ignition OFF, connect SUZUKI scan tool to DLC.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check transmission range signal (P, R, N, D, M) on scan tool when shifting select lever to each range.
</ptxt>
</test1>
<question>
Is applicable range indicated?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504020008">
<title>
Select cable adjustment check
</title>
<test1>
<ptxt>
Check select cable for adjustment. 
<intxreftitleoff1 refid = "AENCP70A5506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it adjusted correctly?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Adjust select cable and recheck DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504020009">
<title>
Transmission range sensor adjustment check
</title>
<test1>
<ptxt>
Check transmission range sensor for adjustment. 
<intxreftitleoff1 refid = "AENCP70A5506021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it adjusted correctly?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Adjust transmission range sensor and recheck DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504020010">
<title>
Transmission range sensor circuit signal check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “C166”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C166”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between each of “A1”, “A2”, “A3”, “A4” and “A5” circuit terminals and other terminal at “C166” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A1”, “A2”, “A3”, “A4” and “A5” circuits: approx. 0 V (when ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504020011">
<title>
Transmission range sensor check
</title>
<test1>
<ptxt>
Check transmission range sensor. 
<intxreftitleoff1 refid = "AENCP70A5506020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace transmission range sensor. 
<intxreftitleoff1 refid = "AENCP70A5506022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
