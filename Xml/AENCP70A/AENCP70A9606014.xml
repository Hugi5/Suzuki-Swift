<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9606014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear End Door Opener Switch Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A9606013">Rear End Door Opener Switch On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A9606014001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear end door trim. 
<intxreftitleoff1 refid = "AENCP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect rear end door opener switch connector (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Remove rear end door lower garnish. 
<intxreftitleoff1 refid = "AENCP70A9206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (1), and then remove rear end door opener switch (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A960020.jpg" width = "88.000mm" height = "57.494mm" ver = "01" gw = "194" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9606014002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
