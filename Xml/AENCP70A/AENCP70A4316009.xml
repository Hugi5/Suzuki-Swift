<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4C">
<servcat sctnbr = "04" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4316009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Brake Back Plate Removal and Installation 
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4316001">Rear Brake Components:Drum Brake Model</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Brake fluid is extremely damaging to painted surfaces. If brake fluid contacts any painted surface, immediately wipe it off and flush the surface with water thoroughly.
</ptxt>
</attention2>
<servinfosub id = "AENCP70A4316009001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove wheel cylinder. 
<intxreftitleoff1 refid = "AENCP70A4316007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove parking brake cable (1) from brake back plate.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A430020.swf" width = "88.000mm" height = "48.493mm" ver = "01" gw = "130" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Remove rear wheel hub assembly. 
<intxreftitleoff1 refid = "AENCP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</s1>
<s1>
<ptxt>
Remove brake back plate.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A4316009002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Install parking brake cable (1) to brake back plate.
</ptxt>
<torque>
<torqueitem id = "T4C103">
<t-part>
Parking cable cap nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I4RS0A430024.swf" width = "88.000mm" height = "48.493mm" ver = "01" gw = "131" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Bleed air from brake system. 
<intxreftitleoff1 refid = "AENCP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</item>
<item>
<ptxt>
Adjust parking brake cable. 
<intxreftitleoff1 refid = "AENCP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
