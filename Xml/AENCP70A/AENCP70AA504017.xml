<servinfosub id = "AENCP70AA504017003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Open driver door.
</ptxt>
</s1>
<s1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 2) and 3) several times.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70AA504017004">
<title>
DTC Troubleshooting
</title>
<attention3>
<ptxt>
This DTC might be detected when battery is run down or the voltage is very low.
</ptxt>
</attention3>
<diag type = "test" id = "AENCP70AA504017005">
<testgroup id = "AENCP70AA504017006">
<title>
Parameter check
</title>
<test1>
<ptxt>
Connect SUZUKI scan tool to DLC when ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Steering Unlock Condition” and “Steering Lock Condition” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENCP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA504017007">
<title>
Steering lock unit operation check
</title>
<test1>
<ptxt>
Open driver door.
</ptxt>
</test1>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Repeat Step 2) and 3) several times.
</ptxt>
</test1>
<test1>
<ptxt>
Check that steering lock is locked / unlocked according to change of ignition.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA504017008">
<title>
Steering lock unit power supply circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect steering lock unit connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to steering lock unit connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check that voltage between “A2” and “C1” circuit is battery voltage when ignition is switched from “OFF” to “ON”.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA504017009">
<title>
Steering lock unit ground circuit check
</title>
<test1>
<ptxt>
Check that voltage between “A2” circuit and ground is battery voltage when ignition is switched from “OFF” to “ON”.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Repair or replace “C1” circuit.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA504017010">
<title>
Steering lock unit power supply circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G28” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “G28” connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A2” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit terminal and each terminal at steering lock unit connector: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70AA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA504017011">
<title>
Steering lock unit signal circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G28” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “G28” connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B1” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit terminal and each terminal at steering lock unit connector: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA504017012">
<title>
DTC check
</title>
<test1>
<ptxt>
Replace steering lock unit. 
<intxreftitleoff1 refid = "AENCP70A6206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Perform 
<intxref refid = "AENCP70AA504017003">DTC Confirmation Procedure</intxref>
 and then recheck DTC.
</ptxt>
</test1>
<question>
Is DTC B1160 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70AA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Steering lock unit was faulty.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
