<servinfosub id = "AENCP70A5504027003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed with two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<ptxt>
Check that the following conditions are satisfied in this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
DTC P0717 is not detected.
</ptxt>
</item>
<item>
<ptxt>
11 V &#60; Battery voltage &#60; 15 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Start engine and drive vehicle at 70 km/h (43 mile/h) constantly for 30 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Stop vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition OFF, and leave ignition OFF for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 1) through 3).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5504027004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A5504027005">
<testgroup id = "AENCP70A5504027006">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504027007">
<title>
TCC solenoid valve drive circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C142”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C142”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A3” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A3” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A3” circuit terminal and other terminal at “C142” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A3” circuit: approx. 0 V (when ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504027008">
<title>
TCC solenoid valve check
</title>
<test1>
<ptxt>
Check resistance of TCC solenoid valve. 
<intxreftitleoff1 refid = "AENCP70A5506029"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace TCC solenoid valve (CVT assembly). 
<intxreftitleoff1 refid = "AENCP70A5506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504027009">
<title>
TCC solenoid valve drive circuit signal check
</title>
<test1>
<ptxt>
Connect “C142”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Connect an oscilloscope between “A3” and ground, and then check TCC control solenoid valve drive circuit signals. 
<intxreftitleoff1 refid = "AENCP70A5504055"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace CVT assembly. 
<intxreftitleoff1 refid = "AENCP70A5506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
