<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A7216014" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "1">
<title>
Evaporator Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A7216009">HVAC Unit Removal and Installation:Manual Type</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENCP70A7216008">HVAC Unit Components:Manual Type</intxrefpoff>
</ptxt>
<ptxt>
Check the following:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Evaporator fins for clogging.
</ptxt>
<ptxt>
If clogged, wash evaporator fins washed with water, and then dry it with compressed air.
</ptxt>
</item>
<item>
<ptxt>
Evaporator fins for leakage and breakage
</ptxt>
<ptxt>
If evaporator fins are leaky or broken, repair or replace evaporator.
</ptxt>
</item>
<item>
<ptxt>
Evaporator fittings for leakage
</ptxt>
<ptxt>
If evaporator fittings are leaky, repair or replace evaporator.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
