<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9206001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Headlight Unit Removal and Installation
</title>
<attention1>
<ptxt>
Headlight bulbs may be extremely hot. There is risk of burn if you touch them carelessly.
</ptxt>
</attention1>
<attention2>
<ptxt>
Do not touch glass surface of bulb with bare hands. Bulb surface with dirt deteriorates and becomes unclear when bulb lights up.
</ptxt>
</attention2>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Bulb(s) can be replaced as headlight unit is installed on vehicle.
</ptxt>
</item>
<item>
<ptxt>
After replacing headlight unit and/or headlight bulb(s), check and adjust headlight. 
<intxreftitleoff1 refid = "AENCP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<servinfosub id = "AENCP70A9206001001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENCP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect headlight unit connectors.
</ptxt>
</s1>
<s1>
<ptxt>
Remove headlight unit screws (1) and clip and then remove headlight unit (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P920007.jpg" width = "88.000mm" height = "69.820mm" ver = "01" gw = "206" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Remove bulbs, if necessary.
</ptxt>
<figure>
<graphic graphicname = "IAP70P920041.swf" width = "88.000mm" height = "68.513mm" ver = "02" gw = "212" gh = "178"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.237in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.235in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.216in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.601in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Clearance light bulb
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Turn signal light bulb socket
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Turn signal light bulb
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Clearance light bulb socket
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Headlight bulb
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
6.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Socket cover
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9206001002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Install headlight unit clip.
</ptxt>
</item>
<item>
<ptxt>
Install headlight unit screws (1, “1” – 1, “4”) according to numerical order as shown in figure.
</ptxt>
<attention2>
<ptxt>
Do not reuse headlight unit screws (1).
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70B920011.jpg" width = "88.000mm" height = "69.820mm" ver = "01" gw = "206" gh = "181"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
