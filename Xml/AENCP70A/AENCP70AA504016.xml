<servinfosub id = "AENCP70AA504016003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Depress brake pedal fully for 3 seconds or more.
</ptxt>
</s1>
<s1>
<ptxt>
Release brake pedal for 3 seconds or more.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70AA504016004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70AA504016005">
<testgroup id = "AENCP70AA504016006">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC in ECM. 
<intxreftitleoff1 refid = "AENCP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC P0504 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA504016007">
<title>
Parameter check
</title>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Brake light switch” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENCP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA504016008">
<title>
Brake light switch signal circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect brake light switch, “C01”, “E01” and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to brake light switch, “C01”, “E01” and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check that resistance of “A1” circuit: less than 1 Ω
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA504016009">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Connect each connector of brake light switch, “C01”, “E01” and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENCP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is current DTC B1137 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70AA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
</testgroup>
</diag>
