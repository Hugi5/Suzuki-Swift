<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A1104009" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "1">
<title>
Engine Basic Inspection
</title>
<ptxt>
This check is very important for troubleshooting when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENCP70A1104008">Visual Inspection</intxref>
.
</ptxt>
<ptxt>
Follow the flow carefully.
</ptxt>
<diag type = "test" id = "AENCP70A1104009001">
<testgroup id = "AENCP70A1104009002">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104009003">
<title>
Check battery voltage
</title>
<question>
Is it 11 V or more?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Charge or replace battery.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104009004">
<question>
Is engine cranked?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1904001">Cranking System Symptom Diagnosis</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104009005">
<question>
Does engine start?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104009006">
<title>
Check idle speed
</title>
<test1>
<ptxt>
Check engine idle speed. 
<intxreftitleoff1 refid = "AENCP70A1106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104010">Engine Symptom Diagnosis</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104009007">
<title>
Check ignition system
</title>
<test1>
<ptxt>
Check ignition system. 
<intxreftitleoff1 refid = "AENCP70A1804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104010">Engine Symptom Diagnosis</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104009008">
<title>
Check immobilizer system for operation
</title>
<test1>
<ptxt>
Check immobilizer control system.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENCP70AA314001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENCP70AA324001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Immobilizer control system malfunction.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104009009">
<title>
Check fuel supply
</title>
<test1>
<ptxt>
Check fuel supply. 
<intxreftitleoff1 refid = "AENCP70A1706014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 9.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104009010">
<title>
Check fuel injector circuit
</title>
<test1>
<ptxt>
Check fuel injector circuit referring to 
<intxref refid = "AENCP70A1704003">Fuel Injector Circuit Check</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104010">Engine Symptom Diagnosis</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1704003">Fuel Injector Circuit Check</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
