<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A4104A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
ABS warning light remains ON (for more than 2 sec) after setting ignition to “ON”
</title>
<diag type = "condition">
<condition>
<ptxt>
ABS warning light remains ON (for more than 2 sec) after setting ignition to “ON”
</ptxt>
</condition>
<ps>
<ptxt>
Faulty ABS / ESP<sup>®</sup> function
</ptxt>
</ps>
<action>
<ptxt>
Perform ABS / ESP<sup>®</sup> system check. 
<intxreftitleoff1 refid = "AENCP70A4504001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ABS / ESP<sup>®</sup> control module power supply and ground circuit
</ptxt>
</ps>
<action>
<ptxt>
Check ABS / ESP<sup>®</sup> control module power supply and ground circuit. 
<intxreftitleoff1 refid = "AENCP70A4504023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty combination meter
</ptxt>
</ps>
<action>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENCP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
