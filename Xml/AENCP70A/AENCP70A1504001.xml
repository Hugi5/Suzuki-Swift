<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A1504001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Oil Pressure Check
</title>
<attention1>
<ptxt>
To avoid danger of being burned, do not touch the exhaust system when the system is hot.
</ptxt>
</attention1>
<attention3>
<ptxt>
Prior to checking oil pressure, check the following.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Oil level in oil pan
</ptxt>
<ptxt>
If oil level is low, add oil up to full level mark (hole) (1) on oil level gauge. 
<intxreftitleoff1 refid = "AENCP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Oil quality
</ptxt>
<ptxt>
If oil is discolored or deteriorated, change it. 
<intxreftitleoff1 refid = "AENCP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Oil leaks
</ptxt>
<ptxt>
If leak is found, repair leaky point.
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
For M/T model, place gear shift lever in “Neutral” and apply parking brake.
</ptxt>
<ptxt>
For CVT model, place select lever in “P” and apply parking brake.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENCP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove engine front cover.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect oil pressure switch lead wire (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil pressure switch (2) from cylinder block.
</ptxt>
<figure>
<graphic graphicname = "I7V20A151002.swf" width = "88.000mm" height = "51.220mm" ver = "01" gw = "182" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Install special tools to threaded hole where oil pressure switch was removed.
</ptxt>
<servicetool>
<servicetoolitem id = "L1E001">
<s-part>
(A)
</s-part>
<s-number num = "09915-77311">
09915–77311
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L1E002">
<s-part>
(B)
</s-part>
<s-number num = "09915-78211">
09915–78211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A151003.swf" width = "88.000mm" height = "51.906mm" ver = "01" gw = "230" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Start engine and warm engine up to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
After warming up, raise engine speed to 4,000 rpm and measure oil pressure.
</ptxt>
<spec>
<title>
Oil pressure specification
</title>
<ptxt>
More than 300 – 500 kPa (3.1 – 5.1 kgf/cm<sup>2</sup>, 43.5 – 72.5 psi) at 4,000 rpm.
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
After checking oil pressure, stop engine and remove special tools.
</ptxt>
</s1>
<s1>
<ptxt>
Apply sealant to thread portion of oil pressure switch (1), and then tighten oil pressure switch to specified torque.
</ptxt>
<attention2>
<ptxt>
Do not apply sealant to oil pressure switch hole.
</ptxt>
</attention2>
<materials>
<materialitem name = "Thread Lock Cement Super 1322" id = "M1E001" uid = "37">
<m-part>
“A”
</m-part>
<m-desc>
Thread lock cement
</m-desc>
<m-number>
99000–32110
</m-number>
<m-name>
Thread Lock Cement Super 1322
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<torque>
<torqueitem id = "T1E001">
<t-part>
Oil pressure switch
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9R90A150004.swf" width = "88.000mm" height = "51.483mm" ver = "01" gw = "184" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Connect oil pressure switch lead wire (1).
</ptxt>
<figure>
<graphic graphicname = "I7V20A151005.swf" width = "88.000mm" height = "51.029mm" ver = "01" gw = "186" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Start engine and check oil pressure switch for oil leakage. If oil leakage is found, repair correct installation of oil pressure switch.
</ptxt>
</s1>
<s1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENCP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If any DTC is displayed, clear DTC. 
<intxreftitleoff1 refid = "AENCP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
