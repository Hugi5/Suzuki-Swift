<servinfosub id = "AENCP70AA204014003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70AA204014004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70AA204014005">
<testgroup id = "AENCP70AA204014006">
<title>
Parameter check
</title>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Outside Air Temp” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENCP70AA204008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA204014007">
<title>
Outside air temperature sensor circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect outside air temperature sensor and following connectors.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ignition switch model: “E04” connector
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: “E05” connector
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to outside air temperature sensor and following connectors.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ignition switch model: “E04” connector
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: “E05” connector
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” and “A2” circuits: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” and “A2” circuit terminals at outside air temperature sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A1” and “A2” circuits: approx. 0 V (when ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA204014008">
<title>
Outside air temperature sensor check
</title>
<test1>
<ptxt>
Check outside air temperature sensor. 
<intxreftitleoff1 refid = "AENCP70AA206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace outside air temperature sensor. 
<intxreftitleoff1 refid = "AENCP70AA206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA204014009">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Connect outside air temperature sensor and following connectors.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ignition switch model: “E04” connector
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: “E05” connector
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENCP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is current DTC B1141 or B1142 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace BCM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
</testgroup>
</diag>
