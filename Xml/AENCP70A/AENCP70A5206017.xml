<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5206017" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Transaxle Right Case Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5206011">Manual Transaxle Unit Dismounting and Remounting</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENCP70A5206010">Manual Transaxle Unit Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A5206017001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove input shaft oil seal (1), if necessary.
</ptxt>
<figure>
<graphic graphicname = "I9P60A521039.jpg" width = "88.000mm" height = "54.306mm" ver = "01" gw = "173" gh = "137"/>
</figure>
</s1>
<s1>
<ptxt>
Pull out countershaft right bearing outer race (1) using special tools, if necessary.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B010">
<s-part>
(A)
</s-part>
<s-number num = "09930-30104">
09930–30104
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B011">
<s-part>
(B)
</s-part>
<s-number num = "09941-64511">
09941–64511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I4RS0B521030.swf" width = "88.000mm" height = "48.940mm" ver = "01" gw = "107" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Replace differential side oil seal from transaxle right case, if necessary. 
<intxreftitleoff1 refid = "AENCP70A5206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5206017002">
<title>
Reassembly
</title>
<attention3>
<ptxt>
Before reassembly, wash each part and apply specified transaxle oil to sliding faces of bearing and gear.
</ptxt>
</attention3>
<s1>
<ptxt>
Install differential side oil seal into transaxle right case, if removed. 
<intxreftitleoff1 refid = "AENCP70A5206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
If input shaft oil seal (1) has been removed, install it with its spring side facing upward using special tool and hammer. Apply grease to oil seal lip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B008" uid = "22">
<m-part>
“B”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<servicetool>
<servicetoolitem id = "L5B012">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913–75810
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
If countershaft right bearing outer race (2) has been removed, install it using special tools and hammer.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B013">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B014">
<s-part>
(C)
</s-part>
<s-number num = "09925-68210">
09925–68210
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I3RM0A520047.swf" width = "88.000mm" height = "59.298mm" ver = "01" gw = "155" gh = "151"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
