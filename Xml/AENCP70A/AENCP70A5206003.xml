<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Differential Side Oil Seal Replacement
</title>
<s1>
<ptxt>
Hoist vehicle and drain transaxle oil.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front drive shafts. 
<intxreftitleoff1 refid = "AENCP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil seals (1) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913–50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A521005.swf" width = "88.000mm" height = "47.981mm" ver = "01" gw = "132" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Install new oil seals (1) facing their spring side inward. Use special tool and hammer for installation.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09925-16010">
09925–16010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Distance between case and oil seal
</title>
<ptxt>
“a”: 0 – 0.5 mm (0 – 0.02 in.)
</ptxt>
<ptxt>
“b”: 2.5 – 3.0 mm (0.10 – 0.12 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Apply grease to oil seal lip and check drive shaft where oil seal contacts for smoothness.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B004" uid = "22">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A521006.swf" width = "88.000mm" height = "54.200mm" ver = "02" gw = "218" gh = "137"/>
</figure>
</s1>
<s1>
<ptxt>
Insert front drive shafts. 
<intxreftitleoff1 refid = "AENCP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Replenish transaxle oil as specified. 
<intxreftitleoff1 refid = "AENCP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Then make sure that oil is sealed with oil seal.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
