<section sectnbr = "0B">
<servcat sctnbr = "00" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A0206022" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "1">
<title>
Suspension System Inspection
</title>
<list1 type = "unordered">
<item>
<ptxt>
Inspect front strut assemblies and rear shock absorbers for sign of oil leakage, dents or any other damage on sleeves. Also inspect anchor ends for deterioration.
</ptxt>
<ptxt>
Replace defective parts, if any.
</ptxt>
</item>
<item>
<ptxt>
Check front and rear suspension systems for damaged, loose or missing parts. Also check them for parts showing signs of wear or lack of lubrication.
</ptxt>
<ptxt>
Repair or replace defective parts, if any.
</ptxt>
<figure>
<title>
Front
</title>
<graphic graphicname = "IAP70P020011.jpg" width = "88.000mm" height = "66.835mm" ver = "01" gw = "113" gh = "173"/>
</figure>
<figure>
<title>
Rear
</title>
<graphic graphicname = "IAP70P020012.jpg" width = "88.000mm" height = "86.351mm" ver = "01" gw = "200" gh = "228"/>
</figure>
</item>
<item>
<ptxt>
Check dust covers of front suspension arm ball joints for leakage, detachment, tear or any other damage.
</ptxt>
<ptxt>
For checking procedure, refer to Step 1) to 11) of “Joint” under 
<intxref refid = "AENCP70A2206009">Suspension Arm Check</intxref>
.
</ptxt>
<figure>
<graphic graphicname = "IAW101020014.swf" width = "88.000mm" height = "44.830mm" ver = "01" gw = "176" gh = "111"/>
</figure>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
