<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1406013" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Camshaft and Tappet Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1406012">Camshaft, Tappet and Shim Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A1406013001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove compressor drive belt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENCP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C model: 
<intxreftitleoff1 refid = "AENCP70A7226043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove water pump / generator drive belt. 
<intxreftitleoff1 refid = "AENCP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove cylinder head cover. 
<intxreftitleoff1 refid = "AENCP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Turn crankshaft clockwise and adjust No.1 cylinder to TDC as follows.
</ptxt>
<s2>
<ptxt>
Align both intake VVT actuator and exhaust VVT actuator marks (1) with surface of cylinder head (2) respectively.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141006.swf" width = "88.000mm" height = "46.550mm" ver = "01" gw = "219" gh = "115"/>
</figure>
</s2>
<s2>
<ptxt>
Align notch (1) on crankshaft pulley with “0” (2) indication on timing chain cover.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141007.swf" width = "88.000mm" height = "45.815mm" ver = "01" gw = "164" gh = "113"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Apply a dab of paint to two timing chain links (2) which meet timing marks (1) on intake VVT actuator and exhaust VVT actuator.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141030.jpg" width = "88.000mm" height = "55.707mm" ver = "01" gw = "209" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Remove crankshaft pulley bolt.
</ptxt>
<ptxt>
To lock crankshaft pulley (1), use special tool as shown in the following figure.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Use special tool to prevent unnecessary load on timing chain, sprockets and any other related parts.
</ptxt>
</item>
<item>
<ptxt>
Use bolts as specified below for installing special tool to crankshaft pulley.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Special tool fixing bolt
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.726in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.726in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bolt size
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
M8
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Pitch
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
1.25 mm (0.05 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Length “a”
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
25 mm (0.98 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Strength
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
7T
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</attention2>
<attention3>
<ptxt>
Use special tool with its pins removed if necessary.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1D006">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917–68221
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141049.swf" width = "88.000mm" height = "49.174mm" ver = "01" gw = "163" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Remove crankshaft pulley (1).
</ptxt>
<ptxt>
If it is hard to remove, use special tools as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D007">
<s-part>
(A)
</s-part>
<s-number num = "09926-37610-001">
09926–37610–001
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L1D008">
<s-part>
(B)
</s-part>
<s-number num = "09926-58010">
09926–58010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A141067.swf" width = "88.000mm" height = "59.461mm" ver = "01" gw = "168" gh = "152"/>
</figure>
</s1>
<s1>
<ptxt>
Remove timing chain cover plate (1) and gasket.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141031.jpg" width = "88.000mm" height = "73.310mm" ver = "01" gw = "199" gh = "191"/>
</figure>
</s1>
<s1>
<ptxt>
Remove timing chain tensioner adjuster (1) using the following procedure:
</ptxt>
<s2>
<ptxt>
Install timing chain tensioner adjuster plunger fixing bolt (2) to timing chain tensioner adjuster (1).
</ptxt>
<attention3>
<ptxt>
Use bolt as specified below for fixing timing chain tensioner adjuster plunger.
</ptxt>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Timing chain tensioner adjuster plunger fixing bolt
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.728in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.728in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Bolt size
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
M3
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Pitch
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
0.5 mm (0.02 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Length “a”
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
30 mm (1.18 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</attention3>
</s2>
<s2>
<ptxt>
Tighten timing chain tensioner adjuster plunger fixing bolt until its tip contacts timing chain tensioner adjuster plunger.
</ptxt>
</s2>
<s2>
<ptxt>
From that point, tighten timing chain tensioner adjuster plunger fixing bolt by 45&#176;.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141032.swf" width = "88.000mm" height = "54.598mm" ver = "01" gw = "199" gh = "138"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.560in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
45&#176;
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
Remove timing chain tensioner adjuster.
</ptxt>
<attention3>
<ptxt>
Turning the intake camshaft slightly in reverse direction facilitates removal of timing chain tensioner adjuster.
</ptxt>
</attention3>
</s2>
</s1>
<s1>
<ptxt>
Loosen camshaft housing bolts in numerical order (“1” – “21”) evenly and gradually.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141033.jpg" width = "88.000mm" height = "49.599mm" ver = "01" gw = "212" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Release timing chain (1) from intake VVT actuator (2) and exhaust VVT actuator (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove intake camshaft (4) and then exhaust camshaft (5).
</ptxt>
<attention3>
<ptxt>
Because a guide to prevent coming off of timing chain from crankshaft timing sprocket is provided, timing chain will not be disengaged from crankshaft timing sprocket even when camshafts are removed.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A141034.swf" width = "88.000mm" height = "61.749mm" ver = "01" gw = "216" gh = "159"/>
</figure>
</s1>
<s1>
<ptxt>
Remove camshaft bearings and tappets, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Remove VVT actuator from camshaft as follows, if necessary.
</ptxt>
<s2>
<ptxt>
Hold hexagonal section of camshaft using vice.
</ptxt>
</s2>
<s2>
<ptxt>
Remove VVT actuator bolt and remove VVT actuator (1).
</ptxt>
<attention2>
<ptxt>
Do not disassemble VVT actuator.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I9P60A141035.swf" width = "88.000mm" height = "63.076mm" ver = "01" gw = "197" gh = "162"/>
</figure>
</s2>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1406013002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1406014">Camshaft and Tappet Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install VVT actuator (1) to camshaft as follows, if removed.
</ptxt>
<s2>
<ptxt>
Hold hexagonal section of camshaft using vice.
</ptxt>
</s2>
<s2>
<ptxt>
Install VVT actuator and tighten VVT actuator bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D003">
<t-part>
VVT actuator bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6.1
</t-value2>
<t-value3>
44.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141076.swf" width = "88.000mm" height = "63.076mm" ver = "01" gw = "197" gh = "162"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Apply engine oil to contact surfaces of each tappet (hatched area), and install tappets (1) to cylinder head.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141016.swf" width = "88.000mm" height = "43.309mm" ver = "01" gw = "218" gh = "106"/>
</figure>
</s1>
<s1>
<ptxt>
Install camshaft bearings as follows:
</ptxt>
<s2>
<ptxt>
Fit tab (1) of camshaft bearing to groove (2) of cylinder head or camshaft housing.
</ptxt>
</s2>
<s2>
<ptxt>
Press camshaft bearing end (3) until the bearing is firmly seated on the cylinder head or camshaft housing.
</ptxt>
</s2>
<s2>
<ptxt>
Apply engine oil to sliding surface (4) of camshaft bearings.
</ptxt>
<attention2>
<ptxt>
Do not apply engine oil to mating surface (5) between bearing and camshaft housing or cylinder head.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I8T401142036.swf" width = "88.000mm" height = "38.847mm" ver = "01" gw = "130" gh = "94"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Apply engine oil to sliding surfaces of camshafts.
</ptxt>
</s1>
<s1>
<ptxt>
Install exhaust camshaft and then intake camshaft to cylinder head.
</ptxt>
</s1>
<s1>
<ptxt>
Install timing chain to intake VVT actuator and exhaust VVT actuator while aligning its painted links (2) with timing marks (1) on actuators.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141030.jpg" width = "88.000mm" height = "55.707mm" ver = "01" gw = "209" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Install camshaft housings (1) to proper places distinguished by letter (2), number (3) and arrow (4) on each camshaft housing.
</ptxt>
<figure>
<graphic graphicname = "I8T401142038.swf" width = "88.000mm" height = "35.927mm" ver = "01" gw = "66" gh = "85"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.055in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
I: For intake camshaft
</ptxt>
<ptxt>
E: For exhaust camshaft
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Position from timing chain side
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Point arrowhead to timing chain side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Tighten camshaft housing bolts as follows:
</ptxt>
<s2>
<ptxt>
Install camshaft housing No.1 (1).
</ptxt>
</s2>
<s2>
<ptxt>
Install camshaft housing bolts and tighten them by hand.
</ptxt>
</s2>
<s2>
<ptxt>
Tighten camshaft housing bolts in numerical order (“1” – “21”) evenly and gradually.
</ptxt>
<torque>
<torqueitem id = "T1D004">
<t-part>
Camshaft housing bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141037.jpg" width = "88.000mm" height = "50.275mm" ver = "02" gw = "223" gh = "126"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Remove timing chain tensioner adjuster plunger fixing bolt from timing chain tensioner adjuster.
</ptxt>
</s1>
<s1>
<ptxt>
Screw in plunger (2) of timing chain tensioner adjuster (1) clockwise and install the retainer (3) (1.4 mm (0.055 in.) diameter wire or the like) to hold plunger in place.
</ptxt>
<figure>
<graphic graphicname = "I8T401142078.swf" width = "88.000mm" height = "36.941mm" ver = "01" gw = "103" gh = "88"/>
</figure>
</s1>
<s1>
<ptxt>
Install timing chain tensioner adjuster as follows:
</ptxt>
<s2>
<ptxt>
Turn intake camshaft in reverse direction until timing chain becomes taut.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Be careful not to make the painted links of timing chain and timing marks on intake and exhaust VVT actuators out of alignment.
</ptxt>
</item>
<item>
<ptxt>
Turning the intake camshaft excessively makes the valve and piston contact. Be careful not to turn the intake camshaft excessively.
</ptxt>
</item>
</list1>
</attention2>
</s2>
<s2>
<ptxt>
Install timing chain tensioner adjuster (1) with the retainer.
</ptxt>
</s2>
<s2>
<ptxt>
Tighten timing chain tensioner adjuster bolts to specified torque, and then remove a retainer (2) from timing chain tensioner adjuster.
</ptxt>
<torque>
<torqueitem id = "T1D005">
<t-part>
Timing chain tensioner adjuster bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141038.swf" width = "88.000mm" height = "54.598mm" ver = "01" gw = "199" gh = "138"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Install timing chain cover plate (1) and new gasket, and then tighten new timing chain cover plate bolts (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D006">
<t-part>
Timing chain cover plate bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141039.jpg" width = "88.000mm" height = "73.310mm" ver = "01" gw = "199" gh = "191"/>
</figure>
</s1>
<s1>
<ptxt>
Install crankshaft pulley (1).
</ptxt>
</s1>
<s1>
<ptxt>
Tighten crankshaft pulley bolt as follows:
</ptxt>
<s2>
<ptxt>
Lock crankshaft pulley using special tool as shown in figure.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Use special tool to prevent unnecessary load on timing chain, sprockets and any other related parts.
</ptxt>
</item>
<item>
<ptxt>
Use bolts as specified below for installing special tool to crankshaft pulley.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Special tool fixing bolt
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.728in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.728in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bolt size
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
M8
</ptxt>
</entry>
</row>
</thead>
<tbody>
