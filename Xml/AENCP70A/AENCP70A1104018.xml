<servinfosub id = "AENCP70A1104018003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed by two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to troubleshoot first unexpected DTCs previously detected in “DTC Confirmation Procedure”.
</ptxt>
</item>
<item>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0100, P0102, P0103, P0112, P0113, P2100, P2101, P2176, P2228 or P2229 is not detected.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Start engine and drive vehicle at 50 to 70 km/h (31 to 43 mile/h) constantly for 3 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1104018004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A1104018005">
<testgroup id = "AENCP70A1104018006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104018007">
<title>
Air intake system and exhaust system check
</title>
<test1>
<ptxt>
Check air intake system, exhaust system, vacuum hose and PCV hose for clogging and damage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective part.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104018008">
<title>
Throttle body check
</title>
<test1>
<ptxt>
Check throttle body for performance. 
<intxreftitleoff1 refid = "AENCP70A1306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace throttle body.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104018009">
<title>
MAF sensor and its circuit check
</title>
<test1>
<ptxt>
Check MAF sensor and its circuit according to Step 2 through 6 under 
<intxref refid = "AENCP70A1104017">DTC P0100 / P0102 / P0103</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective part.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104018010">
<title>
Troubleshooting of other DTC(s) at the same time
</title>
<question>
Is other DTC(s) detected together?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
