<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4106024" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1">
<title>
Brake Booster Switch Inspection (CVT Model)
</title>
<servinfosub id = "AENCP70A4106024001">
<title>
Using SUZUKI Scan Tool
</title>
<s1>
<ptxt>
Disconnect vacuum hose from brake booster (2).
</ptxt>
</s1>
<s1>
<ptxt>
Connect special tool (A) to brake booster.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A014">
<s-part>
(A)
</s-part>
<s-number num = "09917-47011">
09917–47011
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70P410017.swf" width = "88.000mm" height = "55.130mm" ver = "02" gw = "179" gh = "140"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.384in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Brake booster switch
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Connect SUZUKI scan tool to DLC (1) located around bottom of instrument panel on driver’s seat side.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A015">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI scan tool (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70P180002.jpg" width = "88.000mm" height = "65.859mm" ver = "01" gw = "172" gh = "170"/>
</figure>
</s1>
<s1>
<ptxt>
Set ignition “ON”, and select “Brake Booster Condition” in “Data list” mode on SUZUKI scan tool.
</ptxt>
</s1>
<s1>
<ptxt>
Check data displayed on SUZUKI scan tool at each negative pressure specified.
</ptxt>
<ptxt>
If the data displayed is not as shown in the table, replace brake booster assembly with new one.
</ptxt>
<spec>
<title>
Brake booster switch reference value
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.086in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.378in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Negative pressure
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Scan tool display
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
22.7 kPa (0.2 kgf/cm<sup>2</sup>, 3.29 psi)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Value Lo
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
30.7 kPa (0.3 kgf/cm<sup>2</sup>, 4.45 psi)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Value Hi
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A4106024002">
<title>
Using Circuit Tester
</title>
<s1>
<ptxt>
Disconnect connector from brake booster switch (1).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect vacuum hose from brake booster (2).
</ptxt>
</s1>
<s1>
<ptxt>
Connect special tool (A) to brake booster.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A016">
<s-part>
(A)
</s-part>
<s-number num = "09917-47011">
09917–47011
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70P410017.swf" width = "88.000mm" height = "55.130mm" ver = "02" gw = "179" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Apply vacuum to brake booster by special tool and check for continuity between switch terminal and ground at each specified negative pressure in the following table.
</ptxt>
</s1>
<s1>
<ptxt>
If the tester reading is not as shown in the table, replace brake booster assembly with new one.
</ptxt>
<spec>
<title>
Brake booster switch continuity
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.086in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.378in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Negative pressure
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Tester reading
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
22.7 kPa (0.2 kgf/cm<sup>2</sup>, 3.29 psi)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Continuity exists
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
30.7 kPa (0.3 kgf/cm<sup>2</sup>, 4.45 psi)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
No continuity
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<figure>
<graphic graphicname = "IAP70P410018.swf" width = "88.000mm" height = "55.626mm" ver = "01" gw = "171" gh = "141"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.289in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.972in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Brake booster switch
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Circuit tester
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
