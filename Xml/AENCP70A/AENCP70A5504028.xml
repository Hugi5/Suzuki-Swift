<servinfosub id = "AENCP70A5504028003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed with two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<ptxt>
Check that the following condition is satisfied in this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
11 V &#60; Battery voltage &#60; 15 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Start engine and drive vehicle in D range at 50 km/h (31 mile/h) constantly for 5 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5504028004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A5504028005">
<testgroup id = "AENCP70A5504028006">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504028007">
<title>
Secondary pulley speed sensor power supply circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C45” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C45” connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “A1” and “C1” is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504028008">
<title>
Secondary pulley speed sensor signal circuit and ground circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B1” and “C1” circuits: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit terminal and other terminal at “C45” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “C1” circuit terminal and other terminal at “C45” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B1” and “C1” circuits: approx. 0 V (when ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504028009">
<title>
Secondary pulley speed sensor check
</title>
<test1>
<ptxt>
Check secondary pulley speed sensor. 
<intxreftitleoff1 refid = "AENCP70A5506027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace secondary pulley speed sensor. 
<intxreftitleoff1 refid = "AENCP70A5506026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
