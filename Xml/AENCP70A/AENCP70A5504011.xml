<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A5504011" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
DTC Check
</title>
<s1>
<ptxt>
Prepare SUZUKI scan tool.
</ptxt>
</s1>
<s1>
<ptxt>
With ignition OFF, connect SUZUKI scan tool to DLC (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L5E004">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI scan tool (SUZUKI-SDT)
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70P180002.jpg" width = "88.000mm" height = "65.859mm" ver = "01" gw = "172" gh = "170"/>
</figure>
</s1>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Read DTC, pending DTC and freeze frame data according to instructions displayed on scan tool and print it down. Refer to scan tool operator’s manual for further details.
</ptxt>
<ptxt>
If communication between scan tool and TCM is not possible, go to 
<intxref refid = "AENCP70AA804001">CAN Communication Check</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
After completing check, set ignition OFF and disconnect SUZUKI scan tool from DLC.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
