<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5506023" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Key Interlock Cable Removal and Installation (Ignition Switch Model)
</title>
<attention3>
<ptxt>
Do not bend interlock cable excessively when removing and installing it, or system will not operate correctly.
</ptxt>
</attention3>
<servinfosub id = "AENCP70A5506023001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENCP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering column cover. 
<intxreftitleoff1 refid = "AENCP70A6206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Turn ignition switch to ACC position.
</ptxt>
</s1>
<s1>
<ptxt>
Pull out key interlock cable (1) from key cylinder cover (2) while pressing check hook with a flat-bladed screwdriver or the like (3).
</ptxt>
<figure>
<graphic graphicname = "I7V10A510031.swf" width = "88.000mm" height = "52.325mm" ver = "02" gw = "142" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Turn ignition switch to LOCK position.
</ptxt>
</s1>
<s1>
<ptxt>
Remove floor console front box. 
<intxreftitleoff1 refid = "AENCP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Detach cable end (1) from interlock cam (2) while pressing claws (3) of interlock cam boss.
</ptxt>
<ptxt>
At this time, be careful not to cause damage to its claws.
</ptxt>
<ptxt>
Detach cable casing cap (4) from selector bracket (5) while pressing check hook.
</ptxt>
</s1>
<s1>
<ptxt>
Remove interlock cable.
</ptxt>
<figure>
<graphic graphicname = "I9P60A510034.swf" width = "88.000mm" height = "60.804mm" ver = "03" gw = "175" gh = "156"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5506023002">
<title>
Installation
</title>
<s1>
<ptxt>
Lay interlock cable to its original cabling route.
</ptxt>
<figure page = "1">
<graphic graphicname = "IBP50A550024.swf" width = "183.000mm" height = "79.573mm" ver = "01" gw = "283" gh = "209"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "6" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.331in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.070in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.331in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.272in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.331in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.876in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Key interlock cable
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Steering lock assembly
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Select cable
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Clamp
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Select lever assembly
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
6.
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
HVAC unit
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Turn ignition switch to ACC position.
</ptxt>
</s1>
<s1>
<ptxt>
Insert cable casing cap (1) into key cylinder cover (2) securely.
</ptxt>
<figure>
<graphic graphicname = "IBP50A550032.swf" width = "88.000mm" height = "51.557mm" ver = "01" gw = "142" gh = "130"/>
</figure>
</s1>
<s1>
<ptxt>
Pull out lock button (1) of selector side cable end (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH01510086.swf" width = "88.000mm" height = "46.964mm" ver = "01" gw = "112" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Shift select lever to N position.
</ptxt>
</s1>
<s1>
<ptxt>
Install cable casing cap (3) to selector bracket (4).
</ptxt>
</s1>
<s1>
<ptxt>
Connect cable end (1) to interlock cam (2) with ignition switch turned to ACC position.
</ptxt>
</s1>
<s1>
<ptxt>
Drive lock button (5) in cable end until it locks cable expansion and contraction.
</ptxt>
<figure>
<graphic graphicname = "I9P60A510036.swf" width = "88.000mm" height = "60.804mm" ver = "03" gw = "175" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Check key interlock cable function. 
<intxreftitleoff1 refid = "AENCP70A5506024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install floor console front box. 
<intxreftitleoff1 refid = "AENCP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install steering column cover. 
<intxreftitleoff1 refid = "AENCP70A6201001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Enable air bag system. 
<intxreftitleoff1 refid = "AENCP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
