<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5506007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Select Lever Assembly Removal and Installation
</title>
<servinfosub id = "AENCP70A5506007001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove floor console front box. 
<intxreftitleoff1 refid = "AENCP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect adjuster case (select cable end) from select lever assembly. 
<intxreftitleoff1 refid = "AENCP70A5506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect select lever connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove select lever nuts and detach select lever assembly from floor panel.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5506007002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten select lever nuts to specified torque. 
</ptxt>
<torque>
<torqueitem id = "T5E005">
<t-part>
Select lever nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A550101.swf" width = "88.000mm" height = "83.229mm" ver = "01" gw = "158" gh = "219"/>
</figure>
</item>
<item>
<ptxt>
After installing select lever assembly, adjust select cable. 
<intxreftitleoff1 refid = "AENCP70A5506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
