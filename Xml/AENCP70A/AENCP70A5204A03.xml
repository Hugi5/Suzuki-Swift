<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A5204A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Noise
</title>
<diag type = "condition">
<condition>
<ptxt>
Noise
</ptxt>
</condition>
<ps>
<ptxt>
Inadequate or insufficient lubricant
</ptxt>
</ps>
<action>
<ptxt>
Replenish manual transaxle oil.
</ptxt>
</action>
<ps>
<ptxt>
Damaged or worn bearing(s)
</ptxt>
</ps>
<action>
<ptxt>
Replace bearing referring to 
<intxref refid = "AENCP70A5206015">Fifth Gear Disassembly and Reassembly</intxref>
, 
<intxref refid = "AENCP70A5206020">Input Shaft Assembly Disassembly and Reassembly</intxref>
 and/or 
<intxref refid = "AENCP70A5206021">Countershaft Assembly Disassembly and Reassembly</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Damaged or worn gear(s)
</ptxt>
</ps>
<action>
<ptxt>
Replace gear referring to 
<intxref refid = "AENCP70A5206015">Fifth Gear Disassembly and Reassembly</intxref>
, 
<intxref refid = "AENCP70A5206020">Input Shaft Assembly Disassembly and Reassembly</intxref>
 and/or 
<intxref refid = "AENCP70A5206021">Countershaft Assembly Disassembly and Reassembly</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Damaged or worn synchronizer parts
</ptxt>
</ps>
<action>
<ptxt>
Replace synchronizer parts referring to 
<intxref refid = "AENCP70A5206015">Fifth Gear Disassembly and Reassembly</intxref>
, 
<intxref refid = "AENCP70A5206020">Input Shaft Assembly Disassembly and Reassembly</intxref>
 and/or 
<intxref refid = "AENCP70A5206021">Countershaft Assembly Disassembly and Reassembly</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
