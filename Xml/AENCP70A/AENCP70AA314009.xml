<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70AA314009" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "1">
<title>
DTC P1642 / P1646
</title>
<servinfosub id = "AENCP70AA314009001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.406in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.789in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1642: Immobilizer Communication Line Error
</emph>
</ptxt>
<ptxt>
Communication error with BCM.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
CAN communication circuit / connector
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Control module connected with CAN communication line
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1646: ID Code Incorrectness
</emph>
</ptxt>
<ptxt>
CAN communication error.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENCP70AA314009002">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70AA314009003">
<testgroup id = "AENCP70AA314009004">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC related to CAN communication.
</ptxt>
</test1>
<question>
Is there any CAN-DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for CAN-DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70AA314009005">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Check CAN communication circuit referring to “Diagnosis Procedure” in 
<intxref refid = "AENCP70AA804004">Troubleshooting for Communication Bus Off</intxref>
.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace ECM and recheck DTC. If DTC P1642 or P1646 is still detected, replace BCM and recheck DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AENCP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "AENCP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
