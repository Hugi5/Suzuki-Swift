<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A9404A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Wiper malfunctions
</title>
<servinfosub id = "AENCP70A9404002003">
<title>
Rear Wiper and Washer
</title>
<diag type = "condition">
<condition>
<ptxt>
Wiper malfunctions
</ptxt>
</condition>
<ps>
<ptxt>
Faulty rear wiper motor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406006">Rear Wiper Motor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiper and washer switch (wiper switch)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A9406008">Wiper and Washer Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
“Inspection of BCM and Its Circuits” in Section 10B
</ptxt>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENCP70AA204023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENCP70AA204024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
