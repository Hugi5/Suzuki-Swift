<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A9904A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Sun roof cannot operate (sun roof motor can operate)
</title>
<diag type = "condition">
<condition>
<ptxt>
Sun roof cannot operate (sun roof motor can operate)
</ptxt>
</condition>
<ps>
<ptxt>
Some object stuck in sun roof rail
</ptxt>
</ps>
<action>
<ptxt>
Remove or clean stuck object.
</ptxt>
</action>
<ps>
<ptxt>
Incorrect installation of sun roof rail
</ptxt>
</ps>
<action>
<ptxt>
Install correctly.
</ptxt>
</action>
<ps>
<ptxt>
Interference of sun roof parts
</ptxt>
</ps>
<action>
<ptxt>
Fix interference.
</ptxt>
</action>
<ps>
<ptxt>
Incorrect installation of sun roof drive cable
</ptxt>
</ps>
<action>
<ptxt>
Install correctly.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
