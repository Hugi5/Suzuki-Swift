<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70AA204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Select lever cannot be shifted from “P” range with ignition “ON” even when the brake pedal is depressed
</title>
<diag type = "condition">
<condition>
<ptxt>
Select lever cannot be shifted from “P” range with ignition “ON” even when the brake pedal is depressed
</ptxt>
</condition>
<ps>
<ptxt>
Blown “BACK” fuse
</ptxt>
</ps>
<action>
<ptxt>
Check fuse.
</ptxt>
</action>
<ps>
<ptxt>
Faulty transmission range sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A5506020">Transmission Range Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty CAN communication circuit
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70AA804001">CAN Communication Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty TCM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A5504055">Inspection of TCM and Its Circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty brake light switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A4106011">Brake Light Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A1104068">Inspection of ECM and Its Circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty shift lock solenoid
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70A5506009">Shift Lock Solenoid Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wire harness of shift lock solenoid
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace.
</ptxt>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENCP70AA204024">Inspection of BCM and Its Circuits (Keyless Push Start Model)</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
