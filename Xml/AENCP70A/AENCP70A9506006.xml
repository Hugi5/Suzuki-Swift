<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9506006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Defogger Switch Inspection
</title>
<s1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Connect SUZUKI scan tool to DLC.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “ON”, and select “Data List” on SUZUKI scan tool.
</ptxt>
</s1>
<s1>
<ptxt>
Check that “Rear Defogger SW” shown in SUZUKI scan tool is switched between ON and OFF as rear defogger switch is pressed.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
