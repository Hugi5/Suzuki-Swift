<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9206008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
License Plate Light Removal and Installation
</title>
<servinfosub id = "AENCP70A9206008001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear end door lower garnish screws (1), and then remove rear end door lower garnish (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove license plate light (3).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect license plate light connector.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920001.jpg" width = "88.000mm" height = "80.485mm" ver = "01" gw = "211" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Remove bulb.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9206008002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure nothing the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten rear end door lower garnish screws to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9B001">
<t-part>
Rear end door lower garnish screw
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A920002.jpg" width = "88.000mm" height = "80.884mm" ver = "01" gw = "211" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
