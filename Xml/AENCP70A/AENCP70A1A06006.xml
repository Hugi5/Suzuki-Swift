<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1A06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Generator Bracket Removal and Installation
</title>
<servinfosub id = "AENCP70A1A06006001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump / generator drive belt. 
<intxreftitleoff1 refid = "AENCP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump pulley (1). 
<intxreftitleoff1 refid = "AENCP70A1606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove generator bolt (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove generator bracket (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1007.jpg" width = "88.000mm" height = "70.982mm" ver = "01" gw = "192" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1A06006002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Install generator bracket in the following procedure.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Position the generator bracket (1).
</ptxt>
</item>
<item>
<ptxt>
Loosely tighten generator bolt (2).
</ptxt>
</item>
<item>
<ptxt>
Tighten generator bracket nuts (3) to specified torque. 
<intxreftitleoff1 refid = "AENCP70A1606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
<figure>
<graphic graphicname = "I9P60A1A1016.swf" width = "88.000mm" height = "68.664mm" ver = "01" gw = "188" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
