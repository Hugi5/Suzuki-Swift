<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5206015" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "1">
<title>
Fifth Gear Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5206011">Manual Transaxle Unit Dismounting and Remounting</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A5206015001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove gear shift &#38; select shaft assembly. 
<intxreftitleoff1 refid = "AENCP70A5206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove side cover bolts.
</ptxt>
</s1>
<s1>
<ptxt>
Remove side cover (1) from left ease using special tool and hammer.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B003">
<s-part>
(A)
</s-part>
<s-number num = "09921-96510">
09921–96510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A521026.swf" width = "88.000mm" height = "75.790mm" ver = "01" gw = "192" gh = "198"/>
</figure>
</s1>
<s1>
<ptxt>
Using snap ring pliers (3), remove circlip (1) and 5th speed synchronizer hub plate (2).
</ptxt>
<figure>
<graphic graphicname = "I7V20A521012.swf" width = "88.000mm" height = "54.028mm" ver = "01" gw = "174" gh = "137"/>
</figure>
</s1>
<s1>
<ptxt>
Remove spring pin (1) using special tool and hammer.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B004">
<s-part>
(A)
</s-part>
<s-number num = "09922-89810">
09922–89810
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Remove 5th gear shift fork (2), 5th speed synchronizer sleeve &#38; hub assembly (3), 5th speed synchronizer ring (4) and input shaft 5th gear (5) all together. Use gear puller for removal if spline fitting of hub is tight.
</ptxt>
<figure>
<graphic graphicname = "I4RS0B521011.swf" width = "88.000mm" height = "74.541mm" ver = "01" gw = "210" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Unfasten caulking of countershaft nut (2), install input shaft 5th gear (1) and special tool to stop rotation of shafts, and then remove countershaft nut (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L5B005">
<s-part>
(A)
</s-part>
<s-number num = "09927-76010">
09927–76010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I4RS0B521012.swf" width = "88.000mm" height = "47.360mm" ver = "01" gw = "164" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Remove special tool, input shaft 5th gear, needle bearing and then countershaft 5th gear (1). Gear puller (2) is necessary if spline fitting of countershaft 5th gear is tight.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A520041.swf" width = "88.000mm" height = "41.518mm" ver = "01" gw = "114" gh = "101"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5206015002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Fit 5th speed synchronizer sleeve (1) to 5th speed synchronizer hub (2), insert 5th speed synchronizer keys (3) in it and then set 5th speed synchronizer springs (4) at specified position as shown in figure.
</ptxt>
<attention3>
<ptxt>
Short side [B] of key, long flange [C] of hub and chamfered side [D] of sleeve should face inward (5th gear side [A]).
</ptxt>
</attention3>
<spec>
<title>
Synchronizer key installation position
</title>
<ptxt>
“a” = “b”
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A521027.swf" width = "88.000mm" height = "85.121mm" ver = "03" gw = "201" gh = "225"/>
</figure>
</s1>
<s1>
<ptxt>
Install 5th gear (1) to countershaft as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60A521028.swf" width = "88.000mm" height = "38.851mm" ver = "02" gw = "114" gh = "94"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.195in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Countershaft side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install needle bearing (1) to input shaft, apply oil then install input shaft 5th gear (2) and special tool to stop shaft rotation.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B006">
<s-part>
(A)
</s-part>
<s-number num = "09927-76010">
09927–76010
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Tighten new countershaft nut (3) to specified torque, and caulk countershaft nut securely.
</ptxt>
<torque>
<torqueitem id = "T5B010">
<t-part>
Countershaft nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
70
</t-value1>
<t-value2>
7.1
</t-value2>
<t-value3>
52.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I4RS0B521015.swf" width = "88.000mm" height = "77.628mm" ver = "01" gw = "168" gh = "203"/>
</figure>
</s1>
<s1>
<ptxt>
Remove special tool.
</ptxt>
</s1>
<s1>
<ptxt>
Install 5th speed synchronizer ring (6).
</ptxt>
</s1>
<s1>
<ptxt>
Fit 5th gear shift fork (1) to 5th speed synchronizer sleeve (2) and hub (3) assembly and install them into input shaft and gear shift shaft by aligning oil groove (4) with matchmark (5) on input shaft.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
While press-fitting 5th speed synchronizer sleeve &#38; hub, make sure that synchronizer ring key slots (9) are aligned with keys (8) in 5th speed synchronizer sleeve &#38; hub assembly
</ptxt>
</item>
<item>
<ptxt>
Check free rotation of 5th gear after press-fitting 5th speed synchronizer sleeve &#38; hub assembly.
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A521029.swf" width = "88.000mm" height = "128.978mm" ver = "01" gw = "194" gh = "349"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.946in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
7.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Long flange
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install new spring pin (1).
</ptxt>
</s1>
<s1>
<ptxt>
Fit 5th speed synchronizer hub plate (2) and, using snap ring pliers, install new circlip (3) to input shaft (4) in specified direction as shown in figure.
</ptxt>
</s1>
<attention2>
<ptxt>
If the circlip is expanded beyond necessity when installing the circlip, the circlip will remain deformed.
</ptxt>
<ptxt>
Do not expand the circlip beyond necessity.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I4RS0B521017.swf" width = "88.000mm" height = "73.231mm" ver = "02" gw = "209" gh = "191"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.178in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Polished surface
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
<s1>
<ptxt>
Clean mating surface of both left case (2) and side cover (1), apply sealant to side cover (1) as shown in figure, mate it with left case and then tighten bolts to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M5B006" uid = "-491504098">
<m-part>
“B”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<torque>
<torqueitem id = "T5B011">
<t-part>
Side cover No.1 bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
<torqueitem id = "T5B012">
<t-part>
Side cover No.2 bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A521016.swf" width = "88.000mm" height = "82.447mm" ver = "01" gw = "168" gh = "217"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.257in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
1.5 mm (0.059 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install gear shift &#38; select shaft assembly. 
<intxreftitleoff1 refid = "AENCP70A5206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
