<servinfosub id = "AENCP70A1104033003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
5 V power supply circuit is in good condition.
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Run engine at idle speed for 5 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1104033004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A1104033005">
<testgroup id = "AENCP70A1104033006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104033007">
<title>
CKP sensor power supply circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect CKP sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to CKP sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “C1” and “C3” is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104033008">
<title>
CKP sensor ground circuit check
</title>
<test1>
<ptxt>
Check that voltage between “C1” and ground is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Repair “C3” circuit.
</ptxt>
<ptxt>
If this DTC is detected again, replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair “C1” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104033009">
<title>
CKP sensor signal circuit check
</title>
<test1>
<ptxt>
When ignition is OFF, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “C2” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “C2” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “C2” circuit terminal and other terminal at CKP sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “C2” circuit: approx. 0 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104033010">
<title>
CKP sensor and sensor plate check
</title>
<test1>
<ptxt>
Check CKP sensor and sensor plate.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
CKP sensor 
<intxreftitleoff1 refid = "AENCP70A1306019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sensor plate 
<intxreftitleoff1 refid = "AENCP70A1406043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
</diag>
