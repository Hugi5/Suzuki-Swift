<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A5504003" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
CVT Basic Check
</title>
<ptxt>
Perform troubleshooting referring to the following points when no DTC is detected in TCM and no abnormality is found in 
<intxref refid = "AENCP70A5504002">Visual Inspection</intxref>
. Follow the flow carefully.
</ptxt>
<diag type = "test" id = "AENCP70A5504003001">
<testgroup id = "AENCP70A5504003002">
<question>
Was “CVT System Check” preformed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504003003">
<title>
Road test
</title>
<test1>
<ptxt>
Perform road test. 
<intxreftitleoff1 refid = "AENCP70A5504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Refer to items in 
<intxref refid = "AENCP70A5504009">CVT Symptom Diagnosis</intxref>
, repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504003004">
<title>
Stall test
</title>
<test1>
<ptxt>
Perform stall test. 
<intxreftitleoff1 refid = "AENCP70A5504005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts, and go to Step 6.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504003005">
<title>
Time lag test
</title>
<test1>
<ptxt>
Perform time lag test. 
<intxreftitleoff1 refid = "AENCP70A5504006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts, and go to Step 6.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504003006">
<title>
Line pressure test
</title>
<test1>
<ptxt>
Perform line pressure test. 
<intxreftitleoff1 refid = "AENCP70A5504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts, and go to Step 6.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504003007">
<title>
CVT symptom diagnosis
</title>
<question>
Is trouble symptom identified?
</question>
<result type = "yes"/>
<action>
<ptxt>
Refer to items in 
<intxref refid = "AENCP70A5504009">CVT Symptom Diagnosis</intxref>
, repair or replace defective parts.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
