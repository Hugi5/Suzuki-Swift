<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A5306019" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Clutch Cover and Clutch Disc Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A5306018">Clutch Cover and Clutch Disc Removal and Installation</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A5306019001">
<title>
Clutch Disc
</title>
<ptxt>
Measure depth of rivet head depression, i.e. distance between rivet head and facing surface.
</ptxt>
<ptxt>
If depression is found to have reached service limit at any of rivet holes (2), replace clutch disc (1).
</ptxt>
<spec>
<title>
Rivet head depth
</title>
<ptxt>
Standard: 1.15 – 1.75 mm (0.0453 – 0.0689 in.)
</ptxt>
<ptxt>
Limit: 0.5 mm (0.02 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I4RS0A530019.swf" width = "88.000mm" height = "50.788mm" ver = "01" gw = "179" gh = "127"/>
</figure>
</servinfosub>
<servinfosub id = "AENCP70A5306019002">
<title>
Clutch Cover
</title>
<ptxt>
Check clutch cover as follows.
</ptxt>
<s1>
<ptxt>
Check diaphragm spring (1) for abnormal wear or damage.
</ptxt>
</s1>
<s1>
<ptxt>
Inspect pressure plate (2) for wear or heat spots.
</ptxt>
</s1>
<s1>
<ptxt>
Replace clutch cover if defective.
</ptxt>
<ptxt>
Do not disassemble it into diaphragm spring and pressure plate.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I3RM0A530015.swf" width = "88.000mm" height = "47.698mm" ver = "01" gw = "150" gh = "118"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
