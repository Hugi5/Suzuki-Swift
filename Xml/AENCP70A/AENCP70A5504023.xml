<servinfosub id = "AENCP70A5504023003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Check that the following condition is satisfied in this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
11 V &#60; Battery voltage &#60; 15 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Set ignition ON, and leave ignition ON for 5 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A5504023004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A5504023005">
<testgroup id = "AENCP70A5504023006">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504023007">
<title>
CVT fluid temperature sensor signal circuit and ground circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C142”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C142”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “A1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit terminal and other terminal at “C142” connector: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A5504023008">
<title>
CVT fluid temperature sensor check
</title>
<test1>
<ptxt>
 Check CVT fluid temperature sensor. 
<intxreftitleoff1 refid = "AENCP70A5506030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace CVT fluid temperature sensor (CVT assembly). 
<intxreftitleoff1 refid = "AENCP70A5506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
