<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1406018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Timing Chain Cover Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1406017">Timing Chain Cover Components</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Keep working table, tools and hands clean while overhauling.
</ptxt>
</item>
<item>
<ptxt>
Use special care to handle aluminum parts so as not to damage them.
</ptxt>
</item>
<item>
<ptxt>
Do not expose removed parts to dust. Keep them always clean.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENCP70A1406018001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove engine assembly from vehicle. 
<intxreftitleoff1 refid = "AENCP70A1406016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump / generator drive belt. 
<intxreftitleoff1 refid = "AENCP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove crankshaft pulley bolt.
</ptxt>
<ptxt>
To lock crankshaft pulley (1), use special tool as shown in figure.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Use special tool to prevent unnecessary load on timing chain, sprockets and any other related parts.
</ptxt>
</item>
<item>
<ptxt>
Use bolts as specified below for installing special tool to crankshaft pulley.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Special tool fixing bolt
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.733in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.733in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bolt size
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
M8
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Pitch
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
1.25 mm (0.05 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Length “a”
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
25 mm (0.98 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Strength
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
7T
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</attention2>
<attention3>
<ptxt>
Use special tool with its pins removed if necessary.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1D010">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917–68221
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141049.swf" width = "88.000mm" height = "49.174mm" ver = "01" gw = "163" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Remove crankshaft pulley (1).
</ptxt>
<ptxt>
If it is hard to remove, use special tools as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D011">
<s-part>
(A)
</s-part>
<s-number num = "09926-37610-001">
09926–37610–001
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L1D012">
<s-part>
(B)
</s-part>
<s-number num = "09926-58010">
09926–58010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B140052.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "170" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Remove cylinder head cover. 
<intxreftitleoff1 refid = "AENCP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil pan. 
<intxreftitleoff1 refid = "AENCP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump pulley.
</ptxt>
</s1>
<s1>
<ptxt>
Remove timing chain cover bolts, and then remove timing chain cover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove crankshaft oil seal from timing chain cover using a flat-bladed screwdriver or the like, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Remove OCV from timing chain cover, if necessary. 
<intxreftitleoff1 refid = "AENCP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disassemble timing chain cover and oil pump, if necessary. 
<intxreftitleoff1 refid = "AENCP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1406018002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1406019">Timing Chain Cover Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Clean sealing surface on timing chain cover, cylinder block and cylinder head.
</ptxt>
<ptxt>
Remove oil, old sealant and dust from sealing surface.
</ptxt>
</s1>
<s1>
<ptxt>
Reassemble timing chain cover and oil pump if removed. 
<intxreftitleoff1 refid = "AENCP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
 Install OCV, if removed. 
<intxreftitleoff1 refid = "AENCP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check oil seal (1) lip for fault or other damage.
</ptxt>
<ptxt>
Replace oil seal, if necessary.
</ptxt>
<attention3>
<ptxt>
When installing new oil seal, press fit to timing chain cover (2) using special tool (A) as shown in figure.
</ptxt>
</attention3>
<spec>
<title>
Depth
</title>
<ptxt>
“a”: 1.5 mm (0.06 in.)
</ptxt>
</spec>
<servicetool>
<servicetoolitem id = "L1D013">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913–75810
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141050.swf" width = "88.000mm" height = "52.484mm" ver = "01" gw = "179" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Install new O-ring (1) to oil pump (2).
</ptxt>
</s1>
<s1>
<ptxt>
Install new gasket (3) to timing chain cover (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141055.jpg" width = "88.000mm" height = "67.189mm" ver = "01" gw = "144" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Install dowel pins (1) to cylinder block, if removed.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141056.swf" width = "88.000mm" height = "58.478mm" ver = "01" gw = "131" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Apply sealant “A” to mating surface of cylinder and cylinder head and “B” to mating surface of timing chain cover as shown in figure.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207B" id = "M1D002" uid = "29">
<m-part>
“A”
</m-part>
<m-desc>
Water tight sealant
</m-desc>
<m-number>
99000–31140
</m-number>
<m-name>
SUZUKI Bond No.1207B
</m-name>
</materialitem>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1D003" uid = "-491504098">
<m-part>
“B”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<spec>
<title>
Sealant amount for timing chain cover
</title>
<ptxt>
Width “a”: 3 mm (0.12 in.)
</ptxt>
<ptxt>
Height “b”: 2 mm (0.08 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A141057.jpg" width = "88.000mm" height = "49.092mm" ver = "01" gw = "220" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Apply engine oil to oil seal lip, then install timing chain cover (1). Tighten bolts by gradually in numerical order “1” through “15” to specified torque.
</ptxt>
<attention3>
<ptxt>
Before installing timing chain cover, check that pin is securely fitted.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1D011">
<t-part>
Timing chain cover bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141058.jpg" width = "88.000mm" height = "72.952mm" ver = "01" gw = "169" gh = "190"/>
</figure>
</s1>
<s1>
<ptxt>
Install water pump pulley.
</ptxt>
</s1>
<s1>
<ptxt>
Install cylinder head cover. 
<intxreftitleoff1 refid = "AENCP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install oil pan. 
<intxreftitleoff1 refid = "AENCP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install crankshaft pulley (1). Tighten crankshaft pulley bolt to specified torque. To lock crankshaft pulley, use special tool as shown in figure.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Use special tool to prevent unnecessary load on timing chain, sprockets and any other related parts.
</ptxt>
</item>
<item>
<ptxt>
Use bolts as specified below for installing special tool to crankshaft pulley.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Special tool fixing bolt
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.729in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.729in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bolt size
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
M8
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Pitch
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
1.25 mm (0.05 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Length “a”
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
25 mm (0.98 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Strength
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
7T
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</attention2>
<attention3>
<ptxt>
Use special tool with its pins removed if necessary.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1D014">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917–68221
</s-number>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T1D012">
<t-part>
Crankshaft pulley bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
150
</t-value1>
<t-value2>
15.3
</t-value2>
<t-value3>
111.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141040.swf" width = "88.000mm" height = "49.174mm" ver = "02" gw = "174" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Install engine assembly to vehicle. 
<intxreftitleoff1 refid = "AENCP70A1406016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
