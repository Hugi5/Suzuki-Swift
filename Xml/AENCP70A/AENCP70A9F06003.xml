<title>
Tweeter Removal and Installation (If Equipped)
</title>
<servinfosub id = "AENCP70A9F06003001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove sash bracket inner garnish. 
<intxreftitleoff1 refid = "AENCP70A9506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect tweeter connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove 2 screws and remove tweeter (1).
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A9F0006.jpg" width = "88.000mm" height = "72.098mm" ver = "02" gw = "197" gh = "188"/>
</figure>
</servinfosub>
<servinfosub id = "AENCP70A9F06003002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
