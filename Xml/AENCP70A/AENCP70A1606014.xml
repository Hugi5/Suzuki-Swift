<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1606014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Radiator Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1606013">Radiator On-Vehicle Inspection and Cleaning</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A1606014001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove cooling fan assembly. 
<intxreftitleoff1 refid = "AENCP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove A/C condenser assembly. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENCP70A7216006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Automatic A/C model: 
<intxreftitleoff1 refid = "AENCP70A7226006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove radiator outlet hose from radiator.
</ptxt>
</s1>
<s1>
<ptxt>
Remove radiator upper brackets (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove radiator (2) from vehicle.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160007.jpg" width = "88.000mm" height = "62.569mm" ver = "01" gw = "193" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1606014002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENCP70A1606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check cooling system for leakage. 
<intxreftitleoff1 refid = "AENCP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
