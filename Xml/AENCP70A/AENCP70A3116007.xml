<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A3116007" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Front Wheel Bearing Check
</title>
<s1>
<ptxt>
Confirm tightness of wheel nut and, if necessary, retighten them to specified torque. 
<intxreftitleoff1 refid = "AENCP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Hoist vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Check wear of wheel bearing. When measuring thrust play, apply a dial gauge to front wheel as shown in figure.
</ptxt>
<ptxt>
If check result is not as specified, replace bearing.
</ptxt>
<spec-sdm>
<sdm-title>
Front wheel bearing thrust play
</sdm-title>
<sdm1>
<sdm-condition>
Limit
</sdm-condition>
<sdm-value>
0.1 mm (0.004 in.)
</sdm-value>
</sdm1>
</spec-sdm>
<figure>
<graphic graphicname = "I3RM0A230049.swf" width = "88.000mm" height = "55.572mm" ver = "01" gw = "194" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Check wheel bearing noise and smooth wheel rotation by rotating wheel.
</ptxt>
<ptxt>
If defective, replace bearing.
</ptxt>
<figure>
<graphic graphicname = "I3RM0A230050.swf" width = "88.000mm" height = "52.948mm" ver = "01" gw = "162" gh = "133"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
