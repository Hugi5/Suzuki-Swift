<servinfosub id = "AENCP70A1104014003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed by two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to troubleshoot first unexpected DTCs previously detected in “DTC Confirmation Procedure”.
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0010 or P0013 is not detected.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Start engine and drive vehicle at 60 to 80 km/h (37 to 50 mile/h) for more than 10 min with engine speed 1,600 rpm or more.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1104014004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A1104014005">
<testgroup id = "AENCP70A1104014006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104014007">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC.
</ptxt>
</test1>
<question>
Is there DTC(s) other than P0011 and P0014?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC(s).
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104014008">
<title>
OCV power supply circuit and OCV drive circuit check
</title>
<test1>
<ptxt>
Check “A1” or “B1” and “A2” or “B2” circuits according to Steps 2 and 3 under 
<intxref refid = "AENCP70A1104013">DTC P0010 / P0013 / P2088 / P2089 / P2090 / P2091</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104014009">
<title>
Oil pressure check
</title>
<test1>
<ptxt>
Check oil pressure. 
<intxreftitleoff1 refid = "AENCP70A1504001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104014010">
<title>
OCV oil circuit visual check
</title>
<test1>
<ptxt>
Remove cylinder head cover. 
<intxreftitleoff1 refid = "AENCP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Check oil pressure leakage from OCV oil circuit.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104014011">
<title>
CKP sensor and sensor plate check
</title>
<test1>
<ptxt>
Check CKP sensor and sensor plate.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
CKP sensor inspection: 
<intxreftitleoff1 refid = "AENCP70A1306019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sensor plate inspection: 
<intxreftitleoff1 refid = "AENCP70A1406043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104014012">
<title>
CMP sensor and signal rotor check
</title>
<test1>
<ptxt>
Check CMP sensor and signal rotor.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
CMP sensor inspection: 
<intxreftitleoff1 refid = "AENCP70A1306017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Signal rotor inspection: 
<intxreftitleoff1 refid = "AENCP70A1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104014013">
<title>
OCV check
</title>
<test1>
<ptxt>
Check OCV. 
<intxreftitleoff1 refid = "AENCP70A1306026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 9.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace OCV. 
<intxreftitleoff1 refid = "AENCP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104014014">
<title>
CMP actuator check
</title>
<test1>
<ptxt>
Check CMP actuator. 
<intxreftitleoff1 refid = "AENCP70A1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 10. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace CMP actuator. 
<intxreftitleoff1 refid = "AENCP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104014015">
<title>
Valve timing check
</title>
<test1>
<ptxt>
Check parts related to timing chain and their installing condition. 
<intxreftitleoff1 refid = "AENCP70A1406024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Reinstall parts related to timing chain correctly, or replace defective parts.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
