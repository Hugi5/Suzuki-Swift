<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Front Fender Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A9A06004">Front Fender Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A9A06005001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove front bumper and front bumper holder. 
<intxreftitleoff1 refid = "AENCP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove cowl top garnish and cowl top side garnish. 
<intxreftitleoff1 refid = "AENCP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove headlight unit. 
<intxreftitleoff1 refid = "AENCP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove side turn signal light (if equipped). 
<intxreftitleoff1 refid = "AENCP70A9206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove side sill guard. 
<intxreftitleoff1 refid = "AENCP70A9806007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front fender lining.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front fender and front fender cover.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9A06005002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Adjust front fender panel clearance. 
<intxreftitleoff1 refid = "AENCP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
If paint on front fender bolts is peeled off, be sure to apply paint again to prevent rust.
</ptxt>
</item>
<item>
<ptxt>
Perform headlight aiming after installation. 
<intxreftitleoff1 refid = "AENCP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
