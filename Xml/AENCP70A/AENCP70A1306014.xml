<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1306014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
A/F Sensor and HO2S Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1306012">A/F Sensor On-Vehicle Inspection</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENCP70A1306013">HO2S On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A1306014001">
<title>
Removal
</title>
<attention1>
<ptxt>
To avoid danger of being burned, do not touch exhaust system when system is hot. A/F sensor and/or HO2S removal should be performed when system is cool.
</ptxt>
</attention1>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector of A/F sensor and/or HO2S.
</ptxt>
</s1>
<s1>
<ptxt>
Remove A/F sensor (1) and/or HO2S (2) from exhaust manifold.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1306014002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten A/F sensor (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1C004">
<t-part>
A/F sensor
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4.5
</t-value2>
<t-value3>
33.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Tighten HO2S (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1C005">
<t-part>
HO2S
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4.5
</t-value2>
<t-value3>
33.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A131013.swf" width = "88.000mm" height = "49.001mm" ver = "01" gw = "174" gh = "122"/>
</figure>
</item>
<item>
<ptxt>
After installation, check exhaust leakage from sensor with engine running.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
