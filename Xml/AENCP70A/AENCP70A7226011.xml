<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A7226011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
HVAC Control Module Removal and Installation
</title>
<servinfosub id = "AENCP70A7226011001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove auto A/C panel. 
<intxreftitleoff1 refid = "AENCP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove HVAC control module (2).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect HVAC control module connector.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723022.swf" width = "88.000mm" height = "58.912mm" ver = "01" gw = "226" gh = "150"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A7226011002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
