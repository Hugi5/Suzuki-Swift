<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A7214A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Cool air does not come out only at high speed
</title>
<diag type = "condition">
<condition>
<ptxt>
Cool air does not come out only at high speed
</ptxt>
</condition>
<ps>
<ptxt>
Excessive amount of refrigerant
</ptxt>
</ps>
<action>
<ptxt>
Check amount of refrigerant.
</ptxt>
</action>
<ps>
<ptxt>
Frosted evaporator
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check evaporator and evaporator temperature sensor.
</ptxt>
<ptxt>
- Evaporator: 
<intxreftitleoff1 refid = "AENCP70A7216014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Evaporator temperature sensor: 
<intxreftitleoff1 refid = "AENCP70A7216016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
