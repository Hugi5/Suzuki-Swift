<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A9604A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Malfunction request switches (Keyless push start model)
</title>
<diag type = "condition">
<condition>
<ptxt>
Malfunction request switches (Keyless push start model)
</ptxt>
</condition>
<ps>
<ptxt>
Faulty remote controller
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace battery. 
<intxreftitleoff1 refid = "AENCP70AA506020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Refer to 
<intxref refid = "AENCP70AA504031">Inspection of Keyless Start Control Module and Its Circuits</intxref>
.
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENCP70AA204024">Inspection of BCM and Its Circuits (Keyless Push Start Model)</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Faulty door request switch
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENCP70AA506010">Request Switch Inspection</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty keyless start control module
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENCP70AA504031">Inspection of Keyless Start Control Module and Its Circuits</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
