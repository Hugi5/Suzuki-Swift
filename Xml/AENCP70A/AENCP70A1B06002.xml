<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1K">
<servcat sctnbr = "01" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1B06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Exhaust Manifold Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1B06001">Exhaust System Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A1B06002001" page = "2">
<title>
Removal
</title>
<attention2>
<ptxt>
Be careful not to drop exhaust manifold. If it is dropped, inside catalytic converter may be damaged by impact.
</ptxt>
</attention2>
<s1 page = "2">
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Disconnect A/F sensor connector (1) and HO2S connector (2), and then detach them from their stay.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0002.swf" width = "88.000mm" height = "53.833mm" ver = "01" gw = "171" gh = "136"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Disconnect exhaust No.1 pipe (1) from exhaust manifold.
</ptxt>
<figure page = "2">
<graphic graphicname = "I7V20A1B1003.swf" width = "88.000mm" height = "51.237mm" ver = "01" gw = "163" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove exhaust manifold stiffeners (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove exhaust manifold cover (3) from exhaust manifold.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove A/F sensor (4) and HO2S (5) from exhaust manifold, if necessary. 
<intxreftitleoff1 refid = "AENCP70A1306014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove exhaust manifold (1) and its gasket from cylinder head.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0003.swf" width = "88.000mm" height = "70.972mm" ver = "01" gw = "193" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1B06002002" page = "2">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new gasket.
</ptxt>
</item>
<item>
<ptxt>
Tighten exhaust manifold bolts and nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1K001">
<t-part>
Exhaust manifold bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6.1
</t-value2>
<t-value3>
44.5
</t-value3>
</torqueitem>
<torqueitem id = "T1K002">
<t-part>
Exhaust manifold nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6.1
</t-value2>
<t-value3>
44.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1002.jpg" width = "88.000mm" height = "57.647mm" ver = "02" gw = "199" gh = "147"/>
</figure>
</item>
<item>
<ptxt>
Install A/F sensor and HO2S if removed. 
<intxreftitleoff1 refid = "AENCP70A1306014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Install exhaust manifold stiffeners as follows.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Install exhaust manifold stiffeners (1), then tighten exhaust manifold stiffener nuts (2) by hand.
</ptxt>
</item>
<item>
<ptxt>
Tighten exhaust manifold stiffener bolts (3), then tighten exhaust manifold stiffener nuts (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P1B0004.swf" width = "88.000mm" height = "64.959mm" ver = "01" gw = "172" gh = "168"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Tighten exhaust No.1 pipe bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1K003">
<t-part>
Exhaust No.1 pipe bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
43
</t-value1>
<t-value2>
4.4
</t-value2>
<t-value3>
32.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1004.swf" width = "88.000mm" height = "54.949mm" ver = "01" gw = "153" gh = "139"/>
</figure>
</item>
<item>
<ptxt>
Run engine and check for exhaust gas leakage.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
