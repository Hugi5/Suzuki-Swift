<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Excessive tire wear
</title>
<diag type = "condition">
<condition>
<ptxt>
Excessive tire wear
</ptxt>
</condition>
<ps>
<ptxt>
Broken or sagging coil springs
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace coil springs.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENCP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENCP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Wheel out of balance
</ptxt>
</ps>
<action>
<ptxt>
Adjust balance or replace tire.
</ptxt>
</action>
<ps>
<ptxt>
Disturbed wheel alignment
</ptxt>
</ps>
<action>
<ptxt>
Check and adjust wheel alignment. 
<intxreftitleoff1 refid = "AENCP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty front strut assembly (shock absorber)
</ptxt>
</ps>
<action>
<ptxt>
Replace front strut assembly (shock absorber). 
<intxreftitleoff1 refid = "AENCP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hard driving
</ptxt>
</ps>
<action>
<ptxt>
Check loading.
</ptxt>
</action>
<ps>
<ptxt>
Overloaded vehicle
</ptxt>
</ps>
<action>
<ptxt>
Replace tires. 
<intxreftitleoff1 refid = "AENCP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Not rotated tires
</ptxt>
</ps>
<action>
<ptxt>
Replace or rotate tires.
</ptxt>
</action>
<ps>
<ptxt>
Worn or loose wheel bearing
</ptxt>
</ps>
<action>
<ptxt>
Replace wheel bearing. 
<intxreftitleoff1 refid = "AENCP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Wheel or tire wobbles
</ptxt>
</ps>
<action>
<ptxt>
Replace wheel or tire.
</ptxt>
</action>
<ps>
<ptxt>
Tires not adequately inflated
</ptxt>
</ps>
<action>
<ptxt>
Adjust tire pressure.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
