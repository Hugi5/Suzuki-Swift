<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A9204A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Clearance lights, tail lights or license plate lights do not light up
</title>
<diag type = "condition">
<condition>
<ptxt>
Clearance lights, tail lights or license plate lights do not light up
</ptxt>
</condition>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
Repair circuit.
</ptxt>
</action>
<ps>
<ptxt>
Blown bulbs
</ptxt>
</ps>
<action>
<ptxt>
Replace bulbs.
</ptxt>
</action>
<ps>
<ptxt>
Faulty lighting and turn signal switch
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENCP70A9206016">Lighting and Turn Signal Switch Inspection</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Refer to “Inspection of BCM and Its Circuits” in Section 10B.
</ptxt>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENCP70AA204023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENCP70AA204024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
