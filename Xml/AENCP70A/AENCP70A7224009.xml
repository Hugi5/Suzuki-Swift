<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A7224009" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
DTC Clearance
</title>
<servinfosub id = "AENCP70A7224009001">
<title>
Using SUZUKI Scan tool
</title>
<s1>
<ptxt>
Set ignition to “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Connect SUZUKI scan tool to DLC (1) located around bottom of instrument panel on driver’s seat side.
</ptxt>
<servicetool>
<servicetoolitem id = "L7B209">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI scan tool (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A723002.jpg" width = "88.000mm" height = "67.502mm" ver = "03" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Set ignition to “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Clear DTC according to instructions displayed on SUZUKI scan tool.
</ptxt>
<attention3>
<ptxt>
To know how to use SUZUKI scan tool, refer to operator’s manual for SUZUKI scan tool.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
After completing DTC clearance, perform “DTC Check” and confirm if normal DTC (No code) is displayed.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Set ignition to “OFF”, and then disconnect SUZUKI scan tool from DLC.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
