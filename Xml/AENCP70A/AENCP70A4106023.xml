<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4106023" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Brake Booster Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4106022">Brake Booster Removal and Installation</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check brake booster for damage.
</ptxt>
</item>
<item>
<ptxt>
Check brake booster for operation referring to “Operation Check” under 
<intxref refid = "AENCP70A4106021">Brake Booster Function Check</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Check boot for damage and deterioration.
</ptxt>
</item>
<item>
<ptxt>
Check for push rod length.
</ptxt>
<ptxt>
If check result is not as specified, replace brake booster.
</ptxt>
</item>
</list1>
<spec>
<title>
Push rod length
</title>
<ptxt>
“a”: 114.5 – 115.5 mm (4.507 – 4.547 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I3RM0A410056.swf" width = "88.000mm" height = "44.057mm" ver = "01" gw = "139" gh = "108"/>
</figure>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
