<servinfo servinfosgmlid = "AENCP70A9604001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "1">
<title>
Power Door Lock System Symptom Diagnosis
</title>
<diag type = "condition" id = "AENCP70A9604001001">
<condition>
<ptxt>
Only one door cannot be locked / unlocked
</ptxt>
</condition>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Faulty door lock assembly (including door lock open rod and door lock wires)
</ptxt>
</ps>
<action>
<ptxt>
Replace door lock open rod and door lock wires. 
<intxreftitleoff1 refid = "AENCP70A9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Damaged and deformed inside door handle
</ptxt>
</ps>
<action>
<ptxt>
Replace inside door handle. 
<intxreftitleoff1 refid = "AENCP70A9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
All doors cannot be locked / unlocked
</ptxt>
</condition>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Refer to “Inspection of BCM and Its Circuits” in Section 10B.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENCP70AA204023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENCP70AA204024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Faulty keyless start control module (Keyless push start model)
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENCP70AA504031">Inspection of Keyless Start Control Module and Its Circuits</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Faulty power door lock switch
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENCP70A9606009">Power Door Lock Switch Inspection</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty key cylinder
</ptxt>
</ps>
<action>
<ptxt>
Check key cylinder. 
<intxreftitleoff1 refid = "AENCP70A9606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
All door cannot be locked / unlocked by only keyless entry transmitter or remote controller
</ptxt>
</condition>
<ps>
<ptxt>
