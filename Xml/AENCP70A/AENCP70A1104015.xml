<servinfosub id = "AENCP70A1104015001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.155in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.042in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0030: HO2S Heater Control Circuit (Sensor 1)
</emph>
</ptxt>
<ptxt>
A/F sensor heater control circuit is open.
</ptxt>
<ptxt>
(2 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
A/F sensor heater and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0031: HO2S Heater Control Circuit Low (Sensor 1)
</emph>
</ptxt>
<ptxt>
A/F sensor heater control circuit is shorted to ground.
</ptxt>
<ptxt>
(2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0032: HO2S Heater Control Circuit High (Sensor 1)
</emph>
</ptxt>
<ptxt>
A/F sensor heater control circuit is shorted to power supply.
</ptxt>
<ptxt>
(2 D/C detection logic)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
