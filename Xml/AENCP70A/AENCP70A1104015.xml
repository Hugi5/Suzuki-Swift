<servinfosub id = "AENCP70A1104015003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery voltage &#62; 10.7 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Run engine at idle speed for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1104015004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENCP70A1104015005">
<testgroup id = "AENCP70A1104015006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENCP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104015007">
<title>
A/F sensor heater power supply circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect A/F sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to A/F sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “A1” circuit and ground is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wiring harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104015008">
<title>
A/F sensor heater drive circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A6” circuit: less than 1Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A6” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A6” circuit terminal and other terminal at A/F sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A6” circuit: approx. 0 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wiring harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENCP70A1104015009">
<title>
A/F sensor heater check
</title>
<test1>
<ptxt>
Check A/F sensor heater. 
<intxreftitleoff1 refid = "AENCP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENCP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace A/F sensor.
</ptxt>
</action>
</testgroup>
</diag>
