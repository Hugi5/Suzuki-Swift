<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4C">
<servcat sctnbr = "04" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4316005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Brake Shoe Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4316001">Rear Brake Components:Drum Brake Model</intxrefpoff>
</ptxt>
<attention3>
<ptxt>
Replace both right and left brake shoes as a set.
</ptxt>
</attention3>
<servinfosub id = "AENCP70A4316005001">
<title>
Removal 
</title>
<s1>
<ptxt>
Remove rear brake drum. 
<intxreftitleoff1 refid = "AENCP70A4316003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove hold down springs (1) by turning shoe hold down pins (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P431004.swf" width = "88.000mm" height = "52.108mm" ver = "01" gw = "127" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Remove shoe return springs, rear brake shoes and brake adjuster.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect brake shoe lever (1) from parking brake cable (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P431005.swf" width = "88.000mm" height = "60.994mm" ver = "01" gw = "166" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Remove push nut (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove brake shoe lever (2) from shoe rim (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A431015.swf" width = "88.000mm" height = "51.009mm" ver = "01" gw = "100" gh = "128"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A4316005002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4316004">Rear Brake Drum and Shoe Inspection:Drum Brake Model</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Before installing brake shoes to brake back plate, clean brake back plate and apply grease to brake back plate as shown in figure.
</ptxt>
<materials>
<materialitem id = "M4C101" uid = "1188868635">
<m-part>
“A”
</m-part>
<m-desc>
Heat-resistance brake grease
</m-desc>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A431009.swf" width = "88.000mm" height = "45.223mm" ver = "02" gw = "180" gh = "112"/>
</figure>
</item>
<item>
<ptxt>
Connect brake shoe lever to parking brake cable securely.
</ptxt>
</item>
<item>
<ptxt>
Adjust parking brake cable. 
<intxreftitleoff1 refid = "AENCP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hoist vehicle and check that brake drum is free from dragging.
</ptxt>
</item>
<item>
<ptxt>
Perform brake test referring to “Load Test” of 
<intxref refid = "AENCP70A4100001">Precautions for Brake Service</intxref>
 and make sure that brake system operates properly.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
