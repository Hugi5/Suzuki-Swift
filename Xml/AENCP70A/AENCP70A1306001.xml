<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1306001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
ECM Removal and Installation
</title>
<attention2>
<ptxt>
As ECM consists of precision parts, be careful not to expose it to excessive shock.
</ptxt>
</attention2>
<attention3>
<ptxt>
After ECM is replaced with new one, perform 
<intxref refid = "AENCP70A1306002">Procedure after ECM Replacement</intxref>
.
</ptxt>
</attention3>
<servinfosub id = "AENCP70A1306001001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Turn lock lever (1) in direction of arrow until it stops.
</ptxt>
<ptxt>
Then, disconnect connectors from ECM.
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130001.swf" width = "88.000mm" height = "35.930mm" ver = "01" gw = "189" gh = "85"/>
</figure>
</s1>
<s1>
<ptxt>
Remove ECM (1) from its bracket by removing mounting nuts (2).
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130002.swf" width = "88.000mm" height = "46.930mm" ver = "01" gw = "116" gh = "117"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1306001002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten ECM mounting nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1C001">
<t-part>
ECM mounting nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7Y50A130003.swf" width = "88.000mm" height = "46.696mm" ver = "01" gw = "101" gh = "116"/>
</figure>
</item>
<item>
<ptxt>
Connect connectors to ECM as follows:
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Make sure that lock lever of ECM connectors is in unlock position.
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130004.swf" width = "88.000mm" height = "35.930mm" ver = "01" gw = "69" gh = "85"/>
</figure>
</item>
<item>
<ptxt>
Insert ECM connectors to ECM until they stop with lock lever in unlocked position.
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130005.swf" width = "88.000mm" height = "35.928mm" ver = "01" gw = "69" gh = "85"/>
</figure>
</item>
<item>
<ptxt>
Pull lock lever down to lock ECM connectors securely.
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130006.swf" width = "88.000mm" height = "35.930mm" ver = "01" gw = "168" gh = "85"/>
</figure>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
