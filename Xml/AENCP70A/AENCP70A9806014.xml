<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9806014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Accessory Socket Removal and Installation
</title>
<servinfosub id = "AENCP70A9806014001">
<title>
Removal
</title>
<s1>
<ptxt>
Push claws (3) outward and pull out inner part (1) of accessory socket.
</ptxt>
</s1>
<s1>
<ptxt>
Push claws (4) inward and pull out outer cover (2) of accessory socket from instrument panel.
</ptxt>
<figure>
<graphic graphicname = "IAW101980034.swf" width = "88.000mm" height = "43.716mm" ver = "01" gw = "145" gh = "107"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9806014002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
