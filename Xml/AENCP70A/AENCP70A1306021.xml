<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1306021" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Knock Sensor Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A1306020">Knock Sensor On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A1306021001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove intake manifold. 
<intxreftitleoff1 refid = "AENCP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect knock sensor connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove knock sensor (1) from cylinder block.
</ptxt>
<figure>
<graphic graphicname = "I9P60A131018.jpg" width = "88.000mm" height = "51.381mm" ver = "02" gw = "185" gh = "129"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A1306021002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten knock sensor bolt (1) to specified torque.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1C009">
<t-part>
Knock sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A130002.jpg" width = "88.000mm" height = "41.140mm" ver = "02" gw = "222" gh = "100"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.676in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
0 – 45&#176;
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
