<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENCP70A4104A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Braking noise
</title>
<diag type = "condition">
<condition>
<ptxt>
Braking noise
</ptxt>
</condition>
<ps>
<ptxt>
Glazed brake pad and/or brake shoe
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace brake pad and/or brake shoe.
</ptxt>
</action>
<ps>
<ptxt>
Worn or distorted brake shoe (rear drum brake model)
</ptxt>
</ps>
<action>
<ptxt>
Replace brake shoe.
</ptxt>
</action>
<ps>
<ptxt>
Loose front wheel bearings
</ptxt>
</ps>
<action>
<ptxt>
Replace wheel hub.
</ptxt>
</action>
<ps>
<ptxt>
Distorted backing plates or loose mounting bolts
</ptxt>
</ps>
<action>
<ptxt>
Replace or retighten securing bolts.
</ptxt>
</action>
<ps>
<ptxt>
Contact of wear indicator to brake disc
</ptxt>
</ps>
<action>
<ptxt>
Replace brake pads.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
