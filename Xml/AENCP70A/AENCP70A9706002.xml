<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9706002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Front Seat Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A9706001">Front Seat Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENCP70A9706002001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENCP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connectors from front seat.
</ptxt>
</s1>
<s1>
<ptxt>
Remove 4 mounting bolts and remove seat assembly.
</ptxt>
</s1>
<s1>
<ptxt>
Disassemble and repair parts if necessary. 
<intxreftitleoff1 refid = "AENCP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9706002002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Refer to 
<intxref refid = "AENCP70A9706001">Front Seat Components</intxref>
 for tightening torque.
</ptxt>
</item>
<item>
<ptxt>
Enable air bag system. 
<intxreftitleoff1 refid = "AENCP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
