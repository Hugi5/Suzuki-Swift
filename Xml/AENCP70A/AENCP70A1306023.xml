<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A1306023" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
MAF and IAT Sensor On-Vehicle Inspection
</title>
<attention3>
<ptxt>
Before performed this inspection, be sure to read “Precautions for ECM Circuit Inspection” under 
<intxref refid = "AENCP70A1000001">Precautions for Engine</intxref>
.
</ptxt>
</attention3>
<ptxt>
Check that MAF sensor signal is outputted properly. 
<intxreftitleoff1 refid = "AENCP70A1104068"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If faulty condition is found, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Wire harness and connections
</ptxt>
</item>
<item>
<ptxt>
MAF sensor 
<intxreftitleoff1 refid = "AENCP70A1306025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
