<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4C">
<servcat sctnbr = "04" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A4316007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Wheel Cylinder Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4316001">Rear Brake Components:Drum Brake Model</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Brake fluid is extremely damaging to painted surfaces. If brake fluid contacts any painted surface, immediately wipe it off and flush the surface with water thoroughly.
</ptxt>
</attention2>
<servinfosub id = "AENCP70A4316007001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear brake shoes. 
<intxreftitleoff1 refid = "AENCP70A4316005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Loosen brake pipe flare nut (1) but limit loosening to on extent in which fluid does not leak.
</ptxt>
<servicetool>
<servicetoolitem id = "L4C101">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A431010.swf" width = "88.000mm" height = "63.182mm" ver = "01" gw = "192" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Remove wheel cylinder mounting bolts. Disconnect brake pipe from wheel cylinder and put bleeder plug cap (1) onto pipe to prevent fluid from spilling.
</ptxt>
<figure>
<graphic graphicname = "I9P60A431011.swf" width = "88.000mm" height = "60.648mm" ver = "01" gw = "135" gh = "155"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A4316007002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENCP70A4316008">Wheel Cylinder Inspection:Drum Brake Model</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Install wheel cylinder to brake back plate (1), then connect brake pipe (2) to wheel cylinder.
</ptxt>
</item>
<item>
<ptxt>
Tighten wheel cylinder mounting bolts and rear brake pipe flare nut to specified torques.
</ptxt>
<servicetool>
<servicetoolitem id = "L4C102">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T4C101">
<t-part>
Wheel cylinder mounting bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8.5
</t-value1>
<t-value2>
0.87
</t-value2>
<t-value3>
6.5
</t-value3>
</torqueitem>
<torqueitem id = "T4C102">
<t-part>
Rear brake pipe flare nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1.6
</t-value2>
<t-value3>
12.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A431012.swf" width = "88.000mm" height = "68.838mm" ver = "01" gw = "192" gh = "179"/>
</figure>
</item>
<item>
<ptxt>
Bleed air from brake system. 
<intxreftitleoff1 refid = "AENCP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Adjust parking brake cable. 
<intxreftitleoff1 refid = "AENCP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hoist vehicle and check that brake drum is free from dragging.
</ptxt>
</item>
<item>
<ptxt>
Perform brake test referring to “Load Test” of 
<intxref refid = "AENCP70A4100001">Precautions for Brake Service</intxref>
 and make sure that brake system operates properly.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
