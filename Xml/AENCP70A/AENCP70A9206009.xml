<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENCP70A9206009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Combination Light Removal and Installation
</title>
<servinfosub id = "AENCP70A9206009001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear combination light screws (1).
</ptxt>
</s1>
<s1>
<ptxt>
Pull rear combination light (2) in arrow direction shown in figure to disengage stud pins (4) and remove rear combination light.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect rear combination light connector.
</ptxt>
<attention3>
<ptxt>
Check grommet for deterioration.
</ptxt>
<ptxt>
Replace as necessary.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A920003.jpg" width = "88.000mm" height = "58.609mm" ver = "01" gw = "204" gh = "150"/>
<callout-l>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.787in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Grommet
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout-l>
</figure>
</s1>
<s1>
<ptxt>
If necessary, remove bulbs.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENCP70A9206009002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
