<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A9806011" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Extracción y montaje del forro interior del techo
</title>
<servinfosub id = "ASPBP70A9806011001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desactive el sistema de airbag. 
<intxreftitleoff1 refid = "ASPBP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las viseras (1).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la luz personal (2) y la luz del techo (3).
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Luz personal: 
<intxreftitleoff1 refid = "ASPBP70A9206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Luz del techo: 
<intxreftitleoff1 refid = "ASPBP70A9206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga los siguientes embellecedores. 
<intxreftitleoff1 refid = "ASPBP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Embellecedores del pilar delantero
</ptxt>
</item>
<item>
<ptxt>
Embellecedores superiores del pilar central
</ptxt>
</item>
<item>
<ptxt>
Embellecedores superiores interiores laterales traseros
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga las asas auxiliares (4).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los clips y extraiga el forro interior del techo (5).
</ptxt>
<figure>
<graphic graphicname = "IBP70A980009.jpg" width = "183.000mm" height = "108.773mm" ver = "01" gw = "456" gh = "292"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9806011002">
<title>
Instalación
</title>
<ptxt>
Para la instalación, invierta el procedimiento anterior de desmontaje, teniendo en consideración los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Active el sistema de airbag. 
<intxreftitleoff1 refid = "ASPBP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
