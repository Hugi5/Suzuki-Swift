<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A9406002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del depósito y la bomba del lavafaros
</title>
<servinfosub id = "ASPBP70A9406002001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga las piezas siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Parachoques delantero: 
<intxreftitleoff1 refid = "ASPBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Unidad de los faros del lado izquierdo: 
<intxreftitleoff1 refid = "ASPBP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) y la manguera (2) del lavafaros.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los pernos del depósito del lavafaros (3).
</ptxt>
<figure>
<graphic graphicname = "IBP60B940003.swf" width = "88.000mm" height = "133.399mm" ver = "04" gw = "196" gh = "362"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Depósito del lavafaros
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el soporte (1) del miembro de bloqueo del capó (2) mientras presiona la garra en la dirección de la flecha como se muestra en la ilustración.
</ptxt>
<figure>
<graphic graphicname = "IBP60B940010.swf" width = "88.000mm" height = "63.666mm" ver = "01" gw = "162" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el depósito del lavafaros (1).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el perno (2) y, a continuación, extraiga la bomba del lavafaros (3).
</ptxt>
<figure>
<graphic graphicname = "IBP60B940011.swf" width = "88.000mm" height = "68.412mm" ver = "01" gw = "197" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9406002002">
<title>
Instalación
</title>
<ptxt>
Para la instalación, invierta el procedimiento anterior de desmontaje, teniendo en consideración los puntos siguientes.
</ptxt>
<ptxt>
Apriete los pernos del depósito del lavaparabrisas al par especificado.
</ptxt>
<torque>
<torqueitem id = "T9D002">
<t-part>
Perno del depósito del lavaparabrisas
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B940008.swf" width = "88.000mm" height = "82.015mm" ver = "01" gw = "197" gh = "216"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
