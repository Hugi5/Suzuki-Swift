<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A7206013" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del controlador del motor del soplador
</title>
<servinfosub id = "ASPBP70A7206013001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la guantera del panel de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conducto de aire para los pies (2) de la unidad de HVAC retirando el tornillo (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A721036.jpg" width = "88.000mm" height = "94.268mm" ver = "01" gw = "199" gh = "251"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del controlador del motor del soplador (2) y después retire el controlador de la unidad de HVAC, extrayendo los tornillos (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A720022.swf" width = "88.000mm" height = "50.799mm" ver = "01" gw = "187" gh = "127"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A7206013002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
