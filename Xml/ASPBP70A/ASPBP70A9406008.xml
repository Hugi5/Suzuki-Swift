<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A9406008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del limpialunetas trasero
</title>
<servinfosub id = "ASPBP70A9406008001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga la cubierta (1) del brazo del limpialunetas trasero, la tuerca (2) del brazo del limpialunetas trasero, el conjunto de la escobilla y el brazo del limpialunetas trasero (3), el sombrerete (4) del pivote del limpialunetas trasero, la tuerca (5) del limpialunetas trasero y el sello (6) del limpialunetas trasero.
</ptxt>
<figure>
<graphic graphicname = "IBP70A940006.swf" width = "88.000mm" height = "45.318mm" ver = "01" gw = "181" gh = "112"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el embellecedor de la puerta del maletero. 
<intxreftitleoff1 refid = "ASPBP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el motor del limpialunetas trasero.
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del motor del limpialunetas trasero mediante un destornillador de punta plana (2) como se muestra en la ilustración.
</ptxt>
<figure>
<graphic graphicname = "I7V10A940003.swf" width = "88.000mm" height = "79.003mm" ver = "01" gw = "161" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9406008002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A9406009">Inspección del motor del limpialunetas trasero</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete los pernos del motor del limpialunetas trasero al par de apriete especificado.
</ptxt>
<torque>
<torqueitem id = "T9D005">
<t-part>
Perno del motor del limpialunetas trasero
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I5RW0A940011.swf" width = "88.000mm" height = "56.315mm" ver = "01" gw = "172" gh = "143"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
