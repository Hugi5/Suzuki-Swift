<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70AA506006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del interruptor de solicitud y de apertura de la puerta del maletero
</title>
<servinfosub id = "ASPBP70AA506006001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el embellecedor de la puerta del maletero. 
<intxreftitleoff1 refid = "ASPBP70A9606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del interruptor de solicitud y de apertura de la puerta del maletero, y el clip.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la guarnición embellecedora inferior de la puerta del maletero. 
<intxreftitleoff1 refid = "ASPBP70A9206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga los tornillos y, a continuación, el interruptor de solicitud y de apertura de la puerta del maletero (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50023.swf" width = "88.000mm" height = "54.154mm" ver = "01" gw = "198" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70AA506006002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70AA506010">Inspección del interruptor de solicitud</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
