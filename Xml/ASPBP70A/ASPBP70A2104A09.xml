<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A2104A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La carrocería se inclina o se balancea al tomar las curvas
</title>
<diag type = "condition">
<condition>
<ptxt>
La carrocería se inclina o se balancea al tomar las curvas
</ptxt>
</condition>
<ps>
<ptxt>
Barra estabilizadora floja
</ptxt>
</ps>
<action>
<ptxt>
Apriete los pernos o las tuercas de la barra estabilizadora, o reemplace los casquillos. 
<intxreftitleoff1 refid = "ASPBP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Conjunto o soporte del puntal delantero (amortiguador) defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el conjunto del puntal delantero (amortiguador) o apriete el soporte. 
<intxreftitleoff1 refid = "ASPBP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Muelles helicoidales rotos o hundidos
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Reemplace los muelles helicoidales.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Parte delantera: 
<intxreftitleoff1 refid = "ASPBP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Parte trasera: 
<intxreftitleoff1 refid = "ASPBP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Vehículo sobrecargado
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la carga.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
