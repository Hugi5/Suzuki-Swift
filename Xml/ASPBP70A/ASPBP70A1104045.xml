<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A1104045" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0607
</title>
<servinfosub id = "ASPBP70A1104045001">
<title>
Condición de detección del DTC y área afectada
</title>
<attention3>
<ptxt>
Para la distinción de tipo del sistema OBD, consulte &#34;Discriminación del sistema OBD&#34; en 
<intxref refid = "ASPBP70A1101003">Descripción del sistema OBD</intxref>
.
</ptxt>
</attention3>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.010in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.195in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0607: Rendimiento del módulo de control 
</emph>
</ptxt>
<ptxt>
Se detecta un fallo interno en el ECM.
</ptxt>
<ptxt>
(Tipos A y C: (lógica de detección de 1 ciclo de conducción o lógica de detección de 3 ciclos de conducción, pero el MIL no se enciende)
</ptxt>
<ptxt>
(Tipo B: (lógica de detección de 1 ciclo de conducción o lógica de detección de 2 ciclos de conducción, pero el MIL no se enciende)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Circuito de la alimentación eléctrica del ECM y/o circuito a masa
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPBP70A1104045002">
<title>
Procedimiento de confirmación del DTC
</title>
<attention3>
<ptxt>
Compruebe que se cumple la siguiente condición en este &#34;Procedimiento de confirmación del DTC&#34;.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tensión de la batería &#62; 8 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Conecte el encendido (posición ON) durante 1 min. como mínimo.
</ptxt>
</s1>
<s1>
<ptxt>
Arranque el motor si es posible.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A1104045003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70A1104045004">
<testgroup id = "ASPBP70A1104045005">
<title>
Nueva comprobación del DTC.
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPBP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el encendido (posición OFF).
</ptxt>
</test1>
<test1>
<ptxt>
Realice el &#34;Procedimiento de confirmación de DTC&#34; y verifique el DTC.
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC P0607?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Verifique los problemas intermitentes. 
<intxreftitleoff1 refid = "ASPBP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A1104045006">
<title>
Verificación del circuito de masa y de la alimentación del ECM
</title>
<test1>
<ptxt>
Compruebe el circuito de la alimentación eléctrica y/o circuito a masa del ECM. 
<intxreftitleoff1 refid = "ASPBP70A1104068"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el ECM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
