<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A9A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del guardabarros delantero
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A9A06004">Componentes del guardabarros delantero</intxrefpoff>
</ptxt>
<servinfosub id = "ASPBP70A9A06005001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el parachoques delantero y el soporte del parachoques delantero. 
<intxreftitleoff1 refid = "ASPBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la guarnición superior del capó y la guarnición lateral superior del capó. 
<intxreftitleoff1 refid = "ASPBP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la unidad del faro. 
<intxreftitleoff1 refid = "ASPBP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el guardasalpicaduras del umbral lateral. 
<intxreftitleoff1 refid = "ASPBP70A9806007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el forro del guardabarros delantero. 
<intxreftitleoff1 refid = "ASPBP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el guardabarros delantero y la cubierta de éste. 
<intxreftitleoff1 refid = "ASPBP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9A06005002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ajuste la holgura del panel del guardabarros delantero. 
<intxreftitleoff1 refid = "ASPBP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Si se ha desconchado la pintura de los pernos del guardabarros delantero, vuelva a pintarlos para evitar su oxidación.
</ptxt>
</item>
<item>
<ptxt>
Regule los faros tras la instalación. 
<intxreftitleoff1 refid = "ASPBP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
