<servinfosub id = "ASPBP70A9304004003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70A9304004004">
<testgroup id = "ASPBP70A9304004005">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPBP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Asegúrese de que el encendido esté desconectado (posición OFF).
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPBP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1802?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Verifique los problemas intermitentes. 
<intxreftitleoff1 refid = "ASPBP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A9304004006">
<title>
Inspección de los circuitos de la alimentación eléctrica y a masa del juego de instrumentos
</title>
<test1>
<ptxt>
Inspeccione los circuitos de alimentación  y a masa del juego de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Están en buenas condiciones?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare el mazo de cables defectuoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A9304004007">
<title>
Verificación de la tensión de la alimentación eléctrica del juego de instrumentos
</title>
<test1>
<ptxt>
Comprobación de la tensión de alimentación eléctrica con el motor en régimen de ralentí.
</ptxt>
</test1>
<question>
¿La tensión es de 10 – 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el juego de instrumentos y vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Inspeccione el sistema de carga. 
<intxreftitleoff1 refid = "ASPBP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
