<servinfosub id = "ASPBP70A6304010002">
<title>
Localización y reparación de averías
</title>
<diag type = "test" id = "ASPBP70A6304010003">
<testgroup id = "ASPBP70A6304010004">
<title>
Comprobación de la luz de advertencia P/S
</title>
<test1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</test1>
<question>
¿Se encienden otras luces de advertencia?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A6304010005">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPBP70A6304003">Comprobación del DTC</intxref>
.
</ptxt>
</test1>
<question>
¿Aparecen el DTC U0073 o el U0155?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPBP70AA804002">Tabla DTC de CAN (Comunicación perdida y Bus de comunicación apagado)</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A6304010006">
<title>
Inspección del juego de instrumentos
</title>
<test1>
<ptxt>
Sustituya el juego de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</test1>
<question>
¿Permanece apagada la luz de advertencia P/S?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control de P/S. 
<intxreftitleoff1 refid = "ASPBP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A6304010007">
<title>
Inspección del fusible
</title>
<question>
¿Está en buenas condiciones el fusible &#34;MTR&#34; del juego de instrumentos?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Sustituya el fusible &#34;MTR&#34; y verifique si se ha producido un cortocircuito a masa.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASPBP70A6304010008">
<title>
Inspección del circuito de comunicación CAN
</title>
<test1>
<ptxt>
Compruebe el circuito de comunicación CAN entre el juego de instrumentos y el módulo de control de P/S. 
<intxreftitleoff1 refid = "ASPBP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está el circuito de comunicaciones CAN en buenas condiciones?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Repare o reemplace.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASPBP70A6304010009">
<title>
Inspección del circuito de alimentación eléctrica del juego de instrumentos
</title>
<test1>
<ptxt>
Extraiga el juego de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe si la conexión al conector del juego de instrumentos es correcta.
</ptxt>
</test1>
<test1>
<ptxt>
Si el resultado de la comprobación es correcto, coloque el encendido en posición ON.
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe si la tensión entre los terminales &#34;G240-3&#34; y &#34;G240-5&#34; se corresponde con la tensión de la batería.
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Repare el juego de instrumentos y vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Vaya al paso 7.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASPBP70A6304010010">
<title>
Inspección del circuito a masa del juego de instrumentos
</title>
<test1>
<ptxt>
Desconecte el encendido (posición OFF).
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe si la resistencia entre el terminal &#34;G240-5&#34; y la conexión a masa es igual o inferior a 1 &#937;.
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Repare o sustituya el circuito &#34;A1&#34;.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el circuito &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
