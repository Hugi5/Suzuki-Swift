<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A1A04A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La luz de advertencia de carga no se apaga cuando el motor está funcionando (la batería requiere recargas frecuentes)
</title>
<ptxt>
Los problemas en el sistema de carga se manifestarán a través de una o varias de las situaciones siguientes: 
</ptxt>
<servinfosub id = "ASPBP70A1A04002001" page = "1">
<title>
Funcionamiento de la luz de advertencia de carga
</title>
<diag type = "condition">
<condition>
<ptxt>
La luz de advertencia de carga no se apaga cuando el motor está funcionando (la batería requiere recargas frecuentes)
</ptxt>
</condition>
<ps>
<ptxt>
Correa de transmisión suelta o desgastada
</ptxt>
</ps>
<action>
<ptxt>
Ajuste o sustituya la correa de transmisión. 
<intxreftitleoff1 refid = "ASPBP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Juego de instrumentos defectuoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sustituya el juego de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM defectuoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Revise el BCM. 
<intxreftitleoff1 refid = "ASPBP70AA204022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Regulador de IC o generador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el generador. 
<intxreftitleoff1 refid = "ASPBP70A1A06007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el cableado.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
