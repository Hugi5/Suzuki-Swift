<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A7204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
No sale aire caliente o la calefacción es insuficiente
</title>
<diag type = "condition">
<condition>
<ptxt>
No sale aire caliente o la calefacción es insuficiente
</ptxt>
</condition>
<ps>
<ptxt>
Conductos de aire atascados
</ptxt>
</ps>
<action>
<ptxt>
Repare los conductos de aire.
</ptxt>
</action>
<ps>
<ptxt>
Núcleo del calentador atascado o con fugas
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el núcleo del calentador.
</ptxt>
</action>
<ps>
<ptxt>
Mangueras del calentador atascadas o con fugas
</ptxt>
</ps>
<action>
<ptxt>
Sustituya las mangueras del calentador.
</ptxt>
</action>
<ps>
<ptxt>
Filtro de aire obstruido
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el filtro de aire
</ptxt>
</action>
<ps>
<ptxt>
Conjunto de la compuerta de control de temperatura defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione la de unidad HVAC.
</ptxt>
</action>
<ps>
<ptxt>
Actuador de control de temperatura defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el actuador del control de temperatura. 
<intxreftitleoff1 refid = "ASPBP70A7206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado.
</ptxt>
</action>
<ps>
<ptxt>
Sensor de temperatura del evaporador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el sensor de temperatura del evaporador. 
<intxreftitleoff1 refid = "ASPBP70A7206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Avería en el sensor de temperatura del aire interior, el sensor de temperatura del aire exterior o el sensor de carga solar
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Compruebe el sensor de temperatura del aire interior, el sensor de temperatura del aire exterior o el sensor de carga solar.
</ptxt>
<ptxt>
• Sensor de temperatura del aire interior: 
<intxreftitleoff1 refid = "ASPBP70A7206034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
• Sensor de temperatura del aire exterior: 
<intxreftitleoff1 refid = "ASPBP70A7206032"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
• Sensor de carga solar: 
<intxreftitleoff1 refid = "ASPBP70A7206030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el BCM. 
<intxreftitleoff1 refid = "ASPBP70AA204022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Panel del A/C automático defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el panel del A/C automático. 
<intxreftitleoff1 refid = "ASPBP70A7204034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Módulo de control HVAC defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el módulo de control HVAC. 
<intxreftitleoff1 refid = "ASPBP70A7204035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
