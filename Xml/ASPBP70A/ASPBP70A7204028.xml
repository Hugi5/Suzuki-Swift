<servinfo servinfosgmlid = "ASPBP70A7204028" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1580 / B1902
</title>
<servinfosub id = "ASPBP70A7204028001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.922in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.288in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1580: Error de EEPROM 
</emph>
</ptxt>
<ptxt>
Se ha producido un error de EEPROM en el módulo de control HVAC.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Módulo de control HVAC
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1902: Error de programación del módulo de control 
</emph>
</ptxt>
<ptxt>
Se ha producido un error al programar el módulo de control HVAC.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPBP70A7204028002">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Arranque el motor y después ponga en marcha el sistema de A/C.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A7204028003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70A7204028004">
<testgroup id = "ASPBP70A7204028005">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el encendido (posición OFF).
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición ON) y compruebe los DTC
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1580 o B1902?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control HVAC y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPBP70A7206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problema intermitente.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
