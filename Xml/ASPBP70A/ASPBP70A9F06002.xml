<servinfo servinfosgmlid = "ASPBP70A9F06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de los altavoces delantero y trasero
</title>
<servinfosub id = "ASPBP70A9F06002001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el embellecedor de la puerta o el embellecedor interior trasero.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Embellecedor de la puerta: 
<intxreftitleoff1 refid = "ASPBP70A9506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Embellecedores interiores laterales traseros: 
<intxreftitleoff1 refid = "ASPBP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Retire los 3 tornillos y extraiga el altavoz delantero o trasero (1).
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del altavoz.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IBP60B9F0004.jpg" width = "88.000mm" height = "65.800mm" ver = "02" gw = "168" gh = "170"/>
</figure>
</servinfosub>
<servinfosub id = "ASPBP70A9F06002002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
