<servinfosub id = "ASPBP70A7204021003">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el encendido (posición OFF).
</ptxt>
</s1>
<s1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A7204021004">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70A7204021005">
<testgroup id = "ASPBP70A7204021006">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el encendido (posición OFF).
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición ON) y compruebe los DTC
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1541?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problema intermitente.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A7204021008">
<title>
Inspección del fusible
</title>
<test1>
<ptxt>
Inspeccione el fusible &#34;DOME&#34;.
</ptxt>
</test1>
<question>
¿Está en buenas condiciones?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el fusible &#34;DOME&#34; y verifique si se ha producido un cortocircuito a masa.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A7204021007">
<title>
Inspección del circuito de suministro de tensión de la batería
</title>
<test1>
<ptxt>
Desconecte el conector &#34;G20&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Mida la tensión entre el terminal de cable &#34;WHT/RED&#34; del conector &#34;G20&#34; y la masa.
</ptxt>
</test1>
<question>
¿La tensión es de 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control HVAC y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPBP70A7206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el mazo de cables del panel de instrumentos.
</ptxt>
</action>
</testgroup>
