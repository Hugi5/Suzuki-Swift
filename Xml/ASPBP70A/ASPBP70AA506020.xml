<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70AA506020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
 Sustitución de la batería del mando a distancia
</title>
<s1>
<ptxt>
Extraiga la llave de emergencia (4).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la caja superior (1) con ayuda de un destornillador de punta plana tal como se muestra en la ilustración.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la placa de circuito impreso (2) de la caja inferior (3).
</ptxt>
<figure>
<graphic graphicname = "IAW101A50043.swf" width = "88.000mm" height = "73.205mm" ver = "01" gw = "163" gh = "191"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.291in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.847in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Trapo limpio
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Extraiga la pila (2) con ayuda de un destornillador de punta plana (1) tal como se muestra en la ilustración.
</ptxt>
<figure>
<graphic graphicname = "IAW101A50044.swf" width = "88.000mm" height = "32.419mm" ver = "01" gw = "169" gh = "75"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.125in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Trapo limpio
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Coloque la pila (CR 2032 de botón de litio o equivalente) (1) de forma que su terminal &#34;-&#34; quede orientado hacia la marca &#34;-&#34; de la placa de circuito impreso (2).
</ptxt>
<figure>
<graphic graphicname = "IAW101A50045.swf" width = "88.000mm" height = "37.223mm" ver = "01" gw = "130" gh = "89"/>
</figure>
</s1>
<s1>
<ptxt>
Coloque la placa de circuito impreso en la caja inferior y ajuste la caja superior.
</ptxt>
<attention3>
<ptxt>
Deshágase de las pilas gastadas siguiendo las normas adecuadas en materia de desecho de materiales. No tire las pilas de litio con la basura doméstica.
</ptxt>
</attention3>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
