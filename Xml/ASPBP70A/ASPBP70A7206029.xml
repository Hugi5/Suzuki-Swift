<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A7206029" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del sensor solar
</title>
<servinfosub id = "ASPBP70A7206029001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desactive el sistema de airbag. 
<intxreftitleoff1 refid = "ASPBP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Extraiga el panel de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el sensor solar (1) del panel de instrumentos presionando la pestaña y tirando del sensor hacia arriba.
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte los conectores (2) del sensor solar.
</ptxt>
<figure page = "2">
<graphic graphicname = "I7RW01722028.swf" width = "88.000mm" height = "40.458mm" ver = "01" gw = "238" gh = "98"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASPBP70A7206029002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A7206030">Inspección del sensor solar</intxrefpoff>
</ptxt>
<ptxt>
Para la instalación, invierta el procedimiento anterior de extracción, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Coloque el sensor solar (1) en las lengüetas (2) de acoplamiento del panel de instrumentos del sensor de carga solar en las ranuras (3) del panel de instrumentos, tal como se muestra en la imagen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723025.swf" width = "88.000mm" height = "35.371mm" ver = "01" gw = "209" gh = "84"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.181in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Parte delantera del vehículo
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Active el sistema de airbag. 
<intxreftitleoff1 refid = "ASPBP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
