<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A5206016" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Desmontaje y montaje de la caja derecha del transeje
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A5206010">Desmontaje y montaje de la unidad de transeje manual</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASPBP70A5206014">Componentes del conjunto de transeje manual</intxrefpoff>
</ptxt>
<servinfosub id = "ASPBP70A5206016001">
<title>
Desmontaje
</title>
<s1>
<ptxt>
Extraiga el sello de aceite lateral del diferencial de la caja derecha del transeje, si fuera necesario. 
<intxreftitleoff1 refid = "ASPBP70A5206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el anillo exterior (1) del cojinete lateral del diferencial con una barra de latón (2), si es necesario.
</ptxt>
<figure>
<graphic graphicname = "IAY301520029.swf" width = "88.000mm" height = "70.092mm" ver = "02" gw = "206" gh = "182"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Extraiga el sello de aceite del eje de entrada con la herramienta especial, si es necesario.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B008">
<s-part>
(A)
</s-part>
<s-number num = "09913-75830">
09913-75830
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A520026.swf" width = "88.000mm" height = "47.005mm" ver = "01" gw = "190" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Rompa el conducto de aceite (1) con un destornillador de punta plana o un instrumento similar y extráigalo.
</ptxt>
<figure>
<graphic graphicname = "IAY301520030.swf" width = "88.000mm" height = "51.720mm" ver = "01" gw = "186" gh = "130"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el anillo-guía exterior del cojinete derecho del contraeje con las herramientas especiales, si es necesario.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B009">
<s-part>
(A)
</s-part>
<s-number num = "09942-15511">
09942-15511
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B010">
<s-part>
(B)
</s-part>
<s-number num = "09944-96011">
09944-96011
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAY301520031.swf" width = "88.000mm" height = "55.919mm" ver = "01" gw = "194" gh = "142"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A5206016002">
<title>
Montaje
</title>
<s1>
<ptxt>
Instale un nuevo sello de aceite del eje de entrada (1) con el lado del muelle hacia arriba, si se había extraído. Utilice la herramienta especial y un martillo para la colocación, y aplique grasa al borde del sello de aceite.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B007" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasa
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<servicetool>
<servicetoolitem id = "L5B011">
<s-part>
(A)
</s-part>
<s-number num = "09913-75830">
09913-75830
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Distancia de la superficie de la caja al sello de aceite del eje de entrada
</title>
<ptxt>
&#34;a&#34;: 1,0 – 2,0 mm (0,04 – 0,07 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP60B520019.jpg" width = "88.000mm" height = "68.749mm" ver = "02" gw = "206" gh = "178"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Coloque el anillo-guía exterior del cojinete derecho del contraeje y el conducto de aceite del contraeje nuevo con la herramienta especial, si se lo extrajo.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B012">
<s-part>
(A)
</s-part>
<s-number num = "09913-85210">
09913-85210
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAY301520032.swf" width = "88.000mm" height = "55.223mm" ver = "01" gw = "190" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Coloque el anillo-guía exterior del cojinete lateral del diferencial con las herramientas especiales y el martillo, si se lo extrajo.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B013">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B014">
<s-part>
(B)
</s-part>
<s-number num = "09925-14520">
09925-14520
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A520030.swf" width = "88.000mm" height = "48.631mm" ver = "01" gw = "182" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Coloque el sello de aceite lateral del diferencial nuevo en la caja derecha, si se lo extrajo. 
<intxreftitleoff1 refid = "ASPBP70A5206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
