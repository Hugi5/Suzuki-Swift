<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70AA506018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del indicador acústico de advertencia exterior
</title>
<servinfosub id = "ASPBP70AA506018001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el forro del guardabarros delantero del lado del conductor. 
<intxreftitleoff1 refid = "ASPBP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) y, a continuación, extraiga el indicador acústico de advertencia exterior (2).
</ptxt>
<figure>
<graphic graphicname = "IBP70AA50007.jpg" width = "88.000mm" height = "65.351mm" ver = "01" gw = "239" gh = "169"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70AA506018002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70AA506019">Inspección del indicador acústico de advertencia exterior</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
