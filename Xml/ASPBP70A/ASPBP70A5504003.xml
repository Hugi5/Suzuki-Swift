<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A5504003" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Inspección básica de la CVT
</title>
<ptxt>
Localice y repare las averías con referencia a los siguientes puntos cuando no se detecte ningún DTC en el TCM y no se encuentre ninguna anomalía en 
<intxref refid = "ASPBP70A5504002">Inspección visual</intxref>
. Siga cuidadosamente las instrucciones de la tabla.
</ptxt>
<diag type = "test" id = "ASPBP70A5504003001">
<testgroup id = "ASPBP70A5504003002">
<question>
¿Se ha realizado la &#34;Inspección del sistema de la CVT&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPBP70A5504001">Inspección del sistema de la CVT</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A5504003003">
<title>
Prueba de carretera
</title>
<test1>
<ptxt>
Realice la prueba de carretera. 
<intxreftitleoff1 refid = "ASPBP70A5504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Consulte los elementos de 
<intxref refid = "ASPBP70A5504009">Diagnóstico de síntomas de la CVT</intxref>
, y repare o sustituya las piezas defectuosas.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A5504003004">
<title>
Prueba de calado
</title>
<test1>
<ptxt>
Efectúe la prueba de calado. 
<intxreftitleoff1 refid = "ASPBP70A5504005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya las piezas defectuosas y vaya al paso 6.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A5504003005">
<title>
Prueba de retardo
</title>
<test1>
<ptxt>
Realice la prueba de tiempo de retardo. 
<intxreftitleoff1 refid = "ASPBP70A5504006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya las piezas defectuosas y vaya al paso 6.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A5504003006">
<title>
Prueba de presión de la tubería
</title>
<test1>
<ptxt>
Efectúe la prueba de presión de la tubería. 
<intxreftitleoff1 refid = "ASPBP70A5504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya las piezas defectuosas y vaya al paso 6.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A5504003007">
<title>
Diagnóstico de síntomas de la CVT
</title>
<question>
¿Se ha identificado algún síntoma de avería?
</question>
<result type = "yes"/>
<action>
<ptxt>
Consulte los elementos de 
<intxref refid = "ASPBP70A5504009">Diagnóstico de síntomas de la CVT</intxref>
, y repare o sustituya las piezas defectuosas.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
