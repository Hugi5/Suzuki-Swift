<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A9506009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del cristal de la ventanilla delantera
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A9506008">Componentes de la puerta delantera</intxrefpoff>
</ptxt>
<servinfosub id = "ASPBP70A9506009001">
<title>
Extracción
</title>
<s1>
<ptxt>
Baje el cristal de la puerta delantera hasta unos 150 mm (5,91 in.) del borde inferior de la ventanilla.
</ptxt>
<figure>
<graphic graphicname = "IBP70A950005.jpg" width = "88.000mm" height = "45.878mm" ver = "02" gw = "225" gh = "114"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.331in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.870in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
&#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Aproximadamente 150 mm (5,91 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el embellecedor interior (1) del soporte de la ventanilla.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la tapa (2) de la manilla interior.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los tornillos (3) y los clips, y extraiga el embellecedor de la puerta (4) tirando de él en la dirección de la flecha.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950025.jpg" width = "88.000mm" height = "101.074mm" ver = "01" gw = "227" gh = "270"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte los conectores del mazo de cables de la puerta.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el burlete exterior de la puerta delantera (1) moviéndolo en las direcciones de las flechas en el orden (de &#34;1&#34; a &#34;2&#34;) como se muestra en la ilustración.
</ptxt>
<figure>
<graphic graphicname = "IAP70B950009.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.384in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.523in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Garra
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Panel exterior de la puerta delantera
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Retire el soporte del embellecedor de la puerta (1) y la cubierta de sellado de la puerta (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950027.jpg" width = "88.000mm" height = "91.845mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Quite los tornillos (1) y extraiga el cristal de la puerta delantera (2) moviéndolo en las direcciones de las flechas en el orden (de &#34;1&#34; a &#34;2&#34;) como se muestra en la ilustración.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950028.jpg" width = "88.000mm" height = "78.685mm" ver = "02" gw = "225" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9506009002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Coloque los soportes del cristal de la puerta (1) en la posición especificada del cristal de la puerta delantera (2) si se extraen del cristal de la puerta delantera.
</ptxt>
<spec>
<title>
Posición de instalación del soporte del cristal de la puerta delantera
</title>
<ptxt>
&#34;a&#34;: 104 – 106 mm (4,10 – 4,17 in.)
</ptxt>
<ptxt>
&#34;b&#34;: 431,2 – 433,2 mm (16,98 – 17,05 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70P950015.jpg" width = "88.000mm" height = "46.523mm" ver = "01" gw = "191" gh = "115"/>
</figure>
</item>
<item>
<ptxt>
Apriete los tornillos del cristal de la puerta delantera en el orden (de &#34;1&#34; a &#34;2&#34;) como se muestra en la ilustración.
</ptxt>
</item>
<item>
<ptxt>
Apriete los tornillos del cristal de la puerta delantera al par de apriete especificado.
</ptxt>
<torque>
<torqueitem id = "T9E002">
<t-part>
Tornillo del cristal de la puerta delantera*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950029.jpg" width = "88.000mm" height = "81.655mm" ver = "02" gw = "225" gh = "215"/>
</figure>
</item>
<item>
<ptxt>
Si el recorrido del cristal está deformado, sustitúyalo por uno nuevo.
</ptxt>
</item>
<item>
<ptxt>
Fije con cinta de butilo (2) la cubierta de estanqueidad de la puerta (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950031.jpg" width = "88.000mm" height = "81.028mm" ver = "01" gw = "215" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
