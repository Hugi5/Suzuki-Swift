<servinfosub id = "ASPBP70A1104019003">
<title>
Procedimiento de confirmación del DTC
</title>
<attention3>
<ptxt>
Compruebe que no se detecta el siguiente DTC en este &#34;Procedimiento de confirmación del DTC&#34;.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sensor ECT (P0118)
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Caliente el motor hasta que llegue a la temperatura normal de funcionamiento.
</ptxt>
</s1>
<s1>
<ptxt>
Mantenga el motor al ralentí durante 5 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A1104019004">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70A1104019005">
<testgroup id = "ASPBP70A1104019006">
<question>
¿Se ha realizado la &#34;Inspección del sistema de control del motor y de las emisiones&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPBP70A1104001">Inspección del sistema de control del motor y de las emisiones</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A1104019007">
<title>
Comprobación del nivel de refrigerante
</title>
<test1>
<ptxt>
Compruebe el nivel de refrigerante. 
<intxreftitleoff1 refid = "ASPBP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Añada refrigerante y vuelva a realizar la comprobación del DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A1104019008">
<title>
Inspección del circuito del sensor ECT
</title>
<test1>
<ptxt>
Inspeccione los circuitos del sensor ECT conforme al paso 2 de 
<intxref refid = "ASPBP70A1104020">DTC P0117 / P0118</intxref>
.
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A1104019009">
<title>
Verificación del sensor ECT
</title>
<test1>
<ptxt>
Inspeccione el sensor ECT. 
<intxreftitleoff1 refid = "ASPBP70A1306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Reemplace el sensor ECT.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A1104019010">
<title>
Inspección del termostato
</title>
<test1>
<ptxt>
Revise el termostato. 
<intxreftitleoff1 refid = "ASPBP70A1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el ECM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el termostato.
</ptxt>
</action>
</testgroup>
</diag>
