<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A1704001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Inspección del sistema de combustible
</title>
<diag type = "test" id = "ASPBP70A1704001001">
<testgroup id = "ASPBP70A1704001002">
<title>
Inspección de la bomba de combustible
</title>
<test1>
<ptxt>
Extraiga el tapón de llenado de combustible y conecte el encendido (posición ON) .
</ptxt>
</test1>
<test1>
<ptxt>
Confirme que el ruido de funcionamiento de la bomba de combustible se escucha por el orificio de llenado de combustible durante unos 2 segundos, y después deja de oírse.
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Compruebe el circuito de la bomba de combustible. 
<intxreftitleoff1 refid = "ASPBP70A1704004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A1704001003">
<title>
Comprobación de la presión del combustible
</title>
<test1>
<ptxt>
Compruebe la presión del combustible. 
<intxreftitleoff1 refid = "ASPBP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare la pieza defectuosa.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A1704001004">
<title>
Prueba de equilibrio de energía
</title>
<test1>
<ptxt>
Inspeccione el equilibrio de energía. 
<intxreftitleoff1 refid = "ASPBP70A1704002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
El sistema de combustible está en buenas condiciones.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A1704001005">
<title>
Inspección del circuito del inyector de combustible
</title>
<test1>
<ptxt>
Revise el circuito del inyector de combustible. 
<intxreftitleoff1 refid = "ASPBP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare la pieza defectuosa.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A1704001006">
<title>
Inspección del inyector de combustible
</title>
<test1>
<ptxt>
Compruebe los inyectores de combustible. 
<intxreftitleoff1 refid = "ASPBP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el ECM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Reemplace el inyector de combustible. 
<intxreftitleoff1 refid = "ASPBP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
