<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A5206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Desmontaje y montaje de la unidad de transeje manual
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A5206009">Componentes de la unidad de transeje manual</intxrefpoff>
</ptxt>
<servinfosub id = "ASPBP70A5206010001">
<title>
Desmontaje
</title>
<s1>
<ptxt>
Extraiga el motor y el transeje conjuntamente. 
<intxreftitleoff1 refid = "ASPBP70A1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del eje impulsor izquierdo y el conjunto del eje impulsor intermedio.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Conjunto del eje impulsor izquierdo: 
<intxreftitleoff1 refid = "ASPBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Conjunto del eje intermedio: 
<intxreftitleoff1 refid = "ASPBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga el perno de la abrazadera del mazo de cables del motor (1) y el perno de masa del mazo de cables del motor (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B520027.jpg" width = "88.000mm" height = "67.952mm" ver = "01" gw = "191" gh = "176"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el motor de arranque. 
<intxreftitleoff1 refid = "ASPBP70A1906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga soporte del montaje trasero del motor n&#176; 2. 
<intxreftitleoff1 refid = "ASPBP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga del transeje las otras piezas fijadas, si las hay.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los pernos y la tuerca del transeje al motor. 
<intxreftitleoff1 refid = "ASPBP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el transeje del motor.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A5206010002">
<title>
Montaje
</title>
<ptxt>
Invierta el procedimiento de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete el perno de la abrazadera del mazo de cables del motor (1) y el perno de masa del mazo de cables del motor (2) al par de apriete especificado.
</ptxt>
<torque>
<torqueitem id = "T5B005">
<t-part>
Perno de la abrazadera del mazo de cables del motor
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T5B006">
<t-part>
Perno de masa del mazo de cables del motor
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B520028.jpg" width = "88.000mm" height = "68.305mm" ver = "01" gw = "191" gh = "177"/>
</figure>
</item>
<item>
<ptxt>
Apriete cada perno y tuerca al par especificado.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Pernos y tuerca del transeje manual: 
<intxreftitleoff1 refid = "ASPBP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pernos del soporte de montaje trasero del motor n&#176;2: 
<intxreftitleoff1 refid = "ASPBP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tuerca del eje impulsor delantero: 
<intxreftitleoff1 refid = "ASPBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pernos del soporte intermedio: 
<intxreftitleoff1 refid = "ASPBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Perno y tuerca de montaje del motor de arranque: 
<intxreftitleoff1 refid = "ASPBP70A1906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Fije firmemente cada abrazadera del cableado.
</ptxt>
</item>
<item>
<ptxt>
Compruebe la función del motor, el embrague y el transeje.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
