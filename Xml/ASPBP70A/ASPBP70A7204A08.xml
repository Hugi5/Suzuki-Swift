<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A7204A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Sólo sale aire frío a alta velocidad
</title>
<diag type = "condition">
<condition>
<ptxt>
Sólo sale aire frío a alta velocidad
</ptxt>
</condition>
<ps>
<ptxt>
Condensador obstruido
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el condensador. 
<intxreftitleoff1 refid = "ASPBP70A7206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</action>
<ps>
<ptxt>
Carga insuficiente del refrigerante
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la cantidad de refrigerante y si hay fugas en el sistema.
</ptxt>
</action>
<ps>
<ptxt>
Aire en el sistema de A/C
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el condensador y realice la evacuación y carga del sistema de A/C. 
<intxreftitleoff1 refid = "ASPBP70A7206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Correa de transmisión del compresor floja o rota
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la correa de transmisión del compresor. 
<intxreftitleoff1 refid = "ASPBP70A7206041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compresor del A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el compresor del A/C.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
