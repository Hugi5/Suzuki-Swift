<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70AA204004" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Borrado de DTC
</title>
<s1>
<ptxt>
Asegúrese de que el encendido esté desconectado (posición OFF).
</ptxt>
</s1>
<s1>
<ptxt>
Conecte la herramienta de escaneado SUZUKI al DLC (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L10B002">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
Herramienta de escaneado de SUZUKI (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A121001.jpg" width = "88.000mm" height = "67.502mm" ver = "02" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</s1>
<s1>
<ptxt>
Borre el DTC siguiendo las instrucciones de la herramienta de escaneado. Para más información, consulte el manual del usuario de la herramienta de escaneado SUZUKI.
</ptxt>
</s1>
<s1>
<ptxt>
Tras el borrado, desconecte el encendido (posición OFF) y desconecte la herramienta de escaneado SUZUKI del DLC.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
