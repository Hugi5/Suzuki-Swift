<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A1606007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del termostato
</title>
<servinfosub id = "ASPBP70A1606007001">
<title>
Extracción
</title>
<s1>
<ptxt>
Drene el refrigerante. 
<intxreftitleoff1 refid = "ASPBP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del depurador de aire, la manguera de aspiración y el resonador. 
<intxreftitleoff1 refid = "ASPBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la manguera de entrada del radiador (1) de la tapa del termostato (2).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la tapa del termostato de la caja del termostato (3).
</ptxt>
<figure>
<graphic graphicname = "IBP60B160007.jpg" width = "88.000mm" height = "76.125mm" ver = "01" gw = "214" gh = "199"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el termostato (1) de la caja del termostato (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B160008.jpg" width = "88.000mm" height = "63.912mm" ver = "02" gw = "171" gh = "165"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A1606007002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A1606008">Inspección del termostato</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Coloque el termostato (1) en la caja del termostato (2) alineando la válvula de purga de aire (4) del termostato con la marca (3) de la caja del termostato.
</ptxt>
<figure>
<graphic graphicname = "IBP60B160013.jpg" width = "88.000mm" height = "82.434mm" ver = "01" gw = "231" gh = "217"/>
</figure>
</item>
<item>
<ptxt>
Rellene el sistema de refrigeración con refrigerante. 
<intxreftitleoff1 refid = "ASPBP70A1606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verifique si el sistema de refrigeración tiene fugas. 
<intxreftitleoff1 refid = "ASPBP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
