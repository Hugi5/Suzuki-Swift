<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A9406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la boquilla del lavafaros
</title>
<servinfosub id = "ASPBP70A9406005001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el parachoques delantero. 
<intxreftitleoff1 refid = "ASPBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte la manguera del lavaparabrisas (1).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la abrazadera del lavafaros (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B940004.swf" width = "88.000mm" height = "74.839mm" ver = "01" gw = "182" gh = "196"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga la base del lavafaros (1) y, a continuación, la boquilla del lavafaros (2).
</ptxt>
<figure>
<graphic graphicname = "IBP70A940004.swf" width = "88.000mm" height = "74.838mm" ver = "01" gw = "187" gh = "196"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9406005002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
