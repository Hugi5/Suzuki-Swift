<title>
Sustitución del sello de aceite lateral del diferencial
</title>
<s1>
<ptxt>
Eleve el vehículo y drene el líquido de CVT. 
<intxreftitleoff1 refid = "ASPBP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las piezas siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Conjunto del eje impulsor delantero: 
<intxreftitleoff1 refid = "ASPBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Eje impulsor intermedio: 
<intxreftitleoff1 refid = "ASPBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga el sello (1) de aceite del lateral del diferencial con la herramienta especial.
</ptxt>
<servicetool>
<servicetoolitem id = "L5E009">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
