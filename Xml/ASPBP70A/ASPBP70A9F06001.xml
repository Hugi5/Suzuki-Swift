<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A9F06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la unidad de sonido
</title>
<servinfosub id = "ASPBP70A9F06001001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la rejilla de ventilación central. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Retire los 2 tornillos de montaje (2) para extraer la unidad de sonido (1) del panel de instrumentos.
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte los conectores de la unidad de sonido.
</ptxt>
<figure>
<graphic graphicname = "IBP60B9F0003.jpg" width = "88.000mm" height = "63.065mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9F06001002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
