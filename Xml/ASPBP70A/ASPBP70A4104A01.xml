<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A4104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Fuerza de frenado insuficiente
</title>
<diag type = "condition">
<condition>
<ptxt>
Fuerza de frenado insuficiente
</ptxt>
</condition>
<ps>
<ptxt>
Fuga de líquido de frenos de las tuberías de los frenos
</ptxt>
</ps>
<action>
<ptxt>
Localice el punto de fuga y repárelo.
</ptxt>
</action>
<ps>
<ptxt>
Disco de freno o pastillas manchados de líquido, grasa o cualquier otro tipo de aceite
</ptxt>
</ps>
<action>
<ptxt>
Limpie o reemplace.
</ptxt>
</action>
<ps>
<ptxt>
Recalentamiento de los frenos
</ptxt>
</ps>
<action>
<ptxt>
Determine la causa y repare.
</ptxt>
</action>
<ps>
<ptxt>
Pastilla de freno considerablemente desgastada
</ptxt>
</ps>
<action>
<ptxt>
Reemplace.
</ptxt>
</action>
<ps>
<ptxt>
Anomalía en el conjunto de pinza del freno
</ptxt>
</ps>
<action>
<ptxt>
Repare o reemplace.
</ptxt>
</action>
<ps>
<ptxt>
Presencia de aire en el sistema
</ptxt>
</ps>
<action>
<ptxt>
Purgue el aire del sistema de frenos.
</ptxt>
</action>
<ps>
<ptxt>
Fallo interno del servofreno
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el servofreno.
</ptxt>
</action>
<ps>
<ptxt>
La presión negativa del servofreno es inadecuada
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el estado del motor y la manguera de vacío.
</ptxt>
</action>
<ps>
<ptxt>
Avería en el funcionamiento del ESP<sup>&#174;</sup>
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el sistema y proceda a la sustitución si fuera necesario.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
