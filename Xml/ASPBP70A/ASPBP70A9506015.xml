<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A9506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del conjunto del regulador de la luneta
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A9506012">Componentes de la puerta trasera</intxrefpoff>
</ptxt>
<servinfosub id = "ASPBP70A9506015001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el cristal de la puerta trasera. 
<intxreftitleoff1 refid = "ASPBP70A9506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del motor de la ventanilla eléctrica.
</ptxt>
</s1>
<s1>
<ptxt>
Quite los pernos (2) del regulador de la ventanilla y extraiga el conjunto del regulador de la luneta (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950048.jpg" width = "88.000mm" height = "61.700mm" ver = "02" gw = "217" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9506015002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A9506016">Inspección del conjunto del regulador de la luneta</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Aplique grasa a las partes deslizantes del conjunto del regulador de la luneta.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E002" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Grasa
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Apriete los pernos del regulador de la luneta en orden (de &#34;1&#34; a &#34;4&#34;) al par de apriete especificado.
</ptxt>
<torque>
<torqueitem id = "T9E006">
<t-part>
Perno del regulador de la luneta*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,86
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950049.jpg" width = "88.000mm" height = "63.881mm" ver = "01" gw = "225" gh = "165"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
