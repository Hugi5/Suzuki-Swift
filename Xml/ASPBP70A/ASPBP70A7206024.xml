<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A7206024" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del actuador de control del flujo de aire
</title>
<servinfosub id = "ASPBP70A7206024001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desactive el sistema de airbag. 
<intxreftitleoff1 refid = "ASPBP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Para LHD, extraiga las siguientes piezas.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Cubierta del orificio de la columna de dirección: 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Módulo (inflador) del airbag de rodillas (si el vehículo dispone de ello): 
<intxreftitleoff1 refid = "ASPBP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Columna de dirección: 
<intxreftitleoff1 refid = "ASPBP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Conjunto del pedal del freno: 
<intxreftitleoff1 refid = "ASPBP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Para RHD, extraiga las siguientes piezas.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Guantera: 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Conducto de aire para pies (2)
</ptxt>
<figure>
<graphic graphicname = "IBP70A720011.jpg" width = "88.000mm" height = "93.954mm" ver = "01" gw = "182" gh = "250"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Tornillo
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Desconecte el conector del actuador de flujo de aire (1).
</ptxt>
</s1>
<s1>
<ptxt>
Retire los tornillos (2) y, a continuación, extraiga el actuador de control de flujo de aire (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A720013.jpg" width = "88.000mm" height = "63.066mm" ver = "02" gw = "185" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A7206024002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A7206025">Inspección del actuador de control del flujo de aire</intxrefpoff>
</ptxt>
<ptxt>
Para la instalación, invierta el procedimiento anterior de desmontaje, teniendo en consideración los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Introduzca el pasador de la articulación (2) en el orificio (1) del brazo del actuador de control de flujo de aire.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722012.swf" width = "88.000mm" height = "68.493mm" ver = "02" gw = "234" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
