<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A7204A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
No sale aire frío o hay una refrigeración insuficiente (funcionamiento normal del compresor del A/C)
</title>
<diag type = "condition">
<condition>
<ptxt>
No sale aire frío o hay una refrigeración insuficiente (funcionamiento normal del compresor del A/C)
</ptxt>
</condition>
<ps>
<ptxt>
Carga de refrigerante insuficiente o excesiva
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la cantidad de refrigerante y si hay fugas en el sistema.
</ptxt>
</action>
<ps>
<ptxt>
Condensador obstruido
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el condensador. 
<intxreftitleoff1 refid = "ASPBP70A7206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Evaporador obstruido o congelado
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Inspeccione el evaporador. 
<intxreftitleoff1 refid = "ASPBP70A7206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Sensor de temperatura del evaporador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el sensor de temperatura del evaporador. 
<intxreftitleoff1 refid = "ASPBP70A7206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Válvula de expansión, defectuosa
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione la válvula de expansión. 
<intxreftitleoff1 refid = "ASPBP70A7206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deshidratante obstruido
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el desecante y el tapón con filtro.
</ptxt>
</action>
<ps>
<ptxt>
Correa de transmisión del compresor floja o rota
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la correa de transmisión del compresor. 
<intxreftitleoff1 refid = "ASPBP70A7206041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Embrague magnético defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el embrague magnético. 
<intxreftitleoff1 refid = "ASPBP70A7206045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compresor del A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el compresor del A/C.
</ptxt>
</action>
<ps>
<ptxt>
Aire en el sistema de A/C
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el condensador y realice la evacuación y la carga. 
<intxreftitleoff1 refid = "ASPBP70A7206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fuga de aire en la unidad de HVAC o en el conducto de aire
</ptxt>
</ps>
<action>
<ptxt>
Repare el conducto de aire o la unidad de HVAC.
</ptxt>
</action>
<ps>
<ptxt>
Sistema de calefacción y ventilación defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione la de unidad HVAC.
</ptxt>
</action>
<ps>
<ptxt>
Módulo de control HVAC defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el módulo de control HVAC. 
<intxreftitleoff1 refid = "ASPBP70A7204035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Actuador de control de temperatura defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el actuador del control de temperatura. 
<intxreftitleoff1 refid = "ASPBP70A7206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motor del soplador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el motor del soplador. 
<intxreftitleoff1 refid = "ASPBP70A7206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Demasiado aceite del compresor en el sistema de A/C
</ptxt>
</ps>
<action>
<ptxt>
Drene el exceso de aceite del compresor en el circuito del sistema del A/C y el compresor del A/C.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
