<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A5204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Los engranajes se deslizan y desengranan
</title>
<diag type = "condition">
<condition>
<ptxt>
Los engranajes se deslizan y desengranan
</ptxt>
</condition>
<ps>
<ptxt>
Eje de cambio desgastado
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el eje de cambio. 
<intxreftitleoff1 refid = "ASPBP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Manguito del sincronizador u horquilla del cambio desgastados
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sustituya la horquilla de cambio o el manguito del sincronizador.
</ptxt>
<ptxt>
Horquilla de cambio: 
<intxreftitleoff1 refid = "ASPBP70A5206026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Eje de entrada: 
<intxreftitleoff1 refid = "ASPBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Contraeje: 
<intxreftitleoff1 refid = "ASPBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Muelle de posicionamiento de engranaje debilitado o dañado
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el muelle de posicionamiento de engranaje. 
<intxreftitleoff1 refid = "ASPBP70A5206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cojinetes del eje de entrada o el contraeje desgastados
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Reemplace el cojinete del eje de entrada o el cojinete del contraeje.
</ptxt>
<ptxt>
Cojinete del eje de entrada: 
<intxreftitleoff1 refid = "ASPBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Cojinete del contraeje: 
<intxreftitleoff1 refid = "ASPBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Diente biselado del manguito y del engranaje desgastado
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Reemplace el manguito de sincronizador y el engranaje.
</ptxt>
<ptxt>
Eje de entrada: 
<intxreftitleoff1 refid = "ASPBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Contraeje: 
<intxreftitleoff1 refid = "ASPBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
