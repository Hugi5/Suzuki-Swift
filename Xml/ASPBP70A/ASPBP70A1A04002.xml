<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A1A04002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Diagnóstico de síntomas del generador
</title>
<ptxt>
Los problemas en el sistema de carga se manifestarán a través de una o varias de las situaciones siguientes: 
</ptxt>
<servinfosub id = "ASPBP70A1A04002001" page = "1">
<title>
Funcionamiento de la luz de advertencia de carga
</title>
<diag type = "condition" id = "ASPBP70A1A04002002">
<condition>
<ptxt>
La luz de advertencia de carga no se enciende cuando el interruptor de encendido está en posición ON y el motor está apagado
</ptxt>
</condition>
<ps>
<ptxt>
Fusible fundido
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el fusible.
</ptxt>
</action>
<ps>
<ptxt>
Juego de instrumentos defectuoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sustituya el juego de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM defectuoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Revise el BCM. 
<intxreftitleoff1 refid = "ASPBP70AA204022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Línea de comunicación CAN defectuosa
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya la línea de comunicación CAN. 
<intxreftitleoff1 refid = "ASPBP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el cableado.
</ptxt>
</action>
<ps>
<ptxt>
Regulador de IC o bobina de campo defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el generador. 
<intxreftitleoff1 refid = "ASPBP70A1A06007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
La luz de advertencia de carga no se apaga cuando el motor está funcionando (la batería requiere recargas frecuentes)
</ptxt>
</condition>
<ps>
<ptxt>
Correa de transmisión suelta o desgastada
</ptxt>
</ps>
<action>
<ptxt>
Ajuste o sustituya la correa de transmisión. 
<intxreftitleoff1 refid = "ASPBP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Juego de instrumentos defectuoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sustituya el juego de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM defectuoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Revise el BCM. 
<intxreftitleoff1 refid = "ASPBP70AA204022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Regulador de IC o generador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el generador. 
<intxreftitleoff1 refid = "ASPBP70A1A06007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el cableado.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASPBP70A1A04002003">
<title>
Fallo de la carga de la batería
</title>
<diag type = "condition" id = "ASPBP70A1A04002004">
<condition>
<ptxt>
Batería descargada
</ptxt>
</condition>
<ps>
<ptxt>
Correa de transmisión suelta o desgastada
</ptxt>
</ps>
<action>
<ptxt>
Ajuste o sustituya la correa de transmisión. 
<intxreftitleoff1 refid = "ASPBP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Terminal de batería flojo o corroído
</ptxt>
</ps>
<action>
<ptxt>
Apriete el terminal de la batería o sustituya la batería. 
<intxreftitleoff1 refid = "ASPBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rectificador, rotor y/o regulador de IC defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el generador. 
<intxreftitleoff1 refid = "ASPBP70A1A06007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Batería cargada excesivamente
</ptxt>
</condition>
<ps>
<ptxt>
Regulador de IC defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el generador. 
<intxreftitleoff1 refid = "ASPBP70A1A06007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASPBP70A1A04002005">
<title>
Ruido
</title>
<diag type = "condition" id = "ASPBP70A1A04002006">
<condition>
<ptxt>
Generador ruidoso.
</ptxt>
</condition>
<ps>
<ptxt>
Pernos de montaje flojos
</ptxt>
</ps>
<action>
<ptxt>
Apriete los pernos de montaje. 
<intxreftitleoff1 refid = "ASPBP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cojinetes sucios, desgastados y/o defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el generador. 
<intxreftitleoff1 refid = "ASPBP70A1A06007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rotor, diodo y/o estátor defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el generador. 
<intxreftitleoff1 refid = "ASPBP70A1A06007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
