<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A7204A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
No sale aire frío (el sistema de A/C no funciona)
</title>
<diag type = "condition">
<condition>
<ptxt>
No sale aire frío (el sistema de A/C no funciona)
</ptxt>
</condition>
<ps>
<ptxt>
No hay refrigerante
</ptxt>
</ps>
<action>
<ptxt>
Efectúe la recuperación, vaciado y carga. 
<intxreftitleoff1 refid = "ASPBP70A7206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fusible fundido
</ptxt>
</ps>
<action>
<ptxt>
Verifique si hay cortocircuito a masa en los fusibles relacionados.
</ptxt>
</action>
<ps>
<ptxt>
Interruptor de A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el interruptor de A/C. 
<intxreftitleoff1 refid = "ASPBP70A7204035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensor de temperatura del evaporador defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el sensor de temperatura del evaporador. 
<intxreftitleoff1 refid = "ASPBP70A7206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensor de presión del refrigerante del A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Examine el sensor de presión del refrigerante del A/C. 
<intxreftitleoff1 refid = "ASPBP70A7206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado.
</ptxt>
</action>
<ps>
<ptxt>
Termostato defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el termostato. 
<intxreftitleoff1 refid = "ASPBP70A1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ECM defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el ECM. 
<intxreftitleoff1 refid = "ASPBP70A7204036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Módulo de control HVAC defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el módulo de control HVAC. 
<intxreftitleoff1 refid = "ASPBP70A7204035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Embrague magnético defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el embrague magnético. 
<intxreftitleoff1 refid = "ASPBP70A7206045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Correa de transmisión del compresor floja o rota
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la correa de transmisión del compresor. 
<intxreftitleoff1 refid = "ASPBP70A7206041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compresor del A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el compresor del A/C.
</ptxt>
</action>
<ps>
<ptxt>
Relé del compresor del A/C defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el relé del compresor del A/C. 
<intxreftitleoff1 refid = "ASPBP70A7206040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
BCM defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Revise el BCM. 
<intxreftitleoff1 refid = "ASPBP70AA204022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Panel del A/C automático defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el panel del A/C automático. 
<intxreftitleoff1 refid = "ASPBP70A7204034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
