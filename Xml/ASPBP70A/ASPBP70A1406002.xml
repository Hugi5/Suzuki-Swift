<servinfo servinfosgmlid = "ASPBP70A1406002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del filtro del depurador de aire
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A1406001">Componentes del depurador de aire</intxrefpoff>
</ptxt>
<servinfosub id = "ASPBP70A1406002001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el conjunto del depurador de aire. 
<intxreftitleoff1 refid = "ASPBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desenganche las abrazaderas (2) de la caja (1) del depurador de aire y ábrala.
</ptxt>
<figure>
<graphic graphicname = "I8RW0A140006.jpg" width = "88.000mm" height = "36.642mm" ver = "02" gw = "210" gh = "87"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el filtro del depurador de aire de la caja.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A1406002002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A1406003">Inspección y limpieza del filtro del depurador de aire</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
