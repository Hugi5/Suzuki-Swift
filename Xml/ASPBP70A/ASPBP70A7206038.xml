<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A7206038" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del filtro de aire de HVAC
</title>
<servinfosub id = "ASPBP70A7206038001">
<title>
Extracción
</title>
<s1>
<ptxt>
Saque la guantera. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Retire la tapa del filtro de aire de HVAC (2) de la unidad de HVAC.
</ptxt>
</s1>
<s1>
<ptxt>
Retire el filtro del aire (1) de la unidad de HVAC.
</ptxt>
<figure>
<graphic graphicname = "IBP70A720015.swf" width = "88.000mm" height = "59.699mm" ver = "01" gw = "223" gh = "153"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASPBP70A7206038002">
<title>
Instalación
</title>
<ptxt>
Para la instalación, invierta el procedimiento anterior de extracción, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Coloque el filtro de aire (1) con la marca de la flecha (2) apuntando hacia arriba.
</ptxt>
<figure>
<graphic graphicname = "IBP70A720016.swf" width = "88.000mm" height = "58.839mm" ver = "01" gw = "190" gh = "150"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
