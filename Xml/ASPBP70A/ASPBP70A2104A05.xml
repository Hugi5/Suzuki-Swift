<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A2104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ruido anormal, extremo delantero
</title>
<diag type = "condition">
<condition>
<ptxt>
Ruido anormal, extremo delantero
</ptxt>
</condition>
<ps>
<ptxt>
Conjunto o soportes del puntal delantero (amortiguador) dañados
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el conjunto (amortiguador) o los soportes del puntal delantero. 
<intxreftitleoff1 refid = "ASPBP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Extremos de la barra de acoplamiento desgastados, agarrotados o flojos
</ptxt>
</ps>
<action>
<ptxt>
Reemplace los extremos de la barra de acoplamiento. 
<intxreftitleoff1 refid = "ASPBP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Juntas del brazo de la suspensión desgastadas o dañadas
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el brazo de la suspensión. 
<intxreftitleoff1 refid = "ASPBP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Juntas esféricas de la barra de acoplamiento desgastadas, agarrotadas o flojas
</ptxt>
</ps>
<action>
<ptxt>
Reemplace la barra de acoplamiento. 
<intxreftitleoff1 refid = "ASPBP70A6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Juntas del eje impulsor desgastadas, agarrotadas o flojas
</ptxt>
</ps>
<action>
<ptxt>
Sustituya las juntas del eje impulsor. 
<intxreftitleoff1 refid = "ASPBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Casquillos delanteros del brazo de suspensión desgastados
</ptxt>
</ps>
<action>
<ptxt>
Sustituya los casquillos delanteros del brazo de suspensión. 
<intxreftitleoff1 refid = "ASPBP70A2206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Casquillos traseros del brazo de suspensión desgastados
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el brazo de la suspensión. 
<intxreftitleoff1 refid = "ASPBP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Barra estabilizadora floja
</ptxt>
</ps>
<action>
<ptxt>
Apriete los pernos o las tuercas y/o reemplace los casquillos. 
<intxreftitleoff1 refid = "ASPBP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Tuercas de la rueda flojas
</ptxt>
</ps>
<action>
<ptxt>
Apriete las tuercas de la rueda. 
<intxreftitleoff1 refid = "ASPBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pernos o tuercas de la suspensión flojos
</ptxt>
</ps>
<action>
<ptxt>
Apriete los pernos o las tuercas de la suspensión 
<intxreftitleoff1 refid = "ASPBP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cojinetes de rueda rotos o dañados
</ptxt>
</ps>
<action>
<ptxt>
Reemplace los cojinetes de rueda. 
<intxreftitleoff1 refid = "ASPBP70A3116009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Muelles helicoidales rotos
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Reemplace los muelles helicoidales.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Parte delantera: 
<intxreftitleoff1 refid = "ASPBP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Parte trasera: 
<intxreftitleoff1 refid = "ASPBP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Cojinetes del montante desgastados o mal lubricados
</ptxt>
</ps>
<action>
<ptxt>
Sustituya los cojinetes del puntal. 
<intxreftitleoff1 refid = "ASPBP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Avería en el sistema de servodirección
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione y corrija la avería. 
<intxreftitleoff1 refid = "ASPBP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
