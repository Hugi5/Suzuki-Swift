<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A9404A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Averías del limpiaparabrisas
</title>
<servinfosub id = "ASPBP70A9404003001">
<title>
Limpiaparabrisas y lavaparabrisas
</title>
<diag type = "condition">
<condition>
<ptxt>
Averías del limpiaparabrisas
</ptxt>
</condition>
<ps>
<ptxt>
Fusible fundido
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el fusible y verifique si se ha producido un cortocircuito.
</ptxt>
</action>
<ps>
<ptxt>
Motor de limpiaparabrisas defectuoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASPBP70A9406007">Inspección del funcionamiento del motor del limpiaparabrisas</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Interruptor de limpiaparabrisas y lavaparabrisas defectuoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASPBP70A9406013">Inspección del interruptor del lavaparabrisas y limpiaparabrisas</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
