<title>
DTC C1111 / C1113 / C1115 / C1116
</title>
<servinfosub id = "ASPBP70A6304012001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
