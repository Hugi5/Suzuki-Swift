<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Sustitución del sello de aceite lateral del diferencial
</title>
<s1>
<ptxt>
Levante el vehículo y drene el aceite del transeje. 
<intxreftitleoff1 refid = "ASPBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las piezas siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Conjunto del eje impulsor delantero: 
<intxreftitleoff1 refid = "ASPBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Conjunto del eje impulsor intermedio: 
<intxreftitleoff1 refid = "ASPBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga el sello (1) de aceite con la herramienta especial.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A520006.swf" width = "88.000mm" height = "48.410mm" ver = "02" gw = "146" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Coloque un sello de aceite (1) nuevo en la ubicación especificada con la herramienta especial.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Cuando instale el sello de aceite, posicione hacia el interior el muelle.
</ptxt>
</item>
<item>
<ptxt>
Coloque el sello de aceite exactamente en la altura especificada.
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
09944-88220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09944-66010">
09944-66010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B004">
<s-part>
(C)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Distancia de la superficie de la caja al sello de aceite izquierdo
</title>
<ptxt>
&#34;a&#34;: 1,0 – 2,0 mm (0,04 – 0,07 in.)
</ptxt>
</spec>
<spec>
<title>
Distancia de la superficie de la caja al sello de aceite derecho
</title>
<ptxt>
&#34;b&#34;: 8,5 – 9,5 mm (0,34 – 0,37 in.)
</ptxt>
</spec>
</s1>
<c-change/>
<s1>
<ptxt>
Aplique grasa al borde del sello de aceite y, al mismo tiempo, compruebe la suavidad de la zona donde el eje impulsor entra en contacto con el sello de aceite.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B001" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasa
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IBP60B520005.swf" width = "88.000mm" height = "51.231mm" ver = "01" gw = "219" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Coloque las piezas siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Eje propulsor delantero: 
<intxreftitleoff1 refid = "ASPBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Eje impulsor intermedio: 
<intxreftitleoff1 refid = "ASPBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Llene con aceite del transeje. 
<intxreftitleoff1 refid = "ASPBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
