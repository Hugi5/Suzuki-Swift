<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A1606004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Drenaje del sistema de refrigeración
</title>
<ptxt>
Antes de llevar a cabo el procedimiento siguiente, tenga en cuenta lo especificado en 
<intxref refid = "ASPBP70A1600001">Medidas de precaución para el sistema de refrigeración</intxref>
.
</ptxt>
<s1>
<ptxt>
Extraiga la tapa del radiador.
</ptxt>
</s1>
<s1>
<ptxt>
Introduzca la manguera (1) en los orificios de servicio (2).
</ptxt>
<attention3>
<ptxt>
Coloque la manguera en el orificio de servicio como se especifica a continuación.
</ptxt>
<figure>
<graphic graphicname = "IBP60B160005.swf" width = "88.000mm" height = "25.884mm" ver = "02" gw = "171" gh = "57"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.069in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
Diámetro exterior &#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
16 mm (0,63 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
Diámetro interior &#34;b&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
12 – 14 mm (0,48 – 0,55 in,) 
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
Longitud &#34;c&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Más de 150 mm (5,91 in,)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</attention3>
</s1>
<s1>
<ptxt>
Vacíe el refrigerante con el tapón de drenaje del radiador (3).
</ptxt>
</s1>
<s1>
<ptxt>
Después de vaciar el refrigerante, apriete firmemente el tapón de drenaje.
</ptxt>
<figure>
<graphic graphicname = "IBP60B160006.jpg" width = "88.000mm" height = "60.877mm" ver = "01" gw = "195" gh = "156"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
