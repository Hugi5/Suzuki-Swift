<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A9204015" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1967
</title>
<servinfosub id = "ASPBP70A9204015001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.193in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.012in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1967: Falta de ajuste inicial del sensor de altura 
</emph>
</ptxt>
<ptxt>
No se completó el ajuste inicial del sensor de altura trasera del vehículo.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
No se completó el ajuste inicial del sensor de altura trasera del vehículo
</ptxt>
</item>
<item>
<ptxt>
Sensor de altura trasera del vehículo
</ptxt>
</item>
<item>
<ptxt>
Módulo de control de la nivelación automática de los faros y del lavafaros
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPBP70A9204015002">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9204015003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70A9204015004">
<testgroup id = "ASPBP70A9204015005">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Compruebe el DTC.
</ptxt>
</test1>
<question>
¿Aparece algún otro DTC además del B1967?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización de averías del DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A9204015006">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPBP70A9204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el encendido (posición OFF).
</ptxt>
</test1>
<test1>
<ptxt>
Realice el &#34;Procedimiento de confirmación del DTC&#34; y vuelva a verificarlo. 
<intxreftitleoff1 refid = "ASPBP70A9204002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1967?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problema intermitente.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A9204015007">
<title>
Inicialización del sistema de nivelación automática de los faros
</title>
<test1>
<ptxt>
Inicialice el sistema de nivelación automática de los faros. 
<intxreftitleoff1 refid = "ASPBP70A9206018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPBP70A9204002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1967?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control de la nivelación automática de los faros y del lavafaros y vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPBP70A9206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (no se completó el ajuste inicial del sensor de altura trasera del vehículo)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
