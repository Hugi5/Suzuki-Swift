<servinfosub id = "ASPBP70A9406013002">
<title>
Circuito de relé de intermitencia del limpiaparabrisas
</title>
<s1>
<ptxt>
Coloque el interruptor del limpiaparabrisas en la posición &#34;INT&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Conecte el terminal positivo (+) de la batería al terminal &#34;8&#34; y su terminal negativo (–) al terminal &#34;5&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Conecte el cable positivo del voltímetro al terminal &#34;7&#34; y su cable negativo al terminal &#34;5&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Compruebe que el voltímetro indica la tensión de la batería (10 – 14 V).
</ptxt>
</s1>
<s1>
<ptxt>
Conecte el terminal &#34;6&#34; y el terminal &#34;8&#34; mediante un cable de acoplamiento.
</ptxt>
<figure>
<graphic graphicname = "IAP70B940012.swf" width = "88.000mm" height = "96.704mm" ver = "01" gw = "182" gh = "258"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.502in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.250in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Modelos con volante a la derecha con luz antiniebla trasera y volante a la izquierda
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
