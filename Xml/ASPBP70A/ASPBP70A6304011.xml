<diag type = "test" id = "ASPBP70A6304011003">
<testgroup id = "ASPBP70A6304011004">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Arranque el motor y vuelva a realizar la comprobación de DTC del módulo de control de P/S.
</ptxt>
</test1>
<question>
¿Aparece algún DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Efectúe 
<intxref refid = "ASPBP70A6304003">Comprobación del DTC</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A6304011005">
<title>
Inspección del juego de instrumentos
</title>
<test1>
<ptxt>
Sustituya el juego de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</test1>
<question>
¿Permanece encendida la luz de advertencia de P/S?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control de P/S y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPBP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección.
</ptxt>
</action>
</testgroup>
