<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A5304A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vibración del embrague
</title>
<diag type = "condition">
<condition>
<ptxt>
Vibración del embrague
</ptxt>
</condition>
<ps>
<ptxt>
Forros del disco de embrague cristalizados
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el disco del embrague. 
<intxreftitleoff1 refid = "ASPBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Forros del disco de embrague aceitosos.
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
El cojinete de desembrague no se desliza con suavidad
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el conjunto del cilindro de accionamiento del embrague. 
<intxreftitleoff1 refid = "ASPBP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disco del embrague suelto o mal contacto de la superficie
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Muelles de torsión debilitados en el disco de embrague
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Remaches del disco de embrague sueltos
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Superficie de la placa de presión o del volante deformada
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Reemplace la tapa del embrague o el volante.
</ptxt>
<ptxt>
- Cubierta del embrague: 
<intxreftitleoff1 refid = "ASPBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Volante: 
<intxreftitleoff1 refid = "ASPBP70A1406019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Soporte del motor debilitado o pernos / tuercas de montaje del motor flojos
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el montaje del motor o vuelva a apretar los pernos y tuercas del montaje del motor. 
<intxreftitleoff1 refid = "ASPBP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
