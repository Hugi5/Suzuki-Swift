<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A1606015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la bomba de agua
</title>
<servinfosub id = "ASPBP70A1606015001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Drene el refrigerante. 
<intxreftitleoff1 refid = "ASPBP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la correa de transmisión del generador y de la bomba de agua. 
<intxreftitleoff1 refid = "ASPBP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desmonte la polea de la bomba de agua (1).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto de la bomba de agua (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B160011.jpg" width = "88.000mm" height = "56.565mm" ver = "01" gw = "212" gh = "144"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASPBP70A1606015002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A1606016">Inspección de la bomba de agua</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Aplique sellador a la superficie de contacto de la bomba de agua (1), tal como se indica en la ilustración.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1F001" uid = "41">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Producto de sellado
</m-desc>
<m-number>
99000-31250
</m-number>
<m-name>
SUZUKI Bond n°1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I3RM0A160016.swf" width = "88.000mm" height = "44.566mm" ver = "01" gw = "182" gh = "109"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.309in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.250in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.387in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
3 mm (0,12 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;b&#34;: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
2 mm (0,08 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Instale el conjunto de la bomba de agua (1) en el bloque de cilindros y apriete los pernos y las tuercas al par especificado.
</ptxt>
<torque>
<torqueitem id = "T1F003">
<t-part>
Perno de la bomba de agua
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1F004">
<t-part>
Tuerca de la bomba de agua
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Instale la polea de la bomba de agua (2) y apriete los pernos al par especificado.
</ptxt>
<torque>
<torqueitem id = "T1F005">
<t-part>
Perno de la polea de la bomba de agua
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B160012.jpg" width = "88.000mm" height = "57.077mm" ver = "01" gw = "230" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Instale la correa de transmisión del generador y de la bomba de agua. 
<intxreftitleoff1 refid = "ASPBP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Conecte el cable negativo (–) a la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Rellene el sistema de refrigeración con refrigerante. 
<intxreftitleoff1 refid = "ASPBP70A1606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verifique si el sistema de refrigeración tiene fugas. 
<intxreftitleoff1 refid = "ASPBP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
