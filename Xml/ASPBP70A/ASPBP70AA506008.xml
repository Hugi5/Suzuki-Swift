<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70AA506008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la antena interior intermedia
</title>
<servinfosub id = "ASPBP70AA506008001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la caja de la consola trasera del piso. 
<intxreftitleoff1 refid = "ASPBP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) y, a continuación, extraiga la antena interior intermedia (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50026.swf" width = "88.000mm" height = "59.622mm" ver = "01" gw = "196" gh = "153"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70AA506008002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70AA506011">Inspección de la antena</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
