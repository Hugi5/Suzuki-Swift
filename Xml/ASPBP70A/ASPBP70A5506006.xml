<servinfo servinfosgmlid = "ASPBP70A5506006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del interruptor de la leva de cambio
</title>
<servinfosub id = "ASPBP70A5506006001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga el volante de dirección. 
<intxreftitleoff1 refid = "ASPBP70A6206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Quite los tornillos (1) y suelte las garras (2).
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte los conectores y, a continuación, extraiga los interruptores de la leva de cambio (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A550047.swf" width = "88.000mm" height = "90.764mm" ver = "02" gw = "235" gh = "241"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.396in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.413in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Leva de cambio del lado derecho &#34;+&#34;
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Leva de cambio del lado izquierdo &#34;–&#34;
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A5506006002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A5506007">Inspección del interruptor de la leva de cambio</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
