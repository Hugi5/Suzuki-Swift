<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A9F06008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del zócalo USB
</title>
<servinfosub id = "ASPBP70A9F06008001">
<title>
Extracción
</title>
<s1>
<ptxt>
Extraiga la caja de la consola central. 
<intxreftitleoff1 refid = "ASPBP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta lateral de la consola del suelo. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del zócalo USB (1) y, a continuación, extraiga el zócalo USB (2) del panel de instrumentos (3); para ello, desbloquee los mecanismos de bloqueo (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0014.jpg" width = "88.000mm" height = "55.000mm" ver = "02" gw = "206" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A9F06008002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A9F06009">Inspección del zócalo USB</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
