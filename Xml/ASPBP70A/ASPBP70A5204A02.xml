<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Dureza del cambio
</title>
<diag type = "condition">
<condition>
<ptxt>
Dureza del cambio
</ptxt>
</condition>
<ps>
<ptxt>
Lubricante insuficiente
</ptxt>
</ps>
<action>
<ptxt>
Añada aceite del transeje manual. 
<intxreftitleoff1 refid = "ASPBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Recorrido libre del pedal de embrague incorrecto
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sustituya el cilindro de accionamiento del embrague o el cilindro maestro
</ptxt>
<ptxt>
Cilindro de accionamiento del embrague: 
<intxreftitleoff1 refid = "ASPBP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Cilindro maestro del embrague: 
<intxreftitleoff1 refid = "ASPBP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Disco del embrague deformado o roto
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Plato de presión del embrague dañado
</ptxt>
</ps>
<action>
<ptxt>
Reemplace la tapa del embrague. 
<intxreftitleoff1 refid = "ASPBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Anillo del sincronizador desgastado
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sustituya el anillo del sincronizador.
</ptxt>
<ptxt>
Eje de entrada: 
<intxreftitleoff1 refid = "ASPBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Contraeje: 
<intxreftitleoff1 refid = "ASPBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Diente biselado del manguito o del engranaje desgastado
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Reemplace el manguito de sincronizador y el engranaje.
</ptxt>
<ptxt>
Eje de entrada: 
<intxreftitleoff1 refid = "ASPBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Contraeje: 
<intxreftitleoff1 refid = "ASPBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Casquillos de la palanca selectora desgastados
</ptxt>
</ps>
<action>
<ptxt>
Sustituya los casquillos de la palanca selectora. 
<intxreftitleoff1 refid = "ASPBP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Eje de cambio deformado
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el eje de cambio. 
<intxreftitleoff1 refid = "ASPBP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cables de control de cambio y selección de marchas rotos
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el cambio de engranaje y el cable de selección. 
<intxreftitleoff1 refid = "ASPBP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
