<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A1306008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del sensor ECT
</title>
<servinfosub id = "ASPBP70A1306008001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Drene el refrigerante. 
<intxreftitleoff1 refid = "ASPBP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del depurador de aire. 
<intxreftitleoff1 refid = "ASPBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del sensor ECT (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B130003.jpg" width = "88.000mm" height = "63.743mm" ver = "01" gw = "199" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el sensor ECT de la caja del termostato
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A1306008002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A1306009">Inspección del sensor ECT</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Limpie las superficies de contacto del sensor ECT y de la caja del termostato.
</ptxt>
</item>
<item>
<ptxt>
Asegúrese de que la junta tórica no ha sufrido daños y sustitúyala en caso necesario.
</ptxt>
</item>
<item>
<ptxt>
Apriete el sensor ECT (1) al par especificado.
</ptxt>
<torque>
<torqueitem id = "T1C004">
<t-part>
Sensor ECT
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B130004.jpg" width = "88.000mm" height = "63.743mm" ver = "01" gw = "199" gh = "164"/>
</figure>
</item>
<item>
<ptxt>
Conecte el conector al sensor ECT.
</ptxt>
</item>
<item>
<ptxt>
Rellene el sistema de refrigeración con refrigerante. 
<intxreftitleoff1 refid = "ASPBP70A1606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verifique si el sistema de refrigeración tiene fugas. 
<intxreftitleoff1 refid = "ASPBP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
