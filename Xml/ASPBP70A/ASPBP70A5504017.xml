<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A5504017" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
La luz de advertencia de la transmisión permanece encendida después de arrancar el motor
</title>
<servinfosub id = "ASPBP70A5504017001">
<title>
Localización y reparación de averías
</title>
<diag type = "test" id = "ASPBP70A5504017002">
<testgroup id = "ASPBP70A5504017003">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPBP70A5504011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Aparece algún DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Sustituya el juego de instrumentos por otro en buen estado y vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Si la luz de advertencia de la transmisión permanece encendida, sustituya el TCM por uno en buen estado y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
