<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A7206033" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del sensor de la temperatura interior
</title>
<servinfosub id = "ASPBP70A7206033001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta del orificio de la columna de dirección desde el panel de instrumentos. 
<intxreftitleoff1 refid = "ASPBP70AA206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Extraiga el conector (1) y la manguera de aspiración (2) del sensor de temperatura interior (3).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las pestañas (4) y, a continuación, extraiga el sensor de temperatura del aire interior (3) del panel de instrumentos.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723023.swf" width = "88.000mm" height = "65.896mm" ver = "01" gw = "232" gh = "170"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A7206033002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A7206034">Inspección del sensor de temperatura interior</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
