<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A6306013" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Inspección del motor de P/S
</title>
<s1>
<ptxt>
Con el encendido desconectado (posición OFF), desconecte el conector &#34;E12&#34; (1) del módulo de control de P/S.
</ptxt>
</s1>
<s1>
<ptxt>
Compruebe la resistencia entre los terminales &#34;1&#34; y &#34;2&#34; del conector &#34;E12&#34; (1).
</ptxt>
<ptxt>
Si el resultado de la comprobación no es el esperado, sustituya el conjunto de la columna de dirección.
</ptxt>
<spec>
<title>
Resistencia del circuito del motor
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.202in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.264in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Entre los terminales &#34;1&#34; y &#34;2&#34;
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Aproximadamente 1 &#937;
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</s1>
<s1>
<ptxt>
Compruebe la continuidad entre los terminales &#34;1&#34; del conector &#34;E12&#34; y la masa.
</ptxt>
<ptxt>
Si el resultado de la comprobación no es el esperado, sustituya el conjunto de la columna de dirección.
</ptxt>
<spec>
<title>
Resistencia del circuito del motor
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.254in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.221in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
&#34;1&#34; y la masa
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
No hay continuidad
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<figure>
<graphic graphicname = "I9P60A630036.swf" width = "88.000mm" height = "40.047mm" ver = "01" gw = "160" gh = "97"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.445in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Conector &#34;E12&#34; (vista: [a])
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Levante el vehículo.
</ptxt>
</s1>
<s1>
<ptxt>
Con el encendido desconectado (posición OFF), conecte el conector &#34;E12&#34; (1) al módulo de control de P/S (2).
</ptxt>
</s1>
<s1>
<ptxt>
Utilice un amperímetro (3) para comprobar que la corriente del motor de P/S con el motor al ralentí corresponda a lo indicado abajo. Si el resultado de la comprobación no es el esperado, inspeccione el módulo de control de P/S. 
<intxreftitleoff1 refid = "ASPBP70A6304022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Si el resultado de la comprobación es el esperado, sustituya el conjunto de la columna de dirección.
</ptxt>
<spec>
<title>
Corriente del motor con el vehículo elevado
</title>
<table frame = "all" colsep = "1" rowsep = "1" page = "2">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.708in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.863in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.934in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.960in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Estado
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Con el volante en posición recta: [A]
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Cuando el volante se gira a la izquierda o la derecha a una velocidad de giro de 90&#176; /seg.: [B]
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Cuando el volante se mantiene totalmente girado hacia la izquierda o la derecha hasta que se detiene: [C]
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Corriente del motor
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Aproximadamente 0 A
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Aprox.
</ptxt>
<ptxt>
3,0 a 4,2 A
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Aproximadamente 45 a 60 A
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<figure>
<graphic graphicname = "I8C50A630034.swf" width = "88.000mm" height = "87.925mm" ver = "01" gw = "192" gh = "233"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
