</s1>
<s1>
<ptxt>
Extraiga el cilindro maestro de freno del servofreno.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el anillo en O (2) del cilindro maestro de freno (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410022.swf" width = "88.000mm" height = "46.292mm" ver = "01" gw = "137" gh = "115"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A4106017002">
<title>
Instalación
</title>
<ptxt>
<intxrefpoff refid = "ASPBP70A4106019">Inspección del conjunto del cilindro maestro de freno</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Instale una nueva junta tórica (2) en el cilindro maestro de freno (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410026.swf" width = "88.000mm" height = "46.292mm" ver = "01" gw = "137" gh = "115"/>
</figure>
</s1>
<s1>
<ptxt>
Instale el cilindro maestro de freno en el servofreno.
</ptxt>
</s1>
<s1>
<ptxt>
Apriete las tuercas de fijación del cilindro maestro de freno al par especificado.
</ptxt>
<torque>
<torqueitem id = "T4A004">
<t-part>
Tuerca de fijación del cilindro maestro de freno
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
18
</t-value1>
<t-value2>
1,8
</t-value2>
<t-value3>
13,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Conecte los tubos del freno (1) al cilindro maestro de freno y apriete las tuercas abocinadas al par de apriete especificado empleando una herramienta especial.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A003">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T4A005">
<t-part>
Tuerca abocinada (M12) de tubo de freno
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
