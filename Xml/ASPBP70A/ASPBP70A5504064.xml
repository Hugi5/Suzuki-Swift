<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A5504064" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1708
</title>
<servinfosub id = "ASPBP70A5504064001">
<title>
Condición de detección del DTC y área afectada
</title>
<attention3>
<ptxt>
Al sustituir por el nuevo módulo de TCM, se detecta el DTC P1708.
</ptxt>
</attention3>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.762in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.431in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
P1708: Sensor de pendiente no aprendido 
</emph>
</ptxt>
<ptxt>
La inicialización del sensor de pendiente no se ha completado.
</ptxt>
<ptxt>
(Lógica de detección de 1 ciclos de conducción)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
La calibración del sensor de pendiente no se ha realizado.
</ptxt>
</item>
<item>
<ptxt>
TCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPBP70A5504064002">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A5504064003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70A5504064004">
<testgroup id = "ASPBP70A5504064005">
<question>
¿Se ha realizado la &#34;Inspección del sistema de la CVT&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPBP70A5504001">Inspección del sistema de la CVT</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A5504064006">
<title>
Verificación de DTC
</title>
<question>
¿Aparece otro DTC además del P1708?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A5504064007">
<title>
Calibración del sensor de pendiente
</title>
<test1>
<ptxt>
Realice 
<intxref refid = "ASPBP70A5506042">Calibración del sensor de pendiente</intxref>
 y, a continuación, borre el DTC P1708. 
<intxreftitleoff1 refid = "ASPBP70A5504012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Realice el procedimiento de confirmación del DTC y verifíquelo.
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC P1708?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el TCM por uno en buen estado y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
