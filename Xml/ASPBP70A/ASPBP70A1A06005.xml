<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPBP70A1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del generador
</title>
<servinfosub id = "ASPBP70A1A06005001">
<title>
Extracción
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta inferior del motor de la derecha.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el tubo n&#176; 2 de escape. 
<intxreftitleoff1 refid = "ASPBP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la correa de transmisión del generador y de la bomba de agua. 
<intxreftitleoff1 refid = "ASPBP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el cable del terminal &#34;B&#34; (1) y el conector (2) del generador (4).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el brazo de ajuste del alternador (3).
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los soportes del generador (5) y el generador al mismo tiempo.
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga del generador los soportes del generador.
</ptxt>
<figure>
<graphic graphicname = "IBP60B1A0002.jpg" width = "88.000mm" height = "77.525mm" ver = "02" gw = "229" gh = "203"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70A1A06005002">
<title>
Instalación
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete el perno del brazo de ajuste del generador, el perno del soporte del generador y la tuerca del terminal &#34;B&#34; al par especificado.
</ptxt>
<torque>
<torqueitem id = "T1J004">
<t-part>
Perno del brazo de ajuste del generador
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1J005">
<t-part>
Perno del soporte del generador
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1J006">
<t-part>
Tuerca del terminal &#34;B&#34;
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A1A0001.jpg" width = "88.000mm" height = "76.443mm" ver = "02" gw = "233" gh = "200"/>
</figure>
</item>
<item>
<ptxt>
Apriete el perno de pivote del generador de acuerdo con el procedimiento siguiente.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Mida la longitud (L) de la llave dinamométrica (1).
</ptxt>
</item>
<item>
<ptxt>
Calcule la lectura del valor de la llave dinamométrica (M) mediante la fórmula.
</ptxt>
<servicetool>
<servicetoolitem id = "L1J004">
<s-part>
(A)
</s-part>
<s-number num = "09911-78010">
09911-78010
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Fórmula para la lectura del valor de la llave dinamométrica.
</title>
<ptxt>
(M) = T x L ÷ (L + &#34;a&#34;)
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
(M): Valor de lectura utilizando la herramienta especial de prolongación
</ptxt>
</item>
<item>
<ptxt>
T (50 N&#183;m (5,1 kgf-m, 37,0 lbf-ft)): Par de apriete especificado
</ptxt>
</item>
<item>
<ptxt>
L: Longitud de la llave dinamométrica
</ptxt>
</item>
<item>
<ptxt>
&#34;a&#34; (0,05 m (1,96 in.)): Dimensiones de la herramienta especial
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IBP60B1A0006.swf" width = "88.000mm" height = "27.196mm" ver = "03" gw = "196" gh = "61"/>
</figure>
</spec>
</item>
<item>
<ptxt>
Apriete el perno de pivote del generador (1) al valor de lectura de la llave dinamométrica con una herramienta especial.
</ptxt>
<servicetool>
<servicetoolitem id = "L1J005">
<s-part>
(A)
</s-part>
<s-number num = "09911-78010">
09911-78010
</s-number>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T1J007">
<t-part>
Perno de pivote del generador
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B1A0007.swf" width = "88.000mm" height = "51.078mm" ver = "01" gw = "173" gh = "128"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Ajuste la tensión de la correa. 
<intxreftitleoff1 refid = "ASPBP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Apriete los pernos del tubo de escape n&#176; 2 al par especificado. 
<intxreftitleoff1 refid = "ASPBP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
