<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70AA204012" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1133
</title>
<servinfosub id = "ASPBP70AA204012001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.385in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.833in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1133: Tensión de la batería muy alta 
</emph>
</ptxt>
<ptxt>
La tensión del circuito de alimentación eléctrica de reserve procedente del fusible &#34;DOME&#34; es constantemente superior a 16,0 V durante el tiempo especificado.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Sistema de carga
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPBP70AA204012002">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Arranque el motor si es posible.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPBP70AA204012003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70AA204012004">
<testgroup id = "ASPBP70AA204012006">
<title>
Comprobación de parámetros
</title>
<test1>
<ptxt>
Conecte la herramienta de escaneado SUZUKI al DLC cuando el encendido esté desconectado (posición OFF).
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición ON).
</ptxt>
</test1>
<test1>
<ptxt>
Revise el elemento &#34;Tensión de Batería&#34; que aparece en la herramienta de escaneado SUZUKI. 
<intxreftitleoff1 refid = "ASPBP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está en buenas condiciones?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fin de la inspección. (Avería intermitente.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70AA204012005">
<title>
Inspección del sistema de carga
</title>
<test1>
<ptxt>
Inspeccione el sistema de carga. 
<intxreftitleoff1 refid = "ASPBP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está en buenas condiciones?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el BCM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPBP70AA206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare el sistema de carga.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
