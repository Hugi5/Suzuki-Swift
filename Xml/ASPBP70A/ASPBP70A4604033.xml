<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPBP70A4604033" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1074 / C1075
</title>
<servinfosub id = "ASPBP70A4604033001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1074: Calibración del sensor G 
</emph>
</ptxt>
<ptxt>
No se ha realizado la calibración del sensor giroscopio/sensor G.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
La calibración del conjunto del sensor G/sensor de régimen de guiñad no se ha completado
</ptxt>
</item>
<item>
<ptxt>
Módulo de control ESP<sup>&#174;</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1075: Calibración del sensor del ángulo de dirección 
</emph>
</ptxt>
<ptxt>
La calibración del sensor de ángulo de dirección no se ha completado.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Sensor del ángulo de dirección
</ptxt>
</item>
<item>
<ptxt>
La calibración del sensor del ángulo de dirección no se ha terminado
</ptxt>
</item>
<item>
<ptxt>
Módulo de control ESP<sup>&#174;</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPBP70A4604033002">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70A4604033003">
<testgroup id = "ASPBP70A4604033004">
<question>
¿Se ha llevado a cabo el procedimiento de &#34;Inspección del sistema ESP<sup>&#174;</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPBP70A4604001">Comprobación del sistema del ESP&#174;</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A4604033005">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPBP70A4604005">Comprobación del DTC</intxref>
.
</ptxt>
</test1>
<question>
¿Aparece algún otro DTC además del C1074 o C1075?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización de averías del DTC correspondiente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A4604033006">
<title>
Calibración del sensor
</title>
<test1>
<ptxt>
Calibre todos los sensores. 
<intxreftitleoff1 refid = "ASPBP70A4606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se completó la calibración del sensor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Reemplace el sensor del ángulo de la dirección. 
<intxreftitleoff1 refid = "ASPBP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A4604033007">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Borre todos los DTC y compruebe el DTC.
</ptxt>
</test1>
<question>
¿Se siguen detectando los DTC C1074 y/o C1075?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
DTC C1074: Sustituya el conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPBP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
DTC C1075: Sustituya el sensor del ángulo de dirección y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPBP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
