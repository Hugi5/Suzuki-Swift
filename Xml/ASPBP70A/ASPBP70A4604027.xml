<servinfosub id = "ASPBP70A4604027003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPBP70A4604027004">
<testgroup id = "ASPBP70A4604027005">
<question>
¿Se ha llevado a cabo el procedimiento de &#34;Inspección del sistema ESP<sup>&#174;</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPBP70A4604001">Comprobación del sistema del ESP&#174;</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPBP70A4604027006">
<title>
Comprobación de los circuitos de masa del módulo de control del ESP&#174; y de alimentación eléctrica de la válvula solenoide
</title>
<test1>
<ptxt>
Compruebe los circuitos de masa y alimentación eléctrica de la válvula solenoide según 
<intxref refid = "ASPBP70A4604039">Comprobación del circuito de masa y de alimentación eléctrica del módulo de control del ESP&#174;</intxref>
.
</ptxt>
</test1>
<question>
¿Son correctos los resultados de la comprobación?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPBP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso.
</ptxt>
</action>
</testgroup>
</diag>
