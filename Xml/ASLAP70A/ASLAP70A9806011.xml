<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9806011" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž horného obloženia
</title>
<servinfosub id = "ASLAP70A9806011001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Deaktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte slnečné clony (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte bodové svetlo (ak je vo výbave) (3) a vnútorné osvetlenie (2).
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Bodové svetlo (ak je nainštalované): 
<intxreftitleoff1 refid = "ASLAP70A9206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Osvetlenie interiéru vozidla: 
<intxreftitleoff1 refid = "ASLAP70A9206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Odmontujte nasledujúce obloženia. 
<intxreftitleoff1 refid = "ASLAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Obloženia predného stĺpika
</ptxt>
</item>
<item>
<ptxt>
Horné obloženia stredového stĺpika
</ptxt>
</item>
<item>
<ptxt>
Vnútorné horné obloženie zadnej časti
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Odmontujte pomocné úchyty (4).
</ptxt>
</s1>
<s1>
<ptxt>
Pre model so strešným oknom odmontujte obloženie strešného okna (5).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte svorky a vyberte obloženie nad dverami (6).
</ptxt>
<figure>
<graphic graphicname = "IAP70A980008.jpg" width = "183.000mm" height = "158.326mm" ver = "01" gw = "488" gh = "432"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.340in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.116in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.340in"/>
<colspec colnum = "4" colname = "4" colwidth = "2.142in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Bez strešného okna 
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
So strešným oknom 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9806011002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Aktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
