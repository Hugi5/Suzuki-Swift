<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6B">
<servcat sctnbr = "06" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A6206018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spínača zapaľovania (model so spínačom zapaľovania)
</title>
<servinfosub id = "ASLAP70A6206018001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte spodný a vrchný kryt stĺpika riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte, či ste vybrali kľúč zapaľovania.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte prípojku (1) od spínača zapaľovania (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky (4) a vyberte spínač zapaľovania (2) zo zariadenia zámky riadenia (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A620036.jpg" width = "88.000mm" height = "54.155mm" ver = "05" gw = "237" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A6206018002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A6206019">Kontrola spínača zapaľovania (model so zapaľovaním)</intxrefpoff>
</ptxt>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
