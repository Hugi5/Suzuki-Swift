<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Montáž a demontáž expanzného ventilu
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A7216007">Súčiastky jednotky HVAC:Manuálny typ</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A7216018001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Rekuperujte chladiacu kvapalinu z klimatizačného systému pomocou zariadenia na rekuperáciu a recykláciu podľa bodu „Rekuperácia“ v časti 
<intxref refid = "ASLAP70A7216007">Súčiastky jednotky HVAC:Manuálny typ</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite skrutku (1), potom odstráňte potrubie kvapaliny a nasávaciu hadicu z expanzného ventilu (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite skrutky (3) a odmontujte expanzný ventil.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A720028.swf" width = "88.000mm" height = "43.902mm" ver = "01" gw = "173" gh = "109"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7216018002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A7216019">Kontrola expanzného ventilu:Manuálny typ</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Naneste kompresorový olej na tesniaci krúžok expanzného ventila a trubiek.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B104" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Kompresorový olej
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Utiahnite skrutky expanzných ventilov na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T7B102">
<t-part>
Skrutka expanzného ventilu
</t-part>
<t-value1>
7,0
</t-value1>
<t-value2>
0,7
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Odčerpajte a naplňte systém klimatizácie „Vypúšťanie“ a „Plnenie v 
<intxref refid = "ASLAP70A7216001">Prevádzkový postup pre napĺňanie chladiacou kvapalinou:Manuálny typ</intxref>
 .
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
