<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A5306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž hlavného spojkového valca
</title>
<servinfosub id = "ASLAP70A5306011001">
<title>
Demontáž
</title>
<s1 page = "2">
<ptxt>
Vyčistite okolie uzáveru nádržky hlavného brzdového valca a z nádrže hlavného brzdového valca pomocou striekačky alebo podobne vytiahnite kvapalinu.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odpojte potrubie spojkovej kvapaliny od hlavného spojkového valca. 
<intxreftitleoff1 refid = "ASLAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odpojte hadicu nádržky spojky (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530007.swf" width = "88.000mm" height = "49.059mm" ver = "01" gw = "141" gh = "123"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Vyberte tlačnú tyč (1) od spojkového pedála (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte matice hlavného valca (3) a potom vyberte hlavný valec spojky (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530008.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A5306011002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A5306012">Kontrola hlavného spojkového valca</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Na koniec tlačnej tyče naneste vazelínu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Silicone Grease" id = "M5C001" uid = "21">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25100
</m-number>
<m-name>
SUZUKI Silicone Grease
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Matice hlavného valca spojky (1) dotiahnite na predpísaný moment.
</ptxt>
<torque>
<torqueitem id = "T5C004">
<t-part>
Matica hlavného valca spojky
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A531013.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
