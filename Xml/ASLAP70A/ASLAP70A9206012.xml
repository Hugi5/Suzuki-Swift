<servinfo servinfosgmlid = "ASLAP70A9206012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž svetla batožinového priestoru
</title>
<servinfosub id = "ASLAP70A9206012001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Vyberte svetlo osvetlenia batožinového priestoru (1) jeho ťahaním v smere šípky uvoľnením zámky (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte zo svetla batožinového priestoru jeho konektor.
</ptxt>
</s1>
<s1>
<ptxt>
Ak je to potrebné, vyberte žiarovku (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A920016.jpg" width = "88.000mm" height = "62.981mm" ver = "04" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9206012002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
