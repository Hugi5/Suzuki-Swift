<diag type = "test" id = "ASLAP70A6304021002">
<testgroup id = "ASLAP70A6304021003">
<title>
Skontrolujte poistku obvodu
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory “E13” a “G50”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom “G50”, a “E13”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte poistku “P/S” a “IG1 SIG”, či nie sú vypálené.
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte poistku(y) a skontrolujte, či obvody pripojené na poistku(y) nie sú skratované k uzemneniu.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304021004">
<title>
Kontrola hlavného napájania pre obvod riadiacej jednotky P/S
</title>
<test1>
<ptxt>
Skontrolujte napätie medzi konektorom &#34;E13-1&#34; a uzemnením.
</ptxt>
</test1>
<question>
Má napätie hodnotu 10 -14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Obvod “A1” je prerušený.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304021005">
<title>
Kontrola IG1 napájania pre obvod riadiacej jednotky P/S
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte napätie medzi konektorom &#34;G50-3&#34; a uzemnením.
</ptxt>
</test1>
<question>
Má napätie hodnotu 10 -14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Obvod “A2” je otvorený.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304021006">
<title>
Kontrola uzemnenia obvodu riadiacej jednotky P/S
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte odpor medzi konektorom &#34;E13-2&#34; a uzemnením.
</ptxt>
</test1>
<question>
Je odpor 1 &#937; alebo menej?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Obvod “A3” je prerušený alebo má príliš vysoký odpor.
</ptxt>
</action>
</testgroup>
</diag>
