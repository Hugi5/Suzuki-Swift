<servinfosub id = "ASLAP70AA504023003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Nstavte zapaľovanie na “ACC”.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Kroky 1) až 3) niekoľkokrát zopakujte.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA504023004">
<title>
Riešenie problémov DTC
</title>
<attention3>
<ptxt>
Toto DTC môže byť zistené keď je batéria vybitá, alebo je slabé napätie.
</ptxt>
</attention3>
<diag type = "test" id = "ASLAP70AA504023005">
<testgroup id = "ASLAP70AA504023012">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF (vyp.) a k prípojke na údajové spojenie pripojte skenovacie zariadenie SUZUKI.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte „Ignition 1 Relay“ zobrazenú na skenovacom zariadení SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504023006">
<title>
Kontrola obvodu napájania relé IG1 (strana spínača)
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Vyberte relé IG1.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, či je napätie medzi svorkou obvodu “A2” konektora relé IG1 a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok a poistku „IGN“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504023007">
<title>
Kontrola poistky
</title>
<test1>
<ptxt>
Skontrolujte poistku &#34;MTR&#34;.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504023008">
<title>
Kontrola obvodu signálu relé IG1
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svorky konektora “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor medzi obvodom „B2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B2“ a každou svorkou v konektore relé IG1: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte poistku &#34;MTR&#34; a riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok a potom vymeňte poistku „MTR“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504023009">
<title>
Kontrola obvodu signálu relé IG1
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svorky konektora “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „B2“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B2“ a každou svorkou v konektore relé IG1: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „B2“: 0 – 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504023010">
<title>
Kontrola obvodu napájania relé IG1 (strana cievky)
</title>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „C2“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
