<title>
Kontrola relé IG1
</title>
<test1>
<ptxt>
Skontrolujte relé IG1. 
<intxreftitleoff1 refid = "ASLAP70AA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
