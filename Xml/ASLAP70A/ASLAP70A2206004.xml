<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2B">
<servcat sctnbr = "02" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A2206004" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rozobratie a zloženie zariadenia prednej vzpery
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A2206003">Demontáž a montáž montážnej zostavy prednej vzpery</intxrefpoff>
</ptxt>
<attention1>
<ptxt>
Pri stlačení pružiny cievky dodržiavajte nasledovné body, aby ste sa vyhli poraneniu osôb.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zariadenie na stlačenie pružiny pripevnite k vinutej pružine poriadne.
</ptxt>
</item>
<item>
<ptxt>
Na jej stlačenie nepoužívajte nárazový skrutkovač.
</ptxt>
</item>
<item>
<ptxt>
Použite bežne dostupný nástroj na stlačenie pružiny a prísne dodržiavajte pokyny výrobcu.
</ptxt>
</item>
</list1>
</attention1>
<attention2>
<ptxt>
Dolná matica podpery vzpery je natretá stabilizátorom trenia. Maticu nepoužívajte opätovne, inak by sa mohla uvoľniť.
</ptxt>
</attention2>
<servinfosub id = "ASLAP70A2206004001">
<title>
Rozobratie
</title>
<s1>
<ptxt>
Na vinutú pružinu nasaďte špeciálny nástroj podľa obrázku. Striedavo zaskrutkujte skrutky špeciálnym nástrojom (1), až kým sa vo vzpere neuvoľní pružina cievky. Otočte vzperu, aby ste sa uistili, že je bez napnutia pružiny cievky.
</ptxt>
<servicetool>
<servicetoolitem id = "L2B001">
<s-part>
(A)
</s-part>
<s-number num = "09943-25010">
09943–25010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A220008.swf" width = "88.000mm" height = "42.310mm" ver = "02" gw = "188" gh = "104"/>
</figure>
</s1>
<s1>
<ptxt>
Pokiaľ držíte vinutú pružinu stlačenú pomocou špeciálnych nástrojov, demontujte spodnú maticu podpery vzpery pomocou kľúča na šesťhranné matice podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A220008.swf" width = "88.000mm" height = "45.511mm" ver = "01" gw = "98" gh = "112"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte montážnu zostavu prednej vzpery. 
<intxreftitleoff1 refid = "ASLAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A2206004002">
<title>
Zloženie
</title>
<s1>
<ptxt>
Vinutú pružinu stlačte pomocou špeciálneho nástroja (na stlačenie pružiny), pokiaľ nie je dĺžka „a“ cca 260 mm (10,2 in.).
</ptxt>
<servicetool>
<servicetoolitem id = "L2B002">
<s-part>
(A)
</s-part>
<s-number num = "09943-25010">
09943–25010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Dĺžka
</title>
<ptxt>
„a”: Približne 260 mm (10,2 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A220009.swf" width = "88.000mm" height = "43.428mm" ver = "02" gw = "158" gh = "107"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.289in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.355in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.289in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.356in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[u]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Horná strana (veľký priemer)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[l]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Dolná strana (malý priemer)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Nasaďte stlačenú pružinu na prednú vzperu a koniec vinutia pružiny (2) nasaďte na spodné sedlo pružiny (1) podľa obrázku.
</ptxt>
<attention3>
<ptxt>
Koniec pružiny by nemal byť nad spodným sedlom pružiny.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A220010.swf" width = "88.000mm" height = "52.318mm" ver = "01" gw = "206" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Nastavte zarážku nárazníka. 
<intxreftitleoff1 refid = "ASLAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte prachový kryt vzpery (1) nad tri čeľuste (2) veka tlmiča (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A220011.swf" width = "88.000mm" height = "51.821mm" ver = "02" gw = "209" gh = "130"/>
</figure>
</s1>
<s1>
<ptxt>
Rozpernú tyč vytiahnite ako je to len možné a dbajte na to, aby sa znovu nestiahla do vzpery.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte horné sedlo vinutej pružiny.
</ptxt>
</s1>
<s1>
<ptxt>
Nasaďte ložisko vzpery, nosnú dosku vzpery, podporu vzpery a novú spodnú maticu podpery vzpery v tomto poradí. 
<intxreftitleoff1 refid = "ASLAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Dotiahnite spodnú maticu konzoly vzpery na predpísaný uťahovací moment počas držania kolíka pomocou šesťhranného kľúča.
</ptxt>
<torque>
<torqueitem id = "T2B005">
<t-part>
Oporná dolná matica vzpery
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A220038.swf" width = "88.000mm" height = "49.480mm" ver = "01" gw = "188" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Demontujte z vinutej pružiny špeciálny nástroj (na stlačenie pružiny).
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
