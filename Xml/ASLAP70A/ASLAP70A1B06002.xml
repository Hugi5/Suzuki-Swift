<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1K">
<servcat sctnbr = "01" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1B06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zberného výfukového potrubia
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1B06001">Komponenty výfukového systému</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1B06002001" page = "2">
<title>
Demontáž
</title>
<attention2>
<ptxt>
Dávajte pozor, aby vám výfukové potrubie nespadlo. Ak vám spadne, vnútorný katalyzátor by sa mohol nárazom poškodiť.
</ptxt>
</attention2>
<s1 page = "2">
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odpojte konektor snímača A/F (1) (farba konektora: čierna) a konektor HO2S (farba konektora: sivá), a potom ich vyberte z miesta inštalácie.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0002.swf" width = "88.000mm" height = "53.833mm" ver = "01" gw = "171" gh = "136"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Odpojte výfukové potrubie č. 1 (1) od hlavného výfukového potrubia.
</ptxt>
<figure page = "2">
<graphic graphicname = "I7V20A1B1003.swf" width = "88.000mm" height = "51.237mm" ver = "01" gw = "163" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Demontujte výstuhy (2) výfukového potrubia.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odmontujte kryt výfukového potrubia (3) z výfukového potrubia.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Z výfukového potrubia vyberte snímač A/F (4) HO2S (5), ak je to potrebné. 
<intxreftitleoff1 refid = "ASLAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Demontujte hlavné výfukové potrubie (1) a jeho tesnenie od hlavy valca.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0003.swf" width = "88.000mm" height = "70.972mm" ver = "01" gw = "193" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1B06002002" page = "2">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Použite nové tesnenie.
</ptxt>
</item>
<item>
<ptxt>
Dotiahnite skrutky a matice výfukového potrubia na požadovaný doťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1K001">
<t-part>
Skrutka zberného výfukového potrubia
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6,1
</t-value2>
<t-value3>
44,5
</t-value3>
</torqueitem>
<torqueitem id = "T1K002">
<t-part>
Matica zberného výfukového potrubia
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6,1
</t-value2>
<t-value3>
44,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1002.jpg" width = "88.000mm" height = "57.647mm" ver = "02" gw = "199" gh = "147"/>
</figure>
</item>
<item>
<ptxt>
Namontujte snímač A/F a HO2S, ak bol odstránený. 
<intxreftitleoff1 refid = "ASLAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Namontujte výstuže výfukového potrubia podľa nasledovného.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Nainštalujte výstuhy výfukového potrubia (1) a potom rukou dotiahnite matice výstuhy výfukového potrubia (2).
</ptxt>
</item>
<item>
<ptxt>
Dotiahnite skrutky výstuhy výfukového potrubia (3) a potom rukou dotiahnite matice výstuhy výfukového potrubia (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P1B0004.swf" width = "88.000mm" height = "64.959mm" ver = "01" gw = "172" gh = "168"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Skrutky výfukového potrubia č. 1 utiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1K003">
<t-part>
Skrutka rúry výfuku č. 1
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
43
</t-value1>
<t-value2>
4,4
</t-value2>
<t-value3>
32,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1004.swf" width = "88.000mm" height = "54.949mm" ver = "01" gw = "153" gh = "139"/>
</figure>
</item>
<item>
<ptxt>
Spustite motor a skontrolujte unikanie výfukových plynov.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
