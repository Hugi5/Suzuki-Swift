<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A8206024" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž snímača zadného nárazu
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Nikdy neopravujte ani nerozoberajte snímač.
</ptxt>
</item>
<item>
<ptxt>
Nikdy nedovoľte, aby vám snímač spadol, aby ste ho udreli ani ním netraste.
</ptxt>
<ptxt>
Ak vám spadol, vymeňte ho, aj keď na ňom nevidíte žiadne poškodenie.
</ptxt>
<ptxt>
Ak je snímač zdeformovaný alebo prasknutý, vymeňte ho.
</ptxt>
</item>
<item>
<ptxt>
Skrutku snímača musíte pozorne utiahnuť, čím zaistíte jeho správnu činnosť.
</ptxt>
<ptxt>
Slabo pripojený snímač môže spôsobiť nesprávnu činnosť systému airbagu.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "ASLAP70A8206024001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Deaktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte zostavu zadného sedadla. 
<intxreftitleoff1 refid = "ASLAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte obloženie dolnej štvrtiny. 
<intxreftitleoff1 refid = "ASLAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor snímača zadného nárazu (2) nasledovne:
</ptxt>
<s2>
<ptxt>
Uvoľnite poistný posúvač (1) jeho posunutím v smere šípky „1“.
</ptxt>
</s2>
<s2>
<ptxt>
Odpojte snímač zadného nárazu (2) potiahnutím v smere šípky “2”.
</ptxt>
</s2>
</s1>
<s1>
<ptxt>
Demontujte skrutku snímača zadného nárazu (3) a snímač zadného nárazu (4) z vnútorného panela bočného prahu (5).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820076.swf" width = "88.000mm" height = "104.086mm" ver = "01" gw = "215" gh = "279"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A8206024002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A8206025">Kontrola snímača zadného nárazu</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Skontrolujte, či sa nevyskytuje žiaden z nasledujúcich poruchových stavov:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ohnutá, zdeformovaná alebo korodovaná štvrť vnútorného prahu.
</ptxt>
</item>
<item>
<ptxt>
Cudzí materiál na snímači.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Vyrovnajte montážny kolík (1) s montážnym otvorom (2) vozidla a nainštalujte snímač zadného nárazu (3).
</ptxt>
</s1>
<s1>
<ptxt>
Utiahnite skrutku snímača zadného nárazu na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T8B009">
<t-part>
Skrutka zadného snímača bočného nárazu
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,0
</t-value1>
<t-value2>
0,92
</t-value2>
<t-value3>
7,0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Riadne pripojte prípojku snímača zadného nárazu.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820077.swf" width = "88.000mm" height = "71.040mm" ver = "01" gw = "215" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte obloženie dolnej štvrtiny.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte zostavu zadného sedadla. 
<intxreftitleoff1 refid = "ASLAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Aktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
