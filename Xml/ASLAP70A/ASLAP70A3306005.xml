<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3306005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rozobratie a zloženie zariadenia rozvodovky
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A3306003">Odpojenie a pripojenie rozvodovky</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A3306004">Komponenty zariadenia rozvodovky</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A3306005001">
<title>
Rozobratie
</title>
<s1>
<ptxt>
Pomocou špeciálneho nástroja demontujte olejové tesnenie pravej skrine č. 1 (1) z pravej strany rozvodovky.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C001">
<s-part>
</s-part>
<s-number num = "09913-50121">
09913–50121
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Pomocou klieští na poistný krúžok vyberte poistný krúžok (2).
</ptxt>
</s1>
<s1>
<ptxt>
Zo zariadenia rozvodovky demontujte stredový hriadeľ (4) s ložiskom stredového hriadeľa (3).
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou nástroja na vyťahovanie ložísk a hydraulického lisu odstráňte zo stredového hriadeľa (4) ložisko stredového hriadeľa (3).
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330008.swf" width = "88.000mm" height = "26.342mm" ver = "01" gw = "155" gh = "58"/>
</figure>
</s1>
<s1>
<ptxt>
Odstránením upevňovacích skrutiek (2) odstráňte puzdro výstupu rozvodovky (1) a podložku (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330010.swf" width = "88.000mm" height = "55.632mm" ver = "01" gw = "206" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Odstráňte skrutky skrine rozvodovky (1).
</ptxt>
</s1>
<s1>
<ptxt>
Oddeľte pravú skriňu rozvodovky (2) z ľavej skrine rozvodovky (3) pomocou špeciálneho nástroja.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C002">
<s-part>
</s-part>
<s-number num = "09912-34510">
09912–34510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330011.swf" width = "88.000mm" height = "57.119mm" ver = "02" gw = "143" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Demontujte zostavu redukčného hnacieho kolesa (1) a zostavu redukčného hnaného kolesa (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330012.swf" width = "88.000mm" height = "45.732mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Odstráňte vonkajšie krúžky ložiska (1) a podložku (2).
</ptxt>
<attention3>
<ptxt>
Ak je odstraňovanie vonkajších krúžkov ložiska z ložísk ťažké, odstráňte ich pomocou špeciálneho nástroja.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C003">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944–96011
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330013.swf" width = "88.000mm" height = "51.937mm" ver = "01" gw = "196" gh = "131"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A3306005002">
<title>
Zloženie
</title>
<s1>
<ptxt>
Správnu podložku vyberte nasledovne.
</ptxt>
<s2>
<ptxt>
Odmerajte vzdialenosť „a“ medzi kužeľovým valivým ložiskom vonkajších krúžkov zostavy redukčného hnaného kolesa (1).
</ptxt>
</s2>
<s2>
<ptxt>
Zmerajte hĺbku „b“ ľavej skrine (2) a „c“ pravej skrine (3).
</ptxt>
</s2>
<s2>
<ptxt>
Získajte nastavovaciu hrúbku podložky podľa nasledovnej rovnice.
</ptxt>
<ptxt>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "9" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.748in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.157in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.451in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.157in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.451in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.157in"/>
<colspec colnum = "7" colname = "7" colwidth = "0.560in"/>
<colspec colnum = "8" colname = "8" colwidth = "0.157in"/>
<colspec colnum = "9" colname = "9" colwidth = "0.591in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "middle" align = "center">
<ptxt>
Potrebná hrúbka vyrovnávacej podložky
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
=
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Hĺbka „b“
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Hĺbka „c“
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
–
</ptxt>
</entry>
<entry colname = "7" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Vzdialenosť „a“
</ptxt>
</entry>
<entry colname = "8" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "9" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "middle" align = "center">
<ptxt>
0,1 mm (0,004 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<figure>
<graphic graphicname = "IAP70A330014.swf" width = "88.000mm" height = "40.526mm" ver = "02" gw = "225" gh = "98"/>
</figure>
</s2>
<c-change/>
<s2>
<ptxt>
Vyberte podložky z nasledovných dostupných veľkostí, aby celková hrúbka podložiek na pravej a ľavej strane dosiahla vypočítanú hodnotu.
</ptxt>
<ptxt>
<emph etype = "bold">
Napríklad:
</emph>
</ptxt>
<ptxt>
Zmeraná vzdialenosť „a“ je 101,75 mm (4,006 in.).
</ptxt>
<ptxt>
Zmeraná hĺbka „b“ je 77,95 mm (3,069 in.).
</ptxt>
<ptxt>
Zmeraná hĺbka „c“ je 25,80 mm (1,016 in.).
</ptxt>
<ptxt>
Potrebná hrúbka podložky = 77,95 mm (3,069 in.) + 25,80 mm (1,016 in.) – 101,75 mm (4.006 in.) + 0,1 mm (0,004 in.) = 2,10 mm (0,083 in.)
</ptxt>
<spec>
<title>
Dostupná hrúbka redukčného hnaného kolesa
</title>
<ptxt>
Pravá strana:
</ptxt>
<ptxt>
0,60, 0,65, 0,70, 0,75, 0,80, 0,85, 0,90, 0,95, 1,00 a 1,05 mm (0,024, 0,026, 0,028, 0,030, 0,031, 0,033, 0,035, 0,037, 0,039 a 0,041 in.)
</ptxt>
<ptxt>
Ľavá strana:
</ptxt>
<ptxt>
1,00, 1,05, 1,10, 1,15, 1,20, 1,25, 1,30, 1,35, 1,40 a 1,45 mm (0,039, 0,041, 0,043, 0,045, 0,047, 0,049, 0,051, 0,053, 0,055 a 0,057 in.)
</ptxt>
</spec>
</s2>
</s1>
<s1>
<ptxt>
Vyčistite dosadacie plochy praej a ľavej skrine a na pravú skriňu (1) aplikujte tesniaci prostreidok tak, ako je to zobrazené na obrázku v množstve, že jeho časť je s priemerom 1,2 mm (0,047 in.).
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3C005" uid = "-491504098">
<m-part>
„A“
</m-part>
<m-desc>
Tesniaci prostriedok
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I5RW0A330011.swf" width = "88.000mm" height = "42.399mm" ver = "01" gw = "155" gh = "104"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte nasledovné časti v pravej a ľavej skrini postupom, ktorý je opačný ako pri jeho rozobratí.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zostava redukčného hnacieho kolesa (1)
</ptxt>
</item>
<item>
<ptxt>
Zostava redukčného hnaného kolesa (2)
</ptxt>
</item>
<item>
<ptxt>
Vonkajšie krúžky ložiska (3)
</ptxt>
</item>
<item>
<ptxt>
Podložky redukčného hnaného kolesa (4)
</ptxt>
</item>
<item>
<ptxt>
Spojovací kolík (5)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A330015.jpg" width = "88.000mm" height = "60.349mm" ver = "01" gw = "213" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Utiahnite skrutky skrine prevodovky na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T3C006">
<t-part>
Skrutka skrine rozvodovky
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330016.swf" width = "88.000mm" height = "61.238mm" ver = "01" gw = "169" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Vyberte si podložku malého pastorka (1) podľa kroku 1) časti „Opätovná montáž“ v 
<intxref refid = "ASLAP70A3306009">Demontáž a montáž puzdra výstupu rozvodovky</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte kontakt ozubenia podľa 
<intxref refid = "ASLAP70A3306011">Kontrola kontaktu ozubenia kužeľového súkolesia</intxref>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte zostavu puzdra výstupu rozvodovky (2) s ľavou skriňou rozvodovky (3), spolu s podložkou malého pastorka (1) a dotiahnite skrutky na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T3C007">
<t-part>
Skrutka puzdra výstupu rozvodovky
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330017.swf" width = "88.000mm" height = "45.870mm" ver = "01" gw = "165" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Do otvoru skrutky príruby (2) namontujte skrutku a nastavte merací hrot mikrometrického meradla na pravé uhly ku skrutke (1) tak, ako je to zobrazené. Rukou držte redukčné hnané koleso a zmerajte bočnú vôľu pastorku a kužeľového ozubenia.
</ptxt>
<attention3>
<ptxt>
Ak bočná vôľa prekročí stanovené hodnoty uvedené nižšie, nastavte ju zmenou pomeru hrúbky podložiek namontovaných na pravej a ľavej strane skrine v kroku 3).
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C004">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900–20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3C005">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900–20701
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Bočná vôľa kužeľového pastorku a kužeľového ozubenia
</title>
<ptxt>
: 0,1 – 0,2 mm (0,0039 – 0,0078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330018.swf" width = "88.000mm" height = "39.091mm" ver = "01" gw = "157" gh = "94"/>
</figure>
</s1>
<s1>
<ptxt>
Nainštalujte ložisko stredového hriadeľa (1) k stredovému hriadeľu pomocou špeciálneho nástroja (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L3C006">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913–84510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A330015.swf" width = "88.000mm" height = "48.692mm" ver = "01" gw = "71" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Nainštalujte stredový hriadeľ (2) s ložiskom (3) do rozvodovky.
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou klieští na poistný krúžok nasaďte nový poistný krúžok (1). do pravej skrine rozvodovky.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330016.swf" width = "88.000mm" height = "26.757mm" ver = "02" gw = "133" gh = "59"/>
</figure>
</s1>
<s1>
<ptxt>
Okraj nového olejového tesnenia pravej skrine č. 1 namažte vazelínou.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C006" uid = "1126491901">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Pomocou špeciálneho nástroja a kladiva zaskrutkujte olejové tesnenie pravej skrine č. 1 (1) na pravú stranu rozvodovky (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L3C007">
<s-part>
(A)
</s-part>
<s-number num = "09925-16010">
09925–16010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Inštalačná hĺbka stredného vástupu olejového tesnenia
</title>
<ptxt>
„a”: 1,0 – 2,0 mm (0,039 – 0,078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330042.swf" width = "88.000mm" height = "45.592mm" ver = "01" gw = "201" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
