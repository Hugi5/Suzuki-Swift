<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3306007" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rozobratie a zloženie zostavy redukčného hnacieho kolesa
</title>
<servinfosub id = "ASLAP70A3306007001">
<title>
Rozobratie
</title>
<s1>
<ptxt>
Odstráňte ľavé ložisko (1) a kužeľové súkolesie (2) pomocou špeciálneho nástroja, nástroja na vyťahovanie ložísk (3) a hydraulického lisu (4).
</ptxt>
<servicetool>
<servicetoolitem id = "L3C010">
<s-part>
(A)
</s-part>
<s-number num = "09925-98221">
09925–98221
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A330020.swf" width = "88.000mm" height = "45.274mm" ver = "02" gw = "158" gh = "112"/>
</figure>
</s1>
<s1>
<ptxt>
Aby ste mohli odmontovať pravé ložisko (1) z redukčného hnaného kolesa (2), obrúste brúskou (3) jednu časť „a“ ložiska podľa obrázku, až kým nebude tenké.
</ptxt>
<attention2>
<ptxt>
Brúste opatrne, aby ste nezašli priďaleko a nepoškodili hnané koleso.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I5RW0A330021.swf" width = "88.000mm" height = "58.697mm" ver = "01" gw = "161" gh = "150"/>
</figure>
</s1>
<s1>
<ptxt>
Pomocou dláta (1) rozlomte tenké ložisko uzemnenia (2) a vyberte ho.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330022.swf" width = "88.000mm" height = "47.949mm" ver = "01" gw = "131" gh = "119"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A3306007002">
<title>
Zloženie
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Ak je potrebné vymeniť kužeľové súkolesie alebo pastorok, je potrebné ich vymeniť ako sadu.
</ptxt>
</item>
<item>
<ptxt>
Pri výmene kužeľového valivého ložiska vymeňte aj vnútorné aj vonkajšie krúžky ložísk.
</ptxt>
</item>
</list1>
</attention2>
<s1>
<ptxt>
Nainštalujte pravé ložisko (1) na redukčné hnané koleso (2) pomocou špeciálneho nástroja a hydraulického lisu.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C011">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3C012">
<s-part>
(B)
</s-part>
<s-number num = "09925-16310">
09925–16310
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A330023.swf" width = "88.000mm" height = "47.565mm" ver = "01" gw = "83" gh = "118"/>
</figure>
</s1>
<s1>
<ptxt>
Nainštalujte súkolesie pohonu (1) na redukčné hnané koleso (2) pomocou špeciálneho nástroja a hydraulického lisu.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C013">
<s-part>
(A)
</s-part>
<s-number num = "09924-07710">
09924–07710
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3C014">
<s-part>
(B)
</s-part>
<s-number num = "09924-84510-005">
09924–84510–005
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3C015">
<s-part>
(C)
</s-part>
<s-number num = "09925-15410">
09925–15410
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAY301330009.swf" width = "88.000mm" height = "49.676mm" ver = "01" gw = "104" gh = "124"/>
</figure>
</s1>
