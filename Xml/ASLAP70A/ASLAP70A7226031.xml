<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7226031" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž snímača slnečného žiarenia
</title>
<servinfosub id = "ASLAP70A7226031001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Deaktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Zložte prístrojovú dosku. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte z prístrojovej dosky snímač slnečného žiarenia (1) stlačením jazýčka a potlačením snímača smerom dohoda na spodnej strane.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte prípojku snímača slnečného žiarenia (2).
</ptxt>
<figure page = "2">
<graphic graphicname = "I7RW01722028.swf" width = "88.000mm" height = "40.458mm" ver = "01" gw = "238" gh = "98"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASLAP70A7226031002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A7226032">Kontrola snímača slnečného žiarenia:Automatický typ</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Namontujte snímač slnečného žiarenia (1) na jazýček prístrojovej dosky (2) snímača slnečného žiarenia v drážke (3) prístrojovej dosky podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723025.swf" width = "88.000mm" height = "35.371mm" ver = "01" gw = "209" gh = "84"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.181in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Predná časť vozidla
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
