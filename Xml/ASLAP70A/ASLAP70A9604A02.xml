<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A9604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Všetky dvere sa nedajú zamknúť/odomknúť
</title>
<diag type = "condition">
<condition>
<ptxt>
Všetky dvere sa nedajú zamknúť/odomknúť
</ptxt>
</condition>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Obráťte sa na „Kontrola BCM a jej obvodov“ v časti 10B.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky bezkľúčového štartovania (model s bezkľúčovým štartovaním)
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70AA504031">Kontrola riadiacej jednotky bezkľúčového štartovania a jeho obvodov</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha obvodu systému (vrátane relé a poistiek)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača centrálneho uzamykania dverí.
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70A9606009">Kontrola spínača centrálneho uzamykania</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha vložky zámky dverí
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte vložku zámky dvier. 
<intxreftitleoff1 refid = "ASLAP70A9606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
