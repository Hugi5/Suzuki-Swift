<servinfosub id = "ASLAP70AA324007001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.719in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.466in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
P1611: Nesprávne priradenie hesla
</emph>
</ptxt>
<ptxt>
Uložené heslo nie je správne.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Bola nainštalovaná riadiaca jednotka bezkľúčového štartovania alebo ECM, ktoré už boli použité v ďalšom vozidle
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka štartovania bez kľúča
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70AA324007002">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA324007003">
<testgroup id = "ASLAP70AA324007004">
<title>
Registrácia riadiacej jednotky motora
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA326003">Registrácia riadiacej jednotky motora:Model s bezkľúčovým štartovaním</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Znovu skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je stále detekovaný DTC P1611?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. Ak je stále detekovaný DTC P1611, vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka motora: 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka štartovania bez kľúča: 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (ECM nebola zaregistrovaná.)
</ptxt>
</action>
</testgroup>
</diag>
