<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A6306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia riadiacej jednotky posilňovača riadenia
</title>
<servinfosub id = "ASLAP70A6306011001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Zložte prístrojovú klusterový panel. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte sústavu brzdového pedála. 
<intxreftitleoff1 refid = "ASLAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte prípojky (1) z riadiacej jednotky posilňovača riadenia (2).
</ptxt>
</s1>
<s1>
<ptxt>
Z podporného člena riadenia odmontujte skrutky riadiacej jednotky P/S (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A630037.swf" width = "88.000mm" height = "94.023mm" ver = "01" gw = "148" gh = "250"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte riadiacu jednotka posilňovača riadenia.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A6306011002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dotiahnite skrutky riadiacej jednotky P/S na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T6C006">
<t-part>
Montážna skrutka riadiaceho modulu posilňovača riadenia
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,0
</t-value1>
<t-value2>
0,51
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A630034.swf" width = "88.000mm" height = "98.099mm" ver = "02" gw = "148" gh = "262"/>
</figure>
</item>
<item>
<ptxt>
Namontujte sústavu brzdového pedála. 
<intxreftitleoff1 refid = "ASLAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
