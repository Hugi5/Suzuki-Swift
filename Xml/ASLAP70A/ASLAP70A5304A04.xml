<title>
Hlučná spojka
</title>
<diag type = "condition">
<condition>
<ptxt>
Hlučná spojka
</ptxt>
</condition>
<ps>
<ptxt>
Opotrebované alebo poškodené vodiace ložisko
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu pracovného valca spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pravé ložisko vstupného hriadeľa opotrebované
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte pravé ložisko vstupného hriadeľa. 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nadmerné klepanie náboja kotúča spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prasknutý kotúč spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Klepanie prítlačného kotúča a membránovej pružiny
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kryt spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
