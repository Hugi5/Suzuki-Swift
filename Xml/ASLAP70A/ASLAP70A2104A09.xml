<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A2104A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vozidlo sa v zákrutách nakláňa alebo kolíše
</title>
<diag type = "condition">
<condition>
<ptxt>
Vozidlo sa v zákrutách nakláňa alebo kolíše
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnený stabilizátor
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite skrutky alebo matice stabilizátora alebo vymeňte puzdrá ložísk. 
<intxreftitleoff1 refid = "ASLAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Chybná zostava alebo montáž prednej vzpery (tlmič odpruženia)
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte prednú vzperu (tlmič odpruženia) alebo dotiahnite upevnenie. 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zlomené alebo prevísajúce vinuté pružiny
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vymeňte vinuté pružiny. 
</ptxt>
<ptxt>
Predné: 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Preťažené vozidlo
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte náklad vozidla.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
