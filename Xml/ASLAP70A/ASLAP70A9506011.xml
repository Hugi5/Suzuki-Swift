<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž skla predných dverí
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9506010">Komponenty predných dverí</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A9506011001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Stiahnite sklo predných dverí približne na 150 mm (5,91 in.) od spodného okraja okna.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950023.jpg" width = "88.000mm" height = "45.882mm" ver = "02" gw = "225" gh = "114"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.331in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.870in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Približne 150 mm (5,91 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte vnútorné obloženie konzoly rámu (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte vnútorný kryt rukoväte (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky (3), svorku (B) a vyberte obloženie dverí (4) potiahnutím v smere šípky.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950025.jpg" width = "88.000mm" height = "101.074mm" ver = "01" gw = "227" gh = "270"/>
</figure>
</s1>
<s1>
<ptxt>
odpojte konektory káblového zväzku dverí.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte vonkajšiu tesniacu lištu predných dverí (1) posunutím v smere šípky v poradí (“1” až “2”) podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950026.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.071in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.783in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Zárez
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Vonkajší plech predných dverí
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte konzolu obloženia dverí (1) a tesniaci kryt dverí (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950027.jpg" width = "88.000mm" height = "91.845mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte skrutky (1) a odmontujte sklo predných dverí (2) posunutím v smere šípky v poradí (“1” až “2”) podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950028.jpg" width = "88.000mm" height = "78.685mm" ver = "02" gw = "225" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9506011002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Namontujte držiaky skla dverí (1) do predpísanej polohy skla predných dverí (2), ak ste ich demontovali od predného skla dverí.
</ptxt>
<spec>
<title>
Poloha inštalácie držiaka skla predných dverí
</title>
<ptxt>
„a”: 104 – 106 mm (4,10 – 4,17 in.)
</ptxt>
<ptxt>
“b”: 431,2 – 433,2 mm (16,98 – 17,05 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70P950015.jpg" width = "88.000mm" height = "46.523mm" ver = "01" gw = "191" gh = "115"/>
</figure>
</item>
<item>
<ptxt>
Dotiahnite skrutky skla predných dverí v poradí “1” až “2“ podľa obrázku.
</ptxt>
</item>
<item>
<ptxt>
Utiahnite skrutky predného skla na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T9E002">
<t-part>
Skrutka skla predných dverí*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950029.jpg" width = "88.000mm" height = "81.655mm" ver = "02" gw = "225" gh = "215"/>
</figure>
</item>
<item>
<ptxt>
Ak je sklo poškodené, opravte alebo ho vymeňte za nové.
</ptxt>
</item>
<item>
<ptxt>
Upevnite kryt tesnenia dverí (1) pomocou butylovej pásky (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950031.jpg" width = "88.000mm" height = "81.028mm" ver = "01" gw = "215" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
