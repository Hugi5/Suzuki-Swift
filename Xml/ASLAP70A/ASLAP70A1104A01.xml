Tuhý driek ventilu
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406028">Kontrola ventilov a vodidiel ventilov</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabé alebo poškodené ventilové pružiny
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406031">Kontrola ventilovej pružiny</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Únik kompresie na tesnení hlavy valca
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406029">Kontrola hlavy valcov</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Tuhý alebo poškodený piestny krúžok
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406035">Kontrola valca, piestu a piestneho krúžku</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaný piest, piestny krúžok alebo valec
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406035">Kontrola valca, piestu a piestneho krúžku</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybný ventil PCV
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1206006">Kontrola ventilu PCV</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Systém riadenia polohy vačkového hriadeľa (VVT) je mimo prevádzky
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306027">Kontrola OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
