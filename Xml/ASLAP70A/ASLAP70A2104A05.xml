<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A2104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nezvyčajný hluk v prednej časti
</title>
<diag type = "condition">
<condition>
<ptxt>
Nezvyčajný hluk v prednej časti
</ptxt>
</condition>
<ps>
<ptxt>
Chybná zostava alebo montáž prednej vzpery (tlmič odpruženia)
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte prednú vzperu (tlmič nárazov) alebo upevnenia. 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebévané, lepkavé alebo uvoľnené hlavy riadiacej tyče
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte hlavu spojovacej tyče riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované alebo poškodené spoje ramena zavesenia
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte rameno nápravy. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebévané, lepkavé alebo uvoľnené kĺby riadiacej tyče
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu skrine prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované, lepkavé alebo uvoľnené kĺby hnacieho hriadeľa
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kĺby hnacieho hriadeľa. 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované predné misky ložísk ramena nápravy
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte prednú misku ložiska ramena nápravy. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované zadné misky ložísk ramena nápravy
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte rameno nápravy. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnený stabilizátor
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite skrutky alebo matice a/alebo vymeňte puzdrá ložísk. 
<intxreftitleoff1 refid = "ASLAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené matice kolesa
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite matice kolesa. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené skrutky alebo matice zavesenia
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite skrutky alebo matice zavesenia. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rozbité alebo poškodené ložiská kolies
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte ložiská kolies. 
<intxreftitleoff1 refid = "ASLAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prasknuté vinuté pružiny
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vymeňte vinuté pružiny. 
</ptxt>
<ptxt>
Predné: 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Nedostatočne namazané alebo opotrebované ložiská ramena
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte ložiská ramena. 
<intxreftitleoff1 refid = "ASLAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha systému posilňovača riadenia
</ptxt>
</ps>
<action>
<ptxt>
Systém skontrolujte a opravte. 
<intxreftitleoff1 refid = "ASLAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
