<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1581: Chyba panelu EEPROM
</emph>
</ptxt>
<ptxt>
Chyba EEPROM sa vyskytla v paneli automatickej klimatizácie.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Panel automatickej klimatizácie
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70A7224032002">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224032003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224032004">
<testgroup id = "ASLAP70A7224032005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Zapnite spínač zapaľovania a skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1581?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte panel automatickej klimatizácie a opätovne skontrolujte DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
