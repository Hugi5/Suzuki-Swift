<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7214004" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnostika príznakov nezvyčajného hluku systému HVAC
</title>
<servinfosub id = "ASLAP70A7214004001">
<title>
Nezvyčajný hluk z kompresora
</title>
<diag type = "condition" id = "ASLAP70A7214004002">
<condition>
<ptxt>
Počas prevádzky kompresora počuť hluk, ktorý počujete najmä pri zvýšení otáčok motora
</ptxt>
</condition>
<ps>
<ptxt>
Neprimeraná vôľa v oblasti závitnice
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kompresor. 
<intxreftitleoff1 refid = "ASLAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Pri určitých otáčkach, bez ohľadu na rýchlosť počuť hlasný zvuk
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnený alebo chybný hnací remeň kompresora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte hnací remeň kompresora. 
<intxreftitleoff1 refid = "ASLAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené montážne skrutky kompresora
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite montážne skrutky. 
<intxreftitleoff1 refid = "ASLAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Pri nízkych otáčkach motora počuť hlasný klepot
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnená skrutka spojkovej lamely kompresora
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Utiahnite skrutku spojkovej lamely. 
<intxreftitleoff1 refid = "ASLAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Vymeňte kompresor, ak bol v takomto stave v prevádzke dlhodobo.
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A7214004003">
<title>
Nezvyčajný hluk z magnetickej spojky
</title>
<diag type = "condition" id = "ASLAP70A7214004004">
<condition>
<ptxt>
Keď kompresor nie je v prevádzke, počuť hluk.
</ptxt>
</condition>
<ps>
<ptxt>
Opotrebované alebo poškodené ložiská
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte teleso magnetickej spojky. 
<intxreftitleoff1 refid = "ASLAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Keď je kompresor v prevádzke, počuť hluk.
</ptxt>
</condition>
<ps>
<ptxt>
Nevhodná vôľa magnetickej spojky (priveľká vôľa)
</ptxt>
</ps>
<action>
<ptxt>
Nastavte vôľu magnetickej spojky. 
<intxreftitleoff1 refid = "ASLAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaný trecí povrch magnetickej spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte teleso magnetickej spojky. 
<intxreftitleoff1 refid = "ASLAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Znečistenie trecieho povrchu kompresorovým olejom, ktorý unikol cez tesnenie hriadeľa
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte teleso kompresora. 
<intxreftitleoff1 refid = "ASLAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A7214004005">
<title>
Nezvyčajný hluk z potrubí
</title>
<diag type = "condition" id = "ASLAP70A7214004006">
<condition>
<ptxt>
Vo vnútri vozidla je počuť hukot, ktorý v motorovom priestore nie je výrazný
</ptxt>
</condition>
<ps>
<ptxt>
Chybné príchytky trubice
</ptxt>
</ps>
<action>
<ptxt>
Premiestnite alebo pridajte príchytky.
</ptxt>
</action>
<ps>
<ptxt>
Rezonancia spôsobená pulzovaním vyvolaným kolísaním tlaku chladiacej zmesi
</ptxt>
</ps>
<action>
<ptxt>
Pripevnite na trubicu tlmič alebo zmeňte jej polohu a dĺžku.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A7214004007">
<title>
Nezvyčajný hluk z agregátu kondenzátora
</title>
<diag type = "condition" id = "ASLAP70A7214004008">
<condition>
<ptxt>
Značné vibrácie v telese kondenzátora
</ptxt>
</condition>
<ps>
<ptxt>
Rezonancia medzi konzolou a telesom kondenzátora
</ptxt>
</ps>
<action>
<ptxt>
Medzi konzolu a teleso kondenzátora pevne zasuňte tlmič.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A7214004009">
<title>
Nezvyčajný hluk z remenice kľukového hriadeľa
</title>
<diag type = "condition" id = "ASLAP70A7214004010">
<condition>
<ptxt>
Pri voľnobehu alebo náhlej akcelerácii počuť silný klepot.
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnená skrutka remenice kľukového hriadeľa
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite skrutky. 
<intxreftitleoff1 refid = "ASLAP70A1406017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A7214004011">
<title>
Nezvyčajný hluk z napínacej kladky
</title>
<diag type = "condition" id = "ASLAP70A7214004012">
<condition>
<ptxt>
Z kladky počuť hrkotavý hluk
</ptxt>
</condition>
<ps>
<ptxt>
Opotrebované alebo poškodené ložisko
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte napínaciu kladku.
</ptxt>
</action>
<condition>
<ptxt>
Kladka sa prehýba pod dotykom
</ptxt>
</condition>
<ps>
<ptxt>
Prasknutá alebo uvoľnená konzola
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte alebo znovu utiahnite konzolu.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A7214004013">
<title>
Nezvyčajný hluk z výparníka klimatizácie
</title>
<diag type = "condition" id = "ASLAP70A7214004014">
<condition>
<ptxt>
Z výparníka klimatizácie počuť pískavý zvuk
</ptxt>
</condition>
<ps>
<ptxt>
V závislosti od kombinácie vnútornej/vonkajšej teploty, otáčok motora a tlaku chladiacej kvapaliny, môže chladiaca kvapalina pri prúdení cez expanzný ventil vydávať pískavý zvuk.
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Mierne zníženie množstva chladiacej kvapaliny môže tento zvuk ukončiť.
</ptxt>
<ptxt>
Skontrolujte expanzný ventil a v prípade poruchy ho vymeňte.
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A7214004015">
<title>
Nezvyčajný hluk z elektromotora ventilátora
</title>
<diag type = "condition" id = "ASLAP70A7214004016">
<condition>
<ptxt>
Motor ventilátora vydáva čvrlikavý zvuk, ktorý je úmerný jeho rýchlosti otáčania.
</ptxt>
</condition>
<ps>
<ptxt>
Opotrebované alebo poškodené kefky alebo komutátor motora
</ptxt>
</ps>
<action>
<ptxt>
Elektromotor ventilátora vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A7216009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Z elektromotora ventilátora počuť trepotavý zvuk alebo hlasný hukot.
</ptxt>
</condition>
<ps>
<ptxt>
Do motora dúchadla sa cez prívod vzduchu dostalo lístie alebo iné znečistenie
</ptxt>
</ps>
<action>
<ptxt>
Odstráňte znečistenie a uistite sa, či mriežka na prívode čerstvého vzduchu nie je poškodená.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
