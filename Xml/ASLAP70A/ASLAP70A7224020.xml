<diag type = "test" id = "ASLAP70A7224020007">
<testgroup id = "ASLAP70A7224020008">
<title>
Kontrola parametrov skenovacieho zariadenia
</title>
<test1>
<ptxt>
Skontrolujte “Air Mix Pos Sen” pomocou režimu “Zoznamu údajov” na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224020009">
<title>
Kontrola obvodu ovládača regulácie teploty
</title>
<test1>
<ptxt>
Odpojte konektor „G20“ a konektory ovládačov regulácie teploty.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov vodiča „GRY“ a „LT BLU“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor obvodov vodiča „GRY“ a „LT BLU“ medzi ovládačom riadenia teploty a uzemnením: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú hodnoty odporu podľa predpisu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224020010">
<title>
Kontrola ovládača regulácie teploty
</title>
<test1>
<ptxt>
Skontrolujte ovládač riadenia teploty. 
<intxreftitleoff1 refid = "ASLAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je ovládač v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku HVAC a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte ovládač riadenia teploty. 
<intxreftitleoff1 refid = "ASLAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
