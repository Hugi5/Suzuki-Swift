<servinfosub id = "ASLAP70A1104037003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 8,5 V
</ptxt>
</item>
<item>
<ptxt>
Napätie akumulátora je nižšie ako 18 V keď je rýchlosť vozidla vyššia ako 20 km/hod. (12 míľ/hod.)
</ptxt>
</item>
<item>
<ptxt>
DTC P0563 nie je detekovaný.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Zahrejte motor na bežnú prevádzkovú teplotu.
</ptxt>
</s1>
<s1>
<ptxt>
Udržujte motor na voľnobežných otáčkach, kým teplota chladiacej kvapaliny nedosiahne 97 &#176;C (206,6 &#176;F) alebo viac.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104037004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104037005">
<testgroup id = "ASLAP70A1104037006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104037007">
<title>
Kontrola obvodu napájania relé ventilátora chladiča č. 1 (strana cievky)
</title>
<test1>
<ptxt>
So spínačom zapaľovania v polohe OFF (Vyp.) vyberte relé ventilátora chladiča.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektoru relé ventilátora chladiča č. 1.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi „A1“ a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104037008">
<title>
Kontrola relé č. 1 ventilátora chladiča
</title>
<test1>
<ptxt>
Skontrolujte relé ventilátora chladiča č. 1. 
<intxreftitleoff1 refid = "ASLAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte relé ventilátora chladiča č. 1.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104037009">
<title>
Kontrola riadiaci obvod relé ventilátora chladiča
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „B1“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B1“ a ďalšou svorkou v konektore relé ventilátora chladiča: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „B1“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
</diag>
