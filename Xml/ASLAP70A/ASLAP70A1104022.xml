<servinfosub id = "ASLAP70A1104022003">
<title>
Postup potvrdenia DTC
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Cestnú skúšku vykonávajte na mieste, kde nie je doprava, aby ste predišli nehode.
</ptxt>
</item>
<item>
<ptxt>
Skúšobnú jazdu musia vykonať dve osoby, vodič a testujúca osoba a to na rovnej ceste.
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Potvrďte, že ECT je menej ako 40 &#176;C (104 &#176;F).
</ptxt>
</s1>
<s1>
<ptxt>
Naštartujte motor a jazdite vozidlom neustále pri rýchlosti 60 až 80 km/h (37 až 50 míľ/h) po dobu 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104022004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104022005">
<testgroup id = "ASLAP70A1104022006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104022007">
<title>
Kontrola hladiny chladiacej kvapaliny
</title>
<test1>
<ptxt>
Kontrola hladiny chladiacej kvapaliny. 
<intxreftitleoff1 refid = "ASLAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Doplňte chladiacu kvapalinu a znova skontrolujte DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104022008">
<title>
Kontrola obvodu snímača ECT
</title>
<test1>
<ptxt>
Skontrolujte obvod snímača ECT podľa kroku 2 v časti 
<intxref refid = "ASLAP70A1104023">DTC P0117 / P0118</intxref>
.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104022009">
<title>
Kontrola snímača ECT
</title>
<test1>
<ptxt>
Skontrolujte snímač ECT. 
<intxreftitleoff1 refid = "ASLAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte snímač teploty chladiacej kvapaliny motora.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104022010">
<title>
Kontrola termostatu
</title>
<test1>
<ptxt>
Skontrolujte sústavu termostatu. 
<intxreftitleoff1 refid = "ASLAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Termostat vymeňte.
</ptxt>
</action>
</testgroup>
</diag>
