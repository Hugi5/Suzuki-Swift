<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola jednotky kondenzátora na vozidle
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A7216006">Demontáž a montáž jednotky kondenzátora:Manuálny typ</intxrefpoff>
</ptxt>
<ptxt>
Skontrolujte nasledujúce.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Rebrá kondenzátora
</ptxt>
<ptxt>
Ak sú upchaté, umyte kondenzátor vodou a vysušte ho pomocou stlačeného vzduchu.
</ptxt>
</item>
<item>
<ptxt>
Netesnosť alebo zlomenie rebier kondenzátora
</ptxt>
<ptxt>
Ak zistíte akékoľvek poškodenie, opravte alebo vymeňte kondenzátor.
</ptxt>
</item>
<item>
<ptxt>
Netesnosť armatúr kondenzátora.
</ptxt>
<ptxt>
Ak zistíte akékoľvek poškodenie, opravte alebo vymeňte kondenzátor.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
