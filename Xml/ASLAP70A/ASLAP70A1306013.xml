<servinfo servinfosgmlid = "ASLAP70A1306013" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola snímača A/F na vozidle
</title>
<c-change/>
<servinfosub id = "ASLAP70A1306013001">
<title>
Ohrievač snímača A/F
</title>
<s1>
<ptxt>
Odpojte konektor snímača AF pri vypnutom spínači zapaľovania.
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou ohmmetra odmerajte odpor konektora snímača AF (strana snímača) medzi svorkou „2“ a „5“ na konektore snímača AF. Ak zistíte chybu, snímač A/F vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention3>
<ptxt>
Hodnotu odporu výrazne ovplyvňuje teplota sondy. Uistite sa, že sonda je vyhrievaná na správnu teplotu.
</ptxt>
</attention3>
<spec>
<title>
Odpor ohrievača snímača A/F
</title>
<ptxt>
2,4 až 4,0 &#937; at 20 &#176;C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7N301132038.swf" width = "88.000mm" height = "30.676mm" ver = "01" gw = "67" gh = "70"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.314in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.150in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Konektor snímača A/F (zo strany svorky)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1306013002" page = "2">
<title>
Nastaviteľný odpor snímača AF
</title>
<ptxt>
Pomocou ohmmetra zmerajte odpor medzi svorkami „1“ a „3“ na konektore snímača A/F. Ak zistíte chybu, snímač A/F vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<spec>
<title>
