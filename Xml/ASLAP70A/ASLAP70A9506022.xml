<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9506022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spätného zrkadla
</title>
<servinfosub id = "ASLAP70A9506022001">
<title>
Demontáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9506021">Kontrola elektrického ovládania a vyhrievania spätných zrkadiel na vozidle</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Odmontujte vnútorné obloženie konzoly rámu zvisle posuvného okna. 
<intxreftitleoff1 refid = "ASLAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pre model s elekricky ovládanými spätnými zrkadlami vyberte obloženie predných dverí. 
<intxreftitleoff1 refid = "ASLAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pre model s elekricky ovládanými spätnými zrkadlami odpojte konektor elekricky ovládaného spätného zrkadla (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte matice spätného zrkadla (2) a zrkadlo vyberte (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950056.jpg" width = "88.000mm" height = "64.314mm" ver = "01" gw = "219" gh = "166"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9506022002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Po inštalácii skontrolujte činnosť spätného zrkadla.
</ptxt>
</item>
<item>
<ptxt>
Dotiahnite matice spätného zrkadla v poradí “1” až “3” na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T9E007">
<t-part>
Matica spätného zrkadla*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950057.jpg" width = "88.000mm" height = "63.396mm" ver = "01" gw = "225" gh = "163"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
