<servinfosub id = "ASLAP70A1104031002">
<title>
Postup potvrdenia DTC
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Cestnú skúšku vykonávajte na mieste, kde nie je doprava, aby ste predišli nehode.
</ptxt>
</item>
<item>
<ptxt>
Skúšobnú jazdu musia vykonať dve osoby, vodič a testujúca osoba a to na rovnej ceste.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ESP<sup>®</sup> nie je aktivovaná.
</ptxt>
</item>
<item>
<ptxt>
DTC P0122, P0123, P0222, P0223, P0335 alebo P0336 nie sú detekované.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Zahrejte motor na bežnú prevádzkovú teplotu.
</ptxt>
</s1>
<s1>
<ptxt>
Choďte s autom nepretržite rýchlosťou 50 až 80 km/h (31 až 50 míľ/h) 5 min., alebo viac.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104031003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104031004">
<testgroup id = "ASLAP70A1104031005">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104031006">
<title>
Kontrola hladiny paliva
</title>
<test1>
<ptxt>
Hladinu paliva skontrolujte pomocou palivomeru.
</ptxt>
</test1>
<question>
Ukazuje úroveň &#34;E&#34; (prázdna)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Doplňte palivo a znova skontrolujte DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104031007">
<title>
Kontrola kvality paliva
</title>
<test1>
<ptxt>
Je použitý správny typ paliva?
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
 Vymeňte za správny typ paliva a znova skontrolujte DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104031008">
<title>
Kontrola systému nasávania vzduchu a výfukového systému
</title>
<test1>
<ptxt>
Skontrolujte, či nie je výfukový systém a systém nasávania vzduchu upchatý alebo netesný.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybné časti.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104031009">
<title>
 Kontrola systému zapaľovania
</title>
<test1>
<ptxt>
Skontrolujte systém zapaľovania. 
<intxreftitleoff1 refid = "ASLAP70A1804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybné časti.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104031010">
<title>
Kontrola palivového systému
</title>
<test1>
<ptxt>
Skontrolujte nasledovné body, ktoré sa týkajú palivového systému. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tlak paliva: 
<intxreftitleoff1 refid = "ASLAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Obvod vstrekovacieho ventilu: 
<intxreftitleoff1 refid = "ASLAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vstrekovací ventil: 
<intxreftitleoff1 refid = "ASLAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybné časti.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104031011">
<title>
Kontrola mechanických sústav motora
</title>
<test1>
<ptxt>
Skontrolujte nasledovné body, ktoré by mohli spôsobiť nerovnomerný chod motora pri voľnobehu alebo zhoršiť jeho vlastnosti.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kompresia motora. 
<intxreftitleoff1 refid = "ASLAP70A1404001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vôľa ventilu. 
<intxreftitleoff1 refid = "ASLAP70A1404003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Časovanie ventilov. 
<intxreftitleoff1 refid = "ASLAP70A1406023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Skontrolujte napájací a uzemňovací okruh riadiacej jednotky motora. 
<intxreftitleoff1 refid = "ASLAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ak je obvod v poriadku, vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybné časti.
</ptxt>
</action>
</testgroup>
</diag>
