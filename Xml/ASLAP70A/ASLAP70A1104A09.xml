<ptxt>
Netesné zadné olejové tesnenie kľukového hriadeľa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406043">Kontrola zadného olejové tesnenie</intxref>
</ptxt>
</action>
