<ptxt>
Netesné tesnenie veka hlavy valcov
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406010">Súčiastky veka hlavy valcov motora</intxref>
</ptxt>
</action>
</diag>
