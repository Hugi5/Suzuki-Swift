<servinfosub id = "ASLAP70A1104049003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 10 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ na 10 sek.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104049004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104049005">
<testgroup id = "ASLAP70A1104049006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104049007">
<title>
Kontrola obvodu napájania relé palivového čepradla (strana cievky)
</title>
<test1>
<ptxt>
Relé palivového čerpadla vyberte so spínačom zapaľovania v polohe OFF (Vyp.).
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektoru relé palivového čerpadla.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi „A1“ a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104049008">
<title>
Kontrola relé palivového čerpadla
</title>
<test1>
<ptxt>
Skontrolujte relé palivového čerpadla. 
<intxreftitleoff1 refid = "ASLAP70A1306023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte relé palivového čerpadla.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104049009">
<title>
Skontrolujte hnací obvod relé palivového čerpadla
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „B1“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B1“ a ďalšou svorkou v konektore relé palivového čerpadla: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „B1“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
</diag>
