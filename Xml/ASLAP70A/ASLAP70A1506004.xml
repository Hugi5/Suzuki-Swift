<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1506004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž olejovej vane a sacieho koša olejového čerpadla
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1506003">Diely olejovej vane a sacieho koša olejového čerpadla</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1506004001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontáž merača hladiny oleja.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odstráňte pravý spodný kryt motora.
</ptxt>
</s1>
<s1>
<ptxt>
Motorový olej vypustite odstránením vypúšťacej skrutky.
</ptxt>
</s1>
<s1>
<ptxt>
Zložte výfukovú rúru č. 1. 
<intxreftitleoff1 refid = "ASLAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte prevodovku. 
<intxreftitleoff1 refid = "ASLAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte olejový filter. 
<intxreftitleoff1 refid = "ASLAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Demontujte skrutky prevodovky (1) a skrutky olejovej vane (2).
</ptxt>
<figure>
<graphic graphicname = "I7V20A151012.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "227" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Pomocou špeciálneho nástroja a kladiva demontujte z bloku motora olejovú vaňu (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L1E005">
<s-part>
(A)
</s-part>
<s-number num = "09921-96510">
09921–96510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A151013.swf" width = "88.000mm" height = "12.350mm" ver = "02" gw = "230" gh = "123"/>
</figure>
</s1>
<c-change/>
<s1 page = "2">
<ptxt>
Ak je potrebné, demontujte sací kôš olejového čerpadla.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Ak je potreba, demontujte zarážku olejovej vane a závrtné skrutky zarážky olejovej vane.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1506004002">
<title>
Montáž
</title>
<s1>
<ptxt>
Namontujte závrtnú skrutku ochranného plechu olejovej vane (1) ak bola odstránená a potom dotiahnite skrutku ochranného krytu olejovej vane na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1E004">
<t-part>
Závrtná skrutka ochranného krytu olejovej vane
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Namontujte ochranný plech olejovej vane (2) a dotiahnite skrutky ochranného plechu olejovej vane (3) na predpísaný moment.
</ptxt>
<torque>
<torqueitem id = "T1E005">
<t-part>
Skrutka ochranného krytu olejovej vane
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure page = "2">
<graphic graphicname = "I9P60A151002.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "177" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Na nové tesniace krúžky (1) naneste motorový olej a potom ich namontujte k filtru (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Namontujte filter olejového čerpadla s o-krúžkami na olejové čerpadlo a najskôr pripevnite skrutku (3) a maticu (4) na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1E006">
<t-part>
Skrutka filtra olejového čerpadla*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1E007">
<t-part>
Matica konzoly sita olejového čerpadla*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151003.jpg" width = "88.000mm" height = "12.350mm" ver = "01" gw = "199" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte vodiace kolíky (1) na olejovú vaňu do bloku motora.
</ptxt>
<figure>
<graphic graphicname = "I9P60A151004.jpg" width = "88.000mm" height = "12.350mm" ver = "01" gw = "207" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Na nový tesniaci krúžok (1) naneste motorový olej a tesniaci krúžok potom namontujte tak, ako je to zobrazené na obrázku.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Podľa obrázku plynulo naneste na dotykovú plochu olejovej vane tesniaci prostriedok.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Pred aplikovaním tesniaceho prostriedku sa uistite, že dotykové plochy sú čisté a suché.
</ptxt>
</item>
<item>
<ptxt>
Zotrite nadbytočný tesniaci prostriedok.
</ptxt>
</item>
<item>
<ptxt>
Do 2 minút po nanesení tesniaceho prostriedku namontujte olejovú vaňu.
</ptxt>
</item>
</list1>
</attention3>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1E002" uid = "-491504098">
<m-part>
„A“
</m-part>
<m-desc>
Tesniaci prostriedok
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<spec>
<title>
Množstvo tesniaceho prostriedku pre aplikáciu na olejovú vaňu
</title>
<ptxt>
Šírka “a”: 3 mm (0,12 in.)
</ptxt>
<ptxt>
výška &#34;b&#34;: 2 mm (0,08 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151017.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "146" gh = "153"/>
</figure>
</s1>
<s1>
<ptxt>
Olejovú vaňu namontujte k bloku motora a potom dotiahnite skrutky olejovej vane v číselnom poradí („1“ - „17“) rovnomerne a postupne na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1E008">
<t-part>
Skrutka olejovej vane*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151005.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "227" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Skrutky prevodovky (1) utiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1E009">
<t-part>
Skrutka prevodovky
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151006.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "227" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte olejový filter. 
<intxreftitleoff1 refid = "ASLAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte prevodovku. 
<intxreftitleoff1 refid = "ASLAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nasaďte výfukovú rúru č. 1. 
<intxreftitleoff1 refid = "ASLAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte pravý spodný kryt motora.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte vypúšťaciu zátku a doplňte motor motorovým olejom. 
<intxreftitleoff1 refid = "ASLAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte merač hladiny oleja.
</ptxt>
</s1>
<s1>
<ptxt>
Overte, či cez žiaden spoj neuniká motorový olej ani výfukové plyny.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
