<servinfosub id = "ASLAP70A7224023003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224023004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224023005">
<testgroup id = "ASLAP70A7224023006">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Zapnite spínač zapaľovania a skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1540?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224023008">
<title>
Kontrola poistky
</title>
<test1>
<ptxt>
Skontrolujte poistku &#34;MTR&#34;.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte poistku „MTR“ a skontrolujte, či je obvod uzemnený.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224023007">
<title>
Kontrola okruhu dodávky napätia akumulátora
</title>
<test1>
<ptxt>
Odpojte konektor panela automatickej klimatizácie.
</ptxt>
</test1>
<test1>
<ptxt>
Odmerajte napätie medzi svorkou vodiča „WHT/RED“ konektora panela automatickej klimatizácie a uzemnením.
</ptxt>
</test1>
<question>
Má napätie hodnotu 10 -14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte panel automatickej klimatizácie. 
<intxreftitleoff1 refid = "ASLAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
</testgroup>
