<servinfosub id = "ASLAP70A9304008003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A9304008004">
<testgroup id = "ASLAP70A9304008005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vymažte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1850?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte kvôli občasným problémom. 
<intxreftitleoff1 refid = "ASLAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A9304008006">
<title>
Kontrola okruhu komunikácie
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory združeného merača a riadiacej jednotky systému parkovacieho snímača.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek združeného merača a riadiacej jednotky systému parkovaiceho snímača.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte, či nie je okruh medzi konektorom združeného merača a riadiacej jednotky systému parkovacieho snímača prerušený, skratovaný k uzemneniu alebo skratovaný k napájaniu.
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Vymeňte združený merač a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ak je DTC B1850 detekovaný znovu, vymeňte riadiacu jednotku systému parkovacieho snímača. 
<intxreftitleoff1 refid = "ASLAP70A9306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod komunikačnej linky LIN.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
