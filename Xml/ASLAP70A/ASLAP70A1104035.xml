<servinfosub id = "ASLAP70A1104035003">
<title>
Postup potvrdenia DTC
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Cestnú skúšku vykonávajte na mieste, kde nie je doprava, aby ste predišli nehode.
</ptxt>
</item>
<item>
<ptxt>
Skúšobnú jazdu musia vykonať dve osoby, vodič a testujúca osoba a to na rovnej ceste.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné DTC nie sú detekované v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
OCV (P0010 / P0011 / P0013 / P0014)
</ptxt>
</item>
<item>
<ptxt>
Ovládač škrtiacej klapky (P2100 / P2101 / P2119)
</ptxt>
</item>
<item>
<ptxt>
Systém úpravy paliva (P0171 / P0172)
</ptxt>
</item>
<item>
<ptxt>
HO2S (P0137 / P0138 / P0140)
</ptxt>
</item>
<item>
<ptxt>
Snímač A/F (P0131 / P0132 / P0133)
</ptxt>
</item>
<item>
<ptxt>
Snímač MAF (P0100 / P0101 / P0102 / P0103)
</ptxt>
</item>
<item>
<ptxt>
Zaznamenanie zlyhania valca (P0300 / P0301 / P0302 / P0303 / P0304)
</ptxt>
</item>
<item>
<ptxt>
Vypúšťací ventil nádoby EVAP (P0443 / P0458 / P0459)
</ptxt>
</item>
<item>
<ptxt>
Snímač ECT (P0106 / P0107 / P0108) 
</ptxt>
</item>
<item>
<ptxt>
Snímač otáčok kolesa (P0500) 
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Naštartujte motor a jazdite vozidlom neustále pri rýchlosti 70 až 90 km/h (43 až 56 míľ/h) po dobu 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104035004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104035005">
<testgroup id = "ASLAP70A1104035006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104035007">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Skontrolujte DTC.
</ptxt>
</test1>
<question>
Je zobrazené iné DTC ako P0420?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104035008">
<title>
Kontrola výfukového systému
</title>
<test1>
<ptxt>
Skontrolujte, či na výfukovom systéme nie sú úniky, poškodenia alebo voľné spoje.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybné časti.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104035009">
<title>
Kontrola obvodu HO2S
</title>
<test1>
<ptxt>
Skontrolujte signálny a uzemňovací obvod podľa kroku 3 v časti 
<intxref refid = "ASLAP70A1104028">DTC P0137 / P0138 / P0140</intxref>
.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104035010">
<title>
Kontrola signálneho obvodu snímača A/F
</title>
<test1>
<ptxt>
Skontrolujte signálny obvod snímača A/F podľa kroku 3 v 
<intxref refid = "ASLAP70A1104025">DTC P0131 / P0132 / P2237 / P2243 / P2251/ P2626</intxref>
.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený vodič.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104035011">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte výfukové potrubie (zabudované v TWC). 
<intxreftitleoff1 refid = "ASLAP70A1B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte proces potvrdenia DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC P0420?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104035012">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte HO2S. 
<intxreftitleoff1 refid = "ASLAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC P0420?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104035013">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte snímač A/F. 
<intxreftitleoff1 refid = "ASLAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC P0420?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
