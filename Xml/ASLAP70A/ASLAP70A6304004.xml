<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A6304004" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Vymazanie DTC
</title>
<s1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte ku konektoru pre dátové spojenie (DLC) (1), ktorý sa nachádza v spodnej časti prístrojovej dosky na strane vodiča skenovacie zariadenie SUZUKI.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C002">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
Skenovacie zariadenie SUZUKI (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630006.jpg" width = "88.000mm" height = "67.502mm" ver = "03" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Vymažte DTC podľa pokynov zobrazených na skenovacom zariadení SUZUKI. Viac informácií nájdete v návode na obsluhu skenovacieho zariadenia SUZUKI.
</ptxt>
</s1>
<s1>
<ptxt>
Keď je zapaľovanie v polohe “OFF”, odpojte skenovacie zariadenie SUZUKI z DLC po dokončení mazania.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
