<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1706015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zostavy palivového čerpadla
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1706014">Kontrola palivového čerpadla vo vozidle</intxrefpoff>
</ptxt>
<attention1>
<ptxt>
Pri vykonávaní nasledujúceho postupu sa ubezpečte, že ste sa oboznámili s časťou 
<intxref refid = "ASLAP70A1700001">Bezpečnostné opatrenia pre servis palivového systému</intxref>
, aby ste znížili nebezpečenstvo požiaru alebo zranenia osôb.
</ptxt>
</attention1>
<attention2>
<ptxt>
Nikdy nedemontujte zostavu palivového čerpadla okrem senzora hladiny paliva. Ak objavíte chybu, vymeňte ho za nové.
</ptxt>
</attention2>
<servinfosub id = "ASLAP70A1706015001" page = "2">
<title>
Demontáž
</title>
<s1 page = "2">
<ptxt>
Z vozidla demontujte palivovú nádrž. 
<intxreftitleoff1 refid = "ASLAP70A1706011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odpojte potrubie prívodu paliva (1) od zostavy palivového čerpadla (2). 
<intxreftitleoff1 refid = "ASLAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure page = "2">
<graphic graphicname = "I9P60A171009.swf" width = "88.000mm" height = "43.559mm" ver = "01" gw = "176" gh = "107"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Pomocou špeciálneho nástroja demontujte zaisťovaciu maticu palivového čerpadla (1) z palivovej nádrže (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L1G013">
<s-part>
(A)
</s-part>
<s-number num = "09941-51013">
09941–51013
</s-number>
</servicetoolitem>
</servicetool>
<figure page = "2">
<graphic graphicname = "I7V20A171016.swf" width = "88.000mm" height = "51.053mm" ver = "01" gw = "137" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Zodvihnite zostavu palivového čerpadla a odpojte palivovú nasávaciu hadicu (1) zo zostavy palivového čerpadla. 
<intxreftitleoff1 refid = "ASLAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "IAP70P170012.swf" width = "88.000mm" height = "78.039mm" ver = "01" gw = "190" gh = "205"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Z palivovej nádrže odmontujte jednotku palivového čerpadla a tesniaci krúžok.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1706015002" page = "2">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1706018">Kontrola snímača hladiny paliva</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Vyčistite vonkajšie povrchy potrubia, kam chcete pripevniť spoj. Spoj zatlačte na potrubie, až kým nezačujete kliknutie. A skontrolujte, či sú potrubia pripojené pevne. Ak tak neurobíte, môže to viesť k unikaniu paliva.
</ptxt>
</attention2>
<s1 page = "2">
<ptxt>
Očistite povrch častí, ktoré budú spájať jednotku palivového čerpadla s palivovou nádržou.
</ptxt>
</s1>
<s1>
<ptxt>
K palivovej nádrži (2) namontujte nový tesniaci krúžok (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B170007.swf" width = "88.000mm" height = "56.952mm" ver = "01" gw = "199" gh = "145"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
K zostave palivového čerpadla (1) pripojte palivové nasávacie potrubie (2).
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P170012.swf" width = "88.000mm" height = "78.039mm" ver = "01" gw = "190" gh = "205"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Na palivovú nádrž (2) namontujte zostavu palivového čerpadla (1) nasledovne.
</ptxt>
<s2>
<ptxt>
Značku šípky (3) na zostave palivového čerpadla vyrovnajte s výrezom (4) palivovej nádrži.
</ptxt>
</s2>
<s2>
<ptxt>
Zostavu palivového čerpadla stláčajte dole rukou, až kým sa nedostane do kontaktu s palivovou nádržou tak, ako je to zobrazené na obrázku.
</ptxt>
<figure>
<graphic graphicname = "IBP60B170008.swf" width = "88.000mm" height = "90.025mm" ver = "01" gw = "219" gh = "239"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.857in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Tesniaci krúžok
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
V stave kroku b) dotiahnite novú poistnú maticu palivového čerpadla (1) rukou.
</ptxt>
<attention2>
<ptxt>
Používajte iba novú poistnú maticu palivového čerpadla. Opätovné použitie poistnej matice palivového čerpadla môže viesť k unikaniu paliva.
</ptxt>
</attention2>
<attention3>
<ptxt>
Poistnú maticu doťahujte tak, že ju budete rovno stláčať, aby sa nevychyľovala.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IBP60B170009.swf" width = "88.000mm" height = "89.491mm" ver = "01" gw = "200" gh = "237"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.427in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.850in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Zostava palivového čerpadla
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Tesniaci krúžok
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Palivová nádrž
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
Pomocou špeciálneho nástroja dotiahnite poistnú maticu palivového čerpadla (1), kým nie sú značky (3) poistnej matice palivového čerpadla a palivovej nádrže zarovnané.
</ptxt>
<attention3>
<ptxt>
Značky sú zarovnané, keď poistnú maticu palivového čerpadla dotiahnete približne o 1 a 1/3 otáčky.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1G014">
<s-part>
(A)
</s-part>
<s-number num = "09941-51013">
09941–51013
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A171018.swf" width = "88.000mm" height = "89.624mm" ver = "01" gw = "152" gh = "238"/>
</figure>
</s2>
</s1>
<s1 page = "2">
<ptxt>
Na zostavu palivového čerpadla (2) pripojte potrubie prívodu paliva (1). 
<intxreftitleoff1 refid = "ASLAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure page = "2">
<graphic graphicname = "I9P60A171009.swf" width = "88.000mm" height = "43.559mm" ver = "01" gw = "176" gh = "107"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Do vozidla namontujte palivovú nádrž. 
<intxreftitleoff1 refid = "ASLAP70A1706011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
