<servinfo servinfosgmlid = "ASLAP70A9206008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zadného združeného svetla
</title>
<servinfosub id = "ASLAP70A9206008001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte skrutky zadného združeného svetla (1).
</ptxt>
</s1>
<s1>
<ptxt>
Vytiahnite zadné združené svetlo (2) v smere šípky podľa obrázku pre uvoľnenie spojovacích kolíkov (4) a vyberte zadné združené svetlo.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor zadného združeného svetla.
</ptxt>
<attention3>
<ptxt>
Skontrolujte priechodku, či nie je deformovaná.
</ptxt>
<ptxt>
Podľa potreby ju vymeňte.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A920003.jpg" width = "88.000mm" height = "58.609mm" ver = "01" gw = "204" gh = "150"/>
<callout-l>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Priechodka
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout-l>
</figure>
</s1>
<s1>
<ptxt>
Ak je to potrebné, vyberte žiarovky.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9206008002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
