<servinfosub id = "ASLAP70A1104044003">
<title>
Postup potvrdenia DTC
</title>
<topic id = "ASLAP70A1104044004">
<title>
P0560:
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ na 1 min.
</ptxt>
</s1>
</topic>
<topic id = "ASLAP70A1104044005">
<title>
P0562 / P0563:
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Cestnú skúšku vykonávajte na mieste, kde nie je doprava, aby ste predišli nehode.
</ptxt>
</item>
<item>
<ptxt>
Skúšobnú jazdu musia vykonať dve osoby, vodič a testujúca osoba a to na rovnej ceste.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0500 nie je detekovaný.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Naštartujte motor a zohrejte ho na bežnú prevádzkovú teplotu.
</ptxt>
</s1>
<s1>
<ptxt>
Choďte s autom nepretržite rýchlosťou 40 až 60 km/h (25 až 37 míľ/h) 10 min., alebo viac. 
</ptxt>
</s1>
</topic>
</servinfosub>
<servinfosub id = "ASLAP70A1104044006">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104044007">
<testgroup id = "ASLAP70A1104044008">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104044009">
<title>
Kontrola obvodu uzemnenia a napájania riadiacej jednotky motora
</title>
<test1>
<ptxt>
Skontrolujte napájacie a uzemňovacie obvody ECM. 
<intxreftitleoff1 refid = "ASLAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte napájací a uzemňovací obvod ECM.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
