<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7224A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Chladný vzduch neprúdi alebo chladenie nie je dostatočné (pri bežnej prevádzke magnetickej spojky)
</title>
<diag type = "condition">
<condition>
<ptxt>
Chladný vzduch neprúdi alebo chladenie nie je dostatočné (pri bežnej prevádzke magnetickej spojky)
</ptxt>
</condition>
<ps>
<ptxt>
Primálo alebo priveľa chladiacej kvapaliny
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte, či je v systéme správne množstvo chladiacej zmesi a či zmes zo systému neuniká.
</ptxt>
</action>
<ps>
<ptxt>
Upchatý kondenzátor
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte kondenzátor. 
<intxreftitleoff1 refid = "ASLAP70A7226005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Upchatý alebo zamrznutý výparník klimatizácie
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte výparník klimatizácie a snímač teploty výparníka klimatizácie 
<intxreftitleoff1 refid = "ASLAP70A7226017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 a 
<intxreftitleoff1 refid = "ASLAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha snímača teploty výparníka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte snímač teploty výparníka. 
<intxreftitleoff1 refid = "ASLAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha expanzného ventilu
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte expanzný ventil. 
<intxreftitleoff1 refid = "ASLAP70A7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Upchatý sušič
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte sušič a veko s filtrom.
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnený alebo pretrhnutý hnací remeň kompresora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte hnací remeň kompresora. 
<intxreftitleoff1 refid = "ASLAP70A7226043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Preklzujúca magnetická spojka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte magnetickú spojku. 
<intxreftitleoff1 refid = "ASLAP70A7226047"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kompresora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte kompresor.
</ptxt>
</action>
<ps>
<ptxt>
Vzduch v klimatizačnom systéme
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kondenzátor a potom systém vypustite a znova naplňte. 
<intxreftitleoff1 refid = "ASLAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Unikanie vzduchu z jednotky HVAC alebo vzduchového potrubia
</ptxt>
</ps>
<action>
<ptxt>
Opravte jednotku HVAC alebo vzduchové potrubie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha ohrievača a ventilačného systému
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte jednotku HVAC.
</ptxt>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky HVAC
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte riadiacu jednotku HVAC 
<intxreftitleoff1 refid = "ASLAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha ovládača regulácie teploty
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte ovládač riadenia teploty. 
<intxreftitleoff1 refid = "ASLAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha motora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte elektromotor ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7226012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nadbytok oleja kompresora v klimatizačnom systéme
</ptxt>
</ps>
<action>
<ptxt>
Vypustite nadbytočný olej kompresora z okruhu a kompresora klimatizačného systému.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
