</ptxt>
</ps>
<action>
<ptxt>
Vymeňte vnútornú rukoväť dverí 
<intxreftitleoff1 refid = "ASLAP70A9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
