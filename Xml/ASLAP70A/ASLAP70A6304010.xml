<servinfosub id = "ASLAP70A6304010002">
<title>
Riešenie problémov
</title>
<diag type = "test" id = "ASLAP70A6304010003">
<testgroup id = "ASLAP70A6304010004">
<title>
Kontrola výstražnej kontrolky „P/S“
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<question>
Rozsvietili sa ostatné výstražné kontrolky?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304010005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70A6304003">Kontrola DTC</intxref>
.
</ptxt>
</test1>
<question>
Je zistené DTC U0073 alebo DTC U0155?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70AA804002">Tabuľka DTC CAN (strata komunikácie a vypnutie komunikačnej zbernice)</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304010006">
<title>
Kontrola združeného merača
</title>
<test1>
<ptxt>
Vymeňte združený prístroj. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<question>
Zostane výstražná kontrolka P/S vypnutá?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku posilňovača riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304010007">
<title>
Kontrola poistky
</title>
<question>
Je obvod poistky združeného merača v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Vymeňte poistku a skontrolujte, či je obvod uzemnený.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304010008">
<title>
Kontrola komunikačného obvodu CAN
</title>
<test1>
<ptxt>
Skontrolujte komunikačný obvod CAN medzi združeným meračom a riadiacou jednotkou P/S. 
<intxreftitleoff1 refid = "ASLAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je komunikačný obvod CAN v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Opravte alebo vymeňte.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304010009">
<title>
Kontrola obvodu napájania združeného prístroja
</title>
<test1>
<ptxt>
Odmontujte združený merač. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte konektor združeného merača, či je správne pripojený.
</ptxt>
</test1>
<test1>
<ptxt>
Ak je výsledok kontroly v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte či je napätie medzi svorkou „G240-3“ a „G240-5“ akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte združený merač a opätovne skontrolujte. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 7.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304010010">
<title>
Kontrola obvodu uzemnenia združeného merača
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte či je odpor medzi svorkou „G240-5“ a uzemnením 1 Ω alebo menej.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Opravte alebo vymeňte obvod „A1“.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte obvod „A1“.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
