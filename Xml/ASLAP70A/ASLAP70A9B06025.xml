<title>
Demontáž a montáž strešného plechu
</title>
<attention3>
<ptxt>
Nižšie uvedený obrázok zobrazuje podmienky odstraňovania nasledovných častí.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predný blatník 
<intxreftitleoff1 refid = "ASLAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0181.jpg" width = "88.000mm" height = "55.869mm" ver = "02" gw = "227" gh = "142"/>
</figure>
<servinfosub id = "ASLAP70A9B06025001">
<title>
Všeobecné poznámky
</title>
<ptxt>
Konzoly strechy môžete použiť opätovne.
</ptxt>
</servinfosub>
<servinfosub id = "ASLAP70A9B06025002">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odvŕtajte body zvaru a odstráňte 4 nosné konzoly strechy a strešný plech.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A9B0024.jpg" width = "183.000mm" height = "215.042mm" ver = "01" gw = "467" gh = "593"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.438in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.472in"/>
<colspec colnum = "4" colname = "4" colwidth = "4.537in"/>
