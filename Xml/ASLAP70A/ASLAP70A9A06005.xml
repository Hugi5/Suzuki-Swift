<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž predného blatníka
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9A06004">Diely predného blatníka</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A9A06005001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte predný blatník a držiak predného blatníka. 
<intxreftitleoff1 refid = "ASLAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte obloženie krytu s bočným obložením krytu medzi čelným sklom a kapotou motora. 
<intxreftitleoff1 refid = "ASLAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte montážnu zostavu svetlometu. 
<intxreftitleoff1 refid = "ASLAP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte pravé smerové svetlo. 
<intxreftitleoff1 refid = "ASLAP70A9206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte bočný ochranný prah. 
<intxreftitleoff1 refid = "ASLAP70A9806007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte obloženie predného blatníka.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte predný blatník a kryt predného blatníka.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9A06005002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Upravte vôľu plechu predného blatníka. 
<intxreftitleoff1 refid = "ASLAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ak sa farba zo skrutiek predného blatníka olúpala, zabezpečte, aby sa naniesla znovu, aby ste predišli korózii.
</ptxt>
</item>
<item>
<ptxt>
Po montáži zacieľte predné svetlomety. 
<intxreftitleoff1 refid = "ASLAP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
