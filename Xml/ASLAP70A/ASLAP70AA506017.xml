<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70AA506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž vonkajšieho výstražného bzučiaka
</title>
<servinfosub id = "ASLAP70AA506017001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte obloženie predného podbehu na strane vodiča. 
<intxreftitleoff1 refid = "ASLAP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor (1) a potom odmontujte vonkajší výstražný bzučiak (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50032.jpg" width = "88.000mm" height = "68.823mm" ver = "01" gw = "213" gh = "179"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA506017002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70AA506018">Kontrola vonkajšieho výstražného bzučiaka</intxrefpoff>
</ptxt>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
