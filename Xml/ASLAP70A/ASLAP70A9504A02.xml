<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A9504A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nedá sa ovládať jedno okno
</title>
<diag type = "condition">
<condition>
<ptxt>
Nedá sa ovládať jedno okno
</ptxt>
</condition>
<ps>
<ptxt>
Porucha zväzku
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha ovládača a/alebo motora elektrického sťahovania okien
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Predný: 
<intxreftitleoff1 refid = "ASLAP70A9506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A9506018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porucha hlavného spínača elektricky ovládaného okna
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506019">Kontrola hlavného spínača elektricky ovládaného okna</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha pomocného spínača elektricky ovládaného okna
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506020">Kontrola vedľajšieho spínača elektricky ovládaného okna</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Spínač uzamykania okna je stlačený (poloha uzamknutia)
</ptxt>
</ps>
<action>
<ptxt>
Vypnite spínač uzamykania okna
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
