<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1306015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž snímača A/F a HO2S
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1306013">Kontrola snímača A/F na vozidle</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A1306014">Kontrola HO2S vozidla</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1306015001">
<title>
Demontáž
</title>
<attention1>
<ptxt>
Nedotýkajte sa výfukového systému, kým je horúci, aby ste sa vyhli popáleniu. Demontáž snímača A/F a/alebo HO2S by ste mali vykonávať keď je systém studený.
</ptxt>
</attention1>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor snímača A/F a/alebo HO2S.
</ptxt>
</s1>
<s1>
<ptxt>
Z výfukového potrubia vyberte snímač A/F (1) a/alebo HO2S (2).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1306015002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utiahnite snímač A/F (1) na stanovený uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1C003">
<t-part>
Snímač A/F
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,5
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
HO2S (2) utiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1C004">
<t-part>
HO2S
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,5
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A131013.swf" width = "88.000mm" height = "49.001mm" ver = "01" gw = "174" gh = "122"/>
</figure>
</item>
<item>
<ptxt>
Po inštalácii skontrolujte únik výfuku zo senzora pri spustenom motore.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
