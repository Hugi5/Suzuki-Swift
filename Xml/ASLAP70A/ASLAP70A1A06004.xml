<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1A06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž hnacieho remeňa vodného čerpadla/alternátora
</title>
<servinfosub id = "ASLAP70A1A06004001" page = "2">
<title>
Demontáž
</title>
<s1 page = "2">
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte pravý spodný kryt motora.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Hnací remeň kompresora odstráňte pred vybratím hnacieho remeňa vodného čerpadla/alternátora (1).
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s manuálnou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatickou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Uvoľnite skrutku alternátora (2) a otočný čap alternátora (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uvoľnite nastavovaciu skrutku alternátora (4), a potom uvoľnite remeň vodného čerpadla/alternátora.
</ptxt>
<figure>
<graphic graphicname = "I7V20A1A1008.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "148" gh = "123"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1A06004002" page = "2">
<title>
inštalácia
</title>
<s1 page = "2">
<ptxt>
Hnací remeň vodného čerpadla/alternátora (1) nasaďte na remenicu vodného čerpadla (2), remenicu kľukového hriadeľa (3) a remenicu alternátora (4).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Nastavte napnutie remeňa. 
<intxreftitleoff1 refid = "ASLAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nainštalujte hnací remeň kompresora.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s manuálnou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatickou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Uistite sa, že je hnací remeň nainštalovaný správne v drážkach každej kladky.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I7V20A1A1009.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "140" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte pravý spodný kryt motora.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Pripojte kábel záporného (-) pólu k akumulátoru.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
