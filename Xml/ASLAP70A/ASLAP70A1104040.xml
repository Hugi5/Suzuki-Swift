<servinfosub id = "ASLAP70A1104040003">
<title>
Postup potvrdenia DTC
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Cestnú skúšku vykonávajte na mieste, kde nie je doprava, aby ste predišli nehode.
</ptxt>
</item>
<item>
<ptxt>
Skúšobnú jazdu musia vykonať dve osoby, vodič a testujúca osoba a to na rovnej ceste.
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Naštartujte motor a zohrejte ho na bežnú prevádzkovú teplotu.
</ptxt>
</s1>
<s1>
<ptxt>
Jazdite vozidlom rýchlosťou 50 až 70 km/h (31 až 43 míľ/hod.).
</ptxt>
</s1>
<s1>
<ptxt>
Zastavte vozidlo.
</ptxt>
</s1>
<s1>
<ptxt>
Stlačte brzdový pedál.
</ptxt>
</s1>
<s1>
<ptxt>
Kroky 2) až 4) 10-krát zopakujte.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104040004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104040005">
<testgroup id = "ASLAP70A1104040006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104040007">
<title>
Kontrola obvodu napájania spínača brzdového svetla
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté, odpojte konektor spínača brzdového svetla.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektoru spínača brzdového svetla.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi každým obvodom „A1“ a „A2“ a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104040008">
<title>
Kontrola obvodu signálu spínača brzdových svetiel
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „B2“ alebo „C1“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „B1“ a „B2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B1“ a ďalšou svorkou v konektore spínača brzdových svetiel: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B2“ a ďalšou svorkou v konektore spínača brzdových svetiel: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodov „B1“ alebo „B2“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104040009">
<title>
Kontrola spínača brzdových svetiel
</title>
<test1>
<ptxt>
Skontrolujte spínač brzdových svetiel. 
<intxreftitleoff1 refid = "ASLAP70A4106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte spínač brzdových svetiel.
</ptxt>
</action>
</testgroup>
</diag>
