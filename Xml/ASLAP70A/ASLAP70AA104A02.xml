<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10A">
<servcat sctnbr = "10" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70AA104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Rýchlosť vozidla sa nedá nastaviť
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Skôr, ako vykonáte diagnózu symptómov tempomatu vykonajte kontrolu tempomatu podľa 
<intxref refid = "ASLAP70AA104001">Kontrola tempomatu</intxref>
 .
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte každú súčiastku v poradí zhora nasledujúceho zoznamu.
</ptxt>
</item>
</list1>
</attention3>
<diag type = "condition">
<condition>
<ptxt>
Rýchlosť vozidla sa nedá nastaviť
</ptxt>
</condition>
<ps>
<ptxt>
Porucha HLAVNÉHO (ON/OFF) spínača
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte činnosť spínača MAIN (ON/OFF) podľa 
<intxref refid = "ASLAP70AA106002">Kontrola tempomatu</intxref>
 .
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača SET/COAST
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte činnosť spínača SET/COAST podľa 
<intxref refid = "ASLAP70AA106002">Kontrola tempomatu</intxref>
 .
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača brzdového osvetlenia
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte činnosť spínača brzdových svetiel podľa 
<intxref refid = "ASLAP70AA106006">Kontrola spínača brzdových svetiel</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača CPP č. 2
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte činnosť spínača CPP č. 2 podľa 
<intxref refid = "ASLAP70AA106004">Kontrola spínača CPP č. 2</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte.
</ptxt>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky motora
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte po uistení sa, že nie je chybná žiadna z vyššie uvedených súčiastok.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
