<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4D">
<servcat sctnbr = "04" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4406004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž kábla parkovacej brzdy
</title>
<servinfosub id = "ASLAP70A4406004001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odpojte kábel parkovacej brzdy od páky zadného brzdového strmeňa. 
<intxreftitleoff1 refid = "ASLAP70A4306007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zložte zadnú skriňu konzoly podlahy. 
<intxreftitleoff1 refid = "ASLAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte z vozidla lanko parkovacej brzdy. 
<intxreftitleoff1 refid = "ASLAP70A4406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<attention3>
<ptxt>
Ak je to potrebné, demontujte pravé aj ľavé lanko parkovacej brzdy, opakujte vyššie uvedený krok.
</ptxt>
</attention3>
</servinfosub>
<servinfosub id = "ASLAP70A4406004002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Namontujte poriadne svorky. 
<intxreftitleoff1 refid = "ASLAP70A4406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skrutky utiahnite na predpísaný uťahovací moment. 
<intxreftitleoff1 refid = "ASLAP70A4406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či je koniec lanka parkovacej brzdy namontovaný na vyrovnávači a páke zadného brzdového strmeňa.
</ptxt>
</item>
<item>
<ptxt>
Nastavte kábel parkovacej brzdy. 
<intxreftitleoff1 refid = "ASLAP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Po ukončení montáže a nastavení zdvihu páky parkovacej brzdy sa uistite, že brzdový systém pracuje správne.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
