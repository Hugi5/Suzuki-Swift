<servinfosub id = "ASLAP70A1104018003">
<title>
Postup potvrdenia DTC
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Cestnú skúšku vykonávajte na mieste, kde nie je doprava, aby ste predišli nehode.
</ptxt>
</item>
<item>
<ptxt>
Skúšobnú jazdu musia vykonať dve osoby, vodič a testujúca osoba a to na rovnej ceste.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0100, P0102, P0103, P0112, P0113, P2100, P2101, P2176, P2228 alebo P2229 nie sú detekované.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Naštartujte motor a jazdite vozidlom neustále pri rýchlosti 50 až 70 km/h (31 až 43 míľ/h) po dobu 3 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104018004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104018005">
<testgroup id = "ASLAP70A1104018006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104018007">
<title>
Kontrola systému nasávania vzduchu a výfukového systému
</title>
<test1>
<ptxt>
Skontrolujte nasávací systém, výfukový sytém, vákuovú hadicu a PCV hadicu, či nie sú upchaté alebo poškodené.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybnú časť.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104018008">
<title>
Teleso škrtiacej klapky
</title>
<test1>
<ptxt>
Skontrolujte výkon zariadenia telesa škrtiacej klapky. 
<intxreftitleoff1 refid = "ASLAP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte teleso škrtiacej klapky.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104018009">
<title>
Kontrola snímača MAF a jeho obvodu
</title>
<test1>
<ptxt>
Skontrolujte snímač MAF a jeho obvod podľa kroku 2 až 6 v časti 
<intxref refid = "ASLAP70A1104017">DTC P0100 / P0102 / P0103</intxref>
.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybnú časť.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104018010">
<title>
Riešenie problémov ďalších DTC v rovnakom čase
</title>
<question>
Zostilo sa súčasne iné DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
