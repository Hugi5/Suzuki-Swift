<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9906005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Nastavenie skla strešného okna
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9906001">Komponenty strešného okna</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Uvoľnite 4 upevňovacie skrutky strešného okna a posuňte sklo strešného okna (1) hore a dole 2 až 3-krát. Takýmto spôsobom sa dá sklo posuvnej strechy umiestnisť vo vertikálnom aj v horizontálnom smere vďaka elasticite tesniacej pásky (2).
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Umiestnite sklo strešného okna podľa predpísaného.
</ptxt>
<spec>
<title>
Poloha skla strešného okna
</title>
<ptxt>
„a”: 1 mm (0,04 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A990002.swf" width = "88.000mm" height = "105.991mm" ver = "02" gw = "227" gh = "283"/>
</figure>
</s1>
<s1>
<ptxt>
Dotiahnite 4 upevňovacie skrutky strešného okna na predpísaný uťahovací moment podľa 
<intxref refid = "ASLAP70A9906001">Komponenty strešného okna</intxref>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Po správnom nastavení skontrolujte činnosť strešného okna (posunutie, vyklopenie, funkciu proti zacviknutiu). 
<intxreftitleoff1 refid = "ASLAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
