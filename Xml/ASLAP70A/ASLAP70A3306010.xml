<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3306010" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola zostavy rozvodovky
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A3306005">Rozobratie a zloženie zariadenia rozvodovky</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A3306003">Odpojenie a pripojenie rozvodovky</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte každé ložisko, či sa otáča plynulo, či nie je opotrebované alebo ináč sfarbené.
</ptxt>
<ptxt>
Ak nájdete abnormalitu, ložisko vymeňte.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či olejové tesnenie tesní a krúžok nie je príliš tvrdý
</ptxt>
<ptxt>
V prípade zistenia odchýlky olejové tesnenie vymeňte.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či nie je skriňa rozvodovky prasknutá.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či pastorok a kužeľové súkolesie nie sú opotrebované alebo prasknuté.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
