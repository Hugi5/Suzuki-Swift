<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A6104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hluk riadenia (klepanie alebo klokotanie)
</title>
<diag type = "condition">
<condition>
<ptxt>
Hluk riadenia (klepanie alebo klokotanie)
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnené skrutky skrine prevodovky riadenia
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite skrutku skrine prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nesprávny kontakt zubov medzi ozubenou tyčou a pastorkom
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Skontrolujte krútiaci moment otáčania ozubenej tyče a pastorka. 
<intxreftitleoff1 refid = "ASLAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ak je poruchový, vymeňte zariadenie prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Poškodená zostava skrine prevodovky riadenia
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu skrine prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rozbité alebo inak poškodené ložiská kolies
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte ložisko(á) kolesa. 
<intxreftitleoff1 refid = "ASLAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované konce spojovacej tyče alebo vnútorné guľové čapy spojovacej tyče
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vymeňte koniec spojovacej tyče alebo spojovaciu tyč.
</ptxt>
<ptxt>
Hlava riadiacej tyče: 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Riadiaca tyč: 
<intxreftitleoff1 refid = "ASLAP70A6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
