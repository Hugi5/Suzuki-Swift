<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A4604016" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1015 / C1017 / C1023
</title>
<servinfosub id = "ASLAP70A4604016001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.257in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.924in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1015: Porucha pozdĺžneho snímača G v zariadení snímača uhlovej rýchlosti vozidla/snímača G
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Signál pozdĺžneho snímača G je mimo predpísaného rozsahu.
</ptxt>
</item>
<item>
<ptxt>
Signál pozdĺžneho snímača G sa nezmení napriek tomu, že vozidlo pridáva alebo spomaľuje.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka ESP<sup>®</sup>
</ptxt>
</item>
<item>
<ptxt>
Konzola budiča
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1017: Výkon obvodu bočného G snímača
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Signál bočného snímača G je mimo predpísaného rozsahu.
</ptxt>
</item>
<item>
<ptxt>
Signál bočného snímača G sa nezmení napriek tomu, že vozidlo zatáča doprava alebo doľava.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1023: Výkon obvodu snímača rýchlosti stáčania
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Signál snímača uhlovej rýchlosti vozidla je mimo rozsah.
</ptxt>
</item>
<item>
<ptxt>
Napriek tomu, že je vozidlo zastavené, signál snímača uhlovej rýchlosti je vyšší ako predpísaná hodnota.
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70A4604016002">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A4604016003">
<testgroup id = "ASLAP70A4604016004">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604016006">
<title>
Kontrola riadiacej jednotky ESP® a konzoly budiča
</title>
<test1>
<ptxt>
Skontrolujte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a konzolu budiča. 
<intxreftitleoff1 refid = "ASLAP70A4606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybné časti.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604016005">
<title>
Kontrola DTC pre ESP®
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70A4604005">Kontrola DTC</intxref>
.
</ptxt>
</test1>
<question>
Sú zobrazené iné DTC ako C1015, C1017 a C1023?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným procesom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
