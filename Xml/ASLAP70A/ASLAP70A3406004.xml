<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3406004" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zostavy kardanového hriadeľa
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A3406002">Demontáž a montáž kĺbového hriadeľa</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A3406004001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Pred odmontovaním kardanového hriadeľa si na každej spojovacej prírube (2), viskóznej spojke (3) a kĺbovom hriadeli (4) vyznačte značky (1) podľa obrázku.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte kardanový hriadeľ č. 1 (5), č. 2 (7) a stredový hriadeľ (6).
</ptxt>
<figure>
<graphic graphicname = "IAP70A340008.swf" width = "88.000mm" height = "38.820mm" ver = "01" gw = "197" gh = "94"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A3406004002">
<title>
Zloženie
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A3406005">Demontáž a montáž spojky</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačným postupom ako pri rozobratí a všímajte si nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pri opätovnej montáži zostavy kardanového hriadeľa zarovnajte značky (1). V opačnom prípade sa pri jazde môžu vyskytnúť vibrácie.
</ptxt>
</item>
<item>
<ptxt>
Dotiahnite matice stredovej spojky a skrutky kardanového hriadeľa č. 2 na predpísaný uťahovací moment.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T3D003">
<t-part>
Matica stredovej spojky
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
<torqueitem id = "T3D004">
<t-part>
Skrutka kardanového hriadeľa č. 2
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A340009.swf" width = "88.000mm" height = "46.800mm" ver = "01" gw = "198" gh = "116"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
