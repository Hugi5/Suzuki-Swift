<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70AA324001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Kontrola riadiaceho systému imobilizéra
</title>
<diag type = "test" id = "ASLAP70AA324001001">
<testgroup id = "ASLAP70AA324001003">
<title>
Kontrola zapnutia zapaľovania
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“
</ptxt>
</test1>
<test1>
<ptxt>
Stlačte spojkový pedál.
</ptxt>
</test1>
<question>
Rozsvieti sa kontrolka ON a PUSH?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70AA504001">Kontrola systému bezkľúčového štartovania</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA324001004">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Nachádza sa tam nejaké chybné DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA324001006">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Skontrolujte DTC prislúchajúce ku komunikácii CAN.
</ptxt>
</test1>
<question>
Našli ste nejaké CAN-DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA324001005">
<question>
Je motor naštartovaný?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1904001">Diagnostika symptómov štartovania</intxref>
“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA324001002">
<title>
Kontrola štartovania motora
</title>
<question>
Štartuje motor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Riadiaci systém imobilizéra je v dobrom stave.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104009">Základná kontrola motora</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
