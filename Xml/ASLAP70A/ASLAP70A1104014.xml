<servinfosub id = "ASLAP70A1104014003">
<title>
Postup potvrdenia DTC
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Cestnú skúšku vykonávajte na mieste, kde nie je doprava, aby ste predišli nehode.
</ptxt>
</item>
<item>
<ptxt>
Skúšobnú jazdu musia vykonať dve osoby, vodič a testujúca osoba a to na rovnej ceste.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0010 alebo P0013 nie sú detekované.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Naštartujte motor a jazdite vozidlom pri rýchlosti 60 až 80 km/h (37 až 50 míľ/h) viac ako 10 min. s otáčkami motora 1600 ot/min. alebo viac.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104014004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104014005">
<testgroup id = "ASLAP70A1104014006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104014007">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Skontrolujte DTC.
</ptxt>
</test1>
<question>
Sú zobrazené iné DTC ako P0011 a P0014?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104014008">
<title>
Kontrola obvodu napájania OCV a obvodu pohonu OCV
</title>
<test1>
<ptxt>
Skontrolujte obvody „A1“ alebo „B1“ a „A2“ alebo „B2“ podľa krokov 2 a 3 v 
<intxref refid = "ASLAP70A1104013">DTC P0010 / P0013 / P2088 / P2089 / P2090 / P2091</intxref>
 .
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104014009">
<title>
Kontrola tlaku oleja
</title>
<test1>
<ptxt>
Skontrolujte tlak oleja. 
<intxreftitleoff1 refid = "ASLAP70A1504001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybné časti.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104014010">
<title>
Vizuálna kontrola obvodu oleja OCV
</title>
<test1>
<ptxt>
Odmontujte kryt hlavy valca. 
<intxreftitleoff1 refid = "ASLAP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte obvod oleja OCV, či sa niekde nevyskytuje únik tlaku oleja.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybné časti.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104014011">
<title>
Kontrola snímača CKP a klapky snímača
</title>
