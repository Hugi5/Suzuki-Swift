</action>
</testgroup>
<testgroup id = "ASLAP70A1104014013">
<title>
Kontrola OCV
</title>
<test1>
<ptxt>
Skontrolujte OCV. 
<intxreftitleoff1 refid = "ASLAP70A1306027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
