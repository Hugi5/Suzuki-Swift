</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Regulátor CMP vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104014015">
<title>
Kontrola časovania ventilov
</title>
<test1>
<ptxt>
Skontrolujte časti rozvodovej reťaze a ich podmienky inštalácie. 
<intxreftitleoff1 refid = "ASLAP70A1406023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
