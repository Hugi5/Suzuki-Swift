<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A9504A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Všetky ohrievače vonkajších spätných zrkadiel nefungujú
</title>
<diag type = "condition">
<condition>
<ptxt>
Všetky ohrievače vonkajších spätných zrkadiel nefungujú
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte poistku a skontrolujte, či okruh nie je skratovaný.
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača vyhrievania zrkadiel
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506008">Kontrola spínača odhmlievania zadného okna</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Kontrola BCM a jej obvodov: v časti 10B.
</ptxt>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
