<title>
Demontáž a montáž riadiacej jednotky HVAC
</title>
<servinfosub id = "ASLAP70A7226010001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Vyberte panel automatickej klimatizácie. 
<intxreftitleoff1 refid = "ASLAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte skrutky (1).
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte riadiacu jednotku HVAC (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor riadiacej jednotky HVAC.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723022.swf" width = "88.000mm" height = "58.912mm" ver = "01" gw = "226" gh = "150"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7226010002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
