<emph>
B1011: Chybné zariadenie SDM
</emph>
</ptxt>
<ptxt>
SDM nie je konzistentné s ID kódom.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
SDM
</ptxt>
</item>
</list1>
