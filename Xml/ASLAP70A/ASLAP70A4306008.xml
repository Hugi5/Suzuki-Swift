<section sectnbr = "4C">
<servcat sctnbr = "04" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4306008" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Montáž a demontáž strmeňa zadnej brzdy
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4306001">Súčiastky zadných bŕzd</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A4306007">Demontáž a montáž strmeňa zadnej brzdy</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Dávajte pozor, aby ste nepoškodili piest a valec strmeňa zadnej brzdy.
</ptxt>
</attention2>
<servinfosub id = "ASLAP70A4306008001">
<title>
Demontáž
</title>
<topic id = "ASLAP70A4306008002">
<title>
Piestik strmeňa
</title>
<s1>
<ptxt>
Vyčistite povrchy okolo strmeňa.
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite brzdový piest (1) otočením v smere šípky pomocou špeciálneho nástroja.
</ptxt>
<servicetool>
<servicetoolitem id = "L4C005">
<s-part>
(A)
</s-part>
<s-number num = "09945-16030">
09945–16030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A432029.swf" width = "88.000mm" height = "43.929mm" ver = "01" gw = "141" gh = "108"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.760in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Kryt valca
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Demontujte manžetu valca (1) a odvzdušňovaciu zátku (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432042.swf" width = "88.000mm" height = "41.550mm" ver = "02" gw = "110" gh = "101"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte tesnenie piestu (1) z valca strmeňa zadnej brzdy (3) pomocou skrutkovača s plochou hlavou (2) apod.
</ptxt>
<figure>
<graphic graphicname = "I9P60A432043.swf" width = "88.000mm" height = "55.908mm" ver = "01" gw = "143" gh = "142"/>
</figure>
</s1>
</topic>
<topic id = "ASLAP70A4306008003">
<title>
Klzný kolík
</title>
<ptxt>
Demontujte klzné kolíky (2) a manžety čapu (3) z držiaka strmeňa prednej brzdy (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432030.swf" width = "88.000mm" height = "55.219mm" ver = "01" gw = "133" gh = "140"/>
</figure>
</topic>
</servinfosub>
<servinfosub id = "ASLAP70A4306008004">
<title>
Zloženie
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4306009">Kontrola strmeňa zadnej brzdy</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Na umytie brzdových častí používajte iba predpísanú brzdovú kvapalinu.
</ptxt>
<ptxt>
Každá iná tekutina alebo rozpúšťadlo poškodí gumené časti.
</ptxt>
</attention2>
<topic id = "ASLAP70A4306008005">
<title>
Strmeň
</title>
<s1>
<ptxt>
Pred montážou piesta brzdy k strmeňu zadnej brzdy urobte nasledovné.
</ptxt>
<s2>
<ptxt>
Skontrolujte piest dookola a vnútro valca, či nie je hrdzavé, skorodované alebo ináč poškodené. Ak výsledok nie je v poriadku, vymeňte strmeň zadnej brzdy.
</ptxt>
</s2>
<s2>
<ptxt>
Po nanesení kaučukového oleja, ktorý sa nachádza v súprave tesnení piestu nasaďte tesnenie piestu (1) do drážky vo valci a dávajte pozor, aby sa neskrútilo.
</ptxt>
<figure>
<graphic graphicname = "I9P60A432031.swf" width = "88.000mm" height = "55.908mm" ver = "01" gw = "127" gh = "142"/>
</figure>
</s2>
<s2>
<ptxt>
Na novú manžetu valca (1) naneste kaučukový olej, ktorý sa nachádza v súprave tesnení piestu a potom pripevnite manžetu do drážky vo valci podľa nižšie zobrazeného.
</ptxt>
<figure>
<graphic graphicname = "I9P60A432032.swf" width = "88.000mm" height = "42.431mm" ver = "01" gw = "170" gh = "104"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.893in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.401in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Strana valca
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Strana brzdovej doštičky
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Predĺžte manžetu valca (1) a namontujte brzdový piest (2) do valca zadného brzdového strmeňa (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432033.swf" width = "88.000mm" height = "47.869mm" ver = "01" gw = "122" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Otočte brzdový piest (1) v smere šípky pomocou špeciálneho nástroja a naskrutkujte brzodvý piest do valca.
</ptxt>
</s1>
<s1>
<ptxt>
Manžetu valca pripevnite do drážky manžety brzdového piestu.
</ptxt>
<attention2>
<ptxt>
Manžeta valca by sa pri inštalácii brzdového piestu nemala otáčať.
</ptxt>
</attention2>
<attention3>
<ptxt>
Skontrolujte, či je manžeta valca úplne pripevnená v drážke v strmeni zadnej brzdy aj v manžete v brzdovom pieste.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L4C006">
<s-part>
(A)
</s-part>
<s-number num = "09945-16030">
09945–16030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A432011.swf" width = "88.000mm" height = "45.775mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
K strmeňu zadnej brzdy namontujte zátku a dotiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T4C006">
<t-part>
Odvzdušňovacia zátka
</t-part>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
</s1>
</topic>
<topic id = "ASLAP70A4306008006">
<title>
Klzné kolíky
</title>
<s1>
<ptxt>
Pred montážou posuvného kolíka k držiaku strmeňa prednej brzdy skontrolujte nasledovné body.
</ptxt>
<s2>
<ptxt>
Skontrolujte posuvné kolíky, či nie sú skorodované alebo inak poškodené. Ak sú kolíky poškodené, vymeňte ich.
</ptxt>
</s2>
<s2>
<ptxt>
Na stanu novej manžety kolíka (1) naneste kaučukový olej.
</ptxt>
</s2>
<s2>
<ptxt>
Namontujte manžety kolíka (1) k držiaku strmeňa zadnej brzdy (2) s koncami tak, ako je to znázornené nižšie.
</ptxt>
<attention3>
<ptxt>
Použite také gumové mazadlo, ktorého viskozita veľmi nemení ani pri –40 &#176;C (–40 &#176;F).
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A432035.swf" width = "88.000mm" height = "46.795mm" ver = "01" gw = "138" gh = "116"/>
</figure>
</s2>
<s2>
<ptxt>
Na posuvné kolíky (1) naneste kaučukový olej.
</ptxt>
<attention3>
<ptxt>
Použite také gumové mazadlo, ktorého viskozita veľmi nemení ani pri –40 &#176;C (–40 &#176;F).
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A432036.swf" width = "88.000mm" height = "37.816mm" ver = "01" gw = "76" gh = "91"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Posuvný kolík namontujte s tromi drážkami (1) do zadnej strany a posuňte kolík bez drážky (2) do prednej strany držiaka strmeňa zadnej brzdy (3) tak, ako je to zobrazené.
</ptxt>
<figure>
<graphic graphicname = "IAP70A430015.swf" width = "88.000mm" height = "40.813mm" ver = "01" gw = "136" gh = "99"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.956in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Smer dopredu
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</topic>
