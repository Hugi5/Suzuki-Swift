<servinfosub id = "ASLAP70A4604018003">
<title>
Riešenie problémov DTC
</title>
<topic id = "ASLAP70A4604018004">
<title>
Príprava
</title>
<list1 type = "unordered">
<item>
<ptxt>
Potvrďte, že nie je detekované DTC C1057.
</ptxt>
</item>
<item>
<ptxt>
Vykonajte nasledovný postup viac ako 8-krát nepretržite.
</ptxt>
</item>
</list1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Jazdite vyššou rýchlosťou ako 20 km/h (12 mile/h) po dobu viac ako 1 minúty.
</ptxt>
</s1>
<s1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF (VYP).
</ptxt>
</s1>
</topic>
<diag type = "test" id = "ASLAP70A4604018005">
<testgroup id = "ASLAP70A4604018006">
<question>
Bola vykonaná „Kontrola systému ESP®“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604018007">
<title>
Kontrola tlaku pneumatík
</title>
<test1>
<ptxt>
Skontrolujte, či je tlak v pneumatikách v rámci predpísanej hodnoty.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte pneumatiku, alebo nastavte tlak pneumatiky a znovu skontrolujte DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604018008">
<title>
Kontrola obvodu napájania a signálneho obvodu snímača otáčok kolesa
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte „E24“ a konektory snímača otáčok kolesa.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie k „E24“ a každý konektor snímača otáčok kolesa.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov “A1”, “A2”, “B1”, “B2”, “C1”, “C2”, “D1” a “D2”: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom “A1”, “A2”, “B1”, “B2”, “C1”, “C2”, “D1” a “D2” a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A1“ a ďalšou svorkou v konektore snímača otáčok ľavého predného kolesa: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B1“ a ďalšou svorkou v konektore snímača otáčok pravého predného kolesa: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „C1“ a ďalšou svorkou v konektore snímača otáčok ľavého zadného kolesa: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „D1“ a ďalšou svorkou v konektore snímača otáčok pravého zadného kolesa: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor obvodov “A1”, “A2”, “B1”, “B2”, “C1”, “C2”, “D1” a “D2”: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604018009">
<title>
Kontrola signálu snímača otáčok kolesa
</title>
<test1>
<ptxt>
Skontrolujte výstupné napätie a krivku príslušného snímača otáčok kolesa. 
<intxreftitleoff1 refid = "ASLAP70A4606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zodpovedá výsledok kontroly predpísaným hodnotám?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604018010">
<title>
Kontrola snímača otáčok kolesa
</title>
<test1>
<ptxt>
Skontrolujte príslušný snímač otáčok kolesa. 
<intxreftitleoff1 refid = "ASLAP70A4606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Snímač kolesa vyčistite, opravte alebo vymeňte.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Snímač otáčok predného kolesa: 
<intxreftitleoff1 refid = "ASLAP70A4606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Snímač otáčok zadného kolesa: 
<intxreftitleoff1 refid = "ASLAP70A4606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604018011">
<title>
Kontrola prevodníka snímača otáčok kolesa
</title>
<test1>
<ptxt>
Skontrolujte prevodník príslušného snímača otáčok kolesa. 
<intxreftitleoff1 refid = "ASLAP70A4606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Prevodník snímača kolesa vyčistite, opravte alebo vymeňte.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Prevodník snímača otáčok predného kolesa: 
<intxreftitleoff1 refid = "ASLAP70A4606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Prevodník snímača otáčok zadného kolesa: 
<intxreftitleoff1 refid = "ASLAP70A4606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 :
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
