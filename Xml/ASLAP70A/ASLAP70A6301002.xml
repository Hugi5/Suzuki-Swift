<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "1">
<servinfo servinfosgmlid = "ASLAP70A6301002" svcinfotypenbr = "03" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Popis funkcií komponentov systému EPS
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "3" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.429in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.488in"/>
<colspec colnum = "3" colname = "3" colwidth = "4.219in"/>
<thead>
<row rowsep = "1">
<entry namest = "1" nameend = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Komponenty systému EPS
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Funkcia
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Teleso stĺpika riadenia
</emph>
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Snímač krútiaceho momentu
</emph>
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Pomocou dvoch obvodov (hlavného a pomocného) snímač krútiaceho momentu vysiela napätia primerane podľa vstupného krútiaceho momentu riadenia a smeru jednotky riadenia P/S.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Motor P/S
</emph>
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Motor P/S produkuje krútiace momenty na pomoc riadenia, ktorý zodpovedá elektrickému prúdu z riadiacej jednotky P/S.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Riadiaca jednotka posilňovača riadenia
</emph>
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka P/S riadi pohon motora P/S určením jeho množstva a smeru pomoci na základe signálu napätia zo snímača krútiaceho momentu a rýchlosti vozidla a iných údajov, ktoré prijíma cez komunikácie CAN.
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka P/S posúdi, či motor beží alebo nie pomocou signálu otáčok motora z CAN.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry namest = "1" nameend = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Výstražná kontrolka „P/S“
</emph>
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Výstražná kontrolka „P/S“ za zapne keď nie je systém P/S v normálnom stave.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
