<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216010" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola elektromotora ventilátora
</title>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte odpor elektromotora ventilátora medzi svorkami podľa obrázku.
</ptxt>
<ptxt>
Ak je spoj nevodivý, motor ventilátora vymeňte.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721013.swf" width = "88.000mm" height = "42.472mm" ver = "01" gw = "219" gh = "104"/>
</figure>
</item>
<item>
<ptxt>
Skontrolujte činnosť a prúd motora ventilátora.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Dajte elektromotor ventilátora (1) do zveráka s mäkkými čeľusťami.
</ptxt>
</item>
<item>
<ptxt>
Podľa obrázku pripojte k elektromotoru ventilátora akumulátor.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či elektromotor ventilátora funguje plynulo bez abnormálneho hluku.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či ampérmeter indikuje predpísaný prúd keď je na 1 min. aplikované napätie.
</ptxt>
<ptxt>
Ak sa výsledok kontroly nezhoduje s uvedenými hodnotami, vymeňte motor ventilátora.
</ptxt>
<spec>
<title>
Predpísaný prúd ventilátora pri 12 V
</title>
<ptxt>
max. 16 A pri 20 – 25 &#176;C (68 – 77 &#176;F)
</ptxt>
<figure>
<graphic graphicname = "I9P60A721039.swf" width = "88.000mm" height = "44.463mm" ver = "01" gw = "206" gh = "110"/>
</figure>
</spec>
</item>
</list2>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
