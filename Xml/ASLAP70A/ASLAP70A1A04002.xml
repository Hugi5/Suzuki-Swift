<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1A04002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Diagnostika symptómov alternátora
</title>
<ptxt>
Problémy v nabíjacom systéme sa prejavia, ak nastane jedna alebo viacero nasledujúcich situácií:
</ptxt>
<servinfosub id = "ASLAP70A1A04002001" page = "1">
<title>
Funkcia kontrolky dobíjania
</title>
<diag type = "condition" id = "ASLAP70A1A04002002">
<condition>
<ptxt>
Kontrolka dobíjania nesvieti, keď je zapaľovanie v polohe ON a motor je vypnutý
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte poistku.
</ptxt>
</action>
<ps>
<ptxt>
Porucha združeného prístroja
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vymeňte združený prístroj. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Skontrolujte BCM. 
</ptxt>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porucha komunikačnej linky CAN
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte komunikačnú linku CAN. 
<intxreftitleoff1 refid = "ASLAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha zväzku
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte zväzok.
</ptxt>
</action>
<ps>
<ptxt>
Porucha IC regulátora alebo budiacej cievky
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte alternátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Kontrolka dobíjania pri bežiacom motore nezhasne (akumulátor si vyžaduje časté nabíjanie)
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnený alebo opotrebovaný hnací remeň
</ptxt>
</ps>
<action>
<ptxt>
Hnací remeň nastavte alebo vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha združeného prístroja
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vymeňte združený prístroj. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Skontrolujte BCM. 
</ptxt>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porucha IC regulátora alebo alternátora
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte alternátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha zväzku
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte zväzok.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A1A04002003">
<title>
Porucha nabíjania akumulátora
</title>
<diag type = "condition" id = "ASLAP70A1A04002004">
<condition>
<ptxt>
Nedostatočne nabitý akumulátor
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnený alebo opotrebovaný hnací remeň
</ptxt>
</ps>
<action>
<ptxt>
Hnací remeň nastavte alebo vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnená alebo skorodovaná koncovka akumulátora 
</ptxt>
</ps>
<action>
<ptxt>
Dotiahnite svorku akumulátora alebo akumulátor vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha usmerňovača, rotora a/alebo IC regulátora
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte alternátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Príliš nabitý akumulátor
</ptxt>
</condition>
<ps>
<ptxt>
Porucha IC regulátora
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte alternátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A1A04002005">
<title>
Hlučnosť
</title>
<diag type = "condition" id = "ASLAP70A1A04002006">
<condition>
<ptxt>
Porušený alternátor
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnite montážne skrutky
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite montážne skrutky. 
<intxreftitleoff1 refid = "ASLAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Špinavé, opotrebované a/alebo poruchové ložiská
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte alternátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha rotora, diódy a/alebo statora
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte alternátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
