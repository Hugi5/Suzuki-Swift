<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70AA504004" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Vymazanie DTC
</title>
<s1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Skenovacie zariadenie Suzuki pripojte k DLC (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L10E002">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
Skenovacie zariadenie SUZUKI (SUZUKI-SDT)
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A121001.jpg" width = "88.000mm" height = "67.502mm" ver = "02" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Vymažte DTC podľa pokynov zobrazených na skenovacom zariadení. Viac podrobností nájdete v používateľskej príručke pre skenovacie zariadenie SUZUKI.
</ptxt>
</s1>
<s1>
<ptxt>
Po ukončení kontroly vypnite spínač zapaľovania a odpojte skenovacie zariadenie SUZUKI z DLC.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
