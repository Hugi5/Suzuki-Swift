<servinfo servinfosgmlid = "ASLAP70A9B06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž predného panela strany prístrojovej dosky s predným panelom hornej strany kapoty
</title>
<attention3>
<ptxt>
Nižšie uvedený obrázok zobrazuje podmienky odstraňovania nasledovných častí.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predný blatník 
<intxreftitleoff1 refid = "ASLAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Časť zámky kapoty, časť podpory lampy a podpora lampy 
<intxreftitleoff1 refid = "ASLAP70A9B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vonkajší prvok bočného krytu 
<intxreftitleoff1 refid = "ASLAP70A9B06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0030.jpg" width = "88.000mm" height = "56.208mm" ver = "01" gw = "227" gh = "143"/>
</figure>
<servinfosub id = "ASLAP70A9B06006001">
<title>
Všeobecné poznámky
</title>
<ptxt>
Spôsob zvárania a počet bodov zvaru je ten istý na oboch stranách. Tieto pokyny na opravu zobrazujú postup pre ľavú stranu.
</ptxt>
</servinfosub>
<servinfosub id = "ASLAP70A9B06006002">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odvŕtajte body zvaru a vyberte predný panel na strane prístrojovej dosky s predným panelom hornej strany kapoty.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0018.jpg" width = "183.000mm" height = "180.352mm" ver = "04" gw = "474" gh = "495"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.472in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.930in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Ľavá strana vozidla
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Pravá strana vozidla
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Tento symbol indikuje, že vonkajší prvok strany prístrojovej dosky a panel na prístrojovej strane sú vymenené naraz.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9B06006003">
<title>
Montáž
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Pred zváraním skontrolujte polohu inštalácie a stav inštalačnej časti (častí). 
<intxreftitleoff1 refid = "ASLAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
V oprave pokračujte berúc do úvahy inštaláciu častí, ktoré majú vplyv na vzhľad. 
<intxreftitleoff1 refid = "ASLAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Namontujte predný panel prístrojovej dosky s predným panelom horného krytu.
</ptxt>
</s1>
<s1>
<ptxt>
Vykonajte odporové bodové zváranie alebo dierové zváranie.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0031.jpg" width = "183.000mm" height = "209.212mm" ver = "05" gw = "474" gh = "577"/>
