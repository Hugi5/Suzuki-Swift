<servinfo servinfosgmlid = "ASLAP70A3406002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž kĺbového hriadeľa
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A3406001">Komponenty kĺbového hriadeľa</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A3406002001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Zdvihnite vozidlo dielenským zdvihákom.
</ptxt>
</s1>
<s1>
<ptxt>
Pred odmontovaním kĺbového hriadeľa si na spojovacej prírube a kĺbovom hriadeli vyznačte značky (1) podľa obrázku.
</ptxt>
</s1>
<s1>
<ptxt>
Z príruby diferenciálu oddeľte kardanový hriadeľ č. 2 (2).
</ptxt>
</s1>
<s1>
<ptxt>
Z vonkajšieho krúžku prevodovky odstráňte kardanový hriadeľ č. 1 (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A340002.swf" width = "88.000mm" height = "64.119mm" ver = "01" gw = "182" gh = "165"/>
</figure>
<figure>
<graphic graphicname = "IAP70A340003.swf" width = "88.000mm" height = "55.013mm" ver = "01" gw = "176" gh = "139"/>
</figure>
</s1>
<s1>
<ptxt>
Z karosérie vozidla odmontujte podpery stredového ložiska kardanového hriadeľa (1).
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Konzoly a kardanový hriadeľ sa vyberajú dokopy, bez oddelenia.
</ptxt>
</item>
<item>
<ptxt>
Dávajte pozor, aby vám nespadol.
</ptxt>
</item>
<item>
<ptxt>
Dbajte na to, aby ste nepoškodili kryty kĺbu.
</ptxt>
</item>
<item>
<ptxt>
Dbajte na to, aby ste nepoškodili olejové tesnenie priečneho spoja.
</ptxt>
</item>
</list1>
</attention2>
<figure>
<graphic graphicname = "IAP70A340004.swf" width = "88.000mm" height = "53.517mm" ver = "01" gw = "207" gh = "135"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
