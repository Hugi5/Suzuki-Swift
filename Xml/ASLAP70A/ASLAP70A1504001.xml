<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1504001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola tlaku oleja
</title>
<attention1>
<ptxt>
Aby sa predišlo nebezpečenstvu popálenia, nedotýkajte sa výfukového systému, keď je systém horúci.
</ptxt>
</attention1>
<attention3>
<ptxt>
Skôr, ako začnete kontrolovať tlak oleja, skontrolujte nasledovné položky.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Hladina oleja v olejovej vani
</ptxt>
<ptxt>
Ak je hladina oleja nízka, dolejte olej po značku hladiny plnej kapacity (otvor) (1) na meradle stavu oleja. 
<intxreftitleoff1 refid = "ASLAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kvalita oleja
</ptxt>
<ptxt>
Ak olej stráca farbu alebo je znehodnotený, vymeňte ho. 
<intxreftitleoff1 refid = "ASLAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Unikanie oleja
</ptxt>
<ptxt>
Ak nájdete netesnosť, opravte ju.
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Radiacu páku zaraďte do „Neutrálu“ a zatiahnite parkovaciu brzdu.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odmontujte predný nárazník. 
<intxreftitleoff1 refid = "ASLAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Demontujte predný kryt motora.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte vodiaci kábel spínača tlaku oleja (1).
</ptxt>
</s1>
<s1>
<ptxt>
Z bloku valcov vyberte spínač tlaku oleja (2).
</ptxt>
<figure>
<graphic graphicname = "I7V20A151002.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "182" gh = "129"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
K závitovému otvoru spínača tlaku oleja primontujte špeciálne nástroje.
</ptxt>
<servicetool>
<servicetoolitem id = "L1E001">
<s-part>
(A)
</s-part>
<s-number num = "09915-77311">
09915–77311
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L1E002">
<s-part>
(B)
</s-part>
<s-number num = "09915-78211">
09915–78211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A151003.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "230" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Naštartujte motor a zahrejte ho na bežnú prevádzkovú teplotu.
</ptxt>
</s1>
<s1>
<ptxt>
Po zahriatí zvýšte rýchlosť motora na 4000 ot./min a odmerajte tlak oleja.
</ptxt>
<spec>
<title>
Stanovené hodnoty tlaku oleja
</title>
<ptxt>
Viac ako 300 – 500 kPa (3,1 – 5,1 kgf/cm <sup>2</sup> , 43,5 – 72,5 psi) pri 4000 ot/min.
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Po kontrole tlaku oleja zastavte motor a vyberte špeciálne nástroje.
</ptxt>
</s1>
<s1>
<ptxt>
Na závit spínača tlaku oleja (1) naneste tesniaci prostriedok a potom ju utiahnite na predpísaný moment.
</ptxt>
<attention2>
<ptxt>
Tesniaci prostriedok nenanášajte do otvoru spínača tlaku oleja.
</ptxt>
</attention2>
<materials>
<materialitem name = "Thread Lock Cement Super 1322" id = "M1E001" uid = "37">
<m-part>
„A“
</m-part>
<m-desc>
Závitový tmel
</m-desc>
<m-number>
99000–32110
</m-number>
<m-name>
Thread Lock Cement Super 1322
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<torque>
<torqueitem id = "T1E001">
<t-part>
Tlakový olejový spínač
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9R90A150004.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "184" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Pripojte vodiaci kábel spínača tlaku oleja (1).
</ptxt>
<figure>
<graphic graphicname = "I7V20A151005.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "186" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Naštartujte motor a skontrolujte, či zo spínača tlaku oleja neuniká olej. Ak nájdete netesnosť, opravte správnu inštaláciu spínača tlaku oleja.
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ak je zobrazený akýkoľvek DTC, vymažte ho. 
<intxreftitleoff1 refid = "ASLAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
