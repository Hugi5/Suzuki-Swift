<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70AA506005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spínača požiadavky a otvárača zadných koncových dverí
</title>
<servinfosub id = "ASLAP70AA506005001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte obloženie zadných koncových dverí. 
<intxreftitleoff1 refid = "ASLAP70A9606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor spínača otvárača zadných koncových dverí a spínač požiadavky (1) a svorku.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte ozdobnú lištu ŠPZ na zadných výklopných dverách. 
<intxreftitleoff1 refid = "ASLAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte skrutky a potom odmontujte spínač otvárača zadných koncových dverí a spínač požiadavky (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50023.swf" width = "88.000mm" height = "54.154mm" ver = "01" gw = "198" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA506005002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70AA506009">Kontrola spínača požiadavky</intxrefpoff>
</ptxt>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
