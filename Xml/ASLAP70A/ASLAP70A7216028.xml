<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216028" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola tiahla ovládača
</title>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte, či pracuje každé tiahlo ovládača hladko.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či nie je tyč ovládača prehnutá.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či nie je každé tiahlo ovládača poškodené.
</ptxt>
</item>
<item>
<ptxt>
Uistite sa, že sa v prevádzkovom rozsahu tiahla ovládača nenachádza žiadna prekážka.
</ptxt>
<ptxt>
Ak nie je výsledok kontroly v poriadku, opravte alebo vymeňte poruchové časti.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
