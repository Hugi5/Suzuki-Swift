<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216044" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž sušiča
</title>
<servinfosub id = "ASLAP70A7216044001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Rekuperujte chladiacu zmes zo systému klimatizácie (A/C) podľa časti „Rekuperácia“ v 
<intxref refid = "ASLAP70A7216001">Prevádzkový postup pre napĺňanie chladiacou kvapalinou:Manuálny typ</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte predný nárazník. 
<intxreftitleoff1 refid = "ASLAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte prvok predného nárazníka a spodný absorbér predného nárazníka. 
<intxreftitleoff1 refid = "ASLAP70A9806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte veko filtra (1) z prijímača (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte sušič (3) a tesniace krúžky (4).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A721037.swf" width = "88.000mm" height = "45.459mm" ver = "01" gw = "210" gh = "112"/>
</figure>
</servinfosub>
<servinfosub id = "ASLAP70A7216044002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sušič nevyberajte z plastového vrecka skôr, ako tesne pred vložením do prijímača.
</ptxt>
</item>
<item>
<ptxt>
Vložte nový sušič, nový tesniaci krúžok a nové veko filtra.
</ptxt>
</item>
<item>
<ptxt>
Naneste predpísaný kompresorový olej na tesniaci krúžok.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B103" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Kompresorový olej
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Utiahnite veko filtra na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T7B101">
<t-part>
Veko filtra
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
18
</t-value1>
<t-value2>
1,84
</t-value2>
<t-value3>
1,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Odčerpajte a naplňte systém klimatizácie „Vypúšťanie“ a „Plnenie v 
<intxref refid = "ASLAP70A7216001">Prevádzkový postup pre napĺňanie chladiacou kvapalinou:Manuálny typ</intxref>
 .
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A721038.swf" width = "88.000mm" height = "40.160mm" ver = "01" gw = "172" gh = "97"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
