<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1806004" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola telesa zapaľovacej cievky
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1806003">Demontáž a montáž telesa zapaľovacej cievky</intxrefpoff>
</ptxt>
<ptxt>
Skontrolujte teleso zapaľovacej cievky, či:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Nie je poškodené;
</ptxt>
</item>
<item>
<ptxt>
nie je deformované;
</ptxt>
</item>
<item>
<ptxt>
korodované na svorkách
</ptxt>
</item>
</list1>
<ptxt>
Ak výsledok kontroly nezodpovedá predpísaným hodnotám, vymeňte teleso zapaľovacej cievky.
</ptxt>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
