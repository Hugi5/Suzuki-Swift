<servinfosub id = "ASLAP70AA504020003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Sltačte spínač požiadavky dverí týkajúci sa DTC.
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite spínač požiadavky dverí.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ na 10 min. alebo viac.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA504020004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA504020005">
<testgroup id = "ASLAP70AA504020008">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF (vyp.) a k prípojke na údajové spojenie pripojte skenovacie zariadenie SUZUKI.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontolujte „Driver Request SW“, „Passenger Request SW“ aleob „Rear door/trunk requ SW“ zobrazené na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504020006">
<title>
Kontrola obvodu signálu spínača požiadavky dverí
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory spínača požiadavky dverí a “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektoru spínača požiadavky dverí a „L10“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte, či je odpor odbovdu „A1“, „A2“ a „A3“: menej ako 3 &#937;
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504020007">
<title>
Kontrola spínača požiadavky dverí
</title>
<test1>
<ptxt>
Skontrolujte spínač požiadavky dverí. 
<intxreftitleoff1 refid = "ASLAP70AA506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte dopytový spínač dverí.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504020009">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte konektory spínača požiadavky dverí a “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú detekované aktuálne DTC B1180, B1181 alebo B1182?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
</testgroup>
</diag>
