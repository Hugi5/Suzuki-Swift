<servinfo servinfosgmlid = "ASLAP70A9306005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž parkovacieho snímača (ak je vo výbave)
</title>
<servinfosub id = "ASLAP70A9306005001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte zadný nárazník. 
<intxreftitleoff1 refid = "ASLAP70A9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor parkovaiceho snímača.
</ptxt>
</s1>
<s1>
<ptxt>
Vytiahnite kryt parkovacieho snímača (1) podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930025.jpg" width = "88.000mm" height = "106.836mm" ver = "01" gw = "208" gh = "286"/>
</figure>
</s1>
<s1>
<ptxt>
Otvorte čeľuste (1) a vyberte parkovací snímač (2) podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930026.jpg" width = "88.000mm" height = "63.752mm" ver = "01" gw = "196" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Ak je to potrebné, odstráňte konzolu snímača.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9306005002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9306006">Kontrola parkovacieho snímača (ak je súčasťou výbavy)</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Vyčistite a znížte oblasť, kde chcete namontovať konzolu snímača (1).
</ptxt>
</item>
<item>
<ptxt>
Naneste lepidlo (rovnaké ako SUMITOMO 3M K-520 alebo 4298UV) na oblasť, kde chcete namontovať konzolu snímača.
</ptxt>
</item>
<item>
<ptxt>
Konzolu snímača namontujte v smere zobrazenom na obrázku.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A930039.jpg" width = "88.000mm" height = "98.016mm" ver = "01" gw = "199" gh = "261"/>
