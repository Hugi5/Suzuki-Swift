<servinfosub id = "ASLAP70A4604017003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A4604017004">
<testgroup id = "ASLAP70A4604017005">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604017006">
<title>
Kontrola DTC pre ESP®
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70A4604005">Kontrola DTC</intxref>
.
</ptxt>
</test1>
<question>
Je detekovaný DTC U0073 a/alebo U0100?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným procesom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604017007">
<title>
Kontrola spínača brzdových svetiel a obvodu
</title>
<test1>
<ptxt>
Skontrolujte spínač brzdových svetiel a jeho obvody podľa krokov 2 až 4 v časti 
<intxref refid = "ASLAP70A1104040">DTC P0504</intxref>
 .
</ptxt>
</test1>
<question>
Sú výsledky kontroly primerané?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte.
</ptxt>
</action>
</testgroup>
