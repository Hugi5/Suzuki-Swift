<servinfo servinfosgmlid = "ASLAP70AA106002" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola tempomatu
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70AA106001">Demontáž a montáž tempomatu</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Demontujte jednotku (inflátor) airbagu vodiča. 
<intxreftitleoff1 refid = "ASLAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor spínača tempomatu (1) z kontaktného vinutia.
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte odpor medzi svorkami “S62-5” a “S62-6” za určitých podmienok, ktoré sú uvedené nižšie.
</ptxt>
<ptxt>
Ak nie je výsledok kontroly taký, ako je špecifikované, spínač tempomatu vymeňte.
</ptxt>
<attention3>
<ptxt>
Pri kontrole svoriek “9” a “3” použite rozsah diódy skúšobného obvodu.
</ptxt>
</attention3>
<spec>
<title>
Odpor spínača tempomatu
</title>
<ptxt>
Všetky spínače uvoľnené (OFF): 1960 – 2000 &#937;
</ptxt>
<ptxt>
Spínač MAIN (ON/OFF) (2) stlačený (ON): Menej ako 2,5 &#937;
</ptxt>
<ptxt>
Spínač CANCEL (3) stlačený (ON): 99 – 101 &#937;
</ptxt>
<ptxt>
Spínač SET/COAST (4) stlačený (ON): 386 – 394 &#937;
</ptxt>
<ptxt>
Spínač RES/ACC (5) stlačený (ON): 772 – 788 &#937;
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60AA10004.swf" width = "88.000mm" height = "93.199mm" ver = "03" gw = "174" gh = "248"/>
