<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70AA506008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zadnej vnútornej antény
</title>
<servinfosub id = "ASLAP70AA506008001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte obloženie zadnej časti. 
<intxreftitleoff1 refid = "ASLAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor zadnej vnútornej antény (1) a potom vyberte zadnú vnútornú anténu (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50027.swf" width = "88.000mm" height = "59.203mm" ver = "01" gw = "175" gh = "151"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA506008002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70AA506010">Kontrola antény</intxrefpoff>
</ptxt>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
