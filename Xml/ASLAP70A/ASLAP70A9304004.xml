<servinfosub id = "ASLAP70A9304004003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A9304004004">
<testgroup id = "ASLAP70A9304004005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vymažte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1802?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte kvôli občasným problémom. 
<intxreftitleoff1 refid = "ASLAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A9304004006">
<title>
Kontrola obvodov napájania a uzemnenia združeného prístroja
</title>
<test1>
<ptxt>
Skontrolujte obvod napájania a uzemnenia združeného prístroja. 
<intxreftitleoff1 refid = "ASLAP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A9304004007">
<title>
Kontrola napätia dodávky energie združeného prístroja
</title>
<test1>
<ptxt>
Skontrolujte napájacie napätie, keď motor ide na 3000 ot/min.
</ptxt>
</test1>
<question>
Má napätie hodnotu 10 –15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte združený merač a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte systém nabíjania. 
<intxreftitleoff1 refid = "ASLAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
