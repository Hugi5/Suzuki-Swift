<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Namáhavé radenie
</title>
<diag type = "condition">
<condition>
<ptxt>
Namáhavé radenie
</ptxt>
</condition>
<ps>
<ptxt>
Nedostatok vazelíny
</ptxt>
</ps>
<action>
<ptxt>
Doplňte olej do manuálnej prevodovky.
</ptxt>
</action>
<ps>
<ptxt>
Nesprávna voľná dráha spojkového pedálu
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte hlavný spojkový valec alebo rameno spojkového pedála. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Rameno spojkového pedála: 
<intxreftitleoff1 refid = "ASLAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hlavný valec spojky: 
<intxreftitleoff1 refid = "ASLAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Zdeformovaný alebo poškodený kotúč spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodený prítlačný kotúč spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kryt spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaný synchronizačný krúžok
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte synchronizačný krúžok.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Synchronizačný krúžok nízkych rýchlostných stupňov a 2. stupňa: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchronizačný krúžok vysokých rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchronizačný krúžok 5. rýchlostného stupňa: 
<intxreftitleoff1 refid = "ASLAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Opotrebované zošikmené ozubenie na objímke alebo kolese
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte objímku synchronizačnej spojky a náboj a koleso.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
1. a 2. stupeň predlohového riadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
3. a 4. stupeň vstupného hriadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5. stupeň vstupného hriadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Náboj a puzdro synchronizačnej spojky nízkych rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Náboj a puzdro synchronizačnej spojky vysokých rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Náboj a puzdro 5. rýchlostného stupňa: 
<intxreftitleoff1 refid = "ASLAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Opotrebované spojovacie puzdro radiacej tyče radenia prevodov
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte spojovacie puzdro radiacej tyče radenia prevodov. 
<intxreftitleoff1 refid = "ASLAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zdeformovaná radiaca tyč
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte hriadeľ zaraďovacej vidlice alebo hriadeľ radenia.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Radiaca tyč nízkych rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Radiaca tyč vysokých rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zaraďovacia vidlica kolesa 5. rýchlostného stupňa: 
<intxreftitleoff1 refid = "ASLAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Poškodené lanká radenia prevodov / lanká výberu prevodu
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte lanko radenia a výberu prevodu. 
<intxreftitleoff1 refid = "ASLAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
