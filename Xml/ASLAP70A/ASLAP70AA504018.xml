<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70AA504018" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1161 / B1163
</title>
<servinfosub id = "ASLAP70AA504018001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.816in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.388in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1161: Nesprávne priradenie jedn. uzamknutia volantu
</emph>
</ptxt>
<ptxt>
Chyba overenia medzi riadiacou jednotkou bezkľúčového štartovania a jednotkou zámky riadenia.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Obvod/Konektor jednotky zámky riadenia
</ptxt>
</item>
<item>
<ptxt>
Jednotka zámky volantu
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka štartovania bez kľúča
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1163: Neregistrovaná jednotka zámky riadenia
</emph>
</ptxt>
<ptxt>
Nezaregistrovanie jednotky zámky riadenia.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70AA504018002">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Kroky 1) a 2) niekoľkokrát zopakujte.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA504018003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA504018004">
<testgroup id = "ASLAP70AA504018005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vymažte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA504018002">Postup potvrdenia DTC</intxref>
 a potom znovu skontrolujte DTC.
</ptxt>
</test1>
<question>
Stále sa zobrazuje DTC B1161 alebo B1163?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504018006">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte jednotku zámky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA504018002">Postup potvrdenia DTC</intxref>
 a potom znovu skontrolujte DTC.
</ptxt>
</test1>
<question>
Stále sa zobrazuje DTC B1161 alebo B1163?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Porucha jednotky zámky riadenia.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
