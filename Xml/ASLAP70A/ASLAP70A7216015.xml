<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216015" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola výparníka
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A7216008">Demontáž a montáž jednotky HVAC:Manuálny typ</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A7216007">Súčiastky jednotky HVAC:Manuálny typ</intxrefpoff>
</ptxt>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Upchaté rebrá výparníka klimatizácie.
</ptxt>
<ptxt>
Ak sú upchaté, prepláchnite rebrá výparníka klimatizácie vodou a potom ich vysušte stlačeným vzduchom.
</ptxt>
</item>
<item>
<ptxt>
Netesnosť alebo zlomenie rebier výparníka klimatizácie
</ptxt>
<ptxt>
Ak sú rebrá výparníka netesné alebo zlomené, opravte alebo vymeňte výparník klimatizácie.
</ptxt>
</item>
<item>
<ptxt>
Netesnosť armatúr výparníka klimatizácie
</ptxt>
<ptxt>
Ak sú armatúry výparníka netesné, opravte alebo vymeňte výparník klimatizácie.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
