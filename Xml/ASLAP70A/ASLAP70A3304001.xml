<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A3304001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnostika príznakov spojenia
</title>
<diag type = "condition" id = "ASLAP70A3304001001">
<condition>
<ptxt>
Hlučnosť
</ptxt>
</condition>
<ps>
<ptxt>
Nevhodný mazací prostriedok alebo jeho nedostatok
</ptxt>
</ps>
<action>
<ptxt>
Doplňte mazací prostriedok. 
<intxreftitleoff1 refid = "ASLAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodené alebo opotrebované ložisko(á)
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A3306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodené alebo opotrebované ozubené koleso(á)
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A3306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Predpätie kužeľového valového ložiska je znížené
</ptxt>
</ps>
<action>
<ptxt>
Nastavte ho. 
<intxreftitleoff1 refid = "ASLAP70A3306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
