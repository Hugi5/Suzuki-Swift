<servinfosub id = "ASLAP70AA324018003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nechajte motor bežať na voľnobežných otáčkach 10 sekúnd alebo dlhšie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA324018004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA324018005">
<testgroup id = "ASLAP70AA324018006">
<title>
Kontrola obvodu signálu spínača motora
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory “G140” a “G28”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom “G140”, a “G28”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“, „A2“, „A3“ alebo „A4“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „A1“, „A2“, „A3“ a „A4“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A1“ a konektorom „G140“ ďalšou svorkou v konektore alternátora: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA324018007">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte spínač motora. 
<intxreftitleoff1 refid = "ASLAP70AA506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA324018003">Postup potvrdenia DTC</intxref>
 a potom znovu skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1189?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Spínač motora mal poruchu.)
</ptxt>
</action>
</testgroup>
