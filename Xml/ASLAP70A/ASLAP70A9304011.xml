<servinfosub id = "ASLAP70A9304011003">
<title>
Riešenie problémov DTC
</title>
<attention3>
<ptxt>
Nasledovný postup popisuje ako skontrolovať DTC B1864: Chyba systému parkovacieho snímača (ľavý zadný). Postupujte rovnakým spôsobom ako pri DTC B1865, B1866 a B1867.
</ptxt>
</attention3>
<diag type = "test" id = "ASLAP70A9304011004">
<testgroup id = "ASLAP70A9304011005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA204003">Kontrola DTC</intxref>
.
</ptxt>
</test1>
<question>
Rozoznáva sa DTC B1852?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A9304009">DTC B1852</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A9304011006">
<title>
Kontrola parkovacieho snímača
</title>
<test1>
<ptxt>
Vymeňte parkovací snímač za dobrý a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A9306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Našli ste nejaké DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotka systému parkovacieho snímača. 
<intxreftitleoff1 refid = "ASLAP70A9306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte parkovací snímač (ľavý zadný).
</ptxt>
</action>
</testgroup>
</diag>
