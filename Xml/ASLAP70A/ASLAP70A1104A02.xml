<servinfo servinfosgmlid = "ASLAP70A1104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nízky tlak oleja
</title>
<ptxt>
Ak ECM nezistil žiaden kód DTC a pri 
<intxref refid = "ASLAP70A1104008">Vizuálna prehliadka</intxref>
 a 
<intxref refid = "ASLAP70A1104009">Základná kontrola motora</intxref>
 sa nezistila žiadna odchýlka, vykonajte riešenie problémov podľa nasledovných bodov.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Nízky tlak oleja
</ptxt>
</condition>
<ps>
<ptxt>
Nesprávna viskozita oleja
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A0206004">Výmena motorového oleja a olejového filtra</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybný spínač tlaku oleja
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1506002">Kontrola spínača tlaku oleja na vozidle</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Upchatý olejový filter
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte sitko na čistenie oleja, či nie je upchaté.
</ptxt>
</action>
<ps>
<ptxt>
Funkčné opotrebovanie olejového čerpadla
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1506008">Kontrola olejového čerpadla</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaný poistný ventil olejového čerpadla
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1506008">Kontrola olejového čerpadla</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nadmerná vôľa v rôznych pohyblivých častiach
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
