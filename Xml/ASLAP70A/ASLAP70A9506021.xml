<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9506021" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola elektrického ovládania a vyhrievania spätných zrkadiel na vozidle
</title>
<servinfosub id = "ASLAP70A9506021001">
<title>
Motor elektrického ovládania spätného zrkadla
</title>
<s1>
<ptxt>
Odmontujte vnútorné obloženie konzoly a obloženie predných dverí. 
<intxreftitleoff1 refid = "ASLAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor napájania spätného zrkadla (1).
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte svorky akumulátora napájania konektora elektrického ovládania spätných zrkadiel podľa nasledovnej tabuľky a skontrolujte činnosť motora elektricky ovládaných spätných zrkadiel.
</ptxt>
<ptxt>
Ak je výsledok mimo predpísaných hodnôt v nasledovnej činnosti, vymeňte motor.
</ptxt>
<figure>
<title>
Činnosť motora elektrického ovládania spätných zrkadiel
</title>
<graphic graphicname = "IAP70A950007V.swf" width = "88.000mm" height = "38.089mm" ver = "01" gw = "163" gh = "91"/>
</figure>
<figure>
<graphic graphicname = "IAP70A950008.jpg" width = "88.000mm" height = "73.349mm" ver = "01" gw = "203" gh = "191"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9506021002">
<title>
Vyhrievanie zrkadla
</title>
<s1>
<ptxt>
Odmontujte vnútorné obloženie konzoly a obloženie predných dverí. 
<intxreftitleoff1 refid = "ASLAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor napájania spätného zrkadla (1).
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte odpor medzi svorkou “1” a svorkou “6” konektora elekricky ovládaných spätných zrkadiel.
</ptxt>
<ptxt>
Ak sa výsledok kontroly nezhoduje s uvedenými hodnotami, vymeňte spätné zrkadlo.
</ptxt>
<spec>
<title>
Odpor vyhrievania zrkadla
</title>
<ptxt>
Približne 15,6 &#937; pri 25 &#176;C (77 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A950009.jpg" width = "88.000mm" height = "73.740mm" ver = "01" gw = "208" gh = "193"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
