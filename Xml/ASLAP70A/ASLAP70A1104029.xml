</ptxt>
</item>
<item>
<ptxt>
Obvod vstrekovacieho ventilu: 
<intxreftitleoff1 refid = "ASLAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vstrekovací ventil: 
<intxreftitleoff1 refid = "ASLAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Snímač MAF: 
<intxreftitleoff1 refid = "ASLAP70A1306026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vypúšťací ventil nádoby EVAP: 
<intxreftitleoff1 refid = "ASLAP70A1206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ventil PCV: 
<intxreftitleoff1 refid = "ASLAP70A1206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybné časti.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104029009">
<title>
Kontrola výfukového systému a systému vstupu vzduchu
</title>
<test1>
<ptxt>
Skontrolujte, či nie je výfukový systém a systém nasávania vzduchu upchatý alebo netesný.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybnú časť.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104029010">
<title>
Kontrola signálneho obvodu snímača A/F
</title>
<test1>
<ptxt>
Skontrolujte signálne obvody snímača A/F podľa kroku 3 v 
<intxref refid = "ASLAP70A1104025">DTC P0131 / P0132 / P2237 / P2243 / P2251/ P2626</intxref>
.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104029011">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte snímač A/F. 
<intxreftitleoff1 refid = "ASLAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte postup potvrdenia DTC a skontrolujte DTC.
</ptxt>
</test1>
<question>
Je ešte stále rozoznané DTC P0171 alebo P0172?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
