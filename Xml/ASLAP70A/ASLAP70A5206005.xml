<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A5206005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž radiacej páky a tiahla radenia prevodov
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A5206004">Súčiastky radiacej páky a tiahla radenia prevodov</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A5206005001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte ECM z vane akumulátora. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte akumulátor a držiak akumulátora. 
<intxreftitleoff1 refid = "ASLAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zložte prednú podlahovú skriňu prístrojovej dosky. 
<intxreftitleoff1 refid = "ASLAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konce radiacej páky a lanka radenia prevodov (5) z čapu (6) zostavy radiacej páky.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte tiahla voľby prevodu a radenia (1) z telesa radiacej páky (2), pričom ťaháte rýchlospojku (4) v smere podľa obrázku.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte matice (3) a odmontujte teleso radiacej páky zo zadnej podlahy.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520038.swf" width = "88.000mm" height = "74.693mm" ver = "01" gw = "187" gh = "195"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.739in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
7.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Kolík
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Odpojte ovládacie lanká radenia a volenia z prevodovky so spojkou.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte skrutku priechodky tiahla, a potom demontujte z podlahového panela tiahla radenia a voľby prevodov.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A5206005002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dotiahnite každú skrutku a matice na požadovaný uťahovací moment. 
<intxreftitleoff1 refid = "ASLAP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nastavte ovládacie lanko radenia prevodov. 
<intxreftitleoff1 refid = "ASLAP70A5206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
