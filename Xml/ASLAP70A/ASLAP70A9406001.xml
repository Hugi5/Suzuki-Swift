<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9406001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Montáž a demontáž čerpadla a nádržky ostrekovača
</title>
<servinfosub id = "ASLAP70A9406001001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte predný nárazník. 
<intxreftitleoff1 refid = "ASLAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte svorky káblového zväzku (1), konektory čerpadla ostrekovača (2) a hadice ostrekovača (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940004.jpg" width = "88.000mm" height = "67.662mm" ver = "01" gw = "209" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Demontujte skrutky nádržky ostrekovača (1) a demontujte nádržku ostrekovača (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940005.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "180" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Potiahnite čerpadlo ostrekovača čelného skla (1) a čerpadlo zadného ostrekovača (2) v smere šípky a potom ich vyberte z nádržky ostrekovača (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940006.jpg" width = "88.000mm" height = "62.134mm" ver = "01" gw = "161" gh = "160"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9406001002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9406002">Kontrola čerpadla ostrekovača</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utiahnite skrutky nádržky ostrekovača na predpísaný uťahovací moment.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9D001">
<t-part>
Skrutka nádržky ostrekovača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A940008.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "201" gh = "174"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
