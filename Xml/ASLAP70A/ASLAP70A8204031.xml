<servinfosub id = "ASLAP70A8204031003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204031004">
<testgroup id = "ASLAP70A8204031005">
<question>
Vykonala sa „Kontrola diagnostického systému airbagov“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204031006">
<title>
Kontrola jednotky (inflátor) bočného airbagu
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory “Q104” a “Q105”.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte “STEERING WHEEL” (1) špeciálnych nástrojov (A), (B) a (C) ku konektoru “Q104” alebo „Q105“.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B047">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B048">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932–78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B049">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932–75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820026.swf" width = "90.000mm" height = "70.285mm" ver = "02" gw = "211" gh = "183"/>
</testfigure>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je detekované DTC B1062 alebo B1066?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte jednotku (inflátor) bočného airbagu. 
<intxreftitleoff1 refid = "ASLAP70A8206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204031007">
<title>
Kontrola obvodu jednotky (inflátora) bočného airbagu
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie konektora „L04“ a „L05“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor „L04“ alebo „L05“.
</ptxt>
</test1>
<test1>
<ptxt>
Uvoľnite skratovaciu tyč v konektore SDM vložením uvoľňovacieho nástroja, ktorý je vložený do špeciálneho nástroja (A).
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor medzi svorkami “L04-3” a “L04-4” (DTC B1062): nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkami “L05-1” a “L05-2” (DTC B1066): nekonečno
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B050">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820127.swf" width = "90.000mm" height = "108.500mm" ver = "01" gw = "206" gh = "291"/>
</testfigure>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte SDM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204031008">
<title>
Kontrola obvodu podlahového káblového zväzku
</title>
<test1>
<ptxt>
Odpojte konektory “L384” a “L385”.
</ptxt>
</test1>
<test1>
<ptxt>
Uvoľnite skratovaciu tyč v konektore SDM vložením uvoľňovacieho nástroja, ktorý je vložený do špeciálneho nástroja (A).
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor medzi svorkami “L04-3” a “L04-4” (DTC B1062): nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkami “L05-1” a “L05-2” (DTC B1066): nekonečno
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B051">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820127.swf" width = "90.000mm" height = "108.500mm" ver = "01" gw = "206" gh = "291"/>
</testfigure>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte káblový zväzok sedadla.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte káblový zväzok podlahy.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Ak sa vyskytujú DTC, vymažte ich podľa 
<intxref refid = "ASLAP70A8204006">Vymazanie DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
