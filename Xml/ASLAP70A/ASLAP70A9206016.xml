<servinfo servinfosgmlid = "ASLAP70A9206016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia spínača výstražných kontrolných svetiel
</title>
<servinfosub id = "ASLAP70A9206016001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte stredovú vetraciu mriežku (1). 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor a potom vymontujte spínač výstražných svetiel (2) zo stredovej časti prístrojovej dosky, keď sú zámky uvoľnené (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A920023.jpg" width = "88.000mm" height = "65.260mm" ver = "01" gw = "181" gh = "168"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9206016002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9206017">Kontrola spínača výstražných kontrolných svetiel</intxrefpoff>
</ptxt>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
