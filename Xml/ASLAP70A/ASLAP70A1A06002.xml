<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1A06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž akumulátora
</title>
<servinfosub id = "ASLAP70A1A06002001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore (4) odpojte kábel záporného (-) pólu (1).
</ptxt>
</s1>
<s1>
<ptxt>
Na akumulátore (4) odpojte kábel kladného (+) (2) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Zložte držiak (3).
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte akumulátor (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0001.swf" width = "88.000mm" height = "71.286mm" ver = "01" gw = "171" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Vymeňte podložku akumulátora (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte riadiacu jednotku motora (2). 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte konzolu akumulátora (3), ak je to potrebné.
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0002.jpg" width = "88.000mm" height = "55.738mm" ver = "02" gw = "199" gh = "141"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1A06002002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Káble akumulátora bezpečne dotiahnite.
</ptxt>
</item>
<item>
<ptxt>
Ak je to potrebné, inicializujte elektrické zariadenia.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
