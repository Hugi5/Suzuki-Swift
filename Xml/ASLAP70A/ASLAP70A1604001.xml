<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1604001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnostika príznakov chladenia motora
</title>
<diag type = "condition" id = "ASLAP70A1604001001">
<condition>
<ptxt>
Motor sa prehrieva (ventilátor chladiča pracuje) 
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnený alebo pretrhnutý remeň vodného čerpadla
</ptxt>
</ps>
<action>
<ptxt>
Remeň vodného čerpadla nastavte alebo vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nedostatočné množstvo chladiacej kvapaliny
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte hladinu chladiacej kvapaliny a podľa potreby doplňte chladivo. 
<intxreftitleoff1 refid = "ASLAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Chybný termostat
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu termostatu. 
<intxreftitleoff1 refid = "ASLAP70A1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Chybné vodné čerpadlo
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte vodné čerpadlo. 
<intxreftitleoff1 refid = "ASLAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Špinavé alebo ohnuté rebrá chladiča
</ptxt>
</ps>
<action>
<ptxt>
Vyčistite alebo opravte. 
<intxreftitleoff1 refid = "ASLAP70A1606014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Únik chladiacej kvapaliny z chladiaceho systému
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte, či chladiaci systém nepresakuje. 
<intxreftitleoff1 refid = "ASLAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Upchatý chladič
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte radiátor. 
<intxreftitleoff1 refid = "ASLAP70A1606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Chybný uzáver chladiča
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte uzáver chladiča. 
<intxreftitleoff1 refid = "ASLAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zadierajúce sa brzdy
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte brzdy. 
<intxreftitleoff1 refid = "ASLAP70A4104001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Preklzujúca spojka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte spojku. 
<intxreftitleoff1 refid = "ASLAP70A5304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slabo nabitý akumulátor
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte akumulátor. 
<intxreftitleoff1 refid = "ASLAP70A1A04001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Alternátor produkuje slabú elektriku
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte alternátor. 
<intxreftitleoff1 refid = "ASLAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha snímača ECT
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte snímač ECT. 
<intxreftitleoff1 refid = "ASLAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodený elektromotor ventilátora chladiča.
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte ventilátor chladiča motora. 
<intxreftitleoff1 refid = "ASLAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky motora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte ECM a jeho obvod. 
<intxreftitleoff1 refid = "ASLAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodené relé ventilátor chladiča.
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte relé ventilátora chladiča. 
<intxreftitleoff1 refid = "ASLAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Príliš veľa voliteľných elektrických zariadení
</ptxt>
</ps>
<action>
<ptxt>
Odstráňte elektrické zariadenia.
</ptxt>
</action>
<condition>
<ptxt>
Motor sa prehrieva (ventilátor chladiča nepracuje)
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte poistku.
</ptxt>
</action>
<ps>
<ptxt>
Poškodené relé ventilátor chladiča.
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte relé ventilátora chladiča. 
<intxreftitleoff1 refid = "ASLAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha snímača ECT
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte snímač ECT. 
<intxreftitleoff1 refid = "ASLAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodený elektromotor ventilátora chladiča.
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte ventilátor chladiča motora. 
<intxreftitleoff1 refid = "ASLAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky motora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte ECM a jeho obvod. 
<intxreftitleoff1 refid = "ASLAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
