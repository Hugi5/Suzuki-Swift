<section sectnbr = "2C">
<servcat sctnbr = "02" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A2306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zadného tlmiča odpruženia
</title>
<servinfosub id = "ASLAP70A2306003001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Zdvihnite vozidlo dielenským zdvihákom a zložte zadné kolesá. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte kryt prístupového otvoru (1) v štvrtine vnútorného čalúnenia (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A230002.swf" width = "88.000mm" height = "52.091mm" ver = "01" gw = "165" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Podoprite zadnú nápravu pomocou podlahového zdviháka, aby neklesla.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte spodnú maticu (1) a spodnú podložku (5) zadného tlmiča.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte hornú maticu tlmiča odpruženia (2), zadný tlmič odpruženia (3) a horné podložky (4) tlmiča odpruženia.
</ptxt>
<figure>
<graphic graphicname = "IAP70A230002.swf" width = "88.000mm" height = "119.930mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte horné puzdrá tlmiča odpruženia (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A230004.swf" width = "88.000mm" height = "81.823mm" ver = "01" gw = "147" gh = "215"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A2306003002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A2306004">Kontrola zadného tlmiča odpruženia</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Horná matica zadného tlmiča odpruženia je samozaisťovacia. Maticu nepoužívajte opakovane. V opačnom prípade sa môže uvoľniť.
</ptxt>
</attention2>
<s1>
<ptxt>
Namontujte horné puzdrá tlmiča odpruženia (6), zadný tlmič odpruženia (1) a horné podložky tlmiča odpruženia (2) podľa obrázku.
</ptxt>
<ptxt>
V tomto kroku dočasne utiahnite novú hornú (4) a dolnú (5) maticu zadného tlmiča odpruženia.
</ptxt>
<attention3>
<ptxt>
Kvôli dodržaniu správneho smeru montáže hornej podložky tlmiča odpruženia (2) postupujte podľa obrázku.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A230003.swf" width = "88.000mm" height = "52.815mm" ver = "01" gw = "236" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.956in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Panel karosérie
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Vytiahnite podlahový zdvihák spod zadnej nápravy.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte zadné kolesá. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Dotiahnite hornú maticu zadného tlmiča nárazov a spodnú maticu na požadované uťahovacie momenty.
</ptxt>
<attention3>
<ptxt>
Pri doťahovaní týchto matíc vozidlo nesmie byť na zdviháku a nesmie byť naložené.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T2C001">
<t-part>
Horná matica zadného tlmiča odpruženia
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
28
</t-value1>
<t-value2>
2,9
</t-value2>
<t-value3>
21,0
</t-value3>
</torqueitem>
<torqueitem id = "T2C002">
<t-part>
Dolná matica zadného tlmiča odpruženia
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
90
</t-value1>
<t-value2>
9,2
</t-value2>
<t-value3>
66,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A230004.swf" width = "88.000mm" height = "119.931mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte kryt prístupového otvoru v štvrtine vnútorného čalúnenia.
</ptxt>
</s1>
</servinfosub>
