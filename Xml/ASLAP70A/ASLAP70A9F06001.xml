<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9F06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž audio jednotky
</title>
<servinfosub id = "ASLAP70A9F06001001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte stredovú vetraciu mriežku. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte audio jednotku (1) z prístrojovej dosky potom, ako ste odstránili 2 montážne skrutky (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektory zvukovej jednotky (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0004.jpg" width = "88.000mm" height = "63.065mm" ver = "03" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9F06001002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
