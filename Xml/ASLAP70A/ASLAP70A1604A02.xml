<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Motor sa prehrieva (ventilátor chladiča nepracuje)
</title>
<diag type = "condition">
<condition>
<ptxt>
Motor sa prehrieva (ventilátor chladiča nepracuje)
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte poistku.
</ptxt>
</action>
<ps>
<ptxt>
Poškodené relé ventilátor chladiča.
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte relé ventilátora chladiča. 
<intxreftitleoff1 refid = "ASLAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha snímača ECT
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte snímač ECT. 
<intxreftitleoff1 refid = "ASLAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodený elektromotor ventilátora chladiča.
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte ventilátor chladiča motora. 
<intxreftitleoff1 refid = "ASLAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky motora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte ECM a jeho obvod. 
<intxreftitleoff1 refid = "ASLAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
