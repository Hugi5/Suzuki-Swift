<servinfo servinfosgmlid = "ASLAP70A1606009" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola zariadenia termostatu (so snímačom ECT)
</title>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte, či je odvzdušňovací ventil (1) v zostave termostatu čistý.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či sa v sedle ventilu (2) nenachádzajú cudzorodé predmety, ktoré by bránili pevnému nasadeniu ventila.
</ptxt>
<figure>
<graphic graphicname = "I7V20A161006.swf" width = "88.000mm" height = "51.019mm" ver = "01" gw = "123" gh = "128"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Vosková granula
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Skontrolujte zostavu termostatu nasledovne.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Zostavu termostatu (1) ponorte do vody a vodu postupne zohrievajte.
</ptxt>
<attention2>
<ptxt>
Nikdy do vody neponorte konektor snímača ECT.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Skontrolujte, či sa voskové granule začnú otvárať pri stanovenej teplote.
</ptxt>
<spec>
<title>
Teplota, pri ktorej sa ventil začne otvárať (pri zdvihu 0,05 mm (0,002 in)):
</title>
<ptxt>
86,5 – 89,5 &#176;C (187,7 – 193,1 &#176;F)
</ptxt>
</spec>
<spec>
<title>
Teplota, pri ktorej sa ventil naplno otvorí:
</title>
<ptxt>
100 &#176;C (212 &#176;F)
</ptxt>
</spec>
<spec>
<title>
Zdvih ventilu:
</title>
<ptxt>
Viac ako 8 mm (0,3 in) pri 100 &#176;C (212 &#176;F)
</ptxt>
</spec>
<figure page = "2">
<graphic graphicname = "I7V20A161007.swf" width = "88.000mm" height = "49.148mm" ver = "01" gw = "103" gh = "123"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.291in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.328in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.265in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Ohrievač
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Teplomer
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list2>
<item>
<ptxt>
Ak výsledok kontroly nezodpovedá predpísaným hodnotám, vymeňte zariadenie termostatu. 
<intxreftitleoff1 refid = "ASLAP70A1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
