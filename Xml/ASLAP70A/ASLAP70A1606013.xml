<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1606013" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rozobratie a zloženie ventilátora chladiča
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1606012">Demontáž a montáž zostavy ventilátora chladiča</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1606013001">
<title>
Rozobratie
</title>
<s1 page = "2">
<ptxt>
Demontujte z motora ventilátora (2) samotný ventilátor (1).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Demontujte z ochranného krytu ventilátora (3) elektromotor ventilátora (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P160006.jpg" width = "88.000mm" height = "55.324mm" ver = "01" gw = "207" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1606013002" page = "2">
<title>
Zloženie
</title>
<ptxt>
Postupujte opačne ako pri postupe rozobratia.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dotiahnite maticu ventilátora a skrutky motora ventilátora chladiča na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1F001">
<t-part>
Matica ventilátora
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
<torqueitem id = "T1F002">
<t-part>
Skrutka elektromotora ventilátora chladiča
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
4,0
</t-value1>
<t-value2>
0,41
</t-value2>
<t-value3>
3,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70P160010.jpg" width = "88.000mm" height = "51.127mm" ver = "03" gw = "223" gh = "128"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
