<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7214A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nevychádza von teplý vzduch alebo nedostatočné vykurovanie (nesprávne ovládanie teploty)
</title>
<diag type = "condition">
<condition>
<ptxt>
Nevychádza von teplý vzduch alebo nedostatočné vykurovanie (nesprávne ovládanie teploty)
</ptxt>
</condition>
<ps>
<ptxt>
Zlomený alebo ohnutý kábel ovládania teploty
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte tiahlo regulácie teploty.
</ptxt>
</action>
<ps>
<ptxt>
Porucha ovládača teploty
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte volič teploty.
</ptxt>
</action>
<ps>
<ptxt>
Nesprávna inštalácia tiahla regulácie teploty
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte polohu kábla a ak je to potrebné, upravte ju.
</ptxt>
</action>
<ps>
<ptxt>
Porucha jednotky klapky regulácie teploty
</ptxt>
</ps>
<action>
<ptxt>
Jednotku klapky regulácie teploty opravte.
</ptxt>
</action>
<ps>
<ptxt>
Upchaté vzduchové potrubie
</ptxt>
</ps>
<action>
<ptxt>
Vzduchovody opravte.
</ptxt>
</action>
<ps>
<ptxt>
Unikanite alebo upchatie výmenníka tepla
</ptxt>
</ps>
<action>
<ptxt>
Výmenník tepla vymeňte.
</ptxt>
</action>
<ps>
<ptxt>
Unikanite alebo upchatie hadíc výmenníka
</ptxt>
</ps>
<action>
<ptxt>
Hadice vykurovania vymeňte.
</ptxt>
</action>
<ps>
<ptxt>
Chybný termostat
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte termostat. 
<intxreftitleoff1 refid = "ASLAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha snímača ECT
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte snímač ECT. 
<intxreftitleoff1 refid = "ASLAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
