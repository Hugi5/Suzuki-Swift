<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3116008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž hlavy (náboja) predného kolesa, otáčavého čapu riadenia a ložiska kolesa
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A3116006">Diely hlavy predného kolesa a otáčavého čapu riadenia:Predný</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Keď demontujte a montujete teleso otočného čapu riadenia, dbajte na to, aby ste nepoškodili prachový kryt prednej brzdy kĺbu ramena zavesenia.
</ptxt>
</attention2>
<servinfosub id = "ASLAP70A3116008001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Zdvihnite vozidlo a odmontujte predné koleso. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte maticu hriadeľa riadenia. 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte brzdový kotúč. 
<intxreftitleoff1 refid = "ASLAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou špeciálnych nástrojov vytiahnite hlavu kolesa (1).
</ptxt>
<attention3>
<ptxt>
Vonkajšia strana vnútorného krúžka ložiska kolesa vychádza von aj s hlavou kolesa.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3A103">
<s-part>
(A)
</s-part>
<s-number num = "09943-17912">
09943–17912
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A104">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942–15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311016.swf" width = "88.000mm" height = "57.642mm" ver = "01" gw = "181" gh = "147"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Odpojte od otočného čapu riadenia hlavu riadiacej tyče. 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Z otočného čapu riadenia odstráňte snímač otáčok predného kolesa. 
<intxreftitleoff1 refid = "ASLAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky a matice konzoly vzpery. 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte guľový čap zavesenia od otáčavého čapu riadenia. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Z hnacieho hriadeľa demontujte otočný čap riadenia.
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte tesnenie (1) na 4 miestach pomocou dláta alebo podobne.
</ptxt>
</s1>
<s1>
<ptxt>
Zložte prachový kryt prednej brzdy (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A311015.swf" width = "88.000mm" height = "63.961mm" ver = "01" gw = "187" gh = "165"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Odmontujte poistný krúžok (1) z otočného čapu.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte ložisko kolesa pomocou hydraulického lisu (1) a špeciálnych nástrojov.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A105">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913–75810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A106">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951–18211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A311017.swf" width = "88.000mm" height = "46.725mm" ver = "01" gw = "99" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Vypáčte ložisko kolesa z vnútorného krúžku (1) pomocou malého dláta, alebo podobného nástroja.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte vnútorný krúžok z vonkajšieho ložiska kolesa (1) z hlavy kolesa pomocou špeciálneho nástroja tak, ako je to zobrazené na obrázku.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A107">
<s-part>
(A)
</s-part>
<s-number num = "09913-65810">
09913–65810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A108">
<s-part>
(B)
</s-part>
<s-number num = "09926-37610-003">
09926–37610–003
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311020.swf" width = "88.000mm" height = "78.517mm" ver = "01" gw = "104" gh = "206"/>
</figure>
</s1>
<s1>
<ptxt>
Pomocou medenej paličky alebo hydraulického lisu demontujte skrutky náboja (1), ak je to potrebné.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A220020.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "166" gh = "128"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASLAP70A3116008002">
<title>
Montáž
</title>
<s1>
<ptxt>
Do otvoru na náboji vložte novú skrutku (1). Pomaly otáčajte nábojom, aby ste sa uistili, že je zúbkovanie zarovnané s tým, ktoré vytvorila pôvodná skrutka, ak bol odmontovaný.
</ptxt>
<figure>
<graphic graphicname = "I2RH01220040.swf" width = "88.000mm" height = "47.317mm" ver = "01" gw = "142" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Nasaďte nové ložisko kolesa (1) na otočný čap riadenia (2) hnedou tesniacou stranou (3) nadol podľa obrázku.
</ptxt>
</s1>
<s1>
<ptxt>
Tlakom nalistujte ložisko kolesa do otočného čapu nápravy (2) pomocou špeciálnych nástrojov podľa obrázku.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A109">
<s-part>
(A)
</s-part>
<s-number num = "09913-75510">
09913–75510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A110">
<s-part>
(B)
</s-part>
<s-number num = "09926-68310">
09926–68310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A111">
<s-part>
(C)
</s-part>
<s-number num = "09951-18211">
09951–18211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311022.swf" width = "88.000mm" height = "71.587mm" ver = "01" gw = "232" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte poistný krúžok (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Nastavte nový prachový kryt do predpísanej polohy na otočný čap riadenia zobrazenej na obrázku.
</ptxt>
<attention2>
<ptxt>
Dávajte pozor, aby ste pri zalisovaní nezdeformovali prachový kryt.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Nasuňte tlakom prachový kryt prednej brzdy (2) do otočného čapu nápravy pomocou hydraulického lisu (1) a špeciálnych nástrojov.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A112">
<s-part>
(A)
</s-part>
<s-number num = "09951-17010">
09951–17010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A113">
<s-part>
(B)
</s-part>
<s-number num = "09944-77030">
09944–77030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311018.swf" width = "88.000mm" height = "55.099mm" ver = "01" gw = "203" gh = "140"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.135in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.595in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
„a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
13&#176;
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“b”:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
70 mm (2,8 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Utesnite viac ako 4 miesta pomocou malého dláta, alebo malého plochého dláta.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311020.swf" width = "88.000mm" height = "52.911mm" ver = "01" gw = "186" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Utesnenie
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Pomocou špeciálneho nástora a hydraulického lisu nasaďte náboj kolesa (1) do ložiska kolesa (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L3A114">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913–75810
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3A115">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951–18211
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311017.swf" width = "88.000mm" height = "57.910mm" ver = "01" gw = "203" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Pripojte hnací hriadeľ k otočnému čapu riadenia. 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte otáčavý čap riadenia na rameno zavesenia. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte skrutky a matice konzoly vzpery. 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte predný snímač otáčok kolesa. 
<intxreftitleoff1 refid = "ASLAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte hlavu spojovacej tyče na otočný čap. 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nainštalujte brzdový kotúč a strmeň brzdy. 
<intxreftitleoff1 refid = "ASLAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Dotiahnite maticu hnacieho hriadeľa na predpísaný uťahovací moment a maticu zatesnite. 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Uistite sa, že ste použili novú maticu hnacieho hriadeľa.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Namontujte predné koleso. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte geometriu predných kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
