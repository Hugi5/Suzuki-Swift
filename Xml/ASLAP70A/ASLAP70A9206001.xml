<servinfo servinfosgmlid = "ASLAP70A9206001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž jednotky čelného svetlometu
</title>
<attention1>
<ptxt>
Žiarovky svetlometov môžu byť mimoriadne horúce. Ak ich budete chytať neopatrne, môžete sa popáliť.
</ptxt>
</attention1>
<attention2>
<ptxt>
Nedotýkajte sa skleneného povrchu žiarovky holými rukami. Povrch žiarovky sa zašpiní a pri svietení nebude čistý.
</ptxt>
</attention2>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Žiarovka(y) môžete vymeniť keďže jednotka predných svetlometov je namontovaná na vozidle.
</ptxt>
</item>
<item>
<ptxt>
Po výmene jednotky predných svetlometov a/alebo žiarovky predných svetlometov, skontrolujte a nastavte svetlomety. 
<intxreftitleoff1 refid = "ASLAP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<servinfosub id = "ASLAP70A9206001001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte predný nárazník. 
<intxreftitleoff1 refid = "ASLAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektory jednotky svetlometu.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky jednotky svetlometu (1) a svorku a potom vyberte jednotku svetlometu (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P920007.jpg" width = "88.000mm" height = "69.820mm" ver = "01" gw = "206" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
V prípade potreby vymeňte žiarovky.
</ptxt>
<figure>
<graphic graphicname = "IAP70P920041.swf" width = "88.000mm" height = "68.513mm" ver = "02" gw = "212" gh = "178"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.237in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.402in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.216in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.601in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Žiarovka obrysových svetiel
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Objímka smerových svetiel
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Žiarovka smerových svetiel
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Objímka žiarovky obrysových svetiel
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Žiarovka predných svetlometov
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
6.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Kryt objímky
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9206001002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Namontujte svorku jednotky svetlometu.
</ptxt>
</item>
<item>
<ptxt>
Skrutky namontujte v číslenom poradí (1, “1” – 1, “4”) podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920008.jpg" width = "88.000mm" height = "69.820mm" ver = "02" gw = "206" gh = "181"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
