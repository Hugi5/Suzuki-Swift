<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3116003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž sústavy predného hnacieho hriadeľa
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A3116001">Diely predného hnacieho hriadeľa:Predný</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A3116002">Kontrola sústavy predného hnacieho hriadeľa na vozidle:Predný</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A3116003001">
<title>
Demontáž
</title>
<s1 page = "2">
<ptxt>
Zdvihnite vozidlo a odmontujte predné koleso. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odstráňte utesnenie (1) a demontujte maticu hnacieho hriadeľa (2), pričom je brzdový pedál vytlačený.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311002.swf" width = "88.000mm" height = "54.100mm" ver = "01" gw = "182" gh = "137"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Vypustite olej prevodovky a olej rozvodovky.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Olej prevodovky so spojkou: 
<intxreftitleoff1 refid = "ASLAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Olej rozdeľovacej prevodovky: 
<intxreftitleoff1 refid = "ASLAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Z otočného čapu riadenia odstráňte snímač otáčok predného kolesa. 
<intxreftitleoff1 refid = "ASLAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odpojte guľový čap zavesenia od otáčavého čapu riadenia. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Použitím páky (1) alebo plastového kladiva (3) vytiahnite kĺb hnacieho hriadeľa (2).
</ptxt>
<attention3>
<ptxt>
Otáčanie hnacieho hriadeľa počas jeho vyťahovania uľahčí uvoľnenie poistného krúžku klinovej drážky.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A311004.swf" width = "88.000mm" height = "41.941mm" ver = "01" gw = "197" gh = "102"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.298in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.298in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Hriadeľ na ľavej strane
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Hriadeľ na pravej strane
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte sústavu hnacieho hriadeľa.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASLAP70A3116003002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Buďte opatrní, aby ste pri montovaní hnacieho hriadeľa nepoškodili olejové tesnenie a puzdrá.
</ptxt>
</item>
<item>
<ptxt>
Neudierajte kladivom o puzdro kĺbu. Kĺby je povolené montovať len ručne.
</ptxt>
</item>
<item>
<ptxt>
Uistite sa, že kĺb na strane diferenciálu je vsadený na doraz a že jeho poistný krúžok je osadený tak, ako bol predtým.
</ptxt>
</item>
<item>
<ptxt>
Pred vložením hnacieho hriadeľa (1) sa uistite, že okolo prevodníka (2) na ložisku kolesa sa nenachádzajú žiadne cudzie predmety.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311003.swf" width = "88.000mm" height = "51.493mm" ver = "01" gw = "203" gh = "129"/>
</figure>
</item>
</list1>
</attention2>
<list1 type = "unordered">
<item>
<ptxt>
Použite nový poistný krúžok strany diferenciálu.
</ptxt>
</item>
<item>
<ptxt>
Na dosadacie plochy hlavy predného kolesa a hnací hriadeľ naneste vazelínu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A101" uid = "1126491901">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A311005.jpg" width = "88.000mm" height = "67.700mm" ver = "01" gw = "230" gh = "175"/>
</figure>
</item>
<item>
<ptxt>
Dotiahnite maticu (1) hnacieho hriadeľa na predpísaný uťahovací moment.
</ptxt>
<attention2>
<ptxt>
Uistite sa, že ste použili novú maticu hnacieho hriadeľa.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T3A101">
<t-part>
Matica hnacieho hriadeľa
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Maticu hnacieho hriadeľa (1) utesnite podľa obrázku.
</ptxt>
<attention2>
<ptxt>
Dbajte na to, aby ste pri utesňovaní matice hnacieho hriadeľa nepoškodili jej tesniacu časť (2). Ak je prasknutá, vymeňte ju za novú.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A311006.swf" width = "88.000mm" height = "54.205mm" ver = "01" gw = "172" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Pripojte kĺb ramena nápravy. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Namontujte predný snímač otáčok kolesa. 
<intxreftitleoff1 refid = "ASLAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Namontujte predné koleso. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Doplňte olej do prevodovky. 
<intxreftitleoff1 refid = "ASLAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Doplňte olej do prevodovky. 
<intxreftitleoff1 refid = "ASLAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte geometriu predných kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
