<servinfosub id = "ASLAP70A1104024003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</attention3>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ na 10 sek.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104024004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104024005">
<testgroup id = "ASLAP70A1104024006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104024007">
<title>
Kontrola obvodu napájania snímača TP
</title>
<test1>
<ptxt>
Ak je zapaľovanie odpojené, odpojte konektor snímača TP.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie konektora snímača TP na každej svorke.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi obvodom „B1“ a „B4“ je pribl. 5 V.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104024008">
<title>
Skontrolujte uzemňovací obvod snímača tlaku v pneumatikách
</title>
<test1>
<ptxt>
Skontrolujte, že napätie medzi obvodom „B1“ a uzemnením je pribl. 5 V.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Opravte obvod „B4“.
</ptxt>
<ptxt>
Ak je detekovaná táto DTC opätovne, vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod „B1“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104024009">
<title>
Kontrola signálneho obvodu snímača (hlavný) TP
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „B2“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B2“ a ďalšou svorkou v konektore snímača TP: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „B2“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte signálny obvod snímača TP (hlavný).
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104024010">
<title>
Kontrola snímača polohy škrtiacej klapky
</title>
<test1>
<ptxt>
Skontrolujte snímač TP podľa „Kontrola funkčnosti snímača polohy škrtiacej klapky“ v 
<intxref refid = "ASLAP70A1306004">Kontrola telesa elektrickej škrtiacej klapky vo vozidle</intxref>
.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zariadenie telesa elektrickej škrtiacej klapky.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
