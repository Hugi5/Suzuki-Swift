<servinfosub id = "ASLAP70AA204012003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA204012004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA204012005">
<testgroup id = "ASLAP70AA204012008">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF (vyp.) a k prípojke na údajové spojenie pripojte skenovacie zariadenie SUZUKI.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte „Auto Light Sensor“ zobrazenú na skenovacom zariadení SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204012006">
<title>
Kontrola obvodu signálu snímača automatického zapnutia predných svetlometov
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte snímač automatického zapnutia svetiel a konektory “G05”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svorky k snímaču automatického zapnutia svetiel a konektorov “G05”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor medzi obvodom „A1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkami obvodu “A1” a “A3” v konektore snímača automatického zapnutia svetiel: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204012007">
<title>
Kontrola snímača autom. zap. pred. svetiel
</title>
<test1>
<ptxt>
Skontrolujte snímač autom. zap. pred. svetiel. 
<intxreftitleoff1 refid = "ASLAP70A9206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte snímač autom. zap. pred. svetiel. 
<intxreftitleoff1 refid = "ASLAP70A9206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204012009">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte snímač automatického zapnutia svetiel a konektory “G05”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa aktuálne DTC B1132?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte BCM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
</testgroup>
</diag>
