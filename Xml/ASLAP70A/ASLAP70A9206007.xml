<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž osvetlenia evidenčného čísla vozidla
</title>
<servinfosub id = "ASLAP70A9206007001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte skrutky spodného obloženia zadných koncových dverí (1) a potom obloženie vyberte (2).
</ptxt>
</s1>
<s1>
<ptxt>
Domontujte svetlo osvetlenia evidenčného čísla vozidla (3).
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor osvetlenia evidenčného čísla vozidla.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920001.jpg" width = "88.000mm" height = "80.485mm" ver = "01" gw = "211" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Vyberte žiarovku.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9206007002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utiahnite skrutky obloženia zadných koncových dverí na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T9B001">
<t-part>
Skrutka obloženia zadných koncových dverí
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A920002.jpg" width = "88.000mm" height = "80.884mm" ver = "01" gw = "211" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
