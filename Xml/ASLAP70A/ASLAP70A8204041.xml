<servinfosub id = "ASLAP70A8204041003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204041004">
<testgroup id = "ASLAP70A8204041005">
<question>
Vykonala sa „Kontrola diagnostického systému airbagov“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204041006">
<title>
Kontrola obvodu káblového zväzku prístrojového panela
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “G222”.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “G11”.
</ptxt>
</test1>
<test1>
<ptxt>
Uvoľnite skratovaciu tyč v konektore SDM vložením uvoľňovacieho nástroja, ktorý je vložený do špeciálneho nástroja (A).
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovný bod.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie medzi každým obvodom „G11-1“ a „G11-2“ a uzemnením: pribl. 0 V
</ptxt>
<servicetool>
<servicetoolitem id = "L8B077">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
</item>
</list1>
<testfigure>
<graphic graphicname = "IAW10A820027.swf" width = "90.000mm" height = "58.392mm" ver = "01" gw = "197" gh = "149"/>
</testfigure>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte SDM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Ak sa vyskytujú DTC, vymažte ich podľa 
<intxref refid = "ASLAP70A8204006">Vymazanie DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
