<servinfosub id = "ASLAP70A1104017003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 10,5 V
</ptxt>
</item>
<item>
<ptxt>
DTC P0560, P0562 alebo P0563 nie sú detekované.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Motor nechajte 10 sek. bežať na voľnobežných otáčkach.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104017004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104017005">
<testgroup id = "ASLAP70A1104017006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104017007">
<title>
Kontrola obvodu napájania snímača MAF
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté, odpojte konektor snímača MAF a IAT.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektorom snímača MAF a IAT.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi obvodom „A1“ a „C1“ je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104017008">
<title>
Kontrola obvodu uzemnenia snímača MAF
</title>
<test1>
<ptxt>
Skontrolujte, že napätie medzi „A1“ a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Opravte obvod „C1“.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod „A1“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104017009">
<title>
Kontrola obvodu referenčného napätia snímača MAF
</title>
<test1>
<ptxt>
Skontrolujte, že napätie medzi obvodom „A2“ a „C1“ je pribl. 5 V.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Opravte obvod „A2“.
</ptxt>
<ptxt>
Ak je detekovaná táto DTC opätovne, vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104017010">
<title>
Kontrola obvodu signálu snímača MAF
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „A3“: menej ako 1Ω
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A3“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A3“ a ďalšou svorkou v konektore snímača MAF a IAT: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „A3“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104017011">
<title>
Kontrola snímača MAF
</title>
<test1>
<ptxt>
Skontrolujte snímač MAF. 
<intxreftitleoff1 refid = "ASLAP70A1306026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte snímač teploty nasávaného vzduchu a hmotnosti vzduchu.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
