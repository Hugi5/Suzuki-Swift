<servinfosub id = "ASLAP70A4601005001">
<title>
Stav a činnosť výstražných kontroliek a oznamovacích kontroliek
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.188in"/>
<colspec colnum = "2" colname = "2" colwidth = "5.021in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Výstražná kontrolka / oznamovacia kontrolka
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Stav a činnosť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Výstražná kontrolka ABS
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Ak má ABS poruchu, kontrolka sa rozsvieti.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Výstražná kontrolka EBD (výstražná kontrolka brzdového systému)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Ak má EBD systém abnormalitu, kontrolka sa zapne spolu s výstražnou kontrolkou ABS a výstražnou kontrolkou ESP<sup>®</sup>.
</ptxt>
</item>
<item>
<ptxt>
Ak je hladina brzdovej kvapaliny v nádržke nižšia ako minimálna hladina, kontrolka sa zapne (ON).
</ptxt>
</item>
<item>
<ptxt>
Páka parkovacej brzdy je vytiahnutá, zapne sa aj kontrolka (ON).
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Výstražná kontrolka ESP<sup>®</sup>
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Ak má ESP<sup>®</sup> poruchu, kontrolka sa rozsvieti.
</ptxt>
</item>
<item>
<ptxt>
Ak je aktivované ovládanie trakcie a/alebo stability, kontrolka bliká.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Kontrolka vypnutia ESP<sup>®</sup>
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Zapne sa vypínač ESP<sup>®</sup>, aby indikoval, že hydraulická/riadiaca jednotka ESP<sup>®</sup> zastavila funkcie kontroly trakcie a stability.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
</servinfo>
