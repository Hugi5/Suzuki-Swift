<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4106023" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola posilňovača bŕzd
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4106022">Demontáž a montáž posilňovača bŕzd</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte, či nie je poškodený posilňovač bŕzd.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte funkčnosť posilňovača bŕzd podľa „Kontrola prevádzky“ v časti 
<intxref refid = "ASLAP70A4106021">Kontrola funkcie posilňovača bŕzd</intxref>
 .
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte puzdro, či nie je zlomené alebo opotrebované.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte dĺžku tlačnej tyče.
</ptxt>
<ptxt>
Ak nie je výsledok kontroly taký, ako je špecifikované, posilňovač bŕzd vymeňte.
</ptxt>
</item>
</list1>
<spec>
<title>
Dĺžka tlačnej tyče
</title>
<ptxt>
„a”: 114,5 – 115,5 mm (4,507 – 4,547 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I3RM0A410056.swf" width = "88.000mm" height = "44.057mm" ver = "01" gw = "139" gh = "108"/>
</figure>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
