<servinfosub id = "ASLAP70A8204010002">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204010003">
<testgroup id = "ASLAP70A8204010004">
<title>
Kontrola výstražnej kontrolky
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<question>
Rozsvietili sa ostatné kontrolky?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204010005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Skenovacie zariadenie Suzuki pripojte k DLC.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zistilo sa DTC U0073?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70AA804004">Riešenie problémov v prípade vypnutia komunikačnej zbernice</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte SDM a prekontrolujte. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204010006">
<title>
Kontrola poistky
</title>
<question>
Je poistka „MTR“ pre zdužený merač v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte poistku „MTR“ a skontrolujte, či je obvod uzemnený.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204010007">
<title>
Kontrola komunikačného obvodu CAN
</title>
<test1>
<ptxt>
Skontrolujte komunikačný obvod CAN medzi SDM a združeným meračom.
</ptxt>
</test1>
<question>
Je obvod v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204010008">
<title>
Kontrola obvodu napájania združeného prístroja
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odmontujte združený merač.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku koncovke &#34;RED/WHT&#34; a &#34;GRY&#34; vodiča konektora združeného merača.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odmerajte napätie medzi vodičom “RED/WHT” a uzemnením.
</ptxt>
</test1>
<question>
Je to 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod napájania pre združený merač.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204010009">
<title>
Kontrola obvodu uzemnenia združeného merača
</title>
<test1>
<ptxt>
Odmerajte odpor medzi obvodom „GRY“ a uzemnením.
</ptxt>
</test1>
<question>
Je odpor menší ako 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte združený merač a opätovne skontrolujte činnosť výstražnej kontrolky „AIR BAG“. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
&#34;GRY&#34; obvod prerušený.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
