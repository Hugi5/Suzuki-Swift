<servinfosub id = "ASLAP70AA204011003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA204011004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA204011005">
<testgroup id = "ASLAP70AA204011009">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF (vyp.) a k prípojke na údajové spojenie pripojte skenovacie zariadenie SUZUKI.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte „Battery Voltage“, „Ignition 1 Switch“ a „ACC Switch“ na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204011006">
<title>
Skontrolujte poistku obvodu
</title>
<test1>
<ptxt>
Zapaľovanie nastavte na “OFF” a potom vyberte poistku “DOME” a poistku “HAZ” z J/B.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte poistku “DOME” a poistku “HAZ”.
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte poistku (poistky).
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204011007">
<title>
Kontrola obvodu záložnej dodávky energie BCM
</title>
<test1>
<ptxt>
Odpojte konektory “E323” a “E324” zo spojovacieho bloku.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „E323“ a „E324“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie obvodu „A1“ a uzemnením: Napätie akumulátora
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „A2“ a uzemnením: Napätie akumulátora
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte, či nie je vodič “WHT/BLK” alebo “WHT” prerušený alebo skratovaný.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204011008">
<title>
Kontrola obvodu záložného napájania BCM
</title>
<test1>
<ptxt>
Odpojte od BCM konektor „E04“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie konektora každého snímača na konektore „E04“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie obvodu „A3“ a uzemnením: Napätie akumulátora
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „A4“ a uzemnením: Napätie akumulátora
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte BCM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte vodiče “BRN” a/alebo “BLK/RED”, či nie sú obvody skratované alebo prerušené k uzemneniu.
</ptxt>
</action>
</testgroup>
</diag>
