<servinfosub id = "ASLAP70A4604011002">
<title>
Popis obvodu
</title>
<ptxt>
Pozrite si „Popis obvodu“ v oddiele 
<intxref refid = "ASLAP70A4604010">Výstražná kontrolka ESP® sa nerozsvieti, keď je spínač zapaľovania v polohe ON (zap.)</intxref>
.
</ptxt>
</servinfosub>
<servinfosub id = "ASLAP70A4604011003">
<title>
Riešenie problémov
</title>
<diag type = "test" id = "ASLAP70A4604011004">
<testgroup id = "ASLAP70A4604011005">
<title>
Kontrola konektora riadiacej jednotky ESP®
</title>
<test1>
<ptxt>
Skontrolujte správne pripojenie konektora k riadiacej jednotke ESP<sup>® </sup>.
</ptxt>
</test1>
<question>
Je spojenie v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Konektor riadne pripojte.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604011006">
<title>
Skontrolujte DTC v ESP®
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70A4604005">Kontrola DTC</intxref>
.
</ptxt>
</test1>
<question>
Našli ste nejaké DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným procesom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604011007">
<title>
Kontrola obvodov napájania a uzemnenia riadiacej jednotky ESP®
</title>
<test1>
<ptxt>
Skontrolujte obvod napájania a uzemnenia riadiacej jednotky ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "ASLAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú obvody v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604011008">
<title>
Kontrola združeného merača
</title>
<test1>
<ptxt>
Vymeňte združený prístroj. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<question>
Zostala výstražná kontrolka zapnutá?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte činnosť výstražnej kontrolky. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
