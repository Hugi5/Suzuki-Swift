<title>
Kontrola komunikácie CAN
</title>
<ptxt>
Pomocou skenovacieho nástroja SUZUKI vykonajte DTC poruchy komunikácie v Kontrola zbernice a skontrolujte DTC všetkých riadiacich jednotiek pripojených k zbernici komunikácie CAN.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "3" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.854in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.854in"/>
<colspec colnum = "3" colname = "3" colwidth = "1.457in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Stav
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Činnosť
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Údaje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
V každom systéme bola detekovaná iba história DTC.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Skontrolujte DTC opätovne, vymažte DTC a vykonajte jazdnú skúšku. Ak je výsledok kontroly v poriadku, je to prerušovaná porucha. 
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
—
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
V ktoromkoľvek systéme bola detekovaná Zbernica riadiacej jednotky vyp. (aktuálna DTC)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Vykonajte riešenie problémov v prípade vypnutia komunikačnej zbernice 
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
<intxreftitleoff1 refid = "ASLAP70AA804004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
V ktoromkoľvek systéme bola detekovaná iba Stratená komunikácia (aktuálne DTC)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Vykonajte riešenie problémov v prípade straty komunikácie
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
<intxreftitleoff1 refid = "ASLAP70AA804003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Na skenovacom nástroji SUZUKI nie je nič zobrazené (nie je možné komunikovať so všetkými systémami)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Skontrolujte, či skenovacie zariadenie SUZUKI dokáže komunikovať pripojením k inému vozidlu.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
