<section sectnbr = "9C">
<servcat sctnbr = "09" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9306004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž riadiacej jednotky systému parkovacieho snímača (ak je vo výbave)
</title>
<servinfosub id = "ASLAP70A9306004001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte zadné obloženie dolnej štvrtiny. 
<intxreftitleoff1 refid = "ASLAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor riadiacej jednotky systému parkovacieho snímača (1) a konektor bzučiaka parkovacieho snímača (2) od riadiacej jednotky systému parkovaiceho snímača.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky (3) a vyberte riadiacu jednotku systému parkovacieho snímača (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A930024.jpg" width = "88.000mm" height = "56.820mm" ver = "02" gw = "205" gh = "145"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9306004002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
