<servinfo servinfosgmlid = "ASLAP70A1104073" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0602
</title>
<servinfosub id = "ASLAP70A1104073001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<attention3>
<ptxt>
Ak sa po preprogramovaní ECM vyskytne DTC P0602, je možné, že sa preprogramovanie ECM nevykonalo správne.
</ptxt>
</attention3>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.602in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.602in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0602: Programová chyba riadiacej jednotky
</emph>
</ptxt>
<ptxt>
Interná porucha ECM alebo chyba v programovaní ECM
</ptxt>
<ptxt>
(Logika rozpoznávania 1 jazdného cyklu)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Preprogramovanie zlyhania ECM
</ptxt>
</item>
<item>
<ptxt>
Obvod napájania a/alebo obvod uzemnenia ECM
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70A1104073002">
<title>
Popis systému
</title>
<s1>
<ptxt>
Otočte spínač zapaľovania na 10 sek. do polohy ON.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104073003">
<title>
Postup potvrdenia DTC
</title>
<diag type = "test" id = "ASLAP70A1104073005">
<testgroup id = "ASLAP70A1104073006">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymažte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte postup potvrdenia DTC a skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC P0602?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte kvôli občasným problémom. 
<intxreftitleoff1 refid = "ASLAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104073007">
<title>
Kontrola preprogramovania ECM
</title>
<question>
Vykonalo sa preprogramovanie ECM?
</question>
<result type = "yes"/>
<action>
<ptxt>
Znova raz správne preprogramujte ECM.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104073008">
<title>
Kontrola obvodu uzemnenia a napájania riadiacej jednotky motora
</title>
<test1>
<ptxt>
Skontrolujte napájací a uzemňovací obvod riadiacej jednotky motora. 
<intxreftitleoff1 refid = "ASLAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Nahraďte overenou riadiacou jednotkou motora a opäť skontrolujte. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
