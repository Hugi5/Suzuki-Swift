<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0A5A: Výkon/rozsah obvodu snímača prúdu alternátora
</emph>
</ptxt>
<ptxt>
Ktorákoľvek z nasledovných podmienok je splnená.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Signálny obvod snímača elektrického zaťaženia je vyšší ako 4,8 V na 5 sek.
</ptxt>
</item>
<item>
<ptxt>
Signálny obvod snímača elektrického zaťaženia je nižší ako 0,2 V na 5 sek.
</ptxt>
</item>
<item>
<ptxt>
Signálny obvod snímača elektrického zaťaženia kolíše nižšie ako predpísaná hodnota na 5 sek.
</ptxt>
</item>
</list1>
<ptxt>
(logika rozpoznania 3 jazdného cyklu, ale kontrolka poruchy nesvieti)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Snímač elektrického zaťaženia a/alebo jeho obvody
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
