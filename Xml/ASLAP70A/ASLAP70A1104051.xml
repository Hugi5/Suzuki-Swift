<servinfosub id = "ASLAP70A1104051003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ na 10 sek.
</ptxt>
</s1>
<s1>
<ptxt>
Motor nechajte 1 min. bežať na voľnobežných otáčkach.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104051004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104051005">
<testgroup id = "ASLAP70A1104051006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104051007">
<title>
Kontrola obvodu napájania snímača elektrického zaťaženia
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté, odpojte snímač elektrického zaťaženia.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektoru snímača elektrického zaťaženia.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi obvodom „A1“ a „A4“ je pribl. 5 V.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104051008">
<title>
Kontrola uzemňovacieho obvodu snímača elektrického zaťaženia
</title>
<test1>
<ptxt>
Skontrolujte, že napätie medzi obvodom „A1“ a uzemnením je pribl. 5 V.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Opravte obvod „A4“.
</ptxt>
<ptxt>
Ak je detekovaná táto DTC opätovne, vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod „A1“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104051009">
<title>
Kontrola obvodu signálu snímača elektrického zaťaženia
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „A2“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A2“ a ďalšou svorkou konektora snímača elektrického prúdu elektrickej zážťaže: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „A2“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104051010">
<title>
Kontrola snímača elektrického prúdu elektrickej záťaže
</title>
<test1>
<ptxt>
Kontrola snímača elektrického zaťaženia. 
<intxreftitleoff1 refid = "ASLAP70A1306028"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte snímač elektrického prúdu elektrickej zážťaže.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
