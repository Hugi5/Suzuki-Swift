<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zostavy ventilátora chladiča
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1606010">Kontrola zostavy ventilátora chladiča vo vozidle</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1606012001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Vypustite chladiacu kvapalinu. 
<intxreftitleoff1 refid = "ASLAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte prípojku motora ventilátora chladiča (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte nádržku (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte prítokovú hadicu (3) od chladiča.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160005.swf" width = "88.000mm" height = "70.920mm" ver = "01" gw = "221" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Z chladiča odmontujte montážnu zostavu ventilátora chladiča.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASLAP70A1606012002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Chladiaci systém doplňte chladiacou kvapalinou. 
<intxreftitleoff1 refid = "ASLAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či chladiaci systém nepresakuje. 
<intxreftitleoff1 refid = "ASLAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
