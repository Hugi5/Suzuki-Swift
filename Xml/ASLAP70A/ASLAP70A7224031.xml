<title>
DTC B1580 / B1902
</title>
<servinfosub id = "ASLAP70A7224031001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.922in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.288in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1580: Chyba EEPROM
</emph>
</ptxt>
<ptxt>
Chyba EEPROM sa vyskytla v riadiacej jednotke HVAC.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka HVAC
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1902: Programová chyba riadiacej jednotky
</emph>
</ptxt>
<ptxt>
Chyba sa vyskytla v programe v riadiacej jednotke HVAC.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70A7224031002">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224031003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224031004">
<testgroup id = "ASLAP70A7224031005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Zapnite spínač zapaľovania a skontrolujte DTC.
</ptxt>
</test1>
<question>
Stále sa zobrazuje DTC B1580 alebo B1902?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku HVAC a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
