<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A5204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vyskakovanie kolies prevodových stupňov zo záberu
</title>
<diag type = "condition">
<condition>
<ptxt>
Vyskakovanie kolies prevodových stupňov zo záberu
</ptxt>
</condition>
<ps>
<ptxt>
Opotrebovaný hriadeľ zaraďovacej vidlice
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte hriadeľ zaraďovacej vidlice alebo hriadeľ radenia.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Radiaca tyč nízkych rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Radiaca tyč vysokých rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zaraďovacia vidlica kolesa 5. rýchlostného stupňa: 
<intxreftitleoff1 refid = "ASLAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Opotrebovaná radiaca vidlica alebo objímka synchronizátora
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte zaraďovaciu vidlicu, hriadeľ radenia alebo synchronizačnú objímku a náboj.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Radiaca tyč nízkych rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Radiaca tyč vysokých rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zaraďovacia vidlica kolesa 5. rýchlostného stupňa: 
<intxreftitleoff1 refid = "ASLAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Náboj a puzdro synchronizačnej spojky nízkych rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Náboj a puzdro synchronizačnej spojky vysokých rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Náboj a puzdro 5. rýchlostného stupňa: 
<intxreftitleoff1 refid = "ASLAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Opotrebované alebo poškodené nastavovacie pružiny
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte nastavovaciu pružinu. 
<intxreftitleoff1 refid = "ASLAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované ložiská na vstupnom alebo predlohovom hriadeli
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte ložisko vstupného hriadeľa alebo ložisko výstupného hriadeľa.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ľavé ložisko predlohového hriadeľa:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Vnútorný krúžok: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vonkajší krúžok: 
<intxreftitleoff1 refid = "ASLAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Pravé ložisko predlohového hriadeľa:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Vnútorný krúžok: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vonkajší krúžok: 
<intxreftitleoff1 refid = "ASLAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Ľavé a pravé ložisko vstupného hriadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Opotrebované zošikmené ozubenie na objímke a kolese
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte objímku synchronizačnej spojky a náboj a koleso.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
1. a 2. stupeň predlohového riadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
3. a 4. stupeň vstupného hriadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5. stupeň vstupného hriadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Náboj a puzdro synchronizačnej spojky nízkych rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Náboj a puzdro synchronizačnej spojky vysokých rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Náboj a puzdro 5. rýchlostného stupňa: 
<intxreftitleoff1 refid = "ASLAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
