<servinfosub id = "ASLAP70AA504013005">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Úplne stlačte spojkový pedál na 3 sekundy alebo viac.
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite spojkový pedál na 3 sekúnd alebo viac.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA504013008">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA504013018">
<testgroup id = "ASLAP70AA504013019">
<title>
Kontrola DTC
</title>
<question>
Je detekované ine DTC ako B1125?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504013003">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte „P position / CPP2 Switch“ a „Clutch / Shift Switch“ zobrazené na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504013020">
<title>
Kontrola signálneho obvodu spínača CPP č. 1
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory spínača CPP č. 1 “C01”, “E01”, “E25” a “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku spínaču CPP č. 1 “C01”, “E01”, “E25” a “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „A1“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A1“ a každou svorkou v konektore spínača CPP č. 1: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504013021">
<title>
Kontrola signálneho obvodu spínača CPP č. 2
</title>
<test1>
<ptxt>
Odpojte od spínača CPP č. 2 konektor.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku spínaču CPP č. 2 “E25” a “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „A2“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A2“ a každou svorkou v konektore spínača CPP č. 2: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504013022">
<title>
Kontrola spínača CPP č. 1
</title>
<test1>
<ptxt>
Skontrolujte spínač CPP č. 1. 
<intxreftitleoff1 refid = "ASLAP70A5306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte spínač CPP č. 1. 
<intxreftitleoff1 refid = "ASLAP70A5306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504013023">
<title>
Kontrola spínača CPP č. 2
</title>
<test1>
<ptxt>
Skontrolujte spínač CPP č. 2. 
<intxreftitleoff1 refid = "ASLAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte spínač CPP č. 2. 
<intxreftitleoff1 refid = "ASLAP70A5306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504013006">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte konektory spínača CPP č. 1, CPP č. 2, „C01“, „E01“, „E25“ a „L10“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. (Kontrola DTC):
</ptxt>
</test1>
<question>
Rozoznáva sa aktuálne DTC B1125?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
