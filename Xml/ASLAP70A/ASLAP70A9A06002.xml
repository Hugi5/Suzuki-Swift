<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9A06002" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola a nastavenie kapoty
</title>
<servinfosub id = "ASLAP70A9A06002001">
<title>
Kontrola
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9A06001">Demontáž a montáž kapoty</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte, či sa kapota otvára a zatvára hladko a presne. V prípade potreby namažte.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či sa kapota po uvoľnení zámky kapoty zastaví správne v sekundárnej jazýčkovej polohe.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či sa kapota úplne zavrie v absolútnej polohe jazýčka.
</ptxt>
</item>
<item>
<ptxt>
Ak je to nutné, nastavte polohu zámky kapoty.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "ASLAP70A9A06002003">
<title>
Nastavenie
</title>
<topic id = "ASLAP70A9A06002004">
<title>
Horizontálne nastavenie kapoty
</title>
<ptxt>
Uvoľnite skrutky jazýčka kapoty a nastavte inštalačnú polohu kapoty. 
<intxreftitleoff1 refid = "ASLAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</topic>
<topic id = "ASLAP70A9A06002005">
<title>
Vertikálne nastavenie kapoty
</title>
<ptxt>
Vankúš kapoty (1) otáčajte tak, aby bol medzi kapotou a predným blatníkom schod.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9A0003.jpg" width = "88.000mm" height = "56.000mm" ver = "01" gw = "227" gh = "142"/>
</figure>
</topic>
<topic id = "ASLAP70A9A06002006">
<title>
Nastavenie polohy zámky kapoty
</title>
<s1>
<ptxt>
Odmontujte predný nárazník. 
<intxreftitleoff1 refid = "ASLAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite skrutky jazýčka kapoty (1) a nastavte výšku jazýčka kapoty (2).
</ptxt>
</s1>
<s1>
<ptxt>
Utiahnite skrutky západky kapoty na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T9J001">
<t-part>
Skrutka západky kapoty
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A9A0004.jpg" width = "88.000mm" height = "56.000mm" ver = "01" gw = "227" gh = "142"/>
</figure>
</s1>
<s1>
<ptxt>
Skontrolujte, či je kapota bez problémov a bezpečne zamknutá.
</ptxt>
</s1>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
