<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4106010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spínač brzdových svetiel
</title>
<servinfosub id = "ASLAP70A4106010001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Zložte kryt otvoru stĺpika riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor spínača svetla brzdy (1).
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte spínač brzdových svetiel (2) zo sústavy brzdového pedála.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A410013.swf" width = "88.000mm" height = "51.187mm" ver = "01" gw = "167" gh = "129"/>
</figure>
</servinfosub>
<servinfosub id = "ASLAP70A4106010002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4106011">Kontrola spínača brzdových svetiel</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Aby ste dosiahli nasledovné podmienky namontujte spínač svetla brzdy. So zostavou brzdového pedála (2) ťahanou smerom k sedadlu vodiča sa hrot spínača svetla brzdy (1) kontaktuje so zostavou brzdového pedála.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410045.swf" width = "88.000mm" height = "51.187mm" ver = "02" gw = "167" gh = "129"/>
</figure>
<attention3>
<ptxt>
Keď je spínač svetla brzdy namontovaný správne, vôľa „a“ medzi spínačom svetla brzdy a brzdovým pedálom bude nasledovná:
</ptxt>
<ptxt>
1,1 – 2,1 mm (0,044 – 0,082 in.)
</ptxt>
<figure>
<graphic graphicname = "I9P60A410015.swf" width = "88.000mm" height = "51.402mm" ver = "01" gw = "142" gh = "129"/>
</figure>
</attention3>
</s1>
<s1>
<ptxt>
Pripojte zo spínača brzdových svetiel konektor.
</ptxt>
</s1>
<s1>
<ptxt>
Nainštalujte kryt stĺpika riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
