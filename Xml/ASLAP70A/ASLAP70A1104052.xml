<servinfosub id = "ASLAP70A1104052003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Udržujte plynový pedál plne stlačený počas 2 sekúnd.
</ptxt>
</s1>
<s1>
<ptxt>
Udržujte plynový pedál v pokojovej polohe počas 2 sekúnd.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104052004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104052005">
<testgroup id = "ASLAP70A1104052006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104052007">
<title>
Kontrola obvodu ovládača škrtiacej klapky
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ ECM a konektor zariadenia telesa škrtiacej klapky.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektorom „C01“ a „E01“ a konektor zariadenia telesa škrtiacej klapky.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“ alebo „A2“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „A1“ a „A2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A1“ a ďalšou svorkou v konektore zariadenia telesa škrtiacej klapky: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A2“ a ďalšou svorkou v konektore zariadenia telesa škrtiacej klapky: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodov „A1“ alebo „A2“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte hnací obvod ovládača škrtiacej klapky.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104052008">
<title>
Kontrola elektrickej zostavy telesa škrtiacej klapky
</title>
<test1>
<ptxt>
Skontrolujte výkon zariadenia telesa elektrickej škrtiacej klapky. 
<intxreftitleoff1 refid = "ASLAP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte zariadenie telesa elektrickej škrtiacej klapky.
</ptxt>
</action>
</testgroup>
</diag>
