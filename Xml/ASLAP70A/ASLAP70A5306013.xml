<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A5306013" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zostavy prevádzkového valca spojky
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Nedovoľte, aby kvapalina prenikla na lakované plochy. Mohla by spôsobiť poškodenie lakovaného povrchu.
</ptxt>
</item>
<item>
<ptxt>
Zostavu pracovného valca spojky nerozoberajte.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "ASLAP70A5306013001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Vyčistite okolie uzáveru nádržky hlavného brzdového valca a z nádrže hlavného brzdového valca pomocou striekačky alebo podobne vytiahnite kvapalinu.
</ptxt>
</s1>
<s1>
<ptxt>
Rozoberte zariadenie prevodovky s rozvodovkou. 
<intxreftitleoff1 refid = "ASLAP70A5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte svorku (1) a odpojte spoj potrubia spojky (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite prevlečnú maticu potrubia spojkovej kvapaliny (3) zostavy prevádzkového valca spojky (4).
</ptxt>
</s1>
<s1>
<ptxt>
Z prevodovky vyberte objímku spoja potrubia spojky (5) a potom vyberte potrubie spojkovej kvapaliny (6).
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte zostavu pracovného valca spojky z prevodovky.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A530009.jpg" width = "88.000mm" height = "99.746mm" ver = "01" gw = "227" gh = "266"/>
</figure>
</servinfosub>
<servinfosub id = "ASLAP70A5306013002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A5306014">Kontrola zostavy pracovného valca spojky</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Namontujte zostavu prevádzkového valca spojky (2) do prevodovky. Dotiahnite skrutky zostavy prevádzkového valca spojky na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T5C005">
<t-part>
Skrutka zostavy pracovného spojkového valca
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Dočasne pripojte potrubie spojkovej kvapaliny (4) k zostave prevádzkového valca spojky.
</ptxt>
</s1>
<s1>
<ptxt>
Do prevodovky bezpečne namontujte objímku spoja potrubia spojky (3) a potom dotiahnite prevlečnú maticu potrubia spojkovej kvapaliny (1) na špecifikovaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T5C006">
<t-part>
Prevlečná matica potrubia spojkovej kvapaliny
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1,6
</t-value2>
<t-value3>
12,0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Pripojte spoj potrubia spojky (5) a namontujte svorku (6).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530010.jpg" width = "88.000mm" height = "99.746mm" ver = "01" gw = "227" gh = "266"/>
</figure>
</s1>
<s1>
<ptxt>
Zložte zariadenie prevodovky s rozvodovkou. 
<intxreftitleoff1 refid = "ASLAP70A5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Spojkový systém odvzdušnite a skontrolujte voľnú dráhu spojkového pedála.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odvzdušňovanie systému spojky: 
<intxreftitleoff1 refid = "ASLAP70A5306007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Voľná dráha spojkového pedála: 
<intxreftitleoff1 refid = "ASLAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
