<servinfo servinfosgmlid = "ASLAP70A4604028" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1047 / C1048
</title>
<servinfosub id = "ASLAP70A4604028001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.814in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.366in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1047: Výkon signálu ľavého predného snímača otáčok kolesa alebo prevodníka
</emph>
</ptxt>
<ptxt>
Určená uhlová rýchlosť oboch predných snímačov predných kolies nezodpovedá signálu snímača uhlovej rýchlosti.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Snímač uhla natočenia volantu
</ptxt>
</item>
<item>
<ptxt>
Snímač otáčok kolesa
</ptxt>
</item>
<item>
<ptxt>
Obvod snímača otáčok kolesa
</ptxt>
</item>
<item>
<ptxt>
Prevodník snímača otáčok kolesa
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka ESP<sup>®</sup>
</ptxt>
</item>
</list1>
<ptxt>
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1048: Výkon signálu ľavého zadného snímača otáčok kolesa alebo prevodníka
</emph>
</ptxt>
<ptxt>
Určená uhlová rýchlosť oboch zadných snímačov predných kolies nezodpovedá signálu snímača uhlovej rýchlosti.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70A4604028002">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A4604028003">
<testgroup id = "ASLAP70A4604028004">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604028005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70A4604005">Kontrola DTC</intxref>
.
</ptxt>
</test1>
<question>
Sú zobrazené iné DTC ako C1047 alebo C1048?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným procesom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604028006">
<title>
Kontrola snímača uhla natočenia volantu na vozidle
</title>
<test1>
<ptxt>
Skontrolujte snímač uhla natočenia volantu. 
<intxreftitleoff1 refid = "ASLAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Vymeňte snímač uhla natočenia volantu a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604028007">
<title>
Kontrola snímača otáčok kolesa
</title>
<test1>
<ptxt>
Skontrolujte príslušný snímač otáčok kolesa, prevodník snímača otáčok kolesa a/alebo obvod snímača otáčok kolesa podľa 
<intxref refid = "ASLAP70A4604018">DTC C1021 / C1022 / C1025 / C1026 / C1031 / C1032 / C1033/ C1035 / C1036</intxref>
.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybnú časť.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
