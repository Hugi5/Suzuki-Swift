<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž alternátora
</title>
<servinfosub id = "ASLAP70A1A06005001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte pravý spodný kryt motora.
</ptxt>
</s1>
<s1>
<ptxt>
Zložte výfukovú rúru č. 1. 
<intxreftitleoff1 refid = "ASLAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zložte hnací remeň vodného čerpadla/alternátora. 
<intxreftitleoff1 refid = "ASLAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte od alternátora (1) káblovú svorku „B“ (3) a konektor (2).
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte generátor (3) a vyberte ho z motorového priestoru medzi rámom predného zavesenia a zostavu predného hnacieho hriadeľa.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1005.jpg" width = "88.000mm" height = "66.800mm" ver = "01" gw = "237" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1A06005002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utiahnite skrutku alternátora a otočný čap alternátora na stanovený uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1J003">
<t-part>
Skrutka alternátora
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1J004">
<t-part>
Otočný čap alternátora
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Pripojte zväzok (1) k alternátoru tak, ako je to zobrazené na obrázku a pripevnite maticu svorky „B“ na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1J005">
<t-part>
Matica svorky “B”
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1A1006.jpg" width = "88.000mm" height = "61.151mm" ver = "02" gw = "237" gh = "157"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
