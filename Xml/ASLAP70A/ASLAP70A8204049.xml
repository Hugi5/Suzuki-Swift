<servinfosub id = "ASLAP70A8204049003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204049004">
<testgroup id = "ASLAP70A8204049005">
<question>
Vykonala sa „Kontrola diagnostického systému airbagov“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204049006">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Skontrolujte výstup ktorýchkoľvek z nasledovných DTC. 
<intxreftitleoff1 refid = "ASLAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
B1392 alebo B1393 (DTC B1390, B1391 alebo DTC B1394)
</ptxt>
</item>
<item>
<ptxt>
B1397 alebo B1398 (DTC B1395, B1396 alebo DTC B1399)
</ptxt>
</item>
</list1>
</test1>
<question>
Rozoznáva sa nejaký relevantný DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušnou procedúrou riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204049007">
<title>
Kontrola snímača zadného nárazu
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Vymeňte snímač zadného nárazu. 
<intxreftitleoff1 refid = "ASLAP70A8206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa nejaký DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte SDM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Ak sa vyskytujú DTC, vymažte ich podľa 
<intxref refid = "ASLAP70A8204006">Vymazanie DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
