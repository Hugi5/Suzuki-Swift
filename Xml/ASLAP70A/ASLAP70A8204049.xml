<ptxt>
<emph>
B1391: Neplatné kom. údaje snímača zadného nárazu vodiča (strana vodiča)
</emph>
</ptxt>
<ptxt>
Snímač zadného nárazu vodiča komunikuje s neplatnými údajmi.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1394: Nekonzistentné kom. údaje snímača zadného nárazu vodiča (strana vodiča)
</emph>
</ptxt>
<ptxt>
Strana zadného nárazu snímača komunikovala s nekonzistentným kódom ID.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1395: Žiadna odozva snímača zadného nárazu vodiča (strana spolujazdca)
</emph>
</ptxt>
<ptxt>
Snímač zadného nárazu spolujazdca komunikuje bez odozvy.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1396: Neplatné kom. údaje snímača zadného nárazu spolujazdca (strana spolujazdca)
</emph>
</ptxt>
<ptxt>
Snímač zadného nárazu spolujazdca komunikuje s neplatnými údajmi.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1399: Nekonzistentné kom. údaje snímača zadného nárazu spolujazdca (strana spolujazdca)
</emph>
</ptxt>
<ptxt>
Strana zadného nárazu snímača spolujazdca komunikovala s nekonzistentným kódom ID.
</ptxt>
</entry>
