<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4106017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž telesa hlavného brzdového valca
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4106015">Komponenty hlavného brzdového valca</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A4106016">Kontrola sústavy hlavného brzdového valca na vozidle</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Nikdy nerozmontujte hlavný brzdový valec. Rozobratie naruší jeho pôvodné vlastnosti.
</ptxt>
<ptxt>
Ak objavíte chybu, vymeňte hlavný brzdový valec za nový.
</ptxt>
</item>
<item>
<ptxt>
Nedovoľte, aby brzdová kvapalina prenikla na natreté plochy. Lakované povrchy by brzdová kvapalina poškodila. Ak sa rozleje akákoľvek tekutina, okamžite ju opláchnite vodou.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "ASLAP70A4106017001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte akumulátor a držiak akumulátora. 
<intxreftitleoff1 refid = "ASLAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyčistite externý povrch hlavného brzdového valca.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte spojku spínača hladiny brzdovej kvapaliny (1) na nádržke.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410002.swf" width = "88.000mm" height = "65.516mm" ver = "01" gw = "199" gh = "169"/>
</figure>
</s1>
<s1>
<ptxt>
Vypustite brzdovú kvapalinu z nádržky.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte hadicu nádržky spojky zo zásobníka.
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou špeciálneho nástroja uvoľnite prevlečné matice a odpojte brzdové potrubia (1) od hlavného valca.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A002">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Odmontujte upevňovacie matice hlavného brzdového valca (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410010.swf" width = "88.000mm" height = "60.983mm" ver = "01" gw = "159" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Demontujte hlavný brzdový valec (1) a O-krúžok (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410011.swf" width = "88.000mm" height = "46.988mm" ver = "02" gw = "159" gh = "117"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A4106017004">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4106019">Kontrola telesa hlavného brzdového valca</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Na teleso hlavného brzdového valca (1) namontujte nový tesniaci krúžok (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410011.swf" width = "88.000mm" height = "46.988mm" ver = "02" gw = "159" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte hlavný brzdový valec do posilňovača bŕzd.
</ptxt>
</s1>
<s1>
<ptxt>
Upevňovacie matice hlavného brzdového valca dotiahnite na predpísaný moment.
</ptxt>
<torque>
<torqueitem id = "T4A004">
<t-part>
Upevňovacia matica hlavného spojkového valca
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
18
</t-value1>
<t-value2>
1,8
</t-value2>
<t-value3>
13,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Pripojte brzdové potrubie (1) k hlavnému brzdovému valcu a pomocou špeciálneho nástroja utiahnite prievlečné matice na predpísaný moment.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A003">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T4A005">
<t-part>
Matica brzdového potrubia
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A410012.swf" width = "88.000mm" height = "60.983mm" ver = "01" gw = "159" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Pripojte hadicu nádržky spojky k zásobníku.
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte spínač hladiny brzdovej kvapaliny.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte akumulátor a akumulátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Po montáži odvzdušnite systém. 
<intxreftitleoff1 refid = "ASLAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte nainštalované súčiastky, či z nich neuniká brzdová kvapalina.
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte vôľu brzdového pedálu. 
<intxreftitleoff1 refid = "ASLAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uistite sa, že brzdový systém pracuje správne a skontrolujte, či netečie brzdová kvapalina.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
