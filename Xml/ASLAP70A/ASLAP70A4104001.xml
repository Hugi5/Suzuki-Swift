</ptxt>
</ps>
<action>
<ptxt>
Vyčistite alebo vymeňte.
</ptxt>
</action>
<ps>
<ptxt>
Prehriate brzdy
</ptxt>
</ps>
<action>
<ptxt>
Zistite príčinu a opravte ju.
</ptxt>
</action>
<ps>
<ptxt>
