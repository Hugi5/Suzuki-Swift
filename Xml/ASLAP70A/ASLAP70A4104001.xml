</ptxt>
</condition>
<ps>
<ptxt>
Presakovanie brzdovej kvapaliny z brzdových vetiev
</ptxt>
</ps>
<action>
<ptxt>
Nájdite miesto presakovania a opravte ho.
</ptxt>
</action>
<ps>
<ptxt>
