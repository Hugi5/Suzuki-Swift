</ptxt>
</action>
<ps>
<ptxt>
Porucha ESP<sup>®</sup>
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a podľa potreby vymeňte systém.
</ptxt>
</action>
<condition>
<ptxt>
Vozidlo ťahá do jednej strany (Brzdy nefungujú rovnomerne)
</ptxt>
</condition>
<ps>
<ptxt>
