<servinfo servinfosgmlid = "ASLAP70A4606007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž snímača otáčok predného kolesa
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4606006">Kontrola snímača otáčok predného a zadného kolesa na vozidle</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Pri montovaní snímača otáčok predného kolesa, nestláčajte alebo neskrúcajte káblový zväzok viac než je to potrebné.
</ptxt>
</attention2>
<servinfosub id = "ASLAP70A4606007001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Mierne zdvihnite vozidlo a odstráňte koleso.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte dolné obloženie predného blatníka. 
<intxreftitleoff1 refid = "ASLAP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte svorky (1) a odpojte konektor snímača otáčok predného kolesa (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutku snímača otáčok predného kolesa (3).
</ptxt>
</s1>
<s1>
<ptxt>
Z otočného čapu riadenia odstráňte snímač otáčok predného kolesa (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A460016.swf" width = "88.000mm" height = "95.015mm" ver = "01" gw = "196" gh = "253"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.964in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
