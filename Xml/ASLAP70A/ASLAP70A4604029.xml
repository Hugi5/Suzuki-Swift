<servinfosub id = "ASLAP70A4604029003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A4604029004">
<testgroup id = "ASLAP70A4604029005">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604029006">
<title>
Kontrola obvodov napájania a uzemnenia riadiacej jednotky ESP®
</title>
<test1>
<ptxt>
Skontrolujte obvod napájania a uzemnenia riadiacej jednotky ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "ASLAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604029007">
<title>
Kontrola napätia napájania riadiacej jednotky ESP®
</title>
<test1>
<ptxt>
Zmerajte napätie akumulátora, keď motor ide na 3 000 ot/min.
</ptxt>
</test1>
<question>
Je napätie medzi 9,3 a 16,8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Skontrolujte systém nabíjania. 
<intxreftitleoff1 refid = "ASLAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
