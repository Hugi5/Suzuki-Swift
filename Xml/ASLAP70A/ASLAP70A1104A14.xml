<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1104A14" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Slabý výkon motora
</title>
<ptxt>
Ak ECM nezistil žiaden kód DTC a pri 
<intxref refid = "ASLAP70A1104008">Vizuálna prehliadka</intxref>
 a 
<intxref refid = "ASLAP70A1104009">Základná kontrola motora</intxref>
 sa nezistila žiadna odchýlka, vykonajte riešenie problémov podľa nasledovných bodov.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Slabý výkon motora
</ptxt>
</condition>
<ps>
<ptxt>
Chybná sviečka zapaľovania
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1806002">Kontrola zapaľovacích sviečok</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybná zapaľovacia cievka a elektróda
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1806004">Kontrola telesa zapaľovacej cievky</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Poškodený snímač klopania motora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306021">Kontrola snímača klopania motora na vozidle</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Upchaté palivové hadice alebo potrubia
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1704005">Kontrola tlaku paliva</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha na palivovom čerpadle
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1704004">Kontrola palivového čerpadla a jeho obvod</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nasávanie vzduchu z tesnenia nasávacieho potrubia alebo škrtiacej klapky
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte systém vstupu vzduchu.
</ptxt>
</action>
<ps>
<ptxt>
Prehrievanie motora
</ptxt>
</ps>
<action>
<ptxt>
Stav „Prehriatie motora“
</ptxt>
</action>
<ps>
<ptxt>
Slabý výkon snímača teploty chladiacej kvapaliny alebo prúdu nasávaného vzduchu
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306012">Kontrola snímača teploty chladiacej kvapaliny ECT</intxref>
 alebo 
<intxref refid = "ASLAP70A1306026">Kontrola snímača prietoku nasávaného vzduchu a snímača teploty nasávaného vzduchu</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybné zariadenie telesa elektrickej škrtiacej klapky
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306004">Kontrola telesa elektrickej škrtiacej klapky vo vozidle</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybné zariadenie snímača APP
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306008">Kontrola snímača APP</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybné ventily vstrekovania paliva
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1704003">Kontrola obvodu vstrekovacieho ventilu</intxref>
 alebo 
<intxref refid = "ASLAP70A1706009">Kontrola vstrekovacieho ventila</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky motora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1104070">Kontrola riadiacej jednotky motora a jej obvodov</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Zadierajúce sa brzdy
</ptxt>
</ps>
<action>
<ptxt>
Stav „Brzdy blokujúce kolesá“ v 
<intxref refid = "ASLAP70A4104001">Diagnostika príznakov bŕzd</intxref>
 
</ptxt>
</action>
<ps>
<ptxt>
Preklzujúca spojka
</ptxt>
</ps>
<action>
<ptxt>
Stav „preklzávajúca spojka“ v 
<intxref refid = "ASLAP70A5304001">Diagnostika príznakov systému spojky</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nízka kompresia
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1404001">Kontrola kompresie</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Systém riadenia polohy vačkového hriadeľa (VVT) je mimo prevádzky
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306027">Kontrola OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
