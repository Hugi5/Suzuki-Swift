<servinfosub id = "ASLAP70A4604023003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A4604023004">
<testgroup id = "ASLAP70A4604023005">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604023006">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70A4604005">Kontrola DTC</intxref>
.
</ptxt>
</test1>
<question>
Sú zobrazené iné DTC ako C1037, C1038 a C1057?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným procesom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604023007">
<title>
Kontrola DTC v BCM
</title>
<test1>
<ptxt>
Skontrolujte DTC v BCM. 
<intxreftitleoff1 refid = "ASLAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je detekovaný DTC U0073, U0121 a/alebo U0126?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným procesom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604023008">
<title>
Kontrola poistky
</title>
<test1>
<ptxt>
Skontrolujte poistku „ABS“.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte poistku a skontrolujte, či je obvod uzemnený.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604023009">
<title>
Obvod napájania snímača uhla natočenia volantu
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF (VYP).
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor snímača uhla natočenia volantu.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor „G33“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie k snímaču uhla natočenia volantu.
</ptxt>
</test1>
<test1>
<ptxt>
Ak je pripojenie v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odmerate napätie medzi obvodom „A1“ a uzemnením.
</ptxt>
</test1>
<question>
Je to 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte obvod „A1“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604023010">
<title>
Obvod uzemnenia snímača uhla natočenia volantu
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odmerajte odpor medzi obvodom „A2“ a uzemnením.
</ptxt>
</test1>
<question>
Je menší ako 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte obvod „A2“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604023011">
<title>
Kontrola snímača uhla natočenia volantu
</title>
<test1>
<ptxt>
Pripojte konektor snímača uhla natočenia volantu.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte snímač uhla natočenia volantu. 
<intxreftitleoff1 refid = "ASLAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte snímač uhla natočenia volantu a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
