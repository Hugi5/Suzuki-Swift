<servinfosub id = "ASLAP70A8204052002">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204052003">
<testgroup id = "ASLAP70A8204052004">
<title>
Kontrola napätia akumulátora
</title>
<test1>
<ptxt>
Skontrolujte napätie akumulátora.
</ptxt>
</test1>
<question>
Je napätie v rozsahu 9 - 16 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte systém nabíjania a podľa potreby ho opravte. 
<intxreftitleoff1 refid = "ASLAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204052005">
<title>
Kontrola pripojenia SDM
</title>
<test1>
<ptxt>
Skontrolujte správne pripojenie konektora SDM.
</ptxt>
</test1>
<question>
Je pripojená pevne?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Občasná chyba. Skontrolujte kvôli občasným problémom. 
<intxreftitleoff1 refid = "ASLAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ak ste chyby nenašli, SDM vymeňte za funkčnú jednotku a opakujte kontrolu pripojenia. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204052006">
<title>
Kontrola poistky
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Kontrola poistky „A/B“.
</ptxt>
</test1>
<question>
Je poistka &#34;A/B&#34; v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte káblový zväzok podlahy a potom vymeňte poistku “A/B”.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204052007">
<title>
Kontrola obvodu napájania
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “L04”.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odmerajte napätie medzi svorkou “L04-18” a uzemnením.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B095">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820157.swf" width = "90.000mm" height = "34.401mm" ver = "01" gw = "194" gh = "81"/>
</testfigure>
</test1>
<question>
Je napätie v rozsahu 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte káblový zväzok podlahy.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204052008">
<title>
Kontrola obvodu uzemnenia
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odmerajte odpor medzi svorkou “L04-23” a uzemnením.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B096">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820158.swf" width = "90.000mm" height = "34.895mm" ver = "01" gw = "193" gh = "82"/>
</testfigure>
</test1>
<question>
Je odpor 1 &#937; alebo menej?
</question>
<result type = "yes"/>
<action>
<ptxt>
Obvod napájania a uzemnenia SDM sú v poriadku.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte káblový zväzok podlahy.
</ptxt>
</action>
</testgroup>
</diag>
