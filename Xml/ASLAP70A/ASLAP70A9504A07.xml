<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A9504A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Elektricky ovládané zrkadlá dverí sa nedajú ovládať plynule
</title>
<diag type = "condition">
<condition>
<ptxt>
Elektricky ovládané zrkadlá dverí sa nedajú ovládať plynule
</ptxt>
</condition>
<ps>
<ptxt>
Porucha ovládača elektricky ovládaného spätného zrkadla.
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506021">Kontrola elektrického ovládania a vyhrievania spätných zrkadiel na vozidle</intxref>
</ptxt>
</action>
<ps>
<ptxt>
V elektricky ovládaných zrkadlách za zasekol nejaký predmet
</ptxt>
</ps>
<action>
<ptxt>
Odstráňte cudzie telesá
</ptxt>
</action>
<ps>
<ptxt>
Zrkadlá sú von z polohy
</ptxt>
</ps>
<action>
<ptxt>
Namontujte zrkadlo späť do polohy 
<intxreftitleoff1 refid = "ASLAP70A9506022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
