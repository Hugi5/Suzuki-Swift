<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A4104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nedostatočná brzdná sila
</title>
<diag type = "condition">
<condition>
<ptxt>
Nedostatočná brzdná sila
</ptxt>
</condition>
<ps>
<ptxt>
Presakovanie brzdovej kvapaliny z brzdových vetiev
</ptxt>
</ps>
<action>
<ptxt>
Nájdite miesto presakovania a opravte ho.
</ptxt>
</action>
<ps>
<ptxt>
Brzdový kotúč alebo doštička znečistená kvapalinou, vazelínou alebo iným olejom
</ptxt>
</ps>
<action>
<ptxt>
Vyčistite alebo vymeňte.
</ptxt>
</action>
<ps>
<ptxt>
Prehriate brzdy
</ptxt>
</ps>
<action>
<ptxt>
Zistite príčinu a opravte ju.
</ptxt>
</action>
<ps>
<ptxt>
Značne opotrebované brzdové obloženie
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte.
</ptxt>
</action>
<ps>
<ptxt>
Porucha zariadenia strmeňov brzdy
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte.
</ptxt>
</action>
<ps>
<ptxt>
Vzduch v systéme
</ptxt>
</ps>
<action>
<ptxt>
Z brzdového systému vypustite vzduch.
</ptxt>
</action>
<ps>
<ptxt>
Interná porucha posilňovača bŕzd
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte posilňovač bŕzd.
</ptxt>
</action>
<ps>
<ptxt>
Záporný tlak na posilňovači bŕzd nie je adekvátny
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte stav motora a podtlakovej hadice.
</ptxt>
</action>
<ps>
<ptxt>
Porucha ESP<sup>®</sup>
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a podľa potreby vymeňte systém.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
