<servinfosub id = "ASLAP70A1104016003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 8,5 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; –10 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Motor nechajte 10 sek. bežať na voľnobežných otáčkach.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104016004" page = "1">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104016005">
<testgroup id = "ASLAP70A1104016006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104016007">
<title>
Kontrola obvodu napájania ohrievača HO2S
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté odpojte konektor snímača HO2S.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektoru snímača HO2S.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi obvodom „B1“ a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104016008">
<title>
Kontrola hnacieho obvodu ohrievača HO2S
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „B4“: menej ako 1Ω
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B4“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B4“ a ďalšou svorkou v konektore snímača HO2S: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „B4“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104016009">
<title>
Kontrola HO2S
</title>
<test1>
<ptxt>
Skontrolujte ohrievač HO2S. 
<intxreftitleoff1 refid = "ASLAP70A1306014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte HO2S.
</ptxt>
</action>
</testgroup>
</diag>
