<servinfosub id = "ASLAP70A7224015002">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<ptxt>
Pred vykonaním tohto postupu sa najskôr uistite, že sú splnené nasledovné podmienky.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
U0073 a/alebo U0140 nie sú detekované.
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224015003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224015004">
<testgroup id = "ASLAP70A7224015005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Skontrolujte nasledovné DTC BCM.
</ptxt>
<ptxt>
B1503: B1145 a/alebo B1146
</ptxt>
<ptxt>
B1562: B1141 a/alebo B1142
</ptxt>
</test1>
<question>
Našli ste nejaké DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným procesom riešenia DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku HVAC a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
