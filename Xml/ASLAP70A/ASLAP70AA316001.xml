<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70AA316001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž riadiacej jednotky imobilizéra
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka imobilizéra obsahuje citlivé súčasti, nevystavujte ju preto nadmerným otrasom.
</ptxt>
</item>
<item>
<ptxt>
Riadiacu jednotku imobilizéra nerozoberajte.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "ASLAP70AA316001001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte spodný a vrchný kryt stĺpika riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Odpojte konektor (1) od riadiacej jednotky imobilizéra (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutku (3) z riadiacej jednotky imobilizéra.
</ptxt>
</s1>
<s1>
<ptxt>
Zo zariadenia zámky volantu odmontujte riadiacu jednotku imobilizéra podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA31004.jpg" width = "88.000mm" height = "12.350mm" ver = "01" gw = "197" gh = "156"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA316001002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
