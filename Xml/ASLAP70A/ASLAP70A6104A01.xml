<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A6104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ťažkosti pri riadení
</title>
<diag type = "condition">
<condition>
<ptxt>
Ťažkosti pri riadení
</ptxt>
</condition>
<ps>
<ptxt>
Nedostatočný tlak v pneumatikách
</ptxt>
</ps>
<action>
<ptxt>
Upravte tlak v pneumatikách.
</ptxt>
</action>
<ps>
<ptxt>
Porucha systému posilňovača riadenia
</ptxt>
</ps>
<action>
<ptxt>
Systém skontrolujte a opravte. 
<intxreftitleoff1 refid = "ASLAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Tuhosť na guľových skrutkách konca spojovacej tyče
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte koniec spojovacej tyče. 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaný guľový čap ramena zavesenia
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte rameno nápravy. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porušená geometria predných kolies
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a nastavte geometriu predných kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaný stĺpik riadenia
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte stĺpik riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nesprávny kontakt zubov medzi ozubenou tyčou a pastorkom
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Skontrolujte krútiaci moment otáčania ozubenej tyče a pastorka. 
<intxreftitleoff1 refid = "ASLAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ak je poruchový, vymeňte zariadenie prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
