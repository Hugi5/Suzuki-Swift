<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7226026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž ovládača regulácie prúdenia vzduchu
</title>
<servinfosub id = "ASLAP70A7226026001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Deaktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zložte kryt otvoru stĺpika riadenia. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte jednotku (inflátor) airbagu kolien. 
<intxreftitleoff1 refid = "ASLAP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte stĺpik riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte sústavu brzdového pedálu. 
<intxreftitleoff1 refid = "ASLAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky (1), potom odmontujte ovládač riadenia prúdenia vzduchu (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A722011.jpg" width = "88.000mm" height = "63.150mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7226026002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A7226027">Kontrola ovládača regulácie prúdenia vzduchu:Automatický typ</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Do otvoru (1) ovládania prúdenia vzduchu nezabudnite vložiť zarovnávací kolík (2).
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722012.swf" width = "88.000mm" height = "68.493mm" ver = "02" gw = "234" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
