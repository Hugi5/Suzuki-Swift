<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1706017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž snímača hladiny paliva
</title>
<attention2>
<ptxt>
Nedotýkajte sa žiaruvzdornej dosky (1) a nezdeformujte rameno (2). Týmto môžete spôsobiť zlyhanie snímača hladiny paliva.
</ptxt>
<figure>
<graphic graphicname = "IAW101170039.swf" width = "88.000mm" height = "56.718mm" ver = "01" gw = "193" gh = "144"/>
</figure>
</attention2>
<servinfosub id = "ASLAP70A1706017001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Z palivovej nádrže odmontujte jednotku palivového čerpadla. 
<intxreftitleoff1 refid = "ASLAP70A1706015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor snímača hladiny paliva (1).
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte snímač hladiny paliva (3) z palivového čerpadla (4) posunutím v smere šípky tak, ako je to na obrázku uvoľnením zámky (2).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A170008.swf" width = "88.000mm" height = "55.018mm" ver = "01" gw = "169" gh = "139"/>
</figure>
</servinfosub>
<servinfosub id = "ASLAP70A1706017002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1706018">Kontrola snímača hladiny paliva</intxrefpoff>
</ptxt>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
