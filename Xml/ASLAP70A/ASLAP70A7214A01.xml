<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7214A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Elektromotor ventilátora nepracuje
</title>
<diag type = "condition">
<condition>
<ptxt>
Elektromotor ventilátora nepracuje
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte príslušné poistky a potom skontrolujte skratovanie k obvodu uzemnenia.
</ptxt>
</action>
<ps>
<ptxt>
Porucha relé elektromotora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte relé elektromotora ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha rezistora elektromotora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte rezistor elektromotora ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7216012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha voliča rýchlosti ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte volič rýchlosti ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha motora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte elektromotor ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prítomný cudzí materiál
</ptxt>
</ps>
<action>
<ptxt>
Odstraňujte cudzie predmety.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
