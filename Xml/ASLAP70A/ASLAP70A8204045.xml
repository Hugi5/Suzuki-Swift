<servinfosub id = "ASLAP70A8204045003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204045004">
<testgroup id = "ASLAP70A8204045005">
<question>
Vykonala sa „Kontrola diagnostického systému airbagov“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204045006">
<title>
Kontrola jednotky (inflátor) hlavového airbagu
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie konektora „L290“ a „L291“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory „L290“ a „L291“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte “STEERING WHEEL” (1) špeciálnych nástrojov (A), (B) a (C) ku konektoru „L290“ alebo „L291“.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B081">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B082">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932–78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B083">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932–75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820034.swf" width = "90.000mm" height = "73.606mm" ver = "02" gw = "199" gh = "192"/>
</testfigure>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Stále sa zobrazuje DTC B1361 alebo B1365?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte jednotku (inflátor) hlavového airbagu. 
<intxreftitleoff1 refid = "ASLAP70A8206018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204045007">
<title>
Kontrola obvodu podlahového káblového zväzku
</title>
<test1>
<ptxt>
Skontrolujte správne pripojenie konektora “L05”.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “L05”.
</ptxt>
</test1>
<test1>
<ptxt>
Uvoľnite skratovaciu tyč v konektore SDM vložením uvoľňovacieho nástroja, ktorý je vložený do špeciálneho nástroja (A).
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“ alebo „A2“ (DTC B1361): 1 &#937; alebo menej
</ptxt>
</item>
<item>
<ptxt>
Odpor obvodov „A3“ alebo „A4“ (DTC B1365): 1 &#937; alebo menej
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B084">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820112.swf" width = "90.000mm" height = "67.845mm" ver = "01" gw = "219" gh = "176"/>
</testfigure>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte SDM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte káblový zväzok podlahy. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Ak sa vyskytujú DTC, vymažte ich podľa 
<intxref refid = "ASLAP70A8204006">Vymazanie DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
