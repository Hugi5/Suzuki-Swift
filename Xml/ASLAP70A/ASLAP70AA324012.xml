<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70AA324012" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1167
</title>
<servinfosub id = "ASLAP70AA324012001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.260in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.945in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1167: Nesprávne priradenie informácií imobilizéra
</emph>
</ptxt>
<ptxt>
Chyba overenia medzi riadiacou jednotkou bezkľúčového štartovania a ECM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ID kód ECM nie je zaregistrovaný v riadiacej jednotke bezkľúčového štartovania
</ptxt>
</item>
<item>
<ptxt>
Diaľkový ovládač nie je zaregistrovaný
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka štartovania bez kľúča
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70AA324012002">
<title>
Riešenie problémov DTC
</title>
<attention3>
<ptxt>
Ak je riadiaca jednotka bezkľúčového štartovania taká, že už bola zaregistrovaná v inom vozidle (použitá), diaľkové ovládače sa nedajú zaregistrovať. Ak je potrebná výmena, vždy montujte novú riadiacu jednotku bezkľúčového štartovania.
</ptxt>
</attention3>
<diag type = "test" id = "ASLAP70AA324012003">
<testgroup id = "ASLAP70AA324012004">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Skontrolujte DTC v riadiacej jednotke motora. 
<intxreftitleoff1 refid = "ASLAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Nachádza sa tam nejaké chybné DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.	
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA324012005">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA326003">Registrácia riadiacej jednotky motora:Model s bezkľúčovým štartovaním</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Znovu skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1167?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (ECM nebola zaregistrovaná.)
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA324012006">
<title>
Registrácia diaľkového ovládača
</title>
<test1>
<ptxt>
Vykonajte „Registrácia kľúča imobilizéra“. 
<intxreftitleoff1 refid = "ASLAP70AA326002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Znovu skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1167?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. Ak je stále detekovaný DTC P1167, vymeňte BCM a opätovne skontrolujte DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka štartovania bez kľúča: 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka motora: 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Diaľkový ovládač nebol zaregistrovaný)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
