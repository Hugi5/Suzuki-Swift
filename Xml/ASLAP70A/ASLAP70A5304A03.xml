<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A5304A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vibrácie spojky
</title>
<diag type = "condition">
<condition>
<ptxt>
Vibrácie spojky
</ptxt>
</condition>
<ps>
<ptxt>
Hladké (akoby zo skla) plochy kotúča
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Plochy kotúča zamazané olejom
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené ložisko nedosadá plynule
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu pracovného valca spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kmitavý kotúč spojky alebo slabý kontakt plochy
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zoslabené torzné pružiny na kotúči spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené nity kotúča spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Skreslený povrch prítlačného kotúča alebo zotrvačníka
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte kryt spojky alebo zotrvačník.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Kotúč a kryt spojky: 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zotrvačník: 
<intxreftitleoff1 refid = "ASLAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Zoslabené upevnenie motora alebo uvoľnená montážna skrutka a/alebo matica upevnenia motora
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte alebo dotiahnite montážne skrutky a/alebo matice motora. 
<intxreftitleoff1 refid = "ASLAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
