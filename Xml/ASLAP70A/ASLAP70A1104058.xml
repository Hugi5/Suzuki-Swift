<servinfosub id = "ASLAP70A1104058003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 10 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
IAT &#62; 5 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ s uvoľneným plynovým pedálom na 1 min.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104058004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104058005">
<testgroup id = "ASLAP70A1104058006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104058007">
<title>
Kalibrácia systému ovládania elektrického škrtiaceho ventilu
</title>
<test1>
<ptxt>
Vykonajte kalibráciu systému ovládania elektrického škrtiaceho ventilu. 
<intxreftitleoff1 refid = "ASLAP70A1306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Znovu skontrolujte DTC.
</ptxt>
</test1>
<question>
Je ešte stále zistené DTC P2176?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104058008">
<title>
Kontrola káblového zväzku
</title>
<test1>
<ptxt>
Skontrolujte nasledovné body.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Obvod snímača (hlavný) TP: Postupujte podľa kroku 2 až 4 časti 
<intxref refid = "ASLAP70A1104024">DTC P0122 / P0123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Obvod snímača (pomocného) TP: Postupujte podľa kroku 2 až 4 časti 
<intxref refid = "ASLAP70A1104030">DTC P0222 / P0223</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104058009">
<title>
Kontrola snímača polohy škrtiacej klapky
</title>
<test1>
<ptxt>
Skontrolujte snímač TP podľa „Kontrola funkčnosti snímača polohy škrtiacej klapky (TP)“ v 
<intxref refid = "ASLAP70A1306004">Kontrola telesa elektrickej škrtiacej klapky vo vozidle</intxref>
.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zariadenie telesa elektrickej škrtiacej klapky.
</ptxt>
</action>
</testgroup>
</diag>
