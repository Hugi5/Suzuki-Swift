<servinfosub id = "ASLAP70A8204027003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204027004">
<testgroup id = "ASLAP70A8204027005">
<question>
Vykonala sa „Kontrola diagnostického systému airbagov“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204027006">
<title>
Kontrola predpínača bezpečnostného pásu
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory “L283” a “L285”.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte “STEERING WHEEL” (1) špeciálnych nástrojov (A), (B) a (C) ku konektoru “L283” alebo „L285“.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B036">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B037">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932–78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B038">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932–75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820024.swf" width = "90.000mm" height = "65.296mm" ver = "03" gw = "233" gh = "169"/>
</testfigure>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Stále sa zobrazuje DTC B1052 alebo B1056?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte predpínač bezpečnostného pásu. 
<intxreftitleoff1 refid = "ASLAP70A8106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204027007">
<title>
Kontrola obvodu podlahového káblového zväzku
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor „L04“ alebo „L05“.
</ptxt>
</test1>
<test1>
<ptxt>
Uvoľnite skratovaciu tyč v konektore SDM vložením uvoľňovacieho nástroja, ktorý je vložený do špeciálneho nástroja (A).
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor medzi svorkami “L04-6” a “L04-5” (DTC B1052): nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkami “L05-14” a “L05-13” (DTC B1056): nekonečno
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B039">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820122.swf" width = "90.000mm" height = "92.933mm" ver = "01" gw = "235" gh = "247"/>
</testfigure>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte SDM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte káblový zväzok podlahy. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Ak sa vyskytujú DTC, vymažte ich podľa 
<intxref refid = "ASLAP70A8204006">Vymazanie DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
