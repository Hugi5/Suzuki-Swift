<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7214A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Klapka nasávaného vzduchu sa nezmení, aj keď sa zmení režim nasávaného vzduchu.
</title>
<diag type = "condition">
<condition>
<ptxt>
Klapka nasávaného vzduchu sa nezmení, aj keď sa zmení režim nasávaného vzduchu.
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte príslušné poistky a potom skontrolujte skratovanie k obvodu uzemnenia.
</ptxt>
</action>
<ps>
<ptxt>
Zlomená klapka nasávaného vzduchu
</ptxt>
</ps>
<action>
<ptxt>
Opravte klapku nasávaného vzduchu.
</ptxt>
</action>
<ps>
<ptxt>
Porucha ovládača regulácie nasávania vzduchu
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte ovládač regulácie nasávania vzduchu. 
<intxreftitleoff1 refid = "ASLAP70A7216027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača nasávania vzduchu
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte spínač nasávania vzduchu. 
<intxreftitleoff1 refid = "ASLAP70A7216025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
