<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A2104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vozidlo ťahá do strany
</title>
<diag type = "condition">
<condition>
<ptxt>
Vozidlo ťahá do strany
</ptxt>
</condition>
<ps>
<ptxt>
Nesprávne alebo nadmerne opotrebované pneumatiky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte pneumatiky. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nesprávny tlak v pneumatikách
</ptxt>
</ps>
<action>
<ptxt>
Upravte tlak v pneumatikách.
</ptxt>
</action>
<ps>
<ptxt>
Zlomené alebo prevísajúce vinuté pružiny
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vymeňte vinuté pružiny. 
</ptxt>
<ptxt>
Predné: 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Abnormálna vodiaca sila vytvorená radiálnou pneumatikou
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte pneumatiku. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Narušená geometria kolies
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a nastavte geometriu kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zablokovanie jedného z kolies pri brzdení
</ptxt>
</ps>
<action>
<ptxt>
Nastavte alebo obravte brzdu.
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené, ohnuté alebo zlomené časti predného alebo zadného zavesenia
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite alebo vymeňte príslušné časti zavesenia. 
<intxreftitleoff1 refid = "ASLAP70A2106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
