<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7224A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nedostatočný prietok chladného vzduchu
</title>
<diag type = "condition">
<condition>
<ptxt>
Nedostatočný prietok chladného vzduchu
</ptxt>
</condition>
<ps>
<ptxt>
Upchatý alebo zamrznutý výparník klimatizácie
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte výparník klimatizácie a snímač teploty výparníka klimatizácie 
<intxreftitleoff1 refid = "ASLAP70A7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 a 
<intxreftitleoff1 refid = "ASLAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</action>
<ps>
<ptxt>
Unikanie vzduchu z jednotky HVAC alebo vzduchového potrubia
</ptxt>
</ps>
<action>
<ptxt>
Opravte jednotku HVAC alebo vzduchové potrubie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha motora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte elektromotor ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7226012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Ak je to potrebné opravte vedenie.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
