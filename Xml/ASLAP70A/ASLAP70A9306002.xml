<servinfo servinfosgmlid = "ASLAP70A9306002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia klaksónu
</title>
<servinfosub id = "ASLAP70A9306002001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte predný nárazník. 
<intxreftitleoff1 refid = "ASLAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor klaksónu (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutku klaksónu (3) a potom vyberte klaksón (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A930022.jpg" width = "88.000mm" height = "63.673mm" ver = "02" gw = "195" gh = "164"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9306002002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9306003">Kontrola klaksónu</intxrefpoff>
</ptxt>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
