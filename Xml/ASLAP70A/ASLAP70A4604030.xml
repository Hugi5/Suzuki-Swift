<servinfosub id = "ASLAP70A4604030003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A4604030004">
<testgroup id = "ASLAP70A4604030005">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604030006">
<title>
Kontrola napájacieho obvodu riadiacej jednotky ESP®
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF (VYP).
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor „E24“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie k svorke „E24-26“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak je pripojenie v poriadku, skontrolujte napätie mezi svorkou „E24-26“ a uzemnením.
</ptxt>
</test1>
<question>
Je to 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte obvod „A1“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604030007">
<title>
Kontrola obvodu uzemnenia riadiacej jednotky ESP®
</title>
<test1>
<ptxt>
Odmerajte odpor medzi každou svorkou “E24-14” a “E24-27” a uzemnením.
</ptxt>
</test1>
<question>
Je odpor menší ako 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte obvod „B1“ a/alebo „B2“.
</ptxt>
</action>
</testgroup>
</diag>
