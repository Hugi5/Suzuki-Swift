<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A6306006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia puzdra skrine prevodovky riadenia
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A6306001">Komponenty zostavy skrine prevodovky riadenia</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Pri výmene puzdra skrine prevodovky riadenia tiež vymeňte puzdrá na druhej strane ako súpravu.
</ptxt>
</attention2>
<servinfosub id = "ASLAP70A6306006001">
<title>
Demontáž 
</title>
<s1>
<ptxt>
Odmontujte montážnu zostavu skrine prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou noža odrežte prírubu každej skrine prevodovky riadenia (gumenú) (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A630023.swf" width = "88.000mm" height = "51.406mm" ver = "01" gw = "234" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Vytlačte puzdro skrine prevodovky riadenia (1) pomocou hydraulického lisu (2) a špeciálnych nástrojov.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C004">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943–76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C005">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913–75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630024.swf" width = "88.000mm" height = "49.527mm" ver = "01" gw = "104" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A6306006002">
<title>
Montáž
</title>
<s1>
<ptxt>
Vtlačte puzdro skrine prevodovky riadenia (1) pomocou hydraulického lisu (2) a špeciálnych nástrojov.
</ptxt>
<attention2>
<ptxt>
Puzdro skrine prevodovky riadenia nepoužívajte opätovne.
</ptxt>
</attention2>
<servicetool>
<servicetoolitem id = "L6C006">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943–76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C007">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913–75821
</s-number>
</servicetoolitem>
</servicetool>
<attention3>
<ptxt>
Pred montážou puzdra skrine prevodovky riadenia natrite jeho okraj mydlovou vodou, aby sa dalo ľahšie nasadiť.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A630025.swf" width = "88.000mm" height = "51.452mm" ver = "01" gw = "104" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Vtlačte puzdro skrine prevodovky riadenia (1), aby sa rozmery „a“ a „b“ na obrázku vyrovnali.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte montážnu zostavu skrine prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
