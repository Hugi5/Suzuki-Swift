<servinfo servinfosgmlid = "ASLAP70AA204017" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1157
</title>
<servinfosub id = "ASLAP70AA204017001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.635in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.573in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC	
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1157: Vstup signálu na rozvinutie airbagov
</emph>
</ptxt>
<ptxt>
Signál nafúknutia airbagu je privádzaný do SDM z BCM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
SDM
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70AA204017002">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA204017003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA204017004">
<testgroup id = "ASLAP70AA204017005">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymažte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA204017002">Postup potvrdenia DTC</intxref>
 a potom znovu skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1157?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Airbag sa v minulosti rozvinul. (DTC nie je vymazané))
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204017006">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte SDM. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA204017002">Postup potvrdenia DTC</intxref>
 a potom znovu skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1157?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte BCM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (SDM mala poruchu)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
