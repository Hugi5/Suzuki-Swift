<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A6104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nestabilné riadenie pri brzdení
</title>
<diag type = "condition">
<condition>
<ptxt>
Nestabilné riadenie pri brzdení
</ptxt>
</condition>
<ps>
<ptxt>
Opotrebované ložiská kolies
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte ložisko(á) kolesa. 
<intxreftitleoff1 refid = "ASLAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prasknutá alebo prehnutá vinutá pružina
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte vinutú pružinu. 
<intxreftitleoff1 refid = "ASLAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Chybná zostava prednej vzpery (tlmič odpruženia)
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu prednej vzpery (tlmič odpruženia). 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nerovnomerný tlak v pneumatikách
</ptxt>
</ps>
<action>
<ptxt>
Upravte tlak v pneumatikách. 
</ptxt>
</action>
<ps>
<ptxt>
Porušená geometria predných kolies
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a nastavte geometriu predných kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nerovnomerné brzdenie
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a opravte brzdový systém. 
<intxreftitleoff1 refid = "ASLAP70A4101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Predný brzdový kotúč znečistený brzdovou kvapalinou
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte predný brzdový kotúč. 
<intxreftitleoff1 refid = "ASLAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zdeformovaný brzdový kotúč
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte predný brzdový kotúč. 
<intxreftitleoff1 refid = "ASLAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Značne opotrebované brzdové obloženie
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte predné brzdové doštičky. 
<intxreftitleoff1 refid = "ASLAP70A4206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
