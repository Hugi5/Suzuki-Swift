<servinfosub id = "ASLAP70A1606010002">
<title>
Motor ventilátora chladiča
</title>
<s1>
<ptxt>
Odpojte prípojku motora ventilátora chladiča (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70P160004.swf" width = "88.000mm" height = "65.899mm" ver = "01" gw = "201" gh = "170"/>
</figure>
</s1>
<s1>
<ptxt>
Pomocou servisného vodiča pripojte motor ventilátora chladiča a akumulátor tak, ako je to zobrazené na obrázku.
</ptxt>
<figure>
<graphic graphicname = "IAP70A160002.swf" width = "88.000mm" height = "48.839mm" ver = "01" gw = "222" gh = "122"/>
<callout>
