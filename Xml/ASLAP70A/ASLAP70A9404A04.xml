<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A9404A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nesprávna činnosť ostrekovača
</title>
<servinfosub id = "ASLAP70A9404002003">
<title>
Zadný stierač a ostrekovač
</title>
<diag type = "condition">
<condition>
<ptxt>
Nesprávna činnosť ostrekovača
</ptxt>
</condition>
<ps>
<ptxt>
Porucha hadice ostrekovača (vrátane kontrolného ventilu a konektora) alebo trysky ostrekovača
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte hadicu alebo trysku ostrekovača, či nie je upchatá alebo skrútená.
</ptxt>
</action>
<ps>
<ptxt>
Porucha čerpadla ostrekovača
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9406002">Kontrola čerpadla ostrekovača</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača stierača a ostrekovača (spínač ostrekovača)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9406008">Kontrola spínača stierača a ostrekovača</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
