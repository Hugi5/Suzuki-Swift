<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9706002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž predného sedadla
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9706001">Súčiastky predných sedadiel</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A9706002001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Deaktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektory predného sedadla.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte 4 montážne skrutky na demontáž montážnej zostavy sedadla.
</ptxt>
</s1>
<s1>
<ptxt>
Podľa potreby rozmontujte a opravte časti. 
<intxreftitleoff1 refid = "ASLAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9706002002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Obráťte sa na 
<intxref refid = "ASLAP70A9706001">Súčiastky predných sedadiel</intxref>
 kvôli krútiacemu momentu.
</ptxt>
</item>
<item>
<ptxt>
Aktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
