<servinfosub id = "ASLAP70A7224027003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224027004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224027005">
<testgroup id = "ASLAP70A7224027006">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Zapnite spínač zapaľovania a skontrolujte DTC.
</ptxt>
</test1>
<question>
Bol stále zaznamenaný DTC B1550 a/alebo B1550-L?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224027007">
<title>
obvodu združeného prístroja TCM
</title>
<test1>
<ptxt>
Odpojte konektory „G20“ a „G227“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu vodiča „PNK/BLU“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor obvodu vodiča „PNK/BLU“ medzi panelom automatickej klimatizácie a uzemnením: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú hodnoty odporu podľa predpisu?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Nahraďte známu riadiacu jednotku HVAC a/alebo panel automatickej klimatizácie a opätovne skontrolujte DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka HVAC: 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Panel automatickej klimatizácie: 
<intxreftitleoff1 refid = "ASLAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
</testgroup>
