<ptxt>
vyberte podložku, ktorá ma najbližšie k vypočítanej hodnote (potrebná hrúbka podložky) spomedzi dostupných položiek, ktoré sú najbližšie k vypočítanej hodnote.
</ptxt>
<ptxt>
<emph etype = "bold">
Napríklad:
</emph>
</ptxt>
<ptxt>
Zmeraná vzdialenosť „b“ je 73,95 mm (2,911 in.).
</ptxt>
<ptxt>
„c“ = 73,95 mm (2,911 in.) – 40,0 mm (1,575 in.) = 33,95 mm (1,337 in.)
</ptxt>
<ptxt>
„f“ = 33,95 mm (1,337 in.) + 74,0 mm (2,913 in.) – 105,95 mm (4,171 in.) = 2,0 mm (0,079 in.)
</ptxt>
<ptxt>
Vypočítaná hrúbka novej podložky = 2,0 mm (0,079 in.)
</ptxt>
<spec>
<title>
Hrúbka dostupných podložiek kužeľového pastorka
</title>
<ptxt>
0,30, 1,85, 1,88, 1,91, 1,94, 1,97, 2,00, 2,03, 2,06, 2,09, 2,12 a 2,15 mm (0,012, 0,073, 0,074, 0,075, 0,076, 0,078, 0,079, 0,080, 0,081, 0,082, 0,083 a 0,084 in.)
</ptxt>
</spec>
