<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70AA206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž BCM
</title>
<servinfosub id = "ASLAP70AA206003001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Deaktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte kryt stĺpika riadenia podľa kroku 4) v 
<intxref refid = "ASLAP70A6206009">Demontáž a montáž stĺpika riadenia</intxref>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte bočné ozdobné obloženia prístrojov. 
<intxreftitleoff1 refid = "ASLAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektory (1) a svorky od J/B (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte matice (3) a potom vyberte J/B.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20016.jpg" width = "88.000mm" height = "78.207mm" ver = "01" gw = "202" gh = "205"/>
</figure>
</s1>
<s1>
<ptxt>
Odpojte konektory (1) od BCM (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte matice BCM (3) a potom vyberte BCM.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20017.jpg" width = "88.000mm" height = "82.962mm" ver = "01" gw = "198" gh = "219"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA206003002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:	
</ptxt>
</servinfosub>
<list1 type = "unordered">
<item>
<ptxt>
Utiahnite matice BCM na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T10B001">
<t-part>
Matica BCM
</t-part>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Aktivujte systém airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ak je BCM vymenená vykonajte 
<intxref refid = "ASLAP70AA206002">Registrácia BCM (Model so spínačom zapaľovania)</intxref>
 .
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
