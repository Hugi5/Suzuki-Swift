<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7214A11" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nedostatočný prietok chladného vzduchu
</title>
<diag type = "condition">
<condition>
<ptxt>
Nedostatočný prietok chladného vzduchu
</ptxt>
</condition>
<ps>
<ptxt>
Upchatý alebo zamrznutý výparník klimatizácie
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Skontrolujte výparník klimatizácie a snímač teploty výparníka klimatizácie.
</ptxt>
<ptxt>
- Výparník klimatizácie: 
<intxreftitleoff1 refid = "ASLAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Snímač teploty výparníka: 
<intxreftitleoff1 refid = "ASLAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Unikanie vzduchu z jednotky HVAC alebo vzduchového potrubia
</ptxt>
</ps>
<action>
<ptxt>
Opravte jednotku HVAC alebo vzduchové potrubie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha motora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte elektromotor ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
