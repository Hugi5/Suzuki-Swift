<intxreftitleoff1 refid = "ASLAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Riadiaci systém ventilátora chladiča je v dobrom stave.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 8.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1604002007">
<title>
Kontrola obvodu napájania relé č. 1 ventilátora chladiča (strana spínača)
</title>
<test1>
<ptxt>
Vynite zapaľovanie a vyberte relé ventilátora chladiča č. 1 zo samostatnej poistkovej skrinky č. 1.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku každej svorke ku konektoru relé ventilátora chladiča č. 1.
</ptxt>
</test1>
<test1>
<ptxt>
Ak je v poriadku, odmerate napätie medzi obvodom „A1“ a uzemnením.
</ptxt>
</test1>
<question>
Je to 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod „A1“.
</ptxt>
</action>
</testgroup>
