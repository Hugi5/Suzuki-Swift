</title>
<test1>
<ptxt>
Skontrolujte relé ventilátora chladiča č. 3. 
<intxreftitleoff1 refid = "ASLAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 13.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte relé ventilátora chladiča č. 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1604002016">
<title>
Kontrola obvodu uzemnenia relé č. 3 ventilátora chladiča
</title>
<test1>
<ptxt>
Odmerajte odpor medzi obvodom „C2“ a uzemnením.
</ptxt>
</test1>
<question>
Je odpor 1 &#937; alebo menej?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 14.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod „C2“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1604002017">
<title>
Kontrola obvodu napájania relé ventilátora chladiča č. 2 a č. 3 (strana cievky)
</title>
<test1>
<ptxt>
Vynite zapaľovanie a vyberte relé ventilátora chladiča č. 1 zo samostatnej poistkovej skrinky č. 1.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „D1“: 1 &#937; alebo menej
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „D1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „D1“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 15.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod „D1“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1604002018">
<title>
Kontrola riadiaceho obvodu relé ventilátora chladiča č. 2 a č. 3
</title>
<test1>
<ptxt>
Vypnite zapaľovanie a odpojte konektory ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „E1“: 1 &#937; alebo menej
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „E1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „E1“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 16.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod „E1“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1604002019">
<title>
Kontrola motora ventilátora chladiča
</title>
<test1>
<ptxt>
Skontrolujte ventilátor chladiča motora.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte činnosť systému ventilátora chladiča.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte motor ventilátora chladiča.
</ptxt>
</action>
</testgroup>
