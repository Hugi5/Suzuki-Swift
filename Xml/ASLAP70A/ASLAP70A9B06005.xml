<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9B06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž vonkajšieho prvku zadnej strany
</title>
<attention3>
<ptxt>
Nižšie uvedený obrázok zobrazuje podmienky odstraňovania nasledovných častí.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predný blatník 
<intxreftitleoff1 refid = "ASLAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Časť zámky kapoty, časť podpory lampy a podpora lampy 
<intxreftitleoff1 refid = "ASLAP70A9B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0015.jpg" width = "88.000mm" height = "56.208mm" ver = "01" gw = "227" gh = "143"/>
</figure>
<servinfosub id = "ASLAP70A9B06005001">
<title>
Všeobecné poznámky
</title>
<ptxt>
Spôsob zvárania a počet bodov zvaru je ten istý na oboch stranách. Tieto pokyny na opravu zobrazujú postup pre ľavú stranu.
</ptxt>
</servinfosub>
<servinfosub id = "ASLAP70A9B06005002">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odskrutkujte 2 skrutiek.
</ptxt>
</s1>
<s1>
<ptxt>
Odvŕtajte body zvarov a odmontujte vonkajší prvok zadnej strany.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0016.jpg" width = "183.000mm" height = "131.732mm" ver = "02" gw = "438" gh = "357"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.317in"/>
<colspec colnum = "2" colname = "2" colwidth = "6.887in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Tento symbol indikuje, že vonkajší prvok zadnej strany a predný panel na prístrojovej strane sú vymenené naraz.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9B06005003">
<title>
Montáž
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Pred zváraním skontrolujte polohu inštalácie a stav inštalačnej časti (častí). 
<intxreftitleoff1 refid = "ASLAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
V oprave pokračujte berúc do úvahy inštaláciu častí, ktoré majú vplyv na vzhľad. 
<intxreftitleoff1 refid = "ASLAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Namontujte vonkajší prvok zadnej strany, dočasne pritiahnite 2 skrutky a nastavte polohu podľa vedľajších častí.
</ptxt>
</s1>
<s1>
<ptxt>
Vykonajte odporové bodové zváranie a dierové zváranie.
</ptxt>
</s1>
<s1>
<ptxt>
Utiahnite 2 skrutky na predpísaný uťahovací moment.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0017.jpg" width = "183.000mm" height = "131.732mm" ver = "03" gw = "438" gh = "357"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.490in"/>
<colspec colnum = "2" colname = "2" colwidth = "6.715in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Tento symbol indikuje, že vonkajší prvok zadnej strany a predný panel na prístrojovej strane sú vymenené naraz.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
23 N&#183;m (2,3 kgf-m, 17,0 lbf-ft)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
