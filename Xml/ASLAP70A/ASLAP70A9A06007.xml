<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9A06007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zostavy predných dverí
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9A06006">Komponenty predných dverí</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A9A06007001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte predné obloženie dverí. 
<intxreftitleoff1 refid = "ASLAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Od dverí odpojte konektory zväzku dverí.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutku zarážky otvorenia dverí (1).
</ptxt>
<figure>
<graphic graphicname = "I9W10P9A0009.swf" width = "88.000mm" height = "70.937mm" ver = "02" gw = "193" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Pomocou zdviháku (2) podoprite panel dverí (1), pričom medzi zdvihák a panel dverí umiestnite handru (3) a kus dreva (4) podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I2RH019A0003.swf" width = "88.000mm" height = "48.545mm" ver = "01" gw = "144" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte skrutky (2) a vyberte predné dvere (1).
</ptxt>
<figure>
<graphic graphicname = "I9W10P9A0023.swf" width = "88.000mm" height = "64.886mm" ver = "02" gw = "161" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Po demontáži predného blatníka podľa potreby odmontujte pánty dverí. 
<intxreftitleoff1 refid = "ASLAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9A06007002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pri výmene dverí pokryte náhradné dvere zvnútra voskom kvôli správnemu ošetreniu proti korózii. 
<intxreftitleoff1 refid = "ASLAP70A9C06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Na montážnu plochu „A“ závesu dverí (1) naneste tesniaci prostriedok a na rotačnú časť „B“ závesu (1) naneste vazelínu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1215" id = "M9J002" uid = "27">
<m-part>
„A“
</m-part>
<m-desc>
Tesniaci prostriedok
</m-desc>
<m-number>
99000–31110
</m-number>
<m-name>
SUZUKI Bond No.1215
</m-name>
<ptxt>
</ptxt>
</materialitem>
<materialitem name = "SUZUKI Super Grease A" id = "M9J003" uid = "1126491901">
<m-part>
„B“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9W10P9A0010.jpg" width = "88.000mm" height = "70.516mm" ver = "01" gw = "228" gh = "183"/>
</figure>
</item>
<item>
<ptxt>
Dotiahnite skrutky pántu predných dverí a skrutku dorazu otvárania dverí na predpísaný moment. 
<intxreftitleoff1 refid = "ASLAP70A9A06006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Keď je namontovaná zarážka otvorenia dverí (1), otočte správnu značku (2) smerom hore.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Dvere na pravej strane: Značka „R“ smeruje hore
</ptxt>
</item>
<item>
<ptxt>
Dvere na ľavej strane: Značka „L“ smeruje hore
</ptxt>
<figure>
<graphic graphicname = "I9W10P9A0011.swf" width = "88.000mm" height = "71.083mm" ver = "02" gw = "193" gh = "185"/>
</figure>
</item>
</list2>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Nastavte polohu zarážky dverí. 
<intxreftitleoff1 refid = "ASLAP70A9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Po montáži otvorte a zatvorte dvere a skontrolujte, či sa zatvárajú plynule a pevne.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
