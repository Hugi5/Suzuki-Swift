<servinfosub id = "ASLAP70A8204043003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204043004">
<testgroup id = "ASLAP70A8204043005">
<question>
Vykonala sa „Kontrola diagnostického systému airbagov“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204043006">
<title>
Kontrola spínača deaktivovania airbagov spolujazdca
</title>
<test1>
<ptxt>
Demontujte spínač deaktivovania airbagov spolujazdca.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte spínač deaktivovania airbagov spolujazdca.
</ptxt>
</test1>
<question>
Je spínač deaktivovania airbagu spolujazdca v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte spínač deaktivovania airbagov spolujazdca.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204043007">
<title>
Kontrola obvodu spínača deaktivovania airbagov spolujazdca
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “G11”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie medzi každým obvodom „G11-16“ a „G11-17“: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie medzi každým obvodom „G11-16“ a „G11-17“ a uzemnením: nekonečno
</ptxt>
<servicetool>
<servicetoolitem id = "L8B080">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820030.swf" width = "90.000mm" height = "60.504mm" ver = "01" gw = "212" gh = "155"/>
</testfigure>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte SDM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Ak sa vyskytujú DTC, vymažte ich podľa 
<intxref refid = "ASLAP70A8204006">Vymazanie DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
