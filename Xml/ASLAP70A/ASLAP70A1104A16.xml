</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1806004">Kontrola telesa zapaľovacej cievky</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nízka kompresia
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1404001">Kontrola kompresie</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Trojcestný katalyzátor je znečistený olovom
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte, či nechýba škrtiaci ventil plniaceho hrdla.
</ptxt>
</action>
