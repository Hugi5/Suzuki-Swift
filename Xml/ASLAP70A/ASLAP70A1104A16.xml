</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306012">Kontrola snímača teploty chladiacej kvapaliny ECT</intxref>
 alebo 
<intxref refid = "ASLAP70A1306026">Kontrola snímača prietoku nasávaného vzduchu a snímača teploty nasávaného vzduchu</intxref>
