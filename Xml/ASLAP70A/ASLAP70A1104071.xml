</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104071010">
<title>
Kontrola obvodu hlavného napájania
</title>
<test1>
<ptxt>
Pomocou servisného vedenia uzemnite „F1“.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
