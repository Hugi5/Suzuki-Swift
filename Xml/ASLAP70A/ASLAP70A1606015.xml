<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1606015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž chladiča
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1606014">Kontrola a čistenie chladiča vo vozidle</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1606015001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte zariadenie ventilátora chladiča. 
<intxreftitleoff1 refid = "ASLAP70A1606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Demontujte zariadenie kondenzátora klimatizácie. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s manuálnou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7216006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatickou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7226006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Z chladiča vyberte výstupnú hadicu chladiča.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte horné konzoly chladiča (1).
</ptxt>
</s1>
<s1>
<ptxt>
Z vozidla vyberte chladič (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P160007.jpg" width = "88.000mm" height = "62.569mm" ver = "01" gw = "193" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1606015002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Chladiaci systém doplňte chladiacou kvapalinou. 
<intxreftitleoff1 refid = "ASLAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či chladiaci systém nepresakuje. 
<intxreftitleoff1 refid = "ASLAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
