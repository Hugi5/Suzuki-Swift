<servinfosub id = "ASLAP70AA204015003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA204015004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA204015005">
<testgroup id = "ASLAP70AA204015006">
<title>
Kontrola DTC
</title>
<question>
Je DTC B1132 zistený súčasne?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204015009">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte „A/C Evaporator Temp“ zobrazenú na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204015007">
<title>
Kontrola obvodu snímača teploty výparníka
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor snímača teploty výparníka a nasledovné konektory.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: Konektor “G04”
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: Konektor “G05”
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie k snímaču teploty výparníka a nasledovné konektory.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: Konektor “G04”
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: Konektor “G05”
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“ alebo „A2“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkami obvodu “A1” a “A2” v konektore teploty vonkajšieho vzduchu: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodov „A1“ alebo „A2“: 0 – 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204015008">
<title>
Kontrola snímača teploty výparníka
</title>
<test1>
<ptxt>
Skontrolujte snímač teploty výparníka. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s manuálnou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatickou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte snímač teploty výparníka.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Model s manuálnou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7216016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatickou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7226018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204015010">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte konektor snímača teploty výparníka a nasledovné konektory.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: Konektor “E04”
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: Konektor “E05”
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú detekované aktuálne DTC B1145 alebo B1146?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte BCM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
