<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7224A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Elektromotor ventilátora nepracuje
</title>
<diag type = "condition">
<condition>
<ptxt>
Elektromotor ventilátora nepracuje
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte príslušné poistky a potom skontrolujte skratovanie k obvodu uzemnenia.
</ptxt>
</action>
<ps>
<ptxt>
Ovládač poruchy motora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte regulátor elektromotora ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7226014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky HVAC
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte riadiacu jednotku HVAC 
<intxreftitleoff1 refid = "ASLAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha motora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte elektromotor ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7226014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha relé elektromotora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte relé elektromotora ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7226042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha panela automatickej klimatizácie
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte automatickú klimatizáciu. 
<intxreftitleoff1 refid = "ASLAP70A7224037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
