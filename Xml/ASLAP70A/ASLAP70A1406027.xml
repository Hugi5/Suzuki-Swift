</figure>
</s1>
<s1>
<ptxt>
Použitím zvláštnych nástrojov stlačte pružinu ventila a nasaďte dva kliny ventilu (1) do drážky drieku ventila.
</ptxt>
<attention3>
<ptxt>
Pri stláčaní ventilovej pružiny zabráňte poškodeniu vnútornej strany montážneho otvoru zdvíhača.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1D029">
<s-part>
(A)
</s-part>
<s-number num = "09916-14510">
09916–14510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L1D030">
<s-part>
(B)
</s-part>
<s-number num = "09916-14522">
09916–14522
</s-number>
</servicetoolitem>
<servicetoolitem id = "L1D031">
<s-part>
(C)
</s-part>
<s-number num = "09916-84511">
09916–84511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B140101.swf" width = "88.000mm" height = "52.990mm" ver = "01" gw = "166" gh = "133"/>
</figure>
</s1>
<s1>
<ptxt>
Nainštalujte zátku venturi a utiahnite ju na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1D019">
<t-part>
Venturiho zátka
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3,5
</t-value1>
<t-value2>
0,36
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141003.swf" width = "88.000mm" height = "64.914mm" ver = "01" gw = "140" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Nainštalujte vstrekovacie ventily. 
<intxreftitleoff1 refid = "ASLAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nainštalujte výfukové potrubie. 
<intxreftitleoff1 refid = "ASLAP70A1B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
