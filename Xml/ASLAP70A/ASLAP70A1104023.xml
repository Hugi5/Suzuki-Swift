<servinfosub id = "ASLAP70A1104023003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ na 10 sek.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104023004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104023005">
<testgroup id = "ASLAP70A1104023006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104023007">
<title>
Kontrola signálneho obvodu a obvodu uzemnenia snímača ECT
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ ECM a konektor snímača ECT.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektorom „C01“ a „E01“ a konektor snímača ECT.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“ alebo „A2“: menej ako 1Ω
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „A1“ a „A2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A1“ a ďalšou svorkou v konektore snímača ECT: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodov „A1“ alebo „A2“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104023008">
<title>
Kontrola snímača ECT
</title>
<test1>
<ptxt>
Skontrolujte snímač ECT. 
<intxreftitleoff1 refid = "ASLAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte snímač teploty chladiacej kvapaliny motora.
</ptxt>
</action>
</testgroup>
</diag>
