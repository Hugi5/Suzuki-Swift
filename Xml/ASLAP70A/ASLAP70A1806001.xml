<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1806001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia zapaľovacej sviečky
</title>
<servinfosub id = "ASLAP70A1806001001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte teleso zapaľovacej cievky. 
<intxreftitleoff1 refid = "ASLAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte zapaľovacie sviečky.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1806001002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1806002">Kontrola zapaľovacích sviečok</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Nainštalujte sviečky zapaľovania a utiahnite ich na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1H001">
<t-part>
Zapaľovacia sviečka
</t-part>
<t-value1>
18
</t-value1>
<t-value2>
1,8
</t-value2>
<t-value3>
13,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Namontujte teleso zapaľovacej cievky. 
<intxreftitleoff1 refid = "ASLAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
