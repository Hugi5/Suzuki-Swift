<servinfo servinfosgmlid = "ASLAP70AA204013" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1133
</title>
<servinfosub id = "ASLAP70AA204013001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.385in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.833in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1133: Napätie akumulátora príliš vysoké
</emph>
</ptxt>
<ptxt>
Napätie obvodu záložného napájania z poistky “DOME” je neustále vyššie ako 16,0 V v predpísaný čas.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Systém dobíjania
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70AA204013002">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Podľa možnosti naštartujte motor.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA204013003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA204013004">
<testgroup id = "ASLAP70AA204013006">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF (vyp.) a k prípojke na údajové spojenie pripojte skenovacie zariadenie SUZUKI.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte „Battery Voltage“ zobrazenú na skenovacom zariadení SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204013005">
<title>
Kontrola nabíjacieho systému	 
</title>
<test1>
<ptxt>
Skontrolujte systém nabíjania. 
<intxreftitleoff1 refid = "ASLAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte BCM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte systém nabíjania.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
