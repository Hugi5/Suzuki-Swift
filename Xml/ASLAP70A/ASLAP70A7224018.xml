<diag type = "test" id = "ASLAP70A7224018005">
<testgroup id = "ASLAP70A7224018006">
<title>
Kontrola parametrov skenovacieho zariadenia
</title>
<test1>
<ptxt>
Skontrolujte “Air Mix Pos Sen” pomocou režimu “Zoznamu údajov” na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je napätie viac ako 4,8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224018007">
<title>
Kontrola obvodu signálu snímača polohy ovládača riadenia teploty
</title>
<test1>
<ptxt>
Odpojte konektor ovládača regulácie teploty.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte svorky vodičov “YEL” a “YEL/RED” konektora ovládača riadenia teploty pomocou servisného vodiča.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa DTC B1511-L?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ovládač riadenia teploty. 
<intxreftitleoff1 refid = "ASLAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224018008">
<title>
Kontrola obvodu signálu snímača polohy ovládača riadenia teploty
</title>
<test1>
<ptxt>
Pripojte svorky vodičov “YEL” a “YEL/RED” konektora „G20“ pomocou servisného vodiča.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa DTC B1511-L?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku HVAC a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
