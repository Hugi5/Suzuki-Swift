<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4B">
<servcat sctnbr = "04" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola predného brzdového kotúča
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4206005">Demontáž a montáž kotúča prednej brzdy</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A4206006001" page = "2">
<title>
Predná kotúčová brzda
</title>
<list1 type = "unordered">
<item>
<ptxt>
Pomocou magnetického stojana a mikrometrického meradla umiestneného asi 10 mm (0,39 in.) smerom dovnútra od okraju kotúča zmerajte jeho priehyb. Ak je väčší ako limit, predný brzdový kotúč opravte alebo vymeňte.
</ptxt>
<spec-sdm>
<sdm-title>
Priehyb prednej kotúčovej brzdy
</sdm-title>
<sdm1>
<sdm-condition>
Hranica
</sdm-condition>
<sdm-value>
0,10 mm (0,004 in.) 
</sdm-value>
</sdm1>
</spec-sdm>
<servicetool>
<servicetoolitem id = "L4B001">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900–20607
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L4B002">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900–20701
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure page = "2">
<graphic graphicname = "IAP70A420010.swf" width = "88.000mm" height = "49.949mm" ver = "02" gw = "133" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Pomocou mikrometra zmerajte hrúbku predného brzdového kotúča, Ak je menšia ako limit, brzdový kotúč vymeňte.
</ptxt>
<spec-sdm>
<sdm-title>
Hrúbka prednej kotúčovej brzdy
</sdm-title>
<sdm-part>
“a”
</sdm-part>
<sdm1>
<sdm-condition>
Štandardná
</sdm-condition>
<sdm-value>
22,0 mm (0,87 in.)
</sdm-value>
</sdm1>
<sdm1>
<sdm-condition>
Hranica
</sdm-condition>
<sdm-value>
20,0 mm (0,79 in.)
</sdm-value>
</sdm1>
</spec-sdm>
<figure page = "2">
<graphic graphicname = "IAP70A420011.swf" width = "88.000mm" height = "52.057mm" ver = "01" gw = "133" gh = "131"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
