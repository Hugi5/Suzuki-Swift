</servinfosub>
<servinfosub id = "ASLAP70AA314009002">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA314009003">
<testgroup id = "ASLAP70AA314009004">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Skontrolujte DTC prislúchajúce ku komunikácii CAN.
</ptxt>
</test1>
<question>
Našli ste nejaké CAN-DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA314009005">
<title>
Kontrola komunikačného obvodu CAN
</title>
<test1>
<ptxt>
Skontrolujte komunikačný obvod CAN podľa časti “Diagnosis Procedure” v 
<intxref refid = "ASLAP70AA804004">Riešenie problémov v prípade vypnutia komunikačnej zbernice</intxref>
.
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. Ak je stále detekovaný DTC P1642, vymeňte BCM a opätovne skontrolujte DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka motora: 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "ASLAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
