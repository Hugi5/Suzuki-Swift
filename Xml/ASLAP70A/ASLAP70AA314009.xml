<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1642: Chyba komunikačnej linky imobilizéra
</emph>
</ptxt>
<ptxt>
Chyba komunikácie s BCM.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Komunikačný obvod/konektor CAN
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka pripojená s vedením komunikácie CAN.
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
