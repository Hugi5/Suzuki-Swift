<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7214A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Neprúdi von chladný vzduch (motor ventilátora chladenia nefunguje)
</title>
<diag type = "condition">
<condition>
<ptxt>
Neprúdi von chladný vzduch (motor ventilátora chladenia nefunguje)
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte príslušné poistky a potom skontrolujte skratovanie k obvodu uzemnenia.
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Poškodené relé elektromotor ventilátora chladiča
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte relé ventilátora chladiča. 
<intxreftitleoff1 refid = "ASLAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodený elektromotor ventilátora chladiča.
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Skontrolujte ventilátor chladiča motora. 
<intxreftitleoff1 refid = "ASLAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky motora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte riadiacu jednotku motora. 
<intxreftitleoff1 refid = "ASLAP70A7214017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
