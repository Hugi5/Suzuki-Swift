<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1406009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž nasávacieho potrubia
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1406005">Diely škrtiaceho telesa a nasávacieho potrubia</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1406009001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte zostavu čističa vzduchu. 
<intxreftitleoff1 refid = "ASLAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
S pripojenými hadicami chladiča motora vyberte zostavu škrtiacej klapky zo sacieho potrubia.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte spojku MAF snímača (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte nasledujúce hadice:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Hadicu posilňovača bŕzd (2) z posilňovača bŕzd
</ptxt>
</item>
<item>
<ptxt>
Hadicu PCV (3) od ventilu PCV
</ptxt>
<figure>
<graphic graphicname = "I7V20A141039.swf" width = "88.000mm" height = "53.078mm" ver = "01" gw = "221" gh = "134"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Demontujte skrutku prívodnej hadice ohrievača (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141022.jpg" width = "88.000mm" height = "51.297mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Demontujte nasávacie potrubie (1) a tesnenie.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141040.swf" width = "88.000mm" height = "57.944mm" ver = "01" gw = "183" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte chladiace vodné potrubie (1). 
<intxreftitleoff1 refid = "ASLAP70A1606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte rozperu (2) a tesnenie z hlavy valcov.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141023.jpg" width = "88.000mm" height = "57.901mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1406009002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Použite nové tesnenie.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či sú všetky demontované časti opäť na svojom mieste.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
