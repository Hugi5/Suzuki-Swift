<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1104A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Slabý kilometrový výkon paliva
</title>
<ptxt>
Ak ECM nezistil žiaden kód DTC a pri 
<intxref refid = "ASLAP70A1104008">Vizuálna prehliadka</intxref>
 a 
<intxref refid = "ASLAP70A1104009">Základná kontrola motora</intxref>
 sa nezistila žiadna odchýlka, vykonajte riešenie problémov podľa nasledovných bodov.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Slabý kilometrový výkon paliva
</ptxt>
</condition>
<ps>
<ptxt>
Chybná sviečka zapaľovania (nesprávna medzera, ťažké nánosy a spálené elektródy atď.)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1806002">Kontrola zapaľovacích sviečok</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Vysoké otáčky voľnobehu
</ptxt>
</ps>
<action>
<ptxt>
Stav „Nesprávny voľnobeh motora, alebo neschopnosť motora pre chod na voľnobehu“
</ptxt>
</action>
<ps>
<ptxt>
Slabý výkon snímača teploty chladiacej kvapaliny, prúdu nasávaného vzduchu
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306012">Kontrola snímača teploty chladiacej kvapaliny ECT</intxref>
 alebo 
<intxref refid = "ASLAP70A1306026">Kontrola snímača prietoku nasávaného vzduchu a snímača teploty nasávaného vzduchu</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybné zariadenie telesa elektrickej škrtiacej klapky
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306004">Kontrola telesa elektrickej škrtiacej klapky vo vozidle</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybné zariadenie snímača APP
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306008">Kontrola snímača APP</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybné ventily vstrekovania paliva
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1704003">Kontrola obvodu vstrekovacieho ventilu</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky motora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1104070">Kontrola riadiacej jednotky motora a jej obvodov</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nízka kompresia
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1404001">Kontrola kompresie</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nedostatočné sedlo ventilov
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406028">Kontrola ventilov a vodidiel ventilov</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Zadierajúce sa brzdy
</ptxt>
</ps>
<action>
<ptxt>
Stav „Brzdy blokujúce kolesá“ v 
<intxref refid = "ASLAP70A4104001">Diagnostika príznakov bŕzd</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Preklzujúca spojka
</ptxt>
</ps>
<action>
<ptxt>
Stav „preklzávajúca spojka“ v 
<intxref refid = "ASLAP70A5304001">Diagnostika príznakov systému spojky</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Termostat nefunkčný
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1606009">Kontrola zariadenia termostatu (so snímačom ECT)</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neprimeraný tlak v pneumatikách
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A2401001">Popis pneumatík</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Systém riadenia polohy vačkového hriadeľa (VVT) je mimo prevádzky
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1306027">Kontrola OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
