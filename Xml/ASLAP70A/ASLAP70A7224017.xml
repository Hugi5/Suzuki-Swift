<servinfosub id = "ASLAP70A7224017003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224017004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224017005">
<testgroup id = "ASLAP70A7224017006">
<title>
Kontrola parametrov skenovacieho zariadenia
</title>
<test1>
<ptxt>
Skontrolujte „Slnečné žiarenie“ pomocou režimu „Zoznamu údajov“ na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je hodnota slnečného žiarenia 2440 W/m <sup>2</sup> (Napätie signálu spínača slnečného žiarenia je nižšie ako predpísaná hodnota 0,1 V)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224017007">
<title>
Kontrola obvodu signálu snímača slnečného žiarenia
</title>
<test1>
<ptxt>
Odpojte konektor snímača slnečného žiarenia.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa DTC B1504-H?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte snímač slnečného žiarenia. 
<intxreftitleoff1 refid = "ASLAP70A7226031"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224017008">
<title>
Kontrola obvodu signálu snímača slnečného žiarenia
</title>
<test1>
<ptxt>
Odpojte konektor “G20”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, či je napätie medzi svorkou vodiča “PNK” a uzemnením 0 – 1 V so zapnutým zapaľovaním.
</ptxt>
</test1>
<question>
Zodpovedá napätie predpísaným hodnotám?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku HVAC a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
</testgroup>
