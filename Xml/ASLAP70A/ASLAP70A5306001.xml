<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A5306001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spínača CPP č. 1 (ak je vo výbave)
</title>
<servinfosub id = "ASLAP70A5306001001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odpojte konektor spínača CPP č. 1 pri vypnutom spínači zapaľovania.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte spínač CPP č. 1 (1) z konzoly pedála spojky.
</ptxt>
<figure>
<graphic graphicname = "I9P60A531003.swf" width = "88.000mm" height = "79.324mm" ver = "01" gw = "104" gh = "208"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A5306001002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A5306002">Kontrola a nastavenie spínača CPP č. 1 (ak je vo výbave)</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Nasaďte na konzolu pedála spojky spínač CPP č. 1.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte polohu spínača. 
<intxreftitleoff1 refid = "ASLAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte poriadne konektor spínača CPP č. 1.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
