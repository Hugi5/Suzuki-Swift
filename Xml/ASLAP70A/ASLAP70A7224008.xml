<servinfosub id = "ASLAP70A7224008001" page = "2">
<title>
Definície údajov skenovacieho zariadenia
</title>
<deflist>
<term id = "ASLAP70A7224008002">
Volič teploty: (Poloha voliča ovládania teploty, Max Cool, &#176;C / &#176;F, Max Hot)
</term>
<def>
<ptxt>
Tento parameter udáva zvolenú polohu voliča ovládania teploty.
</ptxt>
</def>
<term id = "ASLAP70A7224008003">
Volič režimu (Poloha voliča prúdenia vzduchu, AUTO, FACE, B/L, FOOT, DE-FO, DEF)
</term>
<def>
<ptxt>
Tento parameter udáva zvolenú polohu voliča prúdenia vzduchu.
</ptxt>
</def>
<term id = "ASLAP70A7224008004">
Volič otáčok dúchadla (Volič otáčok ventilátora, AUTO, OFF, 1. - 8.)
</term>
<def>
<ptxt>
Tento parameter udáva zvolenú polohu voliča otáčok ventilátora.
</ptxt>
</def>
<term id = "ASLAP70A7224008005">
Režim nasávania vzduchu (Poloha ovládača nasávania vzduchu, AUTO, FRE, REC, H-REC)
</term>
<def>
<ptxt>
Tento parameter udáva zvolenú polohu voliča nasávania vzduchu.
</ptxt>
</def>
<term id = "ASLAP70A7224008006">
Rýchlosť vozidla (km/h, mph)
</term>
<def>
<ptxt>
Tento parameter udáva rýchlosť vozidla, ktorú vypočítala ECM.
</ptxt>
</def>
<term id = "ASLAP70A7224008007">
ECT (Teplota chladiacej kvapaliny, &#176;C / &#176;F)
</term>
<def>
<ptxt>
Tento parameter udáva teplotu chladiacej kvapaliny motora, ktorú zistil snímač teploty chladiacej kvapaliny motora.
</ptxt>
</def>
<term id = "ASLAP70A7224008008">
Typ motora (signál typu motora, K12)
</term>
<def>
<ptxt>
Tento parameter udáva signál typu motora, ktorý vysiela ECM.
</ptxt>
</def>
<term id = "ASLAP70A7224008009">
Teplota vonkajšieho vzduchu (Teplota vonkajšieho vzduchu, &#176;C / &#176;F)
</term>
<def>
<ptxt>
Tento parameter udáva teplotu vonkajšieho vzduchu, ktorú zistil snímač teploty vonkajšieho vzduchu.
</ptxt>
</def>
<term id = "ASLAP70A7224008010">
Cabin Temperature (Teplota v kabíne) (Teplota vo vnútri vozidla, &#176;C / &#176;F)
</term>
<def>
<ptxt>
Tento parameter udáva teplotu vo vnútri vozidla, ktorú zistil snímač teploty vo vnútri kabíny.
</ptxt>
</def>
<term id = "ASLAP70A7224008011">
Slnečné žiarenie (W/m <sup>2</sup> )
</term>
<def>
<ptxt>
Tento parameter udáva intenzitu slnečného žiadenie, ktoré zistil snímač slnečného žiarenia.
</ptxt>
</def>
<term id = "ASLAP70A7224008012">
Teplota výparníka (Teplota výparníka, &#176;C / &#176;F)
</term>
<def>
<ptxt>
Tento parameter udáva teplotu vzduchu, ktorý prechádza cez výparník.
</ptxt>
</def>
<term id = "ASLAP70A7224008013">
Tlak chladiacej zmesi (Absolútny tlak chladicej zmesi klimatizácie, kPa)
</term>
<def>
<ptxt>
Tento parameter udáva absolútny tlak chladiacej zmesi klimatizácie, ktorý vypočítala ECM
</ptxt>
</def>
<term id = "ASLAP70A7224008014">
Snímač polohy ovládača regulácie teploty (Snímač polohy ovládača riadenia teploty, V)
</term>
<def>
<ptxt>
Tento parameter udáva vstupný signál zo snímača polohy v ovládači riadenia teploty.
</ptxt>
</def>
<term id = "ASLAP70A7224008015">
Snímač polohy ovládača (Snímač polohy ovládača riadenia prúdenia vzduchu, V)
</term>
<def>
<ptxt>
Tento parameter udáva vstupný signál zo snímača polohy v ovládači riadenia prúdenia vzduchu.
</ptxt>
</def>
<term id = "ASLAP70A7224008016">
Požadované napätie ventilátora (Požadované napätie ventilátora, V)
</term>
<def>
<ptxt>
Tento parameter udáva sptorebované napätie motora ventilátora.
</ptxt>
</def>
<term id = "ASLAP70A7224008017">
Riadiaci signál klimatizácie (Riadiaci signál klimatizácie, ON, OFF)
</term>
<def>
<ptxt>
Tento parameter udáva stav spínača klimatizácie.
</ptxt>
</def>
<term id = "ASLAP70A7224008018">
Signál zaťaženia ventilátora dúchadla (Signál zaťaženia ventilátora dúchadla, ON, OFF)
</term>
<def>
<ptxt>
ON: Volič otáčok ventilátora je v 4. alebo vyššej polohe.
</ptxt>
<ptxt>
Vypnutý: Volič otáčok ventilátora v polohe OFF – 3. polohe.
</ptxt>
</def>
<term id = "ASLAP70A7224008019">
Indikátor zadného odhmlievania (indikátor zadného DEF, ON, OFF)
</term>
<def>
<ptxt>
Tento parameter udáva vybranú polohu spínača zadného odhmlievača.
</ptxt>
</def>
<term id = "ASLAP70A7224008020">
Magnetická spojka kompresora klimatizácie (Magnetická spojka kompresora klimatizácie, ON, OFF)
</term>
<def>
<ptxt>
Tento parameter udáva stav magnetickej spojky kompresora klimatizácie.
</ptxt>
</def>
<term id = "ASLAP70A7224008021">
Požiadavka na beh motora (signál požiadavky na beh motora, ON, OFF)
</term>
<def>
<ptxt>
Tento parameter zostane vypnutý.
</ptxt>
</def>
</deflist>
