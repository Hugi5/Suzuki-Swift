<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216043" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Montáž a demontáž poistného ventilu
</title>
<servinfosub id = "ASLAP70A7216043001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Rekuperujte chladiacu kvapalinu z klimatizačného systému pomocou zariadenia na rekuperáciu a recykláciu podľa bodu „Rekuperácia“ v časti 
<intxref refid = "ASLAP70A7216001">Prevádzkový postup pre napĺňanie chladiacou kvapalinou:Manuálny typ</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte pravý spodný kryt motora.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte z kompresora poistný ventil (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A722038.swf" width = "88.000mm" height = "48.588mm" ver = "03" gw = "120" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7216043002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Použite nové tesniace krúžky.
</ptxt>
</item>
<item>
<ptxt>
Naneste kompresorový olej na tesniaci krúžok.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B107" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Kompresorový olej
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Poistný ventil dotiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T7B107">
<t-part>
Poistný ventil
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,8
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A722039.swf" width = "88.000mm" height = "48.612mm" ver = "05" gw = "120" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Odčerpajte a naplňte systém klimatizácie „Vypúšťanie“ a „Plnenie v 
<intxref refid = "ASLAP70A7216001">Prevádzkový postup pre napĺňanie chladiacou kvapalinou:Manuálny typ</intxref>
 .
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
