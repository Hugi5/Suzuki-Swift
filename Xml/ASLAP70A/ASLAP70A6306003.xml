<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A6306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia hlavy spojovacej tyče
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A6306002">Kontrola skrutky hlavy spojovacej tyče priamo na vozidle</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A6306001">Komponenty zostavy skrine prevodovky riadenia</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A6306003001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Zdvihnite vozidlo a odmontujte predné koleso. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte svorku (2) a maticu konca spojovacej tyče (1) od konca spojovacej tyče.
</ptxt>
<figure>
<graphic graphicname = "IAP70A630011.jpg" width = "88.000mm" height = "57.647mm" ver = "01" gw = "171" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Pomocou špeciálneho nástroja odpojte hlavu spojovacej tyče riadenia (1) od otočného čapu riadenia (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L6C003">
<s-part>
(A)
</s-part>
<s-number num = "09913-65210">
09913–65210
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630016.swf" width = "88.000mm" height = "52.953mm" ver = "01" gw = "118" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Aby sa vám pri spätnej inštalácii ľahšie vykonávalo nastavenie, urobte si značku (1) polohy poistnej matice hlavy spojovacej tyče (2) na závite konca spojovacej tyče. Potom uvoľnite poistnú maticu a odmontujte hlavu spojovacej tyče (3) zo spojovacej tyče (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A630017.swf" width = "88.000mm" height = "51.911mm" ver = "02" gw = "108" gh = "131"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASLAP70A6306003002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A6306004">Kontrola hlavy spojovacej tyče</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Nainštalujte poistnú maticu hlavy spojovacej tyče (2) a hlavu spojovacej tyče (3) na spojovaciu tyč (4). Zarovnajte poistnú maticu so značkou (1) na závite spojovacej tyče.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630017.swf" width = "88.000mm" height = "51.911mm" ver = "02" gw = "108" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Pripojte hlavu spojovacej tyče na otočný čap. Utiahnite maticu hlavy spojovacej tyče (1) na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T6C001">
<t-part>
Matica hlavy spojovacej tyče
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Namontujte svorku (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A630012.jpg" width = "88.000mm" height = "57.647mm" ver = "01" gw = "171" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte predné koleso. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte zbiehavosť. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Po potvrdení správnosti zbiehania utiahnite poistnú maticu hlavy spojovacej tyče na predpísaný uťahovací moment. 
<intxreftitleoff1 refid = "ASLAP70A6306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
