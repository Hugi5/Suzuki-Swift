<servinfosub id = "ASLAP70AA504017003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Kroky 1) a 2) niekoľkokrát zopakujte.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA504017004">
<title>
Riešenie problémov DTC
</title>
<attention3>
<ptxt>
Toto DTC môže byť zistené keď je batéria vybitá, alebo je slabé napätie.
</ptxt>
</attention3>
<diag type = "test" id = "ASLAP70AA504017005">
<testgroup id = "ASLAP70AA504017012">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF (vyp.) a k prípojke na údajové spojenie pripojte skenovacie zariadenie SUZUKI.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte „Steering Unlock Condition“ a „Steering Lock Condition“ zobrazené na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504017006">
<title>
Kontrola jednotky zámky riadenia
</title>
<test1>
<ptxt>
Otvorte dvere na strane vodiča.
</ptxt>
</test1>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Kroky 2) a 3) niekoľkokrát zopakujte.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, či je jednotka zámky riadenia zamknutá/odomknutá podľa zmeny zapaľovania.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504017007">
<title>
Kontrola napájacieho obvodu jednotky zámky riadenia
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor jednotky zámky riadenia.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svorky konektora jednotky zámky riadenia.
</ptxt>
</test1>
<test1>
<ptxt>
Ak je pripojenie OK, skontrolujte, či je napätie medzi obvodmi „A2“ a „C1“ akumulátorové napätie po zapnutí zapaľovania z OFF na ON.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504017008">
<title>
Kontrola obvodu uzemnenia jednotky zámky riadenia
</title>
<test1>
<ptxt>
Skontrolujte, či je napätie medzi obvodmi „A2“ a uzemnením akumulátorové napätie po zapnutí zapaľovania z OFF na ON.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Opravte alebo vymeňte obvod „C1“.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504017009">
<title>
Kontrola napájacieho obvodu jednotky zámky riadenia
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “G28”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svorky konektora “G28”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „A2“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A2“ a každou svorkou v konektore jednotky zámky riadenia: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504017010">
<title>
Kontrola signálu obvodu jednotky zámky riadenia
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “G28”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svorky konektora “G28”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „B1“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B1“ a každou svorkou v konektore jednotky zámky riadenia: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504017013">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte jednotku volantu a konektory „G28“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa aktuálne DTC B1160?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504017011">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte jednotku zámky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA504017003">Postup potvrdenia DTC</intxref>
 a potom znovu skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1160?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Porucha jednotky zámky riadenia.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
