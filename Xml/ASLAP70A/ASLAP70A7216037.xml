<title>
Demontáž a montáž hnacieho remeňa kompresora
</title>
<servinfosub id = "ASLAP70A7216037004">
<title>
Demontáž
</title>
<s1>
<ptxt>
Uvoľnite skrutku napínacej kladky (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite napnutie remeňa uvoľnením nastavovacej skrutky napínacej remenice (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte hnací remeň kompresora (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A722023.swf" width = "88.000mm" height = "57.807mm" ver = "08" gw = "182" gh = "147"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7216037001">
<title>
Montáž
</title>
<s1>
<ptxt>
Nainštalujte hnací remeň kompresora.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte napnutie remeňa. 
<intxreftitleoff1 refid = "ASLAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
