<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A4604022" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C102A
</title>
<servinfosub id = "ASLAP70A4604022001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C102A: Nepretržitá prevádzka ovládania ABS
</emph>
</ptxt>
<ptxt>
Riadenie ABS je neustále aktivované na všetkých kolesách.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka ESP<sup>®</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
<attention3>
<ptxt>
V režime núdzového zastavenia, keď riadiaca jednotka ESP<sup>®</sup> zastaví riadenie sa výstražná kontrolka vypne, DTC zostane zobrazený počas aktuálneho cyklu zapaľovania.
</ptxt>
<ptxt>
Je normálne, že DTC sa stane históriou, keď sa vypnuté zapaľovanie zapne.
</ptxt>
</attention3>
</servinfosub>
<servinfosub id = "ASLAP70A4604022002">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A4604022003">
<testgroup id = "ASLAP70A4604022005">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604022004">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70A4604005">Kontrola DTC</intxref>
.
</ptxt>
</test1>
<question>
Je detekovaný DTC C102A?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
