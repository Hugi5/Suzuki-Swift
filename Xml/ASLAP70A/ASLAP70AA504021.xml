<servinfosub id = "ASLAP70AA504021003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Kroky 1) a 2) niekoľkokrát zopakujte.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA504021004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA504021005">
<testgroup id = "ASLAP70AA504021008">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF (vyp.) a k prípojke na údajové spojenie pripojte skenovacie zariadenie SUZUKI.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte “Push Switch1” a “Push Switch2” zobrazené na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504021006">
<title>
Kontrola obvodu signálu spínača a obvodu uzemnenia spínača
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor motora a konektory „G28“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektoru spínača motora a „G28“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“, „A2“ a „B1“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „A1“ a „A2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A2“ a „A2“ a každou svorkou v konektore spínača motora: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B1“ a každou svorkou v konektore snímača spínača motora: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504021007">
<title>
Kontrola spínača motora
</title>
<test1>
<ptxt>
Skontrolujte spínač motora. 
<intxreftitleoff1 refid = "ASLAP70AA506016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte spínač motora. 
<intxreftitleoff1 refid = "ASLAP70AA506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504021009">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte konektor motora a konektory “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa aktuálne DTC B1190?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
</testgroup>
</diag>
