<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž motora ventilátora
</title>
<servinfosub id = "ASLAP70A7216009001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte prípojku (1) z motora ventilátora (2).
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte skrutky (3).
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte elektromotor ventilátora (2) z jednotky HVAC.
</ptxt>
<figure>
<graphic graphicname = "I4RS0B710005.swf" width = "88.000mm" height = "53.250mm" ver = "01" gw = "169" gh = "134"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7216009002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
