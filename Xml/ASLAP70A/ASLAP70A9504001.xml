<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A9504001" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Diagnostika symptómov systému elektricky ovládaných okien
</title>
<diag type = "condition" id = "ASLAP70A9504001001">
<condition>
<ptxt>
Nedá sa ovládať žiadne okno
</ptxt>
</condition>
<ps>
<ptxt>
Porucha zväzku
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha hlavného spínača elektricky ovládaného okna 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506019">Kontrola hlavného spínača elektricky ovládaného okna</intxref>
</ptxt>
</action>
<condition>
<ptxt>
Nedá sa ovládať jedno okno
</ptxt>
</condition>
<ps>
<ptxt>
Porucha zväzku
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha ovládača a/alebo motora elektrického sťahovania okien
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Predný: 
<intxreftitleoff1 refid = "ASLAP70A9506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A9506018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porucha hlavného spínača elektricky ovládaného okna
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506019">Kontrola hlavného spínača elektricky ovládaného okna</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha pomocného spínača elektricky ovládaného okna
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506020">Kontrola vedľajšieho spínača elektricky ovládaného okna</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Spínač uzamykania okna je stlačený (poloha uzamknutia)
</ptxt>
</ps>
<action>
<ptxt>
Vypnite spínač uzamykania okna
</ptxt>
</action>
<condition>
<ptxt>
Funkcia automatického sťahovania nefunguje
</ptxt>
</condition>
<ps>
<ptxt>
Porucha hlavného spínača elektricky ovládaného okna 
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506019">Kontrola hlavného spínača elektricky ovládaného okna</intxref>
</ptxt>
</action>
<condition>
<ptxt>
Nezvyčajný hluk
</ptxt>
</condition>
<ps>
<ptxt>
Uvoľnené montážne skrutky regulátora okien
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Dotiahnite montážne skrutky regulátora okien.
</ptxt>
<ptxt>
Predný: 
<intxreftitleoff1 refid = "ASLAP70A9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Opotrebované alebo poškodené vedenie regulátora okna a rotačné časti
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vymeňte regulátor okna.
</ptxt>
<ptxt>
Predný: 
<intxreftitleoff1 refid = "ASLAP70A9506012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A9506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Slabé namazanie
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Namažte ich.
</ptxt>
<ptxt>
Predný: 
<intxreftitleoff1 refid = "ASLAP70A9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
