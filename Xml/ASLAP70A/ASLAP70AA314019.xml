<servinfosub id = "ASLAP70AA314019003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ na 10 sek.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA314019004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA314019005">
<testgroup id = "ASLAP70AA314019006">
<title>
Kontrola obvodu signálu riadiacej jednotky imobilizéra
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory “G17” a “G04”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom “G17”, a “G04”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“, „A2“, „A3“ alebo „A4“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „A1“, „A2“, „A3“ a „A4“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A1“ a konektorom „G17“ ďalšou svorkou v konektore alternátora.
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA314019007">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Výmena riadiaceho modulu imobilizéra. 
<intxreftitleoff1 refid = "ASLAP70AA316001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70AA314019003">Postup potvrdenia DTC</intxref>
 a potom znovu skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1189?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte BCM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Riadiaca jednotka imobilizéra je chybná.)
</ptxt>
</action>
</testgroup>
</diag>
