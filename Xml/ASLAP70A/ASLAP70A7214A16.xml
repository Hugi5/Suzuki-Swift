<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7214A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Keď je kompresor v prevádzke, počuť hluk.
</title>
<servinfosub id = "ASLAP70A7214004003">
<title>
Nezvyčajný hluk z magnetickej spojky
</title>
<diag type = "condition">
<condition>
<ptxt>
Keď je kompresor v prevádzke, počuť hluk.
</ptxt>
</condition>
<ps>
<ptxt>
Nevhodná vôľa magnetickej spojky (priveľká vôľa)
</ptxt>
</ps>
<action>
<ptxt>
Nastavte vôľu magnetickej spojky. 
<intxreftitleoff1 refid = "ASLAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaný trecí povrch magnetickej spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte teleso magnetickej spojky. 
<intxreftitleoff1 refid = "ASLAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Znečistenie trecieho povrchu kompresorovým olejom, ktorý unikol cez tesnenie hriadeľa
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte teleso kompresora. 
<intxreftitleoff1 refid = "ASLAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
