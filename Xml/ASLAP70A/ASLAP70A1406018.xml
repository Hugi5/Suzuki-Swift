<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1406018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Odstránenie a inštalácia krytu rozvodovej reťaze
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1406017">Diely krytu rozvodovej reťaze</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Počas generálnej opravy dbajte o čistotu pracovného stola, náradia a rúk.
</ptxt>
</item>
<item>
<ptxt>
S hliníkovými časťami manipulujte opatrne, aby sa nepoškodili.
</ptxt>
</item>
<item>
<ptxt>
Demontované časti chráňte pred prachom. Vždy ich udržiavajte čisté.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "ASLAP70A1406018001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Z vozidla odmontujte zariadenie motora. 
<intxreftitleoff1 refid = "ASLAP70A1406016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zložte hnací remeň vodného čerpadla/alternátora. 
<intxreftitleoff1 refid = "ASLAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte skrutku remenice kľukového hriadeľa.
</ptxt>
<ptxt>
Špeciálnym prípravkom (podľa obrázku) zabezpečte remenicu kľukového hriadeľa (1).
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Pri používaní špeciálneho nástroja sa vyhnite nepotrebnej záťaži na rozvodovú reťaz, reťazové kolesá a ostatné príslušné časti.
</ptxt>
</item>
<item>
<ptxt>
Použite nižšie uvedené skrutky na montáž špeciálneho nástroja k remenici kľukového hriadeľa.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Upevňovacia skrutka špeciálneho nástroja
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.729in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.729in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Veľkosť skrutky
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
M8
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Odstup
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
1,25 mm (0,05 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Dĺžka &#34;a&#34;
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
25 mm (0,98 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Sila
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
7T
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</attention2>
<attention3>
<ptxt>
Ak je to potrebné, použite na vybratie týchto kolíkov špeciálny nástroj.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1D010">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917–68221
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141049.swf" width = "88.000mm" height = "49.174mm" ver = "01" gw = "163" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte remenicu kľukového hriadeľa (1).
</ptxt>
<ptxt>
Vyberá sa ťažko, preto použite špeciálny prípravok podľa obrázku.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D011">
<s-part>
(A)
</s-part>
<s-number num = "09926-37610-001">
09926–37610–001
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L1D012">
<s-part>
(B)
</s-part>
<s-number num = "09926-58010">
09926–58010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B140052.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "170" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte kryt hlavy valca. 
<intxreftitleoff1 refid = "ASLAP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte olejovú vaňu. 
<intxreftitleoff1 refid = "ASLAP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte remenicu vodného čerpadla.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky krytu rozvodovej reťaze a potom kryt rozvodovej reťaze vyberte.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte olejové tesnenie vačkového hriadeľa z krytu rozvodovej reťaze pomocou skrutkovača na zápustné hlavy alebo podobným nástrojom, ak je to nutné.
</ptxt>
</s1>
<s1>
<ptxt>
Podľa potreby zložte z krytu rozvodovej reťaze OCV. 
<intxreftitleoff1 refid = "ASLAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ak je to potrebné, rozmontujte kryt rozvodovej reťaze a olejové čerpadlo. 
<intxreftitleoff1 refid = "ASLAP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1406018002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1406019">Kontrola krytu rozvodovej reťaze</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Vyčistite povrch pre tesnenie krytu rozvodovej reťaze, bloku valcov a hlavy valcov.
</ptxt>
<ptxt>
Z povrchu pre tesnenie odstráňte olej, starý tesniaci prostriedok a prach.
</ptxt>
</s1>
<s1>
<ptxt>
Opätovne namontujte kryt rozvodovej reťaze a olejové čerpadlo. 
<intxreftitleoff1 refid = "ASLAP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
 Ak bolo odstránené, namontujte OCV. 
<intxreftitleoff1 refid = "ASLAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte povrch olejového tesnenia (1) či nie je vadný alebo pokazený.
</ptxt>
<ptxt>
Ak je to potrebné, vymeňte olejové tesnenie.
</ptxt>
<attention3>
<ptxt>
Pri montáži nového olejového tesnenia ho zatlačte, aby zapadlo do krytu rozvodovej reťaze (2) pomocou špeciálneho nástroja (A), ako vidno na obrázku.
</ptxt>
</attention3>
<spec>
<title>
Hĺbka
</title>
<ptxt>
„a”: 1,5 mm (1,52 mm.)
</ptxt>
</spec>
<servicetool>
<servicetoolitem id = "L1D013">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913–75810
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141050.swf" width = "88.000mm" height = "52.484mm" ver = "01" gw = "179" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Na olejové čerpadlo (2) namontujte nový tesniaci krúžok (1).
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte nové tesnenie (3) ku krytu rozvodovej reťaze (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141055.jpg" width = "88.000mm" height = "67.189mm" ver = "01" gw = "144" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte spojovací kolík (1) na blok motora, ak bol odmontovaný.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141056.swf" width = "88.000mm" height = "58.478mm" ver = "01" gw = "131" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Podľa obrázku použite tesniaci prostriedok &#34;A&#34; na styčnú plochu valca a hlavy valca, a tesniaci prostriedok &#34;B&#34; na styčnú plochu krytu rozvodovej reťaze.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207B" id = "M1D002" uid = "29">
<m-part>
„A“
</m-part>
<m-desc>
Tesniaci prostriedok
</m-desc>
<m-number>
99000–31140
</m-number>
<m-name>
SUZUKI Bond No.1207B
</m-name>
</materialitem>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1D003" uid = "-491504098">
<m-part>
„B“
</m-part>
<m-desc>
Tesniaci prostriedok
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<spec>
<title>
Použité množstvo tesniaceho prostriedku na kryt rozvodovej reťaze
</title>
<ptxt>
Šírka “a”: 3 mm (3,05 mm.)
</ptxt>
<ptxt>
výška &#34;b&#34;: 2 mm (2,03 mm.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A141057.jpg" width = "88.000mm" height = "49.092mm" ver = "01" gw = "220" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Použite motorový olej na plochu tesnenia, potom namontujte kryt rozvodovej reťaze (1). Skrutky dotiahnite v číselnom poradí „1“ až „15“ na špecifikovaný točivý moment.
</ptxt>
<attention3>
<ptxt>
Pred montážou krytu rozvodovej reťaze preverte, či je kolík bezpečne namontovaný.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1D011">
<t-part>
Skrutka krytu rozvodovej reťaze
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141058.jpg" width = "88.000mm" height = "72.952mm" ver = "01" gw = "169" gh = "190"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte remenicu vodného čerpadla.
</ptxt>
</s1>
<s1>
<ptxt>
Nainštalujte kryt hlavy valca. 
<intxreftitleoff1 refid = "ASLAP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nainštalujte olejovú vaňu. 
<intxreftitleoff1 refid = "ASLAP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte remenicu kľukového hriadeľa (1). Utiahnite skrutku remenice kľukového hriadeľa na predpísaný uťahovací moment. Špeciálnym nástrojom (podľa obrázku) zabezpečte remenicu kľukového hriadeľa.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Pri používaní špeciálneho nástroja sa vyhnite nepotrebnej záťaži na rozvodovú reťaz, reťazové kolesá a ostatné príslušné časti.
</ptxt>
</item>
<item>
<ptxt>
Použite nižšie uvedené skrutky na montáž špeciálneho nástroja k remenici kľukového hriadeľa.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
