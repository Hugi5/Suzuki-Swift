<attention3>
<ptxt>
Ak je to potrebné, použite na vybratie týchto kolíkov špeciálny nástroj.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1D014">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917–68221
</s-number>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T1D012">
<t-part>
Skrutka remenice kľukového hriadeľa
</t-part>
