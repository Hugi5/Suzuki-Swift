111,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141040.swf" width = "88.000mm" height = "49.174mm" ver = "02" gw = "174" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Zostavu motora nasaďte do vozidla. 
<intxreftitleoff1 refid = "ASLAP70A1406016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
