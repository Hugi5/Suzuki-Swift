<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1804002" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Test zapaľovania zapaľovacími sviečkami
</title>
<attention1>
<ptxt>
Ak neodpojíte konektory vstrekovacích ventilov, počas tohto testu sa môže otvormi v zapaľovacích sviečkach uvoľniť horľavý plyn a môže spôsobiť horenie v motorovej časti.
</ptxt>
</attention1>
<s1>
<ptxt>
Odmontujte zapaľovacie sviečky. 
<intxreftitleoff1 refid = "ASLAP70A1806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte zapaľovacie sviečky. 
<intxreftitleoff1 refid = "ASLAP70A1806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte všetky konektory vstrekovacích ventilov.
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte jeden konektor zapaľovacej cievky (1) k zapaľovacej cievke (3).
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte zapaľovaciu sviečku (2) k zapaľovacej cievke (3) a zapaľovacie sviečky uzemnite.
</ptxt>
<figure>
<graphic graphicname = "I9P60A180004.swf" width = "88.000mm" height = "69.562mm" ver = "01" gw = "185" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Roztočte motor a skontrolujte či každá zo zapaľovacích sviečok iskrí.
</ptxt>
</s1>
<s1>
<ptxt>
Ak sviečky neiskria, skontrolujte príslušné diely. 
<intxreftitleoff1 refid = "ASLAP70A1804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
