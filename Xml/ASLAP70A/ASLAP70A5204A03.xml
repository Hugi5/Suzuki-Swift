<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A5204A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hlučnosť
</title>
<diag type = "condition">
<condition>
<ptxt>
Hlučnosť
</ptxt>
</condition>
<ps>
<ptxt>
Nevhodný mazací prostriedok alebo jeho nedostatok
</ptxt>
</ps>
<action>
<ptxt>
Doplňte olej do manuálnej prevodovky.
</ptxt>
</action>
<ps>
<ptxt>
Poškodené alebo opotrebované ložisko(á)
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte ložisko.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ľavé ložisko predlohového hriadeľa:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Vnútorný krúžok: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vonkajší krúžok: 
<intxreftitleoff1 refid = "ASLAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Pravé ložisko predlohového hriadeľa:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Vnútorný krúžok: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vonkajší krúžok: 
<intxreftitleoff1 refid = "ASLAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Ľavé a pravé ložisko vstupného hriadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hnacie ložisko diferenciálu:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Vnútorný krúžok: 
<intxreftitleoff1 refid = "ASLAP70A5206025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pravá strana vonkajšieho krúžku: 
<intxreftitleoff1 refid = "ASLAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ľavá strana vonkajšieho krúžku: 
<intxreftitleoff1 refid = "ASLAP70A5206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Ihličkové ložisko:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
1. a 2. stupeň predlohového riadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
3. a 4. stupeň vstupného hriadeľa: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5. prevodový stupeň: 
<intxreftitleoff1 refid = "ASLAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
</list1>
</action>
<ps>
<ptxt>
Poškodené alebo opotrebované ozubené koleso(á)
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte ozubené koleso.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Koleso 1., 2., 3. a 4. prevodového stupňa na predlohovom hriadeli: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Koleso 1., 2., 3. a 4. prevodového stupňa na vstupnom hriadeli: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Koleso 5. prevodového stupňa na vstupnom hriadeli a 5. prevodového stupňa na predlohovom hriadeli: 
<intxreftitleoff1 refid = "ASLAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Poškodené alebo opotrebované časti synchronizačnej spojky
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte časti synchronizačnej spojky.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Časti synchronizačnej spojky nízkych rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Časti synchronizačnej spojky vysokých rýchlostných stupňov: 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Časti synchronizačnej spojky 5. rýchlostného stupňa: 
<intxreftitleoff1 refid = "ASLAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
