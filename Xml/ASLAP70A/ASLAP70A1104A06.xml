<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hluk motora - hluk kľukového hriadeľa
</title>
<ptxt>
Ak ECM nezistil žiaden kód DTC a pri 
<intxref refid = "ASLAP70A1104008">Vizuálna prehliadka</intxref>
 a 
<intxref refid = "ASLAP70A1104009">Základná kontrola motora</intxref>
 sa nezistila žiadna odchýlka, vykonajte riešenie problémov podľa nasledovných bodov.
</ptxt>
<diag type = "condition">
<condition>
<paragroup>
<ptxt>
Hluk motora - hluk kľukového hriadeľa
</ptxt>
<attention3>
<ptxt>
Pred kontrolou mechanického hluku sa presvedčite, či:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
je použitá predpísaná sviečka zapaľovania.
</ptxt>
</item>
<item>
<ptxt>
je použité predpísané palivo.
</ptxt>
</item>
</list1>
</attention3>
</paragroup>
</condition>
<ps>
<ptxt>
Nízky tlak oleja
</ptxt>
</ps>
<action>
<ptxt>
Stav „Nízky tlak oleja“
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované hlavné ložisko
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406041">Kontrola hlavných ložísk</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaný hlavný čap kľukového hriadeľa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406040">Kontrola kľukového hriadeľa</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené skrutky veka ložiska
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406041">Kontrola hlavných ložísk</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nadmerná vôľa kľukového hriadeľa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406040">Kontrola kľukového hriadeľa</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
