<servinfosub id = "ASLAP70A4604027003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A4604027004">
<testgroup id = "ASLAP70A4604027005">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604027006">
<title>
Kontrola obvodov napájania a uzemnenia elektromagnetického ventilu riadiacej jednotky ESP®
</title>
<test1>
<ptxt>
Skontrolujte obvod napájania a uzemnenia elektromagnetického ventilu podľa 
<intxref refid = "ASLAP70A4604042">Kontrola obvodu napájania a uzemnenia riadiacej jednotky ESP®</intxref>
.
</ptxt>
</test1>
<question>
Sú výsledky kontroly primerané?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
</diag>
