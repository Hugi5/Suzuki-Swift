<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spúšťača ovládania nasávania vzduchu
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A7216020">Komponenty riadiacej jednotky HVAC:Manuálny typ</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A7216026001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odstráňte žeraviace sviečky. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte spodné potrubie na strane spolujazdca. 
<intxreftitleoff1 refid = "ASLAP70A7216011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor ovládača regulácie nasávania vzduchu.
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte skrutky (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte spúšťač ovládania nasávania vzduchu (2) z jednotky HVAC.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721028.jpg" width = "88.000mm" height = "68.236mm" ver = "01" gw = "142" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7216026002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A7216027">Kontrola ovládača regulácie nasávania vzduchu:Manuálny typ</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Do drážky (2) spúšťača ovládania nasávania vzduchu nezabudnite vložiť zarovnávací kolík (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A721029.swf" width = "88.000mm" height = "49.668mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
