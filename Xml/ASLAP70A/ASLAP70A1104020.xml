<servinfosub id = "ASLAP70A1104020003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ na 10 sek.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104020004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104020005">
<testgroup id = "ASLAP70A1104020006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104020007">
<title>
Kontrola obvodu napájacieho napätia snímača MAP
</title>
<test1>
<ptxt>
Ak je zapaľovanie odpojené, odpojte konektor snímača MAP.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie konektora snímača MAP na každej svorke.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi obvodom „A1“ a „A3“ je pribl. 5 V.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104020008">
<title>
Kontrola obvodu uzemnenia snímača tlaku vzduchu v sacom potrubí
</title>
<test1>
<ptxt>
Skontrolujte, že napätie medzi obvodom „A1“ a uzemnením je pribl. 5 V.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Opravte obvod „A3“.
</ptxt>
<ptxt>
Ak je detekovaná táto DTC opätovne, vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte obvod „A1“.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104020009">
<title>
Kontrola obvodu signálu snímača MAP
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „A2“: menej ako 1Ω
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A2“ a ďalšou svorkou v konektore snímača MAP: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „A2“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104020010">
<title>
Kontrola snímača MAP
</title>
<test1>
<ptxt>
Skontrolujte snímač MAP. 
<intxreftitleoff1 refid = "ASLAP70A1306010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte snímač absolútneho tlaku vzduchu v potrubí.
</ptxt>
</action>
</testgroup>
</diag>
