<servinfosub id = "ASLAP70AA104008003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA104008004">
<testgroup id = "ASLAP70AA104008005">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF (vyp.) a k prípojke na údajové spojenie pripojte skenovacie zariadenie SUZUKI.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte “spínač tempomatu CANCEL”, “spínač tempomatu RES/ACC”, “spínač tempomatu SET/COAST” a “vypínač tempomatu”, ktoré sú zobrazené na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA104006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA104008006">
<title>
Kontrola obvodu spínača tempomatu
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory “C01”, “E01” a “G371”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom “C01”, “E01” a “G371”.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“ alebo „A2“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A1“ a konektorom „G371“ ďalšou svorkou v konektore alternátora: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A2“ a konektorom „G371“ ďalšou svorkou v konektore alternátora: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodov „A1“ alebo „A2“: 0 - 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA104008007">
<title>
Kontrola spínača tempomatu
</title>
<test1>
<ptxt>
Skontrolujte spínač tempomatu. 
<intxreftitleoff1 refid = "ASLAP70AA106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte spínač tempomatu. 
<intxreftitleoff1 refid = "ASLAP70AA106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
