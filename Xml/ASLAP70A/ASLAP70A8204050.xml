<servinfosub id = "ASLAP70A8204050003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204050004">
<testgroup id = "ASLAP70A8204050005">
<question>
Vykonala sa „Kontrola diagnostického systému airbagov“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204050006">
<title>
Kontrola prerušenia káblového zväzku podlahy
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory “L04” a “L49” alebo konektory “L05” a “L50”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“ alebo „A2“ (DTC B1392 / B1393): 1 &#937; alebo menej
</ptxt>
</item>
<item>
<ptxt>
Odpor obvodov „A3“ alebo „A4“ (DTC B1397 / B1398): 1 &#937; alebo menej
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B091">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820036.swf" width = "90.000mm" height = "67.074mm" ver = "02" gw = "214" gh = "174"/>
</testfigure>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
