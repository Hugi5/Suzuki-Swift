<servinfosub id = "ASLAP70A4604020003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A4604020004">
<testgroup id = "ASLAP70A4604020005">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604020006">
<title>
Kontrola vypínača ESP®
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF (VYP).
</ptxt>
</test1>
<test1>
<ptxt>
Vyberte vypínač ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "ASLAP70A4606017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, či je pripojenie na každej svorke vypínača ESP<sup>®</sup> správne.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia správne, skontrolujte vypínač ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "ASLAP70A4606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vypínač ESP<sup>®</sup> vymeňte.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604020007">
<title>
Kontrola obvodu vypínača ESP®
</title>
<test1>
<ptxt>
Odpojte konektor „E24“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie k svorke „E24-38“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak je pripojenie v poriadku, skontrolujte odpor mezi svorkou „E24-38“ a uzemnením.
</ptxt>
</test1>
<question>
Je odpor nekonečný?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte ak je obvod „A1“ skratovaný.
</ptxt>
</action>
</testgroup>
</diag>
