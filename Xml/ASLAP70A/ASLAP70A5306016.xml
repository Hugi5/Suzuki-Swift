<servinfo servinfosgmlid = "ASLAP70A5306016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž sústavy spojkového pedála
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A5306015">Súčiastky sústavy pedála spojky</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A5306016001" page = "2">
<title>
Demontáž
</title>
<s1 page = "2">
<ptxt>
Vyberte tlačnú tyč od spojkového pedála. 
<intxreftitleoff1 refid = "ASLAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ak je to potrebné, odpojte konektor spínača CPP č. 1 (ak je vo výbave) a spínača CPP č. 2, podom odmontujte spínač CPP č. 1 (ak je vo výbave) a spínač CPP č. 2 od zostavy spojkového pedála.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Spínač CPP č. 1: 
<intxreftitleoff1 refid = "ASLAP70A5306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
CPP spínač č. 2: 
<intxreftitleoff1 refid = "ASLAP70A5306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Z karosérie vozidla demontujte zostavu spojkového pedála.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASLAP70A5306016002" page = "2">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dotiahnite každú skrutku a matice na požadovaný uťahovací moment. 
<intxreftitleoff1 refid = "ASLAP70A5306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Na koniec tlačnej tyče naneste vazelínu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Silicone Grease" id = "M5C002" uid = "21">
<m-part>
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25100
</m-number>
<m-name>
SUZUKI Silicone Grease
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Ak je potrebné dodatočné namazanie, naneste vazelínu na špecifikované umiestnenie. 
<intxreftitleoff1 refid = "ASLAP70A5306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease E" id = "M5C003" uid = "24">
<m-part>
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25050
</m-number>
<m-name>
SUZUKI Super Grease E
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
