<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1406016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž jednotky motora
</title>
<servinfosub id = "ASLAP70A1406016001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Uvoľnite tlak paliva. 
<intxreftitleoff1 refid = "ASLAP70A1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte akumulátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte prípojky riadiacej jednotky motora. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte konzolu akumulátora s ECM. 
<intxreftitleoff1 refid = "ASLAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte kryty motora na pravej a ľavej strane.
</ptxt>
</s1>
<s1>
<ptxt>
Ak je to potrebné, vypustite nasledovné oleje a tekutiny.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Motorový olej: 
<intxreftitleoff1 refid = "ASLAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Olej manuálnej prevodovky: 
<intxreftitleoff1 refid = "ASLAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Olej rozdeľovacej prevodovky: 
<intxreftitleoff1 refid = "ASLAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Vypustite chladiacu kvapalinu. 
<intxreftitleoff1 refid = "ASLAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte zostavu čističa vzduchu. 
<intxreftitleoff1 refid = "ASLAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Hadica je pripojená, odpojte kompresor klimatizácie z jej konzoly. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s manuálnou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatickou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Demontovaný A/C kompresor klimatizácie odložte na miesto, kde sa počas demontáže a montáže motora nepoškodí.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Odpojte konektory nasledovných elektrických káblov a ich svorky.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Uzemňovací kábel akumulátora (1)
</ptxt>
</item>
<item>
<ptxt>
Konektory (2) v hlavnej poistkovej skrinke
</ptxt>
</item>
<item>
<ptxt>
Konektor snímača elektrickej záťaže (3)
</ptxt>
</item>
<item>
<ptxt>
Konektor (4) v samostatnej poistkovej skrinke obvodu č. 1
</ptxt>
<figure>
<graphic graphicname = "I9P60A141043.jpg" width = "88.000mm" height = "60.102mm" ver = "01" gw = "199" gh = "154"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Odpojte nasledujúce káble.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tiahlo ovládania polohy prevodovky (1)
</ptxt>
</item>
<item>
<ptxt>
Tiahlo ovládania radiacej páky (2)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140002.jpg" width = "88.000mm" height = "62.413mm" ver = "01" gw = "199" gh = "160"/>
</figure>
</s1>
<s1>
<ptxt>
Odpojte nasledujúce hadice.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Hadicu posilňovača bŕzd (1)
</ptxt>
</item>
<item>
<ptxt>
Prívodné a vývodné (2) hadice chladiča
</ptxt>
</item>
<item>
<ptxt>
Prívodné a vývodné hadice ohrievača (3)
</ptxt>
</item>
<item>
<ptxt>
Hadicu dodávky paliva (4)
</ptxt>
</item>
<item>
<ptxt>
Hladica spojkovej kvapaliny (5) 
<intxreftitleoff1 refid = "ASLAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140003.jpg" width = "88.000mm" height = "112.325mm" ver = "02" gw = "199" gh = "302"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Odpojte od hriadeľa pastorku spodný hriadeľ riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Z tyče stabilizátora odmontujte kĺby tyče stabilizátora. 
<intxreftitleoff1 refid = "ASLAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte od otočného čapu riadenia hlavu riadiacej tyče. 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte pravý a ľavý kĺb hnacieho hriadeľa od čapu riadenia. 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte výfukové potrubie č. 1 a stredové výfukové potrubie. 
<intxreftitleoff1 refid = "ASLAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte zostavu kardanového hriadeľa. 
<intxreftitleoff1 refid = "ASLAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou zdviháka podoprite rám predného zavesenia (1), skriňu prevodovky (2) a blok motora (3).
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte skrutky predného rámu nápravy (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A140004.jpg" width = "88.000mm" height = "55.276mm" ver = "01" gw = "199" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Demontujte ľavé montážne skrutky (1) a matice (2) držiaka motora (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A140005.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.309in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.280in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.253in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.280in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Horná strana
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Dolná strana
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Demontujte pravé montážne skrutky (1) a matice (2) držiaka motora (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A140006.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1>
<ptxt>
Pred odmontovaním motora sa uistite, že sú všetky hadice, elektrické vedenia a káble odpojené od motora.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Spustite celok motora s prevodovkou, rámom predného zavesenia, hnacími hriadeľmi a skriňou prevodovky P/S.
</ptxt>
<attention2>
<ptxt>
Pred znížením motora, aby ste sa vyhli poškodeniu kompresora klimatizácie, vytvorte vôľu medzi kompresorom klimatizácie a motorom zavesením kompresora klimatizácie.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Ak je to potrebné, od motora a prevodovky s rozvodovkou odpojte kabeláž motora.
</ptxt>
</s1>
<s1>
<ptxt>
Ak je to potrebné, demontujte zostavu predného hnacieho hriadeľa. 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ak je to potrebné, odstráňte predný rám nápravy.
</ptxt>
</s1>
<s1>
<ptxt>
V prípade potreby vyberte prevodovku. 
<intxreftitleoff1 refid = "ASLAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ak je to potrebné, odpojte prevodovku od motora. 
<intxreftitleoff1 refid = "ASLAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Podľa potreby demontujte kryt a lamelu spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ak je to potrebné, vyberte zotrvačník. 
<intxreftitleoff1 refid = "ASLAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1406016002" page = "2">
<title>
Montáž
</title>
<s1>
<ptxt>
Ak ste odmontovali zotrvačník, namontujte ho. 
<intxreftitleoff1 refid = "ASLAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Ak boli demontované, nainštalujte kryt a lamelu spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Pripojte prevodovku k motoru, ak ste ju predtým demontovali . 
<intxreftitleoff1 refid = "ASLAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ak ste odmontovali prevodovku, namontujte ju. 
<intxreftitleoff1 refid = "ASLAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Ak bol odstránený, namontujte rám predného zavesenia. 
<intxreftitleoff1 refid = "ASLAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Ak bol odstránený, namontujte zostavu predného hnacieho hriadeľa. 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
AK bol vybratý, namontujte zväzok motora k motoru a prevodovke s rozvodovkou a potom dotiahnite uzemňovaciu skrutku zväzku motora (1) na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1D008">
<t-part>
Uzemňovacia skrutka kabeláže motora
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140007.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Spustite celok motora s prevodovkou, rámom predného zavesenia, hnacími hriadeľmi a skriňou prevodovky P/S.
</ptxt>
<attention2>
<ptxt>
Pred zodvihnutím motora, aby ste sa vyhli poškodeniu kompresora klimatizácie, vytvorte vôľu medzi kompresorom klimatizácie a motorom zavesením kompresora klimatizácie.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Namontujte pravé montážne skrutky (1) a matice (2) držiaka motora (1).
</ptxt>
<torque>
<torqueitem id = "T1D009">
<t-part>
Skrutka a matice konzoly upevnenia motora vpravo
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140008.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Skrutky (1) a matice (2) montážnej konzoly motora dotiahnite na predpísaný krútiaci moment.
</ptxt>
<torque>
<torqueitem id = "T1D010">
<t-part>
Skrutku a maticu konzoly upevnenia motora vľavo
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140009.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
