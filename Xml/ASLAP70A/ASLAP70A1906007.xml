<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1906007" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rozobratie a poskladanie motora štartéra
</title>
<servinfosub id = "ASLAP70A1906007001">
<title>
Rozobratie
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1906002">Demontáž a montáž štartéra</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A1906004">Diely štartéra</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Pred demontážou si nakreslite značky (1) a (2) tak, ako je to na obrázku, aby ste zabezpečili správne vyrovnanie pri opätovnej montáži.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190005.swf" width = "88.000mm" height = "55.476mm" ver = "01" gw = "121" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte maticu (1) a odpojte vodič (2) od magnetického spínača (3).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190006.swf" width = "88.000mm" height = "55.476mm" ver = "01" gw = "145" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte skrutky (4) a vytiahnite magnetický spínač (1) zo zostavy štartéra motora.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte pružinu (2) a plunžer (3) z telesa magnetického spínača.
</ptxt>
<attention2>
<ptxt>
Teleso magnetického spínača nerozoberajte.
</ptxt>
<ptxt>
Ak je to potrebné, teleso magnetického spínača vymeňte ako celok.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I8C50B190007.swf" width = "88.000mm" height = "72.205mm" ver = "01" gw = "137" gh = "188"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte skrutky (1) a vyberte strmeň z krytu kotvy (2).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190008.swf" width = "88.000mm" height = "61.193mm" ver = "01" gw = "192" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte priechodku (2) a planétové súkolesia (1).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190009.swf" width = "88.000mm" height = "39.697mm" ver = "01" gw = "134" gh = "96"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte tesniacu gumu (1) a dosku (2).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190010.swf" width = "88.000mm" height = "55.234mm" ver = "01" gw = "170" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte zostavu hriadeľa (1) s pákou pastorka (2).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190011.swf" width = "88.000mm" height = "47.402mm" ver = "01" gw = "164" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
S dorazovým krúžkom pastorka (3) posunutým k strane voľnobežnej spojky (4) (v smere šípky), vyberte poistný krúžok (2) pomocou klieští na montáž krúžkov (5).
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte dorazový krúžok pastorka (3), voľnobežnú spojku (4) a vnútorný prevod (1) z krytu hriadeľa ozubeného kolesa.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190012.swf" width = "88.000mm" height = "39.316mm" ver = "01" gw = "163" gh = "94"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte koniec puzdra (1) a odmontujte držiak kefky (2) zo strmeňa (3).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190013.swf" width = "88.000mm" height = "55.771mm" ver = "01" gw = "226" gh = "142"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte armatúru (1) zo strmeňa (2).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190014.swf" width = "88.000mm" height = "47.593mm" ver = "02" gw = "181" gh = "118"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte pružiny kefiek (2) a kefky (1).
</ptxt>
<figure>
<graphic graphicname = "I6JB01190014.swf" width = "88.000mm" height = "66.987mm" ver = "01" gw = "140" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1906007002">
<title>
Zloženie
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1906009">Kontrola štartéra</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Namontujte pružiny kefky (2) a kefky (1) k držiaku kefky (3).
</ptxt>
<figure>
<graphic graphicname = "I6JB01190015.swf" width = "88.000mm" height = "66.987mm" ver = "01" gw = "140" gh = "173"/>
</figure>
</s1>
<s1>
<ptxt>
Kotvu (2) namontujte na strmeň.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte zostavu kefy (1) k armatúre (2) zatiaľ čo tlačíte 4 kefky (3) smerom von.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190015.swf" width = "88.000mm" height = "90.437mm" ver = "01" gw = "193" gh = "240"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte koniec puzdra (1) k držiaku kefky a dotiahnite skrutky držiaka kefky (2) na predpísané uťahovacie momenty.
</ptxt>
<torque>
<torqueitem id = "T1I003">
<t-part>
Skrutka držiaka kefy
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3,5
</t-value1>
<t-value2>
0,36
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190016.swf" width = "88.000mm" height = "49.914mm" ver = "01" gw = "183" gh = "125"/>
</figure>
</s1>
<s1>
<ptxt>
Na pero hriadeľa prevodu (1) a zuby vnútorného prevodu (2) naneste vazelínu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I001" uid = "1126491901">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A191019.swf" width = "88.000mm" height = "31.442mm" ver = "01" gw = "205" gh = "72"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte vnútorný prevod a spojku voľnobehu (1) k výstupnému hriadeľu (4) s novým poistným krúžkom (3) a dorazový krúžok pastorka (2).
</ptxt>
<attention3>
<ptxt>
Dorazový krúžok pastorka namontujte v smere a polohe podľa obrázku.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IYSQ01190024.swf" width = "88.000mm" height = "42.999mm" ver = "01" gw = "159" gh = "105"/>
</figure>
</s1>
<s1>
<ptxt>
Na hnaciu páku (2) naneste vazelínu a vložte zostavu (1) do krytu kotvy s hnacou pákou umiestnenou tak, ako je to na obrázku.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I002" uid = "1126491901">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAY301190005.swf" width = "88.000mm" height = "47.402mm" ver = "02" gw = "164" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Vyrovnajte otvory skrutky krytu kotvy (3) a výrezy na priechodke, potom namontujte priechodku (1) do krytu kotvy.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte dosku (5) a tesniacu gumu (4) ku krytu kotvy.
</ptxt>
</s1>
<s1>
<ptxt>
Na planétové súkolesie (2) naneste vazelínu a nainštalujte planétové súkolesie k výstupnému hriadeľu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I003" uid = "1126491901">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I8C50B190019.swf" width = "88.000mm" height = "58.155mm" ver = "01" gw = "176" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte strmeň, kotvu, zostavu kefiek a koniec puzdra (4) na kryt kotvy (2), vyrovnajte značky (3), ktoré ste nakreslili pred demontážou.
</ptxt>
</s1>
<s1>
<ptxt>
Utiahnite skrutky konca puzdra (1) na predpísaný moment.
</ptxt>
<torque>
<torqueitem id = "T1I004">
<t-part>
Skrutka konca puzdra
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190020.swf" width = "88.000mm" height = "62.840mm" ver = "01" gw = "192" gh = "162"/>
</figure>
</s1>
<s1>
<ptxt>
Na rozperu naneste vazelínu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I004" uid = "1126491901">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I8C50B190021.swf" width = "88.000mm" height = "54.810mm" ver = "01" gw = "142" gh = "138"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte magnetický spínač (1), pružinu (2) a plunžer (3) ku krytu kotvy (5), nezabudnite vyrovnať značky, ktoré ste nakreslili pred ostránením.
</ptxt>
</s1>
<s1>
<ptxt>
Skrutky (4) utiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1I005">
<t-part>
Skrutka magnetického spínača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190022.swf" width = "88.000mm" height = "72.616mm" ver = "01" gw = "137" gh = "189"/>
</figure>
</s1>
<s1>
<ptxt>
Pripojte vodič (1) ku svorke „M“ (2) potom dotiahnite maticu vodiča na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1I006">
<t-part>
Matica vodiča
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190023.swf" width = "88.000mm" height = "55.487mm" ver = "01" gw = "145" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Skontrolujte činnosť magnetického spínača 
<intxreftitleoff1 refid = "ASLAP70A1906009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
