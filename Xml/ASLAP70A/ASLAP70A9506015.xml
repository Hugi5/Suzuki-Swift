<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž skla zadných dverí
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9506014">Komponenty zadných dverí</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A9506015001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Sklo zadných dverí úplne stiahnite.
</ptxt>
</s1>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte vnútorné ozdobné obloženie zadných dverí (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte vnútorný kryt rukoväte (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky (3) a svorku (B) a potom vyberte obloženie dverí (4) potiahnutím v smere šípky a odpojte konektory káblového zväzku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950037.jpg" width = "88.000mm" height = "109.011mm" ver = "01" gw = "227" gh = "292"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte vonkajšiu tesniacu lištu zadných dverí (1) posunutím v smere šípky v poradí (“1” až “2”) podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950038.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.176in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.502in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Zárez
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Vonkajší plech zadných dverí
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte vnútornú tesniacu lištu zadných dverí (1) posunutím v smere šípky v poradí (“1” až “2”) podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950039.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.905in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Vnútorný plech zadných dverí
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte konzolu obloženia dverí (1) a tesniaci kryt dverí (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950040.jpg" width = "88.000mm" height = "91.844mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Otočte pohyb skla (1) a vyberte skrutku rámu zadných dverí (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky rámu zadných dverí (3) a vyberte rám zadných dverí (4) a pohyb skla.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950041.jpg" width = "88.000mm" height = "80.089mm" ver = "02" gw = "211" gh = "211"/>
</figure>
</s1>
<s1>
<ptxt>
Otočte sklo zadných dverí (1) v smere šípky “1” a vyberte spodný kanál skla (3) od zostavy ovládača zadného okna (2) a potom vyberte sklo zadných dverí v smere šípky “2”.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950042.jpg" width = "88.000mm" height = "97.155mm" ver = "01" gw = "227" gh = "259"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte spodný kanál od skla zadných dverí, ak je to potrebné.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9506015002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Namontujte spodný kanál skla (1) do predpísanej polohy skla zadných dverí (2), ak ste ich demontovali skla zadných dverí.
</ptxt>
<spec>
<title>
Poloha inštalácie skla zadných dverí
</title>
<ptxt>
„a”: 17 – 19 mm (0,67 – 0,74 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A950043.jpg" width = "88.000mm" height = "69.916mm" ver = "01" gw = "227" gh = "182"/>
</figure>
</item>
<item>
<ptxt>
Vložte sklo zadných dverí (3) v smere šípky “1” a otočením v smere šípky “2” posuňte spodný kanál skla (1) v smere šípky “3” a pripevnite zostavu ovládača zadného okna (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950044.jpg" width = "88.000mm" height = "97.155mm" ver = "01" gw = "227" gh = "259"/>
</figure>
</item>
<item>
<ptxt>
Dotiahnite skrutky rámu zadných dverí v poradí “1” až “3” na predpísané uťahovacie momenty.
</ptxt>
<torque>
<torqueitem id = "T9E004">
<t-part>
Skrutka okenného rámu zadných dverí*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3,0
</t-value1>
<t-value2>
0,31
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
<torqueitem id = "T9E005">
<t-part>
Skrutka okenného rámu zadných dverí*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950045.jpg" width = "88.000mm" height = "80.089mm" ver = "04" gw = "227" gh = "211"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.176in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.176in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Okenný rám zadných dverí
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Vedenie okna pri spúšťaní a vyťahovaní
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Ak je sklo poškodené, opravte alebo ho vymeňte za nové.
</ptxt>
</item>
<item>
<ptxt>
Upevnite kryt tesnenia dverí (1) pomocou butylovej pásky (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950046.jpg" width = "88.000mm" height = "80.908mm" ver = "01" gw = "185" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
