<servinfosub id = "ASLAP70A8204047003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204047004">
<testgroup id = "ASLAP70A8204047005">
<question>
Vykonala sa „Kontrola diagnostického systému airbagov“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204047006">
<title>
Kontrola obvodu podlahového káblového zväzku
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory „L290“ a „L291“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “L05”.
</ptxt>
</test1>
<test1>
<ptxt>
Uvoľnite skratovaciu tyč v konektore SDM vložením uvoľňovacieho nástroja, ktorý je vložený do špeciálneho nástroja (A).
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovné body:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor medzi každým obvodom „L05-7-5“ a „L05-8“ a uzemnením (DTC B1363): nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „L05-5-5“ a „L05-6“ a uzemnením (DTC B1367): nekonečno
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B089">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820151.swf" width = "90.000mm" height = "68.195mm" ver = "01" gw = "219" gh = "177"/>
</testfigure>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte SDM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte káblový zväzok podlahy.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Ak sa vyskytujú DTC, vymažte ich podľa 
<intxref refid = "ASLAP70A8204006">Vymazanie DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
