<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A5304A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Viaznutie spojky
</title>
<diag type = "condition">
<condition>
<ptxt>
Viaznutie spojky
</ptxt>
</condition>
<ps>
<ptxt>
Nesprávna voľná dráha spojkového pedálu
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte hlavný spojkový valec a/alebo rameno spojkového pedála.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Rameno spojkového pedála: 
<intxreftitleoff1 refid = "ASLAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hlavný valec spojky: 
<intxreftitleoff1 refid = "ASLAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Zoslabená membránová pružina alebo opotrebovaný hrot pružiny
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kryt spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zhrdzavené klinové drážky vstupného hriadeľa
</ptxt>
</ps>
<action>
<ptxt>
Namažte klinové drážky vstupného hriadeľa.
</ptxt>
</action>
<ps>
<ptxt>
Poškodené alebo opotrebované klinové drážky vstupného hriadeľa prevodovky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte vstupný hriadeľ. 
<intxreftitleoff1 refid = "ASLAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nadmerne kmitajúci kotúč spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Plochy kotúča sú poškodené alebo zamazané olejom
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Únik kvapaliny
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte systém spojky.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
