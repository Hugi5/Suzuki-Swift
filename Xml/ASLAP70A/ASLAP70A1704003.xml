<servinfosub id = "ASLAP70A1704003002">
<title>
Riešenie problémov
</title>
<diag type = "test" id = "ASLAP70A1704003003">
<testgroup id = "ASLAP70A1704003004">
<title>
Kontrola vstrekovacieho ventilu na prevádzkový hluk
</title>
<test1>
<ptxt>
Pomocou stetoskopu skontrolujte zvuk prevádzky každého z vstrekovacích ventilov počas štartovania motora.
</ptxt>
</test1>
<question>
Počuť zvuk prevádzky každého z ventilov?
</question>
<result type = "yes"/>
<action>
<ptxt>
Obvod vstrekovacích ventilov je v poriadku.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704003005">
<title>
Kontrola odporu vstrekovacieho ventilu
</title>
<test1>
<ptxt>
S vypnutým zapaľovaním odpojte konektory od vstrekovačov paliva.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektorom vstrekovača paliva.
</ptxt>
</test1>
<test1>
<ptxt>
Ak áno, skontrolujte odpor všetkých vstrekovacích ventilov. 
<intxreftitleoff1 refid = "ASLAP70A1706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Chybný vstrekovací ventil vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704003006">
<title>
Kontrola odporu izolácie vstrekovacieho ventilu
</title>
<test1>
<ptxt>
Skontrolujte, či je medzi každou z koncoviek vstrekovacích ventilov a uzemnením motora odpor.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Chybný vstrekovací ventil vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704003007">
<title>
Kontrola obvodu napájania vstrekovacieho ventilu
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi každým obvodom „A2“, „B2“, „C2“, „B2“ a „C1“ a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Opravte napájací obvod vstrekovacieho ventilu paliva.
</ptxt>
<ptxt>
Ak je v dobrom stave, pokračujte 
<intxref refid = "ASLAP70A1104071">Kontrola obvodu uzemnenia a napájania riadiacej jednotky motora</intxref>
.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704003008">
<title>
Kontrola hnacieho obvodu vstrekovacieho ventilu
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“, „B1“, „C1“ a „D1“: menej ako 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „A1“, „B1“, “C1” a “D1” a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každou svorkou obvodu „A1“ a ďalšou svorkou v konektore vstrekovania paliva: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každou svorkou obvodu „B1“ a ďalšou svorkou v konektore vstrekovania paliva: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každou svorkou obvodu „C1“ a ďalšou svorkou v konektore vstrekovania paliva: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každou svorkou obvodu „D1“ a ďalšou svorkou v konektore vstrekovania paliva: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu of “A1” – “D1”: 0 - 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte hnací obvod vstrekovacieho ventilu.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704003009">
<title>
Kontrola vstrekovacieho ventilu
</title>
<test1>
<ptxt>
Skontrolujte vstrekovací ventil paliva. 
<intxreftitleoff1 refid = "ASLAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte činnosť vstrekovacieho ventilu paliva. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Chybný vstrekovací ventil vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
