<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1306005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kalibrácia systému elektrického ovládania škrtiacej klapky
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Po vykonaní servisu popísaného v časti 
<intxref refid = "ASLAP70A1101007">Popis kalibrácie systému elektrického ovládania škrtiacej klapky</intxref>
, kalibrujte systém elektrického riadenia škrtiaceho ventilu nasledovne.
</ptxt>
</item>
<item>
<ptxt>
Pred vykonaním tohto postupu sa najskôr uistite, že sú splnené nasledovné podmienky.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
 Okolitá teplota &#62; 5 &#176;C (41 &#176;F)
</ptxt>
</item>
<item>
<ptxt>
Nezistí sa DTC.
</ptxt>
</item>
<item>
<ptxt>
Poloha plynového pedálu: voľnobeh
</ptxt>
</item>
<item>
<ptxt>
5 &#176;C (41 &#176;F) &#60; ECT &#60; 100 &#176;C (212 &#176;F)
</ptxt>
</item>
<item>
<ptxt>
Napätie akumulátora &#62; 10 V
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON“ na 60 sek.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Po dokončení tejto kalibrácie skontrolujte, či nie je DTC zistené v ECM.
</ptxt>
<ptxt>
Ak je DTC zistené, prejdite na riešenie problémov týkajúcich sa DTC.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
