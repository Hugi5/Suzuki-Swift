<section sectnbr = "1K">
<servcat sctnbr = "01" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1B06003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž výfukového potrubia a tlmiča
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1B06001">Komponenty výfukového systému</intxrefpoff>
</ptxt>
<ptxt>
Výmenu výfukového potrubia a tlmiča si pozrite v časti 
<intxref refid = "ASLAP70A1B06001">Komponenty výfukového systému</intxref>
 a v nasledujúcom odseku.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pri montáži dotiahnite skrutky a matice na požadovaný uťahovací moment. 
<intxreftitleoff1 refid = "ASLAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Spustite motor a skontrolujte unikanie výfukových plynov.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
