<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7224010" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Vymazanie DTC
</title>
<servinfosub id = "ASLAP70A7224010001">
<title>
Používanie skenovacieho zariadenia SUZUKI
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte ku konektoru pre dátové spojenie (DLC) (1), ktorý sa nachádza v spodnej časti prístrojovej dosky na strane vodiča skenovacie zariadenie SUZUKI.
</ptxt>
<servicetool>
<servicetoolitem id = "L7B209">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
Skenovacie zariadenie SUZUKI (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A723002.jpg" width = "88.000mm" height = "67.502mm" ver = "03" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Vymažte DTC podľa pokynov zobrazených na skenovacom zariadení SUZUKI.
</ptxt>
<attention3>
<ptxt>
Ak chcete vedieť, ako sa skenovacie zariadenie SUZUKI používa, pozrite si Návod na použitie skenovacieho zariadenia SUZUKI.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Po vymazaní DTC vykonajte “Kontrolu DTC” a uistite sa, že nie je zobrazené žiadne DTC (žiadny kód).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odpojte skenovacie zariadenie SUZUKI od DLC pri spínači zapaľovania v polohe „OFF“ (vyp.).
</ptxt>
</s1>
</servinfosub>
<c-change/>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
