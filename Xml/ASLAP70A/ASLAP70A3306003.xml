<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Odpojenie a pripojenie rozvodovky
</title>
<servinfosub id = "ASLAP70A3306003001">
<title>
Rozobratie
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Vypustite nasledovné oleje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Olej manuálnej prevodovky: 
<intxreftitleoff1 refid = "ASLAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Olej rozdeľovacej prevodovky: 
<intxreftitleoff1 refid = "ASLAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Odmontuje zostavu hnacieho hriadeľa na pravej strane. 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte kardanový hriadeľ. 
<intxreftitleoff1 refid = "ASLAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte predný závesný rám. 
<intxreftitleoff1 refid = "ASLAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte zadné uchytenie motora a zadnú montážnu konzolu motora. 
<intxreftitleoff1 refid = "ASLAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte výstuhu (2) a skrutky prevodovky.
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte prevodovku (1) z rozvodovky.
</ptxt>
<attention1>
<ptxt>
Pri odstraňovaní spojenia dávajte pozor, aby vám nespadol. Inak by mohlo dôjsť k poškodeniu rozvodovky a poraneniu osôb.
</ptxt>
</attention1>
<figure>
<graphic graphicname = "IAP70A330004.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "213" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte tesniaci krúžok (1) a vodiaci kolík (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330005.jpg" width = "88.000mm" height = "52.680mm" ver = "01" gw = "213" gh = "133"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASLAP70A3306003002">
<title>
Zloženie
</title>
<ptxt>
Postupujte opačným postupom ako pri demontáži a všímajte si nasledovné body.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Použite nový tesniaci krúžok a maticu hnacieho hriadeľa.
</ptxt>
</item>
<item>
<ptxt>
Na tesniaci krúžok (1) naneste mazivo.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C004" uid = "1126491901">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A330006.jpg" width = "88.000mm" height = "50.958mm" ver = "02" gw = "213" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Utiahnite skrutky na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T3C004">
<t-part>
Skrutka prevodovky
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Skrutky výstuže prevodovky dotiahnite nasledovne.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Skrutky výstuže prevodovky „2“ a „3“ dotiahnite rukou.
</ptxt>
</item>
<item>
<ptxt>
Vtlačte výstuž prevodovky do prevodovky a postupne dotiahnite skrutky výstuže prevodovky na predpísaný uťahovací moment v číselnom poradí („1“ – „5“).
</ptxt>
<torque>
<torqueitem id = "T3C005">
<t-part>
Skrutka výstuhy prevodovky*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330007.jpg" width = "88.000mm" height = "56.283mm" ver = "01" gw = "213" gh = "143"/>
</figure>
<figure>
<graphic graphicname = "IAP70A330008.jpg" width = "88.000mm" height = "55.083mm" ver = "01" gw = "202" gh = "140"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Dotiahnite nasledovné skrutky a matice na požadovaný doťahovací moment.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Zadná montážna skrutka motora a skrutka konzoly: 
<intxreftitleoff1 refid = "ASLAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Montážna skrutka rámu predného zavesenia: 
<intxreftitleoff1 refid = "ASLAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Uistite sa, že ste použili novú montážnu skrutku rámu predného zavesenia.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Matica kĺbu stabilizátora: 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skrutka guľového čapu ramena zavesenia: 
<intxreftitleoff1 refid = "ASLAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Matica hlavy spojovacej tyče: 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Svorka snímača otáčok predného kolesa: 
<intxreftitleoff1 refid = "ASLAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skrutka kĺbového hriadeľa: 
<intxreftitleoff1 refid = "ASLAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Matica stredovej podpory: 
<intxreftitleoff1 refid = "ASLAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skrutka výfukového potrubia: 
<intxreftitleoff1 refid = "ASLAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skrutka rúry výstuže výfuku č. 1: 
<intxreftitleoff1 refid = "ASLAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Matica hnacieho hriadeľa: 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Uistite sa, že ste použili novú maticu hnacieho hriadeľa.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Matica kolesa: 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Zatesnite maticu hriadeľa riadenia. 
<intxreftitleoff1 refid = "ASLAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Naplňte nasledovné oleje.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Olej manuálnej prevodovky: 
<intxreftitleoff1 refid = "ASLAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
	Olej rozdeľovacej prevodovky: 
<intxreftitleoff1 refid = "ASLAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Overte, či cez žiaden spoj neuniká olej ani výfukové plyny.
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte geometriu predných kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
