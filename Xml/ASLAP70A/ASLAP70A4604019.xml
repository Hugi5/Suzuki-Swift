<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A4604019" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1024
</title>
<servinfosub id = "ASLAP70A4604019001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.328in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.861in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1024: Výkon obvodu snímača uhla natočenia volantu
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
CPU v snímači uhla natočenia volantu detekuje internú poruchu.
</ptxt>
</item>
<item>
<ptxt>
Signál snímača uhla natočenia volantu je mimo predpísaného rozsahu.
</ptxt>
</item>
<item>
<ptxt>
Signál snímača natočenia volantu sa nezmení napriek tomu, že vozidlo zatáča doprava alebo doľava.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Snímač uhla natočenia volantu
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka ESP<sup>®</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70A4604019002">
<title>
Riešenie problémov DTC
</title>
<attention2>
<ptxt>
Detekovanie oboch DTC C1024 a C1075 znamená internú poruchu snímača uhla natočenia volantu. Vymeňte snímač uhla natočenia volantu. 
<intxreftitleoff1 refid = "ASLAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention2>
<diag type = "test" id = "ASLAP70A4604019003">
<testgroup id = "ASLAP70A4604019004">
<question>
Bola vykonaná „Kontrola systému ESP<sup>®</sup>“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A4604001">Kontrola systému ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604019005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70A4604005">Kontrola DTC</intxref>
.
</ptxt>
</test1>
<question>
Je detekovaný DTC U0073 a/alebo U0126?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným procesom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604019006">
<question>
Sú detekované oba DTC C1024 a C1075?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte snímač uhla natočenia volantu. 
<intxreftitleoff1 refid = "ASLAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A4604019007">
<title>
Kontrola snímača uhla natočenia volantu na vozidle
</title>
<test1>
<ptxt>
Skontrolujte snímač uhla natočenia volantu. 
<intxreftitleoff1 refid = "ASLAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup> a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte snímač uhla natočenia volantu. 
<intxreftitleoff1 refid = "ASLAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
