<servinfosub id = "ASLAP70A6304013004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A6304013005">
<testgroup id = "ASLAP70A6304013006">
<question>
Vykonali ste „Kontrolu systému elektrického posilňovača riadenia“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A6304001">Kontrola systému P/S</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304013007">
<title>
Kontrola obvodov motora P/S a výstupu motora P/S
</title>
<test1>
<ptxt>
Keď je zapaľovanie v polohe „OFF (VYP)“, odpojte konektor „E12“ P/S od riadiacej jednotky P/S.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenia svorky ku konektoru motora P/S „E12“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor medzi obvodmi „A1“ a „A2“: približne 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „A1“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Skontrolujte motor P/S. 
<intxreftitleoff1 refid = "ASLAP70A6306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku P/S a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Motor P/S (zostava stĺpika riadenia). 
<intxreftitleoff1 refid = "ASLAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
