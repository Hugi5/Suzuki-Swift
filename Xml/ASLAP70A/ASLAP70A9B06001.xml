<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9B06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž poistnej časti kapoty, časti podpery svetla a podpery svetla
</title>
<attention3>
<ptxt>
Nižšie uvedený obrázok zobrazuje podmienky odstraňovania nasledovných častí.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predný blatník 
<intxreftitleoff1 refid = "ASLAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "IAP70P9B0057.jpg" width = "88.000mm" height = "55.699mm" ver = "01" gw = "227" gh = "141"/>
</figure>
<servinfosub id = "ASLAP70A9B06001001">
<title>
Všeobecné poznámky
</title>
<ptxt>
Spôsob zvárania a počet bodov zvaru je ten istý na oboch stranách. Tieto pokyny na opravu zobrazujú postup pre ľavú stranu.
</ptxt>
</servinfosub>
<servinfosub id = "ASLAP70A9B06001002">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odskrutkujte 12 skrutiek.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte časť zámky kapoty a časť podpory lampy.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0003.jpg" width = "183.000mm" height = "157.046mm" ver = "02" gw = "347" gh = "429"/>
</figure>
</s1>
<s1>
<ptxt>
Odvŕtajte body zvarov a odmontujte podperu lampy.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0022.jpg" width = "183.000mm" height = "123.642mm" ver = "02" gw = "497" gh = "334"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9B06001003">
<title>
Montáž
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Pred zváraním skontrolujte polohu inštalácie a stav inštalačnej časti (častí). 
<intxreftitleoff1 refid = "ASLAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
V oprave pokračujte berúc do úvahy inštaláciu častí, ktoré majú vplyv na vzhľad. 
<intxreftitleoff1 refid = "ASLAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention2>
<s1>
<ptxt>
Namontujte podperu lampy.
</ptxt>
</s1>
<s1>
<ptxt>
Vykonajte odporové bodové zváranie alebo dierové zváranie.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0023.jpg" width = "183.000mm" height = "123.642mm" ver = "02" gw = "497" gh = "334"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte časť zámky kapoty.
</ptxt>
</s1>
<s1>
<ptxt>
Utiahnite 4 skrutky na predpísaný uťahovací moment.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0006.jpg" width = "183.000mm" height = "154.844mm" ver = "04" gw = "364" gh = "422"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.465in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
23 N&#183;m (2,3 kgf-m, 17,0 lbf-ft)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Na opravené alebo vymenené časti naneste náter alebo lak.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte natretý podporný prvok svetla.
</ptxt>
</s1>
<s1>
<ptxt>
Utiahnite 6 skrutky na predpísaný uťahovací moment.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0024.jpg" width = "183.000mm" height = "81.918mm" ver = "02" gw = "511" gh = "216"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.465in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
8,8 N&#183;m (0,90 kgf-m, 6,5 lbf-ft)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
