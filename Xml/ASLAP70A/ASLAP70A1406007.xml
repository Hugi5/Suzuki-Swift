<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1406007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Montáž a demontáž zariadenia telesa škrtiacej klapky
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1406005">Diely škrtiaceho telesa a nasávacieho potrubia</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A1406006">Kontrola telesa škrtiacej klapky vo vozidle</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Teleso škrtiacej klapky nikdy nerozoberajte. Ak objavíte chybu, vymeňte ho za nové.
</ptxt>
</attention2>
<servinfosub id = "ASLAP70A1406007001" page = "2">
<title>
Demontáž
</title>
<s1 page = "2">
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Vypustite chladiacu kvapalinu. 
<intxreftitleoff1 refid = "ASLAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Vyberte zostavu čističa vzduchu. 
<intxreftitleoff1 refid = "ASLAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odpojte hadice chladiacej kvapaliny (1) a prípojku (2) zo skrine škrtiacej klapky (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odmontujte zostavu škrtiacej klapky a konzolu vzduchového filtra (4) zo sacieho vedenia.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1406007002" page = "2">
<title>
Montáž
</title>
<s1 page = "2">
<ptxt>
Vyčistite protiľahlé povrchy a namontujte nové tesnenie skrine škrtiacej klapky (1) na sacie potrubie.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141038.swf" width = "88.000mm" height = "58.059mm" ver = "01" gw = "212" gh = "148"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Namontujte zostavu škrtiacej klapky (3) a konzolu vzduchového filtra (4) k saciemu vedeniu.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Pripojte konektor (2) a hadice chladiacej sústavy (1) na zariadenie telesa elektrickej škrtiacej klapky (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Nainštalujte zostavu vzduchového filtra. 
<intxreftitleoff1 refid = "ASLAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Pripojte kábel záporného (-) pólu k akumulátoru.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Chladiacu kvapalinu doplňte. 
<intxreftitleoff1 refid = "ASLAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte unikanie chladiacej kvapaliny. 
<intxreftitleoff1 refid = "ASLAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
