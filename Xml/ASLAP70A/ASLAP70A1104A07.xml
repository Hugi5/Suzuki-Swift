<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1104A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Prehrievanie motora
</title>
<ptxt>
Ak ECM nezistil žiaden kód DTC a pri 
<intxref refid = "ASLAP70A1104008">Vizuálna prehliadka</intxref>
 a 
<intxref refid = "ASLAP70A1104009">Základná kontrola motora</intxref>
 sa nezistila žiadna odchýlka, vykonajte riešenie problémov podľa nasledovných bodov.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Prehrievanie motora
</ptxt>
</condition>
<ps>
<ptxt>
Nefunkčný termostat
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1606009">Kontrola zariadenia termostatu (so snímačom ECT)</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabý výkon vodného čerpadla
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1606017">Kontrola vodného čerpadla</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Upchatý alebo netesný chladič
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1606014">Kontrola a čistenie chladiča vo vozidle</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neprimeraná trieda oleja
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A0206004">Výmena motorového oleja a olejového filtra</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Upchatý olejový filter alebo sito
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1504001">Kontrola tlaku oleja</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabý výkon olejového čerpadla
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1504001">Kontrola tlaku oleja</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Chybný systém riadenia ventilátora chladiča
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1604002">Kontrola systému ventilátora chladiča</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Zadierajúce sa brzdy
</ptxt>
</ps>
<action>
<ptxt>
Stav „Brzdy blokujúce kolesá“ v 
<intxref refid = "ASLAP70A4104001">Diagnostika príznakov bŕzd</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Preklzujúca spojka
</ptxt>
</ps>
<action>
<ptxt>
Stav „preklzávajúca spojka“ v 
<intxref refid = "ASLAP70A5304001">Diagnostika príznakov systému spojky</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Vyrazené tesnenie hlavy valcov
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406029">Kontrola hlavy valcov</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Zmiešaný vzduch v chladiacom systéme
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1606006">Doplnenie chladiaceho systému</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
