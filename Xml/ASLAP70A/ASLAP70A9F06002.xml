<title>
Demontáž a montáž predného a zadného reproduktora
</title>
<servinfosub id = "ASLAP70A9F06002001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte obloženie dverí.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predné: 
<intxreftitleoff1 refid = "ASLAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A9506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Odmontujte 3 skrutky a vyberte predný alebo zadný reproduktor (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor reproduktora.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A9F0005.jpg" width = "88.000mm" height = "65.800mm" ver = "01" gw = "168" gh = "170"/>
</figure>
</servinfosub>
<servinfosub id = "ASLAP70A9F06002002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
