<servinfosub id = "ASLAP70A7224024003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224024004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224024005">
<testgroup id = "ASLAP70A7224024006">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Zapnite spínač zapaľovania a skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1541?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224024008">
<title>
Kontrola poistky
</title>
<test1>
<ptxt>
Skontrolujte poistku &#34;MTR&#34;.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte poistku „MTR“ a skontrolujte, či je obvod uzemnený.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224024007">
<title>
Kontrola okruhu dodávky napätia akumulátora
</title>
<test1>
<ptxt>
Odpojte konektor “G20”.
</ptxt>
</test1>
<test1>
<ptxt>
Odmerajte napätie medzi svorkou vodiča „WHT/RED“ konektora „G20“ a uzemnením.
</ptxt>
</test1>
<question>
Má napätie hodnotu 10 -14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku HVAC a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
</testgroup>
</diag>
