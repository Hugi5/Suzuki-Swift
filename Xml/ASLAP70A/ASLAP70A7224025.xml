<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7224025" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1544
</title>
<servinfosub id = "ASLAP70A7224025001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.118in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.087in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1544: Neplatné údaje medzi riadiacou jednotkou HVAC a panelom automatickej klimatizácie
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka HVAC vysiela neplatný signál do panela automatickej klimatizácie.
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka HVAC prijíma neplatný signál z panela automatickej klimatizácie.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Panel automatickej klimatizácie
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka HVAC
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70A7224025002">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224025003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224025004">
<testgroup id = "ASLAP70A7224025005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Zapnite spínač zapaľovania a skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1544?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Nahraďte známu riadiacu jednotku HVAC a/alebo panel automatickej klimatizácie a opätovne skontrolujte DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Riadiaca jednotka HVAC: 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Panel automatickej klimatizácie: 
<intxreftitleoff1 refid = "ASLAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
