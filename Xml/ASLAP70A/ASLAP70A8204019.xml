<servinfosub id = "ASLAP70A8204019003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204019004">
<testgroup id = "ASLAP70A8204019005">
<question>
Vykonala sa „Kontrola diagnostického systému airbagov“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204019006">
<title>
Kontrola jednotky (inflátor) airbagu vodiča
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory „G347“ a „G374“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte „STEERING WHEEL“ (1) špeciálnych nástrojov (A) a (B) ku konektoru „G347“ alebo „G374“.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B011">
<s-part>
(A)
</s-part>
<s-number num = "09932-77320">
09932–77320
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B012">
<s-part>
(B)
</s-part>
<s-number num = "09932-75010">
09932–75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820006.swf" width = "90.000mm" height = "63.681mm" ver = "03" gw = "208" gh = "164"/>
</testfigure>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa DTC B1032?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204019007">
<title>
Kontrola obvodu káblového zväzku prístrojového panela
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “G11”.
</ptxt>
</test1>
<test1>
<ptxt>
Uvoľnite skratovaciu tyč v konektore SDM vložením uvoľňovacieho nástroja, ktorý je vložený do špeciálneho nástroja (A).
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovný bod.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor medzi svorkami &#34;G11-5&#34; a &#34;G11-6&#34;: nekonečno
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B013">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820057.swf" width = "90.000mm" height = "55.937mm" ver = "01" gw = "200" gh = "142"/>
</testfigure>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte SDM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204019008">
<title>
Kontrola obvodu kontaktného vinutia
</title>
<test1>
<ptxt>
Skontrolujte obvod kontaktného vinutia. 
<intxreftitleoff1 refid = "ASLAP70A8204053"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je obvod kontaktného vinutia v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Nahraďte jednotku (inflátor) airbagu vodiča. 
<intxreftitleoff1 refid = "ASLAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte kontaktné vinutie. 
<intxreftitleoff1 refid = "ASLAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Ak sa vyskytujú DTC, vymažte ich podľa 
<intxref refid = "ASLAP70A8204006">Vymazanie DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
</servinfo>
</servinfotype>
</configtype>
</servcat>
