</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1082: Neplatné kom. údaje snímača bočného nárazu vodiča (strana vodiča)
</emph>
</ptxt>
<ptxt>
Snímač čelného nárazu vodiča komunikuje s neplatnými údajmi.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1085: Nekonzistentné kom. údaje snímača bočného nárazu vodiča (strana vodiča)
</emph>
</ptxt>
<ptxt>
Strana čelného nárazu snímača komunikovala s nekonzistentným kódom ID.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1091: Žiadna odozva snímača bočného nárazu vodiča (strana spolujazdca)
</emph>
</ptxt>
<ptxt>
Snímač čelného nárazu spolujazdca komunikuje bez odozvy.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1092: Neplatné kom. údaje snímača bočného nárazu spolujazdca (strana spolujazdca)
</emph>
</ptxt>
<ptxt>
Snímač čelného nárazu spolujazdca komunikuje s neplatnými údajmi.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1095: Nekonzistentné kom. údaje snímača bočného nárazu spolujazdca (strana spolujazdca)
</emph>
</ptxt>
<ptxt>
Strana snímača predného nárazu spolujazdca komunikovala s nekonzistentným kódom ID.
</ptxt>
</entry>
</row>
