<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zadného stierača
</title>
<servinfosub id = "ASLAP70A9406005001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte kryt ramena zadného stierača (1), maticu ramena zadného stierača (2), rameno zadného stierača so stieracou lištou (3), kryt čapu stierača (4), maticu zadného stierača (5) a tesnenie zadného stierača (6).
</ptxt>
<figure>
<graphic graphicname = "I9P60A940013.swf" width = "88.000mm" height = "45.733mm" ver = "01" gw = "174" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Odstráňte obloženie zadných koncových dverí. 
<intxreftitleoff1 refid = "ASLAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte motor zadného stierača.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor (1) z motorčeka zadného stierača pomocou skrutkovača s plochým koncom (2) podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I7V10A940003.swf" width = "88.000mm" height = "79.003mm" ver = "01" gw = "161" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9406005002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9406006">Kontrola motora zadného stierača</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dotiahnite skrutky motora zadného stierača na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T9D004">
<t-part>
Skrutka motora zadného stierača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I5RW0A940011.swf" width = "88.000mm" height = "56.315mm" ver = "01" gw = "172" gh = "143"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.373in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Motorček zadného stierača
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Namontujte tesnenie zadného stierača (1) a dotiahnite maticu zadného stierača na špecifikovaný moment.
</ptxt>
<torque>
<torqueitem id = "T9D005">
<t-part>
Matica zadného stierača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,3
</t-value1>
<t-value2>
0,54
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940014.swf" width = "88.000mm" height = "34.877mm" ver = "02" gw = "116" gh = "82"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.538in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Kryt čapu zadného stierača
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Namontujte ramená stierača zadného čelného skla so stieracími lištami (1) do špecifikovanej pozície podľa obrázku, a potom dotiahnite matice stierača zadného čelného skla na špecifikovaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T9D006">
<t-part>
Matica ramena zadného stierača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940018.swf" width = "88.000mm" height = "52.564mm" ver = "01" gw = "208" gh = "132"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
