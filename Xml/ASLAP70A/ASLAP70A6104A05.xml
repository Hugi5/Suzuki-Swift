<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A6104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vybočovanie alebo zlá stabilita riadenia
</title>
<diag type = "condition">
<condition>
<ptxt>
Vybočovanie alebo zlá stabilita riadenia
</ptxt>
</condition>
<ps>
<ptxt>
Rozdielne pneumatiky alebo nerovnomerný tlak v pneumatikách
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte alebo nastavte tlak v pneumatikách. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnený guľový čap ramena zavesenia a koniec spojovacej tyče
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vymeňte rameno nápravy alebo koniec spojovacej tyče.
</ptxt>
<ptxt>
Rameno zavesenia kolesa: 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hlava riadiacej tyče: 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porucha zostavy alebo montáže prednej vzpery
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu prednej vzpery alebo opravte upevnenie. 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnený stabilizátor
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite alebo vymeňte stabilizátor alebo puzdrá. 
<intxreftitleoff1 refid = "ASLAP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prasknutá alebo prehnutá vinutá pružina
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte vinutú pružinu. 
<intxreftitleoff1 refid = "ASLAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Chybná zostava prednej vzpery (tlmič odpruženia)
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu prednej vzpery (tlmič odpruženia). 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nesprávny kontakt zubov medzi ozubenou tyčou a pastorkom
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Skontrolujte krútiaci moment otáčania ozubenej tyče a pastorka. 
<intxreftitleoff1 refid = "ASLAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ak je poruchový, vymeňte zariadenie prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porušená geometria predných kolies
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a nastavte geometriu predných kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodená zostava skrine prevodovky riadenia
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu skrine prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
