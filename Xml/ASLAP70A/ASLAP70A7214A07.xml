<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7214A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Chladný vzduch neprúdi alebo chladenie nie je dostatočné (pri bežnej prevádzke magnetickej spojky)
</title>
<diag type = "condition">
<condition>
<ptxt>
Chladný vzduch neprúdi alebo chladenie nie je dostatočné (pri bežnej prevádzke magnetickej spojky)
</ptxt>
</condition>
<ps>
<ptxt>
Primálo alebo priveľa chladiacej kvapaliny
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte, či je v systéme správne množstvo chladiacej kvapaliny a či kvapalina zo systému neuniká.
</ptxt>
</action>
<ps>
<ptxt>
Upchatý kondenzátor
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte kondenzátor. 
<intxreftitleoff1 refid = "ASLAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Upchatý alebo zamrznutý výparník klimatizácie
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte výparník klimatizácie a snímač teploty výparníka klimatizácie.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Výparník klimatizácie: 
<intxreftitleoff1 refid = "ASLAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Snímač teploty výparníka: 
<intxreftitleoff1 refid = "ASLAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Porucha snímača teploty výparníka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte snímač teploty výparníka. 
<intxreftitleoff1 refid = "ASLAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha expanzného ventilu
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte expanzný ventil. 
<intxreftitleoff1 refid = "ASLAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnený alebo pretrhnutý hnací remeň kompresora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte hnací remeň kompresora. 
<intxreftitleoff1 refid = "ASLAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Preklzujúca magnetická spojka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte magnetickú spojku. 
<intxreftitleoff1 refid = "ASLAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kompresora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte kompresor.
</ptxt>
</action>
<ps>
<ptxt>
Vzduch v klimatizačnom systéme
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kondenzátor a potom chladiacu kvapalinu vypustite a znova naplňte. 
<intxreftitleoff1 refid = "ASLAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Unikanie vzduchu z jednotky HVAC alebo vzduchového potrubia
</ptxt>
</ps>
<action>
<ptxt>
Opravte jednotku HVAC alebo vzduchové potrubie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha ohrievača a ventilačného systému
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte jednotku HVAC.
</ptxt>
</action>
<ps>
<ptxt>
Porucha motora ventilátora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte elektromotor ventilátora. 
<intxreftitleoff1 refid = "ASLAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nadbytok oleja kompresora v klimatizačnom systéme
</ptxt>
</ps>
<action>
<ptxt>
Vypustite nadbytočný olej kompresora z okruhu a kompresora klimatizačného systému.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
