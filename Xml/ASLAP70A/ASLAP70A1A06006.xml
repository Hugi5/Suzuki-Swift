<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1A06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž konzoly alternátora
</title>
<servinfosub id = "ASLAP70A1A06006001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte pravý spodný kryt motora.
</ptxt>
</s1>
<s1>
<ptxt>
Zložte hnací remeň vodného čerpadla/alternátora. 
<intxreftitleoff1 refid = "ASLAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte remenicu vodného čerpadla (1). 
<intxreftitleoff1 refid = "ASLAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutku alternátora (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte konzolu alternátora (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1007.jpg" width = "88.000mm" height = "70.982mm" ver = "01" gw = "192" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1A06006002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Konzolu altenátora namontujte pomocou nasledovného postupu.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Poloha konzola alternátora (1).
</ptxt>
</item>
<item>
<ptxt>
Mierne dotiahnite skrutku alternátora (2).
</ptxt>
</item>
<item>
<ptxt>
Dotiahnite matice (3) konzoly alternátora na predpísaný uťahovací moment. 
<intxreftitleoff1 refid = "ASLAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
<figure>
<graphic graphicname = "I9P60A1A1016.swf" width = "88.000mm" height = "68.664mm" ver = "01" gw = "188" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
