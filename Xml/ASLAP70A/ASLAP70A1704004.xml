<servinfosub id = "ASLAP70A1704004002">
<title>
Riešenie problémov
</title>
<diag type = "test" id = "ASLAP70A1704004003">
<testgroup id = "ASLAP70A1704004004">
<title>
Kontrola riadiaceho systému čerpadla paliva na prevádzku
</title>
<test1>
<ptxt>
Odmontujte veko plniaceho hrdlo palivovej nádrže.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Potvrďte, že z portu plnenia paliva počujete zvuk prevádzky palivového čerpadla asi 2 sek. a potom sa zastaví.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Obvod palivového čerpadla je v poriadku. Opätovne nainštalujte veko plniaceho hrdlo palivovej nádrže.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704004005">
<title>
Kontrola napájania obvodu relé palivového čerpadla
</title>
<test1>
<ptxt>
Opätovne nainštalujte veko plniaceho hrdlo palivovej nádrže.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Vyberte relé palivového čerpadla zo samostatnej poistkovej skrinky obvodu č. 1 .
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektoru relé palivového čerpadla.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi každým obvodom „A1“ a „A2“ a uzemnením je akumulátorové napätie. 
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte napájací obvod relé palivového čerpadla.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704004006">
<title>
Kontrola relé palivového čerpadla
</title>
<test1>
<ptxt>
Skontrolujte relé palivového čerpadla. 
<intxreftitleoff1 refid = "ASLAP70AA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte relé palivového čerpadla.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704004007">
<title>
Skontrolujte hnací obvod relé palivového čerpadla
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory „C01“ a „E01“ od ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „B1“: menej ako 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „B1“: 0 - 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte hnací obvod relé palivového čerpadla.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704004008">
<title>
Skontrolujte signál hnacieho obvodu relé palivového čerpadla
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte konektory „C01“ a „E01“ k ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Pomocou servisného vodiča pripojte relé palivového čerpadla.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, či je napätie medzi obvodom „B1“ a uzemnením 0 - 1 V na pribl. 2 sek. po zapnutí zapaľovania.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte činnosť palivového čerpadla. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704004009">
<title>
Kontrola napájacieho obvodu palivového čerpadla
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte palivovú nádrž.
</ptxt>
</test1>
<test1>
<ptxt>
Z palivového čerpadla odpojte konektor.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že odpor medzi „B2“ a uzemnením je nekonečno.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte napájací obvod palivového čerpadla.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704004010">
<title>
Kontrola napájacieho obvodu palivového čerpadla
</title>
<test1>
<ptxt>
Pripojte servisný vodič medzi „B1“ a uzemnenie.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi „B2“ a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte napájací obvod palivového čerpadla.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704004011">
<title>
Kontrola uzemňovacieho obvodu palivového čerpadla
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, či je odpor medzi obvodom „B3“ a uzemnením menší ako 1 Ω.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte palivové čerpadlo. 
<intxreftitleoff1 refid = "ASLAP70A1706015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte uzemňovací obvod palivového čerpadla.
</ptxt>
</action>
</testgroup>
</diag>
