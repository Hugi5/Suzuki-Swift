<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kmitanie, trasenie alebo vibrácia
</title>
<diag type = "condition">
<condition>
<ptxt>
Kmitanie, trasenie alebo vibrácia
</ptxt>
</condition>
<ps>
<ptxt>
Nevyvážené koleso
</ptxt>
</ps>
<action>
<ptxt>
Vyvážte koleso (kolesá) alebo vymeňte pneumatiku a/alebo koleso (kolesá).
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené ložiská kolies
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte ložiská kolies. 
<intxreftitleoff1 refid = "ASLAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaná hlava spojovacej tyče
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte hlavu spojovacej tyče riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované kĺby ramena nápravy
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte rameno nápravy. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nadmerné hádzanie pneumatík alebo kolies
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte koleso alebo pneumatiku.
</ptxt>
</action>
<ps>
<ptxt>
Pneumatika s hrboľom alebo preliačeninou
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte pneumatiku. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neúmerne veľké radiálne hádzanie sústavy kolesa/pneumatiky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte pneumatiku alebo koleso.
</ptxt>
</action>
<ps>
<ptxt>
Narušená geometria kolies
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a nastavte geometriu kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené alebo opotrebované tyče riadenia
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte systém riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnené skrutky skrine prevodovky riadenia
</ptxt>
</ps>
<action>
<ptxt>
Utiahnite skrutky skrine prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
