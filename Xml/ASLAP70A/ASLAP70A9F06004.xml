<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9F06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž antény rádia
</title>
<servinfosub id = "ASLAP70A9F06004001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte obklad nad dverami. 
<intxreftitleoff1 refid = "ASLAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor antény rádia (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte skrutku konektora antény rádia (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte základňu antény rádia (3) a tyč antény rádia (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0007.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9F06004002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utiahnite skrutky antény na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T9O001">
<t-part>
Skrutka antény
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,0
</t-value1>
<t-value2>
0,7
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A9F0008.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
