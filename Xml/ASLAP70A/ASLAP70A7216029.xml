<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216029" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž stredovej vetracej mriežky
</title>
<servinfosub id = "ASLAP70A7216029001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Z prístrojovej dosky vyberte stredovú vetraciu mriežku. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor spínača výstražnej kontrolky.
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite trubice (2) a potom vyberte stredovú vetraciu mriežku (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A721028.swf" width = "88.000mm" height = "58.762mm" ver = "02" gw = "215" gh = "150"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7216029002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
