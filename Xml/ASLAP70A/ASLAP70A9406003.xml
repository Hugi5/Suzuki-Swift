<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9406003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž motora stierača čelného skla
</title>
<servinfosub id = "ASLAP70A9406003001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte viečka čapov stierača (1) a matice ramena stierača (2) a odmontujte ramená stieračov predného čelného skla (3).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte ozdobný kryt vetracej komory (4). 
<intxreftitleoff1 refid = "ASLAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I9P60A940005.jpg" width = "88.000mm" height = "62.898mm" ver = "01" gw = "198" gh = "162"/>
</figure>
</s1>
<s1>
<ptxt>
Odpojte konektor motora stierača čelného skla (3).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky motora stierača (1) a odmontujte motor stierača (2) čelného skla v smere šípky podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A940006.jpg" width = "88.000mm" height = "41.842mm" ver = "01" gw = "217" gh = "102"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9406003002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9406004">Kontrola činnosti motorčeka stierača čelného skla</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Skrutky motora stierača dotiahnite v číselnom poradí („1“ až „2“) na špecifikovaný točivý moment.
</ptxt>
<torque>
<torqueitem id = "T9D002">
<t-part>
Skrutka motora stierača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A940007.jpg" width = "88.000mm" height = "41.842mm" ver = "02" gw = "217" gh = "102"/>
</figure>
<list1 type = "unordered">
<item>
<ptxt>
Namontujte ramená stierača čelného skla (1) do polohy na obrázku.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ľavá strana [A]
</ptxt>
<ptxt>
Vyrovnajte koniec lopatky stierača čelného skla (5) so značkou (4).
</ptxt>
</item>
<item>
<ptxt>
Ľavá strana [B]
</ptxt>
<ptxt>
Vyrovnajte lopatku s keramickým vedením (3).
</ptxt>
</item>
</list2>
<item>
<ptxt>
Utiahnite matice ramena stierača na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T9D003">
<t-part>
Matica ramena stierača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1,6
</t-value2>
<t-value3>
12,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940009.swf" width = "88.000mm" height = "77.752mm" ver = "02" gw = "189" gh = "204"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
