<section sectnbr = "4D">
<servcat sctnbr = "04" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž páky parkovacej brzdy
</title>
<attention1>
<ptxt>
Pred demontážou parkovacej brzdy sa uistite, že sú splnené nasledovné podmienky.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pracujte na rovnom mieste.
</ptxt>
</item>
<item>
<ptxt>
Zaraďte páku do „1.“ rýchlosti.
</ptxt>
</item>
<item>
<ptxt>
Zablokujte kolesá.
</ptxt>
</item>
</list1>
</attention1>
<servinfosub id = "ASLAP70A4406005001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Zložte zadnú skriňu konzoly podlahy. 
<intxreftitleoff1 refid = "ASLAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor spínača parkovacej brzdy od páky parkovacej brzdy.
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite nastavovaciu maticu (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A440004.swf" width = "88.000mm" height = "66.682mm" ver = "01" gw = "189" gh = "173"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte skrutky páky parkovacej brzdy (1) a potom odmontujte montážnu zostavu páky parkovacej brzdy (2) s vyrovnávačom (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A440005.swf" width = "88.000mm" height = "80.810mm" ver = "01" gw = "168" gh = "213"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A4406005002">
<title>
Montáž
</title>
<s1>
<ptxt>
Skrutky páky parkovacej brzdy (1) dotiahnite určeným doťahovacím momentom.
</ptxt>
<torque>
<torqueitem id = "T4D001">
<t-part>
Skrutka páky parkovacej brzdy
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
26
</t-value1>
<t-value2>
2,7
</t-value2>
<t-value3>
19,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A440006.swf" width = "88.000mm" height = "77.351mm" ver = "01" gw = "174" gh = "203"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte lanko parkovacej brzdy k vyrovnávaču, a potom ho nastavte. 
<intxreftitleoff1 refid = "ASLAP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uistite sa, že brzdný systém funguje správne.
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte konektor spínača parkovacej brzdy k páke parkovacej brzdy.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte zadnú skriňu konzoly podlahy. 
<intxreftitleoff1 refid = "ASLAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
