<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Preklzávanie
</title>
<diag type = "condition">
<condition>
<ptxt>
Preklzávanie
</ptxt>
</condition>
<ps>
<ptxt>
Nesprávna voľná dráha spojkového pedálu
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte hlavný spojkový valec a/alebo rameno spojkového pedála.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Rameno spojkového pedála: 
<intxreftitleoff1 refid = "ASLAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hlavný valec spojky: 
<intxreftitleoff1 refid = "ASLAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Opotrebované alebo olejové plochy kotúča spojky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pokrivený kotúč, prítlačný kotúč alebo povrch zotrvačníka
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vymeňte kotúč, kryt spojky alebo zotrvačník.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Kotúč a kryt spojky: 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zotrvačník: 
<intxreftitleoff1 refid = "ASLAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Zoslabená membránová pružina
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kryt spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Piest alebo tesnenie hlavného valca sa nevracia
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte hlavný valec spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
