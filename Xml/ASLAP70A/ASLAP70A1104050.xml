<servinfosub id = "ASLAP70A1104050003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 8,5 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Motor nechajte 10 sek. bežať na voľnobežných otáčkach.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte spínač A/C do polohy ON (ZAP) na 10 sek.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte spínač A/C do polohy OFF (VYP).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104050004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104050005">
<testgroup id = "ASLAP70A1104050006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104050007">
<title>
Kontrola obvodu napájania relé kompresora klimatizácie (strana cievky)
</title>
<test1>
<ptxt>
Relé kompresora klimatizácie vyberte so spínačom zapaľovania v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektoru relé kompresora klimatizácie.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi „A1“ a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104050008">
<title>
Kontrola relé kompresora klimatizácie
</title>
<test1>
<ptxt>
Skontrolujte relé kompresora klimatizácie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s manuálnou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatickou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7226042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Relé kompresora klimatizácie vymeňte.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104050009">
<title>
Kontrola hnacieho obvodu relé kompresora klimatizácie
</title>
<test1>
<ptxt>
Ak je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ z ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie ku konektorom „C01“ a „E01“.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „B1“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B1“ a ďalšou svorkou konektora relé kompresora klimatizácie: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „B1“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
</diag>
