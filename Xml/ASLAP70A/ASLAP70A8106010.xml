<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A8106010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia bezpečnostného pásu na strednom zadnom sedadle
</title>
<servinfosub id = "ASLAP70A8106010001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte obloženie zadného sedadla. 
<intxreftitleoff1 refid = "ASLAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutku a maticu a potom odmontujte zostavu bezpečnostného pásu na zadnom sedadle. 
<intxreftitleoff1 refid = "ASLAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A8106010002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A8106003">Kontrola zostavy predného bezpečnostného pásu</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte, či kolíky (3) na ráme sedadla sú vložené v dlhých otvoroch (2) na navíjači (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A810016.swf" width = "88.000mm" height = "77.820mm" ver = "02" gw = "236" gh = "204"/>
</figure>
</item>
<item>
<ptxt>
Dotiahnite skrutky zadného stredného sedadla na predpísaný uťahovací moment. 
<intxreftitleoff1 refid = "ASLAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nestúpajte na plášť vozidla (2) pri inštalácii kotviacej platne (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A810017.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
