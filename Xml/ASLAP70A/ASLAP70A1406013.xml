<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1406013" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž vačkového hriadeľa a zdvíhadla ventilu
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1406012">Diely vačkového hriadeľa, zdvíhača ventila a vyrovnávacej podložky</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1406013001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odstráňte pravý spodný kryt motora.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte hnací remeň kompresora.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s manuálnou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatickou klimatizáciou: 
<intxreftitleoff1 refid = "ASLAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Zložte hnací remeň vodného čerpadla/alternátora. 
<intxreftitleoff1 refid = "ASLAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte kryt hlavy valca. 
<intxreftitleoff1 refid = "ASLAP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Kľukový hriadeľ otočte v smere hodinových ručičiek a nastavte č. 1 na TDC nasledovne.
</ptxt>
<s2>
<ptxt>
Zarovnajte značky ovládača nasáv. VVT a výfuk. VVT (1) s povrchom hlavy valca (2) individuálne.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141006.swf" width = "88.000mm" height = "46.550mm" ver = "01" gw = "219" gh = "115"/>
</figure>
</s2>
<s2>
<ptxt>
Vyrovnajte zárez (1) na remenici kľukového hriadeľa s označením „0“ (2) na kryte rozvodovej reťaze.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141007.swf" width = "88.000mm" height = "45.815mm" ver = "01" gw = "164" gh = "113"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Aplikujte trochu farby na dve linky rozvodovej reťaze (2), ktoré majú značky (1) na ovládači nasáv. VVT a výfuk. VVT.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141030.jpg" width = "88.000mm" height = "55.707mm" ver = "01" gw = "209" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Demontujte skrutku remenice kľukového hriadeľa.
</ptxt>
<ptxt>
Špeciálnym nástrojom podľa obrázku zabezpečte remenicu kľukového hriadeľa (1).
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Pri používaní špeciálneho nástroja sa vyhnite nepotrebnej záťaži na rozvodovú reťaz, reťazové kolesá a ostatné príslušné časti.
</ptxt>
</item>
<item>
<ptxt>
Použite nižšie uvedené skrutky na montáž špeciálneho nástroja k remenici kľukového hriadeľa.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Upevňovacia skrutka špeciálneho nástroja
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.729in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.729in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Veľkosť skrutky
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
M8
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Odstup
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
1,25 mm (0,05 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Dĺžka &#34;a&#34;
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
25 mm (0,98 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Sila
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
7T
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</attention2>
<attention3>
<ptxt>
Ak je to potrebné, použite na vybratie týchto kolíkov špeciálny nástroj.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1D006">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917–68221
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141049.swf" width = "88.000mm" height = "49.174mm" ver = "01" gw = "163" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte remenicu kľukového hriadeľa (1).
</ptxt>
<ptxt>
Vyberá sa ťažko, preto použite špeciálny nástroj podľa obrázku.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D007">
<s-part>
(A)
</s-part>
<s-number num = "09926-37610-001">
09926–37610–001
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L1D008">
<s-part>
(B)
</s-part>
<s-number num = "09926-58010">
09926–58010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A141067.swf" width = "88.000mm" height = "59.461mm" ver = "01" gw = "168" gh = "152"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte kryt rozvodovej reťaze (1) a tesnenie (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141031.jpg" width = "88.000mm" height = "73.310mm" ver = "01" gw = "199" gh = "191"/>
</figure>
</s1>
<s1>
<ptxt>
Vyberte napínač rozvodovej reťaze (1) nasledovne.
</ptxt>
<s2>
<ptxt>
Namontujte upevňovaciu skrutku napínača rozvodovej reťaze (2) k napínaču rozvodovej reťaze (1).
</ptxt>
<attention3>
<ptxt>
Použite nižšie uvedenú skrutku na upevnenie napínača rozvodovej reťaze.
</ptxt>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Skrutka nastavenia napínača rozvodovej reťaze
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.728in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.728in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Veľkosť skrutky
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
M3
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Odstup
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
0,5 mm (0,02 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Dĺžka &#34;a&#34;
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
30 mm (1,18 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</attention3>
</s2>
<s2>
<ptxt>
Dotiahnite upevňovaciu skrutku napínača rozvodnej reťaze, až kým sa jej koniec nedotkne napínača rozvodnej reťaze.
</ptxt>
</s2>
<s2>
<ptxt>
Od tohto bodu dotiahnite upevňovaciu skrutku napínača rozvodnej reťaze o 45&#176;.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141032.swf" width = "88.000mm" height = "54.598mm" ver = "01" gw = "199" gh = "138"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.866in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
„a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
45&#176;
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
Odmontujte napínač rozvodovej reťaze.
</ptxt>
<attention3>
<ptxt>
Jemným otáčaním vačkového hriadeľa v opačnom smere uvoľníte a odstránite napínač rozvodovej reťaze.
</ptxt>
</attention3>
</s2>
</s1>
<s1>
<ptxt>
Uvoľnite montážne skrutky vačkového hriadeľa v číselnom poradí („1“ – „21“).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141033.jpg" width = "88.000mm" height = "49.599mm" ver = "01" gw = "212" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Uvoľnite rozvodovú reťaz (1) z ovládača nasáv. VVT (2) a ovládača výfuk. VVT (3).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte sací (4) a potom výfukový vačkový hriadeľ (5).
</ptxt>
<attention3>
<ptxt>
Keďže sa tam nachádza ochrana proti vysunutiu rozvodovej reťaze z rozvodového kolesa, rozvodová reťaz sa nebude dať odopnúť z rozvodového kolesa, ani po vybratí vačkového hriadeľa.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A141034.swf" width = "88.000mm" height = "61.749mm" ver = "01" gw = "216" gh = "159"/>
</figure>
</s1>
<s1>
<ptxt>
Ak je to potrebné, vyberte ložiská a zdvíhadlá vačkového hriadeľa.
</ptxt>
</s1>
<s1>
<ptxt>
Z vačkového hriadeľa vyberte ovládač VV a to nasledovne.
</ptxt>
<s2>
<ptxt>
Šesťuholníkový prierez vačkového hriadeľa držte pomocou zveráka.
</ptxt>
</s2>
<s2>
<ptxt>
Vyberte skrutku ovládača VVT a vyberte ovládač VVT (1).
</ptxt>
<attention2>
<ptxt>
VVT ovládač nerozoberajte.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I9P60A141035.swf" width = "88.000mm" height = "63.076mm" ver = "01" gw = "197" gh = "162"/>
</figure>
</s2>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1406013002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1406014">Kontrola vačkového hriadeľa a zdvíhadla ventilu</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Ak ste ho odstránili, namontujte na vačkový hriadeľ ovládač VVT (1) nasledovne.
</ptxt>
<s2>
<ptxt>
Šesťuholníkový prierez vačkového hriadeľa držte pomocou zveráka.
</ptxt>
</s2>
<s2>
<ptxt>
Namontujte ovládač VVT a dotiahnite skrutku ovládača VVT na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1D003">
<t-part>
Skrutka ovládača VVT
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6,1
</t-value2>
<t-value3>
44,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141076.swf" width = "88.000mm" height = "63.076mm" ver = "01" gw = "197" gh = "162"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Na kontaktný povrch zdvíhadiel (šedá časť) naneste motorový olej a potom zdvíhadlá (1) namontujte na hlavu valca.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141016.swf" width = "88.000mm" height = "43.309mm" ver = "01" gw = "218" gh = "106"/>
</figure>
</s1>
<s1>
<ptxt>
Nasaďte ložisko vačkového hriadeľa nasledovne:
</ptxt>
<s2>
<ptxt>
Pripevnite jazýček (1) ložiska vačkového hriadeľa do drážky (2) hlavy valca krytu vačkového hriadeľa.
</ptxt>
</s2>
<s2>
<ptxt>
Stlačte koniec ložiska vačkového hriadeľa (3), až kým sa ložisko pevne neusadí v hlave vlaca alebo v kryte vačkového hriadeľa.
</ptxt>
</s2>
<s2>
<ptxt>
Na klznú plochu (4) ložiska vačkového hriadeľa naneste motorový olej.
</ptxt>
<attention2>
<ptxt>
Motorový olej neaplikujte na povrch (5) medzi ložiskom a krytom vačkového hriadeľa alebo hlavy valca.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I8T401142036.swf" width = "88.000mm" height = "38.847mm" ver = "01" gw = "130" gh = "94"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Na klzné plochy vačkového hriadeľa naneste motorový olej.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte vačkový hriadeľ výfuku a potom vačkový hriadľ nasávania k hlave vlaca.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte rozvodovú reťaz k ovládaču nasáv. a výfuk. VVT. Na ovládačoch vyrovnajte namaľované riadky (2) so značkami (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141030.jpg" width = "88.000mm" height = "55.707mm" ver = "01" gw = "209" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Kryty vačkového hriadeľa (1) namontujte na predpísané miesta indikované znakom (2), číslom (3) a šípkou (4) pre každý kryt vačkového hriadeľa.
</ptxt>
<figure>
<graphic graphicname = "I8T401142038.swf" width = "88.000mm" height = "35.927mm" ver = "01" gw = "66" gh = "85"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.076in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
I: Pre vačkový hroadeľ nasávania
</ptxt>
<ptxt>
E: Pre vačkový hriadeľ výfuku
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Poloha zo strany rozvodovej reťaze
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Smerom k strane rozvodovej reťaze
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Utiahnite skrutky skrine vačkového hriadeľa nasledovne:
</ptxt>
<s2>
<ptxt>
Namontujte kryt vačkového hriadeľa č. 1 (1).
</ptxt>
</s2>
<s2>
<ptxt>
Namontujte skrutky krytu vačkového hriadeľa a dotiahnite ich rukou.
</ptxt>
</s2>
<s2>
<ptxt>
Dotiahnite montážne skrutky vačkového hriadeľa v číselnom poradí („1“ – „21“).
</ptxt>
<torque>
<torqueitem id = "T1D004">
<t-part>
Skrutka krytu vačkového hriadeľa*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141037.jpg" width = "88.000mm" height = "50.275mm" ver = "02" gw = "223" gh = "126"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Odmontujte upevňovaciu skrutku napínača rozvodovej reťaze z napínača rozvodovej reťaze.
</ptxt>
</s1>
<s1>
<ptxt>
Rozperu (2) nastavovača napínača rozvodovej reťaze (1) priskrutkujte v smere hodinových ručičiek a namontujte držiak (3) (priemer vodiča 1,4 mm (0,055 in.) alebo podobne) na podržanie rozpery na mieste.
</ptxt>
<figure>
<graphic graphicname = "I8T401142078.swf" width = "88.000mm" height = "36.941mm" ver = "01" gw = "103" gh = "88"/>
</figure>
</s1>
<s1>
<ptxt>
Nasledovne namontujte montážnu zostavu nastavovača napínača rozvodovej reťaze:
</ptxt>
<s2>
<ptxt>
Otočte vačkový hriadeľ nasávania opačným smerom, až kým sa rozvodová reťaz nenapne.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Dávajte pozor, aby ste neboli namaľované linky rozvodovej reťaze a značky na ovládačoch nasáv. a výfuk. VVT nevyrovnané.
</ptxt>
</item>
<item>
<ptxt>
Nadmerné otáčanie vačkového hriadeľa nasávania dostane valec a piest do konaktu. Dávajte pozor, aby ste vačkový hriadeľ nasávania neotáčali nadmerne.
</ptxt>
</item>
</list1>
</attention2>
</s2>
<s2>
<ptxt>
Namontujte teleso nastavenia napínača rozvodovej reťaze (1) a poistný krúžok.
</ptxt>
</s2>
<s2>
<ptxt>
Skrutky nastavenia rozvodovej reťaze utiahnite na predpísaný uťahovací moment a potom z telesa nastavenia reťaze vyberte držiak (2).
</ptxt>
<torque>
<torqueitem id = "T1D005">
<t-part>
Skrutka nastavenia napínača rozvodovej reťaze
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141038.swf" width = "88.000mm" height = "54.598mm" ver = "01" gw = "199" gh = "138"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Nainštalujte kryciu zátku rozvodovej reťaze (1) s novým tesnením a potom utiahnite nové skrutky rozvodovej reťaze (2) na špecifikovaný krútiaci moment.
</ptxt>
<torque>
<torqueitem id = "T1D006">
<t-part>
Skrutka krytu rozvodovej reťaze
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141039.jpg" width = "88.000mm" height = "73.310mm" ver = "01" gw = "199" gh = "191"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte remenicu kľukového hriadeľa (1).
</ptxt>
</s1>
<s1>
<ptxt>
Utiahnite skrutku remenice kľukového hriadeľa nasledovne:
</ptxt>
<s2>
<ptxt>
Špeciálnym nástrojom podľa obrázku zabezpečte remenicu kľukového hriadeľa.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Pri používaní špeciálneho nástroja sa vyhnite nepotrebnej záťaži na rozvodovú reťaz, reťazové kolesá a ostatné príslušné časti.
</ptxt>
</item>
<item>
<ptxt>
Použite nižšie uvedené skrutky na montáž špeciálneho nástroja k remenici kľukového hriadeľa.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
