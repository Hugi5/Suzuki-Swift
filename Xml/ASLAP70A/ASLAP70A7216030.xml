<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216030" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia bočnej vetracej mriežky
</title>
<servinfosub id = "ASLAP70A7216030001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Strana vodiča: Demontujte z prístrojovej dosky panel združeného prístroja. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Strana spolujazdca: Odmontujte airbagy na strane spolujazdca. 
<intxreftitleoff1 refid = "ASLAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte bočnú vetraciu mriežku. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uvoľnite trubice (1) a potom oddeľte bočnú vetraciu mriežku (2) z bočného obloženia prístrojovej dosky (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A721039.swf" width = "88.000mm" height = "68.687mm" ver = "01" gw = "177" gh = "178"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7216030002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
