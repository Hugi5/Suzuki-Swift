<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3406005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spojky
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A3406004">Demontáž a montáž zostavy kardanového hriadeľa</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A3406005001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Pomocou klieští na poistný krúžok demontujte poistný krúžok z hriadeľa spojky.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte viskóznu spojku (1) z hriadeľa spojky (2) pomocou hydraulického lisu (3) a vyťahovača (4).
</ptxt>
<figure>
<graphic graphicname = "I5RS0D340007.swf" width = "88.000mm" height = "49.401mm" ver = "01" gw = "114" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A3406005002">
<title>
Zloženie
</title>
<s1>
<ptxt>
Pomocou špeciálneho nástroja a hydraulického lisu namontujte viskóznu spojku (1) na kardanový hriadeľ (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L3D001">
<s-part>
(A)
</s-part>
<s-number num = "09922-55131">
09922–55131
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A340010.swf" width = "88.000mm" height = "50.636mm" ver = "01" gw = "94" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Na stredový hriadeľ namontujte pomocou klieští na poistný krúžok nový poistný krúžok.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
