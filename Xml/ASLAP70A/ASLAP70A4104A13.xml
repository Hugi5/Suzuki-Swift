<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A4104A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Výstražná kontrolka brzdy zostane zapnutá (na viac ako 2 sek.) po naštartovaní motora
</title>
<diag type = "condition">
<condition>
<ptxt>
Výstražná kontrolka brzdy zostane zapnutá (na viac ako 2 sek.) po naštartovaní motora
</ptxt>
</condition>
<ps>
<ptxt>
Konektor riadiacej jednotky ESP<sup>®</sup> nie je správne pripojený
</ptxt>
</ps>
<action>
<ptxt>
Pripojte konektor riadiacej jednotky ESP<sup>®</sup> opätovne.
</ptxt>
</action>
<ps>
<ptxt>
Zabrzdená parkovacia brzda
</ptxt>
</ps>
<action>
<ptxt>
Uvoľnite parkovaciu brzdu a skontrolujte, či sa výstražné svetlo brzdového systému vyplo.
</ptxt>
</action>
<ps>
<ptxt>
Nedostatočné množstvo brzdovej kvapaliny
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte hladinu brzdovej kvapaliny. 
<intxreftitleoff1 refid = "ASLAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Výstražné svetlo ABS bliká
</ptxt>
</ps>
<action>
<ptxt>
Lokalizujte poruchu a opravte ju. 
<intxreftitleoff1 refid = "ASLAP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača parkovacej brzdy a/alebo spínač hladiny brzdovej kvapaliny.
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Skontrolujte spínač parkovacej brzdy a/alebo spínač hladiny brzdovej kvapaliny.
</ptxt>
<ptxt>
Spínač parkovacej brzdy: 
<intxreftitleoff1 refid = "ASLAP70A4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Spínač hladiny brzdovej kvapaliny: 
<intxreftitleoff1 refid = "ASLAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Porucha komunikačného systému CAN.
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte komunikačný systém CAN. 
<intxreftitleoff1 refid = "ASLAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha združeného prístroja
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte združený prístroj. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hydraulická/Riadiaca jednotka ESP<sup>®</sup>
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu hydraulickej jednotky/riadiacej jednotky ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "ASLAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
