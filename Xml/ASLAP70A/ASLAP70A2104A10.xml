<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A2104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Miskovité pneumatiky
</title>
<diag type = "condition">
<condition>
<ptxt>
Miskovité pneumatiky
</ptxt>
</condition>
<ps>
<ptxt>
Narušená geometria kolies
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a nastavte geometriu kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha zostavy prednej vzpery 
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu prednej vzpery. 
<intxreftitleoff1 refid = "ASLAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované ložiská kolies
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte ložiská kolies. 
<intxreftitleoff1 refid = "ASLAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nadmerné hádzanie pneumatík alebo kolies
</ptxt>
</ps>
<action>
<ptxt>
Opravte alebo vymeňte pneumatiku a/alebo koleso.
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované kĺby ramena nápravy
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte rameno nápravy. 
<intxreftitleoff1 refid = "ASLAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nevyvážené koleso
</ptxt>
</ps>
<action>
<ptxt>
Pneumatiku vyvážte alebo vymeňte.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
