<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4106021" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola funkcie posilňovača bŕzd
</title>
<attention3>
<ptxt>
Pred kontrolou sa uistite, či v hydraulickej vetve nie je žiadny vzduch.
</ptxt>
</attention3>
<servinfosub id = "ASLAP70A4106021001">
<title>
Kontrola vzduchotesnosti
</title>
<s1>
<ptxt>
Naštartujte motor.
</ptxt>
</s1>
<s1>
<ptxt>
Motor po 1 až 2 minútach chodu zastavte.
</ptxt>
</s1>
<s1>
<ptxt>
Zatlačte niekoľkokrát brzdový pedál rovnakou záťažou ako pri bežnom brzdení a pozorujte zdvih pedálu. Posilňovač bŕzd je vzduchotesný ak sa zdvih pedála znižuje po stlačení pedála.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410005.swf" width = "88.000mm" height = "50.619mm" ver = "01" gw = "131" gh = "126"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "6" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.501in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.579in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.315in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.631in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
3.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Ak sa zdvih pedála nezmenil, posilňovač bŕzd má poruchu v utesnení vzduchu.
</ptxt>
<attention3>
<ptxt>
Ak je poškodený, skontrolujte podtlakové potrubia a tesnenia a poškodené časti vymeňte. Po tomto zopakujte príslušný test.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I2RH01410006.swf" width = "88.000mm" height = "50.196mm" ver = "01" gw = "132" gh = "125"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.030in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
1., 2., 3.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASLAP70A4106021002">
<title>
Kontrola činnosti
</title>
<s1>
<ptxt>
Pri zastavenom motore niekoľkokrát zatlačte brzdový pedál rovnakou záťažou a uistite sa, že zdvih pedála sa nemení.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410007.swf" width = "88.000mm" height = "50.323mm" ver = "01" gw = "162" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Naštartujte motor so zatlačeným brzdovým pedálom. Ak zdvih pedála mierne zvýši posilňovač bŕzd, činnosť je primeraná. Ak sa poloha nezmení, posilňovač bŕzd má poruchu.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410008.swf" width = "88.000mm" height = "50.958mm" ver = "01" gw = "173" gh = "127"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A4106021003">
<title>
Kontrola vzduchotesnosti pri zaťažení
</title>
<s1>
<ptxt>
Pri bežiacom motore zatlačte brzdový pedál. Potom motor zastavte, pričom brzdový pedál držíte zatlačený.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410009.swf" width = "88.000mm" height = "51.805mm" ver = "01" gw = "123" gh = "130"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.232in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.628in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
H:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Podržať
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Držte brzdový pedál zatlačený počas 30 sekúnd. Ak sa výška pedálu nemení, stav je v poriadku. Ak sa výška pedála mení, stav posilňovača bŕzd nie je v poriadku.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410010.swf" width = "88.000mm" height = "52.059mm" ver = "01" gw = "192" gh = "131"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.382in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.643in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.382in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.800in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
H:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Podržať
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
T:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
30 sekúnd
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
