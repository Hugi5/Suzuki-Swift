<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70AA206004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Montáž a demontáž senzora teploty vonkajšieho vzduchu
</title>
<servinfosub id = "ASLAP70AA206004001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte predný nárazník. 
<intxreftitleoff1 refid = "ASLAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte prípojku (1) od senzora vonkajšej teploty vzduchu.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte senzor teploty vonkajšieho vzduchu (2) z predného nárazníka.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20018.jpg" width = "88.000mm" height = "67.914mm" ver = "01" gw = "210" gh = "176"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA206004002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70AA206005">Kontrola senzora teploty vonkajšieho vzduchu</intxrefpoff>
</ptxt>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
