<servinfosub id = "ASLAP70A1104019003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0107, P0108, P2119, P2135, P2138, P2228 alebo P2229 nie sú detekované.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Motor nechajte 30 sek. bežať na voľnobežných otáčkach.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104019004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104019005">
<testgroup id = "ASLAP70A1104019006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104019007">
<title>
Kontrola systému nasávania vzduchu
</title>
<test1>
<ptxt>
Skontrolujte systém vstupu vzduchu, či nie je upchatý alebo netesný.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte systém nasávania vzduchu.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104019008">
<title>
Kontrola obvodu snímača tlaku vzduchu v sacom potrubí
</title>
<test1>
<ptxt>
Skontrolujte obvody snímača MAP podľa krokov 2 až 4 v časti 
<intxref refid = "ASLAP70A1104020">DTC P0107 / P0108</intxref>
 .
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104019009">
<title>
Kontrola snímača MAP
</title>
<test1>
<ptxt>
Skontrolujte snímač MAP. 
<intxreftitleoff1 refid = "ASLAP70A1306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte snímač absolútneho tlaku vzduchu v potrubí.
</ptxt>
</action>
</testgroup>
</diag>
