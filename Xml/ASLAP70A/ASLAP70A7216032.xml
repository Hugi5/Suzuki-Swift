<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7216032" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž vzduchového filtra HVAC
</title>
<servinfosub id = "ASLAP70A7216032001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte odkladaciu skrinku. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte kryt vzduchového filtra (2) z jednotky HVAC.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte z jednotky HVAC vzduchový filter (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A721033.swf" width = "88.000mm" height = "53.307mm" ver = "01" gw = "219" gh = "135"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7216032002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Umiestnite vzduchový filter tak, aby šípka (1) vyznačená na ňom smerovala hore.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721034.swf" width = "88.000mm" height = "48.728mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
