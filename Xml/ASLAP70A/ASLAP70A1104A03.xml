<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1104A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hluk motora - hluk ventilu
</title>
<ptxt>
Ak ECM nezistil žiaden kód DTC a pri 
<intxref refid = "ASLAP70A1104008">Vizuálna prehliadka</intxref>
 a 
<intxref refid = "ASLAP70A1104009">Základná kontrola motora</intxref>
 sa nezistila žiadna odchýlka, vykonajte riešenie problémov podľa nasledovných bodov.
</ptxt>
<diag type = "condition">
<condition>
<paragroup>
<ptxt>
Hluk motora - hluk ventilu
</ptxt>
<attention3>
<ptxt>
Pred kontrolou mechanického hluku sa presvedčite, či:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
je použitá predpísaná sviečka zapaľovania.
</ptxt>
</item>
<item>
<ptxt>
je použité predpísané palivo.
</ptxt>
</item>
</list1>
</attention3>
</paragroup>
</condition>
<ps>
<ptxt>
Neprimeraná vôľa ventilov
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406014">Kontrola vačkového hriadeľa a zdvíhadla ventilu</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Opotrebovaný driek a vodidlo ventilu
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406028">Kontrola ventilov a vodidiel ventilov</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabé alebo zlomené ventilové pružiny
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406031">Kontrola ventilovej pružiny</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Pokrivený alebo ohnutý ventil
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A1406028">Kontrola ventilov a vodidiel ventilov</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
