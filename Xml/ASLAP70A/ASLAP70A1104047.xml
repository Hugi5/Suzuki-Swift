<servinfosub id = "ASLAP70A1104047003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Teplota akumulátora &#62; 12 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Zahrejte motor na bežnú prevádzkovú teplotu.
</ptxt>
</s1>
<s1>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ventilátor dúchadla: OFF (VYP)
</ptxt>
</item>
<item>
<ptxt>
Prepínač diaľkových a tlmených svetiel: OFF (VYP)
</ptxt>
</item>
<item>
<ptxt>
Spínač odhmlievania zadného skla: OFF (VYP)
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Udržiavajte motor na otáčkach voľnobehu 10 min. a potvrďte, že sú splnené nasledovné podmienky.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ventilátor dúchadla: ON
</ptxt>
</item>
<item>
<ptxt>
Prepínač diaľkových a tlmených svetiel: ON
</ptxt>
</item>
<item>
<ptxt>
Spínač odhmlievania zadného skla: ON
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Udržujte otáčky motora na 4000 ot/min po dobu 30 sekúnd.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104047004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104047005">
<testgroup id = "ASLAP70A1104047006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104047007">
<title>
Kontrola hnacieho remeňa alternátora
</title>
<test1>
<ptxt>
Skontrolujte správne napnutie hnacieho remeňa alternátora. 
<intxreftitleoff1 refid = "ASLAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Hnací remeň alternátora nastavte alebo vymeňte.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104047008">
<title>
Kontrola riadiaceho signálneho obvodu alternátora
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ ECM a konektor alternátora.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektorom „C01“ a „E01“ a konektoru alternátora.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „A1“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A1“ a ďalšou svorkou v konektore alternátora: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „A1“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104047009">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte alternátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC P0620´?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
