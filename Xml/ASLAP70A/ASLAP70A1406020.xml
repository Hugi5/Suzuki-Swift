<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1406020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž OCV
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1406017">Diely krytu rozvodovej reťaze</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1406020001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor nasávania OCV (čierny) (1) a konektor výfuku OCV (modrý) (2).
</ptxt>
</s1>
<s1>
<ptxt>
Z krytu rozvodovej reťaze vyberte nasávací OCV (3), výfukový OCV (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141060.jpg" width = "88.000mm" height = "58.155mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1406020002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utiahnite skrutky OCV na predpísaný uťahovací moment.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1D013">
<t-part>
Skrutka OCV
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
