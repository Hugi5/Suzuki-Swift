<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1406021" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zotrvačníka
</title>
<servinfosub id = "ASLAP70A1406021001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Vyberte kryt spojky a kotúč spojky. 
<intxreftitleoff1 refid = "ASLAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Kvôli uzamknutiu namontujte na ozubenie krúžku prevodovky pomocou špeciálneho nástroja zotrvačník tak, ako je to zobrazené na obrázku.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D015">
<s-part>
(A)
</s-part>
<s-number num = "09924-17811">
09924–17811
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I8C50A140045.swf" width = "88.000mm" height = "50.407mm" ver = "01" gw = "141" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte zotrvačník z kľukového hriadeľa.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1406021002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Namontujte nové skrutky zotrvačníka.
</ptxt>
</item>
<item>
<ptxt>
Kvôli uzamknutiu namontujte na ozubenie krúžku prevodovky pomocou špeciálneho nástroja zotrvačník tak, ako je to zobrazené na obrázku.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L1D016">
<s-part>
(A)
</s-part>
<s-number num = "09924-17811">
09924–17811
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<list1 type = "unordered">
<item>
<ptxt>
Utiahnite skrutky zotrvačníka na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T1D014">
<t-part>
Skrutka zotrvačníka
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
70
</t-value1>
<t-value2>
7,1
</t-value2>
<t-value3>
52,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50A140046.swf" width = "88.000mm" height = "50.407mm" ver = "01" gw = "141" gh = "126"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
