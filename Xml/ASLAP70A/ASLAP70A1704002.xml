<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1704002" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola výkonovej rovnováhy
</title>
<attention2>
<ptxt>
Pri kontrole výkonovej rovnováhy nikdy nezvyšujte otáčky motora na vyššie ako je rýchlosť voľnobehu. Ak tak urobíte, môžete poškodiť motor.
</ptxt>
</attention2>
<s1>
<ptxt>
Radiacu páku zaraďte do „Neutrálu“ a zatiahnite parkovaciu brzdu.
</ptxt>
</s1>
<s1>
<ptxt>
Keď je spínač zapaľovania v polohe OFF, pripojte skenovacie zariadenie SUZUKI na DLC (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L1G001">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
Skenovacie zariadenie SUZUKI (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A121001.jpg" width = "88.000mm" height = "67.502mm" ver = "02" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Vymažte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zahrejte motor na bežnú prevádzkovú teplotu.
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou skenovacieho nástroja SUZUKI vyberte „Fuel Injector“ v „Active Test“ a vypnite všetky vstrekovače paliva.
</ptxt>
</s1>
<s1>
<ptxt>
S vypnutými vstrekovačmi paliva sa uistite, že otáčky motora klesli pod predpísané otáčky vo voľnobehu.
</ptxt>
</s1>
<s1>
<ptxt>
Ak nie sú pomery zníženia rýchlosti motora v rozsahu, skontrolujte nasledovné položky.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Obvod vstrekovacieho ventilu 
<intxreftitleoff1 refid = "ASLAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vstrekovací ventil 
<intxreftitleoff1 refid = "ASLAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zapaľovacia sviečka 
<intxreftitleoff1 refid = "ASLAP70A1806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</item>
<item>
<ptxt>
Obvod zapaľovacej cievky 
<intxreftitleoff1 refid = "ASLAP70A1804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zapaľovacia cievka 
<intxreftitleoff1 refid = "ASLAP70A1806004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kompresia motora 
<intxreftitleoff1 refid = "ASLAP70A1404001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
