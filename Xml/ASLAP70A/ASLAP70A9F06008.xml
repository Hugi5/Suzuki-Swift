<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9F06008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž USB zásuvky
</title>
<servinfosub id = "ASLAP70A9F06008001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Zložte skriňu prístrojovej dosky. 
<intxreftitleoff1 refid = "ASLAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte kryt strednej strany. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor USB zásuvky (1) a potom odstráňte USB zásuvku (2) z prístrojovej dosky (3) uvoľňovaním zámok (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0014.jpg" width = "88.000mm" height = "55.000mm" ver = "02" gw = "206" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9F06008002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9F06009">Kontrola USB zásuvky</intxrefpoff>
</ptxt>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
