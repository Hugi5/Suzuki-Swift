<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A4104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Výstražná kontrolka ABS sa nezapne po zapnutí zapaľovania
</title>
<diag type = "condition">
<condition>
<ptxt>
Výstražná kontrolka ABS sa nezapne po zapnutí zapaľovania
</ptxt>
</condition>
<ps>
<ptxt>
Porucha obvodu napájania a uzemnenia združeného prístroja.
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte obvod združeného prístroja. 
<intxreftitleoff1 refid = "ASLAP70A9304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha združeného prístroja
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte združený prístroj. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha komunikačného systému CAN.
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte komunikačný systém CAN. 
<intxreftitleoff1 refid = "ASLAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte poistku “MTR” a obvod k positke “MTR”: ak je to nutné, vymeňte ho.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
