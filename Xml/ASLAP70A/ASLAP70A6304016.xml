<servinfosub id = "ASLAP70A6304016005">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A6304016006">
<testgroup id = "ASLAP70A6304016007">
<question>
Bola vykonaná kontrola systému P/S?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A6304001">Kontrola systému P/S</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304016008">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
 Kontrola DTC v ECM. 
<intxreftitleoff1 refid = "ASLAP70A6304003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Našli ste nejaké DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC. (porucha týkajúca sa ECM) 
<intxreftitleoff1 refid = "ASLAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku P/S a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
