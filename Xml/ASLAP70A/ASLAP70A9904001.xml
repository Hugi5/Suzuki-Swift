<servinfo servinfosgmlid = "ASLAP70A9904001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnotstika symptómov napájania systému strešného okna
</title>
<diag type = "condition" id = "ASLAP70A9904001001">
<condition>
<ptxt>
Strešné okno sa nedá ovládať (motor strešného okna sa dá ovládať)
</ptxt>
</condition>
<ps>
<ptxt>
V koľajnici strešného okna sa zasekol nejaký predmet
</ptxt>
</ps>
<action>
<ptxt>
Odstráňte alebo vyčistite zaseknutý objekt.
</ptxt>
</action>
<ps>
<ptxt>
Správna inštalácia koľajnice strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Namontujte ho správne.
</ptxt>
</action>
<ps>
<ptxt>
Rušenie častí strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Opravte rušenie.
</ptxt>
</action>
<ps>
<ptxt>
Správna inštalácia lanka strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Namontujte ho správne.
</ptxt>
</action>
<condition>
<ptxt>
Automatické posúvanie a vyklápanie sa nedá ovládať (iba manuálna prevádzka)
</ptxt>
</condition>
<ps>
<ptxt>
Chybné spúšťanie
</ptxt>
</ps>
<action>
<ptxt>
Spustite motor strešného okna. 
<intxreftitleoff1 refid = "ASLAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nesprávna inštalácia skla strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Nastavte montážnu polohu skla strešného okna. 
<intxreftitleoff1 refid = "ASLAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha pohybu posúvania jednotky strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte jednotku strešného okna. 
<intxreftitleoff1 refid = "ASLAP70A9906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha motora strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte motor strešného okna. 
<intxreftitleoff1 refid = "ASLAP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Strešné okno sa nedá ovládať (motor strešného okna sa nedá ovládať)
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte poistku.
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte spínač strešného okna. 
<intxreftitleoff1 refid = "ASLAP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte obvod. 
<intxreftitleoff1 refid = "ASLAP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "ASLAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha motora strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte motor strešného okna. 
<intxreftitleoff1 refid = "ASLAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Vnikanie dažďa
</ptxt>
</condition>
<ps>
<ptxt>
Nesprávna inštalácia skla strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Nastavte montážnu polohu skla strešného okna. 
<intxreftitleoff1 refid = "ASLAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha skla strešného okna
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte sklo strešného okna. 
<intxreftitleoff1 refid = "ASLAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Odpojená alebo upchatá vypúšťacia hadica (predná/zadná)
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte vypúšťaciu hadicu (predná/zadná)
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
