<servinfosub id = "ASLAP70A1104036003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 8,5 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Motor nechajte 10 sek. bežať na voľnobežných otáčkach.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104036004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104036005">
<testgroup id = "ASLAP70A1104036006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104036007">
<title>
Kontrola napájacieho obvodu vypúšťacieho ventilu nádoby EVAP
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté, odpojte konektor vypúšťacieho ventilu nádoby EVAP.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektoru vypúšťacieho ventilu nádoby EVAP.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, prepnite spínač zapaľovania do polohy „ON (zap.)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, že napätie medzi „A1“ a uzemnením je akumulátorové napätie.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104036008">
<title>
Kontrola obvodu pohonu vypúšťacieho ventilu nádoby EVAP
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ ECM a konektor vypúšťacieho ventilu nádoby EVAP.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektorom „C01“ a „E01“ a konektor vypúšťacieho ventilu nádoby EVAP.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodu „B1“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „B1“ a ďalšou svorkou konektora vypúšťacieho ventilu nádoby EVAP: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodu „B1“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104036009">
<title>
Kontrola vypúšťacieho ventilu nádoby EVAP
</title>
<test1>
<ptxt>
Skontrolujte odpor vypúšťacieho ventilu nádoby EVAP. 
<intxreftitleoff1 refid = "ASLAP70A1206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte vypúšťací ventil nádoby EVAP.
</ptxt>
</action>
</testgroup>
</diag>
