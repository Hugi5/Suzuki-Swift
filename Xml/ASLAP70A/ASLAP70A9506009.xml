<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9506009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž vnútorného zrkadla
</title>
<servinfosub id = "ASLAP70A9506009001">
<title>
Demontáž
</title>
<ptxt>
Odmontujte skrutku vnútorného zrkadla (TORX <sup>®</sup> T20) (1) a posuňte zrkadlo (2) v smere šípky.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950021.swf" width = "88.000mm" height = "49.005mm" ver = "01" gw = "227" gh = "122"/>
</figure>
</servinfosub>
<servinfosub id = "ASLAP70A9506009002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dotiahnite skrutku vnútorného zrkadla na predpísaný uťahovací moment.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9E001">
<t-part>
Skrutka vnútorného zrkadla
</t-part>
<t-value1>
3,5
</t-value1>
<t-value2>
0,36
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
