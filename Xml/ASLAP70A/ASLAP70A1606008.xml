<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1606008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zariadenia termostatu (so snímačom ECT)
</title>
<servinfosub id = "ASLAP70A1606008001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Vypustite chladiacu kvapalinu. 
<intxreftitleoff1 refid = "ASLAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte snímač CMP výfuku. 
<intxreftitleoff1 refid = "ASLAP70A1306017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor snímača teploty chladiacej tekutiny.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte prítokovú hadicu chladiča (2) a prítokovú hadicu ohrievača (3) z montážnej zostavy chladiča (1).
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte z hlavy valcov motora zariadenie termostatu (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70P160003.swf" width = "88.000mm" height = "50.065mm" ver = "01" gw = "181" gh = "125"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1606008002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Použite nové tesnenie.
</ptxt>
</item>
<item>
<ptxt>
Chladiaci systém doplňte chladiacou kvapalinou. 
<intxreftitleoff1 refid = "ASLAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či chladiaci systém nepresakuje. 
<intxreftitleoff1 refid = "ASLAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte snímač CMP výfuku, či neuniká olej.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
