<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A8106009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia zostavy bezpečnostného pásu na zadnom sedadle
</title>
<servinfosub id = "ASLAP70A8106009001">
<title>
Demontáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A8106008">Komponenty zadného bezpečnostného pásu</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Odmontujte zadné sedadlo. 
<intxreftitleoff1 refid = "ASLAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte obloženie hornej štvrtiny. 
<intxreftitleoff1 refid = "ASLAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky a potom odmontujte zostavu bezpečnostného pásu na zadnom sedadle. 
<intxreftitleoff1 refid = "ASLAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A8106009002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A8106008">Komponenty zadného bezpečnostného pásu</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte, či kolíky (3) na telese sú vložené v dlhých otvoroch (2) na navíjači (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A810014.swf" width = "88.000mm" height = "66.076mm" ver = "01" gw = "206" gh = "171"/>
</figure>
</item>
<item>
<ptxt>
Dotiahnite skrutky bezpečnostného pásu zadného sedadla v číselnom poradí na predpísaný uťahovací moment. 
<intxreftitleoff1 refid = "ASLAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Namontujte všetky kotviace platne (1) bez rušenia s plášťom (2) na podlahový panel.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810015.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
