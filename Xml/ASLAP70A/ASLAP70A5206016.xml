<servinfo servinfosgmlid = "ASLAP70A5206016" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rozobratie a zloženie pravej skrine prevodovky s rozvodovkou
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A5206010">Rozobratie a zloženie jednotky manuálnej prevodovky s rozvodovkou</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A5206013">Komponenty zostavy manuálnej prevodovky s rozvodovkou</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A5206016001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte vonkajší krúžok ložiska na strane diferenciálu (1) pomocou mosadznej tyče (2), ak je to potrebné.
</ptxt>
<figure>
<graphic graphicname = "I9P60A522034.swf" width = "88.000mm" height = "50.454mm" ver = "01" gw = "161" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Odstráňte olejové tesnenie vstupného hriadeľa. V prípade potreby použite špeciálne nástroje.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B010">
<s-part>
(A)
</s-part>
<s-number num = "09913-75830">
09913–75830
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522035.swf" width = "88.000mm" height = "51.350mm" ver = "01" gw = "182" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
V prípade potreby vytiahnite vonkajší krúžok pravého ložiska predlohového hriadeľa pomocou špeciálnych nástrojov.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B011">
<s-part>
(A)
</s-part>
<s-number num = "09930-30104">
09930–30104
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B012">
<s-part>
(B)
</s-part>
<s-number num = "09941-64511">
09941–64511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A520027.swf" width = "88.000mm" height = "46.995mm" ver = "01" gw = "147" gh = "117"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A5206016002">
<title>
Zloženie
</title>
<s1>
<ptxt>
Pomocou špeciálneho nástroja a kladiva nasaďte olejové tesnenie vstupného hriadeľa s pružnou časťou smerom dohora, pokiaľ sa nedotkne plochy skrine. Na okraj olejového tesnenia naneste vazelínu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B008" uid = "22">
<m-part>
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
<servicetool>
<servicetoolitem id = "L5B013">
<s-part>
(A)
</s-part>
<s-number num = "09913-75830">
09913–75830
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522036.swf" width = "88.000mm" height = "47.369mm" ver = "01" gw = "185" gh = "118"/>
</figure>
</s1>
<s1>
<ptxt>
Nainštalujte vonkajší krúžok ložiska predlohového hriadeľa (1) pomocou špeciálnych nástrojov a kladiva.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B014">
<s-part>
(A)
</s-part>
<s-number num = "09913-75821">
09913–75821
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B015">
<s-part>
(B)
</s-part>
<s-number num = "09924-84510-004">
09924–84510–004
</s-number>
</servicetoolitem>
</servicetool>
<figure>
