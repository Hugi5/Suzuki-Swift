<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A8206025" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola snímača zadného nárazu
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A8206024">Demontáž a montáž snímača zadného nárazu</intxrefpoff>
</ptxt>
<ptxt>
Skontrolujte snímač zadného nárazu a ak zistíte čokoľvek z nasledovného, vymeňte ho za nový.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Bočný airbag/hlavový airbag boli rozvinuté.
</ptxt>
</item>
<item>
<ptxt>
Deformácia alebo poškodenie snímača zadného nárazu.
</ptxt>
</item>
<item>
<ptxt>
Poškodenie konektora snímača zadného nárazu.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
