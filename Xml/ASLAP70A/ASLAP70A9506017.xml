<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zostavy regulátora okna zadných dverí
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9506014">Komponenty zadných dverí</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A9506017001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte sklo zadných dverí. 
<intxreftitleoff1 refid = "ASLAP70A9506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor elektromotora elektricky ovládaných dverí (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky ovládača okna (2) a vyberte zostavu ovládača zadného okna (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950048.jpg" width = "88.000mm" height = "61.700mm" ver = "02" gw = "217" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9506017002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9506018">Kontrola zostavy elektrického ovládania okien zadných dverí</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Na klzné časti regulátora elektrického ovládania okien zadných dverí naneste vazelínu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E002" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Dotiahnite matice ovládača zadného okna v poradí (“1” až “4”) na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T9E006">
<t-part>
Skrutka ovládača zadného okna*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,86
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950049.jpg" width = "88.000mm" height = "63.881mm" ver = "01" gw = "225" gh = "165"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
