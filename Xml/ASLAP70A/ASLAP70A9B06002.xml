<servinfo servinfosgmlid = "ASLAP70A9B06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spodnej konzoly predného blatníka
</title>
<attention3>
<ptxt>
Nižšie uvedený obrázok zobrazuje podmienky odstraňovania nasledovných častí.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predný blatník 
<intxreftitleoff1 refid = "ASLAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0007.jpg" width = "88.000mm" height = "55.869mm" ver = "02" gw = "227" gh = "142"/>
</figure>
<servinfosub id = "ASLAP70A9B06002001">
<title>
Všeobecné poznámky
</title>
<ptxt>
Spôsob zvárania a počet bodov zvaru je ten istý na oboch stranách. Tieto pokyny na opravu zobrazujú postup pre ľavú stranu.
</ptxt>
</servinfosub>
<servinfosub id = "ASLAP70A9B06002002">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odvŕtajte body zvarov a odmontujte spodnú konzolu predného blatníka.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0008.jpg" width = "88.000mm" height = "72.673mm" ver = "03" gw = "209" gh = "189"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9B06002003">
<title>
Montáž
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Pred zváraním skontrolujte polohu inštalácie a stav inštalačnej časti (častí). 
<intxreftitleoff1 refid = "ASLAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
V oprave pokračujte berúc do úvahy inštaláciu častí, ktoré majú vplyv na vzhľad. 
<intxreftitleoff1 refid = "ASLAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention2>
<s1>
<ptxt>
Namontujte spodnú konzolu predného blatníka
</ptxt>
</s1>
<s1>
<ptxt>
Vykonajte odporové bodové zváranie.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0009.jpg" width = "88.000mm" height = "71.219mm" ver = "02" gw = "204" gh = "185"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
