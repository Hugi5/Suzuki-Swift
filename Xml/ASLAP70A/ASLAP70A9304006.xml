<servinfosub id = "ASLAP70A9304006003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A9304006004">
<testgroup id = "ASLAP70A9304006005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vymažte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1810?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte kvôli občasným problémom. 
<intxreftitleoff1 refid = "ASLAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A9304006006">
<title>
Kontrola snímača hladiny paliva
</title>
<test1>
<ptxt>
Skontrolujte snímač hladiny paliva. 
<intxreftitleoff1 refid = "ASLAP70A1706018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Vymeňte snímač úrovne paliva a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1706017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ASLAP70A9304006007">
<title>
Kontrola obvodu snímača hladiny paliva
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte združený merač a konektory snímača hladiny paliva.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie k združenému meraču a svorkám snímača hladiny paliva.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte, či nie je okruh medzi združeným meračom a snímačom hladiny paliva prerušený, skratovaný k uzemneniu alebo skratovaný k napájaniu.
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte združený merač a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte poruchový káblový zväzok a opätovne skontrolujte DTC.
</ptxt>
</action>
</testgroup>
</diag>
