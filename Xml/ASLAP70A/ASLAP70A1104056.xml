<servinfosub id = "ASLAP70A1104056003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0100, P0102 alebo P0103 nie sú detekované.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Naštartujte motor.
</ptxt>
</s1>
<s1>
<ptxt>
Úplne vytlačte plynový pedál a uvoľnite ho.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104056004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104056005">
<testgroup id = "ASLAP70A1104056006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104056007">
<title>
Kontrola káblového zväzku
</title>
<test1>
<ptxt>
Skontrolujte nasledovné body.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Obvod „B2“: Postupujte podľa kroku 2 až 4 časti 
<intxref refid = "ASLAP70A1104024">DTC P0122 / P0123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Obvod „B3“: Postupujte podľa kroku 2 až 4 časti 
<intxref refid = "ASLAP70A1104030">DTC P0222 / P0223</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104056008">
<title>
Kontrola snímača polohy škrtiacej klapky
</title>
<test1>
<ptxt>
Skontrolujte snímač TP podľa „Kontrola funkčnosti snímača polohy škrtiacej klapky (TP)“ v 
<intxref refid = "ASLAP70A1306004">Kontrola telesa elektrickej škrtiacej klapky vo vozidle</intxref>
.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zariadenie telesa elektrickej škrtiacej klapky.
</ptxt>
</action>
</testgroup>
</diag>
