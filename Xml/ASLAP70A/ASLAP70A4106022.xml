<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž posilňovača bŕzd
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4106020">Diely posilňovača bŕzd</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A4106022001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Pomocou špeciálneho nástroja odpojte brzdové potrubia (1) od zostavy hydraulickej jednotky/riadiacej jednotky (2) ESP<sup>®</sup>.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410035.swf" width = "88.000mm" height = "45.139mm" ver = "02" gw = "117" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Vyberte hlavný brzdový valec z posilňovača bŕzd.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte vákuovú hadicu od posilňovača bŕzd.
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte príchytku (1) a čap závesu (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410036.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte matice posilňovača bŕzd (1) a vyberte posilňovač bŕzd z prístrojovej dosky.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410037.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A4106022004">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4106023">Kontrola posilňovača bŕzd</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Uvoľnite maticu konzoly brzdového pedála (1) a skrutku hornej výstuže (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte posilňovač bŕzd na prístrojovú dosku. Potom pripojte tlačnú tyč prípojného zariadenia (3) k ramenu brzdového pedála s kolíkom (2) a svorkou (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410040.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte panel združeného merača. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Utiahnite matice posilňovača bŕzd na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T4A006">
<t-part>
Matica posilňovača bŕzd*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410041.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Maticu konzoly brzdového pedála utiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
Matica konzoly brzdového pedála
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Utiahnite skrutky hornej výstuhy krytu na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
Skrutka hornej výstuže krytu
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410042.swf" width = "88.000mm" height = "64.412mm" ver = "02" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte panel združeného merača.
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte vákuovú hadicu k posilňovaču bŕzd.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte hlavný brzdový valec do posilňovača bŕzd.
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou špeciálneho nástroja pripojte brzdové potrubia (1) k zostave hydraulickej jednotky/riadiacej jednotky (2) ESP<sup>®</sup>.
</ptxt>
<torque>
<torqueitem id = "T4A009">
<t-part>
Matica brzdového potrubia
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410043.swf" width = "88.000mm" height = "46.684mm" ver = "02" gw = "119" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Po montáži odvzdušnite systém. 
<intxreftitleoff1 refid = "ASLAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte nainštalované súčiastky, či z nich neuniká brzdová kvapalina.
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte vôľu brzdového pedála. 
<intxreftitleoff1 refid = "ASLAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uistite sa, že brzdový systém pracuje správne a skontrolujte, či netečie brzdová kvapalina.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
