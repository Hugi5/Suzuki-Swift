<diag type = "test" id = "ASLAP70A7224029003">
<testgroup id = "ASLAP70A7224029005">
<title>
Kontrola údajov skenovacieho zariadenia
</title>
<test1>
<ptxt>
Spínač zapaľovania prepnite do polohy OFF (vyp.) a pripojte skenovacie zariadenie.
</ptxt>
</test1>
<test1>
<ptxt>
Zapnite zapaľovanie a vyberte režim „DATA LIST“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte Engine Type (typ motora) zobrazený skenovacím zariadením.
</ptxt>
</test1>
<question>
Je typ motora správny, podľa údajov v „Scan Tool Data“?
</question>
<result type = "yes"/>
<action>
<ptxt>
Nahraďte overenou riadiacou jednotkou HVAC a opäť skontrolujte.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Nahraďte overenou riadiacou jednotkou motora a opäť skontrolujte.
</ptxt>
</action>
