<diag type = "test" id = "ASLAP70A8204053003">
<testgroup id = "ASLAP70A8204053004">
<title>
Kontrola obvodu jednotky (inflátora) airbagu vodiča
</title>
<test1>
<ptxt>
Zo stĺpika riadenia demontujte jednotku (inflátor) airbagov. 
<intxreftitleoff1 refid = "ASLAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektor “G11”.
</ptxt>
</test1>
<test1>
<ptxt>
Uvoľnite skratovaciu tyč v konektore SDM vložením uvoľňovacieho nástroja, ktorý je vložený do špeciálneho nástroja (A).
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovný bod.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor medzi svorkami &#34;G11-5&#34; a &#34;G11-6&#34;: nekonečno
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B097">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820030.swf" width = "90.000mm" height = "60.504mm" ver = "01" gw = "212" gh = "155"/>
</testfigure>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte poškodený káblový zväzok. Ak je výsledok kontroly v poriadku, vymeňte zostavu kontaktného vinutia. 
<intxreftitleoff1 refid = "ASLAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204053005">
<title>
Kontrola obvodu kontaktného vinutia (obvod airbagu vodiča (inflátora))
</title>
<test1>
<ptxt>
Vyberte zostavu kontaktného vinutia. 
<intxreftitleoff1 refid = "ASLAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte nasledovný bod.
</ptxt>
<ptxt>
Model so spínačom zapaľovania:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odmerajte odpor medzi svorkami “S121-1” až “S172-2” a “S121-2” až “S172-1”.
</ptxt>
</item>
</list1>
<ptxt>
Model s bezkľúčovým štartovaním: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odmerajte odpor medzi svorkami “S121-1” až “S174-2” a “S121-2” až “S174-1”.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B098">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820018.swf" width = "90.000mm" height = "70.672mm" ver = "02" gw = "196" gh = "184"/>
</testfigure>
</test1>
<question>
Je odpor 1 &#937; alebo menej?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte kontaktné vinutie. 
<intxreftitleoff1 refid = "ASLAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204053006">
<title>
Kontrola obvodu kontaktného vinutia (obvod klaksóna)
</title>
<test1>
<ptxt>
Skontrolujte nasledovný bod.
</ptxt>
<ptxt>
Model so spínačom zapaľovania:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odmerajte odpor medzi koncovkou „S61 –1“ a „S171-1“.
</ptxt>
</item>
</list1>
<ptxt>
Model s bezkľúčovým štartovaním:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odmerajte odpor medzi koncovkou „S62 -4“ a „S173-4“.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B099">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820019.swf" width = "90.000mm" height = "85.625mm" ver = "02" gw = "225" gh = "226"/>
</testfigure>
</test1>
<question>
Je odpor 1 &#937; alebo menej?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte kontaktné vinutie. 
<intxreftitleoff1 refid = "ASLAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204053007">
<title>
Kontrola obvodu kontaktného vinutia
</title>
<test1>
<ptxt>
Zmerajte odpor medzi každou koncovkou kontaktného vinutia a ďalšími koncovkami.
</ptxt>
</test1>
<question>
Je každý nameraný odpor nekonečný?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kontaktné vinutie a jeho obvod sú v poriadku.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte kontaktné vinutie. 
<intxreftitleoff1 refid = "ASLAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
