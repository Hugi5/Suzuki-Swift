<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1104012" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
Kontrolka poruchy zostane po spustení motora zapnutá
</title>
<servinfosub id = "ASLAP70A1104012001">
<title>
Riešenie problémov
</title>
<diag type = "test" id = "ASLAP70A1104012002">
<testgroup id = "ASLAP70A1104012003">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Naštartuje motor a znovu skontrolujte DTC ECM počas behu motora.
</ptxt>
</test1>
<question>
Našli ste nejaké DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na riešenie problémov príslušnej činnosti MIL.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Združený prístroj nahraďte overeným a opäť skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ak MIL zostane zapnutá, vymeňte ECM a opätovne skontrolujte činnosť MIL. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
