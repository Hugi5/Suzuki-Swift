<servinfosub id = "ASLAP70A8204009002">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A8204009003">
<testgroup id = "ASLAP70A8204009004">
<title>
Kontrola konektora SDM
</title>
<test1>
<ptxt>
Skontrolujte správne pripojenie konektora SDM.
</ptxt>
</test1>
<question>
Je spojenie v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Konektor riadne pripojte.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204009005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Vykonajte 
<intxref refid = "ASLAP70A8204005">Kontrola DTC</intxref>
. 
</ptxt>
</test1>
<question>
Našli ste nejaké DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušnou procedúrou riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204009006">
<title>
Kontrola obvodu napájania a uzemnenia SDM
</title>
<test1>
<ptxt>
Skontrolujte obvod napájania a uzemnenia SDM. 
<intxreftitleoff1 refid = "ASLAP70A8204052"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú obvody v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte poškodený obvod napájania a uzemnenia SDM.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204009007">
<title>
Kontrola komunikačného obvodu CAN
</title>
<test1>
<ptxt>
Skontrolujte komunikačný obvod CAN medzi SDM a združeným meračom.
</ptxt>
</test1>
<question>
Je obvod v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A8204009008">
<title>
Kontrola združeného merača
</title>
<test1>
<ptxt>
Vymeňte združený prístroj. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<question>
Zostala výstražná kontrolka „AIR BAG“ rozsvietená?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte SDM a opätovne skontrolujte činnosť výstražnej kontrolky „AIR BAG“. 
<intxreftitleoff1 refid = "ASLAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po skončení prehliadky a opravných prácach vykonajte nasledovné:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Znovu pripojte všetky komponenty systému airbagov a skontrolujte, či sú všetky komponenty správne namontované.
</ptxt>
</item>
<item>
<ptxt>
Zopakujte 
<intxref refid = "ASLAP70A8204001">Kontrola diagnostického systému airbagov</intxref>
 na potvrdenie, že porucha bola napravená.
</ptxt>
</item>
</list1>
</attention3>
