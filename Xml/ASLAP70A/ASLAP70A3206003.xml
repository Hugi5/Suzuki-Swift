<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rozobratie a poskladanie zostavy zadného diferenciálu
</title>
<servinfosub id = "ASLAP70A3206003001">
<title>
Rozobratie
</title>
<s1>
<ptxt>
Zdvihnite vozidlo a snímte kolesá.
</ptxt>
</s1>
<s1>
<ptxt>
Ak je to potrebné, vypustite zo zadného diferenciálu olej. 
<intxreftitleoff1 refid = "ASLAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte zadné hnacie hriadele. 
<intxreftitleoff1 refid = "ASLAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Zo zadného diferenciálu odmontujte kardanový hriadeľ. 
<intxreftitleoff1 refid = "ASLAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte odvzdušňovaciu hadicu (1) od zadného diferenciálu.
</ptxt>
</s1>
<s1>
<ptxt>
Zdvihák umiestnite tak, aby sa zostava diferenciálu nenakláňala. 
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte skrutky predného ramena diferenciálu (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte zadnú montážnu skrutku diferenciálu (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A320007.swf" width = "88.000mm" height = "57.146mm" ver = "02" gw = "186" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Znížte zdvihák so zostavou zadného diferenciálu.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A3206003002">
<title>
Zloženie
</title>
<ptxt>
Postupujte opačným postupom ako pri demontáži a všímajte si nasledovné body.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Skrutky utiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T3B004">
<t-part>
Predná skrutka ramena diferenciálu
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
<torqueitem id = "T3B005">
<t-part>
Montážna skrutka zadného diferenciálu
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
80
</t-value1>
<t-value2>
8,2
</t-value2>
<t-value3>
59,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320008.swf" width = "88.000mm" height = "52.572mm" ver = "02" gw = "186" gh = "133"/>
</figure>
</item>
<item>
<ptxt>
Naplňte olejom zadného diferenciálu, ak ste ho vypustili. 
<intxreftitleoff1 refid = "ASLAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
