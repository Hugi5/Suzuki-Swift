<servinfosub id = "ASLAP70A1104028003">
<title>
Postup potvrdenia DTC
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Cestnú skúšku vykonávajte na mieste, kde nie je doprava, aby ste predišli nehode.
</ptxt>
</item>
<item>
<ptxt>
Skúšobnú jazdu musia vykonať dve osoby, vodič a testujúca osoba a to na rovnej ceste.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 10,7 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Zahrejte motor na bežnú prevádzkovú teplotu.
</ptxt>
</s1>
<s1>
<ptxt>
Choďte s autom nepretržite rýchlosťou 50 až 80 km/h (31 až 50 míľ/h) 20 min., alebo viac.
</ptxt>
</s1>
<s1>
<ptxt>
Vozidlo zastavte a motor nechajte bežať na voľnobežnej rýchlosti počas 5 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104028004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104028005">
<testgroup id = "ASLAP70A1104028006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104028007">
<title>
Kontrola DTC
</title>
<question>
Sú zobrazené iné DTC ako P0137 a P0138 a P0140?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušnou procedúrou riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104028008">
<title>
Kontrola signálneho obvodu HO2S a uzemňovacieho obvodu
</title>
<test1>
<ptxt>
Keď je zapaľovanie vypnuté, odpojte konektory „C01“ a „E01“ ECM a konektor HO2S.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektorom „C01“ a „E01“ a konektor HO2S.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „B2“ alebo „B3“: menej ako 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „B2“ a „B3“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B2“ a ďalšou svorkou v konektore HO2S: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „B3“ a ďalšou svorkou v konektore HO2S: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodov „B2“ alebo „B3“: 0 až 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104028009">
<title>
Kontrola výfukového systému a systému vstupu vzduchu
</title>
<test1>
<ptxt>
Skontrolujte, či nie je výfukový systém a systém nasávania vzduchu upchatý alebo netesný.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybnú časť.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104028010">
<title>
Kontrola obvodu ohrievača HO2S
</title>
<test1>
<ptxt>
Skontrolujte obvody ohrievača HO2S podľa kroku 2 až 3 v 
<intxref refid = "ASLAP70A1104016">DTC P0036 / P0037 / P0038</intxref>
 .
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte chybnú časť.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104028011">
<title>
Kontrola vstrekovacích ventilov paliva a ich obvodu
</title>
<test1>
<ptxt>
Skontrolujte obvod vstrekovacieho ventilu paliva. 
<intxreftitleoff1 refid = "ASLAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte vstrekovacie ventily paliva. 
<intxreftitleoff1 refid = "ASLAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Poškodený vstrekovač(e) alebo jeho obvod.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104028012">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte HO2S. 
<intxreftitleoff1 refid = "ASLAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte postup potvrdenia DTC a skontrolujte DTC.
</ptxt>
</test1>
<question>
Je rozoznané DTC P0137, P0138 alebo P0140?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
