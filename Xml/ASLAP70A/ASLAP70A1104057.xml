<servinfosub id = "ASLAP70A1104057003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Systémové napätie &#62; 8 V
</ptxt>
</item>
<item>
<ptxt>
DTC P2122, P2123, P2127 alebo P2128 nie sú detekované.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Udržujte plynový pedál plne stlačený počas 2 sekúnd.
</ptxt>
</s1>
<s1>
<ptxt>
Udržujte plynový pedál v pokojovej polohe počas 2 sekúnd.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104057004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104057005">
<testgroup id = "ASLAP70A1104057006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104057007">
<title>
Kontrola káblového zväzku
</title>
<test1>
<ptxt>
Skontrolujte nasledovné body.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Obvody „A2“ alebo „A3“: Postupujte podľa kroku 3 až 5 časti 
<intxref refid = "ASLAP70A1104054">DTC P2122 / P2123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Obvody „B1“, „B2“ alebo „B3“: Postupujte podľa kroku 3 až 5 časti 
<intxref refid = "ASLAP70A1104055">DTC P2127 / P2128</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104057008">
<title>
Kontrola snímača APP
</title>
<test1>
<ptxt>
Skontrolujte výkon snímača APP. 
<intxreftitleoff1 refid = "ASLAP70A1306006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte teleso snímača APP.
</ptxt>
</action>
</testgroup>
</diag>
