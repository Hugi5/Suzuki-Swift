<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1506008" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola olejového čerpadla
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1506007">Rozloženie a zloženie zariadenia olejového čerpadla</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1506008001">
<title>
Olejové tesnenie
</title>
<ptxt>
Skontrolujte, či krúžok olejového tesnenia nie je opotrebovaný alebo poškodený. Ak sú niektoré súčasti chybné, vymeňte ich.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B150023.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "184" gh = "128"/>
</figure>
</servinfosub>
<servinfosub id = "ASLAP70A1506008002">
<title>
Olejové čerpadlo
</title>
<list1 type = "unordered">
<item>
<ptxt>
Skontrolujte vonkajší (1) a vnútorný rotor (2), platňu rotora a skrinku olejového čerpadla, či nie sú nadmerne opotrebované alebo poškodené.
</ptxt>
<figure>
<graphic graphicname = "I8C50A150028.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "134" gh = "135"/>
</figure>
</item>
<item>
<ptxt>
Skontolujte, či nie je poistný ventil (1) nadmerne opotrebovaný alebo poškodený a či funguje plynule.
</ptxt>
<figure>
<graphic graphicname = "I8C50A150029.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "112" gh = "168"/>
</figure>
</item>
</list1>
<c-change/>
<topic id = "ASLAP70A1506008003">
<title>
Radiálna vôľa
</title>
<ptxt>
Pomocou hrúbkomera skontrolujte radiálnu vôľu medzi vonkajším rotorom (1) a krytom (2).
</ptxt>
<ptxt>
Ak bočná vôľa nezodpovedá predpísanej hodnote, olejové čerpadlo vymeňte.
</ptxt>
<spec>
<title>
Radiálna vôľa medzi vonkajším rotorom a krytom olejového čerpadla
</title>
<ptxt>
Predpis: 0,120 – 0,190 mm (0,0047 – 0,0075 in.)
</ptxt>
<ptxt>
Limit: 0,210 mm (0,0083 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151026.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "171" gh = "124"/>
</figure>
</topic>
<topic id = "ASLAP70A1506008004">
<title>
Axiálna vôľa
</title>
<ptxt>
Pomocou lineára (1) a hrúbkomera (2) zmerajte bočnú vôľu.
</ptxt>
<ptxt>
Ak vôľa nezodpovedá predpísanej hodnote, olejové čerpadlo vymeňte.
</ptxt>
<spec>
<title>
Postranná vôľa vnútorného rotora olejového čerpadla
</title>
<ptxt>
Predpis: 0,045 – 0,100 mm (0,0018 – 0,0039 in.)
</ptxt>
<ptxt>
Limit: 0,120 mm (0,0047 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151027.swf" width = "88.000mm" height = "12.350mm" ver = "01" gw = "185" gh = "133"/>
</figure>
</topic>
<c-change/>
<topic id = "ASLAP70A1506008005" page = "2">
<title>
Vôľa rotorovej dosky
</title>
<ptxt>
Skontrolujte vôľu medzi vnútorným rotorom (1) a rotorovou doskou (2), a to nasledovne.
</ptxt>
<s1 page = "2">
<ptxt>
Zmerajte vonkajší priemer „a“ vnútorného rotora (1) pomocou mikrometra.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Zmerajte vnútorný priemer „b“ rotorovej dosky (2) pomocou mikrometra.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Vypočítajte rozdiel medzi meraniami z kroku 1) a kroku 2).
</ptxt>
</s1>
<ptxt>
Ak bočná vôľa nezodpovedá predpísanej hodnote, olejové čerpadlo vymeňte.
</ptxt>
