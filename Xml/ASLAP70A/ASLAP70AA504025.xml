<servinfosub id = "ASLAP70AA504025003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Naštartujte motor.
</ptxt>
</s1>
<s1>
<ptxt>
Motor zastavte.
</ptxt>
</s1>
<s1>
<ptxt>
Zopakujte kroky 1) až 2).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA504025004">
<title>
Riešenie problémov DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Toto DTC môže byť zistené keď je batéria vybitá, alebo je slabé napätie.
</ptxt>
</item>
<item>
<ptxt>
Pri vykonávaní „Kontroly parametrov“ stlačte spínač motora na 3 sekundy alebo dlhšie.
</ptxt>
</item>
</list1>
</attention3>
<diag type = "test" id = "ASLAP70AA504025005">
<testgroup id = "ASLAP70AA504025006">
<title>
Kontrola DTC
</title>
<question>
Je DTC B1125 zistený súčasne?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504025010">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte „Starting motor Relay“ zobrazenú na skenovacom zariadení SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504025007">
<title>
Kontrola poistky
</title>
<test1>
<ptxt>
Skontrolujte poistky “ST” a “ST SIG”.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte poistky “ST” a “ST SIG”.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504025008">
<title>
Skontrolujte relé ovládania štartéra
</title>
<test1>
<ptxt>
Skontrolujte riadiace relé štartovacieho motora. 
<intxreftitleoff1 refid = "ASLAP70AA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte riadiace relé štartéra.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504025009">
<title>
Kontrola signálneho obvodu riadenia relé štartéra motora
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte konektory “C01”, “E01”, “E25” a štartéra.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie svoriek ku konektorom „C01“, „E01“, „E25“ a konektorov štartéra.
</ptxt>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“ alebo „A2“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi každým obvodom „A1“ a „A2“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkou obvodu „A1“ a každou svorkou v konektore relé riadenia štartéra: nekonečno
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA504025011">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte konektor „L10“ a namontujte riadiace relé štartovania motora.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa aktuálne DTC B1194?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku bezkľúčového štartovania a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
