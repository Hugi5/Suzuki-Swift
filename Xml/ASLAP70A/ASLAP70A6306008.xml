<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A6306008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a inštalácia puzdra spojovacej tyče / ozubenej tyče
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A6306003">Demontáž a inštalácia hlavy spojovacej tyče</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A6306001">Komponenty zostavy skrine prevodovky riadenia</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A6306007">Kontrola puzdra hrebeňového riadenia</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A6306008001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte montážnu zostavu skrine prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vymeňte koniec spojovacej tyče. 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zložte pás (2) a svorku puzdra hrebeňového riadenia (1).
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Odmontujte puzdro hrebeňového riadenia (3) zo spojovacej tyče.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630026.swf" width = "88.000mm" height = "53.031mm" ver = "02" gw = "158" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Narovnajte ohnutú časť poistnej podložky spojovacej tyče (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte spojovaciu tyč (3) od skrine (2) podľa obrázka.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630027.swf" width = "88.000mm" height = "46.459mm" ver = "01" gw = "197" gh = "115"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A6306008002">
<title>
Montáž
</title>
<s1>
<ptxt>
Vyrovnajte drážku (5) hrebeňa (2) s prečnievaním (4) podložky novej spojovacej tyče (3).
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte spojovaciu tyč (1) k prečnievaniu (2) a potom tyč dotiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T6C003">
<t-part>
Riadiaca tyč
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A630015.swf" width = "88.000mm" height = "55.132mm" ver = "01" gw = "145" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Ohnite poistnú podložku (1) v 2 miestach podľa obrázku.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630029.swf" width = "88.000mm" height = "51.419mm" ver = "02" gw = "144" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Na riadiacu tyč „A“ naneste vazelínu tak, ako je to zobrazené na obrázku. Umiestnite puzdro hrebeňa riadenia riadne do drážok zostavy skrine prevodovky (alebo montážneho prvku hrebeňa) a spojovacej tyče.
</ptxt>
<ptxt>
Potom skontrolujte, či puzdro hrebeňa riadenia nie je pokrútené alebo či nemá záhyby.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease E" id = "M6C001" uid = "24">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25050
</m-number>
<m-name>
SUZUKI Super Grease E
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A630030.swf" width = "88.000mm" height = "33.098mm" ver = "01" gw = "196" gh = "77"/>
</figure>
</s1>
<s1>
<ptxt>
Pripevnite nové pásmo (1) pomocou špeciálneho nástroja a namontujte svorku hrebeňového riadenia (2)
</ptxt>
<servicetool>
<servicetoolitem id = "L6C008">
<s-part>
(A)
</s-part>
<s-number num = "09943-55010">
09943–55010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630031.swf" width = "88.000mm" height = "40.262mm" ver = "01" gw = "161" gh = "98"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte koniec spojovacej tyče. 
<intxreftitleoff1 refid = "ASLAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Namontujte montážnu zostavu skrine prevodovky riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
