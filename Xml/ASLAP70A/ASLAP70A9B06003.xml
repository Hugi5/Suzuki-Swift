<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9B06003" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž časti na strane kapoty
</title>
<attention3>
<ptxt>
Nižšie uvedený obrázok zobrazuje podmienky odstraňovania nasledovných častí.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predný blatník 
<intxreftitleoff1 refid = "ASLAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Časť zámky kapoty, časť podpory lampy a podpora lampy 
<intxreftitleoff1 refid = "ASLAP70A9B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Spodná konzola predného blatníka 
<intxreftitleoff1 refid = "ASLAP70A9B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vonkajší prvok bočného krytu 
<intxreftitleoff1 refid = "ASLAP70A9B06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Predný panel prístrojovej dosky s predným panelom horného krytu 
<intxreftitleoff1 refid = "ASLAP70A9B06006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Plech podbehu, predĺženie plechu podbehu a horná konzola zavesenia 
<intxreftitleoff1 refid = "ASLAP70A9B06007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0010.jpg" width = "88.000mm" height = "56.208mm" ver = "01" gw = "227" gh = "143"/>
</figure>
<servinfosub id = "ASLAP70A9B06003001">
<title>
Všeobecné poznámky
</title>
<ptxt>
Spôsob zvárania a počet bodov zvaru je ten istý na oboch stranách. Tieto pokyny na opravu zobrazujú postup pre ľavú stranu.
</ptxt>
</servinfosub>
<servinfosub id = "ASLAP70A9B06003002">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odvŕtajte body zvarov a odmontujte časť s motorovým priestorom.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0011.jpg" width = "183.000mm" height = "196.851mm" ver = "06" gw = "496" gh = "541"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.466in"/>
<colspec colnum = "2" colname = "2" colwidth = "5.199in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Ak je to potrebné, vybrúste body zvaru pomocou brúsky.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9B06003003">
<title>
Montáž
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Pred zváraním skontrolujte polohu inštalácie a stav inštalačnej časti (častí). 
<intxreftitleoff1 refid = "ASLAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "ASLAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
V oprave pokračujte berúc do úvahy inštaláciu častí, ktoré majú vplyv na vzhľad. 
<intxreftitleoff1 refid = "ASLAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention2>
<s1>
<ptxt>
Namontujte časť s motorovým priestorom.
</ptxt>
</s1>
<s1>
<ptxt>
Vykonajte odporové bodové zváranie a dierové zváranie.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0012.jpg" width = "183.000mm" height = "196.851mm" ver = "04" gw = "492" gh = "541"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
