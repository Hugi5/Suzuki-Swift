<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9B06023" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž zadnej bočnej časti zadnej podlahy, zadné predĺženie bočnej časti zadnej podlahy a zadný plech zadnej podlahy (čiastočné)
</title>
<attention3>
<ptxt>
Nižšie uvedený obrázok zobrazuje podmienky odstraňovania nasledovných častí.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predný blatník 
<intxreftitleoff1 refid = "ASLAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zadný panel 
<intxreftitleoff1 refid = "ASLAP70A9B06021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0170.jpg" width = "88.000mm" height = "48.926mm" ver = "02" gw = "227" gh = "122"/>
</figure>
<servinfosub id = "ASLAP70A9B06023001">
<title>
Všeobecné poznámky
</title>
<list1 type = "unordered">
<item>
<ptxt>
Spôsob zvárania a počet bodov zvaru je ten istý na oboch stranách. Tieto pokyny na opravu zobrazujú postup pre ľavú stranu.
</ptxt>
</item>
<item>
<ptxt>
Zadný plech zadnej podlahy sa môže použiť opätovne.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "ASLAP70A9B06023002">
<title>
Demontáž
</title>
<s1>
<ptxt>
Označte v zobrazenej polohe a odrežte zadný plech zadnej podlahy.
</ptxt>
<attention2>
<ptxt>
Pri rezaní nepoškoďte časti pod zadným plechom zadnej podlahy.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Odvŕtajte body zvaru a odstráňte zadný plech zadnej podlahy.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0020V.jpg" width = "183.000mm" height = "128.243mm" ver = "01" gw = "463" gh = "347"/>
</figure>
</s1>
<s1>
<ptxt>
Odvŕtajte body zvaru a odstráňte zadnú bočnú časť zadnej podlahy a zadné predĺženie bočnej časti zadnej podlahy.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0021.jpg" width = "183.000mm" height = "220.754mm" ver = "01" gw = "460" gh = "609"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.411in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Ak je to potrebné, vybrúste body zvaru pomocou brúsky.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A9B06023003">
<title>
Montáž
</title>
<attention3>
<ptxt>
Pred zváraním skontrolujte polohu inštalácie a stav inštalačnej časti (častí). 
<intxreftitleoff1 refid = "ASLAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1>
<ptxt>
Namontujte zadnú bočnú časť zadnej podlahy a zadné predĺženie bočnej časti zadnej podlahy.
</ptxt>
</s1>
<s1>
<ptxt>
Vykonajte odporové bodové zváranie alebo dierové zváranie.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0022.jpg" width = "183.000mm" height = "220.754mm" ver = "01" gw = "460" gh = "609"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte zadný plech zadnej podlahy.
</ptxt>
</s1>
<s1>
<ptxt>
Vykonajte odporové bodové zváranie alebo dierové zváranie.
</ptxt>
</s1>
<s1>
<ptxt>
Vykonajte priebežný zvar.
</ptxt>
</s1>
<s1>
<ptxt>
Na zadnú stranu časti s priebežným zvarom aplikujte antikorozívny vosk.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0023V.jpg" width = "183.000mm" height = "128.243mm" ver = "01" gw = "463" gh = "347"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
