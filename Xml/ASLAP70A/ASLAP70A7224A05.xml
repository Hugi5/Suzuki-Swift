<servinfo servinfosgmlid = "ASLAP70A7224A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Chladný vzduch prúdi prerušovane
</title>
<diag type = "condition">
<condition>
<ptxt>
Chladný vzduch prúdi prerušovane
</ptxt>
</condition>
<ps>
<ptxt>
Chybné pripojenie káblového zväzku
</ptxt>
</ps>
<action>
<ptxt>
Ak je to potrebné opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha expanzného ventilu
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte expanzný ventil. 
<intxreftitleoff1 refid = "ASLAP70A7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nadmerná vlhkosť v klimatizačnom systéme
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kondenzátor a potom systém vypustite a znova naplňte. 
<intxreftitleoff1 refid = "ASLAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha magnetickej spojky
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte magnetickú spojku. 
<intxreftitleoff1 refid = "ASLAP70A7226047"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nadbytok chladiacej zmesi
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte množstvo chladiacej zmesi.
</ptxt>
</action>
</diag>
