<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A7226009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž panela automatickej klimatizácie
</title>
<servinfosub id = "ASLAP70A7226009001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Zložte prednú podlahovú skriňu prístrojovej dosky. 
<intxreftitleoff1 refid = "ASLAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte panel združeného prístroja a stredovú časť ventilačnej mriežky. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Audio jednotku vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A9F06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte jednotku (inflátor) airbagu spolujazdca. 
<intxreftitleoff1 refid = "ASLAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte kryty strednej strany. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte panel automatickej klimatizácie (1) z prístrojovej dosky.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor panela automatickej klimatizácie.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723013.swf" width = "88.000mm" height = "64.865mm" ver = "03" gw = "233" gh = "167"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7226009002">
<title>
Montáž
</title>
<ptxt>
Postupujte ako pri demontáži, ale v opačnom poradí.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
