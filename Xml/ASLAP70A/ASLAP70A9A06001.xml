<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A9A06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž kapoty
</title>
<servinfosub id = "ASLAP70A9A06001001">
<title>
Demontáž
</title>
<attention2>
<ptxt>
Prikryte karosériu vozidla látkou, aby ste predišli poškodeniu.
</ptxt>
</attention2>
</servinfosub>
<s1>
<ptxt>
Na odtiahnutie kapoty (2) odmontujte 4 skrutky pántu kapoty (1).
</ptxt>
</s1>
<s1>
<ptxt>
Po demontáži predného blatníka podľa potreby odmontujte pánty dverí. 
<intxreftitleoff1 refid = "ASLAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<servinfosub id = "ASLAP70A9A06001002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A9A06002">Kontrola a nastavenie kapoty</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Na kontaktnú plochu „A“ pántu kapoty naneste tesniaci prostriedok.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1215" id = "M9J001" uid = "27">
<m-part>
„A“
</m-part>
<m-desc>
Tesniaci prostriedok
</m-desc>
<m-number>
99000–31110
</m-number>
<m-name>
SUZUKI Bond No.1215
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Ak je to nutné, nastavte polohu zámky kapoty. 
<intxreftitleoff1 refid = "ASLAP70A9A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ak sa farba zo skrutiek jazýčka kapoty olúpala, zabezpečte, aby sa naniesla znovu, aby ste predišli korózii.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9A0001.swf" width = "88.000mm" height = "90.826mm" ver = "01" gw = "226" gh = "241"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
