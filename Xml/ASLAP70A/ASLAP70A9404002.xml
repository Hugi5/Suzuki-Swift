</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9406002">Kontrola čerpadla ostrekovača</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača stierača a ostrekovača (spínač ostrekovača)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9406008">Kontrola spínača stierača a ostrekovača</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
</diag>
