<title>
Diagnostika symptómov stierača a ostrekovača
</title>
<servinfosub id = "ASLAP70A9404002001">
<title>
Stierač a ostrekovač čelného skla
</title>
<diag type = "condition" id = "ASLAP70A9404002002">
<condition>
<ptxt>
Poruchy stierača
</ptxt>
</condition>
<ps>
<ptxt>
Porucha motora stierača čelného skla
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9406004">Kontrola činnosti motorčeka stierača čelného skla</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača stierača a ostrekovača (spínač stierača)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9406008">Kontrola spínača stierača a ostrekovača</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<condition>
<ptxt>
Nesprávna činnosť ostrekovača
</ptxt>
</condition>
<ps>
<ptxt>
Porucha hadice ostrekovača (vrátane kontrolného ventilu a konektora) alebo trysky ostrekovača
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte hadicu alebo trysku ostrekovača, či nie je upchatá alebo skrútená. 
<intxreftitleoff1 refid = "ASLAP70A9403001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha čerpadla ostrekovača
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9406002">Kontrola čerpadla ostrekovača</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača stierača a ostrekovača (spínač ostrekovača)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9406008">Kontrola spínača stierača a ostrekovača</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ASLAP70A9404002003">
<title>
