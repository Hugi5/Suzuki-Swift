<servinfo servinfosgmlid = "ASLAP70A9806010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž koberca podlahy
</title>
<servinfosub id = "ASLAP70A9806010001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte sedadlo.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predné sedadlo: 
<intxreftitleoff1 refid = "ASLAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zadné sedadlo: 
<intxreftitleoff1 refid = "ASLAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Odmontujte nasledovné prahy a obloženia. 
<intxreftitleoff1 refid = "ASLAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Predné vnútorné nástupné prahy
</ptxt>
</item>
<item>
<ptxt>
Zadné vnútorné nástupné prahy
</ptxt>
</item>
<item>
<ptxt>
Bočné obloženie palubnej dosky
</ptxt>
</item>
<item>
<ptxt>
Dolné obloženia stredového stĺpika
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Zložte prednú/zadnú skriňu stredovej konzoly. 
<intxreftitleoff1 refid = "ASLAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte kryt kĺbu riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte 5 svoriek (1) a doraz plynového pedála (2) a potom odmontujte koberec na podlahe (3).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A980007.jpg" width = "88.000mm" height = "60.725mm" ver = "02" gw = "238" gh = "156"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
