<servinfosub id = "ASLAP70A1704005002">
<title>
Riešenie problémov
</title>
<attention3>
<ptxt>
Pred vykonaním nasledovnej procedúry sa uistite, že napätie akumulátora je najmenej 11 V. Ak je nižšie, tlak paliva je nižší ako predpísané hodnoty, aj keď je palivové čerpadlo a vedenie v dobrom stave.
</ptxt>
</attention3>
<diag type = "test" id = "ASLAP70A1704005003">
<testgroup id = "ASLAP70A1704005004">
<question>
Bola vykonaná „Kontrola palivového čerpadla a jeho obvodu“? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1704004">Kontrola palivového čerpadla a jeho obvod</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704005005">
<title>
Kontrola tlaku paliva 1
</title>
<test1>
<ptxt>
Skontrolujte tlak paliva. 
<intxreftitleoff1 refid = "ASLAP70A1704006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704005006">
<title>
Kontrola tlaku paliva 2
</title>
<test1>
<ptxt>
Naštartujte motor a zohrejte ho na bežnú prevádzkovú teplotu.
</ptxt>
</test1>
<test1>
<ptxt>
Otáčky motora udržujte na 4 000 ot/m.
</ptxt>
</test1>
<question>
Vykazuje tlak paliva rovnaké hodnoty ako v kroku 2?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ak je regulátor tlaku paliva v zlom stave, vymeňte zostavu palivového čerpadla. 
<intxreftitleoff1 refid = "ASLAP70A1706015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704005007">
<title>
Kontrola palivového potrubia
</title>
<test1>
<ptxt>
Skontrolujte, či palivové potrubie alebo spoj nie sú poškodené alebo zdeformované.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Palivový systém je v dobrom stave.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Chybné časti opravte.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704005008">
<title>
Kontrola palivového potrubia
</title>
<test1>
<ptxt>
Skontrolujte, či palivové potrubie alebo spoj nie sú poškodené alebo zdeformované.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Upchatý palivový filter, porucha regulátora tlaku paliva alebo presakovanie paliva z hadicovej prípojky v palivovej nádrži.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Chybné časti opravte.
</ptxt>
</action>
</testgroup>
