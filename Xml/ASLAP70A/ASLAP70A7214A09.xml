<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A7214A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vzduch prúdi len pri vysokej rýchlosti
</title>
<diag type = "condition">
<condition>
<ptxt>
Vzduch prúdi len pri vysokej rýchlosti
</ptxt>
</condition>
<ps>
<ptxt>
Upchatý kondenzátor
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte kondenzátor. 
<intxreftitleoff1 refid = "ASLAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nedostatok chladiacej zmesi
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte, či je v systéme správne množstvo chladiacej kvapaliny a či kvapalina zo systému neuniká.
</ptxt>
</action>
<ps>
<ptxt>
Vzduch v klimatizačnom systéme
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte kondenzátor a potom chladiacu kvapalinu vypustite a znova naplňte. 
<intxreftitleoff1 refid = "ASLAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnite hnací remeň kompresora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte hnací remeň kompresora. 
<intxreftitleoff1 refid = "ASLAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kompresora
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte kompresor.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
