<servinfosub id = "ASLAP70A7224028002">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<ptxt>
Pred vykonaním tohto postupu sa najskôr uistite, že sú splnené nasledovné podmienky.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
U0073, U0100, U0140 a/alebo U0155 nie sú detekované.
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
<s1>
<ptxt>
B1557: Jazdite vozidlom približne 1 minútu.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224028003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224028004">
<testgroup id = "ASLAP70A7224028005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Skontrolujte DTC v riadiacej jednotke motora. 
<intxreftitleoff1 refid = "ASLAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Našli ste nejaké DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným procesom riešenia DTC. 
<intxreftitleoff1 refid = "ASLAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku HVAC a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
