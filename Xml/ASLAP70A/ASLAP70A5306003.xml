<servinfo servinfosgmlid = "ASLAP70A5306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spínača CPP č. 2
</title>
<servinfosub id = "ASLAP70A5306003001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odpojte konektor spínača CPP č. 2 (1) pri vypnutom spínači zapaľovania.
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte spínač CPP č. 2 (1) z konzoly pedála spojky.
</ptxt>
<figure>
<graphic graphicname = "I9P60A531001.swf" width = "88.000mm" height = "79.324mm" ver = "01" gw = "99" gh = "208"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A5306003002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A5306004">Kontrola a nastavenie spínača CPP č. 2</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Nasaďte na konzolu pedála spojky spínač CPP č. 2.
</ptxt>
</s1>
<s1>
<ptxt>
Nastavte polohu spínača. 
<intxreftitleoff1 refid = "ASLAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pripojte poriadne konektor spínača CPP č. 2.
</ptxt>
</s1>
</servinfosub>
</servinfo>
