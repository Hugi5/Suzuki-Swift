<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1306017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž snímača polohy vačkového hriadeľa (CMP)
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1306016">Kontrola snímača CMP na vozidle</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1306017001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Na akumulátore odpojte kábel záporného (-) pólu.
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor zo snímača nasávania CMP (1) a snímača výfuku CMP (2).
</ptxt>
</s1>
<s1>
<ptxt>
Od hlavy valca odpojte konektor zo snímača nasávania CMP (1) a snímača výfuku CMP (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A131006.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1306017002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1306018">Kontrola snímača CMP</intxrefpoff>
</ptxt>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Naneste motorový olej na tesniaci krúžok.
</ptxt>
</item>
<item>
<ptxt>
Skrutku snímača polohy vačkového hriadeľa utiahnite na predpísaný uťahovací moment.
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Použite nové skrutky, ktoré sú natreté vopred lepiacim prostriedkom. V opačnom prípade sa skrutky môžu uvoľniť.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1C005">
<t-part>
Skrutka snímača nasávania CMP
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1C006">
<t-part>
Skrutka snímača výfukov CMP
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131007.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
