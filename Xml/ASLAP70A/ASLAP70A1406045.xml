<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1406045" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kontrola zotrvačníka
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1406021">Demontáž a montáž zotrvačníka</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1406045001">
<title>
Vizuálna prehliadka
</title>
<list1 type = "unordered">
<item>
<ptxt>
Ak je prevod poškodený, prasknutý alebo opotrebovaný, vymeňte zotrvačník.
</ptxt>
</item>
<item>
<ptxt>
Ak je povrch, ktorý sa dotýka kotúča spojky poškodený alebo nadmerne opotrebovaný, vymeňte zotrvačník.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "ASLAP70A1406045002">
<title>
Hádzanie čela zotrvačníka
</title>
<ptxt>
Skontrolujte hádzanie čela zotrvačníka pomocou mikrometrického meradla. 
</ptxt>
<ptxt>
Ak je hádzanie mimo tolerancie, vymeňte zotrvačník.
</ptxt>
<spec>
<title>
Stranové hádzanie zotrvačníka / taniera pohonu
</title>
<ptxt>
Limit: 0,2 mm (0,2007 mm.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I2RH01140198.swf" width = "88.000mm" height = "42.110mm" ver = "01" gw = "183" gh = "102"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
