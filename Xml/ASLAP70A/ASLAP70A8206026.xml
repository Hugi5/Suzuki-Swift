<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A8206026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spínača deaktivovania airbagu spolujazdca
</title>
<servinfosub id = "ASLAP70A8206026001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Demontujte odkladaciu skrinku. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte konektor (1) zo spínača deaktivovania airbagov spolujazdca.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820078.swf" width = "88.000mm" height = "87.000mm" ver = "01" gw = "231" gh = "230"/>
</figure>
</s1>
<s1>
<ptxt>
Demontujte spínač deaktivovania airbagov spolujazdca (1), pričom uvoľňujete poistky (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820079.swf" width = "88.000mm" height = "59.573mm" ver = "02" gw = "207" gh = "152"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A8206026002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A8206027">Kontrola spínača deaktivovania airbagu spolujazdca</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Namontujte spínač deaktivovania airbagov spolujazdca (1) zarovnaním jeho vypuklej časti (2) so otvorom (3) prístrojovej dosky.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820080.swf" width = "88.000mm" height = "64.695mm" ver = "01" gw = "207" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Pripojte konektor spínača deaktivovania airbagov spolujazdca.
</ptxt>
</s1>
<s1>
<ptxt>
Montáž odkladacej skrinky. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
