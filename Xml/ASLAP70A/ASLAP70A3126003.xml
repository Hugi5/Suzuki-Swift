<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A3126003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž sústavy zadného hnacieho hriadeľa
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A3126001">Komponenty zadného hnacieho hriadeľa:Zadný</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A3126002">Kontrola sústavy zadného hnacieho hriadeľa na vozidle:Zadný</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A3126003001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Zdvihnite vozidlo dielenským zdvihákom a zložte zadné koleso. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odstráňte utesnenie (1) a demontujte maticu hnacieho hriadeľa (2), pričom je brzdový pedál vytlačený.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312002.swf" width = "88.000mm" height = "53.091mm" ver = "01" gw = "177" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Odmontujte matice príruby zadného hnacieho hriadeľa (1) a odmontujte zostavu zadného hnacieho hriadeľa.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312003.swf" width = "88.000mm" height = "47.465mm" ver = "01" gw = "177" gh = "118"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A3126003002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dotiahnite novú maticu (1) hnacieho hriadeľa na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T3A202">
<t-part>
Matica hnacieho hriadeľa
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Maticu hnacieho hriadeľa (1) utesnite podľa obrázku.
</ptxt>
<attention2>
<ptxt>
Dbajte na to, aby ste pri utesňovaní matice hnacieho hriadeľa nepoškodili jej tesniacu časť (2). Ak je prasknutá, vymeňte ju za novú.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A312004.swf" width = "88.000mm" height = "52.301mm" ver = "01" gw = "159" gh = "132"/>
</figure>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Dotiahnite matice príruby zadného hnacieho hriadeľa na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T3A203">
<t-part>
Matica príruby zadného hnacieho hriadeľa
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A312005.swf" width = "88.000mm" height = "49.964mm" ver = "01" gw = "177" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Na dosadacie plochy zostavy hlavy zadného kolesa a zadný hnací hriadeľ naneste vazelínu.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A202" uid = "1126491901">
<m-part>
„A“
</m-part>
<m-desc>
Mazací tuk
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A312006.swf" width = "88.000mm" height = "54.175mm" ver = "02" gw = "227" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Utiahnite matice kolesa na predpísaný uťahovací moment. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
