<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1706019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž pomocného snímača hladiny paliva
</title>
<attention2>
<ptxt>
Nedotýkajte sa žiaruvzdornej dosky (1) a nezdeformujte rameno (2). Týmto môžete spôsobiť zlyhanie pomocného snímača hladiny paliva.
</ptxt>
<figure>
<graphic graphicname = "IAP70P170014.swf" width = "88.000mm" height = "66.314mm" ver = "01" gw = "154" gh = "171"/>
</figure>
</attention2>
<servinfosub id = "ASLAP70A1706019001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Z vozidla demontujte palivovú nádrž. 
<intxreftitleoff1 refid = "ASLAP70A1706011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pomocou špeciálneho nástroja demontujte zaisťovaciu maticu palivového čerpadla (1) z palivovej nádrže (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L1G015">
<s-part>
(A)
</s-part>
<s-number num = "09941-51013">
09941–51013
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A171016.swf" width = "88.000mm" height = "51.053mm" ver = "01" gw = "137" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Pomaly zodvihnite pomocný snímač hladiny paliva (1) a odpojte palivovú nasávaciu hadicu (2) od pomocného snímača hladiny paliva. 
<intxreftitleoff1 refid = "ASLAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "IAP70P170015.swf" width = "88.000mm" height = "87.698mm" ver = "01" gw = "171" gh = "232"/>
</figure>
</s1>
<s1>
<ptxt>
Z palivovej nádrže odmontujte pomocný snímač hladiny paliva a tesniaci krúžok.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1706019002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1706018">Kontrola snímača hladiny paliva</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Vyčistite vonkajšie povrchy potrubia, kam chcete pripevniť spoj. Spoj zatlačte na potrubie, až kým nezačujete kliknutie. A skontrolujte, či sú potrubia pripojené pevne. Ak tak neurobíte, môže to viesť k unikaniu paliva.
</ptxt>
</attention2>
<s1>
<ptxt>
Očistite povrch častí, ktoré budú spájať jednotku palivového čerpadla s palivovou nádržou.
</ptxt>
</s1>
<s1>
<ptxt>
K palivovej nádrži (2) namontujte nový tesniaci krúžok (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B170007.swf" width = "88.000mm" height = "56.952mm" ver = "01" gw = "199" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Palivové nasávacie potrubie (2) pripojte k pomocnému snímaču hladiny paliva (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70P170015.swf" width = "88.000mm" height = "87.698mm" ver = "01" gw = "171" gh = "232"/>
</figure>
</s1>
<s1>
<ptxt>
Na palivovú nádrž (2) namontujte pomocný snímač hladiny paliva (1) nasledovne.
</ptxt>
<s2>
<ptxt>
Značku šípky (3) na pomocnom snímači hladiny paliva vyrovnajte s výrezom (4) palivovej nádrži.
</ptxt>
</s2>
<s2>
<ptxt>
Pomocný snímač hladiny paliva stláčajte dole rukou, až kým sa nedostane do kontaktu s palivovou nádržou tak, ako je to zobrazené na obrázku.
</ptxt>
<figure>
<graphic graphicname = "IBP60B170008.swf" width = "88.000mm" height = "90.025mm" ver = "01" gw = "219" gh = "239"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.857in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Tesniaci krúžok
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
V stave kroku b) dotiahnite novú poistnú maticu palivového čerpadla (1) rukou.
</ptxt>
<attention2>
<ptxt>
Používajte iba novú poistnú maticu palivového čerpadla. Opätovné použitie poistnej matice palivového čerpadla môže viesť k unikaniu paliva.
</ptxt>
</attention2>
<attention3>
<ptxt>
Poistnú maticu doťahujte tak, že ju budete rovno stláčať, aby sa nevychyľovala.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A170015.swf" width = "88.000mm" height = "60.021mm" ver = "01" gw = "128" gh = "154"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.545in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.850in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Pomocný snímač hladiny paliva
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Tesniaci krúžok
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Palivová nádrž
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
Pomocou špeciálneho nástroja dotiahnite poistnú maticu palivového čerpadla (1), kým nie sú značky (3) poistnej matice palivového čerpadla a palivovej nádrže zarovnané.
</ptxt>
<attention3>
<ptxt>
Značky sú zarovnané, keď poistnú maticu palivového čerpadla dotiahnete približne o 1 a 1/3 otáčky.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1G016">
<s-part>
(A)
</s-part>
<s-number num = "09941-51013">
09941–51013
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A171018.swf" width = "88.000mm" height = "89.624mm" ver = "01" gw = "152" gh = "238"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Do vozidla namontujte palivovú nádrž. 
<intxreftitleoff1 refid = "ASLAP70A1706011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
