<servinfo servinfosgmlid = "ASLAP70A5206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž spínača svetla spiatočky
</title>
<servinfosub id = "ASLAP70A5206007001">
<title>
Demontáž
</title>
<s1 page = "2">
<ptxt>
Odmontujte ECM z vane akumulátora. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte akumulátor a držiak akumulátora. 
<intxreftitleoff1 refid = "ASLAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odpojte spojovací prvok spínača svetla spiatočky (1).
</ptxt>
</s1>
<s1>
<ptxt>
Demontujte spínač zadných svetiel (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A520006.jpg" width = "88.000mm" height = "56.038mm" ver = "01" gw = "199" gh = "142"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A5206007002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A5206008">Kontrola spínača svetla spiatočky</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Namažte nový tesniaci krúžok (1) a utiahnite spínač svetla spiatočky (2) na predpísaný moment.
</ptxt>
<torque>
<torqueitem id = "T5B004">
<t-part>
Spínač svetla spiatočky
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I3RH0A520006.swf" width = "88.000mm" height = "31.317mm" ver = "01" gw = "148" gh = "73"/>
</figure>
</s1>
<s1>
<ptxt>
Pripojte spojovací prvok spínača svetla spiatočky.
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte akumulátor a akumulátor. 
<intxreftitleoff1 refid = "ASLAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte ECM do vane akumulátora. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
