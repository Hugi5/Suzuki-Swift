<servinfo servinfosgmlid = "ASLAP70A1104045" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0606
</title>
<servinfosub id = "ASLAP70A1104045001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.643in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.554in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0606: Procesor riadiacej jednotky
</emph>
</ptxt>
<ptxt>
Chyba interného procesoru ECM.
</ptxt>
<ptxt>
(Logika rozpoznávania 3 jazdného cyklu)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Obvod napájania a/alebo obvod uzemnenia ECM
</ptxt>
</item>
<item>
<ptxt>
Snímač A/F
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70A1104045002">
<title>
Popis systému
</title>
<ptxt>
Interný riadiaci modul je namontovaný v riadiacej jednotke motora.
</ptxt>
</servinfosub>
<servinfosub id = "ASLAP70A1104045003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 10,7 V
</ptxt>
</item>
<item>
<ptxt>
DTC P0030, P0031, P0032, P0131 alebo P0132 nie sú detekované.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Motor nechajte 1 min. bežať na voľnobežných otáčkach.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104045004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104045005">
<testgroup id = "ASLAP70A1104045006">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymažte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte postup potvrdenia DTC a skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC P0606?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte kvôli občasným problémom. 
<intxreftitleoff1 refid = "ASLAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104045007">
<title>
Kontrola obvodu uzemnenia a napájania riadiacej jednotky motora
</title>
<test1>
<ptxt>
Skontrolujte napájací a uzemňovací okruh riadiacej jednotky motora. 
<intxreftitleoff1 refid = "ASLAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104045008">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymeňte snímač A/F. 
<intxreftitleoff1 refid = "ASLAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte postup potvrdenia DTC a skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC P0606?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
