<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A9604001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnostika symptómov systému centrálneho uzamykania
</title>
<diag type = "condition" id = "ASLAP70A9604001001">
<condition>
<ptxt>
Nie je možné zamknúť alebo odomknúť iba jedny dvere
</ptxt>
</condition>
<ps>
<ptxt>
Porucha obvodu systému (vrátane relé a poistiek)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Chyba zostavy zámky dverí (vrátane tyče otvorenia zámky dverí a vodičov zámky dverí)
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte tyč otvorenia zámky dverí a káble zámky dverí. 
<intxreftitleoff1 refid = "ASLAP70A9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodená alebo zdeformovaná vnútorná rukoväť dverí
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte vnútornú rukoväť dverí 
<intxreftitleoff1 refid = "ASLAP70A9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Všetky dvere sa nedajú zamknúť/odomknúť
</ptxt>
</condition>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Obráťte sa na „Kontrola BCM a jej obvodov“ v časti 10B.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky bezkľúčového štartovania (model s bezkľúčovým štartovaním)
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70AA504031">Kontrola riadiacej jednotky bezkľúčového štartovania a jeho obvodov</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha obvodu systému (vrátane relé a poistiek)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača centrálneho uzamykania dverí.
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70A9606009">Kontrola spínača centrálneho uzamykania</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha vložky zámky dverí
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte vložku zámky dvier. 
<intxreftitleoff1 refid = "ASLAP70A9606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Žiadne dvere sa nedajú zamknúť/odomknúť iba pomocou systému bezkľúčového odomykania alebo pomocou diaľkového ovládača
</ptxt>
</condition>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Obráťte sa na „Kontrola BCM a jej obvodov“ v časti 10B.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky bezkľúčového štartovania (model s bezkľúčovým štartovaním)
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70AA504031">Kontrola riadiacej jednotky bezkľúčového štartovania a jeho obvodov</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha obvodu systému (vrátane relé a poistiek)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Porucha vysielača (model so spínačom zapaľovania)
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte akumulátor. 
<intxreftitleoff1 refid = "ASLAP70A9606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha diaľkového ovládača (model s bezkľúčovým štartovaním)
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte akumulátor. 
<intxreftitleoff1 refid = "ASLAP70AA506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Porucha prijímača diaľkového ovládania centrálnej zámky dverí
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70A9606016">Kontrola prijímača bezkľúčového vstupu</intxref>
.
</ptxt>
</action>
<condition>
<ptxt>
Porucha spínača požiadavky (model s bezkľúčovým štartovaním)
</ptxt>
</condition>
<ps>
<ptxt>
Porucha diaľkového ovládača
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte akumulátor. 
<intxreftitleoff1 refid = "ASLAP70AA506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70AA504031">Kontrola riadiacej jednotky bezkľúčového štartovania a jeho obvodov</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha obvodu systému (vrátane relé a poistiek)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača požiadavky dverí
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70AA506009">Kontrola spínača požiadavky</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha riadiacej jednotky systému bezkľúčového štartovania
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70AA504031">Kontrola riadiacej jednotky bezkľúčového štartovania a jeho obvodov</intxref>
.
</ptxt>
</action>
<condition>
<ptxt>
Porucha funkcie odozvy výstražných svetiel
</ptxt>
</condition>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Obráťte sa na „Kontrola BCM a jej obvodov“ v časti 10B.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Porucha obvodu systému (vrátane relé a poistiek)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
</diag>
</servinfo>
