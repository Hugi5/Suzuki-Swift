<title>
DTC B1571
</title>
<servinfosub id = "ASLAP70A7224030001">
<title>
Podmienky rozoznania DTC a problémová oblasť
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.922in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.288in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Podmienky rozoznania DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problémová oblasť
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1571: Porucha signálu špecifikácie združeného prístroja
</emph>
</ptxt>
<ptxt>
Riadiaca jednotka HVAC prijala nesprávne údaje signálu špecifikácie združeného prístroja zo zdurženého prístroja.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Združený merač
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka HVAC
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASLAP70A7224030002">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224030003">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A7224030004">
<testgroup id = "ASLAP70A7224030005">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Zapnite spínač zapaľovania a skontrolujte DTC.
</ptxt>
</test1>
<question>
Ešte stále sa zisťuje DTC B1571?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Nahraďte overeným združeným meračom a/alebo riadiacou jednotkou HVAC a opäť skontrolujte DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Združený merač: 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Riadiaca jednotka HVAC: 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
</diag>
