<servinfosub id = "ASLAP70AA204014003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70AA204014004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70AA204014005">
<testgroup id = "ASLAP70AA204014006">
<title>
Kontrola DTC
</title>
<question>
Je DTC B1132 zistený súčasne?
</question>
<result type = "yes"/>
<action>
<ptxt>
Pokračujte príslušným postupom riešenia DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204014009">
<title>
Kontrola parametrov
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte „Outside Air Temp“ zobrazenú na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204014007">
<title>
Kontrola obvodu snímača vonkajšej teploty vzduchu
</title>
<test1>
<ptxt>
Spínač zapaľovania sa nachádza v polohe OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Odpojte snímač teploty vonkajšieho vzduchu a nasledovné konektory.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: Konektor “E04”
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: Konektor “E05”
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Skontrolujte správne pripojenie k snímaču teploty vonkajšieho vzduchu a nasledovné konektory.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: Konektor “E04”
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: Konektor “E05”
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Ak sú pripojenia v poriadku, skontrolujte nasledovné.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Odpor obvodov „A1“ alebo „A2“: menej ako 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi obvodom „A1“ a uzemnením: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Odpor medzi svorkami obvodu “A1” a “A2” v konektore teploty vonkajšieho vzduchu: nekonečno
</ptxt>
</item>
<item>
<ptxt>
Napätie obvodov „A1“ alebo „A2“: 0 – 1 V (keď je zapaľovanie zapnuté)
</ptxt>
</item>
</list1>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204014008">
<title>
Kontrola snímača teploty vonkajšieho vzduchu
</title>
<test1>
<ptxt>
Kontrola senzora vonkajšej teploty vzduchu. 
<intxreftitleoff1 refid = "ASLAP70AA206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte senzor vonkajšej teploty vzduchu. 
<intxreftitleoff1 refid = "ASLAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70AA204014010">
<title>
Kontrola DTC
</title>
<test1>
<ptxt>
Nastavte zapaľovanie na „OFF (VYP)“.
</ptxt>
</test1>
<test1>
<ptxt>
Pripojte snímač teploty vonkajšieho vzduchu a nasledovné konektory.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model so spínačom zapaľovania: Konektor “E04”
</ptxt>
</item>
<item>
<ptxt>
Model s bezkľúčovým štartovaním: Konektor “E05”
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú detekované aktuálne DTC B1141 alebo B1142?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte BCM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec. (Občasná chyba)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
