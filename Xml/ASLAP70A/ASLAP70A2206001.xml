<sdm-title>
Predná zbiehavosť (celková)
</sdm-title>
<sdm-part>
„b“ – „a“
</sdm-part>
<sdm1>
<sdm-condition>
</sdm-condition>
<sdm-value>
Dnu 1 &#177; 1 mm (0,04 &#177; 0,04 in.)
</sdm-value>
</sdm1>
</spec-sdm>
<figure>
<graphic graphicname = "I7V10A220002.swf" width = "88.000mm" height = "63.339mm" ver = "02" gw = "154" gh = "163"/>
