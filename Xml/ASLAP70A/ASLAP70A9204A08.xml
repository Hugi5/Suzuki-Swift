<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A9204A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Obrysové svetlá, koncové svetlá alebo osvetlenie ŠPZ nesvietia
</title>
<diag type = "condition">
<condition>
<ptxt>
Obrysové svetlá, koncové svetlá alebo osvetlenie ŠPZ nesvietia
</ptxt>
</condition>
<ps>
<ptxt>
Porucha obvodu systému (vrátane relé a poistiek)
</ptxt>
</ps>
<action>
<ptxt>
Opravte obvod.
</ptxt>
</action>
<ps>
<ptxt>
Vypálené žiarovky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte žiarovky.
</ptxt>
</action>
<ps>
<ptxt>
Porucha osvetlenia a spínača signálu zapnutia
</ptxt>
</ps>
<action>
<ptxt>
Pozrite 
<intxref refid = "ASLAP70A9206015">Kontrola spínača osvetlenia a smerovky</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Obráťte sa na „Kontrola BCM a jej obvodov“ v časti 10B.
</ptxt>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
