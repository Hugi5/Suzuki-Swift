<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A1704001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Kontrola palivového systému
</title>
<diag type = "test" id = "ASLAP70A1704001001">
<testgroup id = "ASLAP70A1704001002">
<title>
Kontrola palivového čerpadla
</title>
<test1>
<ptxt>
Odmontujte veko plniaceho hrdla palivovej nádrže a zapnite zapaľovanie.
</ptxt>
</test1>
<test1>
<ptxt>
Uistite sa, že z portu hrdla palivovej nádrže počujete prevádzkový zvuk palivového čerpadla pribl. 2 sekundy po zastavení.
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte obvod palivového čerpadla. 
<intxreftitleoff1 refid = "ASLAP70A1704004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704001003">
<title>
Kontrola tlaku paliva
</title>
<test1>
<ptxt>
Skontrolujte tlak paliva. 
<intxreftitleoff1 refid = "ASLAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Chybné časti opravte.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704001004">
<title>
Kontrola výkonovej rovnováhy
</title>
<test1>
<ptxt>
Skontrolujte výkonovú rovnováhu. 
<intxreftitleoff1 refid = "ASLAP70A1704002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Palivový systém je v dobrom stave.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704001005">
<title>
Kontrola obvodu vstrekovacieho ventilu
</title>
<test1>
<ptxt>
Skontrolujte obvod vstrekovacieho ventilu paliva. 
<intxreftitleoff1 refid = "ASLAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Chybné časti opravte.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1704001006">
<title>
Kontrola vstrekovacieho ventilu
</title>
<test1>
<ptxt>
Skontrolujte vstrekovací ventil paliva. 
<intxreftitleoff1 refid = "ASLAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Chybný vstrekovací ventil vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
