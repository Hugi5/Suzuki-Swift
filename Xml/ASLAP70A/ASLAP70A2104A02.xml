<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nadmerné opotrebovanie pneumatík
</title>
<diag type = "condition">
<condition>
<ptxt>
Nadmerné opotrebovanie pneumatík
</ptxt>
</condition>
<ps>
<ptxt>
Zlomené alebo prevísajúce vinuté pružiny
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vymeňte vinuté pružiny. 
</ptxt>
<ptxt>
Predné: 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zadné: 
<intxreftitleoff1 refid = "ASLAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Nevyvážené koleso
</ptxt>
</ps>
<action>
<ptxt>
Pneumatiku vyvážte alebo vymeňte.
</ptxt>
</action>
<ps>
<ptxt>
Narušená geometria kolies
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte a nastavte geometriu kolies. 
<intxreftitleoff1 refid = "ASLAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Chybná zostava prednej vzpery (tlmič odpruženia)
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte zostavu prednej vzpery (tlmič odpruženia). 
<intxreftitleoff1 refid = "ASLAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Namáhavé riadenie
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte pneumatiky. 
<intxreftitleoff1 refid = "ASLAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Preťažené vozidlo
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte náklad vozidla.
</ptxt>
</action>
<ps>
<ptxt>
Pneumatiky sa nestriedali s ostatnými
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte pneumatiky alebo ich vystriedajte.
</ptxt>
</action>
<ps>
<ptxt>
Opotrebované alebo uvoľnené ložisko kolesa
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte ložisko kolesa. 
<intxreftitleoff1 refid = "ASLAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hádzanie kolesa alebo pneumatiky
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte koleso alebo pneumatiku.
</ptxt>
</action>
<ps>
<ptxt>
Nesprávny tlak v pneumatikách
</ptxt>
</ps>
<action>
<ptxt>
Upravte tlak v pneumatikách.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
