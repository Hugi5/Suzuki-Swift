<servinfosub id = "ASLAP70A1104053003">
<title>
Postup potvrdenia DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Uistite sa, že ste vyriešili predtým detekované DTC v „Postup potvrdenia DTC“.
</ptxt>
</item>
<item>
<ptxt>
Potvrďte, že nasledovné podmienky sú splnené v tomto „Postupe potvrdenia DTC“.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Napätie akumulátora &#62; 8 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
IAT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
DTC P0122, P0123, P0222, P0223, P2135 alebo P2176 nie sú detekované.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Nastavte zapaľovanie na „ON (ZAP)“.
</ptxt>
</s1>
<s1>
<ptxt>
Udržujte plynový pedál plne stlačený počas 2 sekúnd.
</ptxt>
</s1>
<s1>
<ptxt>
Udržujte plynový pedál v pokojovej polohe počas 2 sekúnd.
</ptxt>
</s1>
<s1>
<ptxt>
Prepnite zapaľovanie do polohy „OFF“ na 1 min. a potom do „ON“.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1104053004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A1104053005">
<testgroup id = "ASLAP70A1104053006">
<question>
Bola vykonaná &#34;Kontrola systému motora a riadenia emisií&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A1104001">Kontrola systému motora a riadenia emisií</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104053007">
<title>
Opätovná kontrola DTC
</title>
<test1>
<ptxt>
Vymažte DTC.
</ptxt>
</test1>
<test1>
<ptxt>
Vykonajte kalibráciu systému ovládania elektrického škrtiaceho ventilu. 
<intxreftitleoff1 refid = "ASLAP70A1306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Znovu skontrolujte DTC.
</ptxt>
</test1>
<question>
Je ešte stále detekované DTC P2101 / P2119?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Koniec.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104053008">
<title>
Kontrola obvodu ovládača škrtiacej klapky
</title>
<test1>
<ptxt>
Skontrolujte obvod pohonu ovládača škrtiacej klapky podľa kroku 2 v 
<intxref refid = "ASLAP70A1104052">DTC P2100</intxref>
 .
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte hnací obvod ovládača škrtiacej klapky.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A1104053009">
<title>
Kontrola elektrickej zostavy telesa škrtiacej klapky
</title>
<test1>
<ptxt>
Skontrolujte výkon zariadenia telesa elektrickej škrtiacej klapky. 
<intxreftitleoff1 refid = "ASLAP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je výsledok kontroly uspokojivý?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte ECM a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zariadenie telesa elektrickej škrtiacej klapky.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
