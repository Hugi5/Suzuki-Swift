<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A3204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hlučnosť pohonu
</title>
<diag type = "condition">
<condition>
<ptxt>
Hlučnosť pohonu
</ptxt>
</condition>
<ps>
<ptxt>
Opotrebovaný alebo s vodou zmiešaný mazací prostriedok
</ptxt>
</ps>
<action>
<ptxt>
Opravte a znovu doplňte. 
<intxreftitleoff1 refid = "ASLAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nevhodný mazací prostriedok alebo jeho nedostatok
</ptxt>
</ps>
<action>
<ptxt>
Opravte a znovu doplňte. 
<intxreftitleoff1 refid = "ASLAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nesprávne nastavená bočná vôľa medzi pastorkom a ozubeným kolesom
</ptxt>
</ps>
<action>
<ptxt>
Nastavte geometriu podľa predpisu. 
<intxreftitleoff1 refid = "ASLAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nesprávny kontakt ozubenia v zábere medzi pastorkom a kolesom
</ptxt>
</ps>
<action>
<ptxt>
Nastavte alebo vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Uvoľnite poistné skrutky kužeľového súkolesia
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte alebo znovu utiahnite. 
<intxreftitleoff1 refid = "ASLAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poškodené bočné súkolesie(a) alebo pastorok(ky) diferenciálu
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte. 
<intxreftitleoff1 refid = "ASLAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
