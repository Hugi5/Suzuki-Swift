<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A9504003" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnóza symptómov systému odhmlievania zadného okna a vyhrievania spätných zrkadiel
</title>
<diag type = "condition" id = "ASLAP70A9504003001">
<condition>
<ptxt>
Odhmlievanie zadného okna nefunguje
</ptxt>
</condition>
<ps>
<ptxt>
Porucha obvodov systému (vrátane relé a poistiek)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9501002">Popis systému odhmlievania okna zadných koncových dvier a systému vyhrievania spätných zrkadiel</intxref>
 
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača odhmlievania zadného okna
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506008">Kontrola spínača odhmlievania zadného okna</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha odhmlievania zadného okna
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506007">Kontrola odhmlievania zadného okna</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Kontrola BCM a jej obvodov: v časti 10B.
</ptxt>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<condition>
<ptxt>
Všetky ohrievače vonkajších spätných zrkadiel nefungujú
</ptxt>
</condition>
<ps>
<ptxt>
Vypálená poistka
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte poistku a skontrolujte, či okruh nie je skratovaný.
</ptxt>
</action>
<ps>
<ptxt>
Porucha spínača vyhrievania zrkadiel
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506008">Kontrola spínača odhmlievania zadného okna</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
<ps>
<ptxt>
Porucha BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Kontrola BCM a jej obvodov: v časti 10B.
</ptxt>
<ptxt>
Model so spínačom zapaľovania: 
<intxreftitleoff1 refid = "ASLAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model s bezkľúčovým štartovaním: 
<intxreftitleoff1 refid = "ASLAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<condition>
<ptxt>
Iba jeden ohrievač spätných zrkadiel nefunguje
</ptxt>
</condition>
<ps>
<ptxt>
Porucha vyhrievania zrkadla
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ASLAP70A9506021">Kontrola elektrického ovládania a vyhrievania spätných zrkadiel na vozidle</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Porucha kabeláže alebo uzemnenia
</ptxt>
</ps>
<action>
<ptxt>
Opravte vedenie.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
