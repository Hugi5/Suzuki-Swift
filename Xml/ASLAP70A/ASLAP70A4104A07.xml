<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASLAP70A4104A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Pulzovanie pedálu (pedál pri zatlačení pulzuje)
</title>
<diag type = "condition">
<condition>
<ptxt>
Pulzovanie pedálu (pedál pri zatlačení pulzuje)
</ptxt>
</condition>
<ps>
<ptxt>
Poškodené alebo uvoľnené predné a/alebo zadné ložiská kolesa
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte ložiská kolies.
</ptxt>
</action>
<ps>
<ptxt>
Deformovaný otočný čap riadenia
</ptxt>
</ps>
<action>
<ptxt>
Vymeňte čap.
</ptxt>
</action>
<ps>
<ptxt>
Nadmerné bočné hádzanie brzdového kotúča
</ptxt>
</ps>
<action>
<ptxt>
Skontrolujte podľa pokynov. Ak kotúč nevyhovuje predpisom, vymeňte alebo opracujte ho.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
