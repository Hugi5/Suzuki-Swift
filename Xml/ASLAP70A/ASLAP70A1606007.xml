<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A1606007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž potrubí a hadíc sústavy chladenia vodou
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A1606001">Diely chladiaceho systému</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ASLAP70A1606009">Kontrola zariadenia termostatu (so snímačom ECT)</intxrefpoff>
</ptxt>
<servinfosub id = "ASLAP70A1606007001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Vypustite chladiacu kvapalinu. 
<intxreftitleoff1 refid = "ASLAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ak chcete vybrať tieto chladiace potrubia alebo hadice, na každej hadici povoľte príchytku a potiahnite za koniec hadice.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A1606007002">
<title>
Montáž
</title>
<ptxt>
Postupujte opačne ako pri demontáži, pričom dávajte pozor na nasledujúce upozornenie:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dotiahnite poriadne a v správnom smere každú svorku. 
<intxreftitleoff1 refid = "ASLAP70A1606001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Chladiaci systém doplňte chladiacou kvapalinou. 
<intxreftitleoff1 refid = "ASLAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Skontrolujte, či chladiaci systém nepresakuje. 
<intxreftitleoff1 refid = "ASLAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
