<servinfosub id = "ASLAP70A7224014003">
<title>
Postup potvrdenia DTC
</title>
<s1>
<ptxt>
Naštartujte motor a ovládajte systém klimatizácie.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A7224014004">
<title>
Riešenie problémov DTC
</title>
<p-change/>
<diag type = "test" id = "ASLAP70A7224014005">
<testgroup id = "ASLAP70A7224014006">
<title>
Kontrola parametrov skenovacieho zariadenia
</title>
<test1>
<ptxt>
Skontrolujte “Teplota kabíny” pomocou režimu “Zoznamu údajov” na skenovacom nástroji SUZUKI. 
<intxreftitleoff1 refid = "ASLAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je teplota vyššia ako 87,5 &#176;C (189,5 &#176;F) (signálne napätie snímača vnútornej teploty je nižšie ako 0,1 V)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Občasná chyba.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224014007">
<title>
Kontrola snímača teploty vzduchu vo vnútri kabíny
</title>
<test1>
<ptxt>
Odpojte konektor snímača teploty vnútorného vzduchu.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Rozoznáva sa DTC B1502-H?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte senzor vnútornej teploty vzduchu. 
<intxreftitleoff1 refid = "ASLAP70A7226035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A7224014008">
<title>
Kontrola obvodu signálu snímača teploty vzduchu vo vnútri kabíny
</title>
<test1>
<ptxt>
Odpojte konektor “G20”.
</ptxt>
</test1>
<test1>
<ptxt>
Skontrolujte, či je medzi koncovkou „PNK/BLK“a uzemnením motora odpor.
</ptxt>
</test1>
<question>
Je v poriadku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku HVAC a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vymeňte zväzok káblov prístrojovej dosky.
</ptxt>
</action>
</testgroup>
