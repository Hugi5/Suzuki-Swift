<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASLAP70A4106006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontáž a montáž sústavy brzdového pedála
</title>
<attention2>
<ptxt>
Nikdy nedemontujte zostavu plynového pedála s brzdovým pedálom vybaveným mechanizmom ochrany nožnej brzdy.
</ptxt>
<ptxt>
Rozobratie poruší jeho pôvodnú funkciu. Ak zistíte chybu, vymeňte ho za nový ako celú zostavu.
</ptxt>
</attention2>
<servinfosub id = "ASLAP70A4106006001">
<title>
Demontáž
</title>
<s1>
<ptxt>
Odmontujte panel združeného merača. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zložte kryt otvoru stĺpika riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte spínač brzdového svetla. 
<intxreftitleoff1 refid = "ASLAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vyberte spodný hriadeľ stĺpika riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte svorku, čap zavesenia a matice posilňovača bŕzd. 
<intxreftitleoff1 refid = "ASLAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odmontujte maticu konzoly brzdového pedála (1) a skrutku hornej výstuže (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Demontujte sústavu brzdového pedála.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASLAP70A4106006002">
<title>
Montáž
</title>
<ptxt>
<intxrefpoff refid = "ASLAP70A4106022">Demontáž a montáž posilňovača bŕzd</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Namontujte zostavu brzdového pedála a namontujte posilňovač bŕzd.
</ptxt>
</s1>
<s1>
<ptxt>
Utiahnite matice posilňovača bŕzd na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T4A001">
<t-part>
Matica posilňovača bŕzd*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410009.swf" width = "88.000mm" height = "63.332mm" ver = "01" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Maticu konzoly brzdového pedála utiahnite na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T4A002">
<t-part>
Matica konzoly brzdového pedála*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Utiahnite skrutky hornej výstuhy krytu na predpísaný uťahovací moment.
</ptxt>
<torque>
<torqueitem id = "T4A003">
<t-part>
Skrutka hornej výstuže krytu
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410010.swf" width = "88.000mm" height = "64.412mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Namontujte svorku a vidlicu. 
<intxreftitleoff1 refid = "ASLAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nasaďte spodný hriadeľ stĺpika riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Z brzdového systému vypustite vzduch. 
<intxreftitleoff1 refid = "ASLAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte vôľu a voľnú výšku brzdového pedála.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voľná výška brzdového pedála: 
<intxreftitleoff1 refid = "ASLAP70A4106007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vôľa brzdového pedála: 
<intxreftitleoff1 refid = "ASLAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Namontujte spínač brzdového svetla. 
<intxreftitleoff1 refid = "ASLAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skontrolujte všetky pripojenia, či z nich netečie brzdová kvapalina a uistite sa, že brzdový systém pracuje správne.
</ptxt>
</s1>
<s1>
<ptxt>
Nainštalujte kryt otvoru stĺpika riadenia. 
<intxreftitleoff1 refid = "ASLAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Namontujte panel združeného merača. 
<intxreftitleoff1 refid = "ASLAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
