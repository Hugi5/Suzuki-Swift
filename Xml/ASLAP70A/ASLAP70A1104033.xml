<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
P0336: Výkon/rozsah obvodu snímača polohy vačkového hriadeľa „A“
</emph>
</ptxt>
<ptxt>
Ktorákoľvek z nasledovných podmienok je splnená. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Čas detekovania signálu je dlhší ako predpísaný.
</ptxt>
</item>
<item>
<ptxt>
Počet zubov medzi medzerami je vyšší ako predpísaný.
</ptxt>
</item>
<item>
<ptxt>
Čas medzi susednými dvomi zubami je dlhší ako predpísaný.
</ptxt>
</item>
</list1>
<ptxt>
(Logika rozpoznávania 3 jazdného cyklu)
</ptxt>
</entry>
