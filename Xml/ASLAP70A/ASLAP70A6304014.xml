<servinfosub id = "ASLAP70A6304014003">
<title>
Postup potvrdenia DTC
</title>
<ptxt>
Nechajte motor bežať na voľnobežných otáčkach viac ako 5 sek.
</ptxt>
</servinfosub>
<servinfosub id = "ASLAP70A6304014004">
<title>
Riešenie problémov DTC
</title>
<diag type = "test" id = "ASLAP70A6304014005">
<testgroup id = "ASLAP70A6304014006">
<question>
Bola vykonaná kontrola systému P/S?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Pokračujte časťou 
<intxref refid = "ASLAP70A6304001">Kontrola systému P/S</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304014007">
<title>
Kontrola obvodu hlavného napájania a uzemnenia riadiacej jednotky posilňovača riadenia
</title>
<test1>
<ptxt>
Skontrolujte obvody „A1“ a „A2“. 
<intxreftitleoff1 refid = "ASLAP70A6304021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sú v dobrom stave?
</question>
<result type = "yes"/>
<action>
<ptxt>
Prejdite na krok 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Opravte alebo vymeňte poškodený káblový zväzok.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASLAP70A6304014008">
<title>
Kontrola obvodu napájania riadiacej jednotky posilňovača riadenia
</title>
<test1>
<ptxt>
Zmerajte napätie akumulátora, keď motor ide na voľnobežných otáčkach.
</ptxt>
</test1>
<test1>
<ptxt>
Zmerajte napätie akumulátora, keď motor ide na 3 000 ot/min.
</ptxt>
</test1>
<question>
Je napätie medzi 9 a 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vymeňte riadiacu jednotku P/S a opätovne skontrolujte DTC. 
<intxreftitleoff1 refid = "ASLAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Skontrolujte systém nabíjania. 
<intxreftitleoff1 refid = "ASLAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
