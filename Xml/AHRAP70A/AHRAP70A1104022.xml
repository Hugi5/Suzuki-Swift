<servinfosub id = "AHRAP70A1104022003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Potvrdite da je ECT manji od 40 &#176;C (104 &#176;F).
</ptxt>
</s1>
<s1>
<ptxt>
Pokrenite motor i vozite vozilo brzinom od 60 do 80 km/h (37 do 50 milja/h) konstantno tijekom 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104022004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104022005">
<testgroup id = "AHRAP70A1104022006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104022007">
<title>
Provjera razine rashladne tekućine
</title>
<test1>
<ptxt>
Provjerite razinu rashladne tekućine. 
<intxreftitleoff1 refid = "AHRAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Dodajte rashladnu tekućinu i ponovno provjerite DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104022008">
<title>
Provjera strujnog kruga ECT senzora
</title>
<test1>
<ptxt>
Provjerite krugove ECT senzora prema koraku 2 poglavlja 
<intxref refid = "AHRAP70A1104023">DTC P0117/P0118</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104022009">
<title>
Provjera ECT senzora
</title>
<test1>
<ptxt>
Provjerite ECT senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ECT senzor.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104022010">
<title>
Provjera termostata
</title>
<test1>
<ptxt>
Provjerite sklop termostata. 
<intxreftitleoff1 refid = "AHRAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite termostat.
</ptxt>
</action>
</testgroup>
</diag>
