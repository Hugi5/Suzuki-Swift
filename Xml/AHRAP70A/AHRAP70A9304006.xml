<servinfosub id = "AHRAP70A9304006003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A9304006004">
<testgroup id = "AHRAP70A9304006005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Izbrišite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se DTC B1810 i dalje?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite postoje li isprekidani problemi. 
<intxreftitleoff1 refid = "AHRAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A9304006006">
<title>
Provjera senzora razine goriva
</title>
<test1>
<ptxt>
Provjerite senzor razine goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Zamijenite senzor razine kotača i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1706017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AHRAP70A9304006007">
<title>
Provjera kruga senzora razine goriva
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Iskopčajte konektore kombiniranog mjerača i senzora razine goriva.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja s kombiniranim mjeračem i terminalima senzora razine goriva.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite je li krug između konektora kombiniranog mjerača i senzora razine goriva prekinut, u kratkom spoju s uzemljenjem ili napajanjem.
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite kombinirani mjerač i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite neispravno ožičenje ponovno provjerite DTC.
</ptxt>
</action>
</testgroup>
