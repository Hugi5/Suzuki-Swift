<servinfosub id = "AHRAP70A1104048003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Zagrijte motor do normalne radne temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Potvrdite da su sljedeći uvjeti ispunjeni.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ventilator puhala: ISKLJ.
</ptxt>
</item>
<item>
<ptxt>
Prekidač prednjeg svjetla: ISKLJ.
</ptxt>
</item>
<item>
<ptxt>
Prekidač grijača stražnjeg prozora: ISKLJ.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Ostavite motor neka radi 5 min. u praznom hodu i potvrdite da su zadovoljeni sljedeći uvjeti.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ventilator puhala: UKLJ.
</ptxt>
</item>
<item>
<ptxt>
Prekidač prednjeg svjetla: UKLJ.
</ptxt>
</item>
<item>
<ptxt>
Prekidač grijača stražnjeg prozora: UKLJ.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Neka motor radi na 4000 okr./min 30 sekundi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104048004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104048005">
<testgroup id = "AHRAP70A1104048006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104048007">
<title>
Provjera kruga izmjerenog signala uzbudnog namota generatora
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a i konektor generatora.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34; i konektorom generatora.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;B1&#34;: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;B1&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B1&#34; i drugih terminala na konektoru generatora: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;B1&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104048008">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite generator. 
<intxreftitleoff1 refid = "AHRAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC P0622?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
