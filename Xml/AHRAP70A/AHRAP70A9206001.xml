<servinfosub id = "AHRAP70A9206001002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ugradite kopču jedinice prednjih svjetala.
</ptxt>
</item>
<item>
<ptxt>
Ugradite vijke (1, “1” – 1, “4”) prema brojčanom redoslijedu na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920008.jpg" width = "88.000mm" height = "69.820mm" ver = "02" gw = "206" gh = "181"/>
<callout>
