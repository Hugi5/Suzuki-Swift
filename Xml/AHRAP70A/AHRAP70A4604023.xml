<servinfosub id = "AHRAP70A4604023003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A4604023004">
<testgroup id = "AHRAP70A4604023005">
<question>
Je li izvršena “Provjera ESP<sup>®</sup> sustava”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A4604001">Provjera ESP® sustava</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604023006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70A4604005">Provjera DTC-a</intxref>
.
</ptxt>
</test1>
<question>
Postoje li DTC-ovi osim C1037, C1038 i C1057?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajuće rješavanje problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604023007">
<title>
Provjera DTC-a za BCM
</title>
<test1>
<ptxt>
Provjerite DTC za BCM. 
<intxreftitleoff1 refid = "AHRAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li detektirani DTC U0073, U0121 i/ili U0126?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajuće rješavanje problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604023008">
<title>
Provjera osigurača
</title>
<test1>
<ptxt>
Provjerite osigurač &#34;ABS&#34;.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite osigurač i provjerite je li došlo do kratkog spoja s uzemljenjem.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604023009">
<title>
Provjera kruga napajanja senzora kuta zakretanja upravljača
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor senzora kuta zakretanja upravljača.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “G33”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja sa senzorom kuta zakretanja.
</ptxt>
</test1>
<test1>
<ptxt>
Ako je spoj u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite napon između strujnog kruga &#34;A1&#34; i uzemljenja.
</ptxt>
</test1>
<question>
Iznosi li 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite krug &#34;A1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604023010">
<title>
Provjera kruga uzemljenja senzora kuta zakretanja upravljača
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite otpor između kruga &#34;A2&#34; i uzemljenja.
</ptxt>
</test1>
<question>
Je li manji od 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite krug &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604023011">
<title>
Provjera senzora kuta zakretanja upravljača
</title>
<test1>
<ptxt>
Spojite konektor senzora kuta zakretanja upravljača.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite senzor kuta zakretanja upravljača. 
<intxreftitleoff1 refid = "AHRAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite senzor kuta zakretanja upravljača i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
