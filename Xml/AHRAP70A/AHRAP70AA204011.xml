<ptxt>
Uključite kontakt.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA204011004">
<title>
Rješavanje DTC problema
</title>
<diag type = "test" id = "AHRAP70AA204011005">
<testgroup id = "AHRAP70AA204011009">
<title>
Provjera parametara
</title>
<test1>
<ptxt>
Priključite SUZUKI alat za skeniranje na DLC s isključenim kontaktom.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite &#34;Napon akumulatora&#34; i &#34;Prekidač paljenja 1&#34; i &#34;Prekidač ACC&#34; prikazan na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204011006">
<title>
Provjera osigurača strujnog kruga
</title>
<test1>
<ptxt>
Isključite kontakt i zatim uklonite osigurače &#34;DOME&#34; i &#34;HAZ&#34; iz J/B-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite osigurač &#34;DOME&#34; i osigurač &#34;HAZ&#34;.
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite osigurače strujnog kruga.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204011007">
<title>
Provjera kruga pomoćnog napajanja BCM-a
</title>
<test1>
<ptxt>
Odspojite konektore &#34;E323&#34; i &#34;E324&#34; iz razvodnog bloka.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;E323&#34; i &#34;E324&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon kruga &#34;A1&#34; i uzemljenja: Napon akumulatora
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;A2&#34; i uzemljenja: Napon akumulatora
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite je li žica “WHT/BLK” ili “WHT” prekinuta ili u kratkom spoju.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204011008">
<title>
Provjera kruga pomoćnog napajanja BCM-a
</title>
<test1>
<ptxt>
Odspojite konektor &#34;E04&#34; s BCM-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s &#34;E04&#34; konektorom.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon kruga &#34;A3&#34; i uzemljenja: Napon akumulatora
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;A4&#34; i uzemljenja: Napon akumulatora
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite BCM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite jesu li žice “BRN” i/ili “BLK/RED” prekinute ili u kratkom spoju s uzemljenjem.
</ptxt>
</action>
</testgroup>
</diag>
