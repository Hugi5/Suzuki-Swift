<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A8206026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja prekidača za deaktivaciju zračnog jastuka suvozača
</title>
<servinfosub id = "AHRAP70A8206026001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite pretinac za rukavice. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor (1) prekidača za deaktivaciju zračnog jastuka suvozača.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820078.swf" width = "88.000mm" height = "87.000mm" ver = "01" gw = "231" gh = "230"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite prekidač za deaktivaciju zračnog jastuka suvozača (1) dok otpuštate bravice (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820079.swf" width = "88.000mm" height = "59.573mm" ver = "02" gw = "207" gh = "152"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A8206026002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A8206027">Pregled prekidača za deaktivaciju zračnog jastuka suvozača</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Ugradite prekidač za deaktivaciju zračnog jastuka suvozača (1) poravnavajući njegov izdanak (2) s izrezom (3) na ploči s instrumentima.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820080.swf" width = "88.000mm" height = "64.695mm" ver = "01" gw = "207" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Spojite konektor prekidača za deaktivaciju zračnog jastuka suvozača.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite pretinac za rukavice. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
