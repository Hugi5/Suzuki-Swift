<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9F06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja radioantene
</title>
<servinfosub id = "AHRAP70A9F06004001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (-) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite krovnu oblogu. 
<intxreftitleoff1 refid = "AHRAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor radio antene (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijak radio antene (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite bazu (3) i šipku radio antene (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0007.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9F06004002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijak antene propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9O001">
<t-part>
Vijak antene
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,0
</t-value1>
<t-value2>
0,7
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A9F0008.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
