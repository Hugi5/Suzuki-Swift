<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A2104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vozilo vuče na jednu stranu (vodi)
</title>
<diag type = "condition">
<condition>
<ptxt>
Vozilo vuče na jednu stranu (vodi)
</ptxt>
</condition>
<ps>
<ptxt>
Neusklađene ili nejednako istrošene gume
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite gume. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gume nisu propisno napumpane
</ptxt>
</ps>
<action>
<ptxt>
Namjestite tlak u gumi.
</ptxt>
</action>
<ps>
<ptxt>
Slomljene ili uleknute zavojne opruge
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zamijenite zavojne opruge. 
</ptxt>
<ptxt>
Prednja: 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Stražnja: 
<intxreftitleoff1 refid = "AHRAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Neuobičajena bočna sila radijalne gume
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite gumu. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poremećena geometrija kotača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i prilagodite geometriju kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Struganje kočnice na jednom kotaču
</ptxt>
</ps>
<action>
<ptxt>
Namjestite ili popravite kočnicu.
</ptxt>
</action>
<ps>
<ptxt>
Labavi, savijeni ili slomljeni dijelovi prednjeg ili stražnjeg ovjesa
</ptxt>
</ps>
<action>
<ptxt>
Zategnite ili zamijenite povezane dijelove ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
