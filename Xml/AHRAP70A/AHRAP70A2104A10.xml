<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A2104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Gume s istrošenim rubom
</title>
<diag type = "condition">
<condition>
<ptxt>
Gume s istrošenim rubom
</ptxt>
</condition>
<ps>
<ptxt>
Poremećena geometrija kotača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i prilagodite geometriju kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravnost sklopa prednje opružne noge 
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop prednje opružne noge. 
<intxreftitleoff1 refid = "AHRAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošeni ležajevi kotača
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ležajeve kotača. 
<intxreftitleoff1 refid = "AHRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prekomjerno ljuljanje gume ili kotača
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite gumu i/ili kotač.
</ptxt>
</action>
<ps>
<ptxt>
Istrošeni zglobovi ramena ovjesa
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite rame ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kotač nije balansiran
</ptxt>
</ps>
<action>
<ptxt>
Podesite balans ili zamijenite gumu.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
