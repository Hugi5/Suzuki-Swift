<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1393: Krug stražnjeg senzora bočnog udara prekinut (strana vozača)
</emph>
</ptxt>
<ptxt>
Krug stražnjeg senzora bočnog udara na strani vozača u kratkom je spoju s krugom napajanjea ili prekinut.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1397: Krug stražnjeg senzora bočnog udara u kratkom je spoju s uzemljenjem (strana suvozača)
</emph>
</ptxt>
<ptxt>
Krug stražnjeg senzora bočnog udara na strani suvozača u kratkom je spoju s uzemljenjem.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1398: Krug stražnjeg senzora bočnog udara prekinut (strana suvozača)
</emph>
</ptxt>
<ptxt>
