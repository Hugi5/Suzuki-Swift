<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1392: Krug stražnjeg senzora bočnog udara u kratkom je spoju s uzemljenjem (strana vozača)
</emph>
</ptxt>
<ptxt>
Krug stražnjeg senzora bočnog udara na strani vozača u kratkom je spoju s uzemljenjem
</ptxt>
</entry>
<entry colname = "2" morerows = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
