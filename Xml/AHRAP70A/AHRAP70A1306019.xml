<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1306019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja CKP senzora
</title>
<servinfosub id = "AHRAP70A1306019001" page = "2">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Izvadite generator. 
<intxreftitleoff1 refid = "AHRAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor s CKP senzora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite CKP senzor (1) s bloka motora.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A131017.jpg" width = "88.000mm" height = "57.392mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</servinfosub>
<servinfosub id = "AHRAP70A1306019002" page = "2">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1306020">Provjera CKP senzora</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Nanesite motorno ulje na O prsten senzora.
</ptxt>
</item>
<item>
<ptxt>
Pritegnite vijak CKP senzora propisanim momentom pritezanja.
</ptxt>
<attention2>
<ptxt>
Pazite da primijenite nove vijke obložene ljepilom. U suprotnom, vijci se mogu olabaviti.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T1C007">
<t-part>
Vijak CKP senzora
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131008.jpg" width = "88.000mm" height = "57.393mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</item>
<item>
<ptxt>
Dobro spojite konektor i učvrstite ožičenje obujmicom.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
