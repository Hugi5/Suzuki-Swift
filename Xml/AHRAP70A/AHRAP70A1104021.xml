<servinfosub id = "AHRAP70A1104021003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pustite neka motor radi u praznom hodu 10 sekundi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104021004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104021005">
<testgroup id = "AHRAP70A1104021006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104021007">
<title>
Provjera kruga signala i kruga uzemljenja IAT senzora
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a te konektor MAF i IAT senzora.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala na konektorima &#34;C01&#34; i &#34;E01&#34; te konektoru MAF i IAT senzora.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;B1&#34; i &#34;C1&#34;: manji od 1Ω
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova &#34;B1&#34; i &#34;C1&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B1&#34; i drugih terminala konektora MAF i IAT senzora: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;C1&#34; i drugih terminala konektora MAF i IAT senzora: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova &#34;B1&#34; i &#34;C1&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104021008">
<title>
Provjera IAT senzora
</title>
<test1>
<ptxt>
Provjerite IAT senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite MAF i IAT senzor.
</ptxt>
</action>
</testgroup>
</diag>
