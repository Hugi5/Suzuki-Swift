<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0112: Nizak napon strujnog krug senzora 1 temperature usisanog zraka
</emph>
</ptxt>
<ptxt>
Izlazni napon kruga signala IAT senzora niži je od 0,01 V tijekom 5 sekundi.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
IAT senzor i/ili njegov krug
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0113: Visoki napon strujnog kruga senzora 1 temperature usisanog zraka
</emph>
</ptxt>
<ptxt>
Izlazni napon kruga signala IAT senzora viši je od 4,86 V tijekom 5 sekundi.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
