<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1A06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja nosača generatora
</title>
<servinfosub id = "AHRAP70A1A06006001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (-) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite donju desnu oblogu motora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite pogonski remen pumpe vode/generatora. 
<intxreftitleoff1 refid = "AHRAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite remenicu pumpe vode (1). 
<intxreftitleoff1 refid = "AHRAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijak generatora (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite nosač generatora (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1007.jpg" width = "88.000mm" height = "70.982mm" ver = "01" gw = "192" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1A06006002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ugradite nosač generatora prema sljedećoj proceduri.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Postavite nosač generatora (1).
</ptxt>
</item>
<item>
<ptxt>
Labavo zategnite vijak generatora (2).
</ptxt>
</item>
<item>
<ptxt>
Zategnite matice nosača generatora (3) propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
<figure>
<graphic graphicname = "I9P60A1A1016.swf" width = "88.000mm" height = "68.664mm" ver = "01" gw = "188" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
