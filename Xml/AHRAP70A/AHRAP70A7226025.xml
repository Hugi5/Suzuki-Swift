<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7226025" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pregled aktuatora kontrole temperature
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A7226024">Uklanjanje i ugradnja aktuatora kontrole temperature:Automatski tip</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Namjestite ručicu na aktuator i provjerite radi li neometano kad se napon akumulatora prenosi na terminale konektora aktuatora (1).
</ptxt>
<figure>
<title>
Rad aktuatora kontrole temperature
</title>
<graphic graphicname = "IAP70A722009Q.swf" width = "88.000mm" height = "45.766mm" ver = "01" gw = "197" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Ommetrom izmjerite otpor između terminala “3” i “5” konektora aktuatora (1) na svakom položaju ručice.
</ptxt>
<spec>
<title>
Otpor aktuatora kontrole temperature
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.312in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.147in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Položaj ručice
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Otpor (25 &#176;C (77 &#176;F))
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
MAX COOL [a]
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Približno 2,4 k&#937;
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
MAX HOT [b]
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Približno 4,8 k&#937;
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</s1>
<s1>
<ptxt>
Ommetrom izmjerite otpor između terminala “1” i “3”.
</ptxt>
<ptxt>
Ako rezultat provjere ne odgovara propisanom, zamijenite aktuator kontrole temperature.
</ptxt>
<spec>
<title>
Otpor aktuatora kontrole temperature (ukupan otpor)
</title>
<ptxt>
6 k&#937;
</ptxt>
<figure>
<graphic graphicname = "IAP70A722010.swf" width = "88.000mm" height = "74.781mm" ver = "01" gw = "148" gh = "195"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.830in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.805in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
60&#176;
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Ručica
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Aktuator kontrole temperature
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</spec>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
