<servinfosub id = "AHRAP70A8204010002">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204010003">
<testgroup id = "AHRAP70A8204010004">
<title>
Provjera svjetla upozorenja
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<question>
Uključuju li se druga indikatorska svjetla?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204010005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Spojite alat za skeniranje na DLC.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li otkriven DTC U0073?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70AA804004">Rješavanje problema isključene sabirnice komunikacije</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite SDM i ponovo provjerite. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204010006">
<title>
Provjera osigurača
</title>
<question>
Je li osigurač “MTR” za kombinirani mjerač u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite osigurač “MTR” i provjerite uzemljenje radi kratkog spoja.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204010007">
<title>
Provjera strujnog kruga CAN komunikacije
</title>
<test1>
<ptxt>
Provjerite krug CAN komunikacije između SDM-a i kombiniranog mjerača.
</ptxt>
</test1>
<question>
Je li krug u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204010008">
<title>
Provjera strujnog kruga napajanja kombiniranog mjerača
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uklonite kombinirani mjerač.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja sa žicama “RED/WHT” i “GRY” konektora kombiniranog mjerača.
</ptxt>
</test1>
<test1>
<ptxt>
Ako je u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite napon između žice “RED/WHT” i uzemljenja.
</ptxt>
</test1>
<question>
Iznosi li 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug napajanja kombiniranog mjerača.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204010009">
<title>
Provjera kruga uzemljenja kombiniranog mjerača
</title>
<test1>
<ptxt>
Izmjerite otpor između žice “GRY” i uzemljenja.
</ptxt>
</test1>
<question>
Je li otpor manji od 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite kombinirani mjerač i ponovno provjerite rad svjetla upozorenja &#34;AIR BAG&#34;. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Krug žice “GRY” je prekinut.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Nakon završetka pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem uklonjen.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
