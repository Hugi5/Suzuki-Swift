<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A6104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vrludajuća ili slaba stabilnost sustava upravljanja
</title>
<diag type = "condition">
<condition>
<ptxt>
Vrludajuća ili slaba stabilnost sustava upravljanja
</ptxt>
</condition>
<ps>
<ptxt>
Neusklađene gume ili neujednačen tlak u gumama
</ptxt>
</ps>
<action>
<ptxt>
Podesite tlak gume ili zamijenite gumu. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Olabavljen zglob ramena ovjesa i krajnik spone
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zamijenite rame ovjesa ili krajnik spone.
</ptxt>
<ptxt>
Rame ovjesa: 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Krajnik spone: 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Neispravan sklop prednje opružne noge ili nosač
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop prednje opružne noge ili popravite nosač. 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Labava stabilizatorska šipka
</ptxt>
</ps>
<action>
<ptxt>
Zategnite ili zamijenite stabilizatorsku šipku ili čahuru. 
<intxreftitleoff1 refid = "AHRAP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slomljena ili uleknuta zavojna opruga
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite zavojnu oprugu. 
<intxreftitleoff1 refid = "AHRAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop prednje opružne noge (amortizer)
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop prednje opružne noge (amortizer). 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neodgovarajući kontakt zuba između zupčaste letve i zupčanika
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Provjerite okretni moment vratila zupčaste letve i zupčanika. 
<intxreftitleoff1 refid = "AHRAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ako je neispravan, zamijenite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Poremećena geometrija prednjih kotača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i podesite geometriju prednjih kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop kućišta upravljačkog prijenosnika
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
