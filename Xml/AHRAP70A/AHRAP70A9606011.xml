<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9606011" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pregled kopče brave vrata prtljažnika na vozilu
</title>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite je li se vrata prtljažnika neometano otvaraju i zatvaraju.
</ptxt>
</item>
<item>
<ptxt>
Provjerite je li se vrata prtljažnika zatvaraju u potpunosti.
</ptxt>
</item>
</list1>
<servinfosub id = "AHRAP70A9606011001">
<title>
Aktor otvarača vrata prtljažnika
</title>
<s1>
<ptxt>
Uklonite oblogu vrata prtljažnika. 
<intxreftitleoff1 refid = "AHRAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor brave vrata prtljažnika (1) sa sklopa brave vrata prtljažnika (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A960013.jpg" width = "88.000mm" height = "67.722mm" ver = "01" gw = "202" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Provjerite rad aktuatora za vrijeme dok se napon akumulatora nanosi na sljedeće terminale konektora sklopa brave vrata prtljažnika.
</ptxt>
<ptxt>
Ako je sklop neispravan, zamijenite ga.
</ptxt>
</s1>
<figure>
<title>
Rad aktuatora otvarača vrata prtljažnika
</title>
<graphic graphicname = "I9P60A960014Q.jpg" width = "88.000mm" height = "91.742mm" ver = "03" gw = "185" gh = "244"/>
</figure>
</servinfosub>
<servinfosub id = "AHRAP70A9606011002">
<title>
Prekidač vrata prtljažnika
</title>
<s1>
<ptxt>
Uklonite oblogu vrata prtljažnika. 
<intxreftitleoff1 refid = "AHRAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor brave vrata prtljažnika (1) sa sklopa brave vrata prtljažnika (2).
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite postoji li kontinuitet između terminala “1” i “2” kad se otvore vrata prtljažnika.
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite da nema kontinuiteta između terminala kad se zatvore vrata prtljažnika.
</ptxt>
<ptxt>
Ako rezultat provjere ne odgovara propisanom, zamijenite sklop brave vrata prtljažnika.
</ptxt>
<figure>
<title>
Kontinuitet prekidača vrata prtljažnika
</title>
<graphic graphicname = "IAP70A960003Q.jpg" width = "88.000mm" height = "56.814mm" ver = "01" gw = "168" gh = "145"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
