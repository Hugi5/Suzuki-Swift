<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A6104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Buka u sustavu upravljanja (zveckanje ili slično)
</title>
<diag type = "condition">
<condition>
<ptxt>
Buka u sustavu upravljanja (zveckanje ili slično)
</ptxt>
</condition>
<ps>
<ptxt>
Olabavite vijak kućišta upravljačkog prijenosnika
</ptxt>
</ps>
<action>
<ptxt>
Zategnite vijak kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neodgovarajući kontakt zuba između zupčaste letve i zupčanika
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Provjerite okretni moment vratila zupčaste letve i zupčanika. 
<intxreftitleoff1 refid = "AHRAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ako je neispravan, zamijenite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Neispravan sklop kućišta upravljačkog prijenosnika
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slomljeni ili oštećeni ležajevi kotača
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ležajeve kotača. 
<intxreftitleoff1 refid = "AHRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošen krajnik spone ili spona unutar kuglastog zgloba
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zamijenite krajnik spone ili sponu.
</ptxt>
<ptxt>
Krajnik spone: 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Spona: 
<intxreftitleoff1 refid = "AHRAP70A6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
