<servinfosub id = "AHRAP70A1104035003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da sljedeći DTC-ovi nisu detektirani u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
OCV (P0010/P0011/P0013/P0014)
</ptxt>
</item>
<item>
<ptxt>
Aktuator zaklopke (P2100/P2101/P2119)
</ptxt>
</item>
<item>
<ptxt>
Sustav namještanja smjese goriva (P0171/P0172)
</ptxt>
</item>
<item>
<ptxt>
HO2S (P0137/P0138/P0140)
</ptxt>
</item>
<item>
<ptxt>
A/F senzor (P0131/P0132/P0133)
</ptxt>
</item>
<item>
<ptxt>
MAF senzor (P0100/P0101/P0102/P0103)
</ptxt>
</item>
<item>
<ptxt>
Detektiran izostanak paljenja u cilindru (P0300/P0301/P0302/P0303/P0304)
</ptxt>
</item>
<item>
<ptxt>
Ventil pražnjenja EVAP spremnika (P0443/P0458/P0459)
</ptxt>
</item>
<item>
<ptxt>
ECT senzor (P0106/P0107/P0108) 
</ptxt>
</item>
<item>
<ptxt>
Senzor brzine kotača (P0500) 
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Pokrenite motor i vozite vozilo brzinom od 70 do 90 km/h (43 do 56 milja/h) konstantno tijekom 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104035004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104035005">
<testgroup id = "AHRAP70A1104035006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104035007">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC.
</ptxt>
</test1>
<question>
Postoje li drugi DTC-ovi osim P0420?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104035008">
<title>
Pregled ispušnog sustava
</title>
<test1>
<ptxt>
Provjerite propušta li ispušni sustav te ima li oštećenja i labavih spojeva.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104035009">
<title>
Provjera strujnog kruga HO2S-a
</title>
<test1>
<ptxt>
Provjerite krugove signala i uzemljenja prema 3. koraku pod naslovom 
<intxref refid = "AHRAP70A1104028">DTC P0137/P0138/P0140</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104035010">
<title>
Provjera kruga signala A/F senzora
</title>
<test1>
<ptxt>
Provjerite krug signala A/F senzora prema 3. koraku pod naslovom 
<intxref refid = "AHRAP70A1104025">DTC P0131/P0132/P2237/P2243/ P2251/P2626</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravnu žicu.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104035011">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite ispušnu granu (ugrađena u katalizator trostrukog djelovanja). 
<intxreftitleoff1 refid = "AHRAP70A1B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provedite postupak potvrde DTC-a.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC C0420?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104035012">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite HO2S. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC C0420?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 8. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104035013">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite A/F senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC C0420?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
