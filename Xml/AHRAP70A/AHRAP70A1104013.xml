<servinfosub id = "AHRAP70A1104013003">
<title>
Postupak potvrde DTC-a
</title>
<attention3>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon akumulatora &#62; 8,5 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Pustite neka motor radi u praznom hodu 10 sekundi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104013004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104013005">
<testgroup id = "AHRAP70A1104013006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104013007">
<title>
Provjera kruga napajanja OCV-a
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektor s OCV-a povezanog s DTC-om.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorom OCV-a.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite odgovara li napon između &#34;A1&#34; ili &#34;B1&#34; i uzemljenja naponu akumulatora.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104013008">
<title>
Provjera pogonskog kruga OCV-a
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; I &#34;E01&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;A2&#34; ili &#34;B2&#34;: manji od 1Ω
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;A2&#34; ili &#34;B2&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A2&#34; ili &#34;B2&#34; i drugog terminala konektora OCV-a: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;A2&#34; ili &#34;B2&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104013009">
<title>
Provjera OCV-a
</title>
<test1>
<ptxt>
Provjerite OCV povezan s DTC-om. 
<intxreftitleoff1 refid = "AHRAP70A1306027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite OCV.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104013010">
<title>
Rješavanje problema drugih DTC-a detektiranih u isto vrijeme
</title>
<question>
Jesu li drugi DTC-ovi detektirani zajedno?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
