<servinfosub id = "AHRAP70A1104026003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Aktivirana je kontrola povratne informacije A/F-a (zatvorena petlja).
</ptxt>
</item>
<item>
<ptxt>
Nije detektiran DTC P0131 ili P0132.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Pokrenite motor i vozite vozilo brzinom od 60 do 80 km/h (37 do 50 milja/h) tijekom 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104026004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104026005">
<testgroup id = "AHRAP70A1104026006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104026007">
<title>
 Provjera DTC-a
</title>
<question>
Postoje li DTC-ovi osim P0133?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104026008">
<title>
Provjera ispušnog sustava i sustava usisa zraka
</title>
<test1>
<ptxt>
Provjerite jesu li ispušni sustav i sustav usisa zraka začepljeni ili propuštaju.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104026009">
<title>
Pregled sustava goriva
</title>
<test1>
<ptxt>
Provjerite sustav goriva prema uputama pod naslovom 
<intxref refid = "AHRAP70A1704001">Pregled sustava goriva</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104026010">
<title>
Provjera kruga signala A/F senzora
</title>
<test1>
<ptxt>
Provjerite krugove &#34;A2&#34; do &#34;A5&#34; prema koraku 3 poglavlja 
<intxref refid = "AHRAP70A1104025">DTC P0131/P0132/P2237/P2243/ P2251/P2626</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104026011">
<title>
Provjera grijača A/F senzora
</title>
<test1>
<ptxt>
Provjerite grijač A/F senzora. 
<intxreftitleoff1 refid = "AHRAP70A1306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite A/F senzor.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104026012">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite A/F senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Obavite postupak potvrde DTC-a i provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC C0133?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
