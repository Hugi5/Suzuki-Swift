<servinfo servinfosgmlid = "AHRAP70A7216005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pregled sklopa kondenzatora na vozilu
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A7216006">Uklanjanje i ugradnja sklopa kondenzatora:Ručni tip</intxrefpoff>
</ptxt>
<ptxt>
Provjerite sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Rešetke kondenzatora
</ptxt>
<ptxt>
Začepljene rešetke kondenzatora trebaju se oprati vodom i osušiti komprimiranim zrakom.
</ptxt>
</item>
<item>
<ptxt>
Rešetke kondenzatora radi istjecanja i loma
</ptxt>
<ptxt>
Ako se pronađe neispravnost, popravite ili zamijenite kondenzator.
</ptxt>
</item>
<item>
<ptxt>
Priključke kondenzatora radi istjecanja.
</ptxt>
<ptxt>
Ako se pronađe neispravnost, popravite ili zamijenite kondenzator.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
