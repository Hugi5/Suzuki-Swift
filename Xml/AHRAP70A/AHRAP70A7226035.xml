<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7226035" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja senzora temperature zraka unutrašnjosti
</title>
<servinfosub id = "AHRAP70A7226035001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac provrta stupa upravljača s ploče s instrumentima. 
<intxreftitleoff1 refid = "AHRAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite konektor (1) i crijevo usisivača (2) sa senzora temperature zraka unutrašnjosti (3).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite osigurače (4), a zatim uklonite senzor temperature zraka u unutrašnjosti (3) s ploče s instrumentima.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723023.swf" width = "88.000mm" height = "65.896mm" ver = "01" gw = "232" gh = "170"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7226035002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A7226036">Pregled senzora temperature zraka unutrašnjosti:Automatski tip</intxrefpoff>
</ptxt>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
