<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1104A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Buka motora – buka ventila
</title>
<ptxt>
Izvršite rješavanje problema prema sljedećim točkama kada je ECM detektirao da nema DTC-a i nisu pronađene nepravilnosti u 
<intxref refid = "AHRAP70A1104008">Vizualni pregled</intxref>
 i 
<intxref refid = "AHRAP70A1104009">Osnovni pregled motora</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<paragroup>
<ptxt>
Buka motora – buka ventila
</ptxt>
<attention3>
<ptxt>
Prije provjeravanja mehaničke buke, provjerite sljedeće stavke:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Koristi se propisana svjećica.
</ptxt>
</item>
<item>
<ptxt>
Koristi se propisano gorivo.
</ptxt>
</item>
</list1>
</attention3>
</paragroup>
</condition>
<ps>
<ptxt>
Neodgovarajuća zračnost ventila
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406014">Pregled bregastog vratila i podizača</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Istrošeno stablo ventila i vodilica
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406028">Pregled ventila i vodilica ventila</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slaba ili oštećena opruga ventila
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406031">Pregled opruge ventila</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Iskrivljen ili savijen ventil
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406028">Pregled ventila i vodilica ventila</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
