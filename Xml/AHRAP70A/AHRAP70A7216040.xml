<servinfo servinfosgmlid = "AHRAP70A7216040" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pregled magnetske spojke
</title>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite armaturnu ploču radi trošenja i remenicu magnetske spojke radi upijanja ulja.
</ptxt>
</item>
<item>
<ptxt>
Provjerite buku ležaja, trošenje i istjecanje masti na remenici magnetske spojke.
</ptxt>
</item>
<item>
<ptxt>
Izmjerite otpor zavojnice magnetske spojke pri 20 &#176;C (68 &#176;F). Ako izmjereni otpor ne odgovara specifikacijama, zamijenite sklop magnetne spojke.
</ptxt>
<spec>
<title>
Otpor zavojnice magnetske spojke
</title>
<ptxt>
približno 4,0 &#937; (at 20 &#176;C (68 &#176;F))
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A721034.swf" width = "88.000mm" height = "48.333mm" ver = "02" gw = "181" gh = "120"/>
</figure>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
