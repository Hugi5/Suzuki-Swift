<diag type = "test" id = "AHRAP70A7224020007">
<testgroup id = "AHRAP70A7224020008">
<title>
Provjera parametara alata za skeniranje
</title>
<test1>
<ptxt>
Provjerite “Air Ix Pos Sen” koristeći način rada “Popis podataka” na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Isprekidani problem.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224020009">
<title>
Provjera kruga aktuatora kontrole temperature
</title>
<test1>
<ptxt>
Odspojite konektor “G20” i konektor aktuatora kontrole temperature.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova žica &#34;GRY&#34; i &#34;LT BLU&#34;: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor krugova žica “GRY” i &#34;LT BLU&#34; između aktora kontrole temperature i uzemljenja: beskonačan
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li vrijednosti otpora unutar specifikacija?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224020010">
<title>
Provjera aktuatora kontrole temperature
</title>
<test1>
<ptxt>
Provjerite aktuator kontrole temperature 
<intxreftitleoff1 refid = "AHRAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li aktuator u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul HVAC sustava i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite aktor kontrole temperature. 
<intxreftitleoff1 refid = "AHRAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
