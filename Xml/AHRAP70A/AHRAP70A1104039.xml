<servinfosub id = "AHRAP70A1104039003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Nije detektiran DTC P0116, P0117, P0335 ili P0336.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Zagrijte motor do normalne radne temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Vozite vozilo konstantnom brzinom od 60 do 80 km/h (37 do 50 milja/h) u trajanju od 1 min ili više.
</ptxt>
</s1>
<s1>
<ptxt>
Otpustite papučicu gasa i zadržite vozilo u kretanju 10 s kočeći motorom (stanje prekinute dobave goriva).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104039004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104039005">
<testgroup id = "AHRAP70A1104039006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104039007">
<title>
Provjera DTC-a
</title>
<question>
Je li detektiran DTC vezan uz CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na rješavanje problema za DTC vezan uz CAN. 
<intxreftitleoff1 refid = "AHRAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104039008">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC u upravljačkom modulu ESP<sup>®</sup>-a.
</ptxt>
</test1>
<question>
Je li detektiran jedan ili više DTC-ova?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
