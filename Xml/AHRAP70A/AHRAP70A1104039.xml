</ptxt>
</item>
<item>
<ptxt>
Senzor brzine kotača
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul ESP<sup>®</sup>-a
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
