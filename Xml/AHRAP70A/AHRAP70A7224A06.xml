<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A7224A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hladni zrak izlazi van samo pri velikoj brzini
</title>
<diag type = "condition">
<condition>
<ptxt>
Hladni zrak izlazi van samo pri velikoj brzini
</ptxt>
</condition>
<ps>
<ptxt>
Začepljen kondenzator
</ptxt>
</ps>
<action>
<ptxt>
Provjerite kondenzator. 
<intxreftitleoff1 refid = "AHRAP70A7226005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nedovoljno punjenje rashladnog sredstva
</ptxt>
</ps>
<action>
<ptxt>
Provjerite količinu rashladnog sredstva i sustav radi istjecanja.
</ptxt>
</action>
<ps>
<ptxt>
Zrak u sustavu klima uređaja
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite kondenzator, a zatim izvršite odzračivanje i punjenje sustava klima uređaja. 
<intxreftitleoff1 refid = "AHRAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Labav ili oštećen pogonski remen kompresora
</ptxt>
</ps>
<action>
<ptxt>
Provjerite pogonski remen kompresora. 
<intxreftitleoff1 refid = "AHRAP70A7226043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan kompresor
</ptxt>
</ps>
<action>
<ptxt>
Provjerite kompresor.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
