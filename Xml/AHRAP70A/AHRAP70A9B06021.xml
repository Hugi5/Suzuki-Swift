<title>
Uklanjanje
</title>
<s1>
<ptxt>
Izbušite zavarene točke i uklonite vanjsku ploču B-nosača.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0108.jpg" width = "183.000mm" height = "228.447mm" ver = "04" gw = "492" gh = "631"/>
<callout>
