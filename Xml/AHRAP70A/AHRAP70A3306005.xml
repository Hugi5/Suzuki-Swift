<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3306005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rastavljanje i sastavljanje sklopa međumjenjača
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3306003">Postavljanje i rastavljanje međumjenjača</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A3306004">Komponente sklopa međumjenjača</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A3306005001">
<title>
Rastavljanje
</title>
<s1>
<ptxt>
Uklonite brtvu ulja br. 1 desnog kućišta (1) iz desnog kućišta međumjenjača pomoću specijalnog alata.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C001">
<s-part>
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Uklonite uskočnik (2) pomoću kliješta za uskočnike.
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite međuvratilo (4) s ležajem međuvratila (3) od sklopa međumjenjača.
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite ležaj međuvratila (3) od međuvratila (4) pomoću izvlakača ležaja i hidrauličke preše.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330008.swf" width = "88.000mm" height = "26.342mm" ver = "01" gw = "155" gh = "58"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite sklop izlaznog držača međumjenjača (1) i podlošku (3) tako da uklonite vijke držača (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330010.swf" width = "88.000mm" height = "55.632mm" ver = "01" gw = "206" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vijke kućišta međumjenjača (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite desno kućište (2) međumjenjača od lijevog kućišta (3) pomoću specijalnog alata.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C002">
<s-part>
</s-part>
<s-number num = "09912-34510">
09912-34510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330011.swf" width = "88.000mm" height = "57.119mm" ver = "02" gw = "143" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite sklop pogonskog redukcijskog zupčanika (1) i sklop gonjenog redukcijskog zupčanika (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330012.swf" width = "88.000mm" height = "45.732mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vanjske prstenove (1) i podlošku (2).
</ptxt>
<attention3>
<ptxt>
Kada je teško odvojiti prstene od kućišta, uklonite ih sa specijalnim alatom.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C003">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944-96011
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330013.swf" width = "88.000mm" height = "51.937mm" ver = "01" gw = "196" gh = "131"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A3306005002">
<title>
Ponovno sastavljanje
</title>
<s1>
<ptxt>
Odaberite odgovarajuće podloške.
</ptxt>
<s2>
<ptxt>
Izmjerite udaljenost &#34;a&#34; između vanjskih prstenova konusnog valjkastog ležaja sklopa gonjenog redukcijskog zupčanika (1).
</ptxt>
</s2>
<s2>
<ptxt>
Izmjerite dubinu &#34;b&#34; lijevog kućišta (2) i &#34;c&#34; desnog kućišta (3).
</ptxt>
</s2>
<s2>
<ptxt>
Debljinu podloške odredite sljedećom formulom.
</ptxt>
<ptxt>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "9" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.748in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.157in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.451in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.157in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.451in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.157in"/>
<colspec colnum = "7" colname = "7" colwidth = "0.560in"/>
<colspec colnum = "8" colname = "8" colwidth = "0.157in"/>
<colspec colnum = "9" colname = "9" colwidth = "0.591in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "middle" align = "center">
<ptxt>
Neophodna debljina podloške
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
=
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Dubina &#34;b&#34;
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Dubina &#34;c&#34;
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
–
</ptxt>
</entry>
<entry colname = "7" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Udaljenost &#34;a&#34;
</ptxt>
</entry>
<entry colname = "8" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "9" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "middle" align = "center">
<ptxt>
0,1 mm (0,004 in)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<figure>
<graphic graphicname = "IAP70A330014.swf" width = "88.000mm" height = "40.526mm" ver = "02" gw = "225" gh = "98"/>
</figure>
</s2>
<c-change/>
<s2>
<ptxt>
Odaberite podložne pločice među sljedećim dostupnim veličinama tako da ukupna debljina pločica s desne i lijeve strane dostigne izračunatu vrijednost.
</ptxt>
<ptxt>
<emph etype = "bold">
Na primjer:
</emph>
</ptxt>
<ptxt>
Izmjerena udaljenost &#34;a&#34; je 101,75 mm (4,006 in).
</ptxt>
<ptxt>
Izmjerena dubina &#34;b&#34; je 77,95 mm (3,069 in).
</ptxt>
<ptxt>
Izmjerena dubina &#34;c&#34; je 25,80 mm (1,016 in).
</ptxt>
<ptxt>
Potrebna debljina podloške = 77,95 mm (3,069 in) + 25,80 mm (1,016 in) - 101,75 mm (4,006 in) + 0,1 mm (0,004 in) = 2,10 mm (0,083 in)
</ptxt>
<spec>
<title>
Raspoloživa debljina podloške pogonskog redukcijskog zupčanika
</title>
<ptxt>
Desna strana:
</ptxt>
<ptxt>
0,60, 0,65, 0,70, 0,75, 0,80, 0,85, 0,90, 0,95, 1,00 i 1,05 mm (0,024, 0,026, 0,028, 0,030, 0,031, 0,033, 0,035, 0,037, 0,039 i 0,041 in)
</ptxt>
<ptxt>
Lijeva strana:
</ptxt>
<ptxt>
1,00, 1,05, 1,10, 1,15, 1,20, 1,25, 1,30, 1,35, 1,40 i 1,45 mm (0,039, 0,041, 0,043, 0,045, 0,047, 0,049, 0,051, 0,053, 0,055 i 0,057 in)
</ptxt>
</spec>
</s2>
</s1>
<s1>
<ptxt>
Očistite dodirnu površinu lijevog i desnog kućišta, nanesite brtvilo na desno kućište (1) kao što je prikazano na slici tako da mjeri 1,2 mm (0,047 in) u promjeru.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3C005" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Brtvilo
</m-desc>
<m-number>
99000-31260
</m-number>
<m-name>
SUZUKI Bond br.1217G
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I5RW0A330011.swf" width = "88.000mm" height = "42.399mm" ver = "01" gw = "155" gh = "104"/>
</figure>
</s1>
<s1>
<ptxt>
Sastavite sljedeće dijelove u desnom i lijevom kućištu obrnuvši postupak rastavljanja.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sklop pogonskog redukcijskog zupčanika (1)
</ptxt>
</item>
<item>
<ptxt>
Sklop gonjenog redukcijskog zupčanika (2)
</ptxt>
</item>
<item>
<ptxt>
Vanjski prsten ležaja (3)
</ptxt>
</item>
<item>
<ptxt>
Podloške gonjenog redukcijskog zupčanika (4)
</ptxt>
</item>
<item>
<ptxt>
Zatik (5)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A330015.jpg" width = "88.000mm" height = "60.349mm" ver = "01" gw = "213" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Pritegnite vijke kućišta međumjenjača propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T3C006">
<t-part>
Vijak kućišta međumjenjača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330016.swf" width = "88.000mm" height = "61.238mm" ver = "01" gw = "169" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Odaberite podlošku stožastog zupčanika (1) prema koraku 1 u odjeljku &#34;Sastavljanje&#34; pod 
<intxref refid = "AHRAP70A3306009">Rastavljanje i sastavljanje sklopa izlaznog držača međumjenjača</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite dodir zubaca prema 
<intxref refid = "AHRAP70A3306011">Provjera zahvata zuba tanjurastog zupčanika</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite sklop izlaznog držača međumjenjača (2) na lijevo kućište međumjenjača (3) s podloškom stožastog zupčanika (1) i pritegnite vijke držača propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T3C007">
<t-part>
Vijak izlaznog držača međumjenjača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330017.swf" width = "88.000mm" height = "45.870mm" ver = "01" gw = "165" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite vijak u utor prirubnice (2) i postavite komparator pod pravim kutom u odnosu na vijak (1) kao što je prikazano na slici. Držite gonjeni redukcijski zupčanik u ruci i izmjerite zazor stožastog i tanjurastog zupčanika.
</ptxt>
<attention3>
<ptxt>
Ako zazor premašuje propisane vrijednosti, podesite ga promjenom omjera debljine podloški postavljenih na desno i lijevo kućište u 3. koraku.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C004">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900-20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3C005">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900-20701
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Zazor između stožastog i tanjurastog zupčanika
</title>
<ptxt>
: 0,1 – 0,2 mm (0,0039 – 0,0078 in)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330018.swf" width = "88.000mm" height = "39.091mm" ver = "01" gw = "157" gh = "94"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite ležaj međuvratila (1) na međuvratilo (2) pomoću specijalnog alata.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C006">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913-84510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A330015.swf" width = "88.000mm" height = "48.692mm" ver = "01" gw = "71" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite međuvratilo (2) s ležajem (3) u međumjenjač.
</ptxt>
</s1>
<s1>
<ptxt>
Postavite novi uskočnik (1) na desno kućište međumjenjača pomoću kliješta za uskočnike.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330016.swf" width = "88.000mm" height = "26.757mm" ver = "02" gw = "133" gh = "59"/>
</figure>
</s1>
<s1>
<ptxt>
Nanesite mazivo na obod nove brtve ulja br. 1 desnog kućišta.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C006" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Umetnite brtvu ulja br. 1 (1) u desno kućište međumjenjača (2) pomoću specijalnog alata.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C007">
<s-part>
(A)
</s-part>
<s-number num = "09925-16010">
09925-16010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Dubina ugradnje izlazne brtve ulja međuvratila
</title>
<ptxt>
“a”: 1,0 – 2,0 mm (0,039 – 0,078 in)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330042.swf" width = "88.000mm" height = "45.592mm" ver = "01" gw = "201" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
