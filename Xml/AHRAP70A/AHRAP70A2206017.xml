<servinfo servinfosgmlid = "AHRAP70A2206017" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Provjera spojeva okvira prednjeg ovjesa
</title>
<ptxt>
Provjerite zategnutost vijaka i matica koji učvršćuju dijelove ovjesa. Ako postoje labavi vijci ili matice, zategnite ih propisanim momentom pritezanja kako slijedi.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sklop prednje opružne noge: 
<intxreftitleoff1 refid = "AHRAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rame ovjesa: 
<intxreftitleoff1 refid = "AHRAP70A2206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Okvir prednjeg ovjesa i stabilizatorska šipka: 
<intxreftitleoff1 refid = "AHRAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
