<servinfosub id = "AHRAP70AA504020003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Uključite kontakt.
</ptxt>
</s1>
<s1>
<ptxt>
Pritisnite prekidač zahtjeva vrata povezan s DTC-om.
</ptxt>
</s1>
<s1>
<ptxt>
Otpustite prekidač zahtjeva vrata.
</ptxt>
</s1>
<s1>
<ptxt>
Držite kontakt uključen tijekom 10 minuta ili duže.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA504020004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70AA504020005">
<testgroup id = "AHRAP70AA504020008">
<title>
Provjera parametara
</title>
<test1>
<ptxt>
Priključite SUZUKI alat za skeniranje na DLC s isključenim kontaktom.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite “Prekidač zahtjeva vozača”, “Prekidač zahtjeva suvozača” ili “Prekidač zahtjeva stražnjh vrata /prtljažnika” prikazane na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504020006">
<title>
Provjera kruga signala prekidača zahtjeva vrata
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite prekidač zahtjeva vrata i konektore “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s prekidačem zahtjeva vrata i konektorima &#34;L10&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite da je otpor krugova &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;: manji od 3 &#937;
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504020007">
<title>
Provjera prekidača zahtjeva vrata
</title>
<test1>
<ptxt>
Provjerite prekidač zahtjeva vrata. 
<intxreftitleoff1 refid = "AHRAP70AA506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite prekidač zahtjeva vrata.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504020009">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Spojite prekidač zahtjeva vrata i konektore “L10”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li detektirani trenutni DTC-i B1180, B1181 ili B1182?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
</testgroup>
