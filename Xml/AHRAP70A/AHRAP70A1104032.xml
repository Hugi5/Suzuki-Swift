<servinfosub id = "AHRAP70A1104032003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Nije detektiran DTC P0335 ili P0336.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Pokrenite motor i zagrijte ga na normalnu radnu temperaturu.
</ptxt>
</s1>
<s1>
<ptxt>
Pri 2400 ili više okretaja motora u minuti, vozite vozilo brzinom od 80 do 100 km/h (50 do 60 milja/h) ili većom tijekom 3 min.
</ptxt>
</s1>
<s1>
<ptxt>
Ponovite 2. korak 5 puta.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104032004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104032005">
<testgroup id = "AHRAP70A1104032006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104032007">
<title>
Provjera kruga signala senzora detonacija
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a i konektor senzora detonacija.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34; i konektorom senzora detonacija.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;A1&#34; i &#34;B1&#34;: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova &#34;A1&#34; i &#34;B1&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i drugih terminala konektora na konektoru senzora detonacija: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova &#34;A1&#34; i &#34;B1&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104032008">
<title>
Provjera senzora detonacija
</title>
<test1>
<ptxt>
Provjerite senzor detonacija. 
<intxreftitleoff1 refid = "AHRAP70A1306021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite senzor detonacija.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104032009">
<title>
Rješavanje problema drugih DTC-ova u isto vrijeme
</title>
<question>
Jesu li drugi DTC-ovi detektirani zajedno?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
