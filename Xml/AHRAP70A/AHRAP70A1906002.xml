<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja elektropokretača
</title>
<servinfosub id = "AHRAP70A1906002001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite usisnu granu. 
<intxreftitleoff1 refid = "AHRAP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite nosač senzora detonacija (1) s bloka motora.
</ptxt>
<figure>
<graphic graphicname = "IAP70A190003.swf" width = "88.000mm" height = "58.388mm" ver = "01" gw = "172" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Odvojite žicu magnetskog prekidača (1) i kabel elektropokretača (2) od elektropokretača.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite pričvrsne vijke motora pokretača (3).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite motor pokretača (4).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A190005.swf" width = "183.000mm" height = "82.031mm" ver = "02" gw = "405" gh = "216"/>
</figure>
</servinfosub>
<servinfosub id = "AHRAP70A1906002002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1906009">Pregled elektropokretača</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupaka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zategnite pričvrsne vijke elektropokretača i maticu kabela elektropokretača propisanim momentima pritezanja.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1I001">
<t-part>
Matica kabela elektropokretača
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1I002">
<t-part>
Pričvrsni vijak elektropokretača
</t-part>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
