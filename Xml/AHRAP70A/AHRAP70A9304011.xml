<servinfosub id = "AHRAP70A9304011003">
<title>
Rješavanje problema DTC-a
</title>
<attention3>
<ptxt>
Sljedeći postupak opisuje način provjere DTC B1864: Pogreška sustava parkirnog senzora (straga-lijevo). Slijedite isti postupak i za DTC B1865, B1866 i B1867.
</ptxt>
</attention3>
<diag type = "test" id = "AHRAP70A9304011004">
<testgroup id = "AHRAP70A9304011005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA204003">Provjera DTC-a</intxref>
.
</ptxt>
</test1>
<question>
Je li detektiran DTC B1852?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A9304009">DTC B1852</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A9304011006">
<title>
Provjera parkirnog senzora
</title>
<test1>
<ptxt>
Zamijenite parkirni senzor i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A9306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li detektiran jedan ili više DTC-ova?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul sustava parkirnog senzora 
<intxreftitleoff1 refid = "AHRAP70A9306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite parkirni senzor (straga-lijevo)
</ptxt>
</action>
</testgroup>
</diag>
