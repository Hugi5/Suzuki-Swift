<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A8206024" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stražnjeg senzora bočnog udara
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Ne popravljajte ili rastavljajte senzor.
</ptxt>
</item>
<item>
<ptxt>
Nemojte ga ispustiti, udarati ili tresti.
</ptxt>
<ptxt>
Ako ste ga ispustili, zamijenite ga iako na njemu nema vidljivih oštećenja.
</ptxt>
<ptxt>
Ako je senzor izobličen ili napuknut, zamijenite ga.
</ptxt>
</item>
<item>
<ptxt>
Vijak senzora morate pažljivo pritegnuti propisanim momentom pritezanja kako biste osigurali pravilan rad.
</ptxt>
<ptxt>
Labavo spojen konektor može prouzročiti neispravan rad sustava zračnog jastuka.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AHRAP70A8206024001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Deaktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sklop naslona stražnjeg sjedala 
<intxreftitleoff1 refid = "AHRAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite unutarnju donju obloga krila. 
<intxreftitleoff1 refid = "AHRAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor stražnjeg senzora bočnog udara (2) na sljedeći način.
</ptxt>
<s2>
<ptxt>
Otpustite klizač blokade (1) pomičući ga u smjeru strjelice “1”.
</ptxt>
</s2>
<s2>
<ptxt>
Odspojite konektor stražnjeg senzora bočnog udara (2) povlačeći ga u smjeru strjelice.
</ptxt>
</s2>
</s1>
<s1>
<ptxt>
Uklonite vijak stražnjeg senzora bočnog udara (3) pa uklonite stražnji senzor bočnog udara (4) s unutarnje ploče stražnjeg nosača (5).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820076.swf" width = "88.000mm" height = "104.086mm" ver = "01" gw = "215" gh = "279"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A8206024002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A8206025">Provjera stražnjeg senzora bočnog udara</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Provjerite da ne postoje sljedeći kvarovi.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Savijenost, izobličenje ili hrđa na unutarnjoj ploči krila.
</ptxt>
</item>
<item>
<ptxt>
Strani materijal na senzoru.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Poravnajte pričvrsni zatik (1) s otvorom za ugradnju (2) na vozilu da biste pravilno ugradili stražnji senzor bočnog udara (3).
</ptxt>
</s1>
<s1>
<ptxt>
Pritegnite vijak stražnjeg senzora bočnog udara propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T8B009">
<t-part>
Vijak stražnjeg senzora bočnog udara
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,0
</t-value1>
<t-value2>
0,92
</t-value2>
<t-value3>
7,0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Čvrsto spojite konektor stražnjeg senzora bočnog udara.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820077.swf" width = "88.000mm" height = "71.040mm" ver = "01" gw = "215" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite unutarnju donju obloga krila.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite sklop naslona stražnjeg sjedala. 
<intxreftitleoff1 refid = "AHRAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Aktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
