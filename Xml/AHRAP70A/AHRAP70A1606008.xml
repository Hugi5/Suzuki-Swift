<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1606008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa termostata (dio ECT senzora)
</title>
<servinfosub id = "AHRAP70A1606008001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Ispustite rashladnu tekućinu. 
<intxreftitleoff1 refid = "AHRAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite CMP senzor ispuha. 
<intxreftitleoff1 refid = "AHRAP70A1306017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor ECT senzora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite ulazno crijevo hladnjaka (2) i ulazno crijevo grijača (3) sa sklopa termostata (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite sklop termostata (1) od glave motora.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160003.swf" width = "88.000mm" height = "50.065mm" ver = "01" gw = "181" gh = "125"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1606008002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Upotrijebite novu brtvu.
</ptxt>
</item>
<item>
<ptxt>
Dolijte rashladnu tekućinu u rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Provjerite propušta li rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Provjerite CMP senzor ispuha radi istjecanja ispušnih plinova.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
