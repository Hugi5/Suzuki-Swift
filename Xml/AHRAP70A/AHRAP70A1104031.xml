<servinfosub id = "AHRAP70A1104031002">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Nije aktiviran ESP<sup>®</sup>.
</ptxt>
</item>
<item>
<ptxt>
Nije detektiran DTC P0122, P0123, P0222, P0223, P0335 ili P0336.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Zagrijte motor do normalne radne temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Vozite vozilo konstantnom brzinom od 50 do 80 km/h (31 do 50 milja/h) u trajanju od 5 min ili više.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104031003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104031004">
<testgroup id = "AHRAP70A1104031005">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104031006">
<title>
Provjera razine goriva
</title>
<test1>
<ptxt>
Provjerite razinu goriva pomoću mjerača razine goriva.
</ptxt>
</test1>
<question>
Označava li se razina &#34;E&#34; (prazno)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Dolijte gorivo i ponovno provjerite DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104031007">
<title>
Provjera kvalitete goriva
</title>
<test1>
<ptxt>
Je li korištena ispravna vrsta goriva?
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
 Zamijenite ispravnim gorivom i ponovno provjerite DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104031008">
<title>
Provjera sustava usisa zraka i ispušnog sustava
</title>
<test1>
<ptxt>
Provjerite jesu li ispušni sustav i sustav usisa zraka začepljeni ili propuštaju.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104031009">
<title>
 Provjera sustava paljenja
</title>
<test1>
<ptxt>
Provjerite sustav paljenja. 
<intxreftitleoff1 refid = "AHRAP70A1804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104031010">
<title>
Pregled sustava goriva
</title>
<test1>
<ptxt>
Provjerite sljedeće točke povezane sa sustavom goriva. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tlak goriva: 
<intxreftitleoff1 refid = "AHRAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Krug brizgaljke goriva: 
<intxreftitleoff1 refid = "AHRAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Brizgaljka goriva: 
<intxreftitleoff1 refid = "AHRAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104031011">
<title>
Provjera mehaničkih sustava motora
</title>
<test1>
<ptxt>
Provjerite sljedeće točke koje mogu uzrokovati nemiran rad motora u praznom hodu ili slabe performanse.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kompresija motora. 
<intxreftitleoff1 refid = "AHRAP70A1404001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zračnost ventila. 
<intxreftitleoff1 refid = "AHRAP70A1404003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vrijeme otvaranja ventila. 
<intxreftitleoff1 refid = "AHRAP70A1406023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Provjerite krug napajanja i uzemljenja ECM-a. 
<intxreftitleoff1 refid = "AHRAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ako je krug u redu, zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
</diag>
