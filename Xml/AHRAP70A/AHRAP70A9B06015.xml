<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9B06015" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja vanjske ploče bočnog praga
</title>
<attention3>
<ptxt>
Donja slika prikazuje uvjete za uklanjanje sljedećih dijelova.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednji blatobran 
<intxreftitleoff1 refid = "AHRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0091.jpg" width = "88.000mm" height = "55.869mm" ver = "02" gw = "227" gh = "142"/>
</figure>
<servinfosub id = "AHRAP70A9B06015001">
<title>
Opće napomene
</title>
<list1 type = "unordered">
<item>
<ptxt>
Metoda zavarivanja i broj točaka zavarivanja su jednaki na obje strane. Ove upute za popravljanje prikazuju postupak za lijevu stranu.
</ptxt>
</item>
<item>
<ptxt>
Dio napunjen pjenastim materijalom jedan je od dijelova ovog popravka. Stoga, popravak provodite prema uputama za mjere opreza i postupak popravka pod naslovom 
<intxref refid = "AHRAP70A9B06026">Popravak područja za punjenje pjenastog materijala</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Dimenzije prikazane na slici su referentne vrijednosti pri rezanju zamjenskog dijela koji se postavlja na postojeći dio. Odredite najprikladniju liniju rezanja (spajanja), uzimajući u obzir oboje veličinu zamjenskog dijela i stanje postojećeg dijela.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "AHRAP70A9B06015002">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Označite položaj i odsjecite vanjsku ploču bočnog praga.
</ptxt>
<attention2>
<ptxt>
Pazite da pri rezanju ne oštetite dijelove ispod vanjske ploče bočnog praga.
</ptxt>
</attention2>
</s1>
<s1 page = "2">
<ptxt>
Izbušite mjesta za zavarivanje.
</ptxt>
</s1>
<s1>
<ptxt>
Savijte 3 metalna jezička tako da se otvore (strjelica) i uklonite vanjsku ploču bočnog praga.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0012Q.jpg" width = "183.000mm" height = "224.691mm" ver = "01" gw = "498" gh = "620"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.472in"/>
<colspec colnum = "2" colname = "2" colwidth = "6.442in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 1:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Kad zagrijavate oko nanesenog dijela pjenastog materijala kako biste odvojili pjenasti materijal, pobrinite se da temperatura navedenog dijela ne dostigne 170 &#176;C (338 &#176;F).
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 2:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Kad zagrijavate oko nanesenog dijela brtvila kako biste odvojili brtvilo karoserije, pobrinite se da temperatura navedenog dijela ne dostigne 170 &#176;C (338 &#176;F).
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9B06015003">
<title>
Ugradnja
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Prije zavarivanja, provjerite položaj za ugradnju i uvjete za pravilnu ugradnju dijela (dijelova). 
<intxreftitleoff1 refid = "AHRAP70A9B04006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AHRAP70A9B04007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nastavite s popravkom, imajući na umu ugradnju dijelova koji utječu na izgled vozila. 
<intxreftitleoff1 refid = "AHRAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Ugradite novu vanjsku ploču bočnog praga na karoseriju vozila i
</ptxt>
</s1>
<s1>
<ptxt>
Popravite pjenasti materijal. 
<intxreftitleoff1 refid = "AHRAP70A9B06026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nanesite brtvilo na vanjsku ploču bočnog praga.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite vanjsku ploču bočnog praga.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite elektrootporno točkasto zavarivanje i kontaktno zavarivanje.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite neprekidno zavarivanje.
</ptxt>
</s1>
<s1>
<ptxt>
Nanesite vosak za zaštitu od korozije na stražnju stranu neprekidno zavarenog dijela.
</ptxt>
</s1>
<s1>
<ptxt>
Savijte 3 metalna jezička (strjelica) vanjske ploče bočnog praga.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0013Q.jpg" width = "183.000mm" height = "241.297mm" ver = "01" gw = "507" gh = "667"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "6" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.316in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.974in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.316in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.817in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.316in"/>
<colspec colnum = "6" colname = "6" colwidth = "2.466in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Pjenasti materijal
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Pojačanje šarke stražnjih vrata
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Naneseni dio brtvila za karoseriju.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Vanjska ploča bočnog praga
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Ojačanje bočnog praga
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Provedite elektrootporno točkasto zavarivanje ukupne debljine od tri ploče.
</ptxt>
</entry>
