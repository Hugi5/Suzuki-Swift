<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1704001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Pregled sustava goriva
</title>
<diag type = "test" id = "AHRAP70A1704001001">
<testgroup id = "AHRAP70A1704001002">
<title>
Pregled pumpe goriva
</title>
<test1>
<ptxt>
Uklonite čep otvora za ulijevanje goriva i uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Potvrdite čuje li se zvuk rada pumpe iz otvora za punjenje goriva oko 2 sekunde i zatim prestane.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite krug pumpe goriva. 
<intxreftitleoff1 refid = "AHRAP70A1704004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704001003">
<title>
Provjera tlaka goriva
</title>
<test1>
<ptxt>
Provjerite tlak goriva. 
<intxreftitleoff1 refid = "AHRAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704001004">
<title>
Provjera ravnoteže napajanja
</title>
<test1>
<ptxt>
Provjerite ravnotežu napajanja. 
<intxreftitleoff1 refid = "AHRAP70A1704002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustav goriva je u dobrom stanju.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704001005">
<title>
Provjera kruga brizgaljke goriva
</title>
<test1>
<ptxt>
Provjerite krug brizgaljke goriva. 
<intxreftitleoff1 refid = "AHRAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704001006">
<title>
Provjera brizgaljke goriva
</title>
<test1>
<ptxt>
Provjerite brizgaljku goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite brizgaljku goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
