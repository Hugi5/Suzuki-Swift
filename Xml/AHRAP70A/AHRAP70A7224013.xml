<servinfosub id = "AHRAP70A7224013003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pokrenite motor i uključite sustav klima uređaja.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7224013004">
<title>
Rješavanje problema DTC-a
</title>
<attention3>
<ptxt>
Kada se istovremeno prikazuje kod pogreške DTC B1504-H, moguće je da je prekinut krug senzora.
</ptxt>
</attention3>
<diag type = "test" id = "AHRAP70A7224013005">
<testgroup id = "AHRAP70A7224013006">
<title>
Provjera parametara alata za skeniranje
</title>
<test1>
<ptxt>
Provjerite “Temperaturu u kabini” koristeći način rada “Popis podataka” na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li temperatura ispod –40 &#176;C (–40 &#176;F) (Napon signala senzora temperature zraka unutrašnjosti je veći od 4,9 V)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Isprekidani problem.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224013007">
<title>
Provjera kruga signala senzora temperature zraka u unutrašnjosti
</title>
<test1>
<ptxt>
Odspojite konektor senzora temperature zraka u unutrašnjosti
</ptxt>
</test1>
<test1>
<ptxt>
Spojite terminale žica “PNK/BLK” i “YEL/BLK” konektora senzora temperature zraka u unutrašnjosti pomoću servisne žice.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li otkriven DTC B1502-L?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite senzor temperature zraka unutrašnjosti. 
<intxreftitleoff1 refid = "AHRAP70A7226035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224013008">
<title>
Provjera kruga signala senzora temperature zraka u unutrašnjosti
</title>
<test1>
<ptxt>
Spojite terminale žica “PNK/BLK” i “YEL/BLK” konektora “G20” pomoću servisne žice.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. (Provjera DTC-a): 
<intxreftitleoff1 refid = "AHRAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li otkriven DTC B1502-L?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite upravljački modul HVAC sustava i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
