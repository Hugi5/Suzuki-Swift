<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Teška promjena stupnja prijenosa
</title>
<diag type = "condition">
<condition>
<ptxt>
Teška promjena stupnja prijenosa
</ptxt>
</condition>
<ps>
<ptxt>
Nedovoljno sredstva za podmazivanje
</ptxt>
</ps>
<action>
<ptxt>
Obnovite ulje ručnog mjenjača.
</ptxt>
</action>
<ps>
<ptxt>
Neodgovarajući slobodni hod papučice spojke
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite glavni cilindar ili polugu papučice spojke. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Poluga papučice spojke: 
<intxreftitleoff1 refid = "AHRAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Glavni cilindar spojke: 
<intxreftitleoff1 refid = "AHRAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Deformiran ili slomljen tanjur spojke
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite tanjur spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Oštećena potisna ploča spojke
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite poklopac spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošen prsten sinkrona
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite prsten sinkrona.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Prsten sinkrona niskog stupnja prijenosa i prsten sinkrona 2. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Prsten sinkrona visokog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Prsten sinkrona 5. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Istrošen skošeni zub na ogrlici ili zupčaniku
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite sinkron i ogrlicu sinkrona i zupčanik.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Zupčanik 1. i 2. stupnja prijenosa na predložnom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zupčanik 3. i 4. stupnja prijenosa na ulaznom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zupčanik 5. stupnja prijenosa na ulaznom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sinkron i ogrlica sinkrona niskog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sinkron i ogrlica sinkrona visokog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sinkron i ogrlica sinkrona 5. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Istrošena čahura kontrolnog vratila mjenjača
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite čahuru kontrolnog vratila mjenjača. 
<intxreftitleoff1 refid = "AHRAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformirano vratilo promjene stupnja prijenosa
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite vilicu ili vratilo za odabir stupnja prijenosa.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Vratilo za odabir niskog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vratilo za odabir visokog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vilica odabira 5. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Puknute upravljačke sajle za promjenu / odabir stupnja prijenosa
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite mjenjač i sajlu mjenjača. 
<intxreftitleoff1 refid = "AHRAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
