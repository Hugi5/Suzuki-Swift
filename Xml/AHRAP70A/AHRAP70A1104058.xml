<servinfosub id = "AHRAP70A1104058003">
<title>
Postupak potvrde DTC-a
</title>
<attention3>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon akumulatora &#62; 10 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
IAT &#62; 5 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Uključite kontakt bravu s otpuštenom papučicom gasa na 1 minutu.
</ptxt>
</s1>
<s1>
<ptxt>
Isključite kontakt.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104058004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104058005">
<testgroup id = "AHRAP70A1104058006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104058007">
<title>
Kalibracija sustava upravljanja električnom zaklopkom
</title>
<test1>
<ptxt>
Provedite kalibraciju sustava upravljanja električnom zaklopkom. 
<intxreftitleoff1 refid = "AHRAP70A1306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Ponovno provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se DTC P2176 i dalje?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104058008">
<title>
Provjera ožičenja
</title>
<test1>
<ptxt>
Provjerite sljedeće točke:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Strujni krug TP senzora (glavnog): Pogledajte korake 2 do 4 u poglavlju 
<intxref refid = "AHRAP70A1104024">DTC P0122/P0123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Strujni krug TP senzora (pomoćnog): Pogledajte korake 2 do 4 u poglavlju 
<intxref refid = "AHRAP70A1104030">DTC P0222/P0223</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104058009">
<title>
Provjera TP senzora
</title>
<test1>
<ptxt>
Provjerite TP senzor prema uputama u &#34;Provjera performansi senzora položaja zaklopke (TP)&#34; u odjeljku 
<intxref refid = "AHRAP70A1306004">Provjera sklopa tijela eletrične zaklopke na vozilu</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite sklop tijela električne zaklopke.
</ptxt>
</action>
</testgroup>
</diag>
