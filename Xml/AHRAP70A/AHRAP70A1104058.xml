<ptxt>
<emph>
P2176: Upravljački sustav aktuatora zaklopke - nepoznat položaj praznog hoda
</emph>
</ptxt>
<ptxt>
Kalibracija električnog sustava upravljanja zaklopkom nije potpuna ili je kalibrirani položaj zaklopke izvan propisanog raspona.
</ptxt>
<ptxt>
(logika detekcije 1 ciklusa vožnje)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
TP senzor i/ili njegov krug
</ptxt>
</item>
<item>
<ptxt>
Sklop tijela električne zaklopke
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
