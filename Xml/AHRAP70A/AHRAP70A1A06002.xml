<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1A06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja akumulatora
</title>
<servinfosub id = "AHRAP70A1A06002001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni (-) kabel (1) s akumulatora (4).
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite pozitivni (+) kabel (2) s akumulatora (4).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite držač (3).
</ptxt>
</s1>
<s1>
<ptxt>
Izvadite akumulator (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0001.swf" width = "88.000mm" height = "71.286mm" ver = "01" gw = "171" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite policu akumulatora (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite ECM (2). 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite nosač akumulatora (3) ako je potrebno.
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0002.jpg" width = "88.000mm" height = "55.738mm" ver = "02" gw = "199" gh = "141"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1A06002002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Čvrsto pritegnite kabele akumulatora.
</ptxt>
</item>
<item>
<ptxt>
Ako je potrebno, inicijalizirajte električne uređaje.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
