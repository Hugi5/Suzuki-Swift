<diag type = "test" id = "AHRAP70A6304021002">
<testgroup id = "AHRAP70A6304021003">
<title>
Provjera osigurača strujnog kruga
</title>
<test1>
<ptxt>
Potvrdite da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektore &#34;E13&#34; i &#34;G50&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;G50&#34; i &#34;E13&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi ispravni, provjerite osigurač &#34;P/S&#34; i osigurač &#34;IG1 SIG&#34; radi pregaranja.
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite osigurač(e) i provjerite kratke spojeves uzemljenjem u krugovima povezanima s osiguračem(ima).
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304021004">
<title>
Provjera glavnog napajanja za krug upravljačkog modula P/S-a
</title>
<test1>
<ptxt>
Provjerite napon između terminala “E13-1” i uzemljenja.
</ptxt>
</test1>
<question>
Je li napon 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Krug &#34;A1&#34; je prekinut.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304021005">
<title>
Provjera IG1 napajanja za krug upravljačkog modula P/S-a
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite napon između terminala “G50-3” i uzemljenja.
</ptxt>
</test1>
<question>
Je li napon 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Krug &#34;A2&#34; je prekinut.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304021006">
<title>
Provjera uzemljenja za krug upravljačkog modula P/S-a
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite otpor između terminala “E13-2” i uzemljenja.
</ptxt>
</test1>
<question>
Je li otpor 1 &#937; ili manji?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Krug &#34;A3&#34; je prekinut ili je otpor previsok.
</ptxt>
</action>
</testgroup>
</diag>
