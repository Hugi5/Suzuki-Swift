<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A8106009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa stražnjeg sigurnosnog pojasa
</title>
<servinfosub id = "AHRAP70A8106009001">
<title>
Uklanjanje
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A8106008">Komponente stražnjeg sigurnosnog pojasa</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Uklonite naslon stražnjeg sjedala. 
<intxreftitleoff1 refid = "AHRAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite gornju obloga unutarnjeg krila. 
<intxreftitleoff1 refid = "AHRAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke, a zatim uklonite sklop stražnjeg sigurnosnog pojasa. 
<intxreftitleoff1 refid = "AHRAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A8106009002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A8106008">Komponente stražnjeg sigurnosnog pojasa</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite jesu li zatici (3) na karoseriji umetnuti u duboke otvore (2) na spremniku (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A810014.swf" width = "88.000mm" height = "66.076mm" ver = "01" gw = "206" gh = "171"/>
</figure>
</item>
<item>
<ptxt>
Pritegnite vijke stražnjeg sigurnosnog pojasa brojčanim redoslijedom propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Svaku od ploča sidrišta (1) postavite tako da ne ometate spojeve (2) na podnim pločama.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810015.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
