<title>
DTC C1039/C1071
</title>
<servinfosub id = "AHRAP70A4604025001">
<title>
Detektirano stanje DTC-a i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Detektirano stanje DTC-a
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1039: Unutarnji kvar u sklopu senzora brzine zanošenja/G sile
</emph>
</ptxt>
<ptxt>
Detektiran je unutarnji kvar u senzoru brzine zanošenja/G sile.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Upravljački modul ESP<sup>®</sup>-a
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1071: Unutarnji kvar u upravljačkom modulu ESP<sup>®</sup>-a
</emph>
</ptxt>
<ptxt>
Detektiran je unutarnji kvar u upravljačkom modulu ESP<sup>®</sup>-a.
</ptxt>
</entry>
</row>
