<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1706019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja pomoćnog senzora razine goriva
</title>
<attention2>
<ptxt>
Ne dodirujte ploču otpornika (1) da ne biste iskrivili krak (2). To može dovesti do kvara pomoćnog senzora razine goriva.
</ptxt>
<figure>
<graphic graphicname = "IAP70P170014.swf" width = "88.000mm" height = "66.314mm" ver = "01" gw = "154" gh = "171"/>
</figure>
</attention2>
<servinfosub id = "AHRAP70A1706019001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Spremnik goriva uklonite iz vozila. 
<intxreftitleoff1 refid = "AHRAP70A1706011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Specijalnim alatom uklonite sigurnosnu maticu pumpe goriva (1) sa spremnika goriva (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L1G015">
<s-part>
(A)
</s-part>
<s-number num = "09941-51013">
09941-51013
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A171016.swf" width = "88.000mm" height = "51.053mm" ver = "01" gw = "137" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Polako podignite pomoćni senzor razine goriva (1) i odspojite usisnu cijev goriva (2) s pomoćnog senzora razine goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "IAP70P170015.swf" width = "88.000mm" height = "87.698mm" ver = "01" gw = "171" gh = "232"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite pomoćni senzor razine goriva i O-prsten sa spremnika goriva.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1706019002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1706018">Pregled senzora razine goriva</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Očistite vanjsku površinu cijevi gdje spajate priključak pa pogurajte priključak u cijev tako da brava priključka klikne. Provjerite jesu li cijevi čvrsto spojene. Ako to ne učinite, može doći do istjecanja goriva.
</ptxt>
</attention2>
<s1>
<ptxt>
Očistite dodirne površine sklopa pumpe goriva i spremnika goriva.
</ptxt>
</s1>
<s1>
<ptxt>
Postavite novi O prsten (1) na spremnik goriva (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B170007.swf" width = "88.000mm" height = "56.952mm" ver = "01" gw = "199" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Spojite usisnu cijev goriva (2) na pomoćni senzor razine goriva (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70P170015.swf" width = "88.000mm" height = "87.698mm" ver = "01" gw = "171" gh = "232"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite pomoćni senzor razine goriva (1) na spremnik goriva (2) na sljedeći način:
</ptxt>
<s2>
<ptxt>
Poravnajte znak strjelice (3) na pomoćnom senzoru razine goriva s izrezom (4) na spremniku goriva.
</ptxt>
</s2>
<s2>
<ptxt>
Rukom gurajte pomoćni senzor razine goriva dolje dok ne dođe u kontakt sa spremnikom goriva kako je prikazano na slici.
</ptxt>
<figure>
<graphic graphicname = "IBP60B170008.swf" width = "88.000mm" height = "90.025mm" ver = "01" gw = "219" gh = "239"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.580in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
O prsten
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
U stanju kakvo je u koraku b) rukom pritegnite novu sigurnosnu maticu pumpe goriva (1).
</ptxt>
<attention2>
<ptxt>
Upotrijebite isključivo novu sigurnosnu maticu pumpe goriva. Ako ponovo upotrijebite prethodno uklonjenu sigurnosnu maticu pumpe goriva, može doći do istjecanja goriva.
</ptxt>
</attention2>
<attention3>
<ptxt>
Zategnite sigurnosnu maticu izravno je pritišćući da se ne nagne.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A170015.swf" width = "88.000mm" height = "60.021mm" ver = "01" gw = "128" gh = "154"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.482in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.552in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Pomoćni senzor razine goriva
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
O prsten
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Spremnik goriva
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
Specijalnim alatom zatežite sigurnosnu maticu pumpe goriva (1) dok se oznake (3) na matici pumpe goriva i spremniku goriva ne poravnaju.
</ptxt>
<attention3>
<ptxt>
Oznake se poravnaju kada se sigurnosna matica pumpe goriva zategne otprilike 1 i 1/3 okretaja.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1G016">
<s-part>
(A)
</s-part>
<s-number num = "09941-51013">
09941-51013
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A171018.swf" width = "88.000mm" height = "89.624mm" ver = "01" gw = "152" gh = "238"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Ugradite spremnik goriva u vozilo. 
<intxreftitleoff1 refid = "AHRAP70A1706011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
