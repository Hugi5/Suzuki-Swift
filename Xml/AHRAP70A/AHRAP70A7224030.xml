</table>
</servinfosub>
<servinfosub id = "AHRAP70A7224030002">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pokrenite motor i uključite sustav klima uređaja.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7224030003">
<title>
