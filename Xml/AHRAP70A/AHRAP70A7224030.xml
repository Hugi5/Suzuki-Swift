</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt i provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se DTC B1571 i dalje?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite ispravnim kombiniranim mjeračem i/ili upravljačkim modulom HVAC sustava i ponovno provjerite DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Kombinirani mjerač: 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
