<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1571: Pogreška signala specifikacije kombiniranog mjerača
</emph>
</ptxt>
<ptxt>
Upravljački modul HVAC sustava prima neispravne podatke signala specifikacije kombiniranog mjerača iz kombiniranog mjerača.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Kombinirani mjerač
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul HVAC sustava
</ptxt>
</item>
</list1>
</entry>
