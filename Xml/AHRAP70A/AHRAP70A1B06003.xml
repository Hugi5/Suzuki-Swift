<section sectnbr = "1K">
<servcat sctnbr = "01" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1B06003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja ispušne cijevi i ispušnog lonca
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1B06001">Komponente ispušnog sustava</intxrefpoff>
</ptxt>
<ptxt>
Prilikom zamjene ispušne cijevi i ispušnog lonca, pogledajte 
<intxref refid = "AHRAP70A1B06001">Komponente ispušnog sustava</intxref>
 i tekst koji slijedi.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijke i matice propisanim momentom pritezanja prilikom sastavljanja. 
<intxreftitleoff1 refid = "AHRAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pokrenite motor i provjerite propuštaju li negdje ispušni plinovi.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
