<servinfo servinfosgmlid = "AHRAP70A7216016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja senzora temperature isparivača
</title>
<servinfosub id = "AHRAP70A7216016001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite HVAC jedinicu s karoserije vozila. 
<intxreftitleoff1 refid = "AHRAP70A7216008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite senzor temperature isparivača (1) s isparivača (2) rastavljanjem HVAC jedinice.
</ptxt>
<figure>
<graphic graphicname = "I7RW01721018.swf" width = "88.000mm" height = "35.209mm" ver = "01" gw = "149" gh = "83"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7216016002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A7216017">Pregled senzora temperature isparivača:Ručni tip</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeću točku.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ugradite senzor temperature isparivača (1) na isparivač (2) kao što je prikazano.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70A721019.swf" width = "88.000mm" height = "70.551mm" ver = "02" gw = "167" gh = "183"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.247in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.053in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Približno 30 mm (1,2 in)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Dio senzora učvršćen na 16. rešetki slijeva
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Priključak za cijev
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
