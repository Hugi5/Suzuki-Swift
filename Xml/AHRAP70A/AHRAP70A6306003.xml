<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A6306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja krajnika spone
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A6306002">Pregled manžete krajnika spone na vozilu</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A6306001">Komponente sklopa kućišta upravljačkog prijenosnika</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A6306003001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Podignite vozilo, i zatim uklonite prednji kotač. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite rascjepku (2) i maticu krajnika spone (1) s krajnika spone.
</ptxt>
<figure>
<graphic graphicname = "IAP70A630011.jpg" width = "88.000mm" height = "57.647mm" ver = "01" gw = "171" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Odspojite krajnik spone (1) s kutne poluge upravljača (2) pomoću specijalnog alata.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C003">
<s-part>
(A)
</s-part>
<s-number num = "09913-65210">
09913-65210
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630016.swf" width = "88.000mm" height = "52.953mm" ver = "01" gw = "118" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Za jednostavno namještanje nakon ugradnje, napravite oznaku (1) položaja sigurnosne matice krajnika spone (2) na navoju krajnika spone. Zatim, odvijte sigurnosnu maticu i uklonite krajnik spone (3) sa spone (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A630017.swf" width = "88.000mm" height = "51.911mm" ver = "02" gw = "108" gh = "131"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A6306003002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A6306004">Pregled krajnika spone</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Ugradite sigurnosnu maticu krajnika spone (2) i krajnik spone (3) na sponu (4). Poravnajte sigurnosnu maticu s oznakom (1) na navoju spone.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630017.swf" width = "88.000mm" height = "51.911mm" ver = "02" gw = "108" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Spojite krajnik spone na kutnu polugu upravljača. Zategnite maticu krajnika spone (1) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T6C001">
<t-part>
Matica krajnika spone
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Ugradite kopču (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A630012.jpg" width = "88.000mm" height = "57.647mm" ver = "01" gw = "171" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite prednji kotač. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pregledajte radi usmjerenosti. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nakon potvrđivanja da je usmjerenost propisane vrijednosti, zategnite sigurnosnu maticu krajnika spone propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A6306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
