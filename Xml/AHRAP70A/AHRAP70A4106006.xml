<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A4106006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa papučice kočnice
</title>
<attention2>
<ptxt>
Nikada ne rastavljajte sklop papučice kočnice koja je opremljena mehanizmom zaštitne konstrukcije noge papučice kočnice.
</ptxt>
<ptxt>
Rastavljanje će ugroziti njegovu originalnu funkciju. Ako pronađete kvar, zamijenite ga novim u kompletu.
</ptxt>
</attention2>
<servinfosub id = "AHRAP70A4106006001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite ploču kombiniranog mjerača. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac provrta stupa upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite prekidač svjetla kočenja. 
<intxreftitleoff1 refid = "AHRAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite donje vratilo upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite obujmicu, zatik viličastog zgloba i matice servouređaja kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite maticu nosača papučice kočnice (1) i vijak gornjeg ojačanja pokrova (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite sklop papučice kočnice.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A4106006002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A4106022">Uklanjanje i ugradnja servo uređaja kočnice (pojačala)</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Ugradite sklop papučice kočnice pa ugradite servouređaj kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Zategnite matice servouređaja kočnice primjenom navedenog momenta pritezanja.
</ptxt>
<torque>
<torqueitem id = "T4A001">
<t-part>
Matica servouređaja kočnice*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410009.swf" width = "88.000mm" height = "63.332mm" ver = "01" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Pritegnite maticu nosača papučice kočnice propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T4A002">
<t-part>
Matica nosača papučice kočnice*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Pritegnite vijak ojačanja poprečnog nosača propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T4A003">
<t-part>
Vijak ojačanja poprečnog nosača
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410010.swf" width = "88.000mm" height = "64.412mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite rascjepku i viličasti zglob. 
<intxreftitleoff1 refid = "AHRAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite donje vratilo upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odzračite kočni sustav. 
<intxreftitleoff1 refid = "AHRAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite visinu i slobodni hod papučice kočnice.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Visina slobodne papučice kočnice: 
<intxreftitleoff1 refid = "AHRAP70A4106007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Slobodni hod papučice kočnice: 
<intxreftitleoff1 refid = "AHRAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Ugradite prekidač svjetla kočenja. 
<intxreftitleoff1 refid = "AHRAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite istječe li tekućina na nekom od spojeva i uvjerite se da sustav kočenja ispravno radi.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite poklopac za otvor stupa upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite ploču kombiniranog mjerača. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
