<servinfosub id = "AHRAP70A1104044003">
<title>
Postupak potvrde DTC-a
</title>
<topic id = "AHRAP70A1104044004">
<title>
P0560:
</title>
<s1>
<ptxt>
Uključite kontakt na 1 min.
</ptxt>
</s1>
</topic>
<topic id = "AHRAP70A1104044005">
<title>
P0562/P0563:
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Nije detektiran DTC P0500.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Pokrenite motor i zagrijte ga na normalnu radnu temperaturu.
</ptxt>
</s1>
<s1>
<ptxt>
Vozite vozilo konstantnom brzinom od 40 do 60 km/h (25 do 37 milja/h) u trajanju od 10 min ili više. 
</ptxt>
</s1>
</topic>
</servinfosub>
<servinfosub id = "AHRAP70A1104044006">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104044007">
<testgroup id = "AHRAP70A1104044008">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104044009">
<title>
Provjera kruga napajanja i uzemljenja ECM-a
</title>
<test1>
<ptxt>
Provjerite krug napajanja i uzemljenja ECM-a. 
<intxreftitleoff1 refid = "AHRAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug napajanja i/ili uzemljenja ECM-a.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
