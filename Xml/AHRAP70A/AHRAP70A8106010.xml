<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A8106010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stražnjeg srednjeg sigurnosnog pojasa
</title>
<servinfosub id = "AHRAP70A8106010001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite jastuk naslona stražnjeg sjedala. 
<intxreftitleoff1 refid = "AHRAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijak i maticu, a zatim uklonite sklop stražnjeg srednjeg sigurnosnog pojasa. 
<intxreftitleoff1 refid = "AHRAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A8106010002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A8106003">Pregled sklopa prednjeg sigurnosnog pojasa</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite jesu li zatici (3) na okviru naslona sjedala umetnuti u duboke otvore (2) na spremniku (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A810016.swf" width = "88.000mm" height = "77.820mm" ver = "02" gw = "236" gh = "204"/>
</figure>
</item>
<item>
<ptxt>
Pritegnite vijke stražnjeg srednjeg sigurnosnog pojasa propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pazite da ne stanete na obrub vozila (2) pri instaliranju ploče sidrišta (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A810017.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
