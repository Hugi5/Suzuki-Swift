<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9506012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa regulatora prednjeg prozora
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9506010">Komponente prednjih vrata</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9506012001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite staklo prednjih vrata. 
<intxreftitleoff1 refid = "AHRAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor motora električnog prozora (3).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite matice regulatora prednjeg prozora (1) pa uklonite sklop regulatora prednjeg prozora (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950032.jpg" width = "88.000mm" height = "64.165mm" ver = "03" gw = "225" gh = "165"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9506012002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9506013">Pregled sklopa regulatora prednjeg prozora</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Nanesite mazivo na klizne dijelove sklopa regulatora prednjeg prozora.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E001" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Pritegnite matice regulatora prednjeg prozora redoslijedom (“1” do “6”) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9E003">
<t-part>
Matica regulatora prednjeg prozora*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950033.jpg" width = "88.000mm" height = "70.187mm" ver = "02" gw = "225" gh = "182"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
