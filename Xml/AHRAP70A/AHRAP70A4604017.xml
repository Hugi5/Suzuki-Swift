<servinfosub id = "AHRAP70A4604017003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A4604017004">
<testgroup id = "AHRAP70A4604017005">
<question>
Je li izvršena “Provjera ESP<sup>®</sup> sustava”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A4604001">Provjera ESP® sustava</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604017006">
<title>
Provjera DTC-a za ESP®
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70A4604005">Provjera DTC-a</intxref>
.
</ptxt>
</test1>
<question>
Jesu li detektirani DTC U0073 i/ili U0100?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajuće rješavanje problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604017007">
<title>
Provjera kruga i prekidača svjetla kočenja
</title>
<test1>
<ptxt>
Provjerite prekidač svjetla kočenja i njegove krugove prema koracima 2 do 4 pod 
<intxref refid = "AHRAP70A1104040">DTC P0504</intxref>
.
</ptxt>
</test1>
<question>
Jesu li rezultati provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite.
</ptxt>
</action>
</testgroup>
