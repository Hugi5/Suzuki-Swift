<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A4104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Svjetlo upozorenja ABS-a ne uključuje se nakon uključivanja kontakta
</title>
<diag type = "condition">
<condition>
<ptxt>
Svjetlo upozorenja ABS-a ne uključuje se nakon uključivanja kontakta
</ptxt>
</condition>
<ps>
<ptxt>
Krug napajanja i uzemljenja kombiniranog mjerača u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Provjerite kombinirani mjerač i njegov strujni krug. 
<intxreftitleoff1 refid = "AHRAP70A9304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kombinirani mjerač u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite kombinirani mjerač. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan rad sustava CAN komunikacije
</ptxt>
</ps>
<action>
<ptxt>
Provjerite sustav CAN komunikacije. 
<intxreftitleoff1 refid = "AHRAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pregorjeli osigurač
</ptxt>
</ps>
<action>
<ptxt>
Provjerite osigurač &#34;MTR&#34; i strujni krug koji vodi do osigurača &#34;MTR&#34;: zamijenite ako je potrebno.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
