<servinfosub id = "AHRAP70AA504018002">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</s1>
<s1>
<ptxt>
Uključite kontakt.
</ptxt>
</s1>
<s1>
<ptxt>
Nekoliko puta ponovite korake 1) i 2).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA504018003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70AA504018004">
<testgroup id = "AHRAP70AA504018005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Izbrišite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA504018002">Postupak potvrde DTC-a</intxref>
 i zatim ponovno provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se još uvijek DTC B1161 ili B1163?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504018006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite jedinicu brave upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA504018002">Postupak potvrde DTC-a</intxref>
 i zatim ponovno provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se još uvijek DTC B1161 ili B1163?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Jedinica brave upravljača neispravna.)
</ptxt>
</action>
</testgroup>
