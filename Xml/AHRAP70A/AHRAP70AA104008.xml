<servinfosub id = "AHRAP70AA104008003">
<title>
Rješavanje DTC problema
</title>
<diag type = "test" id = "AHRAP70AA104008004">
<testgroup id = "AHRAP70AA104008005">
<title>
Provjera parametara
</title>
<test1>
<ptxt>
Priključite SUZUKI alat za skeniranje na DLC s isključenim kontaktom.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite “Prekidač tempomata CANCEL”, “Prekidač tempomata RES/ACC”, “Prekidač tempomata SET/COAST” i “Prekidač tempomata UKLJ./ISKLJ.” prikazane na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70AA104006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA104008006">
<title>
Provjera kruga prekidača tempomata
</title>
<test1>
<ptxt>
Potvrdite da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektore “C01”, “E01” i “G371”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala na konektorima &#34;C01&#34;, &#34;E01&#34; i &#34;G371&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu provjerite sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;A1&#34; i &#34;A2&#34;: manji od 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;A1&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i ostalih terminala na konektoru &#34;G371&#34;: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A2&#34; i ostalih terminala na konektoru &#34;G371&#34;: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova &#34;A1&#34; i &#34;A2&#34;: 0 – 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA104008007">
<title>
Provjera prekidača tempomata
</title>
<test1>
<ptxt>
Provjerite prekidač tempomata. 
<intxreftitleoff1 refid = "AHRAP70AA106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite prekidač tempomata. 
<intxreftitleoff1 refid = "AHRAP70AA106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
