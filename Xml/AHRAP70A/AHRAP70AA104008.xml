<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
DTC P0575: Ulazni strujni krug tempomata
</emph>
</ptxt>
<ptxt>
Ovaj se DTC detektira ako je ispunjen bilo koji od sljedećih uvjeta.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon signala kruga signala prekidača tempomata neprestano je određeno vrijeme veći od propisanog napona.
</ptxt>
</item>
<item>
<ptxt>
Signali uključivanja (ON) bilo kojeg ili svih sljedećih prekidača sustava tempomata detektira se dulje od propisanog vremena.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
GLAVNI (UKLJ./ISKLJ.) prekidač
</ptxt>
</item>
<item>
<ptxt>
Prekidač CANCEL
</ptxt>
</item>
<item>
<ptxt>
Prekidač RES/ACC
</ptxt>
</item>
<item>
<ptxt>
Prekidač SET/COAST
</ptxt>
</item>
</list2>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Krug/konektor prekidača tempomata
</ptxt>
</item>
<item>
<ptxt>
Prekidač tempomata
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
