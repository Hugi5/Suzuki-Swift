<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2C">
<servcat sctnbr = "02" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A2306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stražnjeg amortizera
</title>
<servinfosub id = "AHRAP70A2306003001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Podignite vozilo i uklonite stražnje kotače. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac otvora za pristup (1) u unutrašnjoj bočnoj oblozi (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A230002.swf" width = "88.000mm" height = "52.091mm" ver = "01" gw = "165" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Oslonite stražnju osovinu korištenjem podne dizalice kako biste spriječili njeno spuštanje.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite donju maticu stražnjeg amortizera (1) i donju podlošku (5).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite gornju maticu stražnjeg amortizera (2), stražnji amortizer (3) i gornju podlošku amortizera (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A230002.swf" width = "88.000mm" height = "119.930mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite gornje čahure amortizera (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A230004.swf" width = "88.000mm" height = "81.823mm" ver = "01" gw = "147" gh = "215"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A2306003002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A2306004">Pregled stražnjeg amortizera</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Gornja matica stražnjeg amortizera je sigurnosna matica. Maticu ne upotrebljavajte ponovno. U suprotnom, matice se mogu olabaviti.
</ptxt>
</attention2>
<s1>
<ptxt>
Ugradite gornje čahure amortizera (6), stražnji amortizer (1) i gornju podlošku amortizera (2) kako je prikazano na slici.
</ptxt>
<ptxt>
Privremeno zategnite novu gornju maticu (4) amortizera i donju maticu (5) u ovom koraku.
</ptxt>
<attention3>
<ptxt>
Za pravilan smjer ugradnje gornje podloške amortizera (2) pogledajte dolje navedenu sliku.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A230003.swf" width = "88.000mm" height = "52.815mm" ver = "01" gw = "236" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.956in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Ploča karoserije
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Uklonite podnu dizalicu sa stražnje osovine.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite stražnje kotače. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zategnite gornju i donju maticu stražnjeg amortizera propisanim momentima pritezanja.
</ptxt>
<attention3>
<ptxt>
Prilikom zatezanja ovih matica, pripazite da vozilo nije na dizalici i da je neopterećeno.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T2C001">
<t-part>
Gornja matica stražnjeg amortizera
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
28
</t-value1>
<t-value2>
2,9
</t-value2>
<t-value3>
21,0
</t-value3>
</torqueitem>
<torqueitem id = "T2C002">
<t-part>
Donja matica stražnjeg amortizera
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
90
</t-value1>
<t-value2>
9,2
</t-value2>
<t-value3>
66,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A230004.swf" width = "88.000mm" height = "119.931mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite poklopac otvora za pristup u unutrašnjoj bočnoj oblozi.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
