<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9A06007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa prednjih vrata
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9A06006">Komponente prednjih vrata</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9A06007001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite oblogu prednjih vrata. 
<intxreftitleoff1 refid = "AHRAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektore ožičenja vrata s vrata.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijak zadržača otvorenih vrata (1).
</ptxt>
<figure>
<graphic graphicname = "I9W10P9A0009.swf" width = "88.000mm" height = "70.937mm" ver = "02" gw = "193" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Oplatu vrata (1) poduprite dizalicom (2) tako da između dizalice i oplate vrata uložite krpe (3) i komad drveta (4) kako je prikazano na slici.
</ptxt>
<figure>
<graphic graphicname = "I2RH019A0003.swf" width = "88.000mm" height = "48.545mm" ver = "01" gw = "144" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vijke (2) i zatim uklonite prednja vrata (1).
</ptxt>
<figure>
<graphic graphicname = "I9W10P9A0023.swf" width = "88.000mm" height = "64.886mm" ver = "02" gw = "161" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Ako je potrebno, nakon uklanjanja prednjeg blatobrana uklonite šarku vrata. 
<intxreftitleoff1 refid = "AHRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9A06007002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prilikom zamjene vrata, unutrašnjost zamjenskih vrata premažite voskom za zaštitu od korozije, osiguravajući time pravilnu zaštitu od korozije. 
<intxreftitleoff1 refid = "AHRAP70A9C06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nanesite brtvilo na pričvrsnu plohu “A” šarke vrata (1) pa nanesite mazivo na rotirajući dio “B” šarke vrata (1).
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1215" id = "M9J002" uid = "27">
<m-part>
“A”
</m-part>
<m-desc>
Brtvilo
</m-desc>
<m-number>
99000-31110
</m-number>
<m-name>
SUZUKI Bond br.1215
</m-name>
<ptxt>
</ptxt>
</materialitem>
<materialitem name = "SUZUKI Super Grease A" id = "M9J003" uid = "1126491901">
<m-part>
“B”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9W10P9A0010.jpg" width = "88.000mm" height = "70.516mm" ver = "01" gw = "228" gh = "183"/>
</figure>
</item>
<item>
<ptxt>
Pritegnite vijke šarke prednjih vrata i vijak zadržača otvorenih vrata propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A9A06006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Prilikom ugradnje zadržača vrata (1), okrenite odgovarajuću oznaku (2) prema gore.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Desna vrata: Oznaka “R” okrenuta je prema gore
</ptxt>
</item>
<item>
<ptxt>
Lijeva vrata: Oznaka “R” okrenuta je prema gore
</ptxt>
<figure>
<graphic graphicname = "I9W10P9A0011.swf" width = "88.000mm" height = "71.083mm" ver = "02" gw = "193" gh = "185"/>
</figure>
</item>
</list2>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Namjestite položaj zadržača vrata. 
<intxreftitleoff1 refid = "AHRAP70A9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nakon instalacije otvorite i zatvorite vrata da biste provjerili zatvaraju li se glatko i čvrsto.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
