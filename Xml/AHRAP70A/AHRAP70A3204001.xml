</ptxt>
</ps>
<action>
<ptxt>
Namjestite razinu ulja. 
<intxreftitleoff1 refid = "AHRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
