<title>
Dijagnostika simptoma stražnjeg diferencijala
</title>
<diag type = "condition" id = "AHRAP70A3204001001">
<condition>
<ptxt>
Buka zupčanika
</ptxt>
</condition>
<ps>
<ptxt>
Istrošeno mazivo ili mazivo miješano s vodom
</ptxt>
</ps>
<action>
<ptxt>
Popravite i napunite. 
<intxreftitleoff1 refid = "AHRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neodgovarajuće mazivo ili nedovoljna količina maziva
</ptxt>
</ps>
<action>
<ptxt>
Popravite i napunite. 
<intxreftitleoff1 refid = "AHRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</action>
<ps>
<ptxt>
Loše namješten zazor između tanjurastog i stožastog zupčanika
</ptxt>
</ps>
<action>
<ptxt>
Namjestite kako je propisano. 
<intxreftitleoff1 refid = "AHRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neodgovarajući kontakt zuba u zahvatu između tanjurastog i stožastog zupčanika
</ptxt>
</ps>
<action>
<ptxt>
Namjestite ili zamijenite. 
<intxreftitleoff1 refid = "AHRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Oslabljeni sigurnosni vijci tanjurastog zupčanika
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ili pritegnite. 
<intxreftitleoff1 refid = "AHRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Oštećeni sateliti ili zupačnici poluosovine
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite. 
<intxreftitleoff1 refid = "AHRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Stalna buka ležaja
</ptxt>
</condition>
<ps>
<ptxt>
Istrošeno mazivo ili mazivo miješano s vodom
</ptxt>
</ps>
<action>
<ptxt>
Popravite i napunite. 
<intxreftitleoff1 refid = "AHRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neodgovarajuće mazivo ili nedovoljna količina maziva
</ptxt>
</ps>
<action>
<ptxt>
Popravite i napunite. 
<intxreftitleoff1 refid = "AHRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Buka ležajeva u kretanju
</ptxt>
</condition>
<ps>
<ptxt>
