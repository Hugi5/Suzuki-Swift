</ptxt>
</ps>
<action>
<ptxt>
Zamijenite. 
<intxreftitleoff1 refid = "AHRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Curenje ulja
</ptxt>
</condition>
<ps>
<ptxt>
Zapriječen čep oduška
</ptxt>
</ps>
<action>
<ptxt>
Očistite.
</ptxt>
</action>
