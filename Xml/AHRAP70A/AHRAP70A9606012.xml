<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja brave vrata prtljažnika
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9606010">Komponente brave vrata prtljažnika</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A9606011">Pregled kopče brave vrata prtljažnika na vozilu</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9606012001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite oblogu vrata prtljažnika (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70P960027.jpg" width = "88.000mm" height = "80.582mm" ver = "01" gw = "198" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Odspojite konektor brave vrata prtljažnika (1) sa sklopa brave vrata prtljažnika (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odvijte vijke brave vrata prtljažnika (3) pa uklonite sklop brave vrata prtljažnika (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A960004.jpg" width = "88.000mm" height = "53.858mm" ver = "01" gw = "142" gh = "136"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9606012002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijke brave vrata prtljažnika propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9F002">
<t-part>
Vijak brave vrata prtljažnika
</t-part>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Po potrebi namjestite zadržač kopče vrata prtljažnika na sljedeći način.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Olabavite vijke zadržača kopče vrata prtljažnika (1)
</ptxt>
</item>
<item>
<ptxt>
Namjestite položaj zadržača kopče vrata prtljažnika (2) tako da se vrata prtljažnika mogu neometano otvarati i zatvarati.
</ptxt>
</item>
<item>
<ptxt>
Pritegnite vijke zadržača vrata prtljažnika propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9F003">
<t-part>
Vijak zadržača kopče vrata prtljažnika
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A960018.jpg" width = "88.000mm" height = "61.730mm" ver = "02" gw = "198" gh = "158"/>
</figure>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
