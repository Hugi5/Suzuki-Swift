<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70AA504012" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1123
</title>
<servinfosub id = "AHRAP70AA504012001">
<title>
Detektirano stanje DTC-a i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.461in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.744in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Detektirano stanje DTC-a
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1123: Kvar pomoćnog napajanja
</emph>
</ptxt>
<ptxt>
Napon kruga pomoćnog napajanja iz &#34;DOME&#34; osigurača manji je od propisane vrijednosti.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Osigurač “DOME”
</ptxt>
</item>
<item>
<ptxt>
Svaki sustav spojen je putem &#34;DOME&#34; osigurača
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul sustava pokretanja bez ključa
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70AA504012002">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Uključite kontakt.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA504012003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70AA504012004">
<testgroup id = "AHRAP70AA504012005">
<title>
Provjera osigurača
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite &#34;DOME&#34; osigurač.
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite &#34;DOME&#34; osigurač i idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504012006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC B1123?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504012007">
<title>
Svaka provjera sustava spojena je putem &#34;DOME&#34; osigurača
</title>
<test1>
<ptxt>
Provjerite svaki sustav spojen preko &#34;DOME&#34; osigurača, osim upravljačkog modula sustava pokretanja bez ključa.
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite &#34;DOME&#34; osigurač i zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio i/ili ožičenje, a zatim zamijenite &#34;DOME&#34; osigurač i ponovno provjerite DTC.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
