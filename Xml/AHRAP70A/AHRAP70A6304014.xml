<servinfosub id = "AHRAP70A6304014003">
<title>
Postupak potvrde DTC-a
</title>
<ptxt>
Pustite da motor radi u praznom hodu dulje od 5 sekundi.
</ptxt>
</servinfosub>
<servinfosub id = "AHRAP70A6304014004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A6304014005">
<testgroup id = "AHRAP70A6304014006">
<question>
Je li izvršena &#34;Provjera sustava P/S-a&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A6304001">Provjera sustava P/S-a</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304014007">
<title>
Provjera kruga glavnog napajanja i uzemljenja upravljačkog modula servoupravljača
</title>
<test1>
<ptxt>
Provjerite krugove &#34;A1&#34; i &#34;A2&#34;. 
<intxreftitleoff1 refid = "AHRAP70A6304021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304014008">
<title>
Provjera napona napajanja upravljačkog modula P/S-a
</title>
<test1>
<ptxt>
Izmjerite napon akumulatora dok motor radi u praznom hodu.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite napon akumulatora dok motor radi na 3000 okr./min.
</ptxt>
</test1>
<question>
Jesu li naponi između 9 V i 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul P/S-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite sustav punjenja. 
<intxreftitleoff1 refid = "AHRAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
