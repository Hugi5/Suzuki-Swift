<servinfosub id = "AHRAP70A8204052002">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204052003">
<testgroup id = "AHRAP70A8204052004">
<title>
Provjera napona akumulatora
</title>
<test1>
<ptxt>
Provjerite napon akumulatora.
</ptxt>
</test1>
<question>
Iznosi li napon između 9 - 16 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite sustav za punjenje i popravite ga. 
<intxreftitleoff1 refid = "AHRAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204052005">
<title>
Provjera spoja SDM-a
</title>
<test1>
<ptxt>
Provjerite ispravnost spoja s konektorom SDM-a.
</ptxt>
</test1>
<question>
Je li čvrsto spojen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Isprekidani problem. Provjerite postoje li isprekidani problemi. 
<intxreftitleoff1 refid = "AHRAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ako je sve u redu, zamijenite ispravnim SDM-om i ponovno provjerite. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204052006">
<title>
Provjera osigurača
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite osigurač “A/B”
</ptxt>
</test1>
<question>
Je li osigurač A/Bu dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje poda pa zamijenite osigurač “A/B”.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204052007">
<title>
Provjera kruga napajanja
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “L04”.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite napon između terminala “L04-18” i uzemljenja.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B095">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820157.swf" width = "90.000mm" height = "34.401mm" ver = "01" gw = "194" gh = "81"/>
</testfigure>
</test1>
<question>
Iznosi li napon između 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje poda.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204052008">
<title>
Provjera kruga uzemljenja
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite otpor između terminala “L04-23” i uzemljenja.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B096">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820158.swf" width = "90.000mm" height = "34.895mm" ver = "01" gw = "193" gh = "82"/>
</testfigure>
</test1>
<question>
Je li otpor 1 &#937; ili manji?
</question>
<result type = "yes"/>
<action>
<ptxt>
Krug napajanja i krug uzemljenja SDM-a su u dobrom stanju.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje poda.
</ptxt>
</action>
</testgroup>
</diag>
