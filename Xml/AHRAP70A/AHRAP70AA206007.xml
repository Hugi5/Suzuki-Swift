<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70AA206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja prijamnika sustava ulaska bez ključa (model s kontakt bravom)
</title>
<s1>
<ptxt>
Odspojite negativni (–) kabel s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite bočnu oblogu lijeve ploče s instrumentima. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac provrta stupa upravljača prema koraku 4) od 
<intxref refid = "AHRAP70A6206009">Uklanjanje i ugradnja stupa upravljača</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Iskopčajte konektor (1) prijamnika sustava ulaska bez ključa.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijak, a zatim uklonite prijamnik sustava ulaska bez ključa (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20024.jpg" width = "88.000mm" height = "66.001mm" ver = "01" gw = "204" gh = "171"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
