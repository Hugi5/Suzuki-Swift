<servinfosub id = "AHRAP70A4604030003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A4604030004">
<testgroup id = "AHRAP70A4604030005">
<question>
Je li izvršena “Provjera ESP<sup>®</sup> sustava”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A4604001">Provjera ESP® sustava</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604030006">
<title>
Provjera strujnog kruga napajanja upravljačkog modula ESP®-a
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “E24”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja na terminalu “E24-26”.
</ptxt>
</test1>
<test1>
<ptxt>
Ako je spoj u redu, izmjerite napon između terminala “E24-26” i uzemljenja.
</ptxt>
</test1>
<question>
Iznosi li 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite krug &#34;A1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604030007">
<title>
Provjera strujnog kruga uzemljenja upravljačkog modula ESP®-a
</title>
<test1>
<ptxt>
Izmjerite otpor između svakog terminala “E24-14” i “E24-27” i uzemljenja.
</ptxt>
</test1>
<question>
Je li otpor manji od 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite krug &#34;B1&#34; i/ili &#34;B2&#34;.
</ptxt>
</action>
</testgroup>
</diag>
