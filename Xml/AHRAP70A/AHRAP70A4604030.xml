<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1061: Rad strujnog kruga motora pumpe
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon napajanja motora pumpe je izvan propisanog raspona.
</ptxt>
</item>
<item>
<ptxt>
Motor pumpe aktivira se iako je upravljački relej motora pumpe isključen.
</ptxt>
</item>
<item>
<ptxt>
Motor pumpe ne aktivira se iako je upravljački relej motora pumpe uključen.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Krug napajanja upravljačkog modula ESP<sup>®</sup>-a (motor pumpe)
</ptxt>
</item>
<item>
<ptxt>
Krug uzemljenja upravljačkog modula ESP<sup>®</sup>-a
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul ESP<sup>®</sup>-a
</ptxt>
</item>
</list1>
</entry>
</row>
