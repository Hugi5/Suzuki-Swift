<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1306027" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Provjera OCV-a
</title>
<list1 type = "unordered">
<item>
<ptxt>
Uklonite OCV-e (usisnu i ispušnu stranu). 
<intxreftitleoff1 refid = "AHRAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Provjerite OCV-e (usisnu i ispušnu stranu) kako slijedi.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Provjerite otpor između terminala OCV konektora (1).
</ptxt>
<ptxt>
Ako rezultat provjere nije zadovoljavajući, zamijenite OCV.
</ptxt>
<spec>
<title>
Otpor OCV-a
</title>
<ptxt>
6,7 do 7,7 &#937; pri 20 &#176;C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9T401132006.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "180" gh = "153"/>
</figure>
</item>
<item>
<ptxt>
Spojite akumulator na OCV konektor (1) kako je prikazano na slici i provjerite zvuk rada momenta razvodnog klipa (2).
</ptxt>
<figure>
<graphic graphicname = "I9T401132007.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "193" gh = "153"/>
</figure>
</item>
</list2>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
