<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A7214A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hladni zrak ne izlazi van ili nedovoljno hlađenje (normalan rad magnetske spojke)
</title>
<diag type = "condition">
<condition>
<ptxt>
Hladni zrak ne izlazi van ili nedovoljno hlađenje (normalan rad magnetske spojke)
</ptxt>
</condition>
<ps>
<ptxt>
Nedovoljno ili prekomjerno napunjeno rashladno sredstvo
</ptxt>
</ps>
<action>
<ptxt>
Provjerite količinu rashladnog sredstva i sustav radi istjecanja.
</ptxt>
</action>
<ps>
<ptxt>
Začepljen kondenzator
</ptxt>
</ps>
<action>
<ptxt>
Provjerite kondenzator. 
<intxreftitleoff1 refid = "AHRAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Začepljen ili zamrznut isparivač klima uređaja
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite isparivač klima uređaja i senzor temperature isparivača.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Isparivač klima uređaja: 
<intxreftitleoff1 refid = "AHRAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Senzor temperature isparivača: 
<intxreftitleoff1 refid = "AHRAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Kvar senzora temperature isparivača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite senzor temperature isparivača. 
<intxreftitleoff1 refid = "AHRAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan ekspanzijski ventil
</ptxt>
</ps>
<action>
<ptxt>
Provjerite ekspanzijski ventil. 
<intxreftitleoff1 refid = "AHRAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Labav ili oštećen pogonski remen kompresora
</ptxt>
</ps>
<action>
<ptxt>
Provjerite pogonski remen kompresora. 
<intxreftitleoff1 refid = "AHRAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Magnetska spojka proklizuje
</ptxt>
</ps>
<action>
<ptxt>
Provjerite magnetsku spojku. 
<intxreftitleoff1 refid = "AHRAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan kompresor
</ptxt>
</ps>
<action>
<ptxt>
Provjerite kompresor.
</ptxt>
</action>
<ps>
<ptxt>
Zrak u sustavu klima uređaja
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite kondenzator, a zatim provedite odzračivanje i punjenje rashladnog sredstva. 
<intxreftitleoff1 refid = "AHRAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istjecanje zraka iz HVAC jedinice ili kanala zraka
</ptxt>
</ps>
<action>
<ptxt>
Popravite HVAC jedinicu ili kanal za zrak.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sustav grijača i sustav provjetravanja
</ptxt>
</ps>
<action>
<ptxt>
Provjerite HVAC jedinicu.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan motor puhala
</ptxt>
</ps>
<action>
<ptxt>
Provjerite motor puhala. 
<intxreftitleoff1 refid = "AHRAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prekomjerno ulje kompresora u sustavu klima uređaja
</ptxt>
</ps>
<action>
<ptxt>
Ispustite prekomjerno ulje kompresora iz kruga sustava klima uređaja i kompresora.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
