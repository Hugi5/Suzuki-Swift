<servinfo servinfosgmlid = "AHRAP70A9B06003" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja nosača na strani plašta
</title>
<attention3>
<ptxt>
Donja slika prikazuje uvjete za uklanjanje sljedećih dijelova.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednji blatobran 
<intxreftitleoff1 refid = "AHRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nosač brave poklopca prostora motora, vodoravni potporni element svjetla i potporanj nosača svjetla 
<intxreftitleoff1 refid = "AHRAP70A9B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Donji nosač prednjeg blatobrana 
<intxreftitleoff1 refid = "AHRAP70A9B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vanjski nosač na strani poprečnog veznog lima 
<intxreftitleoff1 refid = "AHRAP70A9B06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Prednja ploča na strani poprečne pregrade i prednja ploča na strani gornjeg lima uz vjetrobran 
<intxreftitleoff1 refid = "AHRAP70A9B06006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ploča plašta blatobrana, produžetak plašta blatobrana i gornji nosač ovjesa 
<intxreftitleoff1 refid = "AHRAP70A9B06007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0010.jpg" width = "88.000mm" height = "56.208mm" ver = "01" gw = "227" gh = "143"/>
</figure>
<servinfosub id = "AHRAP70A9B06003001">
<title>
Opće napomene
</title>
<ptxt>
Metoda zavarivanja i broj točaka zavarivanja su jednaki na obje strane. Ove upute za popravljanje prikazuju postupak za lijevu stranu.
</ptxt>
</servinfosub>
<servinfosub id = "AHRAP70A9B06003002">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Izbušite zavarene točke i uklonite nosač na strani plašta.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0011.jpg" width = "183.000mm" height = "196.851mm" ver = "06" gw = "496" gh = "541"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.466in"/>
<colspec colnum = "2" colname = "2" colwidth = "5.199in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Po potrebi izbrusite mjesta zavarivanja pomoću trakaste brusilice.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9B06003003">
<title>
Ugradnja
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Prije zavarivanja, provjerite položaj za ugradnju i uvjete za pravilnu ugradnju dijela (dijelova). 
<intxreftitleoff1 refid = "AHRAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AHRAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nastavite s popravkom, imajući na umu ugradnju dijelova koji utječu na izgled vozila. 
<intxreftitleoff1 refid = "AHRAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention2>
<s1>
<ptxt>
Ugradite nosač na strani plašta.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite elektrootporno točkasto zavarivanje i kontaktno zavarivanje.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0012.jpg" width = "183.000mm" height = "196.851mm" ver = "04" gw = "492" gh = "541"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
