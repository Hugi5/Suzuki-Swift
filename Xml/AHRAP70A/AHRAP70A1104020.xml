<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0107: Niski napon strujnog kruga apsolutnog tlaka u grani/barometarskog tlaka
</emph>
</ptxt>
<ptxt>
Izlazni napon kruga signala MAP senzora niži je od 0,01 V tijekom 5 s.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
MAP senzor i/ili njegov krug
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0108: Visoki napon strujnog kruga apsolutnog tlaka u grani/barometarskog tlaka
</emph>
</ptxt>
<ptxt>
Izlazni napon kruga signala MAP senzora viši je od 4,74 V tijekom 5 s.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
