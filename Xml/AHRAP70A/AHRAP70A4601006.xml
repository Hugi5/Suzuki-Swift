<servinfo servinfosgmlid = "AHRAP70A4601006" svcinfotypenbr = "03" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Opis uvjeta za kalibraciju senzora
</title>
<ptxt>
Kada se završe sljedeće operacije, trebate izvršiti kalibriranje senzora zato što su originalni podaci kalibriranja izbrisani. <sup></sup>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1" page = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.646in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.558in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Senzor koji će se kalibrirati
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Uvjeti koji zahtijevaju kalibriranje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Senzor kuta zakretanja upravljača
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Senzor kuta zakretanja upravljača je zamijenjen.
</ptxt>
</item>
<item>
<ptxt>
Sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a je zamijenjen.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Senzor tlaka glavnog cilindra kočnice
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a je zamijenjen.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
