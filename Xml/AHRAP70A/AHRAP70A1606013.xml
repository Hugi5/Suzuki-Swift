<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1606013" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Sastavljanje i rastavljanje ventilatora hlađenja hladnjaka
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1606012">Uklanjanje i ugradnja sklopa ventilatora hlađenja hladnjaka</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1606013001">
<title>
Rastavljanje
</title>
<s1 page = "2">
<ptxt>
Uklonite ventilator (1) iz motora ventilatora hlađenja (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite motor ventilatora hlađenja (2) iz kućišta ventilatora hlađenja (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P160006.jpg" width = "88.000mm" height = "55.324mm" ver = "01" gw = "207" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1606013002" page = "2">
<title>
Sastavljanje
</title>
<ptxt>
Obrnite postupak rastavljanja.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zategnite maticu ventilatora i vijke motora ventilatora hlađenja hladnjaka propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1F001">
<t-part>
Matica ventilatora
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
<torqueitem id = "T1F002">
<t-part>
Vijak motora ventilatora hlađenja hladnjaka
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
4,0
</t-value1>
<t-value2>
0,41
</t-value2>
<t-value3>
3,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70P160010.jpg" width = "88.000mm" height = "51.127mm" ver = "03" gw = "223" gh = "128"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
