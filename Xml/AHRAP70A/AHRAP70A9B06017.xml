<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Naneseni dio brtvila za karoseriju.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Ugradite novu vanjsku ploču nosača krila na karoseriju vozila iskrojivši je preklapanjem ploča.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vanjsku ploču nosača krila i nanesite brtvilo za karoseriju.
</ptxt>
</s1>
<s1>
<ptxt>
Ponovno ugradite vanjsku ploču nosača krila na karoseriju vozila.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite elektrootporno točkasto zavarivanje ili kontaktno zavarivanje.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite neprekidno zavarivanje.
</ptxt>
</s1>
<s1>
<ptxt>
Nanesite vosak za zaštitu od korozije na stražnju stranu neprekidno zavarenog dijela.
</ptxt>
</s1>
<s1>
<ptxt>
Savijte metalni jezičak (strjelica) vanjske ploče nosača krila.
</ptxt>
