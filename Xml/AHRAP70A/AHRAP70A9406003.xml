<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9406003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja motora brisača vjetrobrana
</title>
<servinfosub id = "AHRAP70A9406003001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite poklopce osovina brisača (1) i matice poluga brisača (2) pa uklonite poluge brisača vjetrobrana (3).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite gornju oblogu poprečnog veznog lima (4). 
<intxreftitleoff1 refid = "AHRAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I9P60A940005.jpg" width = "88.000mm" height = "62.898mm" ver = "01" gw = "198" gh = "162"/>
</figure>
</s1>
<s1>
<ptxt>
Odspojite konektor motora brisača vjetrobrana (3).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke motora brisača (1) i uklonite motor brisača vjetrobrana (2) u smjeru strjelice kako je prikazano na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A940006.jpg" width = "88.000mm" height = "41.842mm" ver = "01" gw = "217" gh = "102"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9406003002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9406004">Pregled rada motora brisača vjetrobrana</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijke motora brisača brojčanim redoslijedom (“1” do “2”) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9D002">
<t-part>
Vijak motora brisača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A940007.jpg" width = "88.000mm" height = "41.842mm" ver = "02" gw = "217" gh = "102"/>
</figure>
<list1 type = "unordered">
<item>
<ptxt>
Ugradite polugu brisača vjetrobrana (1) u položaje prikazane na slici.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Desna strana [A]
</ptxt>
<ptxt>
Poravnajte vrh metlice brisača vjetrobrana (5) s oznakom (4).
</ptxt>
</item>
<item>
<ptxt>
Lijeva strana [B]
</ptxt>
<ptxt>
Poravnajte metlicu s keramičkom linijom (3).
</ptxt>
</item>
</list2>
<item>
<ptxt>
Pritegnite matice poluge brisača propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9D003">
<t-part>
Matica poluge brisača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1,6
</t-value2>
<t-value3>
12,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940009.swf" width = "88.000mm" height = "77.752mm" ver = "02" gw = "189" gh = "204"/>
