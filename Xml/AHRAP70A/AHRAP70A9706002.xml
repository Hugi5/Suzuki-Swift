<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9706002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja prednjeg sjedala
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9706001">Komponente prednjeg sjedala</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9706002001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Deaktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektore s prednjeg sjadala.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite 4 pričvrsna vijka pa uklonite sklop sjedala.
</ptxt>
</s1>
<s1>
<ptxt>
Po potrebi rastavite i popravite dijelove. 
<intxreftitleoff1 refid = "AHRAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9706002002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Za propisani moment pritezanja pogledajte 
<intxref refid = "AHRAP70A9706001">Komponente prednjeg sjedala</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Aktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
