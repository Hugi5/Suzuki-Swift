<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A3204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Buka zupčanika
</title>
<diag type = "condition">
<condition>
<ptxt>
Buka zupčanika
</ptxt>
</condition>
<ps>
<ptxt>
Istrošeno mazivo ili mazivo miješano s vodom
</ptxt>
</ps>
<action>
<ptxt>
Popravite i napunite. 
<intxreftitleoff1 refid = "AHRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neodgovarajuće mazivo ili nedovoljna količina maziva
</ptxt>
</ps>
<action>
<ptxt>
Popravite i napunite. 
<intxreftitleoff1 refid = "AHRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</action>
<ps>
<ptxt>
Loše namješten zazor između tanjurastog i stožastog zupčanika
</ptxt>
</ps>
<action>
<ptxt>
Namjestite kako je propisano. 
<intxreftitleoff1 refid = "AHRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neodgovarajući kontakt zuba u zahvatu između tanjurastog i stožastog zupčanika
</ptxt>
</ps>
<action>
<ptxt>
Namjestite ili zamijenite. 
<intxreftitleoff1 refid = "AHRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Oslabljeni sigurnosni vijci tanjurastog zupčanika
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ili pritegnite. 
<intxreftitleoff1 refid = "AHRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Oštećeni sateliti ili zupačnici poluosovine
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite. 
<intxreftitleoff1 refid = "AHRAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
