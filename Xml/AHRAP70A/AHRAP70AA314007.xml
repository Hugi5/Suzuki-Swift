</title>
<diag type = "test" id = "AHRAP70AA314007003">
<testgroup id = "AHRAP70AA314007004">
<title>
Registracija ECM-a
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA316003">Registracija u ECM:Model s kontakt bravom</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se DTC P1611 i dalje?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. Ako se i dalje detektira DTC P1611, zamijenite BCM i ponovno provjerite DTC. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "AHRAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (ECM nije registriran)
</ptxt>
