<servinfo servinfosgmlid = "AHRAP70AA324015" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1173
</title>
<servinfosub id = "AHRAP70AA324015001">
<title>
Detektirano DTC stanje i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Detektirano DTC stanje
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1173: Neregistrirani primopredajnik
</emph>
</ptxt>
<ptxt>
Kod primopredajnika u primopredajniku ugrađenom u daljinski upravljač nije registriran.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Daljinski upravljač nije registriran
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul sustava pokretanja bez ključa
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70AA324015002">
<title>
Rješavanje problema DTC-a
</title>
<attention3>
<ptxt>
Uzrok nemogućnosti da se normalno registrira blokada motora može biti kvar daljinskog upravljača.
</ptxt>
</attention3>
</servinfosub>
<diag type = "test" id = "AHRAP70AA324015003">
<testgroup id = "AHRAP70AA324015006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC u upravljačkom modulu sustava pokretanja bez ključa. 
<intxreftitleoff1 refid = "AHRAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Postoje li DTC-ovi koji se odnose na CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324015005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC povezan s CAN komunikacijom.
</ptxt>
</test1>
<question>
Postoje li DTC-ovi koji se odnose na CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324015004">
<title>
Registracija daljinskog upravljača
</title>
<test1>
<ptxt>
Izvršite &#34;Registraciju ključa blokade motora&#34;. 
<intxreftitleoff1 refid = "AHRAP70AA326002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC B1173?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Daljinski upravljač nije registriran)
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
