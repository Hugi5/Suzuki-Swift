<servinfosub id = "AHRAP70A6304016002">
<title>
Postupak potvrde DTC-a
</title>
<topic id = "AHRAP70A6304016003">
<title>
DTC C1161
</title>
<list1 type = "unordered">
<item>
<ptxt>
Pogledajte Postupak potvrde za DTC P0500 senzora &#34;A&#34; brzine vozila. 
<intxreftitleoff1 refid = "AHRAP70A1104039"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</topic>
<topic id = "AHRAP70A6304016004">
<title>
DTC C1162
</title>
<list1 type = "unordered">
<item>
<ptxt>
Pogledajte Postupak potvrde za DTC P0335 senzora &#34;A&#34; položaja koljenastog vratila. 
<intxreftitleoff1 refid = "AHRAP70A1104033"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</topic>
</servinfosub>
<servinfosub id = "AHRAP70A6304016005">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A6304016006">
<testgroup id = "AHRAP70A6304016007">
<question>
Je li izvršena &#34;Provjera sustava P/S-a&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A6304001">Provjera sustava P/S-a</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304016008">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
 Provjerite DTC u ECM-u. 
<intxreftitleoff1 refid = "AHRAP70A6304003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li detektiran jedan ili više DTC-ova?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC. (ECM-neispravno povezan) 
<intxreftitleoff1 refid = "AHRAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite upravljački modul P/S-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
