<servinfosub id = "AHRAP70A8204041003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204041004">
<testgroup id = "AHRAP70A8204041005">
<question>
Je li izvršena “Provjera dijagnostičkog sustava zračnih jastuka”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204041006">
<title>
Provjera kruga ožičenja ploče s instrumentima
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “G222”.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “G11”.
</ptxt>
</test1>
<test1>
<ptxt>
Otpustite kratkospojnu šipku u konektoru SDM-a tako da umetnete alat za otpuštanje priložen sa specijalnim alatom (A).
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon između svakog od terminala “G11-1” i “G11-2” i uzemljenja: približno 0 V
</ptxt>
<servicetool>
<servicetoolitem id = "L8B077">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
</item>
</list1>
<testfigure>
<graphic graphicname = "IAW10A820027.swf" width = "90.000mm" height = "58.392mm" ver = "01" gw = "197" gh = "149"/>
</testfigure>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite SDM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po završetku pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ako su detektirani DTC-ovi, izbrišite ih prema uputama pod naslovom 
<intxref refid = "AHRAP70A8204006">Brisanje DTC-a</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem riješen.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
