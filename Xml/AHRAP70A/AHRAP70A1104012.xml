<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1104012" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
MIL ostaje uključen nakon pokretanja motora
</title>
<servinfosub id = "AHRAP70A1104012001">
<title>
Rješavanje problema
</title>
<diag type = "test" id = "AHRAP70A1104012002">
<testgroup id = "AHRAP70A1104012003">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Pokrenite motor i ponovo provjerite DTC u ECM-u dok motor radi.
</ptxt>
</test1>
<question>
Postoje li DTC-ovi?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za odgovarajući rad MIL-a.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Zamijenite ispravnim kombiniranim mjeračem i ponovno provjerite DTC-ove. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ako je MIL ostaje uključen, zamijenite ECM i ponovo provjerite rad MIL-a. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
