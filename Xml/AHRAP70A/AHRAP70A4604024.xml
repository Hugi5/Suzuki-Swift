<title>
DTC C1038
</title>
<servinfosub id = "AHRAP70A4604024001">
<title>
Detektirano stanje DTC-a i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.259in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.896in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Detektirano stanje DTC-a
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1038: Kvar na brojaču detekcije okretanja senzora kuta zakretanja upravljača
</emph>
</ptxt>
<ptxt>
Senzor kuta zakretanja upravljača detektira nevaljane CAN podatke iz upravljačkog modula ESP<sup>®</sup>-a.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Strujni krug CAN komunikacije
</ptxt>
</item>
<item>
<ptxt>
Senzor kuta zakretanja upravljača
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul ESP<sup>®</sup>-a
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70A4604024002">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A4604024003">
<testgroup id = "AHRAP70A4604024004">
<question>
Je li izvršena “Provjera ESP<sup>®</sup> sustava”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A4604001">Provjera ESP® sustava</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604024005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70A4604005">Provjera DTC-a</intxref>
.
</ptxt>
</test1>
<question>
Jesu li detektirani bilo koji DTC-ovi osim C1038?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajuće rješavanje problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604024006">
<title>
Provjera senzora kuta zakretanja upravljača
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Zamijenite senzor kuta zakretanja upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC C1038?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
