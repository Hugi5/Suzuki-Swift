<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1306015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja A/F senzora i HO2S
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1306013">Pregled A/F senzora na vozilu</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A1306014">Provjera HO2S na vozilu</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1306015001">
<title>
Uklanjanje
</title>
<attention1>
<ptxt>
Da biste izbjegli opasnost od nastanka opeklina, ne dodirujte ispušni sustav dok je još vruć. Uklanjanje A/F senzora i/ili HO2S treba obavljati kada je sustav hladan.
</ptxt>
</attention1>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor A/F senzora i/ili HO2S.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite A/F senzor (1) i/ili HO2S (2) s ispušne grane.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1306015002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite A/F senzor (1) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1C003">
<t-part>
A/F senzor
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,5
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Pritegnite HO2S (2) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1C004">
<t-part>
HO2S
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,5
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A131013.swf" width = "88.000mm" height = "49.001mm" ver = "01" gw = "174" gh = "122"/>
</figure>
</item>
<item>
<ptxt>
Nakon ugradnje provjerite istjecanje ispušnih plinova sa senzora dok motor radi.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
