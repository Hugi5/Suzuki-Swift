<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A4106021" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Provjera rada servouređaja kočnice
</title>
<attention3>
<ptxt>
Prije ove provjere budite sigurni da u hidrauličnom vodu nema zraka.
</ptxt>
</attention3>
<servinfosub id = "AHRAP70A4106021001">
<title>
Provjera nepropusnosti za zrak
</title>
<s1>
<ptxt>
Pokrenite motor.
</ptxt>
</s1>
<s1>
<ptxt>
Zaustavite motor nakon 1 - 2 minute rada.
</ptxt>
</s1>
<s1>
<ptxt>
Pritisnite papučicu kočnice nekoliko puta istom silom kao kod uobičajenog kočenja i promatrajte kako se mijenja hod papučice. Servouređaj kočnice hermetički je zatvoren ako se hod papučice smanjuje svaki put kada je pritisnete.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410005.swf" width = "88.000mm" height = "50.619mm" ver = "01" gw = "131" gh = "126"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "6" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.501in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.579in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.315in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.631in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
3.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Ako se hod papučice ne mijenja, ugrožena je hermetičnost servouređaja kočnice.
</ptxt>
<attention3>
<ptxt>
Ako je neispravan, pregledajte vakuumske vodove i brtveće dijelove pa zamijenite neispravni dio. Nakon ovoga ponovite cijeli test.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I2RH01410006.swf" width = "88.000mm" height = "50.196mm" ver = "01" gw = "132" gh = "125"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.030in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
1., 2., 3.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A4106021002">
<title>
Provjera rada
</title>
<s1>
<ptxt>
S isključenim motorom pritisnite papučicu kočnice nekoliko puta istom silom i uvjerite se da se hod papučice ne mijenja.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410007.swf" width = "88.000mm" height = "50.323mm" ver = "01" gw = "162" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Pokrenite motor dok pritišćete papučicu kočnice. Ako se hod papučice malo poveća, rad servouređaja kočnice je zadovoljavajući. Ako nema promjene u hodu papučice, to znači da je servouređaj kočnice u kvaru.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410008.swf" width = "88.000mm" height = "50.958mm" ver = "01" gw = "173" gh = "127"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A4106021003">
<title>
Provjera nepropusnosti za zrak pod uvjetom opterećenja
</title>
<s1>
<ptxt>
Dok motor radi, pritisnite papučicu kočnice. Zatim isključite motor dok papučicu kočnice držite pritisnutu.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410009.swf" width = "88.000mm" height = "51.805mm" ver = "01" gw = "123" gh = "130"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.232in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.628in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
H:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Držite
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Papučicu kočnice držite pritisnutu 30 sekundi. Ako se visina papučice ne promijeni, stanje servouređaja kočnice je dobro. Ako se hod papučice mijenja, servouređaj kočnice nije u dobrom stanju.
</ptxt>
<figure>
<graphic graphicname = "I2RH01410010.swf" width = "88.000mm" height = "52.059mm" ver = "01" gw = "192" gh = "131"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.382in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.643in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.382in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.800in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
H:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Držite
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
T:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
30 sekundi
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
