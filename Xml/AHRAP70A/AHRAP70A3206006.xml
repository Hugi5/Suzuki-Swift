<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "1" supplyoff = "1" modify = "0">
<title>
Provjera stražnjeg diferencijala
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3206005">Sastavljanje i rastavljanje stražnjeg diferencijala</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite je li prirubnica istrošena ili oštećena.
</ptxt>
</item>
<item>
<ptxt>
Provjerite jesu li ležajevi istrošeni ili bez boje.
</ptxt>
</item>
<item>
<ptxt>
Provjerite je li nosač diferencijala napuknut.
</ptxt>
</item>
<item>
<ptxt>
Provjerite jesu li stožasti zupčanik i tanjurasti zupčanik istrošeni ili napukli.
</ptxt>
</item>
<item>
<ptxt>
Provjerite jesu li zupčanici poluosovine, sateliti i osovinica satelita istrošeni ili oštećeni.
</ptxt>
</item>
<item>
<ptxt>
Provjerite je li žlijeb zupčanika poluosovine istrošen ili oštećen.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
