<servinfosub id = "AHRAP70AA314019003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Uključite kontakt na 10 s.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA314019004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70AA314019005">
<testgroup id = "AHRAP70AA314019006">
<title>
Provjera kruga signala upravljačkog modula blokade motora
</title>
<test1>
<ptxt>
Potvrdite da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektore “G17” i “G04”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;G17&#34; i &#34;G04&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34; i &#34;A4&#34;: manji od 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34; i &#34;A4&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i ostalih terminala na konektoru &#34;G17&#34; beskonačan.
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA314019007">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite upravljački modul blokade motora. 
<intxreftitleoff1 refid = "AHRAP70AA316001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA314019003">Postupak potvrde DTC-a</intxref>
 i zatim ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC B1189?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite BCM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Upravljački modul blokade motora je neispravan)
</ptxt>
</action>
</testgroup>
</diag>
