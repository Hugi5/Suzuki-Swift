<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja prednjeg svjetla za maglu (ako je dio opreme)
</title>
<servinfosub id = "AHRAP70A9206003001">
<title>
Uklanjanje
</title>
<attention3>
<ptxt>
Nakon što ste zamijenili prednje svjetlo za maglu i/ili žarulje prednjeg svjetla za maglu, provjerite i namjestite prednja svjetla za maglu. 
<intxreftitleoff1 refid = "AHRAP70A9206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1>
<ptxt>
Uklonite okvir prednjeg svjetla za maglu (1). 
<intxreftitleoff1 refid = "AHRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odvijte vijke svjetla za maglu (2) pa skinite prednje svjetlo za maglu (3).
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektore s prednjeg svjetla za maglu.
</ptxt>
</s1>
<s1>
<ptxt>
Zakrenite grlo (4) suprotno od kazaljki na satu i uklonite žarulju.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920009.jpg" width = "88.000mm" height = "81.348mm" ver = "01" gw = "206" gh = "214"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9206003002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
