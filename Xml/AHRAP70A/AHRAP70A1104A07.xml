<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1104A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Motor se pregrijava
</title>
<ptxt>
Izvršite rješavanje problema prema sljedećim točkama kada je ECM detektirao da nema DTC-a i nisu pronađene nepravilnosti u 
<intxref refid = "AHRAP70A1104008">Vizualni pregled</intxref>
 i 
<intxref refid = "AHRAP70A1104009">Osnovni pregled motora</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Motor se pregrijava
</ptxt>
</condition>
<ps>
<ptxt>
Termostat ne radi
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1606009">Pregled sklopa termostata (dio ECT senzora)</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabe performanse pumpe vode
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1606017">Pregled pumpe vode</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Začepljen ili probijen hladnjak
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1606014">Provjera i čišćenje hladnjaka na vozilu</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Motorno ulje pogrešne kvalitete
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A0206004">Zamjena motornog ulja i filtra</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Začepljen filtar ulja ili grubi filtar ulja
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1504001">Provjera tlaka ulja</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabe performanse pumpe ulja
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1504001">Provjera tlaka ulja</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sustav kontrole ventilatora hlađenja hladnjaka
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1604002">Provjera sustava ventilatora hlađenja hladnjaka</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kočnica struže
</ptxt>
</ps>
<action>
<ptxt>
Stanje &#34;kočnica struže&#34; u 
<intxref refid = "AHRAP70A4104001">Dijagnostika simptoma kočnica</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Spojka klizi
</ptxt>
</ps>
<action>
<ptxt>
Stanje &#34;spojka klizi&#34; u 
<intxref refid = "AHRAP70A5304001">Dijagnostika simptoma sustava spojke</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Pregorena brtva glave motora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406029">Provjera glave motora</intxref>
</ptxt>
</action>
<ps>
<ptxt>
U rashladnom sustavu ima zraka
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1606006">Punjenje rashladnog sustava</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
