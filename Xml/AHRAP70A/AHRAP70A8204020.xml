<servinfosub id = "AHRAP70A8204020003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204020004">
<testgroup id = "AHRAP70A8204020005">
<question>
Je li izvršena “Provjera dijagnostičkog sustava zračnih jastuka”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204020006">
<title>
Provjera krugova na ožičenju ploče s instrumentima
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektore “G347&#34; ili “G374” i “G11”.
</ptxt>
</test1>
<test1>
<ptxt>
Otpustite kratkospojnu šipku u konektoru SDM-a tako da umetnete alat za otpuštanje priložen sa specijalnim alatom (A).
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor između svakog od krugova “A1” i “A2” i uzemljenja: beskonačan
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B014">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820052.swf" width = "90.000mm" height = "57.786mm" ver = "02" gw = "207" gh = "147"/>
</testfigure>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204020007">
<title>
Provjera kruga zavojnice kontakta
</title>
<test1>
<ptxt>
Spojite konektor “G347&#34; ili “G374”.
</ptxt>
</test1>
<test1>
<ptxt>
Uklonite modul zračnog jastuka vozača (uređaj za napuhavanje) sa stupa upravljača. 
<intxreftitleoff1 refid = "AHRAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Otpustite kratkospojnu šipku u konektoru SDM-a tako da umetnete alat za otpuštanje priložen sa specijalnim alatom (A).
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor između svakog od krugova “A1” i “A2” i uzemljenja: beskonačan
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B015">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820052.swf" width = "90.000mm" height = "57.786mm" ver = "02" gw = "207" gh = "147"/>
</testfigure>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite SDM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite zavojnicu kontakta. 
<intxreftitleoff1 refid = "AHRAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Nakon završetka pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ako su detektirani DTC-ovi, izbrišite ih prema uputama pod naslovom 
<intxref refid = "AHRAP70A8204006">Brisanje DTC-a</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem riješen.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
