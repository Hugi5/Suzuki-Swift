<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7216028" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pregled polužja aktuatora
</title>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite radi li polužje svakog aktuatora bez ometanja.
</ptxt>
</item>
<item>
<ptxt>
Provjerite je li šipka aktuatora savijena.
</ptxt>
</item>
<item>
<ptxt>
Provjerite polužje svakog aktuatora radi lomova.
</ptxt>
</item>
<item>
<ptxt>
Uvjerite se da nema nikakvih prepreka u radnom području polužja aktuatora.
</ptxt>
<ptxt>
Ako rezultat provjere nije u redu, popravite ili zamijenite neispravni dio (dijelove).
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
