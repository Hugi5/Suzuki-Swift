<servinfo servinfosgmlid = "AHRAP70A3406005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rastavljanje i sastavljanje spojke
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3406004">Rastavljanje i sastavljanje sklopa kardanskog vratila</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A3406005001">
<title>
Rastavljanje
</title>
<s1>
<ptxt>
Uklonite uskočnik s vratila spojke kliještima za uskočnike.
</ptxt>
</s1>
<s1>
<ptxt>
Pomoću hidrauličke preše (3) i izvlakača (4) uklonite viskoznu spojku (1) s vratila spojke (2).
</ptxt>
<figure>
<graphic graphicname = "I5RS0D340007.swf" width = "88.000mm" height = "49.401mm" ver = "01" gw = "114" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A3406005002">
<title>
Ponovno sastavljanje
</title>
<s1>
<ptxt>
Postavite viskoznu spojku (1) na vratilo spojke (2) posebnim alatom i hidrauličkom prešom.
</ptxt>
<servicetool>
<servicetoolitem id = "L3D001">
<s-part>
(A)
</s-part>
<s-number num = "09922-55131">
09922-55131
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A340010.swf" width = "88.000mm" height = "50.636mm" ver = "01" gw = "94" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite novi uskočnik na središnje vratilo pomoću kliješta za uskočnike.
</ptxt>
</s1>
</servinfosub>
</servinfo>
