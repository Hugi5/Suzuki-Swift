<title>
Uklanjanje i ugradnja unutarnjeg retrovizora
</title>
<servinfosub id = "AHRAP70A9506009001">
<title>
Uklanjanje
</title>
<ptxt>
Uklonite vijak unutarnjeg retrovizora (TORX <sup>®</sup> T20) (1) i pomičite ogledalo (2) u smjeru strjelice.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950021.swf" width = "88.000mm" height = "49.005mm" ver = "01" gw = "227" gh = "122"/>
</figure>
</servinfosub>
<servinfosub id = "AHRAP70A9506009002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijak unutarnjeg retrovizora propisanim momentom pritezanja.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9E001">
<t-part>
Vijak unutarnjeg retrovizora
</t-part>
<t-value1>
3,5
</t-value1>
<t-value2>
0,36
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
