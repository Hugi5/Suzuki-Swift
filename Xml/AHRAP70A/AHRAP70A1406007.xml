<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1406007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa tijela električne zaklopke
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1406005">Komponente tijela zaklopke i usisne grane</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A1406006">Pregled tijela zaklopke na vozilu</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Ne rastavljajte kućište tijela električne zaklopke. Ako pronađete neispravnost, zamijenite ga novim.
</ptxt>
</attention2>
<servinfosub id = "AHRAP70A1406007001" page = "2">
<title>
Uklanjanje
</title>
<s1 page = "2">
<ptxt>
Odspojite negativni kabel (-) s akumulatora.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Ispustite rashladnu tekućinu. 
<intxreftitleoff1 refid = "AHRAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite sklop pročistača zraka. 
<intxreftitleoff1 refid = "AHRAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odvojite crijeva rashladne tekućine (1) i konektor (2) od sklopa tijela električne zaklopke gasa (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite sklop tijela električne zaklopke i nosač pročistača zraka (4) od usisne grane.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1406007002" page = "2">
<title>
Ugradnja
</title>
<s1 page = "2">
<ptxt>
Očistite dodirne površine i ugradite novu brtvu tijela zaklopke (1) na usisnu granu.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141038.swf" width = "88.000mm" height = "58.059mm" ver = "01" gw = "212" gh = "148"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Ugradite sklop tijela električne zaklopke (3) i nosač pročistača zraka (4) na usisnu granu.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Spojite konektor (2) i crijeva rashladne tekućine (1) na sklop tijela električne zaklopke gasa (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Ugradite sklop pročistača zraka. 
<intxreftitleoff1 refid = "AHRAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Spojite negativni kabel (-) na akumulator.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Dopunite rashladnu tekućinu. 
<intxreftitleoff1 refid = "AHRAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite istječe li rashladna tekućina. 
<intxreftitleoff1 refid = "AHRAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
