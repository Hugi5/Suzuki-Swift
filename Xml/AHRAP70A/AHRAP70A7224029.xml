</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1570: Pogreška signala tipa motora
</emph>
</ptxt>
<ptxt>
Upravljački modul HVAC sustava prima neispravne podatke signala tipa motora iz ECM-a.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul HVAC sustava
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70A7224029002">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A7224029003">
<testgroup id = "AHRAP70A7224029005">
<title>
Provjera podataka alata za skeniranje
</title>
<test1>
<ptxt>
Spojite alat za skeniranje s isključenim kontaktom.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt i odaberite način rada “Popis podataka”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite “Tip motora” prikazan na alatu za skeniranje.
</ptxt>
</test1>
<question>
Je li vrsta motora ispravna kako je naznačeno u “Podacima alata za skeniranje”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ispravnim upravljačkim modulom HVAC sustava i ponovno provjerite.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ispravnim ECM-om i ponovno provjerite.
</ptxt>
</action>
</testgroup>
</diag>
