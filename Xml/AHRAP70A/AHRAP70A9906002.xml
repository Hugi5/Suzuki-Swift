<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa krovnog prozora
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9906001">Komponente krovnog prozora</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9906002001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite krovnu oblogu. 
<intxreftitleoff1 refid = "AHRAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite staklo krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Iskopčajte crijeva za pražnjenje (1) spojena na 4 mjesta na sklop krovnog prozora.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990005.jpg" width = "88.000mm" height = "75.169mm" ver = "01" gw = "227" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Odspojite konektor motora krovnog prozora (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990006.jpg" width = "88.000mm" height = "69.556mm" ver = "01" gw = "225" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Odvojite obujmice (1) i ožičenje krovnog prozora (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990007.jpg" width = "88.000mm" height = "61.392mm" ver = "01" gw = "227" gh = "158"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite matice kućišta krovnog prozora (1) pa uklonite sklop krovnog prozora (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990008.jpg" width = "88.000mm" height = "83.554mm" ver = "01" gw = "227" gh = "220"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A9906002002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite svaki dio propisanim momentom pritezanja prema uputama pod naslovom 
<intxref refid = "AHRAP70A9906001">Komponente krovnog prozora</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Pritegnite matice kućišta krovnog prozora (1) redoslijedom (“1” do “4”) na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990009.jpg" width = "88.000mm" height = "82.828mm" ver = "01" gw = "227" gh = "218"/>
</figure>
</item>
<item>
<ptxt>
Spojite crijeva za pražnjenje (1) na 4 mjesta sklopa krovnog prozora. Obujmicama (2) čvrsto obujmite crijeva za pražnjenje.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990010.jpg" width = "88.000mm" height = "75.168mm" ver = "01" gw = "227" gh = "197"/>
</figure>
<figure>
<title>
Prednji stup
</title>
<graphic graphicname = "I9P60A990011.swf" width = "88.000mm" height = "95.842mm" ver = "02" gw = "210" gh = "255"/>
</figure>
<figure>
<title>
Ploča krila
</title>
<graphic graphicname = "I9P60A990013.swf" width = "88.000mm" height = "94.869mm" ver = "03" gw = "225" gh = "252"/>
</figure>
</item>
<item>
<ptxt>
Inicijalizirajte motor krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nakon ponovnog postavljanja sklopa krovnog prozora, obavezno namjestite položaj stakla. 
<intxreftitleoff1 refid = "AHRAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
