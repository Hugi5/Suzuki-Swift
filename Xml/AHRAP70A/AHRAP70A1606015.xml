<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1606015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja hladnjaka
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1606014">Provjera i čišćenje hladnjaka na vozilu</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1606015001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite sklop ventilatora hlađenja. 
<intxreftitleoff1 refid = "AHRAP70A1606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite sklop kondenzatora klima uređaja. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s ručnim klima uređajem: 
<intxreftitleoff1 refid = "AHRAP70A7216006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatskim klima uređajem: 
<intxreftitleoff1 refid = "AHRAP70A7226006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Odvojite izlazno crijevo hladnjaka od hladnjaka.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite gornje nosače hladnjaka (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite hladnjak (2) iz vozila.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160007.jpg" width = "88.000mm" height = "62.569mm" ver = "01" gw = "193" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1606015002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dolijte rashladnu tekućinu u rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Provjerite propušta li rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
