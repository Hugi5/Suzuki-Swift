</title>
<ptxt>
Pogledajte pod naslovom “Opis kruga” u poglavlju 
<intxref refid = "AHRAP70A4604010">Svjetlo upozorenja ESP®-a ne uključuje se nakon uključivanja kontakta</intxref>
.
</ptxt>
</servinfosub>
<servinfosub id = "AHRAP70A4604011003">
<title>
Rješavanje problema
</title>
<diag type = "test" id = "AHRAP70A4604011004">
<testgroup id = "AHRAP70A4604011005">
<title>
Provjera konektora upravljačkog modula ESP®-a
</title>
<test1>
<ptxt>
Provjerite ispravnost spoja na konektor upravljačkog modula ESP<sup>®</sup>-a.
</ptxt>
</test1>
<question>
Je li spoj u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Čvrsto spojite konektor.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604011006">
<title>
Provjera DTC-a za ESP®
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70A4604005">Provjera DTC-a</intxref>
.
</ptxt>
</test1>
<question>
Postoje li DTC-ovi?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajuće rješavanje problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604011007">
<title>
Provjera kruga napajanja i uzemljenja upravljačkog modula ESP®-a
</title>
<test1>
<ptxt>
Provjerite krug napajanja i uzemljenja upravljačkog modula ESP<sup>®</sup>-a. 
<intxreftitleoff1 refid = "AHRAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li krugovi u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604011008">
<title>
Provjera kombiniranog mjerača
</title>
<test1>
<ptxt>
Zamijenite kombinirani mjerač. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<question>
Ostaje li svjetlo upozorenja uključeno?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a i ponovno provjerite rad svjetla upozorenja. 
<intxreftitleoff1 refid = "AHRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
