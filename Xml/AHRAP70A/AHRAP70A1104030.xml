<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0223: Visoki napon strujnog kruga prekidača/senzora &#34;B&#34; položaja zaklopke/papučice gasa
</emph>
</ptxt>
<ptxt>
Izlazni napon kruga signala TP senzora (pomoćnog) viši je od 4,81 V.
</ptxt>
<ptxt>
(logika detekcije 1 ciklusa vožnje)
</ptxt>
</entry>
