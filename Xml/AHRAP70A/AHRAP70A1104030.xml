<servinfosub id = "AHRAP70A1104030003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pokrenite motor.
</ptxt>
</s1>
<s1>
<ptxt>
Držite papučicu gasa na trenutak u potpuno pritisnutom položaju.
</ptxt>
</s1>
<s1>
<ptxt>
Držite papučicu gasa u otpuštenom položaju tijekom 2 s.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104030004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104030005">
<testgroup id = "AHRAP70A1104030006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104030007">
<title>
Provjera kruga napajanja TP senzora
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektor TP senzora.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorom TP senzora.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite je li napon između &#34;B1&#34; i &#34;B4&#34; približno 5 V.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104030008">
<title>
Provjera kruga uzemljenja TP senzora
</title>
<test1>
<ptxt>
Provjerite je li napon između &#34;B1&#34; i uzemljenja približno 5 V.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Popravite krug &#34;B4&#34;.
</ptxt>
<ptxt>
Ako se ovaj DTC i dalje detektira, zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug &#34;B1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104030009">
<title>
Provjera kruga signala TP senzora (pomoćnog)
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;B3&#34;: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;B3&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B2&#34; i drugih terminala na konektoru TP senzora: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;B3&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug signala TP senzora (pomoćnog).
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104030010">
<title>
Provjera TP senzora
</title>
<test1>
<ptxt>
Provjerite rad TP senzora. 
<intxreftitleoff1 refid = "AHRAP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite sklop tijela električne zaklopke.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
