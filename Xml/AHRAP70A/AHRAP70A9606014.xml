<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9606014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja prekidača otvarača vrata prtljažnika
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9606013">Pregled prekidača otvarača vrata prtljažnika na vozilu</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9606014001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite oblogu vrata prtljažnika. 
<intxreftitleoff1 refid = "AHRAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor otvarača vrata prtljažnika (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite donju oblogu vrata prtljažnika. 
<intxreftitleoff1 refid = "AHRAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke (1), zatim uklonite prekidač otvarača vrata prtljažnika (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A960020.jpg" width = "88.000mm" height = "57.494mm" ver = "01" gw = "194" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9606014002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
