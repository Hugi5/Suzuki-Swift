<servinfosub id = "AHRAP70A1104029003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Aktivirana je kontrola povratne informacije A/F-a (zatvorena petlja).
</ptxt>
</item>
<item>
<ptxt>
Nije detektiran DTC P0300, P0301, P0302, P0303 ili P0304.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Zagrijte motor do normalne radne temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Vozite vozilo konstantnom brzinom od 50 do 80 km/h (31 do 50 milja/h) u trajanju od 30 min ili više.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104029004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104029005">
<testgroup id = "AHRAP70A1104029006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104029007">
<title>
Provjera DTC-a
</title>
<question>
Postoje li DTC-ovi osim P0171 i P0172?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104029008">
<title>
Provjera sustava goriva i sustava emisije
</title>
<test1>
<ptxt>
Provjerite sljedeće točke povezane sa sustavom upravljanja gorivom i emisijom.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tlak goriva: 
<intxreftitleoff1 refid = "AHRAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Krug brizgaljke goriva: 
<intxreftitleoff1 refid = "AHRAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Brizgaljka goriva: 
<intxreftitleoff1 refid = "AHRAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
MAF senzor: 
<intxreftitleoff1 refid = "AHRAP70A1306026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ventil pražnjenja EVAP spremnika: 
<intxreftitleoff1 refid = "AHRAP70A1206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
PCV ventil: 
<intxreftitleoff1 refid = "AHRAP70A1206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104029009">
<title>
Provjera ispušnog sustava i sustava usisa zraka
</title>
<test1>
<ptxt>
Provjerite jesu li ispušni sustav i sustav usisa zraka začepljeni ili propuštaju.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104029010">
<title>
Provjera kruga signala A/F senzora
</title>
<test1>
<ptxt>
Provjerite krugove signala A/F senzora prema 3. koraku pod 
<intxref refid = "AHRAP70A1104025">DTC P0131/P0132/P2237/P2243/ P2251/P2626</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104029011">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite A/F senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Obavite postupak potvrde DTC-a i provjerite DTC.
</ptxt>
</test1>
<question>
Detektiraju li se još uvijek DTC P0171 ili P0172?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
