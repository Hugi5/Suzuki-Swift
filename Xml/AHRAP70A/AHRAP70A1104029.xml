<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0171: Smjesa u sustavu je presiromašna
</emph>
</ptxt>
<ptxt>
Korekcija smjese goriva veća je od propisane vrijednosti u propisanom vremenu u propisanim uvjetima vozila.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
