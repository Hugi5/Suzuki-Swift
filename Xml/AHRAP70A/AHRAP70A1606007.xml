<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1606007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja cijevi ili crijeva rashladnog sustava
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1606001">Komponente rashladnog sustava</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A1606009">Pregled sklopa termostata (dio ECT senzora)</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1606007001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Ispustite rashladnu tekućinu. 
<intxreftitleoff1 refid = "AHRAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Da biste uklonili crijeva ili cijevi rashladne tekućine, olabavite obujmice na svakom crijevu i izvucite kraj crijeva.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1606007002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Svaku obujmicu zategnite čvrsto i u odgovarajućem smjeru. 
<intxreftitleoff1 refid = "AHRAP70A1606001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dolijte rashladnu tekućinu u rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Provjerite propušta li rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
