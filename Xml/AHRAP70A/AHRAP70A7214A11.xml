<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A7214A11" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nedovoljan protok hladnog zraka
</title>
<diag type = "condition">
<condition>
<ptxt>
Nedovoljan protok hladnog zraka
</ptxt>
</condition>
<ps>
<ptxt>
Začepljen ili zamrznut isparivač klima uređaja
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Provjerite isparivač klima uređaja i senzor temperature isparivača.
</ptxt>
<ptxt>
- Isparivač klima uređaja: 
<intxreftitleoff1 refid = "AHRAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Senzor temperature isparivača: 
<intxreftitleoff1 refid = "AHRAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Istjecanje zraka iz HVAC jedinice ili kanala zraka
</ptxt>
</ps>
<action>
<ptxt>
Popravite HVAC jedinicu ili kanal za zrak.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan motor puhala
</ptxt>
</ps>
<action>
<ptxt>
Provjerite motor puhala. 
<intxreftitleoff1 refid = "AHRAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravno ožičenje ili uzemljenje
</ptxt>
</ps>
<action>
<ptxt>
Popravite ožičenje.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
