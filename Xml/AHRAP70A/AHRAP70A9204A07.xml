<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A9204A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Svjetlo putničkog prostora ili reflektorsko svjetlo ne svijetli.
</title>
<diag type = "condition">
<condition>
<ptxt>
Svjetlo putničkog prostora ili reflektorsko svjetlo ne svijetli.
</ptxt>
</condition>
<ps>
<ptxt>
Neispravan BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Pogledajte “Inspection of BCM and Its Circuits” (“Pregled BCM-a i njegovih strujnih krugova”) u odjeljku 10B.
</ptxt>
<ptxt>
Model s kontakt bravom: 
<intxreftitleoff1 refid = "AHRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model sa sustavom pokretanja pritiskom bez ključa: 
<intxreftitleoff1 refid = "AHRAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Neispravan krug sustava (uključujući releje i osigurače)
</ptxt>
</ps>
<action>
<ptxt>
Popravite krug.
</ptxt>
</action>
<ps>
<ptxt>
Pregorjele žarulje
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite žarulje.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan prekidač vrata
</ptxt>
</ps>
<action>
<ptxt>
Pogledajte 
<intxref refid = "AHRAP70A9606008">Pregled prekidača prednjih i stražnjih vrata</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
