<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0480: Upravljački strujni krug ventilatora 1
</emph>
</ptxt>
<ptxt>
Pogonski krug releja br. 1 ventilatora hlađenja hladnjaka u kratkom je spoju s uzemljenjem ili je prekinut.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje, ali MIL ne zasvijetli)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Relej br. 1 ventilatora hlađenja hladnjaka i/ili njegov krug
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0692: Visoki napon upravljačkog strujnog kruga ventilatora 1
</emph>
</ptxt>
<ptxt>
Pogonski krug releja br. 1 ventilatora hlađenja hladnjaka u kratkom je spoju s napajanjem.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje, ali MIL ne zasvijetli)
</ptxt>
</entry>
</row>
