<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A7214004" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Dijagnostika simptoma abnormalne buke HVAC sustava
</title>
<servinfosub id = "AHRAP70A7214004001">
<title>
Abnormalna buka iz kompresora
</title>
<diag type = "condition" id = "AHRAP70A7214004002">
<condition>
<ptxt>
Tijekom rada kompresora, čuje se hučenje proporcionalno povećanju brzine vrtnje motora
</ptxt>
</condition>
<ps>
<ptxt>
Neodgovarajuća zračnost u području kotrljanja
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite kompresor. 
<intxreftitleoff1 refid = "AHRAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Glasna buka se čuje pri određenom broju okretaja u minuti motora, bez obzira na količinu brzine u
</ptxt>
</condition>
<ps>
<ptxt>
Labav ili neispavan pogonski remen kompresora
</ptxt>
</ps>
<action>
<ptxt>
Provjerite pogonski remen kompresora. 
<intxreftitleoff1 refid = "AHRAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Labavi pričvrsni vijci kompresora
</ptxt>
</ps>
<action>
<ptxt>
Zategnite pričvrsne vijke. 
<intxreftitleoff1 refid = "AHRAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Pri malom broju okretaja u minuti motora čuje se glasno zveckanje
</ptxt>
</condition>
<ps>
<ptxt>
Labava matica na ploči spojke kompresora
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zategnite maticu ploče spojke. 
<intxreftitleoff1 refid = "AHRAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Zamijenite kompresor ako je dugo radio u stanju glasnog zveckanja.
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHRAP70A7214004003">
<title>
Neuobičajena buka iz magnetske spojke
</title>
<diag type = "condition" id = "AHRAP70A7214004004">
<condition>
<ptxt>
Čuje se hučenje kada kompresor ne radi
</ptxt>
</condition>
<ps>
<ptxt>
Istrošeni ili oštećeni ležajevi
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop magnetske spojke. 
<intxreftitleoff1 refid = "AHRAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Čuje se buka klopotanja kada kompresor ne radi
</ptxt>
</condition>
<ps>
<ptxt>
Neispravna zračnost magnetske spojke (prekomjerna zračnost)
</ptxt>
</ps>
<action>
<ptxt>
Podesite zračnost magnetske spojke. 
<intxreftitleoff1 refid = "AHRAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošena tarna površina magnetske spojke
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop magnetske spojke. 
<intxreftitleoff1 refid = "AHRAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ulje kompresora istječe iz brtve vratila, onečišćujući tarnu površinu
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop tijela kompresora. 
<intxreftitleoff1 refid = "AHRAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHRAP70A7214004005">
<title>
Neuobičajena buka iz cijevi
</title>
<diag type = "condition" id = "AHRAP70A7214004006">
<condition>
<ptxt>
Čuje se brujanje iz unutrašnjosti vozila, ali u prostoru motora brujanje nije zamjetljivo
</ptxt>
</condition>
<ps>
<ptxt>
Neispravne obujmice cijevi
</ptxt>
</ps>
<action>
<ptxt>
Pomaknite obujmice ili povećajte broj obujmica.
</ptxt>
</action>
<ps>
<ptxt>
Rezonancija uzrokovana pulsiranjem zbog promjena tlaka rashladnog sredstva
</ptxt>
</ps>
<action>
<ptxt>
Na cijevi ugradite prigušivač, ili promijenite njihov položaj i duljinu.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHRAP70A7214004007">
<title>
Neuobičajena buka iz sklopa kondenzatora
</title>
<diag type = "condition" id = "AHRAP70A7214004008">
<condition>
<ptxt>
Značajne vibracije u sklopu kondenzatora
</ptxt>
</condition>
<ps>
<ptxt>
Rezonancija iz nosača i tijela sklopa kondenzatora
</ptxt>
</ps>
<action>
<ptxt>
Utisnite prigušivač između nosača i tijela sklopa kondenzatora.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHRAP70A7214004009">
<title>
Neuobičajena buka iz remenice koljenastog vratila
</title>
<diag type = "condition" id = "AHRAP70A7214004010">
<condition>
<ptxt>
Jako zveckanje se čuje u praznom hodu ili pri naglom ubrzavanju
</ptxt>
</condition>
<ps>
<ptxt>
Labav vijak remenice koljenastog vratila
</ptxt>
</ps>
<action>
<ptxt>
Pritegnite vijak. 
<intxreftitleoff1 refid = "AHRAP70A1406017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHRAP70A7214004011">
<title>
Neuobičajena buka iz zatezne remenice
</title>
<diag type = "condition" id = "AHRAP70A7214004012">
<condition>
<ptxt>
Čuje se klopotanje iz remenice
</ptxt>
</condition>
<ps>
<ptxt>
Istrošen ili oštećen ležaj
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite zateznu remenicu.
</ptxt>
</action>
<condition>
<ptxt>
Remenica se pomiče pri kontaktu
</ptxt>
</condition>
<ps>
<ptxt>
Slomljen ili labav nosač
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ili pritegnite nosač.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHRAP70A7214004013">
<title>
Neuobičajena buka iz isparivača klima uređaja
</title>
<diag type = "condition" id = "AHRAP70A7214004014">
<condition>
<ptxt>
Zvuk fijukanja se čuje iz isparivača klima uređaja
</ptxt>
</condition>
<ps>
<ptxt>
Ovisno o kombinaciji temperatura u unutrašnjosti/okolini, broju okretaja u minuti motora i tlaku rashladnog sredstva, protjecanje rashladnog sredstva iz ekspanzijskog ventila može stvoriti zvuk fijukanja.
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Malo smanjenje količine rashladnog sredstva može zaustaviti buku.
</ptxt>
<ptxt>
Pregledajte ekspanzijski ventil i zamijenite ga ako je neispravan.
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHRAP70A7214004015">
<title>
Neuobičajena buka iz motora puhala
</title>
<diag type = "condition" id = "AHRAP70A7214004016">
<condition>
<ptxt>
Motor puhala stvara zvuk pijukanja proporcionalno svojoj brzini i rotaciji
</ptxt>
</condition>
<ps>
<ptxt>
Istrošene ili oštećene četkice ili komutator motora
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite motor puhala. 
<intxreftitleoff1 refid = "AHRAP70A7216009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Buka lepršanja ili snažno brujanje čuje se iz motora puhala
</ptxt>
</condition>
<ps>
<ptxt>
Lišće ili drugi ostaci su ušli iz ulaza za svježi zrak u motor puhala
</ptxt>
</ps>
<action>
<ptxt>
Uklonite ostatke i uvjerite se da je pregrada na ulazu svježeg zraka neoštećena.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
