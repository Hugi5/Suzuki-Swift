<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Postavljanje i rastavljanje međumjenjača
</title>
<servinfosub id = "AHRAP70A3306003001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Ispraznite sljedeća ulja.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ulje ručnog mjenjača: 
<intxreftitleoff1 refid = "AHRAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ulje međumjenjača: 
<intxreftitleoff1 refid = "AHRAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Uklonite sklop pogonskog vratila s desne strane. 
<intxreftitleoff1 refid = "AHRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite kardansko vratilo. 
<intxreftitleoff1 refid = "AHRAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite okvir prednjeg ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite stražnji nosač motora i konzolu stražnjeg nosača motora. 
<intxreftitleoff1 refid = "AHRAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite ojačanje međumjenjača (2) i vijke međumjenjača.
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite međumjenjač (1) od mjenjača.
</ptxt>
<attention1>
<ptxt>
Kada uklanjate međumjenjač, pazite da vam ne ispadne. U suprotnom se može oštetiti i mogu nastati osobne ozljede.
</ptxt>
</attention1>
<figure>
<graphic graphicname = "IAP70A330004.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "213" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite O-prsten (1) i zatik (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330005.jpg" width = "88.000mm" height = "52.680mm" ver = "01" gw = "213" gh = "133"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A3306003002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka rastavljanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Koristite novi O-prsten i maticu pogonskog vratila.
</ptxt>
</item>
<item>
<ptxt>
Nanesite mast na O-prsten (1).
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C004" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A330006.jpg" width = "88.000mm" height = "50.958mm" ver = "02" gw = "213" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Pritegnite vijke međumjenjača propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T3C004">
<t-part>
Vijak međumjenjača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Zategnite vijke ojačanja međumjenjača kako slijedi.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Rukom zategnite vijke ojačanja međumjenjača “2” i “3”.
</ptxt>
</item>
<item>
<ptxt>
Gurnite ojačanje međumjenjača na međumjenjač i pritegnite vijke ojačanja propisanim momentom pritezanja slijedom brojeva (“1” – “5”) ravnomjerno i postupno.
</ptxt>
<torque>
<torqueitem id = "T3C005">
<t-part>
Vijak za ojačanje međumjenjača*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330007.jpg" width = "88.000mm" height = "56.283mm" ver = "01" gw = "213" gh = "143"/>
</figure>
<figure>
<graphic graphicname = "IAP70A330008.jpg" width = "88.000mm" height = "55.083mm" ver = "01" gw = "202" gh = "140"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Pritegnite sljedeće vijke i matice propisanim momentom pritezanja.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Vijak stražnjeg nosača motora i vijak konzole: 
<intxreftitleoff1 refid = "AHRAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pričvrsni vijak okvira prednjeg ovjesa: 
<intxreftitleoff1 refid = "AHRAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Obavezno koristite novi pričvrsni vijak okvira ovjesa.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Matica zgloba stabilizatora: 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vijak kuglastog zgloba ramena ovjesa: 
<intxreftitleoff1 refid = "AHRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Matica krajnika spone: 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vijak senzora brzine prednjih kotača: 
<intxreftitleoff1 refid = "AHRAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vijak kardanskog vratila: 
<intxreftitleoff1 refid = "AHRAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Matica središnjeg oslonca: 
<intxreftitleoff1 refid = "AHRAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vijak ispušne cijevi: 
<intxreftitleoff1 refid = "AHRAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vijak ojačanja ispušne cijevi br. 1: 
<intxreftitleoff1 refid = "AHRAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Matica pogonskog vratila: 
<intxreftitleoff1 refid = "AHRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Svakako koristite novu maticu pogonskog vratila.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Matica kotača: 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Osigurajte maticu pogonskog vratila. 
<intxreftitleoff1 refid = "AHRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Napunite sljedeća ulja.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ulje ručnog mjenjača: 
<intxreftitleoff1 refid = "AHRAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
	Ulje međumjenjača: 
<intxreftitleoff1 refid = "AHRAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Potvrdite da nigdje na spojevima ne istječu ulje i ispušni plinovi.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite geometriju prednjih kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
