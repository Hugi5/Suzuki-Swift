<servinfosub id = "AHRAP70A1104040003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Pokrenite motor i zagrijte ga na normalnu radnu temperaturu.
</ptxt>
</s1>
<s1>
<ptxt>
Vozite brzinom od 50 do 70 km/h (31 do 43 milja/h).
</ptxt>
</s1>
<s1>
<ptxt>
Zaustavite vozilo.
</ptxt>
</s1>
<s1>
<ptxt>
Pritisnite papučicu kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Deset puta ponovite korake 2 do 4.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104040004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104040005">
<testgroup id = "AHRAP70A1104040006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104040007">
<title>
Provjera kruga napajanja prekidača svjetla kočenja
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektor prekidača svjetla kočenja.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorom prekidača svjetla kočenja.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite odgovara li napon između svakog od krugova &#34;A1&#34; i &#34;A2&#34; i uzemljenja naponu akumulatora.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104040008">
<title>
Provjera kruga signala prekidača svjetla kočenja
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;B2&#34; i &#34;B2&#34;: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova &#34;B1&#34; i &#34;B2&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B1&#34; i drugih terminala konektora prekidača svjetla kočenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B2&#34; i drugih terminala konektora prekidača svjetla kočenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova &#34;B1&#34; i &#34;B2&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104040009">
<title>
Provjera prekidača svjetla kočenja
</title>
<test1>
<ptxt>
Provjerite prekidač svjetla kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite prekidač svjetla kočenja.
</ptxt>
</action>
</testgroup>
</diag>
