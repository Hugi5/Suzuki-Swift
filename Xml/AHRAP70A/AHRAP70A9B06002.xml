<servinfo servinfosgmlid = "AHRAP70A9B06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja donjeg nosača prednjeg blatobrana
</title>
<attention3>
<ptxt>
Donja slika prikazuje uvjete za uklanjanje sljedećih dijelova.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednji blatobran 
<intxreftitleoff1 refid = "AHRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0007.jpg" width = "88.000mm" height = "55.869mm" ver = "02" gw = "227" gh = "142"/>
</figure>
<servinfosub id = "AHRAP70A9B06002001">
<title>
Opće napomene
</title>
<ptxt>
Metoda zavarivanja i broj točaka zavarivanja su jednaki na obje strane. Ove upute za popravljanje prikazuju postupak za lijevu stranu.
</ptxt>
</servinfosub>
<servinfosub id = "AHRAP70A9B06002002">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Izbušite zavarene točke i uklonite donji nosač prednjeg blatobrana.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0008.jpg" width = "88.000mm" height = "72.673mm" ver = "03" gw = "209" gh = "189"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9B06002003">
<title>
Ugradnja
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Prije zavarivanja, provjerite položaj za ugradnju i uvjete za pravilnu ugradnju dijela (dijelova). 
<intxreftitleoff1 refid = "AHRAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nastavite s popravkom, imajući na umu ugradnju dijelova koji utječu na izgled vozila. 
<intxreftitleoff1 refid = "AHRAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention2>
<s1>
<ptxt>
Ugradite donji nosač prednjeg blatobrana
</ptxt>
</s1>
<s1>
<ptxt>
Provedite elektrootporno točkasto zavarivanje.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0009.jpg" width = "88.000mm" height = "71.219mm" ver = "02" gw = "204" gh = "185"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
