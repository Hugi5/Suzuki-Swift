<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja servo uređaja kočnice (pojačala)
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A4106020">Dijelovi servouređaja kočnice</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A4106022001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Specijalnim alatom odspojite cijevi kočnice (1) sa sklopa hidrauličkog uređaja / upravljačkog modula ESP<sup>®</sup>-a (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410035.swf" width = "88.000mm" height = "45.139mm" ver = "02" gw = "117" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite sklop glavnog cilindra kočnice sa servouređaja kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite vakuumsko crijevo sa servouređaja kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite obujmicu (1) i zatik viličastog zgloba (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410036.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite matice servouređaja kočnice (1) i uklonite servouređaj kočnice s poprečnog veznog lima.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410037.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A4106022004">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A4106023">Pregled servouređaja kočnice</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Olabavite maticu nosača papučice kočnice (1) i vijak gornjeg ojačanja pokrova (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite servouređaj kočnice na poprečni vezni lim. Zatim spojite viličasti zglob potisne šipke (3) na rame papučice kočnice sa zatikom viličastog zgloba (2) i rascjepkom (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410040.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite ploču kombiniranog mjerača. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zategnite matice servouređaja kočnice primjenom navedenog momenta pritezanja.
</ptxt>
<torque>
<torqueitem id = "T4A006">
<t-part>
Matica servouređaja kočnice*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410041.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Pritegnite maticu nosača papučice kočnice propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
Matica nosača papučice kočnice
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Pritegnite vijak ojačanja poprečnog nosača propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
Vijak ojačanja poprečnog nosača
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410042.swf" width = "88.000mm" height = "64.412mm" ver = "02" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite ploču mjerača.
</ptxt>
</s1>
<s1>
<ptxt>
Priključite vakuumsko crijevo na servouređaj kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite sklop glavnog cilindra kočnice na servouređaj kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Specijalnim alatom spojite cijevi kočnice (1) sa sklopom hidrauličkog uređaja / upravljačkog modula ESP<sup>®</sup>-a (2).
</ptxt>
<torque>
<torqueitem id = "T4A009">
<t-part>
Priključna matica cijevi kočnice
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410043.swf" width = "88.000mm" height = "46.684mm" ver = "02" gw = "119" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Nakon ugradnje odzračite kočni sustav. 
<intxreftitleoff1 refid = "AHRAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite ugrađene dijelove radi istjecanja kočne tekućine.
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite slobodni hod papučice kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uvjerite se da kočni sustav pravilno radi i da kočna tekućina ne istječe.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
