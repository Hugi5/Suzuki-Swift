<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P2127: Niski napon strujnog kruga senzora/prekidača &#34;E&#34; položaja zaklopke/papučice gasa
</emph>
</ptxt>
<ptxt>
Izlazni napon kruga signala APP senzora (pomoćnog) niži je od 0,3 V.
</ptxt>
<ptxt>
(logika detekcije 1 ciklusa vožnje)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
APP senzor (pomoćni) i/ili njegov krug
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P2128: Visoki napon strujnog kruga senzora/prekidača &#34;E&#34; položaja zaklopke/papučice gasa
</emph>
</ptxt>
<ptxt>
Izlazni napon kruga signala APP senzora (pomoćnog) viši je od 2,5 V.
</ptxt>
<ptxt>
(logika detekcije 1 ciklusa vožnje)
</ptxt>
</entry>
</row>
