<servinfosub id = "AHRAP70A8204045003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204045004">
<testgroup id = "AHRAP70A8204045005">
<question>
Je li izvršena “Provjera dijagnostičkog sustava zračnih jastuka”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204045006">
<title>
Provjera modula zračne zavjese (uređaj za napuhavanje)
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja s konektorom “L290” ili “L291”.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “L290” ili “L291”.
</ptxt>
</test1>
<test1>
<ptxt>
Spojite “KOLO UPRAVLJAČA” (1) sa specijalnih alata (A), (B) i (C) na konektor “L290” ili “L291”.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B081">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B082">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932-78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B083">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932-75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820034.swf" width = "90.000mm" height = "73.606mm" ver = "02" gw = "199" gh = "192"/>
</testfigure>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li prikazani DTC B1361 ili B1365?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite modul zračne zavjese (uređaj za napuhavanje). 
<intxreftitleoff1 refid = "AHRAP70A8206018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204045007">
<title>
Provjera kruga ožičenja poda
</title>
<test1>
<ptxt>
Provjerite ispravnost spoja s konektorom “L05”.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “L05”.
</ptxt>
</test1>
<test1>
<ptxt>
Otpustite kratkospojnu šipku u konektoru SDM-a tako da umetnete alat za otpuštanje priložen sa specijalnim alatom (A).
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova “A1” i “A2” (DTC B1361): 1 &#937; ili manje
</ptxt>
</item>
<item>
<ptxt>
Otpor krugova “A3” i “A4” (DTC B1365): 1 &#937; ili manje
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B084">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820112.swf" width = "90.000mm" height = "67.845mm" ver = "01" gw = "219" gh = "176"/>
</testfigure>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite SDM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje poda. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po završetku pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ako su detektirani DTC-ovi, izbrišite ih prema uputama pod naslovom 
<intxref refid = "AHRAP70A8204006">Brisanje DTC-a</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem riješen.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
