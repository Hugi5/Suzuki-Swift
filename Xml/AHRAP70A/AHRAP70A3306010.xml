<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3306010" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Provjera sklopa međumjenjača
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3306005">Rastavljanje i sastavljanje sklopa međumjenjača</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A3306003">Postavljanje i rastavljanje međumjenjača</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite vrti li se svaki ležaj besprijekorno te je li oštećen ili izgubio boju
</ptxt>
<ptxt>
Ako nađete nepravilnosti, zamijenite ležaj.
</ptxt>
</item>
<item>
<ptxt>
Provjerite curi li brtva ulja te je li obrub pretjerano otvrdnuo
</ptxt>
<ptxt>
Ako pronađete ijedno, zamijenite brtvu ulja.
</ptxt>
</item>
<item>
<ptxt>
Provjerite je li kućište međumjenjača napuklo.
</ptxt>
</item>
<item>
<ptxt>
Provjerite jesu li tanjurasti i stožasti zupčanik istrošeni ili napukli.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
