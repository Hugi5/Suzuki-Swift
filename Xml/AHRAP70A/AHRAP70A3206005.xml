</servicetool>
<figure>
<graphic graphicname = "IAP70A320012.swf" width = "88.000mm" height = "54.701mm" ver = "01" gw = "98" gh = "139"/>
</figure>
</s1>
<s1>
<ptxt>
Pomoću izvlakača ležajeva (3) i preše (4) uklonite stražnji ležaj (1) s pogoskog stožastog zupčanika (2).
</ptxt>
<figure>
<graphic graphicname = "I5RS0D320016.swf" width = "88.000mm" height = "47.285mm" ver = "02" gw = "111" gh = "118"/>
</figure>
</s1>
