<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Teško pokretanje (motor se može pokrenuti)
</title>
<ptxt>
Izvršite rješavanje problema prema sljedećim točkama kada je ECM detektirao da nema DTC-a i nisu pronađene nepravilnosti u 
<intxref refid = "AHRAP70A1104008">Vizualni pregled</intxref>
 i 
<intxref refid = "AHRAP70A1104009">Osnovni pregled motora</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Teško pokretanje (motor se može pokrenuti)
</ptxt>
</condition>
<ps>
<ptxt>
Neispravna svjećica
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1806002">Provjera svjećice</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravna indukcijska zavojnica
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1806004">Pregled sklopa indukcijske zavojnice</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Prljava ili začepljena crijeva ili cijevi goriva
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1704005">Provjera tlaka goriva</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravna pumpa goriva
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1704005">Provjera tlaka goriva</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Zrak se usisava kroz brtvu usisne grane ili brtvu tijela zaklopke
</ptxt>
</ps>
<action>
<ptxt>
Provjerite sustav usisa zraka.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop tijela električne zaklopke
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306004">Provjera sklopa tijela eletrične zaklopke na vozilu</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop APP senzora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306008">Pregled APP senzora</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan ECT senzor ili MAF senzor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306012">Pregled ECT senzora</intxref>
 ili 
<intxref refid = "AHRAP70A1306026">Pregled MAF i IAT senzora</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1104070">Pregled ECM-a i njegovih krugova</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Niska kompresija
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1404001">Provjera kompresije</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabo pritegnuta svjećica ili neispravna brtva
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1806001">Uklanjanje i postavljanje svjećica</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Istjecanje kompresije na sjedištu ventila
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406028">Pregled ventila i vodilica ventila</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Lijepljenje stabla ventila
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406028">Pregled ventila i vodilica ventila</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabe ili oštećene opruge ventila
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406031">Pregled opruge ventila</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Istjecanje kompresije na brtvi glave motora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406029">Provjera glave motora</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Lijepljenje ili oštećenje klipnog prstena
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406035">Provjera cilindra, klipa i klipnog prstena</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Istrošen klip, prsten klipa ili cilindar
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406035">Provjera cilindra, klipa i klipnog prstena</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan PCV ventil
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1206006">Pregled PCV ventila</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sustav kontrole položaja bregastog vratila (VVT)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306027">Provjera OCV-a</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
