<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A7224026" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1546
</title>
<servinfosub id = "AHRAP70A7224026001">
<title>
Detektirano stanje DTC-a i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.937in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.274in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Detektirano stanje DTC-a
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1546: Neispravnost tlaka rashladnog sredstva klima uređaja
</emph>
</ptxt>
<ptxt>
Tlak rashladnog sredstva klima uređaja je manji od propisane vrijednosti, iako je temperatura okoline veća od propisane vrijednosti.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Senzor tlaka rashladnog sredstva klima uređaja
</ptxt>
</item>
<item>
<ptxt>
Senzor temperature zraka u okolini
</ptxt>
</item>
<item>
<ptxt>
Nedovoljno rashladnog sredstva
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul HVAC sustava
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70A7224026002">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pokrenite motor i uključite sustav klima uređaja.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7224026003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A7224026004">
<testgroup id = "AHRAP70A7224026005">
<title>
Provjera tlaka rashladnog sredstva klima uređaja
</title>
<test1>
<ptxt>
Uključite klima uređaj i pokrenite kompresor klima uređaja.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite “Tlak rashladnog sredstva” koristeći način “Popis podataka” na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li tlak veći od 0,34 MPa?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Napunite rashladno sredstvo i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224026006">
<title>
Provjera senzora tlaka rashladnog sredstva klima uređaja
</title>
<test1>
<ptxt>
Provjerite senzor tlaka rashladnog sredstva klima uređaja. 
<intxreftitleoff1 refid = "AHRAP70A7226022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li senzor u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite senzor tlaka rashladnog sredstva klima uređaja. 
<intxreftitleoff1 refid = "AHRAP70A7226023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224026007">
<title>
Provjera senzora temperature zraka u okolini
</title>
<test1>
<ptxt>
Provjerite senzor temperature zraka u okolini 
<intxreftitleoff1 refid = "AHRAP70AA206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li senzor u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite senzor temperature zraka u okolini. 
<intxreftitleoff1 refid = "AHRAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224026008">
<title>
Provjera sustava klima uređaja
</title>
<test1>
<ptxt>
Provjerite sustav klima uređaja. 
<intxreftitleoff1 refid = "AHRAP70A7224001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li sustav u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul HVAC sustava i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provedite 
<intxref refid = "AHRAP70A7224002">Dijagnostika problema neuobičajenog tlaka:Automatski tip</intxref>
 i ponovno provjerite DTC.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
