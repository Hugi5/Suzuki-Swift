<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1A04003" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Test generatora
</title>
<ptxt>
Uzroci za ovo stanje na koje ukazuje sporo paljenje ili niska specifična težina mogu biti jedan ili više od sljedećih uvjeta čak i ako svjetlo upozorenja radi normalno. Sljedeća procedura primjenjuje se na automobile s voltmetrom i ampermetrom.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Uvjerite se da uzrok ispražnjenosti akumulatora nije oprema koja je ostavljena uključena duže vrijeme.
</ptxt>
</item>
<item>
<ptxt>
Provjerite je li pogonski remen istrošen i koliko je zategnut. 
<intxreftitleoff1 refid = "AHRAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ako sumnjate u neispravnost akumulatora, pogledajte 
<intxref refid = "AHRAP70A1A01001">Opis akumulatora</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Potražite neispravnosti na ožičenju. Provjerite jesu li sve veze čvrste i čiste, kao i konektori kabela akumulatora na akumulatoru, kabel elektropokretača i kabel uzemljenja paljenja.
</ptxt>
</item>
</list1>
<servinfosub id = "AHRAP70A1A04003001">
<title>
Provjera bez opterećenja
</title>
<attention3>
<ptxt>
Koristite potpuno napunjen akumulator.
</ptxt>
</attention3>
<s1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Pronađete li DTC, provedite odgovarajući postupak za rješavanje problema, a zatim obrišite DTC.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Rješavanje problema: 
<intxreftitleoff1 refid = "AHRAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Brisanje DTC-a: 
<intxreftitleoff1 refid = "AHRAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Isključite sve električne uređaje (5).
</ptxt>
</s1>
<s1>
<ptxt>
Priključite voltmetar (3) i ampermetar (2) kao što je prikazano na slici.
</ptxt>
</s1>
<s1>
<ptxt>
Pokrenite motor i zagrijte ga na normalnu radnu temperaturu.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1018.swf" width = "88.000mm" height = "47.952mm" ver = "01" gw = "198" gh = "119"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.299in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.252in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.299in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.070in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Generator
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
6.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Prekidač
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Akumulator
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
7.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Terminal “B”
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Pustite da motor radi pri 2000 okr./min i očitajte mjerače.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ako je napon viši od uobičajenog, provjerite krug uzemljenja četkica. 
<intxreftitleoff1 refid = "AHRAP70A1A06009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ako četkice nisu uzemljene, zamijenite IC regulator.
</ptxt>
</item>
<item>
<ptxt>
Ako je napon niži od standardne vrijednosti, pregledajte rotor, stator, ispravljač, čahure i regulator. 
<intxreftitleoff1 refid = "AHRAP70A1A06009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<spec>
<title>
Specifikacija za ispražnjeni akumulator (provjera bez opterećenja)
</title>
<ptxt>
Struja: 10 A 
</ptxt>
<ptxt>
Regulirani napon: 11,7 – 15,3 V (pri 25 &#176;C, 77 &#176;F)
</ptxt>
</spec>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1A04003002">
<title>
Provjera opterećenja
</title>
<attention3>
<ptxt>
Koristite potpuno napunjen akumulator.
</ptxt>
</attention3>
<s1 page = "2">
<ptxt>
Spojite ampermetar jednako kao u slučaju 
<intxref refid = "AHRAP70A1A04003001">Provjera bez opterećenja</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Neka motor radi na približno 2000 okr./min pa uključite sljedeće električne uređaje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednje svjetlo (dugo svjetlo)
</ptxt>
</item>
<item>
<ptxt>
Grijač stražnjeg prozora
</ptxt>
</item>
<item>
<ptxt>
Motor puhala (maksimalna brzina)
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Očitajte ampermetar.
</ptxt>
<ptxt>
Ako je očitanje manje od 20 A, popravite ili zamijenite generator.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
