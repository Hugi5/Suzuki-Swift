<diag type = "test" id = "AHRAP70A7224019005">
<testgroup id = "AHRAP70A7224019006">
<title>
Provjera parametara alata za skeniranje
</title>
<test1>
<ptxt>
Provjerite “Air Ix Pos Sen” koristeći način rada “Popis podataka” na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li napon ispod 0,1 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Isprekidani problem.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224019007">
<title>
Provjera kruga signala senzora položaja aktuatora kontrole temperature
</title>
<test1>
<ptxt>
Odspojite konektor aktuatora kontrole temperature.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li otkriven DTC B1511-H?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite aktor kontrole temperature. 
<intxreftitleoff1 refid = "AHRAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224019008">
<title>
Provjera kruga signala senzora položaja aktuatora kontrole temperature
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite napon između terminala žice “WHT” konektora aktora kontrole temperature i uzemljenja.
</ptxt>
</test1>
<question>
Je li napon 5 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224019009">
<title>
Provjera kruga signala senzora položaja aktuatora kontrole temperature
</title>
<test1>
<ptxt>
Odspojite konektor “G20”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga žice “WHT”: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor kruga žice “WHT” između aktuatora kontrole temperature i uzemljenja: beskonačan
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li vrijednosti otpora unutar specifikacija?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul HVAC sustava i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224019010">
<title>
Provjera kruga signala senzora položaja aktuatora kontrole temperature
</title>
<test1>
<ptxt>
Provjerite da je otpor između terminala žice “YEL” i uzemljenja beskonačan.
</ptxt>
</test1>
<question>
Je li otpor prema specifikacijama?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul HVAC sustava i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
