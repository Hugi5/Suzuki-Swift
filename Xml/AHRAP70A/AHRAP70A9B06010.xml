<s1>
<ptxt>
Ugradite pojačanje šarke prednjih vrata.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite kontaktno zavarivanje.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0047.jpg" width = "183.000mm" height = "153.828mm" ver = "05" gw = "406" gh = "420"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite novu vanjsku ploču A-nosača na karoseriju vozila i režite u
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite vanjsku ploču A-nosača.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite elektrootporno točkasto zavarivanje i kontaktno zavarivanje.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite neprekidno zavarivanje.
</ptxt>
</s1>
<s1>
<ptxt>
Nanesite vosak za zaštitu od korozije na stražnju stranu neprekidno zavarenog dijela.
</ptxt>
</s1>
<s1>
<ptxt>
Savijte metalni jezičak (strjelica) vanjske ploče A-nosača.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0071Q.jpg" width = "183.000mm" height = "231.685mm" ver = "06" gw = "497" gh = "640"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
