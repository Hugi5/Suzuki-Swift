<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A9404A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kvarovi sustava za pranje
</title>
<servinfosub id = "AHRAP70A9404002003">
<title>
Stražnji brisač i sustav za pranje stražnjeg prozora
</title>
<diag type = "condition">
<condition>
<ptxt>
Kvarovi sustava za pranje
</ptxt>
</condition>
<ps>
<ptxt>
Neispravno crijevo za pranje (uključujući nepovratni ventil i konektor) ili mlaznica za pranje
</ptxt>
</ps>
<action>
<ptxt>
Provjerite jesu li crijevo ili mlaznica za pranje začepljeni ili savijeni.
</ptxt>
</action>
<ps>
<ptxt>
Neispravna pumpa za pranje
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A9406002">Provjera pumpe sustava za pranje</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan prekidač brisača i sustava za pranje (prekidač brisača)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A9406008">Pregled prekidača brisača i sustava za pranje</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravno ožičenje ili uzemljenje
</ptxt>
</ps>
<action>
<ptxt>
Popravite ožičenje.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
