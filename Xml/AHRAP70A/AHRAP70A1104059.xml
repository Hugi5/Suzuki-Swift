<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1104059" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P2228/P2229
</title>
<servinfosub id = "AHRAP70A1104059001">
<title>
Detektirano stanje DTC-a i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.143in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.027in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Detektirano stanje DTC-a
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P2228: Niski napon strujnog kruga senzora barometarskog tlaka &#34;A&#34;
</emph>
</ptxt>
<ptxt>
Izlazni napon signala senzora barometarskog tlaka niži je od 0,2 V tijekom 5 s.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Senzor barometarskog tlaka u ECM-u
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P2229: Visoki napon strujnog kruga senzora barometarskog tlaka &#34;A&#34;
</emph>
</ptxt>
<ptxt>
Izlazni napon signala senzora barometarskog tlaka viši je od 4,8 V tijekom 5 s.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70A1104059002">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Uključite kontakt na 10 s.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104059003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104059004">
<testgroup id = "AHRAP70A1104059005">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104059006">
<title>
Provjera kruga napajanja i uzemljenja ECM-a
</title>
<test1>
<ptxt>
Provjerite krug napajanja i uzemljenja ECM-a. 
<intxreftitleoff1 refid = "AHRAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug napajanja i uzemljenja ECM-a.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
