<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vrludanje, trešnja ili vibracije
</title>
<diag type = "condition">
<condition>
<ptxt>
Vrludanje, trešnja ili vibracije
</ptxt>
</condition>
<ps>
<ptxt>
Kotač nije balansiran
</ptxt>
</ps>
<action>
<ptxt>
Balansirajte kotač(e) ili zamijenite gumu/gume i/ili kotač(e).
</ptxt>
</action>
<ps>
<ptxt>
Labavi ležajevi kotača
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ležajeve kotača. 
<intxreftitleoff1 refid = "AHRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošeni krajnici spone
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite krajnike spone. 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošeni zglobovi ramena ovjesa
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite rame ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prekomjerno ljuljanje gume ili kotača
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite kotač i/ili gumu.
</ptxt>
</action>
<ps>
<ptxt>
Mjehur ili izbočina na gumi
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite gumu. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prekomjerna ovalnost gume/sklopa kotača
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite gumu ili kotač.
</ptxt>
</action>
<ps>
<ptxt>
Poremećena geometrija kotača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i prilagodite geometriju kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Labavo ili istrošeno polužje upravljača
</ptxt>
</ps>
<action>
<ptxt>
Pregledajte sustav upravljanja. 
<intxreftitleoff1 refid = "AHRAP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Labavi vijci kućišta upravljačkog prijenosnika
</ptxt>
</ps>
<action>
<ptxt>
Zategnite vijke kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
