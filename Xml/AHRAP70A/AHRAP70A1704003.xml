<servinfosub id = "AHRAP70A1704003002">
<title>
Rješavanje problema
</title>
<diag type = "test" id = "AHRAP70A1704003003">
<testgroup id = "AHRAP70A1704003004">
<title>
Provjera zvuka rada brizgaljke goriva
</title>
<test1>
<ptxt>
Alatom za slušanje provjerite zvuk rada svake brizgaljke pri pokretanju motora.
</ptxt>
</test1>
<question>
Čujete li da sve brizgaljke rade?
</question>
<result type = "yes"/>
<action>
<ptxt>
Krug brizgaljki goriva je u dobrom stanju.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704003005">
<title>
Provjera otpora brizgaljke goriva
</title>
<test1>
<ptxt>
Isključite kontakt bravu i odspojite konektore s brizgaljki goriva.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima brizgaljke goriva.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su u redu, provjerite otpor na svim brizgaljkama goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite brizgaljku goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704003006">
<title>
Provjera otpora izolacije brizgaljke goriva
</title>
<test1>
<ptxt>
Provjerite je li otpor između terminala svake brizgaljke goriva i uzemljenja beskonačan.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite brizgaljku goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704003007">
<title>
Provjera kruga napajanja brizgaljke goriva
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite odgovara li napon između svakog od krugova “A2”, “B2”, “C2” i“D2” i uzemljenja naponu akumulatora.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Popravite krug napajanja brizgaljke goriva.
</ptxt>
<ptxt>
Ako je u dobrom stanju, idite na 
<intxref refid = "AHRAP70A1104071">Provjera kruga napajanja i uzemljenja ECM-a</intxref>
.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704003008">
<title>
Provjera pogonskog kruga brizgaljke goriva
</title>
<test1>
<ptxt>
S isključenim kontaktom odspojite konektore “C01” i “E01” s ECM-a.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova “A1”, “B1”, “C1” i“D1”: manji od 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova “A1”, “B1”, “C1” i“D1” i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog terminala kruga &#34;A1&#34; i drugog terminala na konektoru brizgaljke goriva: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog terminala kruga &#34;B1&#34; i drugog terminala na konektoru brizgaljke goriva: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog terminala kruga &#34;C1&#34; i drugog terminala na konektoru brizgaljke goriva: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog terminala kruga &#34;D1&#34; i drugog terminala na konektoru brizgaljke goriva: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova “A1” – “D1”: 0 - 1 V (s uključenim kontaktom)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug napajanja brizgaljke goriva.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704003009">
<title>
Provjera brizgaljke goriva
</title>
<test1>
<ptxt>
Provjerite brizgaljku goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite krug brizgaljke goriva. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite brizgaljku goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
