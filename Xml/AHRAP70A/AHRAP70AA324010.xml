<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70AA324010" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1644
</title>
<servinfosub id = "AHRAP70AA324010001">
<title>
Detektirano DTC stanje i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.166in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.039in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Detektirano DTC stanje
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1644: Neusklađen ID blokade motora
</emph>
</ptxt>
<ptxt>
Pogreška potvrde između ECM-a i upravljačkog modula sustava pokretanja bez ključa.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Daljinski upravljač
</ptxt>
</item>
<item>
<ptxt>
ID kod ECM-a nije registriran u upravljački modul sustava pokretanja bez ključa
</ptxt>
</item>
<item>
<ptxt>
Daljinski upravljač nije registriran
</ptxt>
</item>
<item>
<ptxt>
Konektor / krug prekidača motora
</ptxt>
</item>
<item>
<ptxt>
Prekidač motora
</ptxt>
</item>
<item>
<ptxt>
Krug napajanja / uzemljenja upravljačkog modula sustava pokretanja bez ključa
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul sustava pokretanja bez ključa
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70AA324010002">
<title>
Rješavanje problema DTC-a
</title>
<attention3>
<ptxt>
Ako se radi o upravljačkom modulu sustava pokretanja bez ključa koji je bio registriran u drugom vozilu (prethodno korištena stavka), daljinski upravljači ne mogu se registrirati. Kada je zamjena neophodna, uvijek ugradite novi upravljački modul sustava pokretanja bez ključa.
</ptxt>
</attention3>
<diag type = "test" id = "AHRAP70AA324010003">
<testgroup id = "AHRAP70AA324010004">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC u upravljačkom modulu sustava pokretanja bez ključa. 
<intxreftitleoff1 refid = "AHRAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se i DTC B1189?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70AA324018">DTC B1189:Model sa sustavom pokretanja pritiskom prekidača, bez ključa</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324010005">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Potvrdite da je daljinski upravljač u radnom području funkcije pokretanja motora bez ključa.
</ptxt>
</test1>
<test1>
<ptxt>
Potvrdite da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se DTC P1644 i dalje?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Mogućnost vađenja daljinskog upravljača izvan područja rada.)
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324010006">
<title>
Provjera kruga uzemljenja i napajanja upravljačkog modula sustava pokretanja bez ključa
</title>
<test1>
<ptxt>
Provjerite krug uzemljenja i napajanja upravljačkog modula sustava pokretanja bez ključa. 
<intxreftitleoff1 refid = "AHRAP70AA504031"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324010007">
<title>
Registracija ECM-a
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA326003">Registracija u ECM:Model sa sustavom pokretanja pritiskom prekidača, bez ključa</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se DTC P1644 i dalje?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (ECM nije registriran)
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324010008">
<title>
Registracija daljinskog upravljača
</title>
<test1>
<ptxt>
Izvršite &#34;Registraciju ključa blokade motora&#34;. 
<intxreftitleoff1 refid = "AHRAP70AA326002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se DTC P1644 i dalje?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. Ako se i dalje detektira DTC P1644, zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul sustava pokretanja bez ključa: 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Daljinski upravljač nije registriran)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
