<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9B06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja nosača brave poklopca prostora motora, vodoravnog potpornog elementa svjetla i potpornja nosača svjetla
</title>
<attention3>
<ptxt>
Donja slika prikazuje uvjete za uklanjanje sljedećih dijelova.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednji blatobran 
<intxreftitleoff1 refid = "AHRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "IAP70P9B0057.jpg" width = "88.000mm" height = "55.699mm" ver = "01" gw = "227" gh = "141"/>
</figure>
<servinfosub id = "AHRAP70A9B06001001">
<title>
Opće napomene
</title>
<ptxt>
Metoda zavarivanja i broj točaka zavarivanja su jednaki na obje strane. Ove upute za popravljanje prikazuju postupak za lijevu stranu.
</ptxt>
</servinfosub>
<servinfosub id = "AHRAP70A9B06001002">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odvijte 12 vijaka.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite nosač brave poklopca prostora motora i vodoravni potporni element svjetla.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0003.jpg" width = "183.000mm" height = "157.046mm" ver = "02" gw = "347" gh = "429"/>
</figure>
</s1>
<s1>
<ptxt>
Izbušite zavarene točke i uklonite potporanj nosača svjetla.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0022.jpg" width = "183.000mm" height = "123.642mm" ver = "02" gw = "497" gh = "334"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9B06001003">
<title>
Ugradnja
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Prije zavarivanja, provjerite položaj za ugradnju i uvjete za pravilnu ugradnju dijela (dijelova). 
<intxreftitleoff1 refid = "AHRAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nastavite s popravkom, imajući na umu ugradnju dijelova koji utječu na izgled vozila. 
<intxreftitleoff1 refid = "AHRAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention2>
<s1>
<ptxt>
Ugradite potporanj nosača svjetla.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite elektrootporno točkasto zavarivanje ili kontaktno zavarivanje.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0023.jpg" width = "183.000mm" height = "123.642mm" ver = "02" gw = "497" gh = "334"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite nosač brave poklopca prostora motora.
</ptxt>
</s1>
<s1>
<ptxt>
Pritegnite 4 vijka propisanim momentom pritezanja.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0006.jpg" width = "183.000mm" height = "154.844mm" ver = "04" gw = "364" gh = "422"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.465in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
23 N&#183;m (2,3 kgf-m, 17,0 lbf-ft)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Nanesite boju i premaze na popravljene dijelove, ili zamijenite navedene dijelove.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite potporni nosača obojenog svjetla.
</ptxt>
</s1>
<s1>
<ptxt>
Pritegnite 6 vijaka propisanim momentom pritezanja.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0024.jpg" width = "183.000mm" height = "81.918mm" ver = "02" gw = "511" gh = "216"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.465in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
8,8 N&#183;m (0,90 kgf-m, 6,5 lbf-ft)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
