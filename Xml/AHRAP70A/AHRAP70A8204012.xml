<servinfosub id = "AHRAP70A8204012002">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204012003">
<testgroup id = "AHRAP70A8204012004">
<question>
Je li izvršena “Provjera dijagnostičkog sustava zračnih jastuka”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204012005">
<title>
Provjera konektora SDM-a
</title>
<test1>
<ptxt>
Provjerite pravilan spoj konektora SDM-a i “Pina detekcije spoja” konektora SDM-a.
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite SDM novim. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite probleme koji se javljaju povremeno. 
<intxreftitleoff1 refid = "AHRAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Nakon završetka pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ako su detektirani DTC-ovi, izbrišite ih prema uputama pod naslovom 
<intxref refid = "AHRAP70A8204006">Brisanje DTC-a</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem riješen.
</ptxt>
</item>
</list1>
</attention3>
