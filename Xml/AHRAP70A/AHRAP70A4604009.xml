<servinfosub id = "AHRAP70A4604009001" page = "2">
<title>
Definicija podataka alata za skeniranje
</title>
<deflist>
<term id = "AHRAP70A4604009002">
Brzina PD kotača, brzina PL kotača, brzina SD kotača i brzina SL kotača (km/h, MILJA/H)
</term>
<def>
<ptxt>
Brzina kotača unutarnji je parametar upravljačkog modula ESP<sup>®</sup>-a. Računa se putem referentnih impulsa sa senzora brzine kotača.
</ptxt>
</def>
<term id = "AHRAP70A4604009003">
G senzor (G)
</term>
<def>
<ptxt>
Ubrzavanje i usporavanje mjere se senzorom brzine zanošenja/G sile u upravljačkom modulu ESP<sup>®</sup>-a.
</ptxt>
</def>
<term id = "AHRAP70A4604009004">
Napon akumulatora (V)
</term>
<def>
<ptxt>
Napon akumulatora analogni je ulazni signal koji očitava upravljački modul ESP<sup>®</sup>-a. Funkcije upravljačkog modula ESP<sup>®</sup>-a mogu se zaustaviti ako napon akumulatora padne ili poraste iznad programiranih granica.
</ptxt>
</def>
<term id = "AHRAP70A4604009005">
Pokretač motora pumpe (V)
</term>
<def>
<ptxt>
Ovaj parametar označava radno stanje pokretača motora pumpe (tranzistor).
</ptxt>
</def>
<term id = "AHRAP70A4604009006">
Tlak na glavnom cilindru (MPa)
</term>
<def>
<ptxt>
Ovo označava tlak kočne tekućine iz glavnog cilindra kočnice.
</ptxt>
</def>
<term id = "AHRAP70A4604009007">
G senzor (poprečna) (G)
</term>
<def>
<ptxt>
Poprečno ubrzanje mjeri se senzorom brzine zanošenja/G sile u upravljačkom modulu ESP<sup>®</sup>-a.
</ptxt>
</def>
<term id = "AHRAP70A4604009008">
Senzor brzine zanošenja (stupnjeva u sekundi)
</term>
<def>
<ptxt>
Brzina zanošenja mjeri se senzorom brzine zanošenja/G sile u upravljačkom modulu ESP<sup>®</sup>-a.
</ptxt>
</def>
<term id = "AHRAP70A4604009009">
Senzor kuta zakretanja upravljača (&#176;)
</term>
<def>
<ptxt>
Senzor kuta zakretanja mjeri kut zakretanja kola upravljača i prenosi ga u upravljački modul ESP<sup>®</sup>-a putem signala CAN komunikacije.
</ptxt>
</def>
<term id = "AHRAP70A4604009010">
Prekidač kočnice (UKLJ., ISKLJ.)
</term>
<def>
<ptxt>
Signali ovog prekidača informiraju upravljački modul ESP<sup>®</sup>-a je li kočnica aktivna ili ne.
</ptxt>
</def>
<term id = "AHRAP70A4604009011">
Kontrola stabilnosti (UKLJ., ISKLJ.)
</term>
<def>
<ptxt>
Ovaj parametar šalje informaciju o tome koristi li se kočnica aktivno ili ne kad je vozilo u stanju preupravljivosti ili podupravljivosti.
</ptxt>
</def>
<term id = "AHRAP70A4604009012">
Kontrola TCS-a (kočnica) (UKLJ., ISKLJ.)
</term>
<def>
<ptxt>
Ovaj parametar šalje informaciju o tome koristi li se kočnica aktivno ili ne kad vozilo povećava brzinu.
</ptxt>
</def>
<term id = "AHRAP70A4604009013">
Kontrola TCS-a (motor) (UKLJ., ISKLJ.)
</term>
<def>
<ptxt>
Ovaj parametar šalje informaciju o tome radi li upravljanje okretnim momentom motora ili ne kad vozilo povećava brzinu.
</ptxt>
</def>
<term id = "AHRAP70A4604009014">
Stanje prekidača TCSS OFF (UKLJ.,ISKLJ.)
</term>
<def>
<ptxt>
Ovaj parametar označava stanje prekidača ESP<sup>®</sup> OFF.
</ptxt>
</def>
<term id = "AHRAP70A4604009015">
Signal kuta zakretanja upravljača (neutralan, nije neutralan)
</term>
<def>
<ptxt>
Ovaj parametar šalje informaciju detektira li senzor kuta zakretanja upravljača je li kolo upravljača usmjereno ravno naprijed ili ne.
</ptxt>
</def>
<term id = "AHRAP70A4604009016">
Prekidač kontrole držanja na nagibu (sa, bez)
</term>
<def>
<ptxt>
Ovaj parametar šalje informaciju je li vozilo opremljeno funkcijom kontrole držanja na nagibu ili nije.
</ptxt>
</def>
<term id = "AHRAP70A4604009017">
Stanje komunikacije IPC-a (normalno, neuobičajeno)
</term>
<def>
<ptxt>
Ovaj parametar šalje informaciju je li senzor kuta zakretanja za ESP<sup>®</sup> ili nije.
</ptxt>
</def>
</deflist>
</servinfosub>
</servinfo>
</servinfotype>
