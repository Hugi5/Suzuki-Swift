<servinfo servinfosgmlid = "AHRAP70A1406045" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Provjera zamašnjaka
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1406021">Uklanjanje i postavljanje zamašnjaka</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1406045001">
<title>
Vizualni pregled
</title>
<list1 type = "unordered">
<item>
<ptxt>
Ako je nazubljeni vijenac zamašnjaka oštećen, napuknut ili istrošen, zamijenite zamašnjak.
</ptxt>
</item>
<item>
<ptxt>
Ako je površina koja dolazi u dodir s lamelom spojke oštećena ili pretjerano istrošena, zamijenite zamašnjak.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "AHRAP70A1406045002">
<title>
Čeona deformacija zamašnjaka
</title>
<ptxt>
Komparatorom provjerite čeonu deformaciju zamašnjaka. 
</ptxt>
<ptxt>
Ako deformacija prelazi graničnu vrijednost, zamijenite zamašnjak.
</ptxt>
<spec>
<title>
Čeona deformacija zamašnjaka/pogonske ploče
</title>
<ptxt>
Granica: 0,2 mm (0,0079 in)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I2RH01140198.swf" width = "88.000mm" height = "42.110mm" ver = "01" gw = "183" gh = "102"/>
</figure>
</servinfosub>
</servinfo>
