<title>
Uklanjanje i ugradnja krovne obloge
</title>
<servinfosub id = "AHRAP70A9806011001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Deaktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite štitnike za sunce (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite reflektorsko svjetlo (ako je dio opreme) (3) i svjetlo putničkog prostora (2).
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reflektorsko svjetlo (ako je dio opreme): 
<intxreftitleoff1 refid = "AHRAP70A9206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Svjetlo putničkog prostora: 
<intxreftitleoff1 refid = "AHRAP70A9206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Uklonite sljedeće obloge. 
<intxreftitleoff1 refid = "AHRAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Obloge prednjeg stupa
</ptxt>
</item>
<item>
<ptxt>
Gornje obloge srednjeg stupa
</ptxt>
</item>
<item>
<ptxt>
Unutarnje gornje obloge stražnjeg krila
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Uklonite pomoćne rukohvate (4).
</ptxt>
</s1>
<s1>
<ptxt>
Za modele s krovnim prozorom, uklonite oblogu krovnog prozora (5).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite kopče, a potom i samu krovnu oblogu (6).
</ptxt>
<figure>
<graphic graphicname = "IAP70A980008.jpg" width = "183.000mm" height = "158.326mm" ver = "01" gw = "488" gh = "432"/>
