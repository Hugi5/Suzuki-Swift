<servinfosub id = "AHRAP70A1104027003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Napon akumulatora &#62; 10,7 V
</ptxt>
</item>
<item>
<ptxt>
Nije detektiran DTC P0030, P0031, P0032, P0131 ili P0132.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Zagrijte motor do normalne radne temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Vozite vozilo konstantnom brzinom od 50 do 80 km/h (31 do 50 milja/h) u trajanju od 5 min ili više.
</ptxt>
</s1>
<s1>
<ptxt>
Alatom za skeniranje provjerite je li test spremnosti/nadzora A/F senzora dovršen.
</ptxt>
<ptxt>
Ako nije dovršen test spremnosti/nadzora A/F senzora, provjerite stanje vozila (okoliša) i ponovite 2. i 3. korak.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104027004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104027005">
<testgroup id = "AHRAP70A1104027006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104027007">
<title>
Provjera grijača A/F senzora
</title>
<test1>
<ptxt>
Provjerite grijač A/F senzora. 
<intxreftitleoff1 refid = "AHRAP70A1306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite A/F senzor.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104027008">
<title>
Provjera kruga grijača A/F senzora
</title>
<test1>
<ptxt>
Provjerite krugove grijača A/F senzora prema koracima 2 do 3 u poglavlju 
<intxref refid = "AHRAP70A1104015">DTC P0030/P0031/P0032</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
