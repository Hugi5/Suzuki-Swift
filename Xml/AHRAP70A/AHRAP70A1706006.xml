<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1706006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i postavljanje cijevi goriva
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1706001">Komponente sustava goriva</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A1706005">Provjera vodova goriva na vozilu</intxrefpoff>
</ptxt>
<attention1>
<ptxt>
Prije sljedećeg postupka svakako pročitajte 
<intxref refid = "AHRAP70A1700001">Mjere opreza za servisiranje sustava goriva</intxref>
 da biste umanjili rizik od izbijanja požara ili ozljeđivanja.
</ptxt>
</attention1>
<servinfosub id = "AHRAP70A1706006001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Otpustite tlak goriva iz dobavnog voda goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite crijeva goriva (3) od cijevi goriva (2) s prednje i stražnje strane svake cijevi goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Označite položaj obujmica (1) na cijevima goriva (2) tako da ih možete vratiti na originalno mjesto.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite obujmice (1) s karoserije vozila i s cijevi goriva.
</ptxt>
<attention2>
<ptxt>
Budite oprezni da ne savijete i ne oštetite cijevi goriva pri uklanjanju obujmice.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Uklonite cijevi goriva (2).
</ptxt>
<figure>
<graphic graphicname = "I4RS0B170007.swf" width = "88.000mm" height = "42.608mm" ver = "01" gw = "173" gh = "104"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1706006002">
<title>
Ugradnja
</title>
<s1>
<ptxt>
Postavite obujmice na označena mjesta na cijevima. Ako je obujmica deformirana ili je štipaljka savijena ili slomljena, zamijenite je novom.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite cijevi s obujmicom na vozilo.
</ptxt>
</s1>
<s1>
<ptxt>
Spojite crijeva goriva s cijevima. 
<intxreftitleoff1 refid = "AHRAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Spojite negativni kabel (–) na akumulator.
</ptxt>
</s1>
<s1>
<ptxt>
Dok motor ne radi, a kontakt brava je uključena, potražite istječe li negdje gorivo. 
<intxreftitleoff1 refid = "AHRAP70A1706004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
