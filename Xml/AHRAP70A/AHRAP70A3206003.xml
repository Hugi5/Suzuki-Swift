<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa stražnjeg diferencijala
</title>
<servinfosub id = "AHRAP70A3206003001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Podignite vozilo i uklonite kotače.
</ptxt>
</s1>
<s1>
<ptxt>
Ispustite ulje iz stražnjeg diferencijala, ako je potrebno. 
<intxreftitleoff1 refid = "AHRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite stražnja pogonska vratila. 
<intxreftitleoff1 refid = "AHRAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite kardansko vratilo sa stražnjeg diferencijala. 
<intxreftitleoff1 refid = "AHRAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite crijevo oduška (1) sa stražnjeg diferencijala.
</ptxt>
</s1>
<s1>
<ptxt>
Postavite dizalicu tako da se sklop diferencijala ne naginje. 
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke prednjeg ramena diferencijala (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite stražnji pričvrsni vijak diferencijala (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A320007.swf" width = "88.000mm" height = "57.146mm" ver = "02" gw = "186" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Spustite dizalicu sa sklopom stražnjeg diferencijala.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A3206003002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka rastavljanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite sve vijke propisanim momentima pritezanja.
</ptxt>
<torque>
<torqueitem id = "T3B004">
<t-part>
Vijak prednjeg ramena diferencijala
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
<torqueitem id = "T3B005">
<t-part>
Stražnji pričvrsni vijak diferencijala
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
80
</t-value1>
<t-value2>
8,2
</t-value2>
<t-value3>
59,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320008.swf" width = "88.000mm" height = "52.572mm" ver = "02" gw = "186" gh = "133"/>
</figure>
</item>
<item>
<ptxt>
Napunite uljem stražnjeg diferencijala, ako je ispušteno, 
<intxreftitleoff1 refid = "AHRAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
