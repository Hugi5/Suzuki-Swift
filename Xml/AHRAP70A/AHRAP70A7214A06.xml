<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A7214A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hladni zrak ne izlazi van (motor ventilatora hlađenja hladnjaka ne radi)
</title>
<diag type = "condition">
<condition>
<ptxt>
Hladni zrak ne izlazi van (motor ventilatora hlađenja hladnjaka ne radi)
</ptxt>
</condition>
<ps>
<ptxt>
Pregorjeli osigurač
</ptxt>
</ps>
<action>
<ptxt>
Provjerite povezane osigurače, a zatim provjerite postoji li kratki spoj s uzemljenjem.
</ptxt>
</action>
<ps>
<ptxt>
Neispravno ožičenje ili uzemljenje
</ptxt>
</ps>
<action>
<ptxt>
Popravite ožičenje.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan relej motora ventilatora hlađenja hladnjaka
</ptxt>
</ps>
<action>
<ptxt>
Provjerite relej ventilatora hlađenja hladnjaka. 
<intxreftitleoff1 refid = "AHRAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motor ventilatora hlađenja hladnjaka u kvaru
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Provjerite motor ventilatora hlađenja hladnjaka. 
<intxreftitleoff1 refid = "AHRAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Neispravan ECM
</ptxt>
</ps>
<action>
<ptxt>
Provjerite ECM. 
<intxreftitleoff1 refid = "AHRAP70A7214017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
