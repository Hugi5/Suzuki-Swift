<servinfo servinfosgmlid = "AHRAP70A9206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja svjetla registarske pločice
</title>
<servinfosub id = "AHRAP70A9206007001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite vijke donje obloge vrata prtljažnika (1) pa uklonite donju oblogu vrata prtljažnika (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite svjetlo registarske pločice (3).
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor svjetla registarske pločice.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920001.jpg" width = "88.000mm" height = "80.485mm" ver = "01" gw = "211" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite žarulju.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9206007002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijke donje obloge vrata prtljažnika propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9B001">
<t-part>
Vijak donje obloge vrata prtljažnika
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A920002.jpg" width = "88.000mm" height = "80.884mm" ver = "01" gw = "211" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
