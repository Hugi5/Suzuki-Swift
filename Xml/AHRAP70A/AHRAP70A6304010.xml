<servinfosub id = "AHRAP70A6304010002">
<title>
Rješavanje problema
</title>
<diag type = "test" id = "AHRAP70A6304010003">
<testgroup id = "AHRAP70A6304010004">
<title>
Provjera svjetla upozorenja &#34;P/S&#34;-a
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<question>
Uključuju li se druga svjetla upozorenja?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304010005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70A6304003">Provjera DTC-a</intxref>
.
</ptxt>
</test1>
<question>
Postoji li DTC U0073 ili DTC U0155?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70AA804002">Tablica DTC-a CAN-a (Prekid komunikacije i Sabirnica komunikacije isključena)</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304010006">
<title>
Provjera kombiniranog mjerača
</title>
<test1>
<ptxt>
Zamijenite kombinirani mjerač. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<question>
Ostaje li svjetlo upozorenja isključeno?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul P/S-a. 
<intxreftitleoff1 refid = "AHRAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304010007">
<title>
Provjera osigurača
</title>
<question>
Je li osigurač kruga za kombinirani mjerač u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Zamijenite osigurač i provjerite je li došlo do kratkog spoja s uzemljenjem.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304010008">
<title>
Provjera strujnog kruga CAN komunikacije
</title>
<test1>
<ptxt>
Provjerite strujni krug CAN komunikacije između kombiniranog mjerača i upravljačkog modula P/S-a. 
<intxreftitleoff1 refid = "AHRAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li krug CAN komunikacije u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Popravite ili zamijenite.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304010009">
<title>
Provjera strujnog kruga napajanja kombiniranog mjerača
</title>
<test1>
<ptxt>
Uklonite kombinirani mjerač. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja s konektorom kombiniranog mjerača.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su rezultati provjere u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite odgovara li napon između terminala “G240-3” i “G240-5” naponu akumulatora.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite kombinirani mjerač i ponovno provjerite. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304010010">
<title>
Provjera kruga uzemljenja kombiniranog mjerača
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite da je otpor između terminala “G240-5” i uzemljenja 1 Ω ili manji.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Popravite ili zamijenite krug &#34;A1&#34;.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite krug &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
