<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1406009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i postavljanje usisne grane
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1406005">Komponente tijela zaklopke i usisne grane</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1406009001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (-) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sklop pročistača zraka. 
<intxreftitleoff1 refid = "AHRAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Spojite crijeva rashladne tekućine motora pa uklonite sklop tijela električne zaklopke s usisne grane.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite MAP senzor od priključka (1).
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite sljedeća crijeva:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Crijevo servouređaja kočnice (2) od servouređaja kočnice
</ptxt>
</item>
<item>
<ptxt>
PCV crijevo (3) od PCV ventila
</ptxt>
<figure>
<graphic graphicname = "I7V20A141039.swf" width = "88.000mm" height = "53.078mm" ver = "01" gw = "221" gh = "134"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Uklonite vijak ulazne cijevi grijača (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141022.jpg" width = "88.000mm" height = "51.297mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite usisnu granu (1) i brtvu.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141040.swf" width = "88.000mm" height = "57.944mm" ver = "01" gw = "183" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite cijev za rashladnu vodu (1). 
<intxreftitleoff1 refid = "AHRAP70A1606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite odstojnik (2) i brtvu s glave motora.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141023.jpg" width = "88.000mm" height = "57.901mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1406009002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Upotrijebite novu brtvu.
</ptxt>
</item>
<item>
<ptxt>
Provjerite jesu li svi uklonjeni dijelovi vraćeni na mjesto.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
