<servinfosub id = "AHRAP70A1104028003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon akumulatora &#62; 10,7 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Zagrijte motor do normalne radne temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Vozite vozilo konstantnom brzinom od 50 do 80 km/h (31 do 50 milja/h) u trajanju od 20 min ili više.
</ptxt>
</s1>
<s1>
<ptxt>
Zaustavite vozilo i pustite motor neka radi u praznom hodu 5 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104028004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104028005">
<testgroup id = "AHRAP70A1104028006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104028007">
<title>
Provjera DTC-a
</title>
<question>
Postoje li DTC-ovi osim P0137, P0138 i P0140?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajući postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104028008">
<title>
Provjera kruga signala i uzemljenja HO2S-a
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a i konektor HO2S-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34; i konektorom HO2S-a.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;B2&#34; i &#34;B3&#34;: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova &#34;B2&#34; i &#34;B3&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B2&#34; i drugih terminala na konektoru HO2S-a: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B3&#34; i drugih terminala na konektoru HO2S-a: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova &#34;B2&#34; i &#34;B3&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104028009">
<title>
Provjera ispušnog sustava i sustava usisa zraka
</title>
<test1>
<ptxt>
Provjerite jesu li ispušni sustav i sustav usisa zraka začepljeni ili propuštaju.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104028010">
<title>
Provjera strujnog kruga HO2S grijača
</title>
<test1>
<ptxt>
Provjerite krugove HO2S grijača prema koracima 2 do 3 u poglavlju 
<intxref refid = "AHRAP70A1104016">DTC P0036/P0037/P0038</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104028011">
<title>
Provjerite brizgaljke goriva i njihov krug
</title>
<test1>
<ptxt>
Provjerite krug brizgaljke goriva. 
<intxreftitleoff1 refid = "AHRAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite brizgaljke goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Neispravna jedna ili više brizgaljki ili njihovi krugovi.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104028012">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite HO2S. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Izvršite postupak potvrde DTC-a i provjerite DTC-ove.
</ptxt>
</test1>
<question>
Jesu li detektirani DTC-ovi P137, P0138 ili P0140?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
