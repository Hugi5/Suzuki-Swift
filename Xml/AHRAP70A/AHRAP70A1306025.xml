<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1306025" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja MAF i IAT senzora
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1306024">Pregled MAF i IAT senzora na vozilu</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Prilikom servisiranja MAF i IAT senzora, svakako imajte na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ne rastavljajte MAF i IAT senzore.
</ptxt>
</item>
<item>
<ptxt>
Ne izlažite MAF i IAT senzore udarcima. Senzor koji je pao na pod treba zamijeniti.
</ptxt>
</item>
<item>
<ptxt>
Ne čistite MAF i IAT senzor.
</ptxt>
</item>
<item>
<ptxt>
Ne ispuhujte MAF i IAT senzore komprimiranim zrakom pomoću zračnog pištolja ili sličnog.
</ptxt>
</item>
<item>
<ptxt>
Ne gurajte prste ili neki drugi predmet u MAF i IAT senzor.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AHRAP70A1306025001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Iskopčajte konektore MAF i IAT senzora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sklop pročistača zraka. 
<intxreftitleoff1 refid = "AHRAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite MAF i IAT senzor (1) iz kućišta pročistača zraka (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A131010.jpg" width = "88.000mm" height = "48.136mm" ver = "01" gw = "185" gh = "120"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A1306025002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1306026">Pregled MAF i IAT senzora</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijke (1) MAF i IAT senzora propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1C009">
<t-part>
Vijak MAF i IAT senzora
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
1,2
</t-value1>
<t-value2>
0,12
</t-value2>
<t-value3>
0,9
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131011.jpg" width = "88.000mm" height = "48.136mm" ver = "01" gw = "185" gh = "120"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
