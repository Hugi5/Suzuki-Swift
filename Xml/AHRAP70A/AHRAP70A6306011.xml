<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A6306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja upravljačkog modula P/S-a
</title>
<servinfosub id = "AHRAP70A6306011001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite ploču s instrumentima. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sklop papučice kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektore (1) s upravljačkog modula P/S-a (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke upravljačkog modula P/S-a (3) sa potpornja upravljača.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630037.swf" width = "88.000mm" height = "94.023mm" ver = "01" gw = "148" gh = "250"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite upravljački modul P/S-a.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A6306011002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zategnite vijke upravljačkog modula P/S-a primjenom odgovarajućeg momenta pritezanja.
</ptxt>
<torque>
<torqueitem id = "T6C006">
<t-part>
Pričvrsni vijak upravljačkog modula servoupravljača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,0
</t-value1>
<t-value2>
0,51
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A630034.swf" width = "88.000mm" height = "98.099mm" ver = "02" gw = "148" gh = "262"/>
</figure>
</item>
<item>
<ptxt>
Ugradite sklop papučice kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
