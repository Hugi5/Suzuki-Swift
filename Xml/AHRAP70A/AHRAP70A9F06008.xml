<title>
Uklanjanje i ugradnja priključka za USB
</title>
<servinfosub id = "AHRAP70A9F06008001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite kutiju centralne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite centralnu zaštitu. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor USB priključka (1), zatim uklonite USB priključak (2) s ploče s instrumentima (3) dok otpuštate brave (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0014.jpg" width = "88.000mm" height = "55.000mm" ver = "02" gw = "206" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9F06008002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9F06009">Pregled USB priključka</intxrefpoff>
</ptxt>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
