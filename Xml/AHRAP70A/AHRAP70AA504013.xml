<servinfosub id = "AHRAP70AA504013005">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Uključite kontakt.
</ptxt>
</s1>
<s1>
<ptxt>
Do kraja pritisnite papučicu spojke tijekom 3 sekunde ili dulje.
</ptxt>
</s1>
<s1>
<ptxt>
Otpustite papučicu spojke tijekom 3 sekunde ili dulje.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA504013008">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70AA504013018">
<testgroup id = "AHRAP70AA504013019">
<title>
Provjera DTC-a
</title>
<question>
Je li detektiran DTC osim B1125?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504013003">
<title>
Provjera parametara
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite &#34;Prekidač položaja P / CPP2&#34; i &#34;Prekidač spojke / mjenjača&#34; prikazan na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504013020">
<title>
Provjera kruga signala CPP prekidača br. 1
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite CPP prekidač br. 1, konektore “C01”, “E01”, &#34;E25” i &#34;L10&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s prekidačem CPP br. 1 i konektorima “C01”, “E01”, &#34;E25” i &#34;L10&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu provjerite sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;A1&#34;: manji od 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;A1&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i svakog terminala na konektoru CPP prekidača br. 1: beskonačan
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504013021">
<title>
Provjera kruga signala CPP prekidača br. 2
</title>
<test1>
<ptxt>
Odspojite konektor CPP prekidača br. 2.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s prekidačem CPP br. 2 i konektorima &#34;E25” i &#34;L10&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu provjerite sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;A2&#34;: manji od 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;A2&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A2&#34; i svakog terminala na konektoru CPP prekidača br. 2: beskonačan
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504013022">
<title>
Provjera CPP prekidača br. 1
</title>
<test1>
<ptxt>
Provjerite CPP prekidač br. 1. 
<intxreftitleoff1 refid = "AHRAP70A5306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite CPP prekidač br. 1. 
<intxreftitleoff1 refid = "AHRAP70A5306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504013023">
<title>
Provjera CPP prekidača br. 2
</title>
<test1>
<ptxt>
Provjerite CPP prekidač br. 2. 
<intxreftitleoff1 refid = "AHRAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite CPP prekidač br. 2. 
<intxreftitleoff1 refid = "AHRAP70A5306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504013006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Spojite CPP prekidač br. 1, CPP prekidač br. 2, konektore “C01”, “E01”, &#34;E25” i &#34;L10&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. (Provjera DTC-a):
</ptxt>
</test1>
<question>
Je li detektiran trenutni DTC B1125?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
