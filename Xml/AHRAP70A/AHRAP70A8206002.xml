<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A8206002" svcinfotypenbr = "08" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
Aktiviranje sustava zračnog jastuka
</title>
<s1>
<ptxt>
Uvjerite se da su uklonjene komponente ugrađene i/ili odspojeni konektori ispravno spojeni.
</ptxt>
</s1>
<s1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</s1>
<s1>
<ptxt>
Spojite negativni (–) kabel na akumulator i/ili ugradite osigurač “A/B” u razvodni blok. 
<intxreftitleoff1 refid = "AHRAP70A8200003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uključite kontakt.
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite da se svjetlo upozorenja “AIR BAG”-a uključuje na približno 6 sekundi, a zatim se gasi.
</ptxt>
</s1>
<s1>
<ptxt>
Ako je neispravno, izvršite 
<intxref refid = "AHRAP70A8201001">Konstrukcija sustava zračnih jastuka</intxref>
.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
