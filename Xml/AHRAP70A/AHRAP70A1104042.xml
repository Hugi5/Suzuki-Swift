<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0530: Krug senzora &#34;A&#34; tlaka rashladnog sredstva klima uređaja
</emph>
</ptxt>
<ptxt>
Bilo koji od sljedećih uvjeta je ispunjen. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Izlazni napon kruga signala senzora tlaka rashladnog sredstva klima uređaja niži je od 0,15 V.
</ptxt>
</item>
<item>
<ptxt>
Izlazni napon kruga signala senzora tlaka rashladnog sredstva klima uređaja viši je od 4,93 V.
</ptxt>
</item>
</list1>
<ptxt>
(logika detekcije 3 ciklusa vožnje, ali MIL ne zasvijetli)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Senzor tlaka rashladnog sredstva klima uređaja i/ili njegov krug
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
