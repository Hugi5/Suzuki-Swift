<servinfosub id = "AHRAP70A1104042003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pustite neka motor radi u praznom hodu 10 sekundi.
</ptxt>
</s1>
<s1>
<ptxt>
Uključite prekidač klima uređaja na 10 s.
</ptxt>
</s1>
<s1>
<ptxt>
Isključite prekidač klima uređaja.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104042004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104042005">
<testgroup id = "AHRAP70A1104042006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104042007">
<title>
Provjera kruga napajanja senzora tlaka rashladnog sredstva klima uređaja
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektor senzora tlaka rashladnog sredstva klima uređaja.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorom senzora tlaka rashladnog sredstva klima uređaja.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite je li napon između &#34;A1&#34; i &#34;A3&#34; približno 5 V.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104042008">
<title>
Provjera kruga uzemljenja senzora tlaka rashladnog sredstva klima uređaja
</title>
<test1>
<ptxt>
Provjerite je li napon između &#34;A1&#34; i uzemljenja približno 5 V.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Popravite krug &#34;A3&#34;.
</ptxt>
<ptxt>
Ako se ovaj DTC i dalje detektira, zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug &#34;A1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104042009">
<title>
Provjera kruga signala senzora tlaka rashladnog sredstva klima uređaja
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;A2&#34;: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;A2&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A2&#34; i drugih terminala konektora senzora tlaka rashladnog sredstva klima uređaja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;A2&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ili popravite krug signala senzora tlaka rashladnog sredstva klima uređaja.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104042010">
<title>
Provjera senzora tlaka rashladnog sredstva klima uređaja
</title>
<test1>
<ptxt>
Provjerite senzor tlaka rashladnog sredstva klima uređaja. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s ručnim klima uređajem: 
<intxreftitleoff1 refid = "AHRAP70A7216023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatskim klima uređajem: 
<intxreftitleoff1 refid = "AHRAP70A7226022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite senzor tlaka rashladnog sredstva klima uređaja.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
