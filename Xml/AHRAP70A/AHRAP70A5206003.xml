<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Zamjena brtve ulja na strani diferencijala
</title>
<s1>
<ptxt>
Podignite vozilo i ispustite ulje mjenjača.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sklop lijevog pogonskog vratila. 
<intxreftitleoff1 refid = "AHRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Specijalnim alatom uklonite brtvu ulja (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522004.swf" width = "88.000mm" height = "48.454mm" ver = "01" gw = "146" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Specijalnim alatom ugradite novu brtvu ulja (1).
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno ugradite brtvu ulja s oprugom prema unutra.
</ptxt>
</item>
<item>
<ptxt>
Obavezno ugradite brtvu ulja na površinu lijevog kućišta (2) paralelno.
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
09944-88220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Udaljenost između površine kućišta i brtve ulja
</title>
<ptxt>
“a”: 0 – 1,0 mm (0 – 0,04 in)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Nanesite mazivo na rub brtve i provjerite pogonsko vratilo na mjestu kontakta s brtvom ulja i uvjerite se da je glatko.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B004" uid = "22">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A522005.swf" width = "88.000mm" height = "44.718mm" ver = "02" gw = "110" gh = "110"/>
</figure>
</s1>
<s1>
<ptxt>
Umetnite sklop lijevog pogonskog vratila. 
<intxreftitleoff1 refid = "AHRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nadopunite ulje mjenjača. 
<intxreftitleoff1 refid = "AHRAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
