<servinfosub id = "AHRAP70A1704005002">
<title>
Rješavanje problema
</title>
<attention3>
<ptxt>
Prije upotrebe tablice toka u nastavku, potvrdite da je napon akumulatora 11 V ili veći. Ako je niži, tlak goriva postaje niži od propisanog čak i ako su pumpa goriva i vod u dobrom stanju.
</ptxt>
</attention3>
<diag type = "test" id = "AHRAP70A1704005003">
<testgroup id = "AHRAP70A1704005004">
<question>
Je li obavljena &#34;Provjera pumpe goriva i njenog kruga&#34;? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1704004">Provjera pumpe goriva i njenog kruga</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704005005">
<title>
Provjera tlaka goriva 1
</title>
<test1>
<ptxt>
Provjerite tlak goriva. 
<intxreftitleoff1 refid = "AHRAP70A1704006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704005006">
<title>
Provjera tlaka goriva 2
</title>
<test1>
<ptxt>
Pokrenite motor i zagrijte ga na normalnu radnu temperaturu.
</ptxt>
</test1>
<test1>
<ptxt>
Održavajte brzinu vrtnje motora na 4000 okr./min.
</ptxt>
</test1>
<question>
Pokazuje li tlak goriva približno istu vrijednost kao u 2. koraku?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ako je regulator tlaka u neispravnom stanju, zamijenite sklop pumpe goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704005007">
<title>
Provjera voda goriva
</title>
<test1>
<ptxt>
Provjerite cijev i spoj goriva radi istjecanja goriva, oštećenja ili deformacije.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustav goriva je u dobrom stanju.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704005008">
<title>
Provjera voda goriva
</title>
<test1>
<ptxt>
Provjerite jesu li cijev i spoj goriva oštećeni ili deformirani.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Začepljen filtar goriva, neispravna pumpa goriva, neispravan regulator tlaka goriva ili istjecanje goriva iz spoja cijevi u spremniku goriva.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite neispravni dio.
</ptxt>
</action>
</testgroup>
</diag>
