<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A6306008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja spone / manžete zupčaste letve upravljača
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A6306003">Uklanjanje i ugradnja krajnika spone</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A6306001">Komponente sklopa kućišta upravljačkog prijenosnika</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A6306007">Pregled manžete zupčaste letve upravljača</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A6306008001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite krajnik spone. 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite obujmicu (2) i osigurač manžete zupčaste letve upravljača (1).
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Uklonite manžetu zupčaste letve upravljača (3) sa spone.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630026.swf" width = "88.000mm" height = "53.031mm" ver = "02" gw = "158" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Izravnajte savijene dijelove sigurnosne podloške krajnika spone (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sponu (3) sa zupčaste letve (2) kako je prikazano.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630027.swf" width = "88.000mm" height = "46.459mm" ver = "01" gw = "197" gh = "115"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A6306008002">
<title>
Ugradnja
</title>
<s1>
<ptxt>
Poravnajte utor (5) zupčaste letve (2) s izdankom (4) sigurnosne podloške krajnika spone (3).
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite sponu (1) na zupčastu letvu (2), a zatim zategnite sponu primjenom odgovarajućeg momenta pritezanja.
</ptxt>
<torque>
<torqueitem id = "T6C003">
<t-part>
Spona
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A630015.swf" width = "88.000mm" height = "55.132mm" ver = "01" gw = "145" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Savijte sigurnosnu podlošku na 2 mjesta (1) kao što je prikazano na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630029.swf" width = "88.000mm" height = "51.419mm" ver = "02" gw = "144" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Nanesite mast na dio &#34;A&#34; spone, označeno na slici. Pravilno pozicionirajte manžetu zupčaste letve upravljača u utore sklopa kućišta upravljačkog prijenosnika (ili na strani zupčaste letve) i spone.
</ptxt>
<ptxt>
Nakon toga, provjerite kako biste bili sigurni da manžeta zupčaste letve upravljača nije uvijena i udubljena.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease E" id = "M6C001" uid = "24">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25050
</m-number>
<m-name>
SUZUKI Super Mast E
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A630030.swf" width = "88.000mm" height = "33.098mm" ver = "01" gw = "196" gh = "77"/>
</figure>
</s1>
<s1>
<ptxt>
Učvrstite novu vrpcu (1) upotrebom specijalnog alata i ugradite osigurač manžete zupčaste letve (2)
</ptxt>
<servicetool>
<servicetoolitem id = "L6C008">
<s-part>
(A)
</s-part>
<s-number num = "09943-55010">
09943-55010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630031.swf" width = "88.000mm" height = "40.262mm" ver = "01" gw = "161" gh = "98"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite krajnik spone. 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Ugradite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
