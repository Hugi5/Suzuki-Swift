<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A5204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Zupčanici klize iz zahvata
</title>
<diag type = "condition">
<condition>
<ptxt>
Zupčanici klize iz zahvata
</ptxt>
</condition>
<ps>
<ptxt>
Istrošena osovina vilice mjenjača
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite vilicu ili vratilo za odabir stupnja prijenosa.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Vratilo za odabir niskog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vratilo za odabir visokog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vilica odabira 5. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Istrošena vilica za odabir stupnja prijenosa ili ogrlica sinkrona
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite vilicu za odabir stupnja prijenosa, vratilo za odabir stupnja prijenosa ili sinkron i ogrlicu sinkrona.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Vratilo za odabir niskog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vratilo za odabir visokog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vilica odabira 5. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sinkron i ogrlica sinkrona niskog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sinkron i ogrlica sinkrona visokog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sinkron i ogrlica sinkrona 5. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Slabe ili oštećene opruge za određivanje položaja
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite oprugu za određivanje položaja. 
<intxreftitleoff1 refid = "AHRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošeni ležajevi na ulaznom vratilu ili predložnom vratilu
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite ležaj ulaznog vratila ili ležaj izlaznog vratila.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Lijevi ležaj predložnog vratila:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Unutarnji prsten: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vanjski prsten: 
<intxreftitleoff1 refid = "AHRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Desni ležaj predložnog vratila:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Unutarnji prsten: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vanjski prsten: 
<intxreftitleoff1 refid = "AHRAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Lijevi i desni ležaj ulaznog vratila: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Istrošen skošeni zub na ogrlici i zupčaniku
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite sinkron i ogrlicu sinkrona i zupčanik.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Zupčanik 1. i 2. stupnja prijenosa na predložnom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zupčanik 3. i 4. stupnja prijenosa na ulaznom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zupčanik 5. stupnja prijenosa na ulaznom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sinkron i ogrlica sinkrona niskog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sinkron i ogrlica sinkrona visokog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sinkron i ogrlica sinkrona 5. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
