<title>
DTC B1133
</title>
<servinfosub id = "AHRAP70AA204013001">
<title>
Detektirano stanje DTC-a i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.385in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.833in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Detektirano stanje DTC-a
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1133: Previsok napon akumulatora
</emph>
</ptxt>
<ptxt>
Napon kruga pomoćnog napajanja iz &#34;DOME&#34; osigurača neprestano je viši od 16,0 V u određenom vremenu.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Sustav punjenja
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70AA204013002">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pokrenite motor ako je moguće.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA204013003">
<title>
Rješavanje DTC problema
</title>
<diag type = "test" id = "AHRAP70AA204013004">
<testgroup id = "AHRAP70AA204013006">
<title>
Provjera parametara
</title>
<test1>
<ptxt>
Priključite SUZUKI alat za skeniranje na DLC s isključenim kontaktom.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite &#34;Napon akumulatora&#34; prikazan na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204013005">
<title>
Provjera sustava punjenja	 
</title>
<test1>
<ptxt>
Provjerite sustav punjenja. 
<intxreftitleoff1 refid = "AHRAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite BCM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite sustav punjenja.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
