<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9B06022" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stražnje ploče stražnjeg dijela poda
</title>
<attention3>
<ptxt>
Donja slika prikazuje uvjete za uklanjanje sljedećih dijelova.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednji blatobran 
<intxreftitleoff1 refid = "AHRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Stražnja ploča 
<intxreftitleoff1 refid = "AHRAP70A9B06021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0166.jpg" width = "88.000mm" height = "48.926mm" ver = "02" gw = "227" gh = "122"/>
</figure>
<servinfosub id = "AHRAP70A9B06022001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Izbušite zavarene točke i uklonite stražnju ploču stražnjeg dijela poda.
</ptxt>
<attention3>
<ptxt>
Po potrebi savijte oba kraja prirubnice srednje ploče stražnjeg dijela poda, na način da se otvori.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A9B0018.jpg" width = "183.000mm" height = "184.007mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9B06022002">
<title>
Ugradnja
</title>
<attention3>
<ptxt>
Prije zavarivanja, provjerite položaj za ugradnju i uvjete za pravilnu ugradnju dijela (dijelova). 
<intxreftitleoff1 refid = "AHRAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1 page = "1">
<ptxt>
Ugradite nosač rezervne gume i nosač kutije za alat.
</ptxt>
</s1>
<s1 page = "1">
<ptxt>
Provedite elektrootporno točkasto zavarivanje.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0168.jpg" width = "183.000mm" height = "100.573mm" ver = "01" gw = "495" gh = "269"/>
</figure>
</s1>
<s1 page = "1">
<ptxt>
Ugradite stražnju ploču stražnjeg dijela poda.
</ptxt>
<attention3>
<ptxt>
Po potrebi savijte oba kraja prirubnice srednje ploče stražnjeg dijela poda.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Provedite elektrootporno točkasto zavarivanje i kontaktno zavarivanje.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0019.jpg" width = "183.000mm" height = "183.872mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
