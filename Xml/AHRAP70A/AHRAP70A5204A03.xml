<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A5204A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Buka
</title>
<diag type = "condition">
<condition>
<ptxt>
Buka
</ptxt>
</condition>
<ps>
<ptxt>
Neodgovarajuće mazivo ili nedovoljna količina maziva
</ptxt>
</ps>
<action>
<ptxt>
Obnovite ulje ručnog mjenjača.
</ptxt>
</action>
<ps>
<ptxt>
Oštećeni ili istrošeni ležaj(evi)
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite ležaj.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Lijevi ležaj predložnog vratila:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Unutarnji prsten: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vanjski prsten: 
<intxreftitleoff1 refid = "AHRAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Desni ležaj predložnog vratila:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Unutarnji prsten: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vanjski prsten: 
<intxreftitleoff1 refid = "AHRAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Lijevi i desni ležaj ulaznog vratila: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ležaj na strani diferencijala:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Unutarnji prsten: 
<intxreftitleoff1 refid = "AHRAP70A5206025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vanjski prsten na desnoj strani: 
<intxreftitleoff1 refid = "AHRAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vanjski prsten na lijevoj strani: 
<intxreftitleoff1 refid = "AHRAP70A5206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Igličasti ležaj:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Zupčanik 1. i 2. stupnja prijenosa na predložnom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zupčanik 3. i 4. stupnja prijenosa na ulaznom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zupčanik 5. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
</list1>
</action>
<ps>
<ptxt>
Oštećeni ili istrošeni zupčanici
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite zupčanik.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Zupčanik 1., 2., 3. i 4. stupnja prijenosa na predložnom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zupčanik 1., 2., 3. i 4. stupnja prijenosa na ulaznom vratilu: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ulazno vratilo 5. stupnja i predložno vratilo 5. stupnja: 
<intxreftitleoff1 refid = "AHRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Oštećeni ili istrošeni dijelovi sinkrona
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite dijelove sinkrona.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Dijelovi sinkrona niskog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dijelovi sinkrona visokog stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dijelovi sinkrona 5. stupnja prijenosa: 
<intxreftitleoff1 refid = "AHRAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
