<servinfosub id = "AHRAP70A1704004002">
<title>
Rješavanje problema
</title>
<diag type = "test" id = "AHRAP70A1704004003">
<testgroup id = "AHRAP70A1704004004">
<title>
Provjera rada sustava upravljanja pumpe goriva
</title>
<test1>
<ptxt>
Uklonite čep otvora za punjenje goriva.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Potvrdite čuje li se zvuk rada pumpe iz otvora za punjenje goriva oko 2 sekunde i zatim prestane.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Krug pumpe goriva je u dobrom stanju. Postavite čep otvora za punjenje.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704004005">
<title>
Provjera kruga napajanja releja pumpe goriva
</title>
<test1>
<ptxt>
Postavite čep otvora za punjenje.
</ptxt>
</test1>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Uklonite relej pumpe goriva sa zasebne kutije s osiguračem br. 1.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorom releja pumpe goriva.
</ptxt>
</test1>
<test1>
<ptxt>
Ako je u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite odgovara li napon između svakog od krugova “A1” i “A2” i uzemljenja naponu akumulatora. 
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug napajanja releja pumpe goriva.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704004006">
<title>
Provjera releja pumpe goriva
</title>
<test1>
<ptxt>
Provjerite relej pumpe goriva. 
<intxreftitleoff1 refid = "AHRAP70AA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite relej pumpe goriva.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704004007">
<title>
Provjera pogonskog kruga releja pumpe goriva
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektore “C01” i “E01” s ECM-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga “B1”: manji od 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga “B1” i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;B1&#34;: 0 - 1 V (s uključenim kontaktom)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite pogonski krug releja pumpe goriva.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704004008">
<title>
Provjera signala pogonskog kruga releja pumpe goriva
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Spojite konektore “C01” i “E01” na ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Servisnom žicom spojite relej pumpe goriva.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite iznosi li napon između &#34;B1&#34; i uzemljenja 0 - 1 V tijekom 2 sekunde nakon uključivanja kontakta.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite rad pumpe goriva. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704004009">
<title>
Provjera kruga napajanja pumpe goriva
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uklonite spremnik goriva.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor pumpe goriva.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite je li otpor između &#34;B2&#34; i uzemljenja beskonačan.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug napajanja pumpe goriva.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704004010">
<title>
Provjera kruga napajanja pumpe goriva
</title>
<test1>
<ptxt>
Spojite servisnu žicu između &#34;B1&#34; i uzemljenja.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite odgovara li napon između &#34;B2&#34; i uzemljenja naponu akumulatora.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 8. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug napajanja pumpe goriva.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1704004011">
<title>
Provjera kruga uzemljenja pumpe goriva
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite je li otpor između &#34;B3&#34; i uzemljenja manji od 1 Ω.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite pumpu goriva. 
<intxreftitleoff1 refid = "AHRAP70A1706015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug uzemljenja pumpe goriva.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
