<servinfo servinfosgmlid = "AHRAP70A9B06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
(Djelomično) uklanjanje i ugradnja nosača na strani plašta
</title>
<attention3>
<ptxt>
Donja slika prikazuje uvjete za uklanjanje sljedećih dijelova.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednji blatobran 
<intxreftitleoff1 refid = "AHRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nosač brave poklopca prostora motora, vodoravni potporni element svjetla i potporanj nosača svjetla 
<intxreftitleoff1 refid = "AHRAP70A9B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0013.jpg" width = "88.000mm" height = "56.038mm" ver = "01" gw = "227" gh = "142"/>
</figure>
<servinfosub id = "AHRAP70A9B06004001">
<title>
Opće napomene
</title>
<ptxt>
Metoda zavarivanja i broj točaka zavarivanja su jednaki na obje strane. Ove upute za popravljanje prikazuju postupak za lijevu stranu.
</ptxt>
</servinfosub>
<servinfosub id = "AHRAP70A9B06004002">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Izbušite zavarene točke i uklonite gornju ploču nosača prednjeg odbojnika.
</ptxt>
</s1>
<s1>
<ptxt>
Izbušite zavarene točke i uklonite produžetak nosača na strani plašta, vanjski produžetak nosača na strani plašta i donju ploču nosača prednjeg odbojnika.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0014.jpg" width = "183.000mm" height = "219.193mm" ver = "03" gw = "497" gh = "605"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9B06004003">
<title>
Ugradnja
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Prije zavarivanja, provjerite položaj za ugradnju i uvjete za pravilnu ugradnju dijela (dijelova). 
<intxreftitleoff1 refid = "AHRAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AHRAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nastavite s popravkom, imajući na umu ugradnju dijelova koji utječu na izgled vozila. 
<intxreftitleoff1 refid = "AHRAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Ugradite produžetak nosača na strani plašta, vanjski produžetak nosača na strani plašta i donju ploču nosača prednjeg odbojnika.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite kontaktno zavarivanje.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0032.jpg" width = "183.000mm" height = "92.153mm" ver = "02" gw = "497" gh = "245"/>
