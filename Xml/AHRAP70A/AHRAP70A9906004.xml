<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9906004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stakla krovnog prozora
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9906001">Komponente krovnog prozora</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9906004001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Potpuno otvorite zaštitu od sunca (1) i podignite krovni prozor.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990022.swf" width = "88.000mm" height = "43.115mm" ver = "01" gw = "138" gh = "106"/>
</figure>
</s1>
<s1>
<ptxt>
Odspojite negativni (–) kabel s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite staklo krovnog prozora uklanjanjem pričvrsnih vijaka stakla krovnog prozora (TORX<sup>®</sup> T25) (1).
</ptxt>
<figure>
<graphic graphicname = "I5JB0A990003.swf" width = "88.000mm" height = "45.253mm" ver = "01" gw = "185" gh = "112"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9906004002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite pričvrsne vijke stakla krovnog prozora propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Namjestite položaj za ugradnju stakla krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Inicijalizirajte motor krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
