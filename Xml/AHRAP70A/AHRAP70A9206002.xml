<servinfo servinfosgmlid = "AHRAP70A9206002" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Provjera smjera i intenziteta svjetla prednjih svjetala
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Za namještanje smjera prednjeg svjetla, koristite jedan od sljedećih postupaka, osim ako lokalni propisi ne nalažu drugačiji postupak.
</ptxt>
</item>
<item>
<ptxt>
Svakako namjestite usmjerenost prednjih svjetala nakon bilo kojeg od sljedećih servisnih radova.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Zamjena žarulje prednjeg svjetla
</ptxt>
</item>
<item>
<ptxt>
Uklanjanje i ugradnja jedinice prednjih svjetala.
</ptxt>
</item>
</list2>
<item>
<ptxt>
Prilikom provjere i namještanja prednjeg svjetla sa sustavom namještanja razine, prekidač namještanja razine prednjeg svjetla obavezno postavite u položaj “0” uz uključeni kontakt.
</ptxt>
</item>
</list1>
</attention3>
<servinfosub id = "AHRAP70A9206002001">
<title>
Priprema
</title>
<s1>
<ptxt>
Tlak zraka svih guma namjestite na propisanu vrijednost.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sav teret iz vozila.
</ptxt>
</s1>
<s1>
<ptxt>
Neka jedna osoba težine 75 kg (165 lb) sjedne na vozačevo sjedalo.
</ptxt>
</s1>
<s1>
<ptxt>
Pokrenite motor da biste potpuno napunili akumulator.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9206002002">
<title>
Vijci za namještanje smjera
</title>
<ptxt>
Koristite vijke za namještanje smjera kao što je prikazano na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920006.jpg" width = "88.000mm" height = "60.026mm" ver = "01" gw = "207" gh = "154"/>
</figure>
</servinfosub>
<servinfosub id = "AHRAP70A9206002003">
<title>
Postupak za korištenje ispitivača
</title>
<ptxt>
Pratite upute proizvođača ispitivača.
</ptxt>
</servinfosub>
