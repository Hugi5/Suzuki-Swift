<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stražnjeg brisača
</title>
<servinfosub id = "AHRAP70A9406005001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite zaštitu poluge stražnjeg brisača (1), maticu poluge stražnjeg brisača (2), sklop poluge stražnjeg brisača s metlicom (3), poklopac osovine brisača (4), maticu stražnjeg brisača (5) i brtvu stražnjeg brisača (6).
</ptxt>
<figure>
<graphic graphicname = "I9P60A940013.swf" width = "88.000mm" height = "45.733mm" ver = "01" gw = "174" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite oblogu vrata prtljažnika. 
<intxreftitleoff1 refid = "AHRAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite motor stražnjeg brisača.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor (1) s motora stražnjeg brisača pomoću plosnatog odvijača (2), na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "I7V10A940003.swf" width = "88.000mm" height = "79.003mm" ver = "01" gw = "161" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9406005002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9406006">Provjera motora stražnjeg brisača</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijke motora stražnjeg brisača propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9D004">
<t-part>
Vijak motora stražnjeg brisača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I5RW0A940011.swf" width = "88.000mm" height = "56.315mm" ver = "01" gw = "172" gh = "143"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
