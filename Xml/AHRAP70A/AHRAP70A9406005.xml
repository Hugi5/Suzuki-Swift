<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Motor stražnjeg brisača
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Postavite brtvu stražnjeg brisača (1) i zategnite maticu stražnjeg brisača propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9D005">
<t-part>
Matica stražnjeg brisača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,3
</t-value1>
<t-value2>
0,54
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940014.swf" width = "88.000mm" height = "34.877mm" ver = "02" gw = "116" gh = "82"/>
