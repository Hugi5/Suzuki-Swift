<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A5304A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vibracije spojke
</title>
<diag type = "condition">
<condition>
<ptxt>
Vibracije spojke
</ptxt>
</condition>
<ps>
<ptxt>
Uglačane (kao staklo) obloge spojke
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite disk spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Obloge spojke zaprljane uljem
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite disk spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Potisni ležaj ne pomiče se glatko
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop radnog cilindra spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformiran disk spojke, ili slab kontakt obloga
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite disk spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Oslabljene zavojne opruge u disku spojke
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite disk spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Olabavljene zakovice diska spojke
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite disk spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformirana potisna ploča ili površina zamašnjaka
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite spojku, poklopac ili zamašnjak.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Disk i poklopac spojke: 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zamašnjak: 
<intxreftitleoff1 refid = "AHRAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Oslabljen nosač motora ili otpušteni pričvrsni vijci i/ili matice motora
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite nosač motora ili ponovo zategnite pričvrsne vijke i/ili matice motora. 
<intxreftitleoff1 refid = "AHRAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
