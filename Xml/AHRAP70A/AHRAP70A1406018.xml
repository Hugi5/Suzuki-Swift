<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1406018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Postavljanje i uklanjanje poklopca lanca razvodnog mehanizma
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1406017">Komponente poklopca lanca razvodnog mehanizma</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Tijekom pregleda držite radni stol, alat i ruke čistima.
</ptxt>
</item>
<item>
<ptxt>
Pažljivo rukujte aluminijskim dijelovima da ih ne biste oštetili.
</ptxt>
</item>
<item>
<ptxt>
Ne izlažite uklonjene dijelove prašini. Neka budu uvijek čisti.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AHRAP70A1406018001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite sklop motora s vozila. 
<intxreftitleoff1 refid = "AHRAP70A1406016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite pogonski remen pumpe vode/generatora. 
<intxreftitleoff1 refid = "AHRAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijak remenice koljenastog vratila.
</ptxt>
<ptxt>
Da biste učvrstili remenicu koljenastog vratila (1), koristite specijalan alat prikazan na slici.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Koristite specijalni alat da biste spriječili nepotrebno opterećenje lanca razvodnog mehanizma, lančanika i ostalih povezanih dijelova.
</ptxt>
</item>
<item>
<ptxt>
Koristite dolje navedene vijke za postavljanje specijalnog alata na remenicu koljenastog vratila.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Pričvrsni vijak za specijalni alat
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.722in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.722in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Veličina vijka
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
M8
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Korak
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
1,25 mm (0,05 in)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Duljina &#34;a&#34;
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
25 mm (0,98 in)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Čvrstoća
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
7T
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</attention2>
<attention3>
<ptxt>
Upotrijebite specijalni alat s kojeg ćete ukloniti zatike ako je potrebno.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1D010">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917-68221
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141049.swf" width = "88.000mm" height = "49.174mm" ver = "01" gw = "163" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite remenicu koljenastog vratila (1).
</ptxt>
<ptxt>
Ako ju je teško izvaditi, upotrijebite specijalan alat kao što je prikazano na slici.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D011">
<s-part>
(A)
</s-part>
<s-number num = "09926-37610-001">
09926-37610-001
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L1D012">
<s-part>
(B)
</s-part>
<s-number num = "09926-58010">
09926-58010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B140052.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "170" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite poklopac glave motora. 
<intxreftitleoff1 refid = "AHRAP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite korito ulja. 
<intxreftitleoff1 refid = "AHRAP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite remenicu pumpe vode.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke poklopca lanca razvodnog mehanizma, a zatim poklopac lanca razvodnog mehanizma.
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite brtvu ulja koljenastog vratila od poklopca lanca razvodnog mehanizma plosnatim odvijačem ili sličnim alatom, ako je potrebno.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite OCV s poklopca lanca razvodnog mehanizma ako je potrebno. 
<intxreftitleoff1 refid = "AHRAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rastavite poklopac lanca razvodnog mehanizma i pumpu ulja ako je potrebno. 
<intxreftitleoff1 refid = "AHRAP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1406018002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1406019">Provjera poklopca lanca razvodnog mehanizma</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Očistite površinu za brtvljenje na poklopcu lanca razvodnog mehanizma, bloku motora i glavi motora.
</ptxt>
<ptxt>
Uklonite ulje, staro brtvilo i prašinu s površine za brtvljenje.
</ptxt>
</s1>
<s1>
<ptxt>
Ponovo sastavite poklopac lanca razvodnog mehanizma i pumpu ulja ako ste ih uklonili. 
<intxreftitleoff1 refid = "AHRAP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
 Ugradite OCV ako ste ga uklonili. 
<intxreftitleoff1 refid = "AHRAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pregledajte ima li oštećenja ili neispravnosti na obodu brtve ulja (1).
</ptxt>
<ptxt>
Zamijenite brtvu ulja ako je potrebno.
</ptxt>
<attention3>
<ptxt>
Prilikom postavljanja nove brtve ulja, pritisnite je na poklopac lanca razvodnog mehanizma (2) pomoću specijalnog alata (A) kao što je prikazano na slici.
</ptxt>
</attention3>
<spec>
<title>
Dubina
</title>
<ptxt>
“a”: 1,5 mm (0,06 in)
</ptxt>
</spec>
<servicetool>
<servicetoolitem id = "L1D013">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913-75810
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141050.swf" width = "88.000mm" height = "52.484mm" ver = "01" gw = "179" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite novi O prsten (1) na pumpu ulja (2).
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite novu brtvu (3) na poklopac lanca razvodnog mehanizma (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141055.jpg" width = "88.000mm" height = "67.189mm" ver = "01" gw = "144" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite cilindrične zatike (1) na blok motora ako ste ih uklonili.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141056.swf" width = "88.000mm" height = "58.478mm" ver = "01" gw = "131" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Nanesite brtvilo &#34;A&#34; na dodirne površine cilindra i bloka motora, a brtvilo &#34;B&#34; na dodirne površine poklopca lanca razvodnog mehanizma kao što je prikazano na slici.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207B" id = "M1D002" uid = "29">
<m-part>
“A”
</m-part>
<m-desc>
Brtvilo
</m-desc>
<m-number>
99000-31140
</m-number>
<m-name>
SUZUKI Bond br.1207B
</m-name>
</materialitem>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1D003" uid = "-491504098">
<m-part>
“B”
</m-part>
<m-desc>
Brtvilo
</m-desc>
<m-number>
99000-31260
</m-number>
<m-name>
SUZUKI Bond br.1217G
</m-name>
</materialitem>
</materials>
<spec>
<title>
Količina brtvila za poklopac lanca razvodnog mehanizma
</title>
<ptxt>
Širina &#34;a&#34;: 3 mm (0,12 in)
</ptxt>
<ptxt>
Visina &#34;b&#34;: 2 mm (0,08 in)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A141057.jpg" width = "88.000mm" height = "49.092mm" ver = "01" gw = "220" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Nanesite ulje motora na rubove brtve ulja, a zatim postavite poklopac lanca razvodnog mehanizma (1). Postepeno pritegnite vijke redoslijedom od &#34;1&#34; do &#34;15&#34; propisanim momentom pritezanja.
</ptxt>
<attention3>
<ptxt>
Prije postavljanja poklopca lanca razvodnog mehanizma provjerite je li zatik dobro učvršćen.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1D011">
<t-part>
Vijak poklopca lanca razvodnog mehanizma
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141058.jpg" width = "88.000mm" height = "72.952mm" ver = "01" gw = "169" gh = "190"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite remenicu pumpe vode.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite poklopac glave motora. 
<intxreftitleoff1 refid = "AHRAP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite korito ulja. 
<intxreftitleoff1 refid = "AHRAP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Postavite remenicu koljenastog vratila (1). Pritegnite vijak remenice koljenastog vratila propisanim momentom pritezanja. Da biste zaglavili remenicu koljenastog vratila, koristite specijalan alat prikazan na slici.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Koristite specijalni alat da biste spriječili nepotrebno opterećenje lanca razvodnog mehanizma, lančanika i ostalih povezanih dijelova.
</ptxt>
</item>
<item>
<ptxt>
Koristite dolje navedene vijke za postavljanje specijalnog alata na remenicu koljenastog vratila.
</ptxt>
</item>
</list1>
