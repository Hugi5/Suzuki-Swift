<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa ventilatora hlađenja hladnjaka
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1606010">Pregled sklopa ventilatora hlađenja hladnjaka na vozilu</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1606012001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Ispustite rashladnu tekućinu. 
<intxreftitleoff1 refid = "AHRAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor (1) motora ventilatora hlađenja hladnjaka.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite spremnik (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite ulazno crijevo hladnjaka (3) s hladnjaka.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160005.swf" width = "88.000mm" height = "70.920mm" ver = "01" gw = "221" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Odvojite sklop ventilatora hlađenja hladnjaka od hladnjaka.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A1606012002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Dolijte rashladnu tekućinu u rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Provjerite propušta li rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
