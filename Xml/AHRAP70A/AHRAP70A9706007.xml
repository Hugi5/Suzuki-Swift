<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9706007" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stražnjeg sjedala
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9706006">Komponente stražnjeg sjedala</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9706007001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite sklop jastuka stražnjeg sjedala. 
<intxreftitleoff1 refid = "AHRAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sklopove naslona stražnjeg sjedala uklanjanjem vijaka šarke stražnjeg sjedala. 
<intxreftitleoff1 refid = "AHRAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Po potrebi rastavite i popravite stražnje sjedalo. 
<intxreftitleoff1 refid = "AHRAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9706007002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Za propisani moment pritezanja pogledajte 
<intxref refid = "AHRAP70A9706006">Komponente stražnjeg sjedala</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
