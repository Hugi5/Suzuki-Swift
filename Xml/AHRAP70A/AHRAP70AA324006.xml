<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70AA324006" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1610
</title>
<servinfosub id = "AHRAP70AA324006001">
<title>
Detektirano DTC stanje i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.281in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.924in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Detektirano DTC stanje
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1610: Neregistriran ID blokade motora
</emph>
</ptxt>
<ptxt>
ID blokade motora kod nije registriran.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ID kod ECM-a nije registriran u upravljački modul sustava pokretanja bez ključa
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Konektor/strujni krug CAN komunikacije
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul spojen s CAN komunikacijskom linijom
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70AA324006002">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70AA324006003">
<testgroup id = "AHRAP70AA324006005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC u upravljačkom modulu sustava pokretanja bez ključa. 
<intxreftitleoff1 refid = "AHRAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li otkriveni DTC B1173, B1175 ili B1176?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324006004">
<title>
Registracija ECM-a
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA326003">Registracija u ECM:Model sa sustavom pokretanja pritiskom prekidača, bez ključa</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se DTC P1610 i dalje?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (ECM nije registriran)
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324006006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC povezan s CAN komunikacijom.
</ptxt>
</test1>
<question>
Postoje li DTC-ovi koji se odnose na CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
