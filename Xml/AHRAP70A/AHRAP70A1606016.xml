<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1606016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja pumpe vode
</title>
<servinfosub id = "AHRAP70A1606016001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Ispustite rashladnu tekućinu. 
<intxreftitleoff1 refid = "AHRAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite pogonski remen pumpe vode/generatora. 
<intxreftitleoff1 refid = "AHRAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite remenicu pumpe vode (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sklop pumpe vode (1) s nosačem generatora (3).
</ptxt>
<figure>
<graphic graphicname = "I7V20A161014.swf" width = "88.000mm" height = "66.198mm" ver = "01" gw = "211" gh = "171"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A1606016002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1606017">Pregled pumpe vode</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Nanesite brtvilo na dodirnu površinu pumpe vode kao što je prikazano na slici.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1F001" uid = "41">
<m-part>
“A”
</m-part>
<m-desc>
Brtvilo
</m-desc>
<m-number>
99000-31250
</m-number>
<m-name>
SUZUKI Bond br.1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I7V20A161015.swf" width = "88.000mm" height = "43.075mm" ver = "01" gw = "184" gh = "106"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.309in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.250in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.387in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
3 mm (0,12 in)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“b”:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
2 mm (0,08 in)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Postavite sklop pumpe vode (1) s nosačem generatora (3) na glavu motora i zategnite vijke i matice propisanim momentom pritezanja.
</ptxt>
<attention3>
<ptxt>
Za proceduru ugradnje nosača generatora (3) pogledajte 
<intxref refid = "AHRAP70A1A06006">Uklanjanje i ugradnja nosača generatora</intxref>
.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1F003">
<t-part>
Vijak i matica pumpe vode
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Namjestite remenicu pumpe vode (2) i pritegnite vijke propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1F004">
<t-part>
Vijak remenice pumpe vode
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A161016.swf" width = "88.000mm" height = "66.198mm" ver = "02" gw = "211" gh = "171"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite pogonski remen pumpe vode/generatora. 
<intxreftitleoff1 refid = "AHRAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Spojite negativni kabel (–) na akumulator.
</ptxt>
</s1>
<s1>
<ptxt>
Dolijte rashladnu tekućinu u rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite propušta li rashladni sustav. 
<intxreftitleoff1 refid = "AHRAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
