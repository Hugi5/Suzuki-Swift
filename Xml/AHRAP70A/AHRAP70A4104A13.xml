<title>
Svjetlo upozorenja kočnice ostaje uključeno (dulje od 2 sekunde) nakon pokretanja motora
</title>
<diag type = "condition">
<condition>
<ptxt>
Svjetlo upozorenja kočnice ostaje uključeno (dulje od 2 sekunde) nakon pokretanja motora
</ptxt>
</condition>
<ps>
<ptxt>
Konektor upravljačkog modula ESP<sup>®</sup>-a nije dobro spojen
</ptxt>
</ps>
<action>
<ptxt>
Ponovo spojite konektor upravljačkog modula ESP<sup>®</sup>-a.
</ptxt>
</action>
<ps>
<ptxt>
Parkirna kočnica je zategnuta
</ptxt>
</ps>
<action>
<ptxt>
Otpustite parkirnu kočnicu i provjerite gasi li se svjetlo upozorenja.
</ptxt>
</action>
<ps>
<ptxt>
Nedovoljna količina kočne tekućine
</ptxt>
</ps>
<action>
<ptxt>
Provjera razine kočne tekućine. 
<intxreftitleoff1 refid = "AHRAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Svjetlo upozorenja ABS-a treperi
</ptxt>
</ps>
<action>
<ptxt>
Pronađite mjesto kvara i popravite. 
<intxreftitleoff1 refid = "AHRAP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan prekidač parkirne kočnice i/ili prekidač razine kočne tekućine
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Provjerite prekidač parkirne kočnice i/ili prekidač razine kočne tekućine.
</ptxt>
<ptxt>
Prekidač parkirne kočnice: 
<intxreftitleoff1 refid = "AHRAP70A4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Prekidač razine kočne tekućine: 
<intxreftitleoff1 refid = "AHRAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Neispravan rad sustava CAN komunikacije
</ptxt>
</ps>
<action>
<ptxt>
Provjerite sustav CAN komunikacije. 
<intxreftitleoff1 refid = "AHRAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kombinirani mjerač u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite kombinirani mjerač. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hidraulički uređaj / upravljački modul ESP<sup>®</sup>-a u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite hidraulički uređaj / upravljački modul ESP<sup>®</sup>-a. 
<intxreftitleoff1 refid = "AHRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
