<servinfosub id = "AHRAP70A1804001002">
<title>
Rješavanje problema
</title>
<diag type = "test" id = "AHRAP70A1804001003">
<testgroup id = "AHRAP70A1804001004">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1804001005">
<title>
Provjera svjećica paljenja 1
</title>
<test1>
<ptxt>
Izvedite provjeru paljenja svjećica. 
<intxreftitleoff1 refid = "AHRAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1804001006">
<title>
Provjera kuta paljenja
</title>
<test1>
<ptxt>
Provjerite kut paljenja. 
<intxreftitleoff1 refid = "AHRAP70A1806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustav paljenja je u dobrom stanju.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1804001007">
<title>
Potvrda neispravnog cilindra
</title>
<test1>
<ptxt>
Potvrdite neispravni cilindar ili više njih u testu paljenja svjećica.
</ptxt>
</test1>
<question>
Jesu li svi cilindri?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1804001008">
<title>
Provjera svjećica paljenja 2
</title>
<test1>
<ptxt>
Zamijenite svjećicu svakog neispravnog cilindra svjećicom cilindra koji radi.
</ptxt>
</test1>
<test1>
<ptxt>
Izvedite provjeru paljenja svjećica. 
<intxreftitleoff1 refid = "AHRAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite svjećicu. 
<intxreftitleoff1 refid = "AHRAP70A1806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1804001009">
<title>
Provjera svjećica paljenja 3
</title>
<test1>
<ptxt>
Zamijenite indukcijsku zavojnicu svakog neispravnog cilindra zavojnicom cilindra koji radi.
</ptxt>
</test1>
<test1>
<ptxt>
Izvedite provjeru paljenja svjećica. 
<intxreftitleoff1 refid = "AHRAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite indukcijsku zavojnicu. 
<intxreftitleoff1 refid = "AHRAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Idite na 7. korak.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AHRAP70A1804001010">
<title>
Provjera strujnog kruga uzemljenja i napajanja sklopa indukcijske zavojnice 
</title>
<test1>
<ptxt>
S isključenom kontakt bravom odspojite konektore “C01” i “E01” ECM-a i konektore indukcijske zavojnice.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima indukcijske zavojnice.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova “A1”, “A2”, “A3”, “A4”, “C1”, “C2”, “C3” i “C4”: manje od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova “A1”, “A2”, “A3”, “A4”, “C1”, “C2”, “C3” i “C4” i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i drugog terminala na konektoru indukcijske zavojnice: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A2&#34; i drugog terminala na konektoru indukcijske zavojnice: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A3&#34; i drugog terminala na konektoru indukcijske zavojnice: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A4&#34; i drugog terminala na konektoru indukcijske zavojnice: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova “A1”, “A2”, “A3”, “A4”, “C1”, “C2”, “C3” i “C4”: 0 do 1 V (s uključenim kontaktom)
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li rezultati provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 8. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1804001011">
<title>
Provjera pogonskih krugova sklopa indukcijske zavojnice
</title>
<test1>
<ptxt>
Kada je kontakt isključen, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova “B1”, “B2”, “B3” i “B4”: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova “B1”, “B2”, “B3” i “B4” i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B1&#34; i drugog terminala na konektoru indukcijske zavojnice: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B2&#34; i drugog terminala na konektoru indukcijske zavojnice: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B3&#34; i drugog terminala na konektoru indukcijske zavojnice: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B4&#34; i drugog terminala na konektoru indukcijske zavojnice: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova “B1”, “B2”, “B3” i “B4”: 0 do 1 V (s uključenim kontaktom)
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li rezultati provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 9. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1804001012">
