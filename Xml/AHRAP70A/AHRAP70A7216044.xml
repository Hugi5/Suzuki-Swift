<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7216044" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Ugradnja i uklanjanje dijela za isušivanje
</title>
<servinfosub id = "AHRAP70A7216044001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Obnovite rashladno sredstvo iz sustava klima uređaja prema uputama pod naslovom “Obnavljanje” u poglavlju 
<intxref refid = "AHRAP70A7216001">Procedura za punjenje rashladnog sredstva:Ručni tip</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite prednji odbojnik. 
<intxreftitleoff1 refid = "AHRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite učvršćenje nosača prednjeg odbojnika i donji amortizer prednjeg odbojnika. 
<intxreftitleoff1 refid = "AHRAP70A9806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite čep filtra (1) s prijamnika (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sredstvo za isušivanje (3) i O-prstenove (4).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A721037.swf" width = "88.000mm" height = "45.459mm" ver = "01" gw = "210" gh = "112"/>
</figure>
</servinfosub>
<servinfosub id = "AHRAP70A7216044002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ne uklanjajte sredstvo za isušivanje iz plastične vrećice prije nego što ga trebate umetnuti u prijamnik.
</ptxt>
</item>
<item>
<ptxt>
Postavite novo sredstvo za isušivanje, novi O-prsten i novi čep filtra.
</ptxt>
</item>
<item>
<ptxt>
Nanesite propisano ulje kompresora na O-prsten.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B103" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Ulje kompresora
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Pritegnite čep filtra propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T7B101">
<t-part>
Poklopac filtra
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
18
</t-value1>
<t-value2>
1,84
</t-value2>
<t-value3>
1,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Odzračite i napunite sustav klima uređaja prema uputama u odlomcima “Odzračivanje” i “Punjenje” u poglavlju 
<intxref refid = "AHRAP70A7216001">Procedura za punjenje rashladnog sredstva:Ručni tip</intxref>
.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A721038.swf" width = "88.000mm" height = "40.160mm" ver = "01" gw = "172" gh = "97"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
