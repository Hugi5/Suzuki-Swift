<servinfo servinfosgmlid = "AHRAP70AA506007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja srednje unutrašnje antene
</title>
<servinfosub id = "AHRAP70AA506007001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite kutiju centralne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor (1), te zatim uklonite srednju unutrašnju antenu (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50026.swf" width = "88.000mm" height = "59.622mm" ver = "01" gw = "196" gh = "153"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA506007002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70AA506010">Pregled antene</intxrefpoff>
</ptxt>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
