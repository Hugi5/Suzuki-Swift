<servinfosub id = "AHRAP70AA324014002">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70AA324014003">
<testgroup id = "AHRAP70AA324014004">
<title>
Provjera DTC-a
</title>
<question>
Jesu li detektirani DTC-i osim B1169?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324014005">
<title>
Registracija ECM-a
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA326003">Registracija u ECM:Model sa sustavom pokretanja pritiskom prekidača, bez ključa</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Potvrdite da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC B1169?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
