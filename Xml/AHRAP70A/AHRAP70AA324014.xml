<emph etype = "bold">
B1169: Greška pri registraciji
</emph>
</ptxt>
<ptxt>
Registracijska pogreška ECM-a ili daljinskog upravljača.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Konektor / strujni krug napajanja
</ptxt>
</item>
<item>
<ptxt>
Konektor/strujni krug CAN komunikacije
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul sustava pokretanja bez ključa
</ptxt>
</item>
