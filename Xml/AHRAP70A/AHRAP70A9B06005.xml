<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9B06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja vanjskog nosača na strani poprečnog veznog lima
</title>
<attention3>
<ptxt>
Donja slika prikazuje uvjete za uklanjanje sljedećih dijelova.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednji blatobran 
<intxreftitleoff1 refid = "AHRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nosač brave poklopca prostora motora, vodoravni potporni element svjetla i potporanj nosača svjetla 
<intxreftitleoff1 refid = "AHRAP70A9B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0015.jpg" width = "88.000mm" height = "56.208mm" ver = "01" gw = "227" gh = "143"/>
</figure>
<servinfosub id = "AHRAP70A9B06005001">
<title>
Opće napomene
</title>
<ptxt>
Metoda zavarivanja i broj točaka zavarivanja su jednaki na obje strane. Ove upute za popravljanje prikazuju postupak za lijevu stranu.
</ptxt>
</servinfosub>
<servinfosub id = "AHRAP70A9B06005002">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odvijte 2 vijaka.
</ptxt>
</s1>
<s1>
<ptxt>
Izbušite zavarene točke i uklonite vanjski nosač na strani poprečnog veznog lima.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0016.jpg" width = "183.000mm" height = "131.732mm" ver = "02" gw = "438" gh = "357"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.317in"/>
<colspec colnum = "2" colname = "2" colwidth = "6.887in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Ovaj simbol pokazuje da se vanjski nosač na strani poprečnog veznog lima i prednja ploča na strani poprečne pregrade zamjenjuju istovremeno.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9B06005003">
<title>
Ugradnja
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Prije zavarivanja, provjerite položaj za ugradnju i uvjete za pravilnu ugradnju dijela (dijelova). 
<intxreftitleoff1 refid = "AHRAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nastavite s popravkom, imajući na umu ugradnju dijelova koji utječu na izgled vozila. 
<intxreftitleoff1 refid = "AHRAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Ugradite vanjski nosač na strani poprečnog veznog lima, privremeno pritegnite 2 vijka te prilagodite položaj.
</ptxt>
</s1>
<s1>
<ptxt>
Provedite elektrootporno točkasto zavarivanje i kontaktno zavarivanje.
</ptxt>
</s1>
<s1>
<ptxt>
Pritegnite 2 vijaka propisanim momentom pritezanja.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0017.jpg" width = "183.000mm" height = "131.732mm" ver = "03" gw = "438" gh = "357"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.490in"/>
<colspec colnum = "2" colname = "2" colwidth = "6.715in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Ovaj simbol pokazuje da se vanjski nosač na strani poprečnog veznog lima i prednja ploča na strani poprečne pregrade zamjenjuju istovremeno.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
 :
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
23 N&#183;m (2,3 kgf-m, 17,0 lbf-ft)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
