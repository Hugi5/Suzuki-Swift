<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0458: Niski napon strujnog kruga upravljačkog ventila sustava pražnjenja para
</emph>
</ptxt>
<ptxt>
Upravljački krug ventila pražnjenja EVAP spremnika u kratkom je spoju s uzemljenjem dok motor radi.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0459: Visoki napon strujnog kruga upravljačkog ventila sustava pražnjenja para
</emph>
</ptxt>
<ptxt>
Upravljački krug ventila pražnjenja EVAP spremnika u kratkom je spoju s napajanjem dok motor radi.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
