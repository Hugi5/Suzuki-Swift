<servinfosub id = "AHRAP70AA504025003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pokrenite motor.
</ptxt>
</s1>
<s1>
<ptxt>
Isključite motor.
</ptxt>
</s1>
<s1>
<ptxt>
Ponovite jednom korake 1 i 2.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA504025004">
<title>
Rješavanje problema DTC-a
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Ovaj DTC može se detektirati kada je baterija prazna ili je napon vrlo nizak.
</ptxt>
</item>
<item>
<ptxt>
Kada izvršavate &#34;Provjeru parametra&#34;, pritisnite prekidač motora 3 sekunde ili više.
</ptxt>
</item>
</list1>
</attention3>
<diag type = "test" id = "AHRAP70AA504025005">
<testgroup id = "AHRAP70AA504025006">
<title>
Provjera DTC-a
</title>
<question>
Je li istovremeno prikazan DTC B1125?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504025010">
<title>
Provjera parametara
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite &#34;Relej elektropokretača&#34; prikazan na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504025007">
<title>
Provjera osigurača
</title>
<test1>
<ptxt>
Provjerite “ST” i &#34;ST SIG&#34; osigurače.
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite “ST” i/ili &#34;ST SIG&#34; osigurače.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504025008">
<title>
Provjera upravljačkog releja motora pokretača
</title>
<test1>
<ptxt>
Provjerite upravljački releja elektropokretača. 
<intxreftitleoff1 refid = "AHRAP70AA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite kontrolni relej elektropokretača.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504025009">
<title>
Provjera signalnog kruga upravljačkog releja motora pokretača
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektore “C01”, “E01”, “E25” i konektore elektropokretača.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala na konektorima &#34;C01&#34;, &#34;E01&#34; i &#34;E25&#34; i konektorima elektropokretača.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu provjerite sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;A1&#34; i &#34;A2&#34;: manji od 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova &#34;A1&#34; i &#34;A2&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i svakog terminala na konektoru upravljačkog releja elektropokretača: beskonačan
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504025011">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Spojite konektor &#34;L10&#34; i ugradite upravljački relej elektropokretača.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li detektiran trenutni DTC B1194?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
