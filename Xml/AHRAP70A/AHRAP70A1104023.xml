<servinfosub id = "AHRAP70A1104023003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Uključite kontakt na 10 s.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104023004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104023005">
<testgroup id = "AHRAP70A1104023006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104023007">
<title>
Provjera kruga signala i kruga uzemljenja ECT senzora
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a i konektor ECT senzora.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala na konektorima &#34;C01&#34; i &#34;E01&#34; te konektoru ECT senzora.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;A1&#34; i &#34;A2&#34;: manji od 1Ω
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova &#34;A1&#34; i &#34;A2&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i drugih terminala konektora ECT senzora: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova &#34;A1&#34; i &#34;A2&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104023008">
<title>
Provjera ECT senzora
</title>
<test1>
<ptxt>
Provjerite ECT senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ECT senzor.
</ptxt>
</action>
</testgroup>
</diag>
