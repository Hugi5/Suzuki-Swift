<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A9604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ne mogu se zaključati/otključati sva vrata
</title>
<diag type = "condition">
<condition>
<ptxt>
Ne mogu se zaključati/otključati sva vrata
</ptxt>
</condition>
<ps>
<ptxt>
Neispravan BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Pogledajte “Inspection of BCM and Its Circuits” (“Pregled BCM-a i njegovih strujnih krugova”) u odjeljku 10B.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Model s kontakt bravom: 
<intxreftitleoff1 refid = "AHRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model sa sustavom pokretanja pritiskom bez ključa: 
<intxreftitleoff1 refid = "AHRAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Neispravan upravljački modul pokretanja bez ključa (model sa sustavom pokretanja pritiskom bez ključa)
</ptxt>
</ps>
<action>
<ptxt>
Pogledajte pod naslovom 
<intxref refid = "AHRAP70AA504031">Provjera upravljačkog modula sustava pokretanja bez ključa i njegovih strujnih krugova</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan krug sustava (uključujući releje i osigurače)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Neispravan prekidač električne brave vrata
</ptxt>
</ps>
<action>
<ptxt>
Pogledajte pod naslovom 
<intxref refid = "AHRAP70A9606009">Provjera prekidača električne brave vrata</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan cilindar brave
</ptxt>
</ps>
<action>
<ptxt>
Provjerite cilindar brave. 
<intxreftitleoff1 refid = "AHRAP70A9606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
