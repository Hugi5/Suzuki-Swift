<servinfo servinfosgmlid = "AHRAP70A9506022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja ogledala na vratima
</title>
<servinfosub id = "AHRAP70A9506022001">
<title>
Uklanjanje
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9506021">Pregled elekktrično podesivog ogledala na vratima i grijača ogledala na vozilu</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Uklonite unutarnju oblogu nosača okvira stakla. 
<intxreftitleoff1 refid = "AHRAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Za model s električno podesivim ogledalom na vratima uklonite oblogu prednjih vrata. 
<intxreftitleoff1 refid = "AHRAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Za model s električno podesivim ogledalom na vratima odspojite konektor ogledala (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite matice ogledala na vratima (2), a zatim uklonite staklo vrata (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950056.jpg" width = "88.000mm" height = "64.314mm" ver = "01" gw = "219" gh = "166"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9506022002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite rad ogledala na vratima nakon ugradnje.
</ptxt>
</item>
<item>
<ptxt>
Pritegnite matice vrata ogledala (“1” do “3”) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9E007">
<t-part>
Matica ogledala na vratima*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950057.jpg" width = "88.000mm" height = "63.396mm" ver = "01" gw = "225" gh = "163"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
