<servinfo servinfosgmlid = "AHRAP70A3406002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i postavljanje kardanskog vratila
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3406001">Komponente kardanskog vratila</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A3406002001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Podignite vozilo.
</ptxt>
</s1>
<s1>
<ptxt>
Prije uklanjanja kardanskog vratila, označite mjesta (1) na prirubnici zgloba i kardanskom vratilu kao što je prikazano.
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite kardansko vratilo br. 2 (2) s prirubnice stražnjeg diferencijala.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite kardansko vratilo br. 1 (3) s izlazne prirubnice međumjenjača.
</ptxt>
<figure>
<graphic graphicname = "IAP70A340002.swf" width = "88.000mm" height = "64.119mm" ver = "01" gw = "182" gh = "165"/>
</figure>
<figure>
<graphic graphicname = "IAP70A340003.swf" width = "88.000mm" height = "55.013mm" ver = "01" gw = "176" gh = "139"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite potporne nosače središnjeg ležaja kardanskog vratila (1) iz karoserije vozila.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Nosači i kardansko vratilo uklanjaju se odjednom, bez odvajanja.
</ptxt>
</item>
<item>
<ptxt>
Pazite da ga ne ispustite.
</ptxt>
</item>
<item>
<ptxt>
Pazite da ne oštetite manžete spoja.
</ptxt>
</item>
<item>
<ptxt>
Pazite da ne oštetite brtvu ulja križnog zgloba.
</ptxt>
</item>
</list1>
</attention2>
<figure>
<graphic graphicname = "IAP70A340004.swf" width = "88.000mm" height = "53.517mm" ver = "01" gw = "207" gh = "135"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
