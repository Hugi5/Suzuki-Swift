</servinfosub>
<servinfosub id = "AHRAP70AA324009002">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70AA324009003">
<testgroup id = "AHRAP70AA324009004">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC povezan s CAN komunikacijom.
</ptxt>
</test1>
<question>
Postoje li DTC-ovi koji se odnose na CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324009005">
<title>
Provjera strujnog kruga CAN komunikacije
</title>
<test1>
<ptxt>
Provjerite krug CAN komunikacije prema uputama u &#34;Postupku dijagnostike&#34; u 
<intxref refid = "AHRAP70AA804004">Rješavanje problema isključene sabirnice komunikacije</intxref>
.
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. Ako se i dalje detektira DTC P1642, zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul sustava pokretanja bez ključa: 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
