</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1642: Pogreška u komunikacijskoj liniji blokade motora
</emph>
</ptxt>
<ptxt>
Komunikacijska greška s upravljačkim modulom sustava pokretanja bez ključa.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Konektor/strujni krug CAN komunikacije
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Upravljački modul spojen s CAN komunikacijskom linijom
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Upravljački modul sustava pokretanja bez ključa
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
