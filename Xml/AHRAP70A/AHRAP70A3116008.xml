<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3116008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja glavčine prednjeg kotača, kutne poluge i ležaja kotača
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3116006">Dijelovi glavčine prednjeg kotača i kutne poluge:Sprijeda</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Prilikom uklanjanja i ugradnje sklopa kutne poluge, pazite da ne oštetite poklopac za prašinu prednje kočnice zgloba ramena ovjesa.
</ptxt>
</attention2>
<servinfosub id = "AHRAP70A3116008001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Podignite vozilo i uklonite prednji kotač. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite maticu pogonskog vratila. 
<intxreftitleoff1 refid = "AHRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite disk kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Glavčinu kotača (1) izvucite van specijalnim alatom.
</ptxt>
<attention3>
<ptxt>
Vanjska strana unutarnjeg prstena ležaja kotača izlazi zajedno s glavčinom kotača.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3A103">
<s-part>
(A)
</s-part>
<s-number num = "09943-17912">
09943-17912
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A104">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942-15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311016.swf" width = "88.000mm" height = "57.642mm" ver = "01" gw = "181" gh = "147"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Odvojite krajnik spone od kutne poluge upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite senzor brzine prednjih kotača s kutne poluge. 
<intxreftitleoff1 refid = "AHRAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite matice i vijke nosača opružne noge. 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite zglob ramena ovjesa s kutne poluge. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite kutnu polugu s pogonskog vratila.
</ptxt>
</s1>
<s1>
<ptxt>
Dlijetom ili sličnim alatom odstranite brtvu (1) na 4 mjesta.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac za prašinu prednje kočnice (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A311015.swf" width = "88.000mm" height = "63.961mm" ver = "01" gw = "187" gh = "165"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Uklonite uskočnik (1) s kutne poluge.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Pomoću hidraulične preše (1) i specijalnog alata izgurajte ležaj kotača.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A105">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913-75810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A106">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A311017.swf" width = "88.000mm" height = "46.725mm" ver = "01" gw = "99" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Dlijetom ili sličnim alatom malo rastvorite unutarnji prsten s vanjske strane ležaja kotača (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite unutarnji prsten s vanjske strane ležaja kotača (1) s glavčine kotača pomoću specijalnog alata prikazanog na slici.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A107">
<s-part>
(A)
</s-part>
<s-number num = "09913-65810">
09913-65810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A108">
<s-part>
(B)
</s-part>
<s-number num = "09926-37610-003">
09926-37610-003
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311020.swf" width = "88.000mm" height = "78.517mm" ver = "01" gw = "104" gh = "206"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vijke glavčine (1) bakrenim čekićem ili hidrauličkom prešom, ako je potrebno.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A220020.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "166" gh = "128"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A3116008002">
<title>
Ugradnja
</title>
<s1>
<ptxt>
Umetnite novi vijak glavine (1) u provrt glavine. Polako zakrenite vijak glavčine da biste se uvjerili da su ozubljenja poravnata s onima na originalnom vijku, ako je uklonjen.
</ptxt>
<figure>
<graphic graphicname = "I2RH01220040.swf" width = "88.000mm" height = "47.317mm" ver = "01" gw = "142" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Stavite novi ležaj kotača (1) na nosač rukavca (2) sa stranom smeđe brtve (3) prema gore, kao što je prikazano.
</ptxt>
</s1>
<s1>
<ptxt>
Utisnite ležaj kotača u kutnu polugu upravljača (2) upotrebom specijalnih alata kao što je prikazano na slici.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A109">
<s-part>
(A)
</s-part>
<s-number num = "09913-75510">
09913-75510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A110">
<s-part>
(B)
</s-part>
<s-number num = "09926-68310">
09926-68310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A111">
<s-part>
(C)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311022.swf" width = "88.000mm" height = "71.587mm" ver = "01" gw = "232" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite novi uskočnik (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Postavite novi poklopac za prašinu u propisani položaj na kutnoj poluzi upravljača prikazan na slici.
</ptxt>
<attention2>
<ptxt>
Pazite da prilikom utiskivanja ne iskrivite poklopac za prašinu.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Utisnite poklopac za prašinu prednje kočnice (2) u kutnu polugu pomoću hidraulične preše (1) i specijalnih alata.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A112">
<s-part>
(A)
</s-part>
<s-number num = "09951-17010">
09951-17010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A113">
<s-part>
(B)
</s-part>
<s-number num = "09944-77030">
09944-77030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311018.swf" width = "88.000mm" height = "55.099mm" ver = "01" gw = "203" gh = "140"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.135in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.595in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
13&#176;
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“b”:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
70 mm (2,8 in)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Osigurajte na više od 4 mjesta malim hladnim dlijetom.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311020.swf" width = "88.000mm" height = "52.911mm" ver = "01" gw = "186" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Brtvljenje
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Koristeći specijalni alat i hidrauličku prešu, utisnite glavčinu kotača (1) u ležaj kotača (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L3A114">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913-75810
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3A115">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311017.swf" width = "88.000mm" height = "57.910mm" ver = "01" gw = "203" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Spojite pogonsko vratilo na kutnu polugu upravljača. 
<intxreftitleoff1 refid = "AHRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Spojite kutnu polugu upravljača na rame ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite vijke i matice nosača opružne noge. 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite senzor brzine prednjeg kotača. 
<intxreftitleoff1 refid = "AHRAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Spojite krajnik spone na kutnu polugu upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite disk kočnice i kočna kliješta. 
<intxreftitleoff1 refid = "AHRAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zategnite maticu pogonskog vratila propisanim momentom pritezanja i osigurajte ju. 
<intxreftitleoff1 refid = "AHRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Svakako koristite novu maticu pogonskog vratila.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Ugradite prednji kotač. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Potvrdite poravnanje prednjih kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
