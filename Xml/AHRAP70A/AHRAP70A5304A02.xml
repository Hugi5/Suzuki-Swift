<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A5304A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vučenje spojke
</title>
<diag type = "condition">
<condition>
<ptxt>
Vučenje spojke
</ptxt>
</condition>
<ps>
<ptxt>
Neodgovarajući slobodni hod papučice spojke
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite glavni cilindar i/ili polugu papučice spojke.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Poluga papučice spojke: 
<intxreftitleoff1 refid = "AHRAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Glavni cilindar spojke: 
<intxreftitleoff1 refid = "AHRAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Oslabljena tanjurasta opruga, ili istrošen vrh opruge
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite poklopac spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hrđavi utor ulaznog vratila
</ptxt>
</ps>
<action>
<ptxt>
Podmažite utor ulaznog vratila.
</ptxt>
</action>
<ps>
<ptxt>
Oštećeni ili istrošeni utori ulaznog vratila mjenjača
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ulazno vratilo. 
<intxreftitleoff1 refid = "AHRAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Previše raskliman disk spojke
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite disk spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neravne obloge spojke ili zaprljane uljem
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite disk spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istjecanje tekućine
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite sustav spojke.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
