Ne može se pokrenuti jedan od električnih prozora
</ptxt>
</condition>
<ps>
<ptxt>
Neispravno ožičenje
</ptxt>
</ps>
<action>
<ptxt>
Popravite ožičenje.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan regulator i/ili motor električnog prozora
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Prednji: 
<intxreftitleoff1 refid = "AHRAP70A9506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
