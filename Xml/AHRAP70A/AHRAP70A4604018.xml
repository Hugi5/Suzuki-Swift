<servinfosub id = "AHRAP70A4604018003">
<title>
Rješavanje problema DTC-a
</title>
<topic id = "AHRAP70A4604018004">
<title>
Priprema
</title>
<list1 type = "unordered">
<item>
<ptxt>
Potvrdite da nije detektiran DTC C1057.
</ptxt>
</item>
<item>
<ptxt>
Izvedite slijedeću proceduru kontinuirano više od 8 puta.
</ptxt>
</item>
</list1>
<s1>
<ptxt>
Uključite kontakt.
</ptxt>
</s1>
<s1>
<ptxt>
Vozite brzinom od preko 20 km/h (12 milja/h) dulje od 1 minute.
</ptxt>
</s1>
<s1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</s1>
</topic>
<diag type = "test" id = "AHRAP70A4604018005">
<testgroup id = "AHRAP70A4604018006">
<question>
Je li izvršena &#34;Provjera ESP® sustava&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A4604001">Provjera ESP® sustava</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604018007">
<title>
Provjera tlaka u gumama
</title>
<test1>
<ptxt>
Provjerite odgovara li tlak u gumama propisanoj vrijednosti.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Prilagodite tlak u gumama ili zamijenite gumu i ponovno provjerite DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604018008">
<title>
Provjera kruga napajanja i kruga signala senzora brzine kotača.
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite “E24” i konektore senzora brzine kotača.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spojeva na “E24” i sve konektore senzora brzine kotača.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova “A1”, “A2”, “B1”, “B2”, “C1”, “C2”, “D1” i “D2”: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova “A1”, “A2”, “B1”, “B2”, “C1”, “C2”, “D1” i “D2” i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i drugih terminala konektora senzora brzine prednjeg lijevog kotača: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B1&#34; i drugih terminala konektora senzora brzine prednjeg desnog kotača: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;C1&#34; i drugih terminala konektora senzora brzine stražnjeg lijevog kotača: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;D1&#34; i drugih terminala konektora senzora brzine stražnjeg desnog kotača: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova “A1”, “A2”, “B1”, “B2”, “C1”, “C2”, “D1” i “D2”: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604018009">
<title>
Provjera signala senzora brzine kotača
</title>
<test1>
<ptxt>
Provjerite izlazni napon i valni oblik odgovarajućeg senzora brzine kotača. 
<intxreftitleoff1 refid = "AHRAP70A4606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat u skladu sa specifikacijama?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604018010">
<title>
Provjera senzora brzine kotača
</title>
<test1>
<ptxt>
Provjerite odgovarajući senzor brzine kotača. 
<intxreftitleoff1 refid = "AHRAP70A4606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Očistite, popravite ili zamijenite senzor brzine kotača.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Senzor brzine prednjeg kotača: 
<intxreftitleoff1 refid = "AHRAP70A4606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Senzor brzine stražnjeg kotača: 
<intxreftitleoff1 refid = "AHRAP70A4606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604018011">
<title>
Provjera enkodera senzora brzine kotača
</title>
<test1>
<ptxt>
Provjerite enkoder odgovarajućeg senzora brzine kotača. 
<intxreftitleoff1 refid = "AHRAP70A4606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Očistite, popravite ili zamijenite enkoder senzora brzine kotača.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Enkoder senzora brzine prednjeg kotača: 
<intxreftitleoff1 refid = "AHRAP70A4606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Enkoder senzora brzine stražnjeg kotača: 
<intxreftitleoff1 refid = "AHRAP70A4606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
:
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
