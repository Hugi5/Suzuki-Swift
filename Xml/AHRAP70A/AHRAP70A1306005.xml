<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1306005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kalibracija upravljačkog sustava električne zaklopke gasa
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Ako je obavljen servis opisan pod 
<intxref refid = "AHRAP70A1101007">Opis kalibracije sustava upravljanja električnom zaklopkom</intxref>
, kalibrirajte upravljački sustav električne zaklopke na sljedeći način.
</ptxt>
</item>
<item>
<ptxt>
Provjerite jesu li zadovoljeni sljedeći uvjeti prilikom obavljanja ove procedure.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
 Temperatura okoline &#62; 5 &#176;C (41 &#176;F)
</ptxt>
</item>
<item>
<ptxt>
Nije detektiran DTC.
</ptxt>
</item>
<item>
<ptxt>
Položaj papučice gasa: prazan hod
</ptxt>
</item>
<item>
<ptxt>
5 &#176;C (41 &#176;F) &#60; ECT &#60; 100 &#176;C (212 &#176;F)
</ptxt>
</item>
<item>
<ptxt>
Napon akumulatora &#62; 10 V
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Uključite kontakt na 60 s.
</ptxt>
</s1>
<s1>
<ptxt>
Isključite kontakt.
</ptxt>
</s1>
<s1>
<ptxt>
Nakon kalibriranja provjerite da ECM ne detektira DTC.
</ptxt>
<ptxt>
Ako se detektira DTC, potražite rješenje problema za primjenjivi DTC.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
