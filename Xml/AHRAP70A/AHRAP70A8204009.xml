<servinfosub id = "AHRAP70A8204009002">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204009003">
<testgroup id = "AHRAP70A8204009004">
<title>
Provjera konektora SDM-a
</title>
<test1>
<ptxt>
Provjerite ispravnost spoja s konektorom SDM-a.
</ptxt>
</test1>
<question>
Je li spoj u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Čvrsto spojite konektor.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204009005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70A8204005">Provjera DTC-a</intxref>
. 
</ptxt>
</test1>
<question>
Postoje li DTC-ovi?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajuće rješavanje problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204009006">
<title>
Provjera kruga napajanja i uzemljenja SDM-a
</title>
<test1>
<ptxt>
Provjerite krug napajanja i uzemljenja SDM-a. 
<intxreftitleoff1 refid = "AHRAP70A8204052"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li krugovi u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite krug napajanja i uzemljenja SDM-a.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204009007">
<title>
Provjera strujnog kruga CAN komunikacije
</title>
<test1>
<ptxt>
Provjerite krug CAN komunikacije između SDM-a i kombiniranog mjerača.
</ptxt>
</test1>
<question>
Je li krug u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204009008">
<title>
Provjera kombiniranog mjerača
</title>
<test1>
<ptxt>
Zamijenite kombinirani mjerač. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<question>
Ostaje li svjetlo upozorenja &#34;AIR BAG&#34; uključeno?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite SDM i ponovno provjerite rad svjetla upozorenja &#34;AIR BAG&#34;. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Nakon završetka pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem riješen.
</ptxt>
</item>
</list1>
</attention3>
