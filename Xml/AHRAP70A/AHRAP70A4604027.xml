<servinfosub id = "AHRAP70A4604027003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A4604027004">
<testgroup id = "AHRAP70A4604027005">
<question>
Je li izvršena “Provjera ESP<sup>®</sup> sustava”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A4604001">Provjera ESP® sustava</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604027006">
<title>
Provjera krugova napajanja elektromagnetnog ventila i uzemljenja upravljačkog modula ESP®-a
</title>
<test1>
<ptxt>
Provjerite krugove napajanja i uzemljenja elektromagnetnog ventila pod 
<intxref refid = "AHRAP70A4604042">Provjera kruga napajanja i uzemljenja upravljačkog modula ESP®-a</intxref>
.
</ptxt>
</test1>
<question>
Jesu li rezultati provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
</diag>
