<servinfosub id = "AHRAP70A1104018003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Nije detektiran DTC P0100, P0102, P0103, P0112, P0113, P2100, P2101, P2176, P2228 ili P2229.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Pokrenite motor i vozite vozilo brzinom od 50 do 70 km/h (31 do 43 milja/h) konstantno tijekom 3 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104018004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104018005">
<testgroup id = "AHRAP70A1104018006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104018007">
<title>
Provjera sustava usisa zraka i ispušnog sustava
</title>
<test1>
<ptxt>
Provjerite jesu li usisni sustav, ispušni sustav, vakuumsko crijevo i PCV crijevo začepljeni ili oštećeni.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104018008">
<title>
Provjera tijela zaklopke
</title>
<test1>
<ptxt>
Provjerite rad tijela zaklopke. 
<intxreftitleoff1 refid = "AHRAP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite tijelo zaklopke.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104018009">
<title>
Provjera MAF senzora i njegovog kruga
</title>
<test1>
<ptxt>
Provjerite MAF senzor i njegov krug prema koracima 2 do 6 u poglavlju 
<intxref refid = "AHRAP70A1104017">DTC P0100/P0102/P0103</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104018010">
<title>
Rješavanje problema drugih DTC-ova u isto vrijeme
</title>
<question>
Jesu li drugi DTC-ovi detektirani zajedno?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
