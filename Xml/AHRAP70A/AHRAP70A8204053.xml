</testfigure>
</test1>
<question>
Je li otpor 1 &#937; ili manji?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite sklop zavojnice kontakta. 
<intxreftitleoff1 refid = "AHRAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204053007">
<title>
Provjera kruga zavojnice kontakta
</title>
<test1>
<ptxt>
Izmjerite otpor između svakog terminala zavojnice kontakta i drugih terminala.
</ptxt>
</test1>
<question>
Je li svaki izmjereni otpor beskonačan?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zavojnica kontakta i njen krug su u dobrom stanju.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite sklop zavojnice kontakta. 
<intxreftitleoff1 refid = "AHRAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
