<title>
Nedostatna sila kočenja
</title>
<diag type = "condition">
<condition>
<ptxt>
Nedostatna sila kočenja
</ptxt>
</condition>
<ps>
<ptxt>
Istjecanje tekućine iz vodova kočnice
</ptxt>
</ps>
<action>
<ptxt>
Pronađite mjesto istjecanja i popravite.
</ptxt>
</action>
<ps>
<ptxt>
Disk ili pločica kočnice onečišćeni su tekućinom, mazivom ili drugim uljem
</ptxt>
</ps>
<action>
<ptxt>
Očistite ili zamijenite.
</ptxt>
</action>
<ps>
<ptxt>
Pregrijane kočnice
</ptxt>
</ps>
<action>
<ptxt>
Pronađite uzrok i popravite.
</ptxt>
</action>
<ps>
<ptxt>
Vrlo istrošene kočne pločice
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite.
</ptxt>
</action>
<ps>
<ptxt>
Kvar sklopa kočnih kliješta
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite.
</ptxt>
</action>
<ps>
<ptxt>
Zrak u sustavu
</ptxt>
</ps>
<action>
<ptxt>
Odzračite kočni sustav.
</ptxt>
</action>
<ps>
<ptxt>
Unutarnja pogreška servouređaja kočnice
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite servouređaj.
</ptxt>
</action>
<ps>
<ptxt>
Negativan tlak servouređaja kočnice nije odgovarajući
</ptxt>
</ps>
<action>
<ptxt>
Provjerite stanje motora i vakuumsko crijevo.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan rad ESP<sup>®-a</sup>
</ptxt>
</ps>
<action>
<ptxt>
Provjerite sustav i po potrebi zamijenite.
</ptxt>
</action>
</diag>
