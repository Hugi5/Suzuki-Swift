<diag type = "test" id = "AHRAP70A6304011003">
<testgroup id = "AHRAP70A6304011004">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Pokrenite motor i ponovo provjerite DTC u upravljačkom modulu P/S-a.
</ptxt>
</test1>
<question>
Postoje li DTC-ovi?
</question>
<result type = "yes"/>
<action>
<ptxt>
Provedite 
<intxref refid = "AHRAP70A6304003">Provjera DTC-a</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304011005">
<title>
Provjera kombiniranog mjerača
</title>
<test1>
<ptxt>
Zamijenite kombinirani mjerač. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<question>
Ostaje li svjetlo upozorenja P/S-a uključeno?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul P/S-a i ponovno provjerite. 
<intxreftitleoff1 refid = "AHRAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
