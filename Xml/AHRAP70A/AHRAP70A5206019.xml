</s1>
<s1>
<ptxt>
Ugradite sigurno novi uskočnik (1) u utor.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Ugradite igličasti ležaj (2) i na njega nanesite ulje, zatim ugradite prsten sinkrona (3) i zupčanik 4. stupnja.
</ptxt>
<figure>
<graphic graphicname = "I2RH01520052.swf" width = "88.000mm" height = "45.751mm" ver = "01" gw = "170" gh = "113"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
