<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1506004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja korita ulja i grubog filtra pumpe ulja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1506003">Dijelovi korita ulja i grubog filtra pumpe ulja</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1506004001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite mjerač razine ulja.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite donju desnu oblogu motora.
</ptxt>
</s1>
<s1>
<ptxt>
Ispustite motorno ulje uklanjanjem čepa za ispuštanje.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite ispušnu cijev br. 1. 
<intxreftitleoff1 refid = "AHRAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite međumjenjač. 
<intxreftitleoff1 refid = "AHRAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite filtar za ulje. 
<intxreftitleoff1 refid = "AHRAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite vijke mjenjača (1) i vijke korita ulja (2).
</ptxt>
<figure>
<graphic graphicname = "I7V20A151012.swf" width = "88.000mm" height = "49.208mm" ver = "01" gw = "227" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Specijalnim alatom i čekićem odvojite korito ulja (1) od bloka motora.
</ptxt>
<servicetool>
<servicetoolitem id = "L1E005">
<s-part>
(A)
</s-part>
<s-number num = "09921-96510">
09921-96510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A151013.swf" width = "88.000mm" height = "49.206mm" ver = "02" gw = "230" gh = "123"/>
</figure>
</s1>
<c-change/>
<s1 page = "2">
<ptxt>
Po potrebi uklonite grubi filtar pumpe ulja.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Po potrebi izvadite pregradnu ploču korita ulja i svorne vijke pregradne ploče korita ulja.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1506004002">
<title>
Ugradnja
</title>
<s1>
<ptxt>
Namjestite svorni vijak pregradne ploče korita ulja (1) ako je bila uklonjena, a zatim pritegnite svorni vijak pregradne ploče korita ulja propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1E004">
<t-part>
Svorni vijak pregradne ploče korita ulja
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Ugradite pregradnu ploču korita ulja (2) a zatim pritegnite vijke pregradne ploče korita ulja (3) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1E005">
<t-part>
Vijak pregradne ploče korita ulja
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure page = "2">
<graphic graphicname = "I9P60A151002.swf" width = "88.000mm" height = "50.955mm" ver = "01" gw = "177" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Nanesite motorno ulje na novi O-prsten (1), a zatim ugradite O-prstenove na grubi filtar pumpe ulja (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Ugradite grubi filtar pumpe ulja s O-prstenom na pumpu ulja i najprije pritegnite vijak (3), a zatim maticu (4) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1E006">
<t-part>
Vijak grubog filtra pumpe ulja*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1E007">
<t-part>
Matica nosača grubog filtra pumpe ulja*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151003.jpg" width = "88.000mm" height = "61.290mm" ver = "01" gw = "199" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite cilindrične zatike (1) na korito ulja i blok motora.
</ptxt>
<figure>
<graphic graphicname = "I9P60A151004.jpg" width = "88.000mm" height = "67.299mm" ver = "01" gw = "207" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Nanesite motorno ulje na novi O-prsten (1), a zatim ugradite O-prsten na mjesto kako je prikazano na slici.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Nanesite brtvilo na dodirne površine korita ulja kao što je prikazano na slici.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Prije nanošenja brtvila uvjerite se da su dosjedne površine čiste i suhe.
</ptxt>
</item>
<item>
<ptxt>
Obrišite višak brtvila.
</ptxt>
</item>
<item>
<ptxt>
Ugradite korito ulja unutar 2 minute nakon nanošenja brtvila.
</ptxt>
</item>
</list1>
</attention3>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1E002" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Brtvilo
</m-desc>
<m-number>
99000-31260
</m-number>
<m-name>
SUZUKI Bond br.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<spec>
<title>
Količina brtvila za korito ulja
</title>
<ptxt>
Širina &#34;a&#34;: 3 mm (0,12 in)
</ptxt>
<ptxt>
Visina &#34;b&#34;: 2 mm (0,08 in)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151017.swf" width = "88.000mm" height = "59.875mm" ver = "01" gw = "146" gh = "153"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite korito ulja na blok motora i zatim ravnomjerno i postupno pritegnite vijke korita ulja slijedom brojeva (&#34;1&#34; - &#34;17&#34;) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1E008">
<t-part>
Vijak korita ulja*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151005.swf" width = "88.000mm" height = "63.567mm" ver = "01" gw = "227" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Zategnite vijke mjenjača (1) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1E009">
<t-part>
Vijak mjenjača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151006.swf" width = "88.000mm" height = "46.039mm" ver = "01" gw = "227" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite filtar za ulje. 
<intxreftitleoff1 refid = "AHRAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite međumjenjač. 
<intxreftitleoff1 refid = "AHRAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Postavite ispušnu cijev br. 1. 
<intxreftitleoff1 refid = "AHRAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite donju desnu oblogu motora.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite čep za ispuštanje i napunite motor motornim uljem. 
<intxreftitleoff1 refid = "AHRAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Postavite mjerač razine ulja.
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite da nigdje na spojevima ne istječe ulje i ispušni plinovi.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
