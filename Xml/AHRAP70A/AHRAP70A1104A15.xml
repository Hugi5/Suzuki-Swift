<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1104A15" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nepravilan rad motora u praznom hodu ili motor ne može raditi u praznom hodu
</title>
<ptxt>
Izvršite rješavanje problema prema sljedećim točkama kada je ECM detektirao da nema DTC-a i nisu pronađene nepravilnosti u 
<intxref refid = "AHRAP70A1104008">Vizualni pregled</intxref>
 i 
<intxref refid = "AHRAP70A1104009">Osnovni pregled motora</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Nepravilan rad motora u praznom hodu ili motor ne može raditi u praznom hodu
</ptxt>
</condition>
<ps>
<ptxt>
Neispravna svjećica
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1806002">Provjera svjećice</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravna indukcijska zavojnica s upaljačem
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1806004">Pregled sklopa indukcijske zavojnice</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Tlak goriva izvan specifikacija
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1704005">Provjera tlaka goriva</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Istjecanje na grani, tijelu zaklopke ili brtvi glave motora
</ptxt>
</ps>
<action>
<ptxt>
Provjerite sustav usisa zraka.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sustav kontrole emisije para goriva
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1206002">Pregled ventila za pražnjenje EVAP spremnika</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravne brizgaljke goriva
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1704003">Provjera kruga brizgaljke goriva</intxref>
 ili 
<intxref refid = "AHRAP70A1706009">Pregled brizgaljke goriva</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabe performanse ECT senzora ili MAF senzora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306012">Pregled ECT senzora</intxref>
 ili 
<intxref refid = "AHRAP70A1306026">Pregled MAF i IAT senzora</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop tijela električne zaklopke
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306004">Provjera sklopa tijela eletrične zaklopke na vozilu</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop APP senzora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306008">Pregled APP senzora</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1104070">Pregled ECM-a i njegovih krugova</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slab spoj ili odspojena vakuumska crijeva
</ptxt>
</ps>
<action>
<ptxt>
Provjerite spoj vakuumskih crijeva.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan PCV ventil
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1206006">Pregled PCV ventila</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Motor se pregrijava
</ptxt>
</ps>
<action>
<ptxt>
Stanje &#34;motor se pregrijava&#34;
</ptxt>
</action>
<ps>
<ptxt>
Niska kompresija
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1404001">Provjera kompresije</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan generator i/ili njegov strujni krug
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1A04003">Test generatora</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sustav kontrole položaja bregastog vratila (VVT)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306027">Provjera OCV-a</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
