<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7216018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja ekspanzijskog ventila
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A7216007">Komponente HVAC jedinice:Ručni tip</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A7216018001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Obnovite rashladno sredstvo iz sustava klima uređaja opremom za izvlačenje i recikliranje prema uputama pod naslovom “Izvlačenje”, u poglavlju 
<intxref refid = "AHRAP70A7216007">Komponente HVAC jedinice:Ručni tip</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Odvijte vijak (1), zatim uklonite cijev za tekućinu i ususno crijevo s ekspanzijskog ventila (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odvijte vijke (3) i uklonite ekspanzijski ventil.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A720028.swf" width = "88.000mm" height = "43.902mm" ver = "01" gw = "173" gh = "109"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7216018002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A7216019">Pregled ekspanzijskog ventila:Ručni tip</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Nanesite ulje kompresora na O-prsten ekspanzijskog ventila i cijevi.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B104" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Ulje kompresora
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Vijke ekspanzijskog ventila zategnite specificiranim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T7B102">
<t-part>
Vijak ekspanzijskog ventila
</t-part>
<t-value1>
7,0
</t-value1>
<t-value2>
0,7
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Odzračite i napunite sustav klima uređaja prema uputama u odlomcima “Odzračivanje” i “Punjenje” u poglavlju 
<intxref refid = "AHRAP70A7216001">Procedura za punjenje rashladnog sredstva:Ručni tip</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
