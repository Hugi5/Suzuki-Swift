<servinfo servinfosgmlid = "AHRAP70A9506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa regulatora stražnjeg prozora
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9506014">Komponente stražnjih vrata</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9506017001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite staklo stražnjih vrata. 
<intxreftitleoff1 refid = "AHRAP70A9506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor motora električnog prozora (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite matice regulatora prozora (2) pa uklonite sklop regulatora stražnjeg prozora (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950048.jpg" width = "88.000mm" height = "61.700mm" ver = "02" gw = "217" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9506017002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9506018">Pregled sklopa regulatora stražnjeg prozora</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Nanesite mazivo na klizne dijelove sklopa regulatora stražnjeg prozora.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E002" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Pritegnite vijke regulatora stražnjeg prozora redoslijedom (“1” do “4”) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9E006">
<t-part>
Vijak regulatora stražnjeg prozora*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,86
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950049.jpg" width = "88.000mm" height = "63.881mm" ver = "01" gw = "225" gh = "165"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
