<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1A06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja pogonskog remena pumpe vode/generatora
</title>
<servinfosub id = "AHRAP70A1A06004001" page = "2">
<title>
Uklanjanje
</title>
<s1 page = "2">
<ptxt>
Odspojite negativni kabel (-) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite donju desnu oblogu motora.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Prije uklanjanja pogonskog remena pumpe vode/generatora (1) uklonite pogonski remen kompresora.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s ručnim klima uređajem: 
<intxreftitleoff1 refid = "AHRAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatskim klima uređajem: 
<intxreftitleoff1 refid = "AHRAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Otpustite vijak generatora (2) i zakretni vijak generatora (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Olabavite vijak namještanja generatora (4), a zatim uklonite pogonski remen pumpe vode/generatora.
</ptxt>
<figure>
<graphic graphicname = "I7V20A1A1008.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "148" gh = "123"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1A06004002" page = "2">
<title>
ugradnja
</title>
<s1 page = "2">
<ptxt>
Postavite pogonski remen pumpe vode/generatora (1) na remenicu pumpe vode (2), remenicu koljenastog vratila (3) i remenicu generatora (4).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Podesite napetost remena. 
<intxreftitleoff1 refid = "AHRAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite pogonski remen kompresora.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s ručnim klima uređajem: 
<intxreftitleoff1 refid = "AHRAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model s automatskim klima uređajem: 
<intxreftitleoff1 refid = "AHRAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Pazite da pogonski remen pravilno ugradite u utore svake remenice.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I7V20A1A1009.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "140" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite donju desnu oblogu motora.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Spojite negativni kabel (-) na akumulator.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
