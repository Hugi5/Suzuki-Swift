<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0620: Upravljački strujni krug generatora
</emph>
</ptxt>
<ptxt>
Napon akumulatora ostaje niži od 12,3 V dulje od 30 s čak i s radnim omjerom C većim od 65 % i radnim omjerom FR manjim od 60 %.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje, ali MIL ne zasvijetli)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Generator i/ili njegov strujni krug
</ptxt>
</item>
<item>
<ptxt>
Pogonski remen generatora
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
