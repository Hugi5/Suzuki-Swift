<servinfosub id = "AHRAP70A1104047003">
<title>
Postupak potvrde DTC-a
</title>
<attention3>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Temperatura akumulatora &#62; 12 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Zagrijte motor do normalne radne temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Potvrdite da su sljedeći uvjeti ispunjeni.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ventilator puhala: ISKLJ.
</ptxt>
</item>
<item>
<ptxt>
Prekidač prednjeg svjetla: ISKLJ.
</ptxt>
</item>
<item>
<ptxt>
Prekidač grijača stražnjeg prozora: ISKLJ.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Ostavite motor neka radi 10 min. u praznom hodu i potvrdite da su zadovoljeni sljedeći uvjeti.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ventilator puhala: UKLJ.
</ptxt>
</item>
<item>
<ptxt>
Prekidač prednjeg svjetla: UKLJ.
</ptxt>
</item>
<item>
<ptxt>
Prekidač grijača stražnjeg prozora: UKLJ.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Neka motor radi na 4000 okr./min 30 sekundi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104047004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104047005">
<testgroup id = "AHRAP70A1104047006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104047007">
<title>
Provjera pogonskog remena generatora
</title>
<test1>
<ptxt>
Provjerite je li pogonski remen generatora dobro zategnut. 
<intxreftitleoff1 refid = "AHRAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Namjestite ili zamijenite pogonski remen generatora.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104047008">
<title>
Provjera kruga upravljačkog signala generatora
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a i konektor generatora.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34; i konektorom generatora.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;A1&#34;: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;A1&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i drugih terminala na konektoru generatora: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;A1&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104047009">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite generator. 
<intxreftitleoff1 refid = "AHRAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC P0620?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
