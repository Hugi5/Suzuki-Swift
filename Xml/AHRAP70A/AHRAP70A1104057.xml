<servinfosub id = "AHRAP70A1104057003">
<title>
Postupak potvrde DTC-a
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Napon sustava &#62; 8 V
</ptxt>
</item>
<item>
<ptxt>
Nije detektiran DTC P2122, P2123, P2127 ili P2128.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Uključite kontakt.
</ptxt>
</s1>
<s1>
<ptxt>
Držite papučicu gasa u potpuno pritisnutom položaju tijekom 2 sekunde.
</ptxt>
</s1>
<s1>
<ptxt>
Držite papučicu gasa u položaju praznog hoda tijekom 2 sekunde.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104057004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104057005">
<testgroup id = "AHRAP70A1104057006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104057007">
<title>
Provjera ožičenja
</title>
<test1>
<ptxt>
Provjerite sljedeće točke:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon krugova &#34;A1&#34;, &#34;A2&#34; i &#34;A3&#34;: Pogledajte korake 3 do 5 u poglavlju 
<intxref refid = "AHRAP70A1104054">DTC P2122/P2123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Napon krugova &#34;B1&#34;, &#34;B2&#34; i &#34;B3&#34;: Pogledajte korake 3 do 5 u poglavlju 
<intxref refid = "AHRAP70A1104055">DTC P2127/P2128</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104057008">
<title>
Provjera APP senzora
</title>
<test1>
<ptxt>
Provjerite performanse APP senzora. 
<intxreftitleoff1 refid = "AHRAP70A1306006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite sklop APP senzora.
</ptxt>
</action>
</testgroup>
</diag>
