<servinfosub id = "AHRAP70A1104019003">
<title>
Postupak potvrde DTC-a
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Nije detektiran DTC P0107, P0108, P2119, P2135, P2138, P2228 ili P2229.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Pustite neka motor radi u praznom hodu 30 sekundi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104019004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104019005">
<testgroup id = "AHRAP70A1104019006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104019007">
<title>
Provjera sustava usisa zraka
</title>
<test1>
<ptxt>
Provjerite sustav usisa zraka radi začepljenja ili istjecanja.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite sustav usisa zraka.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104019008">
<title>
Provjera kruga MAP senzora
</title>
<test1>
<ptxt>
Provjerite krugove MAP senzora prema koracima 2 do 4 u poglavlju 
<intxref refid = "AHRAP70A1104020">DTC P0107/P0108</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104019009">
<title>
Provjera MAP senzora
</title>
<test1>
<ptxt>
Provjerite MAP senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite MAP senzor.
</ptxt>
</action>
</testgroup>
</diag>
