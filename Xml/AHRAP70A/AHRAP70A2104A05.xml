<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A2104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Abnormalna buka, prednji kraj
</title>
<diag type = "condition">
<condition>
<ptxt>
Abnormalna buka, prednji kraj
</ptxt>
</condition>
<ps>
<ptxt>
Oštećen sklop prednje opružne noge (amortizer) ili nosači
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite sklop prednje opružne noge (amortizer) ili nosače. 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošeni, ljepljivi ili labavi krajnici spone
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite krajnike spone. 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošeni ili oštećeni zglobovi ramena ovjesa
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite rame ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošeni, ljepljivi ili labavi kuglasti zglobovi
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošeni, ljepljivi ili labavi zglobovi pogonskog vratila
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite zglobove pogonskog vratila. 
<intxreftitleoff1 refid = "AHRAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošene prednje čahure ramena ovjesa
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite prednje čahure ramena ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istrošene stražnje čahure ramena ovjesa
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite rame ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Labava stabilizatorska šipka
</ptxt>
</ps>
<action>
<ptxt>
Zategnite vijke ili matice i/ili zamijenite čahure. 
<intxreftitleoff1 refid = "AHRAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Otpuštene matice kotača
</ptxt>
</ps>
<action>
<ptxt>
Zategnite matice kotača. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Labavi vijci ovjesa ili matice
</ptxt>
</ps>
<action>
<ptxt>
Zategnite vijke ovjesa ili matice. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slomljeni ili oštećeni ležajevi kotača
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ležajeve kotača. 
<intxreftitleoff1 refid = "AHRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slomljene zavojne opruge
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zamijenite zavojne opruge. 
</ptxt>
<ptxt>
Prednja: 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Stražnja: 
<intxreftitleoff1 refid = "AHRAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Slabo podmazani ili istrošeni ležajevi opružne noge
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ležajeve opružne noge. 
<intxreftitleoff1 refid = "AHRAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kvar sustava servoupravljača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i ispravite kvar. 
<intxreftitleoff1 refid = "AHRAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
