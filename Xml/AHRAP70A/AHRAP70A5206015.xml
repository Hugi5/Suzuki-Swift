</ptxt>
<figure>
<graphic graphicname = "IAP70A520018.jpg" width = "88.000mm" height = "130.644mm" ver = "02" gw = "227" gh = "354"/>
</figure>
</s1>
<s1>
<ptxt>
Specijalnim alatom uklonite lijevo kućište mjenjača (1) od desnog kućišta mjenjača (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L5B007">
<s-part>
