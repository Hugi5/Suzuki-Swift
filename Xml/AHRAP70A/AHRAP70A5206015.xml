</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A5206013">Komponente sklopa ručnog mjenjača</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A5206018">Komponente ulaznog vratila i predložnog vratila</intxrefpoff>
</ptxt>
<ptxt>
