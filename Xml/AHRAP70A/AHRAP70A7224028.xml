<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1557: Kvar senzora brzine kotača i/ili njegovog kruga
</emph>
</ptxt>
<ptxt>
HVAC upravljački modul prima neispravne podatke od signala senzora brzine vozila iz ECM-a.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Senzor brzine kotača
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>®</sup> upravljački modul
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul HVAC sustava
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1561: Kvar senzora temperature rashladne tekućine motora i/ili njegovog strujnog kruga
</emph>
</ptxt>
<ptxt>
Upravljački modul HVAC sustava prima neispravne podatke ECT signala iz ECM-a.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ECT senzor
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul HVAC sustava
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1563: Kvar senzora tlaka rashladnog sredstva klima uređaja i/ili njegovog kruga
</emph>
</ptxt>
<ptxt>
Upravljački modul HVAC sustava prima neispravne podatke signala tlaka rashladnog sredstva klima uređaja iz BCM-a.
</ptxt>
</entry>
