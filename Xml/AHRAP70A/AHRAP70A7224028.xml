</servinfosub>
<servinfosub id = "AHRAP70A7224028002">
<title>
Postupak potvrde DTC-a
</title>
<attention3>
<ptxt>
Provjerite da su zadovoljeni sljedeći uvjeti prilikom primjene ovog postupka.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
U0073, U0100, U0140 i/ili U0155 nisu detektirani
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Pokrenite motor i uključite sustav klima uređaja.
</ptxt>
</s1>
<s1>
<ptxt>
B1557: Vozite otprilike 1 minutu.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7224028003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A7224028004">
<testgroup id = "AHRAP70A7224028005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC u ECM-u. 
<intxreftitleoff1 refid = "AHRAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li detektiran jedan ili više DTC-ova?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajuće rješavanje problema za dotični DTC. 
<intxreftitleoff1 refid = "AHRAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite upravljački modul HVAC sustava i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
