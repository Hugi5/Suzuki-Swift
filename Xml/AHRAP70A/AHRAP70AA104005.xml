 P0504 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Korelacija prekidača kočnice &#34;A&#34;/&#34;B&#34;
</ptxt>
</entry>
<entry namest = "3" nameend = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
