<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja generatora
</title>
<servinfosub id = "AHRAP70A1A06005001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (-) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite donju desnu oblogu motora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite ispušnu cijev br. 1. 
<intxreftitleoff1 refid = "AHRAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite pogonski remen pumpe vode/generatora. 
<intxreftitleoff1 refid = "AHRAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite žicu terminala &#34;B&#34; (1) i konektor (2) od generatora (3).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite generator (3) i izvadite ga iz prostora motora između nosača prednjeg ovjesa i prednjeg sklopa pogonskog vratila.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1005.jpg" width = "88.000mm" height = "66.800mm" ver = "01" gw = "237" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1A06005002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zategnite vijak generatora i zakretni vijak generatora propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1J003">
<t-part>
Vijak generatora
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1J004">
<t-part>
Zakretni vijak generatora
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Spojite žicu (1) s generatorom kako je prikazano na slici pa zategnite maticu terminala &#34;B&#34; propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1J005">
<t-part>
Matica terminala “B”
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1A1006.jpg" width = "88.000mm" height = "61.151mm" ver = "02" gw = "237" gh = "157"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
