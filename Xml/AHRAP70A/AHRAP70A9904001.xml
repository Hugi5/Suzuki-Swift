<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A9904001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Dijagnostika simptoma sustava električnog krovnog prozora
</title>
<diag type = "condition" id = "AHRAP70A9904001001">
<condition>
<ptxt>
Motor krovnog prozora se ne može pokrenuti (motor krovnog prozora se može pokrenuti)
</ptxt>
</condition>
<ps>
<ptxt>
Strani predmet zaglavljen u vodilici krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Uklonite ili očistite zaglavljeni predmet.
</ptxt>
</action>
<ps>
<ptxt>
Neispravna ugradnja vodilice krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Pravilno ugradite.
</ptxt>
</action>
<ps>
<ptxt>
Preklapanje dijelova krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Popravite preklapanje.
</ptxt>
</action>
<ps>
<ptxt>
Neispravna ugradnja pogonskog kabela krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Pravilno ugradite.
</ptxt>
</action>
<condition>
<ptxt>
Funkcije automatskog kliznog otvaranja i automatskog podizanja se ne mogu pokrenuti
</ptxt>
</condition>
<ps>
<ptxt>
Inicijalizacija je neispravna.
</ptxt>
</ps>
<action>
<ptxt>
Inicijalizirajte motor krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan položaj za ugradnju stakla krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Namjestite položaj za ugradnju stakla krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravno klizno pokretanje jedinice krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite jedinicu krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan motor krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite motor krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Krovni prozor se ne može pokrenuti (motor krovnog prozora se može pokrenuti)
</ptxt>
</condition>
<ps>
<ptxt>
Pregorjeli osigurač
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite osigurač.
</ptxt>
</action>
<ps>
<ptxt>
Zamijenite prekidač krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Provjerite prekidač krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravno ožičenje ili uzemljenje
</ptxt>
</ps>
<action>
<ptxt>
Provjerite krug. 
<intxreftitleoff1 refid = "AHRAP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AHRAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan motor krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Provjerite motor krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Prokišnjavanje
</ptxt>
</condition>
<ps>
<ptxt>
Neispravan položaj za ugradnju stakla krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Namjestite položaj za ugradnju stakla krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravno staklo krovnog prozora
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite staklo krovnog prozora. 
<intxreftitleoff1 refid = "AHRAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Odspojeno ili začepljeno crijevo za pražnjenje (prednje/stražnje)
</ptxt>
</ps>
<action>
<ptxt>
Provjerite crijevo za pražnjenje (prednje/stražnje)
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
