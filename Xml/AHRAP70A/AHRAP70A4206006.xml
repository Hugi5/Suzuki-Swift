<servinfo servinfosgmlid = "AHRAP70A4206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pregled diska prednje kočnice
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A4206005">Uklanjanje i ugradnja diska prednje kočnice</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A4206006001" page = "2">
<title>
Disk prednje kočnice
</title>
<list1 type = "unordered">
<item>
<ptxt>
Korištenjem magnetskog stalka, ticalo komparatora postavite približno 10 mm (0,39 in) unutra od ruba diska, izmjerite deformaciju diska. Ako prelazi granicu, ispravite ili zamijenite disk prednje kočnice.
</ptxt>
<spec-sdm>
<sdm-title>
Deformacija diska prednje kočnice
</sdm-title>
<sdm1>
<sdm-condition>
Granica
</sdm-condition>
<sdm-value>
0,10 mm (0,004 in) 
</sdm-value>
</sdm1>
</spec-sdm>
<servicetool>
<servicetoolitem id = "L4B001">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900-20607
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L4B002">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900-20701
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure page = "2">
<graphic graphicname = "IAP70A420010.swf" width = "88.000mm" height = "49.949mm" ver = "02" gw = "133" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Upotrebom mikrometra izmjerite debljinu diska prednje kočnice. Ako je manja od granične, zamijenite disk prednje kočnice.
</ptxt>
<spec-sdm>
<sdm-title>
Debljina diska prednje kočnice
</sdm-title>
<sdm-part>
“a”
</sdm-part>
<sdm1>
<sdm-condition>
Standardna
</sdm-condition>
<sdm-value>
22,0 mm (0,87 in)
</sdm-value>
</sdm1>
<sdm1>
<sdm-condition>
Granica
</sdm-condition>
<sdm-value>
20,0 mm (0,79 in)
</sdm-value>
</sdm1>
</spec-sdm>
<figure page = "2">
<graphic graphicname = "IAP70A420011.swf" width = "88.000mm" height = "52.057mm" ver = "01" gw = "133" gh = "131"/>
</figure>
</item>
