<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7216043" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sigurnosnog ventila
</title>
<servinfosub id = "AHRAP70A7216043001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Obnovite rashladno sredstvo iz sustava klima uređaja opremom za izvlačenje i recikliranje prema uputama pod naslovom “Obnavljanje” u poglavlju 
<intxref refid = "AHRAP70A7216001">Procedura za punjenje rashladnog sredstva:Ručni tip</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite desnu stranu donjeg poklopca motora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sigurnosni ventil (1) s kompresora.
</ptxt>
<figure>
<graphic graphicname = "I9P60A722038.swf" width = "88.000mm" height = "48.588mm" ver = "03" gw = "120" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7216043002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Koristite novi O-prsten.
</ptxt>
</item>
<item>
<ptxt>
Nanesite ulje kompresora na O-prsten.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B107" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Ulje kompresora
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Sigurnosni ventil pritegnite propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T7B107">
<t-part>
Sigurnosni ventil
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,8
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A722039.swf" width = "88.000mm" height = "48.612mm" ver = "05" gw = "120" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Odzračite i napunite sustav klima uređaja prema uputama u odlomcima “Odzračivanje” i “Punjenje” u poglavlju 
<intxref refid = "AHRAP70A7216001">Procedura za punjenje rashladnog sredstva:Ručni tip</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
