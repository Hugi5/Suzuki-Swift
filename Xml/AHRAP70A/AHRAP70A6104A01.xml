<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A6104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Teško upravljanje
</title>
<diag type = "condition">
<condition>
<ptxt>
Teško upravljanje
</ptxt>
</condition>
<ps>
<ptxt>
Nedovoljan tlak u gumi
</ptxt>
</ps>
<action>
<ptxt>
Podesite tlak u gumi.
</ptxt>
</action>
<ps>
<ptxt>
Kvar u sustavu servo upravljača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i ispravite. 
<intxreftitleoff1 refid = "AHRAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zaglavljenje kuglastog zgloba krajnika spone
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite krajnik spone. 
<intxreftitleoff1 refid = "AHRAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zaglavljenje kuglastog zgloba ramena ovjesa
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite rame ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poremećena geometrija prednjih kotača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i podesite geometriju prednjih kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zaglavljeni stup upravljača.
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite stup upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neodgovarajući kontakt zuba između zupčaste letve i zupčanika
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Provjerite okretni moment vratila zupčaste letve i zupčanika. 
<intxreftitleoff1 refid = "AHRAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ako je neispravan, zamijenite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
