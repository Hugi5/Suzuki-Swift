<title>
Pri malom broju okretaja u minuti motora čuje se glasno zveckanje
</title>
<servinfosub id = "AHRAP70A7214004001">
<title>
Abnormalna buka iz kompresora
</title>
<diag type = "condition">
<condition>
<ptxt>
Pri malom broju okretaja u minuti motora čuje se glasno zveckanje
</ptxt>
</condition>
<ps>
<ptxt>
Labava matica na ploči spojke kompresora
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
