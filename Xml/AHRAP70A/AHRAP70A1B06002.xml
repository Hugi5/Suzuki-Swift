<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1K">
<servcat sctnbr = "01" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1B06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja ispušne grane
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1B06001">Komponente ispušnog sustava</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1B06002001" page = "2">
<title>
Uklanjanje
</title>
<attention2>
<ptxt>
Pazite da vam ispušna grana ne ispadne. Ako vam ispadne, udarac može oštetiti unutarnji katalizator.
</ptxt>
</attention2>
<s1 page = "2">
<ptxt>
Odspojite negativni kabel (-) s akumulatora.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odspojite konektor A/F senzora (1) (boja konektora: crna) i konektora HO2S-a (2) (boja konektora: siva), a zatim ih odvojite od nosača.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0002.swf" width = "88.000mm" height = "53.833mm" ver = "01" gw = "171" gh = "136"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Odspojite ispušnu cijev br. 1 (1) od ispušne grane.
</ptxt>
<figure page = "2">
<graphic graphicname = "I7V20A1B1003.swf" width = "88.000mm" height = "51.237mm" ver = "01" gw = "163" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Uklonite učvršćenja ispušne grane (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite poklopac ispušne grane (3) s ispušne grane.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite A/F senzor (4) ili HO2S (5) s ispušne grane, ako je potrebno. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite ispušnu granu (1) i njezinu brtvu s glave motora.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0003.swf" width = "88.000mm" height = "70.972mm" ver = "01" gw = "193" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1B06002002" page = "2">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Upotrijebite novu brtvu.
</ptxt>
</item>
<item>
<ptxt>
Pritegnite vijke i matice ispušne grane propisanim momentom sile.
</ptxt>
<torque>
<torqueitem id = "T1K001">
<t-part>
Vijak ispušne grane
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6,1
</t-value2>
<t-value3>
44,5
</t-value3>
</torqueitem>
<torqueitem id = "T1K002">
<t-part>
Matica ispušne grane
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6,1
</t-value2>
<t-value3>
44,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1002.jpg" width = "88.000mm" height = "57.647mm" ver = "02" gw = "199" gh = "147"/>
</figure>
</item>
<item>
<ptxt>
Ako ste ih uklonili, ugradite A/F senzor i HO2S. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ugradite učvršćenja ispušne grane kako slijedi.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Ugradite učvršćenja ispušne grane (1), a zatim rukom pritegnite matice učvršćenja ispušne grane (2).
</ptxt>
</item>
<item>
<ptxt>
Zategnite vijke učvršćenja ispušne grane (3) pa zategnite matice učvršćenja ispušne grane (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P1B0004.swf" width = "88.000mm" height = "64.959mm" ver = "01" gw = "172" gh = "168"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Pritegnite vijke ispušne cijevi br. 1 propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1K003">
<t-part>
Vijak ispušne cijevi br. 1
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
43
</t-value1>
<t-value2>
4,4
</t-value2>
<t-value3>
32,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1004.swf" width = "88.000mm" height = "54.949mm" ver = "01" gw = "153" gh = "139"/>
</figure>
</item>
<item>
<ptxt>
Pokrenite motor i provjerite propuštaju li negdje ispušni plinovi.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
