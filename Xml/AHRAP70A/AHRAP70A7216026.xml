<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7216026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja aktuatora kontrole usisa zraka
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A7216020">Komponente upravljačke jedinice HVAC sustava:Ručni tip</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A7216026001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite kutiju za rukavice. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite kanal za noge na suvozačevoj strani. 
<intxreftitleoff1 refid = "AHRAP70A7216011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor aktora kontrole usisa zraka.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite pokretač nadzora ulaza zraka (2) s HVAC jedinice.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721028.jpg" width = "88.000mm" height = "68.236mm" ver = "01" gw = "142" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7216026002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A7216027">Pregled aktuatora kontrole usisa zraka:Ručni tip</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeću točku.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno umetnite zatik polužja (1) u utor (2) aktuatora kontrole usisa zraka.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721029.swf" width = "88.000mm" height = "49.668mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
