<servinfosub id = "AHRAP70A8204027003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204027004">
<testgroup id = "AHRAP70A8204027005">
<question>
Je li izvršena “Provjera dijagnostičkog sustava zračnih jastuka”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204027006">
<title>
Provjera zatezača sigurnosnog pojasa
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “L283” ili “L285”.
</ptxt>
</test1>
<test1>
<ptxt>
Spojite “KOLO UPRAVLJAČA” (1) sa specijalnih alata (A), (B) i (C) na konektore “L283” i “L285”.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B036">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B037">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932-78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B038">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932-75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820024.swf" width = "90.000mm" height = "65.296mm" ver = "03" gw = "233" gh = "169"/>
</testfigure>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li još uvijek prikazani kodovi DTC B1052 ili DTC B1056?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite zatezač sigurnosnog pojasa. 
<intxreftitleoff1 refid = "AHRAP70A8106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204027007">
<title>
Provjera kruga ožičenja poda
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “L04” ili “L05”.
</ptxt>
</test1>
<test1>
<ptxt>
Otpustite kratkospojnu šipku u konektoru SDM-a tako da umetnete alat za otpuštanje priložen sa specijalnim alatom (A).
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor između terminala “L04-6” i “L04-5” (DTC B1052): beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala “L05-14” i “L05-13” (DTC B1056): beskonačan
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B039">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820122.swf" width = "90.000mm" height = "92.933mm" ver = "01" gw = "235" gh = "247"/>
</testfigure>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite SDM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje poda. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Nakon završetka pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ako su detektirani DTC-ovi, izbrišite ih prema uputama pod naslovom 
<intxref refid = "AHRAP70A8204006">Brisanje DTC-a</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem riješen.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
