<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1806003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa indukcijske zavojnice
</title>
<servinfosub id = "AHRAP70A1806003001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite sklop pročistača zraka. 
<intxreftitleoff1 refid = "AHRAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektore indukcijske zavojnice.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke indukcijske zavojnice (1), a zatim izvadite sklopove indukcijske zavojnice (2).
</ptxt>
<figure>
<graphic graphicname = "I7V20A180004.swf" width = "88.000mm" height = "54.310mm" ver = "01" gw = "212" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1806003002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1806004">Pregled sklopa indukcijske zavojnice</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijak indukcijske zavojnice propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1H002">
<t-part>
Vijak indukcijske zavojnice
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
