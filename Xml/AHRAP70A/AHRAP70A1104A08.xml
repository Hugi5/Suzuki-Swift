<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1104A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Velika potrošnja goriva
</title>
<ptxt>
Izvršite rješavanje problema prema sljedećim točkama kada je ECM detektirao da nema DTC-a i nisu pronađene nepravilnosti u 
<intxref refid = "AHRAP70A1104008">Vizualni pregled</intxref>
 i 
<intxref refid = "AHRAP70A1104009">Osnovni pregled motora</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Velika potrošnja goriva
</ptxt>
</condition>
<ps>
<ptxt>
Neispravna svjećica (pogrešna zračnost, mnogo naslaga i izgorene elektrode itd.)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1806002">Provjera svjećice</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Visoka brzina vrtnje motora u praznom hodu
</ptxt>
</ps>
<action>
<ptxt>
Stanje &#34;nepravilan rad motora u praznom hodu ili motor ne može raditi u praznom hodu&#34;
</ptxt>
</action>
<ps>
<ptxt>
Slabe performanse ECT senzora, MAF senzora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306012">Pregled ECT senzora</intxref>
 ili 
<intxref refid = "AHRAP70A1306026">Pregled MAF i IAT senzora</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop tijela električne zaklopke
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306004">Provjera sklopa tijela eletrične zaklopke na vozilu</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop APP senzora
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306008">Pregled APP senzora</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravne brizgaljke goriva
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1704003">Provjera kruga brizgaljke goriva</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1104070">Pregled ECM-a i njegovih krugova</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Niska kompresija
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1404001">Provjera kompresije</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slabo nasjedanje ventila
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406028">Pregled ventila i vodilica ventila</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kočnica struže
</ptxt>
</ps>
<action>
<ptxt>
Stanje &#34;kočnica struže&#34; u 
<intxref refid = "AHRAP70A4104001">Dijagnostika simptoma kočnica</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Spojka klizi
</ptxt>
</ps>
<action>
<ptxt>
Stanje &#34;spojka klizi&#34; u 
<intxref refid = "AHRAP70A5304001">Dijagnostika simptoma sustava spojke</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Termostat ne radi
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1606009">Pregled sklopa termostata (dio ECT senzora)</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Pogrešan tlak u gumama
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A2401001">Opis guma</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sustav kontrole položaja bregastog vratila (VVT)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1306027">Provjera OCV-a</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
