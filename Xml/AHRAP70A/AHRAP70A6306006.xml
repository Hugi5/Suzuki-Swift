<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A6306006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnje čahure kućišta upravljačkog prijenosnika
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A6306001">Komponente sklopa kućišta upravljačkog prijenosnika</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Pri zamjeni čahure kućišta upravljačkog prijenosa, također zamijenite čahure na suprotnoj strani od postavljenih.
</ptxt>
</attention2>
<servinfosub id = "AHRAP70A6306006001">
<title>
Uklanjanje 
</title>
<s1>
<ptxt>
Uklonite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nožem odsijecite dio prirubnice (gumu) (1) svake čahure kućišta upravljačkog prijenosnika.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630023.swf" width = "88.000mm" height = "51.406mm" ver = "01" gw = "234" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Gurnite čahuru kućišta upravljačkog prijenosa (1) korištenjem hidrauličke preše (2) i specijalnih alata.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C004">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C005">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630024.swf" width = "88.000mm" height = "49.527mm" ver = "01" gw = "104" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A6306006002">
<title>
Ugradnja
</title>
<s1>
<ptxt>
Pritiskom utisnite novu čahuru kućišta upravljačkog prijenosa (1) korištenjem specijalnih alata i preše (2).
</ptxt>
<attention2>
<ptxt>
Nemojte ponovno koristiti čahuru kućišta upravljačkog prijenosnika.
</ptxt>
</attention2>
<servicetool>
<servicetoolitem id = "L6C006">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C007">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<attention3>
<ptxt>
Prije ugradnje čahure kućišta upravljačkog prijenosnika, nanesite sapunicu po njenom obodu radi lakše ugradnje.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A630025.swf" width = "88.000mm" height = "51.452mm" ver = "01" gw = "104" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Pritiskom utisnite čahuru kućišta upravljačkog prijenosa (1) tako da dimenzije &#34;a&#34; i &#34;b&#34; na slici budu jednake.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite sklop kućišta upravljačkog prijenosnika. 
<intxreftitleoff1 refid = "AHRAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
