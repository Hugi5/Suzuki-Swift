<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1306013" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pregled A/F senzora na vozilu
</title>
<c-change/>
<servinfosub id = "AHRAP70A1306013001">
<title>
Grijač A/F senzora
</title>
<s1>
<ptxt>
Odspojite konektor A/F senzora s isključenim kontaktom.
</ptxt>
</s1>
<s1>
<ptxt>
Ommetrom izmjerite otpor konektora A/F senzora (sa strane senzora) između terminala &#34;&#34;2 i &#34;5&#34; na konektoru A/F senzora. Ako pronađete neispravnost, zamijenite A/F senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention3>
<ptxt>
Temperatura senzora značajno utječe na vrijednost otpora. Uvjerite se da je senzor grijača odgovarajuće temperature.
</ptxt>
</attention3>
<spec>
<title>
Otpor grijača A/F senzora
</title>
<ptxt>
2,4 do 4,0 &#937; pri 20 &#176;C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7N301132038.swf" width = "88.000mm" height = "30.676mm" ver = "01" gw = "67" gh = "70"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.314in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.150in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Konektor A/F senzora (gledano sa strane terminala)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1306013002" page = "2">
<title>
Regulacijski otpornik A/F senzora
</title>
<ptxt>
Pomoću ommetra izmjerite otpor između terminala &#34;1&#34; i &#34;3&#34; konektora A/F senzora. Ako pronađete neispravnost, zamijenite A/F senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<spec>
<title>
Regulacijski otpornik A/F senzora
</title>
<ptxt>
30 do 300 &#937; pri 20 &#176;C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7N301132038.swf" width = "88.000mm" height = "30.676mm" ver = "01" gw = "67" gh = "70"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.314in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.150in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Konektor A/F senzora (gledano sa strane terminala)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
