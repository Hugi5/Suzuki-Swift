<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Buka motora – buka klipnjače
</title>
<ptxt>
Izvršite rješavanje problema prema sljedećim točkama kada je ECM detektirao da nema DTC-a i nisu pronađene nepravilnosti u 
<intxref refid = "AHRAP70A1104008">Vizualni pregled</intxref>
 i 
<intxref refid = "AHRAP70A1104009">Osnovni pregled motora</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<paragroup>
<ptxt>
Buka motora – buka klipnjače
</ptxt>
<attention3>
<ptxt>
Prije provjeravanja mehaničke buke, provjerite sljedeće stavke:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Koristi se propisana svjećica.
</ptxt>
</item>
<item>
<ptxt>
Koristi se propisano gorivo.
</ptxt>
</item>
</list1>
</attention3>
</paragroup>
</condition>
<ps>
<ptxt>
Istrošen klip, prsten klipa ili provrt cilindra
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406035">Provjera cilindra, klipa i klipnog prstena</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Istrošen ležaj klipnjače
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406037">Pregled rukavca klipnjače i ležaja klipnjače</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Istrošen rukavac klipnjače
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406037">Pregled rukavca klipnjače i ležaja klipnjače</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Labavi vijci klipnjače
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHRAP70A1406033">Uklanjanje i ugradnja klipa, klipnog prstena, klipnjače i cilindra</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Niski tlak ulja
</ptxt>
</ps>
<action>
<ptxt>
Stanje &#34;niski tlak ulja&#34;
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
