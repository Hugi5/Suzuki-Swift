<servinfosub id = "AHRAP70AA504024003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</s1>
<s1>
<ptxt>
Postavite način paljenja na &#34;ACC&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Uključite kontakt.
</ptxt>
</s1>
<s1>
<ptxt>
Nekoliko puta ponovite korake 1 do 3.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA504024004">
<title>
Rješavanje problema DTC-a
</title>
<attention3>
<ptxt>
Ovaj DTC može se detektirati kada je baterija prazna ili je napon vrlo nizak.
</ptxt>
</attention3>
<diag type = "test" id = "AHRAP70AA504024005">
<testgroup id = "AHRAP70AA504024012">
<title>
Provjera parametara
</title>
<test1>
<ptxt>
Priključite SUZUKI alat za skeniranje na DLC s isključenim kontaktom.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite &#34;Relej paljenja 2&#34; prikazan na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504024006">
<title>
Provjera kruga napajanja releja IG2 (sa strane prekidača)
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uklonite relej IG2.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite odgovara li napon između kruga &#34;A3&#34; i uzemljenja naponu akumulatora.
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje i &#34;IGN2&#34; osigurač.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504024007">
<title>
Provjera osigurača
</title>
<test1>
<ptxt>
Provjerite “IG2 SIG” osigurač.
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504024008">
<title>
Provjera kruga signala releja IG2
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Otpojite konektor &#34;L10&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s &#34;L10&#34; konektorom.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu provjerite sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor između kruga &#34;B3&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B3&#34; i svakog terminala na konektoru releja IG2: beskonačan
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite &#34;IG2 SIG&#34; osigurač i upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje i zatim zamijenite &#34;IG2 SIG&#34; osigurač.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA504024009">
<title>
Provjera kruga signala releja IG2
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Otpojite konektor &#34;L10&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s &#34;L10&#34; konektorom.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu provjerite sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;B3&#34;: manji od 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B3&#34; i svakog terminala na konektoru releja IG2: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;B3&#34;: 0 - 1 V (s uključenim kontaktom)
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
