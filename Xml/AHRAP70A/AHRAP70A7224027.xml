<servinfosub id = "AHRAP70A7224027003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pokrenite motor i uključite sustav klima uređaja.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7224027004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A7224027005">
<testgroup id = "AHRAP70A7224027006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt i provjerite DTC.
</ptxt>
</test1>
<question>
Detektiraju li se i dalje DTC-i B1550-H ili B1550-L?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Isprekidani problem.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224027007">
<title>
Provjera strujnog kruga komunikacije
</title>
<test1>
<ptxt>
Odspojite konektore “G20” i “G227”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga žice “PNK/BLU”: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor kruga žice “PNK/BLU” između aktuatora kontrole temperature i uzemljenja: beskonačan
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li vrijednosti otpora unutar specifikacija?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite ispravnim upravljačkim modulom HVAC sustava i/ili pločom automatskog klima uređaja i ponovno provjerite DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Upravljački modul HVAC sustava: 
<intxreftitleoff1 refid = "AHRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ploča automatskog klima uređaja: 
<intxreftitleoff1 refid = "AHRAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
</diag>
