</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70AA804004">Rješavanje problema isključene sabirnice komunikacije</intxref>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
</testgroup>
