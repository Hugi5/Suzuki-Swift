<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja prednjeg blatobrana
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9A06004">Komponente prednjeg blatobrana</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9A06005001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite prednji odbojnik i držač prednjeg odbojnika. 
<intxreftitleoff1 refid = "AHRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite gornju oblogu poprečnog veznog lima s pripadajućom bočnom gornjom oblogom. 
<intxreftitleoff1 refid = "AHRAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite jedinicu prednjih svjetala. 
<intxreftitleoff1 refid = "AHRAP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite bočni pokazivač smjera. 
<intxreftitleoff1 refid = "AHRAP70A9206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite zaštitu bočnog praga. 
<intxreftitleoff1 refid = "AHRAP70A9806007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite oblogu prednjeg blatobrana.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite prednji blatobran i zaštitu prednjeg blatobrana.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9A06005002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prilagodite zračnost prednjeg blatobrana. 
<intxreftitleoff1 refid = "AHRAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ako se sastruže boja s vijka prednjeg blatobrana, obavezno je ponovo nanesite kako biste spriječili stvaranje hrđe.
</ptxt>
</item>
<item>
<ptxt>
Nakon ugradnje namjestite usmjerenost prednjeg svjetla. 
<intxreftitleoff1 refid = "AHRAP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
