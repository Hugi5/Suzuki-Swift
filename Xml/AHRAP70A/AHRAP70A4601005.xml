<servinfosub id = "AHRAP70A4601005001">
<title>
Uvjeti i rad svjetala upozorenja i indikatorskih svjetala
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.188in"/>
<colspec colnum = "2" colname = "2" colwidth = "5.021in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Svjetlo upozorenja/indikatorsko svjetlo
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Stanje i rad
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Svjetlo upozorenja ABS-a
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Ako postoji nepravilnost u ABS-u, svjetlo se uključuje.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Svjetlo upozorenja EBD-a (svjetlo upozorenja kočnice)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Ako postoji nepravilnost u sustavu EBD-a, svjetlo se uključuje zajedno sa svjetlom upozorenja ABS-a i svjetlom upozorenja ESP<sup>®</sup>-a.
</ptxt>
</item>
<item>
<ptxt>
Ako je razina kočne tekućine u spremniku niža od minimalne razine, svjetlo se uključuje.
</ptxt>
</item>
<item>
<ptxt>
Ako je poluga parkirne kočnice zategnuta, svjetlo se uključuje.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Svjetlo upozorenja ESP<sup>®</sup>-a
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Ako postoji nepravilnost u sustavu ESP<sup>®</sup>-a, svjetlo se uključuje.
</ptxt>
</item>
<item>
<ptxt>
Ako su upravljanje stabilnošću i/ili upravljanje vučom aktivni, svjetlo trepti.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Svjetlo ESP<sup>®</sup> OFF
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Svjetlo ESP<sup>®</sup> OFF se uključuje da bi pokazalo da sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a obustavlja funkcije upravljanja vučom i stabilnošću.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
