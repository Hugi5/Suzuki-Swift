<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A2104A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Karoserija se naginje ili leluja u zavojima
</title>
<diag type = "condition">
<condition>
<ptxt>
Karoserija se naginje ili leluja u zavojima
</ptxt>
</condition>
<ps>
<ptxt>
Labava stabilizatorska šipka
</ptxt>
</ps>
<action>
<ptxt>
Zategnite vijke stabilizatorske šipke ili matice ili zamijenite čahure. 
<intxreftitleoff1 refid = "AHRAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravni sklop prednje opružne noge (amortizer) ili nosač
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop prednje opružne noge (amortizer) ili zategnite nosač. 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slomljene ili uleknute zavojne opruge
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zamijenite zavojne opruge. 
</ptxt>
<ptxt>
Prednja: 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Stražnja: 
<intxreftitleoff1 refid = "AHRAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Preopterećeno vozilo
</ptxt>
</ps>
<action>
<ptxt>
Provjerite opterećenje.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
