<servinfosub id = "AHRAP70A1104014003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Nije detektiran DTC P0010 ili P0013.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Pokrenite motor i vozite vozilo brzinom od 60 do 80 km/h (37 do 50 milja/h), uz brzinu vrtnje motora od 1600 okr./min. ili veću, više od 10 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104014004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104014005">
<testgroup id = "AHRAP70A1104014006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104014007">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC.
</ptxt>
</test1>
<question>
Postoje li DTC-ovi osim P0011 i P0014?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajući DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104014008">
<title>
Provjera kruga napajanja OCV-a i pogonskog kruga OCV-a
</title>
<test1>
<ptxt>
Provjerite krugove &#34;A1&#34; ili &#34;B1&#34; i &#34;A2&#34; ili &#34;B2&#34; prema koracima 2 do 3 u poglavlju 
<intxref refid = "AHRAP70A1104013">DTC P0010/P0013/P2088/P2089/P2090/P2091</intxref>
.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104014009">
<title>
Provjera tlaka ulja
</title>
<test1>
<ptxt>
Provjerite tlak ulja. 
<intxreftitleoff1 refid = "AHRAP70A1504001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104014010">
<title>
Vizualni pregled kruga ulja OCV-a
</title>
<test1>
<ptxt>
Uklonite poklopac glave motora. 
<intxreftitleoff1 refid = "AHRAP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite otpuštanje tlaka ulja iz kruga ulja OCV-a.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 6. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104014011">
<title>
Provjera CKP senzora i ploče senzora
</title>
<test1>
<ptxt>
Provjerite CKP senzor i ploču senzora.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pregled CKP senzora: 
<intxreftitleoff1 refid = "AHRAP70A1306020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pregled ploče senzora: 
<intxreftitleoff1 refid = "AHRAP70A1406042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 7. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104014012">
<title>
Provjera CMP senzora i signalnog rotora
</title>
<test1>
<ptxt>
Provjerite CMP senzor i signalni rotor. 
<intxreftitleoff1 refid = "AHRAP70A1306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 8. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104014013">
<title>
Provjera OCV-a
</title>
<test1>
<ptxt>
Provjerite OCV. 
<intxreftitleoff1 refid = "AHRAP70A1306027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 9. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite OCV. 
<intxreftitleoff1 refid = "AHRAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104014014">
<title>
Provjera aktuatora CMP-a
</title>
<test1>
<ptxt>
Provjerite aktuator CMP-a. 
<intxreftitleoff1 refid = "AHRAP70A1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 10. korak. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite aktuator CMP-a. 
<intxreftitleoff1 refid = "AHRAP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104014015">
<title>
Provjera vremena otvaranja ventila
</title>
<test1>
<ptxt>
Provjerite dijelove povezane s lancem razvodnog mehanizma i njihove uvjete ugradnje. 
<intxreftitleoff1 refid = "AHRAP70A1406023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ponovo ispravno ugradite dijelove povezane s lancem razvodnog mehanizma ili zamijenite neispravne dijelove.
</ptxt>
</action>
