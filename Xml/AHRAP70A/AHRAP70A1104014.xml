<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0011: Preuranjen pomak položaja ili performanse sustava bregastog vratila &#34;A&#34;
</emph>
</ptxt>
<ptxt>
Izmjereni CMP na strani usisa ne doseže ciljani CMP na strani usisa tijekom propisanog vremena.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
