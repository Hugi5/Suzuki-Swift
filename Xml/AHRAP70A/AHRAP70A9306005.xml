<servinfo servinfosgmlid = "AHRAP70A9306005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja parkirnog senzora (ako je dio opreme)
</title>
<servinfosub id = "AHRAP70A9306005001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite stražnji odbojnik. 
<intxreftitleoff1 refid = "AHRAP70A9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor parkirnog senzora.
</ptxt>
</s1>
<s1>
<ptxt>
Skinite poklopac parkirnog senzora (1) na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930025.jpg" width = "88.000mm" height = "106.836mm" ver = "01" gw = "208" gh = "286"/>
</figure>
</s1>
<s1>
<ptxt>
Otpustite štipaljke (1), a zatim uklonite parkirni senzor (2) na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930026.jpg" width = "88.000mm" height = "63.752mm" ver = "01" gw = "196" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Po potrebi uklonite nosač senzora.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9306005002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9306006">Pregled parkirnog senzora (ako je dio opreme)</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Mjesto na kojem ćete ugraditi nosač senzora (1) očistite od tragova maziva ili prljavštine.
</ptxt>
</item>
<item>
<ptxt>
Nanesite bazni premaz (ekvivalent premaza SUMITOMO 3M K-520 ili 4298UV) na područje na koje ćete ugraditi senzor.
</ptxt>
</item>
<item>
<ptxt>
Ugradite nosač senzora u smjeru kao što je prikazano na slici.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A930039.jpg" width = "88.000mm" height = "98.016mm" ver = "01" gw = "199" gh = "261"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
