<section sectnbr = "2B">
<servcat sctnbr = "02" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A2206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja prednje čahure ramena ovjesa
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A2206008">Uklanjanje i ugradnja ramena ovjesa</intxrefpoff>
</ptxt>
<attention3>
<ptxt>
Stražnju čahuru ramena ovjesa nije moguće zasebno mijenjati. Ako je čahura neispravna, zamijenite rame ovjesa.
</ptxt>
</attention3>
<servinfosub id = "AHRAP70A2206010001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Nožem odrežite prirubnicu prednje čahure ramena ovjesa (guma) (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A220022.jpg" width = "88.000mm" height = "56.949mm" ver = "01" gw = "238" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Gurnite prednju čahuru okvira prednjeg ovjesa (1) korištenjem hidraulične preše (2) i specijalnog alata.
</ptxt>
<servicetool>
<servicetoolitem id = "L2B003">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L2B004">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A220023.swf" width = "88.000mm" height = "48.435mm" ver = "01" gw = "173" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A2206010002">
<title>
Ugradnja
</title>
<s1>
<ptxt>
Pritiskom utisnite prednju čahuru ramena ovjesa (1) upotrebom specijalnih alata i hidraulične preše (2).
</ptxt>
<attention2>
<ptxt>
Čahuru ne upotrebljavajte ponovno.
</ptxt>
</attention2>
<attention3>
<ptxt>
Prije ugradnje čahure, nanesite sapunicu po njenom obodu radi lakše ugradnje.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L2B005">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L2B006">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A220024.swf" width = "88.000mm" height = "48.773mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Pritiskom utisnite prednju čahuru prednjeg ramena ovjesa (1) tako da dimenzije &#34;a&#34; i &#34;b&#34; na slici budu jednake.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
