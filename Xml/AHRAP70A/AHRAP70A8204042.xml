<servinfosub id = "AHRAP70A8204042003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204042004">
<testgroup id = "AHRAP70A8204042005">
<question>
Je li izvršena “Provjera dijagnostičkog sustava zračnih jastuka”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204042006">
<title>
Provjera prekidača za deaktivaciju zračnog jastuka suvozača
</title>
<test1>
<ptxt>
Uklonite prekidač za deaktivaciju zračnog jastuka suvozača.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja s konektorom “G168”.
</ptxt>
</test1>
<test1>
<ptxt>
Pregledajte prekidač za deaktivaciju zračnog jastuka suvozača. 
<intxreftitleoff1 refid = "AHRAP70A8206027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li prekidač za deaktivaciju zračnog jastuka suvozača u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite prekidač za deaktivaciju zračnog jastuka suvozača.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204042007">
<title>
Pregled kruga prekidača za deaktivaciju zračnog jastuka suvozača
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “G11”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja s “G11-16” i “G11-17”.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite otpor između “G11-16” i “G168-1”.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite otpor između “G11-17” i “G168-2”.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B078">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820029.swf" width = "90.000mm" height = "56.862mm" ver = "01" gw = "217" gh = "145"/>
</testfigure>
</test1>
<question>
Je li izmjereni otpor 1&#937; ili manji?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204042008">
<title>
Pregled kruga prekidača za deaktivaciju zračnog jastuka suvozača
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon između svakog od terminala “G11-16” i “G11-17” i uzemljenja: približno 0 V
</ptxt>
<servicetool>
<servicetoolitem id = "L8B079">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820056.swf" width = "90.000mm" height = "55.764mm" ver = "01" gw = "203" gh = "142"/>
</testfigure>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite SDM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po završetku pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ako su detektirani DTC-ovi, izbrišite ih prema uputama pod naslovom 
<intxref refid = "AHRAP70A8204006">Brisanje DTC-a</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem riješen.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
