<servinfosub id = "AHRAP70A8204049003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204049004">
<testgroup id = "AHRAP70A8204049005">
<question>
Je li izvršena “Provjera dijagnostičkog sustava zračnih jastuka”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204049006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite detektira li se bilo koji od sljedećih DTC-ova. 
<intxreftitleoff1 refid = "AHRAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
B1392 ili B1393 (DTC B1390, B1391 ili DTC B1394)
</ptxt>
</item>
<item>
<ptxt>
B1397 ili B1398 (DTC B1395, B1396 ili DTC B1399)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li detektiran odgovarajući DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na odgovarajuće rješavanje problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204049007">
<title>
Provjera stražnjeg senzora bočnog udara
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Zamijenite stražnji senzor bočnog udara. 
<intxreftitleoff1 refid = "AHRAP70A8206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li otkriven DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite SDM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Po završetku pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ako su detektirani DTC-ovi, izbrišite ih prema uputama pod naslovom 
<intxref refid = "AHRAP70A8204006">Brisanje DTC-a</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem riješen.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
