<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70AA316001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja upravljačkog modula blokade motora
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Kako se upravljački modul blokade motora sastoji od preciznih dijelova, pazite da ga ne izložite pretjeranim potresima.
</ptxt>
</item>
<item>
<ptxt>
Ne rastavljajte upravljački modul blokade motora.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AHRAP70AA316001001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Isključite kontakt.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite gornje i donje poklopce stupa upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Odspojite konektor (1) iz upravljačkog modula blokade motora (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijak (3) iz upravljačkog modula blokade motora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite upravljački modul blokade motora iz sklopa brave upravljača kako je prikazano na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA31004.jpg" width = "88.000mm" height = "60.854mm" ver = "01" gw = "197" gh = "156"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA316001002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
