<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3116003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa prednjeg pogonskog vratila
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3116001">Dijelovi prednjeg pogonskog vratila:Sprijeda</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A3116002">Provjera sklopa pogonskog vratila na vozilu:Sprijeda</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A3116003001">
<title>
Uklanjanje
</title>
<s1 page = "2">
<ptxt>
Podignite vozilo i uklonite prednji kotač. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Skinite osigurač (1) i uklonite maticu pogonskog vratila (2) dok je papučica kočnice pritisnuta.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311002.swf" width = "88.000mm" height = "54.100mm" ver = "01" gw = "182" gh = "137"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Ispustite ulje međumjenjača i ulje mjenjača.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ulje mjenjača: 
<intxreftitleoff1 refid = "AHRAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ulje međumjenjača: 
<intxreftitleoff1 refid = "AHRAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Uklonite senzor brzine prednjih kotača s kutne poluge. 
<intxreftitleoff1 refid = "AHRAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odspojite zglob ramena ovjesa s kutne poluge. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Polugom za gumu (1) ili plastičnim čekićem (3) odvojite zglob pogonskog vratila (2).
</ptxt>
<attention3>
<ptxt>
Zakretanje pogonskog vratila tijekom njegova izvlačenja olakšat će otpuštanje uskočnika sa žlijeba zgloba.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A311004.swf" width = "88.000mm" height = "41.941mm" ver = "01" gw = "197" gh = "102"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.298in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.298in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lijeva osovina
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Vratilo s desne strane
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Uklonite sklop pogonskog vratila.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A3116003002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Pazite da ne oštetite brtve ulja i manžete prilikom ugradnje pogonskog vratila.
</ptxt>
</item>
<item>
<ptxt>
Ne udarajte manžetu zgloba čekićem. Zglob možete umetnuti rukama.
</ptxt>
</item>
<item>
<ptxt>
Uvjerite se da je zglob na strani diferencijala potpuno umetnut i da se uskočnik nalazi na mjestu na koje je ugrađen.
</ptxt>
</item>
<item>
<ptxt>
Prije umetanja pogonskog vratila (1) uvjerite se da nema strane tvari oko enkodera (2) na ležaju kotača.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311003.swf" width = "88.000mm" height = "51.493mm" ver = "01" gw = "203" gh = "129"/>
</figure>
</item>
</list1>
</attention2>
<list1 type = "unordered">
<item>
<ptxt>
Upotrijebite novi uskočnik za zglob na strani diferencijala.
</ptxt>
</item>
<item>
<ptxt>
Nanesite mast na dodirnu površinu glavčine prednjeg kotača i pogonskog vratila.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A101" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A311005.jpg" width = "88.000mm" height = "67.700mm" ver = "01" gw = "230" gh = "175"/>
</figure>
</item>
<item>
<ptxt>
Zategnite maticu pogonskog vratila (1) propisanim momentom pritezanja.
</ptxt>
<attention2>
<ptxt>
Svakako koristite novu maticu pogonskog vratila.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T3A101">
<t-part>
Matica pogonskog vratila
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Osigurajte spoj matice pogonskog vratila (1) kao što je prikazano.
</ptxt>
<attention2>
<ptxt>
Pazite da ne slomite brtvilo matice (2) pogonskog vratila dok brtvite. Ako se slomi, zamijenite novim.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A311006.swf" width = "88.000mm" height = "54.205mm" ver = "01" gw = "172" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Spojite zglob ramena ovjesa. 
<intxreftitleoff1 refid = "AHRAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ugradite senzor brzine prednjeg kotača. 
<intxreftitleoff1 refid = "AHRAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ugradite prednji kotač. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nadopunite ulje mjenjača. 
<intxreftitleoff1 refid = "AHRAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nadopunite ulje međumjenjača. 
<intxreftitleoff1 refid = "AHRAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Provjerite geometriju prednjeg kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
