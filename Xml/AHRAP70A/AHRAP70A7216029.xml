<title>
Uklanjanje i ugradnja rešetke središnjeg otvora za provjetravanje
</title>
<servinfosub id = "AHRAP70A7216029001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite rešetku središnjeg otvora za provjetravanje s ploče s instrumentima. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor prekidača svih pokazivača smjera.
</ptxt>
</s1>
<s1>
<ptxt>
Otpustite zaponce (2) pa odvojite rešetku središnjeg otvora za provjetravanje (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A721028.swf" width = "88.000mm" height = "58.762mm" ver = "02" gw = "215" gh = "150"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7216029002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
