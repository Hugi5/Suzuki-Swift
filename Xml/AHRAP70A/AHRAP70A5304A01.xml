<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Klizanje
</title>
<diag type = "condition">
<condition>
<ptxt>
Klizanje
</ptxt>
</condition>
<ps>
<ptxt>
Neodgovarajući slobodni hod papučice spojke
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite glavni cilindar i/ili polugu papučice spojke.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Poluga papučice spojke: 
<intxreftitleoff1 refid = "AHRAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Glavni cilindar spojke: 
<intxreftitleoff1 refid = "AHRAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Istrošene ili nauljene obloge diska spojke
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite disk spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformiran disk, potisna ploča ili površina zamašnjaka
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zamijenite disk spojke, poklopac spojke ili zamašnjak.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Disk i poklopac spojke: 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Zamašnjak: 
<intxreftitleoff1 refid = "AHRAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Oslabljena tanjurasta opruga
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite poklopac spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Klip glavnog cilindra ili čašica brtve se ne vraća
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite glavni cilindar spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
