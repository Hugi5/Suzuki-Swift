<title>
Vratašca za usis zraka se ne mijenjaju čak i ako je promijenjen način ulaza zraka
</title>
<diag type = "condition">
<condition>
<ptxt>
Vratašca za usis zraka se ne mijenjaju čak i ako je promijenjen način ulaza zraka
</ptxt>
</condition>
<ps>
<ptxt>
Pregorjeli osigurač
</ptxt>
</ps>
<action>
<ptxt>
Provjerite povezane osigurače, a zatim provjerite postoji li kratki spoj s uzemljenjem.
</ptxt>
</action>
<ps>
<ptxt>
Razbijena vratašca za usis zraka
</ptxt>
</ps>
<action>
<ptxt>
Popravite vratašca za usis zraka.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan aktuator kontrole usisa zraka
</ptxt>
</ps>
<action>
<ptxt>
Provjerite aktuator kontrole usisa zraka. 
<intxreftitleoff1 refid = "AHRAP70A7216027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravna sklopka za ulaz zraka
</ptxt>
</ps>
<action>
<ptxt>
Provjerite sklopka za ulaz zraka. 
<intxreftitleoff1 refid = "AHRAP70A7216025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravno ožičenje ili uzemljenje
</ptxt>
</ps>
<action>
<ptxt>
Popravite ožičenje.
</ptxt>
</action>
</diag>
