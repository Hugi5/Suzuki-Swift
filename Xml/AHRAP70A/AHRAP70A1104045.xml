<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1104045" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0606
</title>
<servinfosub id = "AHRAP70A1104045001">
<title>
Detektirano stanje DTC-a i problematično područje
</title>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.087in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.117in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Detektirano stanje DTC-a
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Problematično područje
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0606: Procesor upravljačkog modula
</emph>
</ptxt>
<ptxt>
Neispravan interni procesor ECM-a.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Krug napajanja i/ili krug uzemljenja ECM-a
</ptxt>
</item>
<item>
<ptxt>
A/F senzor
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHRAP70A1104045002">
<title>
Opis sustava
</title>
<ptxt>
Interni upravljački modul je ugrađen u ECM.
</ptxt>
</servinfosub>
<servinfosub id = "AHRAP70A1104045003">
<title>
Postupak potvrde DTC-a
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Napon akumulatora &#62; 10,7 V
</ptxt>
</item>
<item>
<ptxt>
Nije detektiran DTC P0030, P0031, P0032, P0131 ili P0132.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Pustite neka motor radi u praznom hodu 1 minutu.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104045004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104045005">
<testgroup id = "AHRAP70A1104045006">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Izbrišite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Obavite postupak potvrde DTC-a i provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC C0606?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite postoje li isprekidani problemi. 
<intxreftitleoff1 refid = "AHRAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104045007">
<title>
Provjera kruga napajanja i uzemljenja ECM-a
</title>
<test1>
<ptxt>
Provjerite krug napajanja i uzemljenja ECM-a. 
<intxreftitleoff1 refid = "AHRAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104045008">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite A/F senzor. 
<intxreftitleoff1 refid = "AHRAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Obavite postupak potvrde DTC-a i provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC C0606?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
