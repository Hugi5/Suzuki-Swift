<intxreftitleoff1 refid = "AHRAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac spojke i lamelu spojke, ako je potrebno. 
<intxreftitleoff1 refid = "AHRAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite zamašnjak ako je potrebno. 
<intxreftitleoff1 refid = "AHRAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1406016002" page = "2">
<title>
Ugradnja
</title>
<s1>
