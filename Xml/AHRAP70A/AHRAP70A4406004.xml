<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4D">
<servcat sctnbr = "04" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A4406004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sajle parkirne kočnice
</title>
<servinfosub id = "AHRAP70A4406004001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite sajlu parkirne kočnice s poluge kliješta stražnje kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4306007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite stražnju kutiju podne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite sajlu parkirne kočnice s vozila. 
<intxreftitleoff1 refid = "AHRAP70A4406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<attention3>
<ptxt>
Ako je potrebno ukloniti i desnu i lijevu sajlu parkirne kočnice, ponovite gore opisane korake.
</ptxt>
</attention3>
</servinfosub>
<servinfosub id = "AHRAP70A4406004002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pravilno ugradite obujmice. 
<intxreftitleoff1 refid = "AHRAP70A4406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pritegnite sve vijke propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A4406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Provjerite da je kraj sajle parkirne kočnice čvrsto ugrađen na kompenzator i polugu kliješta stražnje kočnice.
</ptxt>
</item>
<item>
<ptxt>
Namjestite sajlu parkirne kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nakon dovršetka ugradnje i namještanja hoda poluge parkirne kočnice, uvjerite se da sustav kočnice radi pravilno.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
