<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70AA506006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stražnje vanjske antene
</title>
<servinfosub id = "AHRAP70AA506006001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite stražnji odbojnik. 
<intxreftitleoff1 refid = "AHRAP70A9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor (1), te zatim uklonite stražnju vanjsku antenu (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50025.swf" width = "88.000mm" height = "54.582mm" ver = "01" gw = "176" gh = "138"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA506006002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70AA506010">Pregled antene</intxrefpoff>
</ptxt>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
