<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1906007" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rastavljanje i sastavljanje elektropokretača
</title>
<servinfosub id = "AHRAP70A1906007001">
<title>
Rastavljanje
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1906002">Uklanjanje i ugradnja elektropokretača</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A1906004">Komponente elektropokretača</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Prije rastavljanja nacrtajte oznake poravnanja (1) i (2) kako je prikazano na slici da biste osigurali pravilno poravnanje prilikom sastavljanja.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190005.swf" width = "88.000mm" height = "55.476mm" ver = "01" gw = "121" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite maticu (1) i odspojite vodič (2) s magnetskog prekidača (3).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190006.swf" width = "88.000mm" height = "55.476mm" ver = "01" gw = "145" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vijke (4) i izvucite magnetski prekidač (1) sa sklopa elektropokretača.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite oprugu (2) i zapinjač (3) s tijela magnetskog prekidača.
</ptxt>
<attention2>
<ptxt>
Ne rastavljajte tijelo magnetskog prekidača.
</ptxt>
<ptxt>
Zamijenite tijelo magnetskog prekidača ako je potrebno.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I8C50B190007.swf" width = "88.000mm" height = "72.205mm" ver = "01" gw = "137" gh = "188"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vijke (1) pa razdvojite stator od kućišta rotora (2).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190008.swf" width = "88.000mm" height = "61.193mm" ver = "01" gw = "192" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite umetak (2) i planetne zupčanike (1).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190009.swf" width = "88.000mm" height = "39.697mm" ver = "01" gw = "134" gh = "96"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite gumenu brtvu (1) i pločicu (2).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190010.swf" width = "88.000mm" height = "55.234mm" ver = "01" gw = "170" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite sklop vratila (1) zajedno s pogonskom polugom (2).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190011.swf" width = "88.000mm" height = "47.402mm" ver = "01" gw = "164" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Pomaknite granični prsten zupčanika (3) prema strani sigurnosne spojke (4) (u smjeru strjelice), pa kliještima (5) uklonite uskočnik (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite granični prsten zupčanika (3), sigurnosnu spojku (4) i zupčanik s unutarnjim ozubljenjem (1) s vratila stupnja prijenosa.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190012.swf" width = "88.000mm" height = "39.316mm" ver = "01" gw = "163" gh = "94"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite poklopac kućišta (1) i uklonite sklop četkica (2) sa statora (3).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190013.swf" width = "88.000mm" height = "55.771mm" ver = "01" gw = "226" gh = "142"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite stator (2) s rotora (1).
</ptxt>
<figure>
<graphic graphicname = "I8C50B190014.swf" width = "88.000mm" height = "47.593mm" ver = "02" gw = "181" gh = "118"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite četkice (1) i opruge četkica (2).
</ptxt>
<figure>
<graphic graphicname = "I6JB01190014.swf" width = "88.000mm" height = "66.987mm" ver = "01" gw = "140" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1906007002">
<title>
Ponovno sastavljanje
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1906009">Pregled elektropokretača</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Ugradite oprugu četkica (2) i četkice (1) na držač četkica (3).
</ptxt>
<figure>
<graphic graphicname = "I6JB01190015.swf" width = "88.000mm" height = "66.987mm" ver = "01" gw = "140" gh = "173"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite stator (2) na rotor.
</ptxt>
</s1>
<s1>
<ptxt>
Postavite sklop četkica (1) na rotor (2) dok gurate 4 četkice (3) prema van.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190015.swf" width = "88.000mm" height = "90.437mm" ver = "01" gw = "193" gh = "240"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite poklopac kućišta (1) na držač četkica i pritegnite vijke držača četkica (2) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1I003">
<t-part>
Vijak držača četkice
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3,5
</t-value1>
<t-value2>
0,36
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190016.swf" width = "88.000mm" height = "49.914mm" ver = "01" gw = "183" gh = "125"/>
</figure>
</s1>
<s1>
<ptxt>
Nanesite mast na žlijeb vratila stupnja prijenosa (1) i zupce zupčanika s unutarnjim ozubljenjem (2).
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I001" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A191019.swf" width = "88.000mm" height = "31.442mm" ver = "01" gw = "205" gh = "72"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite zupčanik s unutarnjim ozubljenjem i sigurnosnu spojku (1) na vratilo stupnja prijenosa (4) s novim uskočnikom (3) i graničnim prstenom zupčanika (2).
</ptxt>
<attention3>
<ptxt>
Ugradite granični prsten zupčanika u smjeru i na mjesto koji su prikazani na slici.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IYSQ01190024.swf" width = "88.000mm" height = "42.999mm" ver = "01" gw = "159" gh = "105"/>
</figure>
</s1>
<s1>
<ptxt>
Nanesite mast na pogonsku polugu (2) i umetnite sklop vratila (1) u kućište rotora tako da pogonsku polugu namjestite kako je prikazano na slici.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I002" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAY301190005.swf" width = "88.000mm" height = "47.402mm" ver = "02" gw = "164" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Poravnajte otvore vijaka kućišta rotora (3) i izreze u umetku pa ugradite umetak (1) na kućište rotora.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite ploču (5) i gumenu brtvu (4) na kućište rotora.
</ptxt>
</s1>
<s1>
<ptxt>
Nanesite mast na planetne zupčanike (2) pa postavite planetne zupčanike na vratilo stupnja prijenosa.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I003" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I8C50B190019.swf" width = "88.000mm" height = "58.155mm" ver = "01" gw = "176" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite stator, rotor, sklop četkica i poklopac kućišta (4) u kućište rotora (2) poravnavajući oznake za poravnanje (3) koje ste napravili prije rastavljanja.
</ptxt>
</s1>
<s1>
<ptxt>
Vijke poklopca kućišta (1) zategnite propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1I004">
<t-part>
Vijak poklopca kućišta
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190020.swf" width = "88.000mm" height = "62.840mm" ver = "01" gw = "192" gh = "162"/>
</figure>
</s1>
<s1>
<ptxt>
Nanesite mast na zapinjač.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I004" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I8C50B190021.swf" width = "88.000mm" height = "54.810mm" ver = "01" gw = "142" gh = "138"/>
</figure>
</s1>
<s1>
<ptxt>
Postavite magnetski prekidač (1), oprugu (2) i zapinjač (3) na kućište rotora (5) poravnavajući oznake poravnanja koje ste napravili prije uklanjanja.
</ptxt>
</s1>
<s1>
<ptxt>
Pritegnite vijke (4) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1I005">
<t-part>
Vijak magnetskog prekidača
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190022.swf" width = "88.000mm" height = "72.616mm" ver = "01" gw = "137" gh = "189"/>
</figure>
</s1>
<s1>
<ptxt>
Spojite vodič (1) na terminal &#34;M&#34; (2) pa zategnite maticu vodiča propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1I006">
<t-part>
Matica vodiča
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190023.swf" width = "88.000mm" height = "55.487mm" ver = "01" gw = "145" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Provjerite rad magnetskog prekidača. 
<intxreftitleoff1 refid = "AHRAP70A1906009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
