<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3406004" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Rastavljanje i sastavljanje sklopa kardanskog vratila
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3406002">Uklanjanje i postavljanje kardanskog vratila</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A3406004001">
<title>
Rastavljanje
</title>
<s1>
<ptxt>
Prije rastavljanja kardanskog vratila, označite mjesta (1) na prirubnici zgloba (2), viskoznoj spojci (3) i vratilu spojke (4) kao što je prikazano.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite kardansko vratilo br. 1 (5), br. 2 (7) i središnje vratilo (6).
</ptxt>
<figure>
<graphic graphicname = "IAP70A340008.swf" width = "88.000mm" height = "38.820mm" ver = "01" gw = "197" gh = "94"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A3406004002">
<title>
Ponovno sastavljanje
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3406005">Rastavljanje i sastavljanje spojke</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka rastavljanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kada rastavljate sklop kardanskog vratila, poravnajte označena mjesta (1). U protivnom može doći do vibracija u vožnji.
</ptxt>
</item>
<item>
<ptxt>
Zategnite matice središnje spojke i vijke kardanskog vratila br. 2 propisanim momentom pritezanja.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T3D003">
<t-part>
Matica središnje spojke
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
<torqueitem id = "T3D004">
<t-part>
Vijak kardanskog vratila br. 2
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
