<servinfosub id = "AHRAP70A7224023003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pokrenite motor i uključite sustav klima uređaja.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7224023004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A7224023005">
<testgroup id = "AHRAP70A7224023006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt i provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se DTC B1540 i dalje?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Isprekidani problem.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224023008">
<title>
Provjera osigurača
</title>
<test1>
<ptxt>
Provjerite &#34;MTR&#34; osigurač.
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite osigurač “MTR” i provjerite uzemljenje radi kratkog spoja.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224023007">
<title>
Provjera kruga napajanja naponom akumulatora
</title>
<test1>
<ptxt>
Odspojite konektor ploče automatskog klima uređaja.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite napon između terminala žice “WHT/RED” konektora ploče automatskog klima uređaja i uzemljenja.
</ptxt>
</test1>
<question>
Je li napon 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ploču automatskog klima uređaja. 
<intxreftitleoff1 refid = "AHRAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
</diag>
