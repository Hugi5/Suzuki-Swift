<servinfo servinfosgmlid = "AHRAP70AA206004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja senzora temperature zraka u okolini
</title>
<servinfosub id = "AHRAP70AA206004001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni (–) kabel s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite prednji odbojnik. 
<intxreftitleoff1 refid = "AHRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Iskopčajte konektor (1) iz senzora temperature zraka u okolini.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite senzor temperature zraka u okolini (2) s nosača prednjeg odbojnika.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20018.jpg" width = "88.000mm" height = "67.914mm" ver = "01" gw = "210" gh = "176"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA206004002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70AA206005">Pregled senzora temperature zraka u okolini</intxrefpoff>
</ptxt>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
