<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stakla stražnjih vrata
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9506014">Komponente stražnjih vrata</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9506015001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Staklo stražnjih vrata spustite do kraja.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite negativni (–) kabel s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite unutarnju oblogu stražnjih vrata (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac unutarnje ručke (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke (3) i kopču (B), a zatim uklonite oblogu vrata (4) povlačeći ju u smjeru strelice te odspojite konektore ožičenja vrata.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950037.jpg" width = "88.000mm" height = "109.011mm" ver = "01" gw = "227" gh = "292"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vanjsku brtvu prednjih vrata (1) pomičući ju u smjerovima strjelice redoslijedom (“1” do “2”) na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950038.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.176in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.475in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Zaponac
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Vanjska ploča stražnjih vrata
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Uklonite unutarnju brtvu stražnjih vrata (1) pomičući ju u smjerovima strjelice redoslijedom (“1” do “2”) na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950039.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.905in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Unutarnja ploča stražnjih vrata
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Uklonite nosač obloge vrata (1) i zaštitnu foliju (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950040.jpg" width = "88.000mm" height = "91.844mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Okrenite vodilicu stakla (1), a zatim uklonite vijak okvira stakla stražnjih vrata (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke okvira stakla stražnjih vrata (3), a zatim okvir (4) i vodilicu stakla.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950041.jpg" width = "88.000mm" height = "80.089mm" ver = "02" gw = "211" gh = "211"/>
</figure>
</s1>
<s1>
<ptxt>
Okrenite staklo stražnjih vrata (1) u smjeru strjelice “1” da biste uklonili donji kanal stakla (3) sa sklopa regulatora stražnjeg prozora (2) pa uklonite staklo stražnjih vrata u smjeru strjelice “2”.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950042.jpg" width = "88.000mm" height = "97.155mm" ver = "01" gw = "227" gh = "259"/>
</figure>
</s1>
<s1>
<ptxt>
Ako je potrebno, uklonite donji kanal stakla sa stakla stražnjih vrata.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9506015002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ako je uklonjen sa stakla stražnjih vrata, postavite donji kanal stakla (1) na zadani položaj na stakla stražnjih vrata (2).
</ptxt>
<spec>
<title>
Položaj za ugradnju stakla stražnjih vrata
</title>
<ptxt>
“a”: 17 – 19 mm (0,67 – 0,74 in)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A950043.jpg" width = "88.000mm" height = "69.916mm" ver = "01" gw = "227" gh = "182"/>
</figure>
</item>
<item>
<ptxt>
Umetnite staklo stražnjih vrata (3) u smjeru strjelice “1” i zakrenite u smjeru strjelice “2” da biste pomaknuli donji kanal stakla (1) u smjeru strjelice “3” i postavili na sklop regulatora stražnjeg prozora (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950044.jpg" width = "88.000mm" height = "97.155mm" ver = "01" gw = "227" gh = "259"/>
</figure>
</item>
<item>
<ptxt>
Pritegnite vijak i matice okvira stakla stražnjih vrata redoslijedom “1” do “3” propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9E004">
<t-part>
Vijak okvir stakla stražnjih vrata*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3,0
</t-value1>
<t-value2>
0,31
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
<torqueitem id = "T9E005">
<t-part>
Vijak okvira stakla stražnjih vrata*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950045.jpg" width = "88.000mm" height = "80.089mm" ver = "04" gw = "227" gh = "211"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.426in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.176in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Okvir stakla stražnjih vrata
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Vodilica stakla
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Ako je vodilica stakla oštećena, popravite ju ili zamijenite novom.
</ptxt>
</item>
<item>
<ptxt>
Zaštitnu foliju vrata (1) učvrstite butil trakom (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950046.jpg" width = "88.000mm" height = "80.908mm" ver = "01" gw = "185" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
