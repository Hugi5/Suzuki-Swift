<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1504-H: Kvar na senzoru sunčevog svjetla i/ili njegovom krugu
</emph>
</ptxt>
<ptxt>
Napon signala senzora sunčevog svjetla kontinuirano je veći od propisane vrijednosti (4,9 V) tijekom propisanog vremena.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Strujni krug senzora sunčevog svjetla
</ptxt>
</item>
<item>
<ptxt>
Senzor sunčevog svjetla
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul HVAC sustava
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
