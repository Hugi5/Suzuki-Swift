<servinfosub id = "AHRAP70A8204028003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A8204028004">
<testgroup id = "AHRAP70A8204028005">
<question>
Je li izvršena “Provjera dijagnostičkog sustava zračnih jastuka”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A8204028006">
<title>
Provjera kruga ožičenja poda
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “L283” ili “L285”.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektor “L04” ili “L05”.
</ptxt>
</test1>
<test1>
<ptxt>
Otpustite kratkospojnu šipku u konektoru SDM-a tako da umetnete alat za otpuštanje priložen sa specijalnim alatom (A).
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor između svakog od krugova “A1” i “A2” i uzemljenja (DTC B1053): beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova “A3” i “A4” i uzemljenja (DTC B1057): beskonačan
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B040">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820123.swf" width = "90.000mm" height = "89.682mm" ver = "01" gw = "228" gh = "238"/>
</testfigure>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite SDM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje poda. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Nakon završetka pregleda i popravka izvršite sljedeće radnje.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ponovo spojite sve komponente sustava zračnih jastuka i pazite da sve budu ispravno ugrađene.
</ptxt>
</item>
<item>
<ptxt>
Ako su detektirani DTC-ovi, izbrišite ih prema uputama pod naslovom 
<intxref refid = "AHRAP70A8204006">Brisanje DTC-a</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ponovite 
<intxref refid = "AHRAP70A8204001">Provjera dijagnostičkog sustava zračnih jastuka</intxref>
 kako biste potvrdili da je problem riješen.
</ptxt>
</item>
</list1>
</attention3>
