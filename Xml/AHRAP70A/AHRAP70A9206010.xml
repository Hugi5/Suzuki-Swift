</title>
<servinfosub id = "AHRAP70A9206010001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite reflektor (1) dok otpuštate brave (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektore s reflektorskog svjetla.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920027.jpg" width = "88.000mm" height = "68.223mm" ver = "02" gw = "199" gh = "177"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite grlo žarulje (1) s reflektorskog svjetla (2) pa uklonite žarulje.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920015.jpg" width = "88.000mm" height = "57.222mm" ver = "01" gw = "204" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9206010002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
