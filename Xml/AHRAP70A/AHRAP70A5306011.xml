<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A5306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja glavnog cilindra spojke
</title>
<servinfosub id = "AHRAP70A5306011001">
<title>
Uklanjanje
</title>
<s1 page = "2">
<ptxt>
Očistite oko čepa spremnika glavnog cilindra kočnice i uklonite tekućinu sisaljkom ili sličnim iz spremnika glavnog cilindra kočnice.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odspojite cijev tekućine za spojku s glavnog cilindra spojke. 
<intxreftitleoff1 refid = "AHRAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odspojite crijevo spremnika spojke (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530007.swf" width = "88.000mm" height = "49.059mm" ver = "01" gw = "141" gh = "123"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Uklonite potisnu šipku (1) s papučice spojke (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite matice glavnog cilindra spojke (3), a zatim uklonite glavni cilindar spojke (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530008.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A5306011002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A5306012">Pregled glavnog cilindra spojke</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Nanesite mast na vrh potisne šipke.
</ptxt>
<materials>
<materialitem name = "SUZUKI Silicone Grease" id = "M5C001" uid = "21">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25100
</m-number>
<m-name>
SUZUKI silikonska mast
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Matice (1) glavnog cilindra spojke pritegnite propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T5C004">
<t-part>
Matica glavnog cilindra spojke
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A531013.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
