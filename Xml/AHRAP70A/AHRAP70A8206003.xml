<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A8206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Ugradnja i uklanjanje SDM-a
</title>
<attention1>
<ptxt>
Tijekom servisnih postupaka budite vrlo pažljivi kada rukujete SDM-om.
</ptxt>
<ptxt>
Svakako pročitajte 
<intxref refid = "AHRAP70A8200002">Mjere opreza za rukovanje i spremanje komponenti sustava zračnih jastuka</intxref>
 prije početka rada i pridržavajte se svih mjera opreza za vrijeme rada. Ako to ne učinite, može doći do ozljede, smrti ili se sustav zračnih jastuka neće aktivirati kada to bude potrebno.
</ptxt>
</attention1>
<servinfosub id = "AHRAP70A8206003001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Deaktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite stražnju kutiju podne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Preokrenite podni tepih. 
<intxreftitleoff1 refid = "AHRAP70A9806010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke (1), a zatim i nosač (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820048.swf" width = "88.000mm" height = "76.877mm" ver = "01" gw = "234" gh = "201"/>
</figure>
</s1>
<s1>
<ptxt>
Odspojite konektore SDM-a (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke SDM-a (2), zatim uklonite SDM (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820046.swf" width = "88.000mm" height = "68.795mm" ver = "01" gw = "236" gh = "178"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A8206003002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A8206004">Pregled guma</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite da ne postoje sljedeći kvarovi.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Savijenost, ogrebotina, izobličenost na dodirnoj površini karoserije vozila na koju je ugrađen SDM.
</ptxt>
</item>
<item>
<ptxt>
Strana tvar ili hrđa na dodirnoj površini karoserije vozila na koju je ugrađen SDM.
</ptxt>
</item>
</list2>
<item>
<ptxt>
Pazite da strjelica (1) na SDM-u pokazuje prema prednjem dijelu vozila.
</ptxt>
</item>
<item>
<ptxt>
Zategnite vijke SDM-a (2) primjenom određenog okretnog momenta.
</ptxt>
<torque>
<torqueitem id = "T8B001">
<t-part>
Vijak SDM-a
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,0
</t-value1>
<t-value2>
0,92
</t-value2>
<t-value3>
7,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A820047.swf" width = "88.000mm" height = "70.496mm" ver = "01" gw = "236" gh = "183"/>
</figure>
</item>
<item>
<ptxt>
Ugradite nosač (2) pa pritegnite vijke (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820049.swf" width = "88.000mm" height = "76.877mm" ver = "01" gw = "234" gh = "201"/>
</figure>
</item>
<item>
<ptxt>
Aktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
