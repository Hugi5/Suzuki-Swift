<servinfosub id = "AHRAP70A1104016003">
<title>
Postupak potvrde DTC-a
</title>
<attention3>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Napon akumulatora &#62; 8,5 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; -10 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Pustite neka motor radi u praznom hodu 10 sekundi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104016004" page = "1">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104016005">
<testgroup id = "AHRAP70A1104016006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104016007">
<title>
Provjera kruga napajanja HO2S grijača
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektor HO2S senzora.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorom HO2S senzora.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite odgovara li napon između kruga &#34;B1&#34; i uzemljenja naponu akumulatora.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104016008">
<title>
Provjera pogonskog kruga HO2S grijača
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;B4&#34;: manji od 1Ω
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;B4&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;B4&#34; i drugih terminala konektora HO2S senzora: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;B4&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104016009">
<title>
Provjera HO2S-a
</title>
<test1>
<ptxt>
Provjerite HO2S grijač. 
<intxreftitleoff1 refid = "AHRAP70A1306014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite HO2S.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
