<ptxt>
<emph etype = "bold">
P0036: Upravljački strujni krug HO2S grijača (senzor 2)
</emph>
</ptxt>
<ptxt>
Upravljački strujni krug HO2S grijača je prekinut.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
HO2S grijač i/ili njegov krug
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0037: Signal upravljačkog kruga HO2S grijača nizak (senzor 2)
</emph>
</ptxt>
<ptxt>
Upravljački krug HO2S grijača u kratkom je spoju s uzemljenjem.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0038: Signal upravljačkog kruga HO2S grijača visok (senzor 2)
</emph>
</ptxt>
<ptxt>
Upravljački strujni krug HO2S grijača u kratkom je spoju s napajanjem.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje)
</ptxt>
</entry>
