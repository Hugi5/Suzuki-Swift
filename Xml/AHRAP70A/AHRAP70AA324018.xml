<servinfosub id = "AHRAP70AA324018003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Neka se motor vrti pri brzini praznog hoda 10 sekundi ili dulje.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA324018004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70AA324018005">
<testgroup id = "AHRAP70AA324018006">
<title>
Provjera kruga signala prekidača motora
</title>
<test1>
<ptxt>
Potvrdite da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite konektore “G140” i “G28”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;G140&#34; i &#34;G28&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu provjerite sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34; i &#34;A4&#34;: manji od 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između svakog od krugova &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34; i &#34;A4&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i ostalih terminala na konektoru &#34;G140&#34;: beskonačan
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324018007">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite prekidač motora. 
<intxreftitleoff1 refid = "AHRAP70AA506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA324018003">Postupak potvrde DTC-a</intxref>
 i zatim ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC B1189?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul sustava pokretanja bez ključa i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Neispravan prekidač motora)
</ptxt>
</action>
</testgroup>
</diag>
