<servinfosub id = "AHRAP70A1104034003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pustite neka motor radi u praznom hodu 10 sekundi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104034004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104034005">
<testgroup id = "AHRAP70A1104034006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104034007">
<title>
Provjera strujnog kruga napajanja CMP senzora
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektor CMP senzora povezanog s DTC-om.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorom CMP senzora.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite odgovara li napon između &#34;A1&#34; i &#34;A3&#34; ili &#34;B1&#34; i &#34;B3&#34; naponu akumulatora.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104034008">
<title>
Provjera kruga uzemljenja CMP senzora
</title>
<test1>
<ptxt>
Provjerite odgovara li napon između &#34;A1&#34; ili &#34;B1&#34; i uzemljenja naponu akumulatora.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Popravite krug &#34;A3&#34; ili &#34;B3&#34;.
</ptxt>
<ptxt>
Ako se ovaj DTC i dalje detektira, zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104034009">
<title>
Provjera kruga signala CMP senzora
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektore &#34;C01&#34; i &#34;E01&#34; s ECM-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala s konektorima &#34;C01&#34; i &#34;E01&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor kruga &#34;A2&#34; ili &#34;B2&#34;: manji od 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;A2&#34; ili &#34;B2&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A2&#34; ili &#34;B2&#34; i drugih terminala na konektoru CMP senzora: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;A2&#34; ili &#34;B2&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104034010">
<title>
Provjera CMP senzora i signalnog rotora
</title>
<test1>
<ptxt>
Provjerite sljedeće: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
CMP senzor 
<intxreftitleoff1 refid = "AHRAP70A1306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Signalni rotor 
<intxreftitleoff1 refid = "AHRAP70A1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite ECM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravne dijelove.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
