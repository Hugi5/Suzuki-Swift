<section sectnbr = "6B">
<servcat sctnbr = "06" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A6206018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja kontakt brave (model s kontakt bravom)
</title>
<servinfosub id = "AHRAP70A6206018001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni (–) kabel s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite gornji i donji poklopac stupa upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uvjerite se da je ključ za pokretanje izvučen.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor (1) sa kontakt brave (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke (4), zatim uklonite kontakt bravu (2) sa brave upravljača (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A620036.jpg" width = "88.000mm" height = "54.155mm" ver = "05" gw = "237" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A6206018002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A6206019">Pregled kontakt brave (model s kontakt bravom)</intxrefpoff>
</ptxt>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
