<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3126003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i postavljanje sklopa stražnjeg pogonskog vratila
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A3126001">Komponente stražnjeg pogonskog vratila:Straga</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A3126002">Pregled sklopa stražnjeg pogonskog vratila na vozilu:Straga</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A3126003001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Podignite vozilo i uklonite stražnji kotač. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Skinite brtvu (1) i uklonite maticu pogonskog vratila (2) dok je papučica kočnice pritisnuta.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312002.swf" width = "88.000mm" height = "53.091mm" ver = "01" gw = "177" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite prirubne matice stražnjeg pogonskog vratila (1) i uklonite sklop stražnjeg pogonskog vratila.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312003.swf" width = "88.000mm" height = "47.465mm" ver = "01" gw = "177" gh = "118"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A3126003002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zategnite novu maticu pogonskog vratila (1) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T3A202">
<t-part>
Matica pogonskog vratila
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Osigurajte spoj matice pogonskog vratila (1) kao što je prikazano.
</ptxt>
<attention2>
<ptxt>
Pazite da ne slomite osigurač (2) matice pogonskog vratila dok brtvite. Ako se slomi, zamijenite novim.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A312004.swf" width = "88.000mm" height = "52.301mm" ver = "01" gw = "159" gh = "132"/>
</figure>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Zategnite prirubne matice stražnjeg pogonskog vratila propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T3A203">
<t-part>
Matica prirubnice vratila stražnjeg pogona
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A312005.swf" width = "88.000mm" height = "49.964mm" ver = "01" gw = "177" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Nanesite mast na dodirnu površinu sklopa glavčine stražnjeg kotača i stražnjeg pogonskog vratila.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A202" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Mazivo
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Mast A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A312006.swf" width = "88.000mm" height = "54.175mm" ver = "02" gw = "227" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Matice kotača zategnite propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
