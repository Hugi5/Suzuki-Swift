<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A7224A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hladni zrak ne izlazi van ili nedovoljno hlađenje (normalan rad magnetske spojke)
</title>
<diag type = "condition">
<condition>
<ptxt>
Hladni zrak ne izlazi van ili nedovoljno hlađenje (normalan rad magnetske spojke)
</ptxt>
</condition>
<ps>
<ptxt>
Nedovoljno ili prekomjerno napunjeno rashladno sredstvo
</ptxt>
</ps>
<action>
<ptxt>
Provjerite količinu rashladnog sredstva i sustav radi istjecanja.
</ptxt>
</action>
<ps>
<ptxt>
Začepljen kondenzator
</ptxt>
</ps>
<action>
<ptxt>
Provjerite kondenzator. 
<intxreftitleoff1 refid = "AHRAP70A7226005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Začepljen ili zamrznut isparivač klima uređaja
</ptxt>
</ps>
<action>
<ptxt>
Provjerite isparivač klima uređaja i senzor temperature isparivača. 
<intxreftitleoff1 refid = "AHRAP70A7226017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 i 
<intxreftitleoff1 refid = "AHRAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kvar senzora temperature isparivača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite senzor temperature isparivača. 
<intxreftitleoff1 refid = "AHRAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan ekspanzijski ventil
</ptxt>
</ps>
<action>
<ptxt>
Provjerite ekspanzijski ventil. 
<intxreftitleoff1 refid = "AHRAP70A7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Začepljen ispušite
</ptxt>
</ps>
<action>
<ptxt>
Provjerite ispušite i čep s filtrom.
</ptxt>
</action>
<ps>
<ptxt>
Labav ili oštećen pogonski remen kompresora
</ptxt>
</ps>
<action>
<ptxt>
Provjerite pogonski remen kompresora. 
<intxreftitleoff1 refid = "AHRAP70A7226043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Magnetska spojka proklizuje
</ptxt>
</ps>
<action>
<ptxt>
Provjerite magnetsku spojku. 
<intxreftitleoff1 refid = "AHRAP70A7226047"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan kompresor
</ptxt>
</ps>
<action>
<ptxt>
Provjerite kompresor.
</ptxt>
</action>
<ps>
<ptxt>
Zrak u sustavu klima uređaja
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite kondenzator, a zatim provedite odzračivanje i punjenje. 
<intxreftitleoff1 refid = "AHRAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Istjecanje zraka iz HVAC jedinice ili kanala zraka
</ptxt>
</ps>
<action>
<ptxt>
Popravite HVAC jedinicu ili kanal za zrak.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sustav grijača i sustav provjetravanja
</ptxt>
</ps>
<action>
<ptxt>
Provjerite HVAC jedinicu.
</ptxt>
</action>
<ps>
<ptxt>
Neispravan upravljački modul HVAC sustava
</ptxt>
</ps>
<action>
<ptxt>
Provjerite upravljački modul HVAC sustava. 
<intxreftitleoff1 refid = "AHRAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan aktuator kontrole temperature
</ptxt>
</ps>
<action>
<ptxt>
Provjerite aktuator kontrole temperature 
<intxreftitleoff1 refid = "AHRAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan motor puhala
</ptxt>
</ps>
<action>
<ptxt>
Provjerite motor puhala. 
<intxreftitleoff1 refid = "AHRAP70A7226012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Prekomjerno ulje kompresora u sustavu klima uređaja
</ptxt>
</ps>
<action>
<ptxt>
Ispustite prekomjerno ulje kompresora iz kruga sustava klima uređaja i kompresora.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
