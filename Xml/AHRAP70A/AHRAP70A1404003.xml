<colspec colnum = "2" colname = "2" colwidth = "1.121in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
90&#176;
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
<figure>
<graphic graphicname = "I9P60A141016.swf" width = "88.000mm" height = "50.727mm" ver = "01" gw = "175" gh = "127"/>
</figure>
</servinfosub>
<servinfosub id = "AHRAP70A1404003002" page = "1">
<title>
Namještanje
</title>
<s1>
<ptxt>
Uklonite podizač kojeg trebate zamijeniti. 
<intxreftitleoff1 refid = "AHRAP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Izaberite podizač primjerene veličine prema sljedećim uputama da biste regulirali zračnost pojedinog ventila.
</ptxt>
<s2>
<ptxt>
Pomoću mikrometra izmjerite debljinu uklonjenog podizača (1).
</ptxt>
</s2>
<s2>
<ptxt>
Izračunajte debljinu novog podizača pomoću donje formule.
</ptxt>
</s2>
<s2>
<ptxt>
Odaberite novi podizač najbliži izračunatoj vrijednosti između dostupnih veličina u rezervnim dijelovima.
</ptxt>
<attention3>
<ptxt>
Ako je broj na drugom mjestu iza decimalne točke neparan, upotrijebite podizač (A-0,01).
</ptxt>
</attention3>
<ptxt>
Usis:
</ptxt>
<ptxt>
A = B + C – 0,19 mm (0,0075 in)
</ptxt>
<ptxt>
Ispuh:
</ptxt>
<ptxt>
A = B + C – 0,35 mm (0,0138 in)
</ptxt>
<ptxt>
A: Debljina &#34;a&#34; novog podizača
</ptxt>
<ptxt>
B: Debljina &#34;a&#34; uklonjenog podizača
</ptxt>
<ptxt>
C: Izmjerena zračnost ventila
</ptxt>
<figure>
<graphic graphicname = "I7V20A141015.swf" width = "88.000mm" height = "65.217mm" ver = "01" gw = "174" gh = "168"/>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Ugradite bregasta vratila i podizače. 
<intxreftitleoff1 refid = "AHRAP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ponovo provjerite zračnost ventila.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
