<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70AA324001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Provjera sustava kontrole blokade motora
</title>
<diag type = "test" id = "AHRAP70AA324001001">
<testgroup id = "AHRAP70AA324001003">
<title>
Provjera paljenja
</title>
<test1>
<ptxt>
Uključite kontakt
</ptxt>
</test1>
<test1>
<ptxt>
Pritisnite papučicu spojke.
</ptxt>
</test1>
<question>
Uključuju li se indikatorska svjetla ON i PUSH?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70AA504001">Provjera sustava pokretanja bez ključa</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324001004">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li otkriven DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324001006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Provjerite DTC povezan s CAN komunikacijom.
</ptxt>
</test1>
<question>
Postoje li DTC-ovi koji se odnose na CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324001005">
<question>
Je li se motor okretao pri pokretanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1904001">Dijagnostika simptoma sustava za pokretanje</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA324001002">
<title>
Provjera pokretanja motora
</title>
<question>
Je li se motor pokrenuo?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustav kontrole blokade motora je u dobrom stanju.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104009">Osnovni pregled motora</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
