<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9406001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja spremnika tekućine za pranje i pumpe za pranje
</title>
<servinfosub id = "AHRAP70A9406001001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite prednji odbojnik. 
<intxreftitleoff1 refid = "AHRAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite obujmice ožičenja (1), konektore pumpe za pranje (2) i crijeva za pranje (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940004.jpg" width = "88.000mm" height = "67.662mm" ver = "01" gw = "209" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vijke spremnika tekućine za pranje (1) i zatim uklonite spremnik tekućine za pranje (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940005.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "180" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Povucite pumpu za pranje vjetrobrana (1) i pumpu za pranje stražnjeg prozora (2) u smjeru strjelice da biste ih uklonili sa spremnika tekućine za pranje (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940006.jpg" width = "88.000mm" height = "62.134mm" ver = "01" gw = "161" gh = "160"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9406001002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9406002">Provjera pumpe sustava za pranje</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijke spremnika tekućine za pranje propisanim momentom pritezanja.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9D001">
<t-part>
Vijak spremnika tekućine za pranje
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A940008.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "201" gh = "174"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
