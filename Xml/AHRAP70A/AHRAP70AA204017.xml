<servinfosub id = "AHRAP70AA204017003">
<title>
Rješavanje DTC problema
</title>
<diag type = "test" id = "AHRAP70AA204017004">
<testgroup id = "AHRAP70AA204017005">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Izbrišite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA204017002">Postupak potvrde DTC-a</intxref>
 i zatim ponovno provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC B1157?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Zračni jastuk se u prošlosti napuhao. (DTC nije obrisan))
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204017006">
<title>
Ponovna provjera DTC-a
</title>
<test1>
<ptxt>
Zamijenite SDM. 
<intxreftitleoff1 refid = "AHRAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provedite 
<intxref refid = "AHRAP70AA204017002">Postupak potvrde DTC-a</intxref>
 i zatim ponovno provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se i dalje DTC B1157?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite BCM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (SDM je bio neispravan)
</ptxt>
</action>
</testgroup>
