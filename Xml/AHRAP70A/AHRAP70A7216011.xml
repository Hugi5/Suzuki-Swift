<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7216011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja otpornika motora puhala
</title>
<servinfosub id = "AHRAP70A7216011001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite pretinac za rukavice s ploče s instrumentima. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite kanal za noge (2) na suvozačevoj strani s HVAC jedinice uklanjanjem vijka (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A721036.jpg" width = "88.000mm" height = "94.268mm" ver = "01" gw = "199" gh = "251"/>
</figure>
</s1>
<s1>
<ptxt>
Odspojite konektor (1) s otpornika motora puhala (2), i zatim uklonite otpornik motora puhala s HVAC jedinice uklanjanjem vijaka (3).
</ptxt>
<figure>
<graphic graphicname = "I4RS0A710010.swf" width = "88.000mm" height = "53.049mm" ver = "01" gw = "183" gh = "134"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7216011002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
