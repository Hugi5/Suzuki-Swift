<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0627: Upravljački strujni krug pumpe goriva &#34;A&#34;/prekinut
</emph>
</ptxt>
<ptxt>
Pogonski krug releja pumpe goriva je prekinut.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje, ali MIL ne zasvijetli)
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Relej pumpe goriva i/ili njegov krug
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0628: Niski napon upravljačkog kruga pumpe goriva &#34;A&#34;
</emph>
</ptxt>
<ptxt>
Pogonski krug releja pumpe goriva u kratkom je spoju s uzemljenjem.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje, ali MIL ne zasvijetli)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0629: Visoki napon upravljačkog kruga pumpe goriva &#34;A&#34;
</emph>
</ptxt>
<ptxt>
Pogonski krug releja pumpe goriva u kratkom je spoju s napajanjem.
</ptxt>
<ptxt>
(logika detekcije 3 ciklusa vožnje, ali MIL ne zasvijetli)
</ptxt>
</entry>
