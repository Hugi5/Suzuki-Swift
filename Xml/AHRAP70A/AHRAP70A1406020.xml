<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1406020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja kontrolnog ventila ulja (OCV)
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1406017">Komponente poklopca lanca razvodnog mehanizma</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1406020001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (-) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor OCV-a usisa (crni) (1) i konektor OCV-a ispuha (plavi) (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite OCV usisa (3) i OCV ispuha (4) s poklopca lanca razvodnog mehanizma.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141060.jpg" width = "88.000mm" height = "58.155mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1406020002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijke OCV-a propisanim momentom pritezanja.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1D013">
<t-part>
OCV vijak
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
