<servinfosub id = "AHRAP70AA204014004">
<title>
Rješavanje DTC problema
</title>
<diag type = "test" id = "AHRAP70AA204014005">
<testgroup id = "AHRAP70AA204014006">
<title>
Provjera DTC-a
</title>
<question>
Je li istovremeno prikazan DTC B1132?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204014009">
<title>
Provjera parametara
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite &#34;Temperaturu zraka u okolini&#34; prikazanu na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204014007">
<title>
Provjera kruga senzora temperature zraka u okolini
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite senzor temperature zraka u okolini i sljedeće konektore.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s kontakt bravom: Konektor &#34;E04&#34;
</ptxt>
</item>
<item>
<ptxt>
Model sa sustavom pokretanja pritiskom prekidača, bez ključa: Konektor &#34;E05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala sa senzorom temperature zraka u okolini i sljedećim konektorima.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s kontakt bravom: Konektor &#34;E04&#34;
</ptxt>
</item>
<item>
<ptxt>
Model sa sustavom pokretanja pritiskom prekidača, bez ključa: Konektor &#34;E05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor krugova &#34;A1&#34; i &#34;A2&#34;: manji od 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;A1&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i &#34;A3&#34; na konektoru senzora temperature zraka u okolini: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon krugova &#34;A1&#34; i &#34;A2&#34;: 0 – 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204014008">
<title>
Provjera senzora temperature zraka u okolini
</title>
<test1>
<ptxt>
Provjerite senzor temperature zraka u okolini 
<intxreftitleoff1 refid = "AHRAP70AA206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite senzor temperature zraka u okolini. 
<intxreftitleoff1 refid = "AHRAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204014010">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Spojite senzor temperature zraka u okolini i sljedeće konektore.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model s kontakt bravom: Konektor &#34;E04&#34;
</ptxt>
</item>
<item>
<ptxt>
Model sa sustavom pokretanja pritiskom prekidača, bez ključa: Konektor &#34;E05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li detektirani DTC B1141 ili B1142?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite BCM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
</testgroup>
</diag>
