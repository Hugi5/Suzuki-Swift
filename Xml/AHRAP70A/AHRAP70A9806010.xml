<title>
Uklanjanje i ugradnja podnog tepiha
</title>
<servinfosub id = "AHRAP70A9806010001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite sjedalo.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednje sjedalo: 
<intxreftitleoff1 refid = "AHRAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Stražnje sjedalo: 
<intxreftitleoff1 refid = "AHRAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Uklonite sljedeće pragove i obloge. 
<intxreftitleoff1 refid = "AHRAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Unutarnje prednje obloge bočnog praga
</ptxt>
</item>
<item>
<ptxt>
Unutarnje stražnje obloge bočnog praga
</ptxt>
</item>
<item>
<ptxt>
Bočna strana obloga
</ptxt>
</item>
<item>
<ptxt>
Donje obloge srednjeg stupa
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Uklonite prednju/stražnju kutiju centralne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac zgloba upravljača. 
<intxreftitleoff1 refid = "AHRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite 5 kopči (1) i graničnik papučice gasa (2), a zatim uklonite podni tepih (3).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A980007.jpg" width = "88.000mm" height = "60.725mm" ver = "02" gw = "238" gh = "156"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
