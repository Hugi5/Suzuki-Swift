<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A5206005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja kontrolne ručice mjenjača i sajle
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A5206004">Komponente kontrolne ručice mjenjača i sajle</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A5206005001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite ECM s police akumulatora. 
<intxreftitleoff1 refid = "AHRAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite akumulator i njegovu policu. 
<intxreftitleoff1 refid = "AHRAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite prednju kutiju podne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite krajeve sajle za odabir stupnja prijenosa i upravljačke sajle mjenjača (5) s osovine (6) sklopa kontrolne ručice mjenjača.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite mjenjač i upravljačke sajle za odabir stupnja prijenosa (1) sa sklopa kontrolne ručice mjenjača (2) dok povlačite brzi zglob (4) u smjeru strjelice prema prikazu na slici.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite matice (3) i uklonite sklop kontrolne ručice mjenjača sa podne ploče.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520038.swf" width = "88.000mm" height = "74.693mm" ver = "01" gw = "187" gh = "195"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.649in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
7.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Zatik
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Odspojite upravljačke sajle za odabir stupnja prijenosa s mjenjača.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijak vodilice sajle i zatim uklonite upravljačke sajle za odabir stupnja prijenosa s podne ploče.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A5206005002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite vijke i obujmice propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Namjestite upravljačku sajlu za odabir stupnja prijenosa. 
<intxreftitleoff1 refid = "AHRAP70A5206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
