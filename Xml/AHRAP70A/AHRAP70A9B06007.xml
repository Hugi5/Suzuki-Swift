<servinfo servinfosgmlid = "AHRAP70A9B06007" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja ploče plašta blatobrana, produžetka plašta blatobrana i gornjeg nosača ovjesa
</title>
<attention3>
<ptxt>
Donja slika prikazuje uvjete za uklanjanje sljedećih dijelova.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Prednji blatobran 
<intxreftitleoff1 refid = "AHRAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nosač brave poklopca prostora motora, vodoravni potporni element svjetla i potporanj nosača svjetla 
<intxreftitleoff1 refid = "AHRAP70A9B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Donji nosač prednjeg blatobrana 
<intxreftitleoff1 refid = "AHRAP70A9B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Prednja ploča na strani poprečne pregrade i prednja ploča na strani gornjeg lima uz vjetrobran 
<intxreftitleoff1 refid = "AHRAP70A9B06006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0019.jpg" width = "88.000mm" height = "56.208mm" ver = "01" gw = "227" gh = "143"/>
</figure>
<servinfosub id = "AHRAP70A9B06007001">
<title>
Opće napomene
</title>
<ptxt>
Metoda zavarivanja i broj točaka zavarivanja su jednaki na obje strane. Ove upute za popravljanje prikazuju postupak za lijevu stranu.
</ptxt>
</servinfosub>
<servinfosub id = "AHRAP70A9B06007002">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Izbušite zavarene točke i uklonite ploču plašta blatobrana, produžetak plašta blatobrana i gornji nosač ovjesa
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0060.jpg" width = "183.000mm" height = "233.898mm" ver = "01" gw = "496" gh = "647"/>
