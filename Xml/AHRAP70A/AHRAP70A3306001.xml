</s1>
<s1>
<ptxt>
Postavite ispušnu cijev br. 1. 
<intxreftitleoff1 refid = "AHRAP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite ispušni sustav radi istjecanja ispušnih plinova.
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite međumjenjač zbog istjecanja ulja.
</ptxt>
