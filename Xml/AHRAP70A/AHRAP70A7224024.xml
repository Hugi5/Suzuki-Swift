</servinfosub>
<servinfosub id = "AHRAP70A7224024004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A7224024005">
<testgroup id = "AHRAP70A7224024006">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt i provjerite DTC.
</ptxt>
</test1>
<question>
Detektira li se DTC B1541 i dalje?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Isprekidani problem.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224024008">
<title>
Provjera osigurača
</title>
<test1>
<ptxt>
Provjerite &#34;MTR&#34; osigurač.
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite osigurač “MTR” i provjerite uzemljenje radi kratkog spoja.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A7224024007">
<title>
Provjera kruga napajanja naponom akumulatora
</title>
<test1>
<ptxt>
Odspojite konektor “G20”.
</ptxt>
</test1>
<test1>
<ptxt>
Izmjerite napon između terminala žice “WHT/RED” konektora “G20” i uzemljenja.
</ptxt>
</test1>
<question>
Je li napon 10 - 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul HVAC sustava i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite ožičenje ploče s instrumentima.
</ptxt>
</action>
</testgroup>
