<servinfo servinfosgmlid = "AHRAP70A7216032" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja filtra zraka HVAC sustava
</title>
<servinfosub id = "AHRAP70A7216032001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite pretinac za rukavice. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac filtra zraka HVAC sustava (2) s HVAC jedinice.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite filtar zraka (1) s HVAC jedinice.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721033.swf" width = "88.000mm" height = "53.307mm" ver = "01" gw = "219" gh = "135"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7216032002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeću točku.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Postavite filtar zraka usmjeravanjem oznake strjelice (1) prema gore.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721034.swf" width = "88.000mm" height = "48.728mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
