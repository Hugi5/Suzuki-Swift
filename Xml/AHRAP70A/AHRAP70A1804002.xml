<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1804002" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Provjera svjećica paljenja
</title>
<attention1>
<ptxt>
Ako ne iskopčate konektore brizgaljki, zapaljivi plin može prosukljati iz otvora svjećica tijekom provjere i zapaliti se u prostoru motora.
</ptxt>
</attention1>
<s1>
<ptxt>
Uklonite svjećice. 
<intxreftitleoff1 refid = "AHRAP70A1806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite svjećice. 
<intxreftitleoff1 refid = "AHRAP70A1806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite sve konektore brizgaljke.
</ptxt>
</s1>
<s1>
<ptxt>
Spojite konektor indukcijske zavojnice (1) sa sklopom indukcijske zavojnice (3).
</ptxt>
</s1>
<s1>
<ptxt>
Priključite svjećicu (2) na sklop indukcijske zavojnice i svjećicu uzemljenja.
</ptxt>
<figure>
<graphic graphicname = "I9P60A180004.swf" width = "88.000mm" height = "69.562mm" ver = "01" gw = "185" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Pokrećite motor i provjerite baca li svaka svjećica iskru.
</ptxt>
</s1>
<s1>
<ptxt>
Ako nema iskri, provjerite ostale dijelove. 
<intxreftitleoff1 refid = "AHRAP70A1804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
