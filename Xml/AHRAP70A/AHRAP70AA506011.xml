<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70AA506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja prijemnika sustava ulaska bez ključa (ako je dio opreme)
</title>
<servinfosub id = "AHRAP70AA506011001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite kutiju centralne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Iskopčajte konektor (1) prijamnika sustava ulaska bez ključa.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijak (3), a zatim uklonite prijamnik sustava ulaska bez ključa (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50030.swf" width = "88.000mm" height = "77.203mm" ver = "01" gw = "202" gh = "202"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA506011002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70AA506012">Pregled prijamnika sustava ulaska bez ključa</intxrefpoff>
</ptxt>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
