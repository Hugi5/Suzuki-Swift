<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A4106017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja sklopa glavnog cilindra kočnice
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A4106015">Komponente glavnog cilindra kočnice</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHRAP70A4106016">Pregled sklopa glavnog cilindra kočnice na vozilu</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Nikada ne rastavljajte glavni cilindar kočnice. Rastavljanjem ćete pokvariti njezine izvorne performanse.
</ptxt>
<ptxt>
Ako pronađete kvar, zamijenite glavni cilindar kočnice novim sklopom.
</ptxt>
</item>
<item>
<ptxt>
Ne dozvolite da kočna tekućina dođe u dodir s obojenim površinama. Obojene površine će se oštetiti kočnom tekućinom. Ako je tekućina prolivena, odmah je isperite sa vodom.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AHRAP70A4106017001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite akumulator i njegovu policu. 
<intxreftitleoff1 refid = "AHRAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Očistite vanjsku površinu glavnog cilindra kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Iskopčajte konektor prekidača razine kočne tekućine (1) na spremniku.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410002.swf" width = "88.000mm" height = "65.516mm" ver = "01" gw = "199" gh = "169"/>
</figure>
</s1>
<s1>
<ptxt>
Ispustite kočnu tekućinu iz spremnika.
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite crijevo spremnika spojke sa spremnika.
</ptxt>
</s1>
<s1>
<ptxt>
Specijalnim alatom odvijte priključne matice i odspojite cijevi kočnice (1) s glavnog cilindra kočnice.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A002">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Uklonite pričvrsne matice glavnog cilindra kočnice (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410010.swf" width = "88.000mm" height = "60.983mm" ver = "01" gw = "159" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite glavni cilindar kočnice (1) i O-prsten (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410011.swf" width = "88.000mm" height = "46.988mm" ver = "02" gw = "159" gh = "117"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A4106017004">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A4106019">Pregled sklopa glavnog cilindra kočnice</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Ugradite novi O-prsten (2) na sklop glavnog cilindra kočnice (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410011.swf" width = "88.000mm" height = "46.988mm" ver = "02" gw = "159" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Ugradite glavni cilindar kočnice na servouređaj kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Pričvrsne matice glavnog cilindra kočnice pritegnite propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T4A004">
<t-part>
Pričvrsna matica glavnog cilindra kočnice
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
18
</t-value1>
<t-value2>
1,8
</t-value2>
<t-value3>
13,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Spojite cijev kočnice (1) na glavni cilindar kočnice i zategnite priključne matice specijalnim alatom propisanim momentom pritezanja.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A003">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T4A005">
<t-part>
Priključna matica cijevi kočnice
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A410012.swf" width = "88.000mm" height = "60.983mm" ver = "01" gw = "159" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Spojite crijevo spremnika spojke na spremnik.
</ptxt>
</s1>
<s1>
<ptxt>
Spojite konektor prekidača razine kočne tekućine.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite policu akumulatora i akumulator. 
<intxreftitleoff1 refid = "AHRAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nakon ugradnje odzračite kočni sustav. 
<intxreftitleoff1 refid = "AHRAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite ugrađene dijelove radi istjecanja kočne tekućine.
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite slobodni hod papučice kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uvjerite se da kočni sustav pravilno radi i da tekućina ne istječe.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
