<servinfosub id = "AHRAP70AA204012004">
<title>
Rješavanje DTC problema
</title>
<diag type = "test" id = "AHRAP70AA204012005">
<testgroup id = "AHRAP70AA204012008">
<title>
Provjera parametara
</title>
<test1>
<ptxt>
Priključite SUZUKI alat za skeniranje na DLC s isključenim kontaktom.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite &#34;Senzor automatskog svjetla&#34; prikazan na SUZUKI alatu za skeniranje. 
<intxreftitleoff1 refid = "AHRAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204012006">
<title>
Provjera kruga napajanja senzora automatskog uključivanja prednjih svjetala
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Odspojite senzor automatskog uključivanja prednjih svjetala i konektore &#34;G05&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja terminala sa senzorom automatskog uključivanja prednjih svjetala i &#34;G05&#34; konektorima.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor između kruga &#34;A1&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Otpor između terminala kruga &#34;A1&#34; i &#34;A3&#34; na konektoru senzora automatskog uključivanja prednjih svjetala: beskonačan
</ptxt>
</item>
</list1>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204012007">
<title>
Provjera senzora automatskog uključivanja prednjih svjetala
</title>
<test1>
<ptxt>
Provjerite senzor automatskog uključivanja prednjih svjetala. 
<intxreftitleoff1 refid = "AHRAP70A9206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite senzor automatskog uključivanja prednjih svjetala. 
<intxreftitleoff1 refid = "AHRAP70A9206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70AA204012009">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Isključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Spojite senzor automatskog uključivanja prednjih svjetala i konektore &#34;G05&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li detektiran trenutni DTC B1132?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite BCM i ponovo provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraj. (Isprekidani problem.)
</ptxt>
</action>
</testgroup>
