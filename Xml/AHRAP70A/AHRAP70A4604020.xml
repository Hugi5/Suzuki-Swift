<servinfosub id = "AHRAP70A4604020003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A4604020004">
<testgroup id = "AHRAP70A4604020005">
<question>
Je li izvršena “Provjera ESP<sup>®</sup> sustava”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A4604001">Provjera ESP® sustava</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604020006">
<title>
Provjera prekidača ESP® OFF
</title>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uklonite prekidač ESP<sup>®</sup> OFF. 
<intxreftitleoff1 refid = "AHRAP70A4606017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja na svakom terminalu prekidača ESP<sup>®</sup> OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite prekidač ESP<sup>®</sup> OFF. 
<intxreftitleoff1 refid = "AHRAP70A4606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite prekidač ESP<sup>®</sup> OFF.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A4604020007">
<title>
Provjera kruga prekidača ESP® OFF
</title>
<test1>
<ptxt>
Odspojite konektor “E24”.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spoja na terminalu “E24-38”.
</ptxt>
</test1>
<test1>
<ptxt>
Ako je spoj u redu, provjerite otpor između terminala “E24-38” i uzemljenja.
</ptxt>
</test1>
<question>
Je li otpor beskonačan?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite sklop hidrauličkog uređaja/upravljačkog modula ESP<sup>®</sup>-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite krug &#34;A1&#34; koji je u kratkom spoju.
</ptxt>
</action>
</testgroup>
</diag>
