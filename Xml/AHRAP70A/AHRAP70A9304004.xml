<servinfosub id = "AHRAP70A9304004003">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A9304004004">
<testgroup id = "AHRAP70A9304004005">
<title>
Provjera DTC-a
</title>
<test1>
<ptxt>
Izbrišite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Uvjerite se da je kontakt isključen.
</ptxt>
</test1>
<test1>
<ptxt>
Uključite kontakt.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Detektira li se DTC B1802 i dalje?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite postoje li isprekidani problemi. 
<intxreftitleoff1 refid = "AHRAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A9304004006">
<title>
Provjera krugova napajanja i uzemljenja kombiniranog mjerača
</title>
<test1>
<ptxt>
Provjerite krugove napajanja i uzemljenja kombiniranog mjerača. 
<intxreftitleoff1 refid = "AHRAP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A9304004007">
<title>
Provjera napona napajanja kombiniranog mjerača
</title>
<test1>
<ptxt>
Provjerite napon napajanja dok motor radi na 3000 okr./min.
</ptxt>
</test1>
<question>
Iznosi li napon između 10 - 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite kombinirani mjerač i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Provjerite sustav punjenja. 
<intxreftitleoff1 refid = "AHRAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
