<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A9506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja stakla prednjih vrata
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A9506010">Komponente prednjih vrata</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A9506011001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Spustite staklo prednjih vrata na ptprilike 150 mm (5,91) od donjeg ruba stakla.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950023.jpg" width = "88.000mm" height = "45.882mm" ver = "02" gw = "225" gh = "114"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.331in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.870in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Oko 150 mm (5,91 in)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Odspojite negativni (–) kabel s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite unutarnju oblogu nosača okvira stakla (1).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac unutarnje ručke (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vijke (3), kopču i uklonite oblogu vrata (4) povlačeći ju u smjeru strelice.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950025.jpg" width = "88.000mm" height = "101.074mm" ver = "01" gw = "227" gh = "270"/>
</figure>
</s1>
<s1>
<ptxt>
Odspojite konektore ožičenja vrata.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite vanjsku brtvu prednjih vrata (1) povlačeći ju u smjerovima strjelice redoslijedom (“1” do “2”) na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950026.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.071in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.783in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Zaponac
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Vanjska ploča prednjih vrata
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Uklonite nosač obloge vrata (1) i zaštitnu foliju (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950027.jpg" width = "88.000mm" height = "91.845mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vijke (1) pa uklonite staklo prednjih vrata (2) povlačeći ju u smjerovima strjelice redoslijedom (“1” do “2”) na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950028.jpg" width = "88.000mm" height = "78.685mm" ver = "02" gw = "225" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A9506011002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ako su uklonjeni sa stakla prednjih vrata, postavite držače stakala vrata (1) na zadani položaj na staklu prednjih vrata (2).
</ptxt>
<spec>
<title>
Položaj za ugradnju držača stakla prednjih vrata
</title>
<ptxt>
“a”: 104 – 106 mm (4,10 – 4,17 in)
</ptxt>
<ptxt>
“b”: 431,2 – 433,2 mm (16,98 – 17,05 in)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70P950015.jpg" width = "88.000mm" height = "46.523mm" ver = "01" gw = "191" gh = "115"/>
</figure>
</item>
<item>
<ptxt>
Pritegnite vijke stakla prednjih vrata redoslijedom (“1” do “2”) na način prikazan na slici.
</ptxt>
</item>
<item>
<ptxt>
Pritegnite vijke stakla prednjih vrata propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T9E002">
<t-part>
Vijak stakla prednjih vrata*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950029.jpg" width = "88.000mm" height = "81.655mm" ver = "02" gw = "225" gh = "215"/>
</figure>
</item>
<item>
<ptxt>
Ako je vodilica stakla oštećena, popravite ju ili zamijenite novom.
</ptxt>
</item>
<item>
<ptxt>
Zaštitnu foliju vrata (1) učvrstite butil trakom (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950031.jpg" width = "88.000mm" height = "81.028mm" ver = "01" gw = "215" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
