<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1704002" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Provjera ravnoteže napajanja
</title>
<attention2>
<ptxt>
Prilikom provjere ravnoteže napajanja nemojte povećavati brzinu vrtnje motora više od postavljene brzine praznog hoda. Ako to učinite, možete oštetiti motor.
</ptxt>
</attention2>
<s1>
<ptxt>
Postavite polugu mjenjača u neutralni položaj i zategnite parkirnu kočnicu.
</ptxt>
</s1>
<s1>
<ptxt>
Priključite SUZUKI alat za skeniranje na DLC (1) dok je kontakt isključen.
</ptxt>
<servicetool>
<servicetoolitem id = "L1G001">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI alat za skeniranje (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A121001.jpg" width = "88.000mm" height = "67.502mm" ver = "02" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Očistite DTC. 
<intxreftitleoff1 refid = "AHRAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zagrijte motor do normalne radne temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Na SUZUKI alatu za skeniranje odaberite &#34;Brizgaljka goriva&#34; u načinu &#34;Aktivni test&#34; i isključite svaku brizgaljku.
</ptxt>
</s1>
<s1>
<ptxt>
Sa isključenim svim brizgaljkama, potvrdite da brzina rada motora pada ispod propisane brzine vrtnje u praznom hodu.
</ptxt>
</s1>
<s1>
<ptxt>
Ako stope smanjenja brzine motora nisu usklađene, provjerite sljedeće stavke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Krug brizgaljke goriva 
<intxreftitleoff1 refid = "AHRAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Brizgaljka goriva 
<intxreftitleoff1 refid = "AHRAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Svjećica 
<intxreftitleoff1 refid = "AHRAP70A1806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Krug indukcijske zavojnice 
<intxreftitleoff1 refid = "AHRAP70A1804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Indukcijska zavojnica 
<intxreftitleoff1 refid = "AHRAP70A1806004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kompresija motora 
<intxreftitleoff1 refid = "AHRAP70A1404001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
