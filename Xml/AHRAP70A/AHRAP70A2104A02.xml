<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Prevelika istrošenost guma
</title>
<diag type = "condition">
<condition>
<ptxt>
Prevelika istrošenost guma
</ptxt>
</condition>
<ps>
<ptxt>
Slomljene ili uleknute zavojne opruge
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zamijenite zavojne opruge. 
</ptxt>
<ptxt>
Prednja: 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Stražnja: 
<intxreftitleoff1 refid = "AHRAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Kotač nije balansiran
</ptxt>
</ps>
<action>
<ptxt>
Podesite balans ili zamijenite gumu.
</ptxt>
</action>
<ps>
<ptxt>
Poremećena geometrija kotača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i prilagodite geometriju kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop prednje opružne noge (amortizer)
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop prednje opružne noge (amortizer). 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Teška vožnja
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite gume. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Preopterećeno vozilo
</ptxt>
</ps>
<action>
<ptxt>
Provjerite opterećenje.
</ptxt>
</action>
<ps>
<ptxt>
Gume nisu rotirane
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ili rotirajte gume.
</ptxt>
</action>
<ps>
<ptxt>
Istrošen ili labav ležaj kotača
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ležaj kotača. 
<intxreftitleoff1 refid = "AHRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Klimanje kotača ili gume
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite kotač ili gumu.
</ptxt>
</action>
<ps>
<ptxt>
Gume nisu propisno napumpane
</ptxt>
</ps>
<action>
<ptxt>
Namjestite tlak u gumi.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
