<servinfo servinfosgmlid = "AHRAP70A4106023" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Pregled servouređaja kočnice
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A4106022">Uklanjanje i ugradnja servo uređaja kočnice (pojačala)</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Provjerite je li servouređaj kočnice oštećen.
</ptxt>
</item>
<item>
<ptxt>
Provjerite rad servouređaja kočnice prema uputama pod naslovom &#34;Provjera rada&#34; pod 
<intxref refid = "AHRAP70A4106021">Provjera rada servouređaja kočnice</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Provjerite manžetu radi oštećenja i dotrajalosti.
</ptxt>
</item>
<item>
<ptxt>
Provjerite duljinu potisne šipke.
</ptxt>
<ptxt>
Ako rezultati ne odgovaraju propisanom, zamijenite servouređaj kočnice.
</ptxt>
</item>
</list1>
<spec>
<title>
Duljina potisne šipke
</title>
<ptxt>
“a”: 114,5 – 115,5 mm (4,507 – 4,547 in)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I3RM0A410056.swf" width = "88.000mm" height = "44.057mm" ver = "01" gw = "139" gh = "108"/>
</figure>
</servinfo>
</servinfotype>
</configtype>
</servcat>
