<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A6104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nepredvidivo upravljanje tijekom kočenja
</title>
<diag type = "condition">
<condition>
<ptxt>
Nepredvidivo upravljanje tijekom kočenja
</ptxt>
</condition>
<ps>
<ptxt>
Istrošeni ležajevi kotača
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite ležajeve kotača. 
<intxreftitleoff1 refid = "AHRAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slomljena ili uleknuta zavojna opruga
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite zavojnu oprugu. 
<intxreftitleoff1 refid = "AHRAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neispravan sklop prednje opružne noge (amortizer)
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite sklop prednje opružne noge (amortizer). 
<intxreftitleoff1 refid = "AHRAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Neujednačen tlak u gumi
</ptxt>
</ps>
<action>
<ptxt>
Podesite tlak u gumi. 
</ptxt>
</action>
<ps>
<ptxt>
Poremećena geometrija prednjih kotača
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i podesite geometriju prednjih kotača. 
<intxreftitleoff1 refid = "AHRAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kočnice ne rade zajednički
</ptxt>
</ps>
<action>
<ptxt>
Provjerite i popravite sustav kočnica. 
<intxreftitleoff1 refid = "AHRAP70A4101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disk prednje kočnice onečišćen je kočnom tekućinom
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite disk prednje kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Iskrivljeni disk kočnice
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite prednji disk kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vrlo istrošene kočne pločice
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite stražnji disk kočnice. 
<intxreftitleoff1 refid = "AHRAP70A4206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
