<servinfosub id = "AHRAP70A1104061003">
<title>
Postupak potvrde DTC-a
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Provedite testnu vožnju u području gdje nema prometa kako biste spriječili nezgodu.
</ptxt>
</item>
<item>
<ptxt>
Test trebaju izvršiti dvije osobe, vozač i ispitivač, na ravnoj cesti.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Obavezno prvo riješite probleme neočekivanih DTC-ova prethodno detektiranih u &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<item>
<ptxt>
Potvrdite da su zadovoljeni sljedeći uvjeti u ovom &#34;Postupku potvrde DTC-a&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Napon akumulatora &#62; 10,7 V
</ptxt>
</item>
<item>
<ptxt>
Aktivirana je kontrola povratne informacije A/F-a (zatvorena petlja).
</ptxt>
</item>
<item>
<ptxt>
Nije detektiran DTC P0137, P0138, P0140, P0300, P0301, P0302, P0303, P0304, P0443, P0458, P0459, P0627, P0628 ili P0629.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Pokrenite motor i zagrijte ga na normalnu radnu temperaturu.
</ptxt>
</s1>
<s1>
<ptxt>
Vozite vozilo brzinom od 60 do 80 km/h (37 do 50 milja/h) u trajanju od 20 min ili više.
</ptxt>
</s1>
<s1>
<ptxt>
Otpustite papučicu gasa pri brzini vozila 60 km/h (37 milja/h) i pustite da se vozilo kreće pod utjecajem kočenja motorom kako bi se proizvelo stanje prekida dobave goriva.
</ptxt>
</s1>
<s1>
<ptxt>
Ponovite 2. i 3. korak 5 puta.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1104061004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A1104061005">
<testgroup id = "AHRAP70A1104061006">
<question>
Je li izvršena &#34;Provjera sustava upravljanja motorom i emisijom&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A1104001">Provjera sustava upravljanja motorom i emisijom</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104061007">
<title>
Provjera DTC-a
</title>
<question>
Postoje li DTC-i osim P2270 i P2271?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na postupak rješavanja problema za dotični DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 3. korak.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104061008">
<title>
Provjera ispušnog sustava i sustava usisa zraka
</title>
<test1>
<ptxt>
Provjerite jesu li ispušni sustav i sustav usisa zraka začepljeni ili propuštaju.
</ptxt>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 4. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravni dio.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A1104061009">
<title>
Provjera strujnog kruga uzemljenja i signala HO2S
</title>
<test1>
<ptxt>
Provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Krugovi &#34;B2&#34; i &#34;B3&#34;: Idite na 3. korak pod 
<intxref refid = "AHRAP70A1104028">DTC P0137/P0138/P0140</intxref>
</ptxt>
</item>
</list1>
</test1>
<question>
Je li rezultat provjere u redu?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 5. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Popravite ili zamijenite neispravno ožičenje.
</ptxt>
</action>
</testgroup>
