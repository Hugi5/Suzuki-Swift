<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7226031" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja senzora sunčevog svjetla
</title>
<servinfosub id = "AHRAP70A7226031001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Deaktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite ploču s instrumentima. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite senzor sunčevog svjetla (1) s ploče s instrumentima pritiskanjem osigurača i guranjem senzora gore s donje strane.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor senzora sunčevog svjetla (2).
</ptxt>
<figure page = "2">
<graphic graphicname = "I7RW01722028.swf" width = "88.000mm" height = "40.458mm" ver = "01" gw = "238" gh = "98"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHRAP70A7226031002">
<title>
Ugradnja
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A7226032">Pregled senzora sunčevog svjetla:Automatski tip</intxrefpoff>
</ptxt>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeću točku.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ugradite senzor sunčevog svjetla (1) na ploču s instrumentima, namještajući osigurače (2) senzora sunčevog svjetla u utore (3) na ploči s instrumentima na način prikazan na slici.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723025.swf" width = "88.000mm" height = "35.371mm" ver = "01" gw = "209" gh = "84"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.181in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Prednji dio vozila
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
