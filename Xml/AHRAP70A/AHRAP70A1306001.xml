<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1306001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja ECM-a
</title>
<attention2>
<ptxt>
ECM se sastoji od preciznih dijelova, pazite da ga ne izložite pretjeranim potresima.
</ptxt>
</attention2>
<attention3>
<ptxt>
Nakon što ste ECM zamijenili novim, napravite 
<intxref refid = "AHRAP70A1306002">Postupak nakon zamjene ECM-a</intxref>
.
</ptxt>
</attention3>
<servinfosub id = "AHRAP70A1306001001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Okrenite polugu zaključavanja (1) u smjeru strelice dok se ne zaustavi.
</ptxt>
<ptxt>
Odspojite konektore s ECM-a.
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130001.swf" width = "88.000mm" height = "35.930mm" ver = "01" gw = "189" gh = "85"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite ECM (1) iz nosača uklanjajući pričvrsne matice (2).
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130002.swf" width = "88.000mm" height = "46.930mm" ver = "01" gw = "116" gh = "117"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1306001002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Pritegnite pričvrsne matice ECM-a propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T1C001">
<t-part>
Matica za ugradnju ECM-a
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7Y50A130003.swf" width = "88.000mm" height = "46.696mm" ver = "01" gw = "101" gh = "116"/>
</figure>
</item>
<item>
<ptxt>
Spojite konektore na ECM na sljedeći način:
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Pazite da je poluga zaključavanja konektora ECM-a u otključanom položaju.
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130004.swf" width = "88.000mm" height = "35.930mm" ver = "01" gw = "69" gh = "85"/>
</figure>
</item>
<item>
<ptxt>
Umetnite ECM konektore u ECM dok se ne zaustave s polugom u zaključanom položaju.
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130005.swf" width = "88.000mm" height = "35.928mm" ver = "01" gw = "69" gh = "85"/>
</figure>
</item>
<item>
<ptxt>
Povucite polugu zaključavanja prema dolje da biste čvrsto zaključali ECM konektore.
</ptxt>
<figure>
<graphic graphicname = "I7Y50A130006.swf" width = "88.000mm" height = "35.930mm" ver = "01" gw = "168" gh = "85"/>
</figure>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
