<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1406004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i postavljanje sklopa pročistača zraka
</title>
<ptxt>
<intxrefpoff refid = "AHRAP70A1406001">Komponente pročistača zraka</intxrefpoff>
</ptxt>
<servinfosub id = "AHRAP70A1406004001" page = "2">
<title>
Uklanjanje
</title>
<s1 page = "2">
<ptxt>
Odspojite negativni kabel (-) s akumulatora.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Iskopčajte konektor MAF i IAT senzora (1).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Uklonite ventil pražnjenja EVAP spremnika (2).
</ptxt>
</s1>
<s1>
<ptxt>
Odvojite kopče ožičenja motora.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Odvijte vijak obujmice izlaznog crijeva pročistača zraka i uklonite sklop pročistača zraka (3) s usisnom cijevi zraka (4).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite izlazno crijevo pročistača zraka (6) prema sljedećoj proceduri, ako je potrebno.
</ptxt>
<s2>
<ptxt>
Odspojite cijev oduška (5) od izlaznog crijeva pročistača zraka.
</ptxt>
</s2>
<s2>
<ptxt>
Uklonite izlazno crijevo pročistača zraka.
</ptxt>
</s2>
<figure>
<graphic graphicname = "I9P60A141019.jpg" width = "88.000mm" height = "98.987mm" ver = "01" gw = "199" gh = "264"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A1406004002" page = "2">
<title>
Ugradnja
</title>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
