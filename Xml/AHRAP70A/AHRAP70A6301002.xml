<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "1">
<servinfo servinfosgmlid = "AHRAP70A6301002" svcinfotypenbr = "03" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Opis funkcija komponenti EPS sustava
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "3" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.429in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.488in"/>
<colspec colnum = "3" colname = "3" colwidth = "4.219in"/>
<thead>
<row rowsep = "1">
<entry namest = "1" nameend = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Komponente EPS sustava
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Funkcija
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Sklop stupa upravljača
</emph>
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Senzor okretnog momenta
</emph>
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Koristeći dva kruga (npr. glavni i pomoćne krugove), senzor okretnog momenta šalje napone proporcionalne ulaznom okretnom momentu upravljača i smjeru na upravljački modul servoupravljača.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Motor P/S-a
</emph>
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Motor P/S-a proizvodi pomoćne okretne momente upravljaču koji odgovaraju električnoj struji iz upravljačkog modula P/S-a.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Upravljački modul servoupravljača
</emph>
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Upravljački modul P/S-a upravlja strujom pogonskog motora tako da određuje količinu i smjer pomoći zasnovane na signalu napona senzora okretnog momenta i brzini vozila i drugih podataka koji dolaze putem CAN komunikacija.
</ptxt>
</item>
<item>
<ptxt>
Upravljački modul P/S-a procjenjuje je li motor radi ili ne pomoću signala brzine vrtnje motora sa CAN-a
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry namest = "1" nameend = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
Svjetlo upozorenja &#34;P/S&#34;
</emph>
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
&#34;P/S&#34; svjetlo upozorenja se uključuje kada postoji abnormalnost u sustavu P/S-a.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
