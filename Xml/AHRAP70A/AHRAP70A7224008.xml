<servinfosub id = "AHRAP70A7224008001" page = "2">
<title>
Definicije podataka alata za skeniranje
</title>
<deflist>
<term id = "AHRAP70A7224008002">
Temp Cont Switch: (Položaj prekidača kontrole temperature, maks. hladno, &#176;C/&#176;F, maks. vruće)
</term>
<def>
<ptxt>
Ovaj parametar označava odabrani položaj prekidača kontrole temperature.
</ptxt>
</def>
<term id = "AHRAP70A7224008003">
Mode Cont Switch (Položaj prekidača protoka zraka, AUTO, FACE, B/L, FOOT, DE-FO, DEF)
</term>
<def>
<ptxt>
Ovaj parametar označava odabrani položaj prekidača protoka zraka.
</ptxt>
</def>
<term id = "AHRAP70A7224008004">
Fan Cont Switch (Prekidač brzine puhala, AUTO, OFF, 1. - 8.)
</term>
<def>
<ptxt>
Ovaj parametar označava odabrani položaj prekidača brzine puhala.
</ptxt>
</def>
<term id = "AHRAP70A7224008005">
Air Intake Mode (Položaj prekidača usisa zraka, AUTO, FRE, REC, H-REC)
</term>
<def>
<ptxt>
Ovaj parametar označava odabrani položaj prekidača usisa zraka.
</ptxt>
</def>
<term id = "AHRAP70A7224008006">
Vehicle spojeno (km/h, milja/h)
</term>
<def>
<ptxt>
Ovaj parametar označava brzinu vozila koju je izračunao ECM.
</ptxt>
</def>
<term id = "AHRAP70A7224008007">
ECT (Temperatura rashladne tekućine &#176;C/&#176;F)
</term>
<def>
<ptxt>
Ovaj parametar označava temperatura rashladne tekućine motora koju je detektirao senzor temperature rashladne tekućine motora.
</ptxt>
</def>
<term id = "AHRAP70A7224008008">
Vrsta motora (Signal vrste motora, K12)
</term>
<def>
<ptxt>
Ovaj parametar označava signal tipa motora kojega šalje ECM.
</ptxt>
</def>
<term id = "AHRAP70A7224008009">
Odspojite Air Temp (Temperatura zraka u okolini, &#176;C/&#176;F)
</term>
<def>
<ptxt>
Ovaj parametar označava temperaturu zraka u okolini koju je detektirao senzor temperature zraka u okolini.
</ptxt>
</def>
<term id = "AHRAP70A7224008010">
Rabin Temperature: (Temperatura u automobilu, &#176;C/&#176;F)
</term>
<def>
<ptxt>
Ovaj parametar označava temperaturu u automobilu koju je detektirao senzor temperature zraka unutrašnjosti.
</ptxt>
</def>
<term id = "AHRAP70A7224008011">
Sun Load (W/m<sup>2</sup> )
</term>
<def>
<ptxt>
Ovaj parametar označava intenzitet sunčevog svjetla kojeg je detektirao senzor sunčevog svjetla.
</ptxt>
</def>
<term id = "AHRAP70A7224008012">
Evaporator Temp (Temperatura isparivača, &#176;C/&#176;F)
</term>
<def>
<ptxt>
Ovaj parametar označava temperaturu zraka koji prolazi kroz isparivač.
</ptxt>
</def>
<term id = "AHRAP70A7224008013">
Refrigerant Pressure (Apsolutni tlak rashladnog sredstva klima uređaja, kPa)
</term>
<def>
<ptxt>
Ovaj parametar označava apsolutni tlak rashladnog sredstva klima uređaja koji je izračunao ECM
</ptxt>
</def>
<term id = "AHRAP70A7224008014">
Air Ix Pos Sen (Senzor položaja aktivatora kontrole temperature, V)
</term>
<def>
<ptxt>
Ovaj parametar označava ulazni signal sa senzora položaja u aktivatoru kontrole temperature.
</ptxt>
</def>
<term id = "AHRAP70A7224008015">
Mode Pos Sensor (Senzor položaja aktivatora kontrole protoka zraka, V)
</term>
<def>
<ptxt>
Ovaj parametar označava ulazni signal sa senzora položaja u aktivatoru protoka zraka.
</ptxt>
</def>
<term id = "AHRAP70A7224008016">
Fan Desired Volt (Željeni napon ventilatora, V)
</term>
<def>
<ptxt>
Ovaj parametar označava potrošnju napona na motoru puhala.
</ptxt>
</def>
<term id = "AHRAP70A7224008017">
AC Cont Žig (Upravljački signal klima uređaja, ON, OFF)
</term>
<def>
<ptxt>
Ovaj parametar označava stanje prekidača klima uređaja.
</ptxt>
</def>
<term id = "AHRAP70A7224008018">
Blower Load Sig (Signal opterećenja ventilatora puhala, ON, OFF)
</term>
<def>
<ptxt>
ON: Prekidač brzine puhala je u 4. ili višem položaju.
</ptxt>
<ptxt>
ISKLJUČENO: Prekidač brzine puhala je u položaju od ISKLJ do 3.
</ptxt>
</def>
<term id = "AHRAP70A7224008019">
Erar Def Indikator (Indikator stražnjeg grijača prozora, ON, OFF)
</term>
<def>
<ptxt>
Ovaj parametar označava odabrani položaj prekidača stražnjeg grijača prozora.
</ptxt>
</def>
<term id = "AHRAP70A7224008020">
A/C Comp Cluch (Magnetska spojka kompresora klima uređaja, ON, OFF)
</term>
<def>
<ptxt>
Ovaj parametar označava stanje magnetske spojke kompresora klima uređaja.
</ptxt>
</def>
<term id = "AHRAP70A7224008021">
Engine Čun Request (Signal zahtjeva za pokretanje motora, ON, OFF)
</term>
<def>
<ptxt>
Ovaj parametar ostaje isključen.
</ptxt>
</def>
</deflist>
