<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A7226009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja ploče automatskog klima uređaja
</title>
<servinfosub id = "AHRAP70A7226009001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Odspojite negativni kabel (–) s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite prednju kutiju podne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite ploču sklopa kombiniranog mjerača s ploče s instrumentima i rešetku središnjeg otvora za provjetravanje. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite audio uređaj. 
<intxreftitleoff1 refid = "AHRAP70A9F06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite modul zračnog jastuka suvozača (uređaj za napuhavanje). 
<intxreftitleoff1 refid = "AHRAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite središnje obloge. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite ploču automatskog klima uređaja (1) s ploče s instrumentima.
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor ploče automatskog klima uređaja.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723013.swf" width = "88.000mm" height = "64.865mm" ver = "03" gw = "233" gh = "167"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A7226009002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite postupak uklanjanja.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
