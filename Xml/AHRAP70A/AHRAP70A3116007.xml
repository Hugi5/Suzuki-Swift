<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A3116007" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Provjera prednjeg ležaja kotača
</title>
<s1>
<ptxt>
Potvrdite zategnutost matice kotača i, ako je potrebno, ponovno ih zategnite propisanim momentom pritezanja. 
<intxreftitleoff1 refid = "AHRAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Podignite vozilo.
</ptxt>
</s1>
<s1>
<ptxt>
Provjerite trošenje ležaja kotača. Kada mjerite slobodni hod, koristite komparator na prednjem kotaču kao što je prikazano na slici.
</ptxt>
<ptxt>
Ako rezultati ne odgovaraju propisanima, zamijenite ležaj.
</ptxt>
<spec-sdm>
<sdm-title>
Slobodni hod ležaja prednjeg kotača
</sdm-title>
<sdm1>
<sdm-condition>
Granica
</sdm-condition>
<sdm-value>
0,1 mm (0,004 in)
</sdm-value>
</sdm1>
</spec-sdm>
<figure>
<graphic graphicname = "I3RM0A230049.swf" width = "88.000mm" height = "55.572mm" ver = "01" gw = "194" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Provjerite buku ležaja kotača i lagano okretanje kotača rotiranjem kotača.
</ptxt>
<ptxt>
Ako je neispravan, zamijenite ležaj.
</ptxt>
<figure>
<graphic graphicname = "I3RM0A230050.swf" width = "88.000mm" height = "52.948mm" ver = "01" gw = "162" gh = "133"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
