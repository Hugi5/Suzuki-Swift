<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70AA206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i postavljanje BCM-a
</title>
<servinfosub id = "AHRAP70AA206003001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Deaktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite negativni (–) kabel s akumulatora.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite poklopac provrta stupa upravljača prema koraku 4) od 
<intxref refid = "AHRAP70A6206009">Uklanjanje i ugradnja stupa upravljača</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite oblogu na strani poprečne pregradne stijene. 
<intxreftitleoff1 refid = "AHRAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektore (1) i obujmice s J/B-a (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite matice (3) i zatim uklonite J/B (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20016.jpg" width = "88.000mm" height = "78.207mm" ver = "01" gw = "202" gh = "205"/>
</figure>
</s1>
<s1>
<ptxt>
Odspojite konektore (1) iz BCM-a (2).
</ptxt>
</s1>
<s1>
<ptxt>
Uklonite matice BCM-a (3) i zatim uklonite BCM.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20017.jpg" width = "88.000mm" height = "82.962mm" ver = "01" gw = "198" gh = "219"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70AA206003002">
<title>
Ugradnja
</title>
<ptxt>
Obrnite redoslijed postupka uklanjanja imajući na umu sljedeće.	
</ptxt>
</servinfosub>
<list1 type = "unordered">
<item>
<ptxt>
Matice BCM-a zategnite propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T10B001">
<t-part>
Matica BCM-a
</t-part>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Aktivirajte sustav zračnih jastuka. 
<intxreftitleoff1 refid = "AHRAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ako se zamijeni BCM, izvršite 
<intxref refid = "AHRAP70AA206002">Registracija BCM-a (model s kontakt bravom)</intxref>
.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
