<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A1706007" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Provjera brizgaljke goriva na vozilu
</title>
<s1>
<ptxt>
Korištenjem alata za slušanje (1) ili sličnog, provjerite zvuk rada brizgaljke (2) dok motor radi ili ga pokrećete.
</ptxt>
<ptxt>
Ciklus zvuka trebao bi varirati prema brzini motora.
</ptxt>
<ptxt>
Ako ne začujete nikakav zvuk ili začujete neobičan zvuk, provjerite strujni krug brizgaljke (žica ili priključak) ili brizgaljku.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B170007.swf" width = "88.000mm" height = "48.375mm" ver = "01" gw = "143" gh = "120"/>
</figure>
</s1>
<s1>
<ptxt>
Isključite konektor (1) iz brizgaljke, spojite ommetar između terminala brizgaljke i provjerite otpor.
</ptxt>
<ptxt>
Ako otpor značajno odskače od propisanog, zamijenite.
</ptxt>
<spec>
<title>
Referentni otpor brizgaljke goriva
</title>
<ptxt>
11,6 – 12,4 &#937; pri 20 &#176;C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I2RH0B170008.swf" width = "88.000mm" height = "52.482mm" ver = "01" gw = "179" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Čvrsto priključite konektor na brizgaljku.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
