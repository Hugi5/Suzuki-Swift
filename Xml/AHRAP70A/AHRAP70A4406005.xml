<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4D">
<servcat sctnbr = "04" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHRAP70A4406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uklanjanje i ugradnja poluge parkirne kočnice
</title>
<attention1>
<ptxt>
Pazite da postoje sljedeći uvjeti prije nego što uklonite polugu parkirne kočnice.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Radite na ravnoj površini.
</ptxt>
</item>
<item>
<ptxt>
Prebacite stupanj prijenosa u 1. brzinu.
</ptxt>
</item>
<item>
<ptxt>
Blokirajte kotače.
</ptxt>
</item>
</list1>
</attention1>
<servinfosub id = "AHRAP70A4406005001">
<title>
Uklanjanje
</title>
<s1>
<ptxt>
Uklonite stražnju kutiju podne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Odspojite konektor prekidača parkirne kočnice s poluge parkirne kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Odvijte maticu za namještanje (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A440004.swf" width = "88.000mm" height = "66.682mm" ver = "01" gw = "189" gh = "173"/>
</figure>
</s1>
<s1>
<ptxt>
Uklonite vijke poluge parkirne kočnice (1) i zatim uklonite polugu parkirne kočnice (2) s kompenzatorom (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A440005.swf" width = "88.000mm" height = "80.810mm" ver = "01" gw = "168" gh = "213"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A4406005002">
<title>
Ugradnja
</title>
<s1>
<ptxt>
Pritegnite vijke poluge parkirne kočnice (1) propisanim momentom pritezanja.
</ptxt>
<torque>
<torqueitem id = "T4D001">
<t-part>
Vijak poluge parkirne kočnice
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
26
</t-value1>
<t-value2>
2,7
</t-value2>
<t-value3>
19,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A440006.swf" width = "88.000mm" height = "77.351mm" ver = "01" gw = "174" gh = "203"/>
</figure>
</s1>
<s1>
<ptxt>
Spojite sajlu parkirne kočnice na kompenzator, a zatim je podesite. 
<intxreftitleoff1 refid = "AHRAP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Uvjerite se da kočni sustav radi pravilno.
</ptxt>
</s1>
<s1>
<ptxt>
Spojite konektor prekidača parkirne kočnice s polugom parkirne kočnice.
</ptxt>
</s1>
<s1>
<ptxt>
Ugradite stražnju kutiju podne konzole. 
<intxreftitleoff1 refid = "AHRAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
