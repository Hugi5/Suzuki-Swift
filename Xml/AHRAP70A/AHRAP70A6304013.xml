<servinfosub id = "AHRAP70A6304013003">
<title>
Postupak potvrde DTC-a
</title>
<s1>
<ptxt>
Pokrenite motor.
</ptxt>
</s1>
<s1>
<ptxt>
Okrenite kolo upravljača u potpunosti u oba smjera.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHRAP70A6304013004">
<title>
Rješavanje problema DTC-a
</title>
<diag type = "test" id = "AHRAP70A6304013005">
<testgroup id = "AHRAP70A6304013006">
<question>
Je li izvršena &#34;Provjera EPS sustava&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Idite na 2. korak.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Idite na 
<intxref refid = "AHRAP70A6304001">Provjera sustava P/S-a</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHRAP70A6304013007">
<title>
Provjera krugova motora P/S-a i izlaza motora P/S-a
</title>
<test1>
<ptxt>
Kada je kontakt isključen, odspojite konektor motora P/S-a &#34;E12&#34; s upravljačkog modula P/S-a.
</ptxt>
</test1>
<test1>
<ptxt>
Provjerite ispravnost spojeva terminala s konektorom motora P/S-a &#34;E12&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ako su spojevi u redu, provjerite sljedeće točke.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Otpor između krugova &#34;A1&#34; i &#34;A2&#34;: približno 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Otpor između kruga &#34;A1&#34; i uzemljenja: beskonačan
</ptxt>
</item>
<item>
<ptxt>
Napon kruga &#34;A1&#34;: 0 do 1 V (kada je kontakt uključen)
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Provjerite motor P/S-a. 
<intxreftitleoff1 refid = "AHRAP70A6306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Jesu li u dobrom stanju?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zamijenite upravljački modul P/S-a i ponovno provjerite DTC. 
<intxreftitleoff1 refid = "AHRAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zamijenite motor P/S-a (sklop stupa upravljača). 
<intxreftitleoff1 refid = "AHRAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
