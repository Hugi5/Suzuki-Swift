<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHRAP70A1A04002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Dijagnostika simptoma generatora
</title>
<ptxt>
Problemi u sustavu punjenja očitovat će se kao jedno od sljedećih stanja.
</ptxt>
<servinfosub id = "AHRAP70A1A04002001" page = "1">
<title>
Rad svjetla upozorenja na punjenje
</title>
<diag type = "condition" id = "AHRAP70A1A04002002">
<condition>
<ptxt>
Svjetlo upozorenja na punjenje ne svijetli kada je kontakt uključen, a motor isključen
</ptxt>
</condition>
<ps>
<ptxt>
Pregorjeli osigurač
</ptxt>
</ps>
<action>
<ptxt>
Zamijenite osigurač.
</ptxt>
</action>
<ps>
<ptxt>
Kombinirani mjerač u kvaru
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zamijenite kombinirani mjerač. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Neispravan BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Provjerite BCM. 
</ptxt>
<ptxt>
Model s kontakt bravom: 
<intxreftitleoff1 refid = "AHRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model sa sustavom pokretanja pritiskom prekidača, bez ključa: 
<intxreftitleoff1 refid = "AHRAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
CAN komunikacijska linija u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite CAN komunikacijsku liniju. 
<intxreftitleoff1 refid = "AHRAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ožičenje u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite ožičenje.
</ptxt>
</action>
<ps>
<ptxt>
IC regulator ili uzbudni namot u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite generator. 
<intxreftitleoff1 refid = "AHRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Svjetlo upozorenja na punjenje ne isključuje se kada je motor pokrenut (akumulator je potrebno često puniti)
</ptxt>
</condition>
<ps>
<ptxt>
Labav ili istrošen pogonski remen
</ptxt>
</ps>
<action>
<ptxt>
Namjestite ili zamijenite pogonski remen. 
<intxreftitleoff1 refid = "AHRAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kombinirani mjerač u kvaru
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zamijenite kombinirani mjerač. 
<intxreftitleoff1 refid = "AHRAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Neispravan BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Provjerite BCM. 
</ptxt>
<ptxt>
Model s kontakt bravom: 
<intxreftitleoff1 refid = "AHRAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model sa sustavom pokretanja pritiskom prekidača, bez ključa: 
<intxreftitleoff1 refid = "AHRAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
IC regulator ili generator u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite generator. 
<intxreftitleoff1 refid = "AHRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ožičenje u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite ožičenje.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHRAP70A1A04002003">
<title>
Prekid punjenja akumulatora
</title>
<diag type = "condition" id = "AHRAP70A1A04002004">
<condition>
<ptxt>
Nedovoljno napunjeni akumulator
</ptxt>
</condition>
<ps>
<ptxt>
Labav ili istrošen pogonski remen
</ptxt>
</ps>
<action>
<ptxt>
Namjestite ili zamijenite pogonski remen. 
<intxreftitleoff1 refid = "AHRAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Labav ili korodiran terminal akumulatora 
</ptxt>
</ps>
<action>
<ptxt>
Pritegnite terminal akumulatora ili zamijenite akumulator. 
<intxreftitleoff1 refid = "AHRAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ispravljač, rotor i/ili IC regulator u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite generator. 
<intxreftitleoff1 refid = "AHRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Previše napunjeni akumulator
</ptxt>
</condition>
<ps>
<ptxt>
IC regulator u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite generator. 
<intxreftitleoff1 refid = "AHRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHRAP70A1A04002005">
<title>
Buka
</title>
<diag type = "condition" id = "AHRAP70A1A04002006">
<condition>
<ptxt>
Bučan generator
</ptxt>
</condition>
<ps>
<ptxt>
Labavi pričvrsni vijci
</ptxt>
</ps>
<action>
<ptxt>
Zategnite pričvrsne vijke. 
<intxreftitleoff1 refid = "AHRAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ležajevi prljavi, istrošeni i/ili u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite generator. 
<intxreftitleoff1 refid = "AHRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ispravljač, dioda i/ili stator u kvaru
</ptxt>
</ps>
<action>
<ptxt>
Popravite ili zamijenite generator. 
<intxreftitleoff1 refid = "AHRAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
