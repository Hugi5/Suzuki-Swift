<servinfo servinfosgmlid = "AITAP70A1104073" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0602
</title>
<servinfosub id = "AITAP70A1104073001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<attention3>
<ptxt>
Dopo aver riprogrammato l&#39;ECM, se compare il DTC P0602, è probabile che la riprogrammazione dell&#39;ECM non si sia conclusa correttamente.
</ptxt>
</attention3>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.373in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.824in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0602: Errore di programmazione centralina
</emph>
</ptxt>
<ptxt>
Guasto interno ECM o errore di programmazione della ECM
</ptxt>
<ptxt>
(Logica di rilevamento a 1 D/C)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Guasto di riprogrammazione dell&#39;ECM
</ptxt>
</item>
<item>
<ptxt>
Circuito di alimentazione e/o circuito di massa della ECM
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70A1104073002">
<title>
Descrizione del sistema
</title>
<s1>
<ptxt>
Posizionare il commutatore di accensione su ON per 10 secondi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1104073003">
<title>
Procedura di conferma DTC
</title>
<diag type = "test" id = "AITAP70A1104073005">
<testgroup id = "AITAP70A1104073006">
<title>
Ricontrollo presenza di DTC
</title>
<test1>
<ptxt>
Cancellare il DTC. 
<intxreftitleoff1 refid = "AITAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Posizionare il commutatore di accensione su OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire la procedura di conferma DTC e controllare i DTC.
</ptxt>
</test1>
<question>
È ancora presente il DTC P0602?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controllo guasti intermittenti. 
<intxreftitleoff1 refid = "AITAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104073007">
<title>
Controllo riprogrammazione dell&#39;ECM
</title>
<question>
È stata eseguita la riprogrammazione dell&#39;ECM?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ripetere correttamente la riprogrammazione dell&#39;ECM.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104073008">
<title>
Controllo circuiti di alimentazione e massa ECM
</title>
<test1>
<ptxt>
Controllare i circuiti di alimentazione e di massa della ECM. 
<intxreftitleoff1 refid = "AITAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM con una di provata affidabilità e ricontrollare. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
