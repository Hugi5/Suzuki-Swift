<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A6306008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del tirante / della cuffia cremagliera
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A6306003">Rimozione e installazione dello snodo del tirante</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AITAP70A6306001">Componenti gruppo scatola guida</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AITAP70A6306007">Ispezione della cuffia cremagliera</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A6306008001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il gruppo scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere lo snodo del tirante. 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la fascetta (2) e il fermaglio (1) della cuffia cremagliera.
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Rimuovere la cuffia cremagliera (3) dal tirante.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630026.swf" width = "88.000mm" height = "53.031mm" ver = "02" gw = "158" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Raddrizzare le parti curve della rondella di sicurezza (1) del tirante.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il tirante (3) dalla cremagliera (2) come indicato.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630027.swf" width = "88.000mm" height = "46.459mm" ver = "01" gw = "197" gh = "115"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A6306008002">
<title>
Installazione
</title>
<s1>
<ptxt>
Allineare la scanalatura (5) della cremagliera (2) alla sporgenza (4) della rondella di sicurezza (3) del tirante.
</ptxt>
</s1>
<s1>
<ptxt>
Installare il tirante (1) alla cremagliera (2), quindi serrare il tirante alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T6C003">
<t-part>
Tirante
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A630015.swf" width = "88.000mm" height = "55.132mm" ver = "01" gw = "145" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Piegare la rondella di sicurezza (1) in 2 punti, come indicato in figura.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630029.swf" width = "88.000mm" height = "51.419mm" ver = "02" gw = "144" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Ingrassare la sezione &#34;A&#34; del tirante indicato in figura. Posizionare correttamente la cuffia cremagliera nelle rispettive scanalature del gruppo scatola guida (o nel supporto sul lato della cremagliera) e del tirante.
</ptxt>
<ptxt>
A questo punto, verificare che la cuffia della cremagliera non sia né storta né piegata.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease E" id = "M6C001" uid = "24">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasso
</m-desc>
<m-number>
99000–25050
</m-number>
<m-name>
SUZUKI Super Grease E
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A630030.swf" width = "88.000mm" height = "33.098mm" ver = "01" gw = "196" gh = "77"/>
</figure>
</s1>
<s1>
<ptxt>
Fissare una fascetta nuova (1) utilizzando l&#39;attrezzo speciale e montare il fermaglio (2) della cuffia cremagliera.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C008">
<s-part>
(A)
</s-part>
<s-number num = "09943-55010">
09943–55010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630031.swf" width = "88.000mm" height = "40.262mm" ver = "01" gw = "161" gh = "98"/>
</figure>
</s1>
<s1>
<ptxt>
Installare lo snodo del tirante. 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Montare il gruppo scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
