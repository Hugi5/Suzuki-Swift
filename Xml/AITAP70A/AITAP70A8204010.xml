<servinfosub id = "AITAP70A8204010002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204010003">
<testgroup id = "AITAP70A8204010004">
<title>
Controllo spia di malfunzionamento
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<question>
Si accendono altre spie?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204010005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Collegare lo strumento di diagnosi alla DLC.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente il DTC U0073?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70AA804004">Ricerca guasti per bus di comunicazione dati off</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire la SDM e ripetere il controllo. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204010006">
<title>
Controllo fusibili
</title>
<question>
Il fusibile &#34;MTR&#34; del quadro strumenti è in buone condizioni?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il fusibile &#34;MTR&#34; e controllare la presenza di cortocircuito a massa.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204010007">
<title>
Controllo circuito di comunicazione CAN
</title>
<test1>
<ptxt>
Controllare il circuito di comunicazione CAN tra la SDM e il quadro strumenti.
</ptxt>
</test1>
<question>
Il circuito è integro?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204010008">
<title>
Controllo del circuito di alimentazione del quadro strumenti
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Rimuovere il quadro strumenti.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il collegamento ai terminali del connettore del quadro strumenti collegati ai fili &#34;RED/WHT&#34; e &#34;GRY&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se OK, portare il commutatore d’accensione in posizione &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la tensione tra il filo &#34;RED/WHT&#34; e la massa.
</ptxt>
</test1>
<question>
Il valore della tensione è tra 10 e 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare il circuito di alimentazione del quadro strumenti.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204010009">
<title>
Controllo del circuito di massa del quadro strumenti
</title>
<test1>
<ptxt>
Misurare la resistenza tra il filo &#34;GRY&#34; e la massa.
</ptxt>
</test1>
<question>
La resistenza è inferiore a 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il quadro strumenti e ricontrollare il funzionamento della spia &#34;AIRBAG&#34;. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Interruzione nel filo &#34;GRY&#34;.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Ripetere quanto prescritto in 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per confermare il buon esito della riparazione.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
