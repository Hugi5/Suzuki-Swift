<servinfosub id = "AITAP70A1104022003">
<title>
Procedura di conferma DTC
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Effettuare la prova su strada in una zona esente da traffico, onde evitare incidenti.
</ptxt>
</item>
<item>
<ptxt>
La prova su strada va effettuata su una strada pianeggiante e con a bordo due persone, una che guida e l’altra che esegue i controlli.
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Confermare che la temperatura dell&#39;ECT sia inferiore a 40 &#176;C (104 &#176;F).
</ptxt>
</s1>
<s1>
<ptxt>
Avviare il motore e guidare ad una velocità compresa tra 60 e 80 km/h (37 e 50 miglia/h), costantemente per 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1104022004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A1104022005">
<testgroup id = "AITAP70A1104022006">
<question>
È stata eseguita la procedura &#34;Verifica del sistema di controllo del motore e delle emissioni&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1104001">Verifica del sistema di controllo del motore e delle emissioni</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104022007">
<title>
Controllo livello del liquido di raffreddamento
</title>
<test1>
<ptxt>
Controllare il livello del liquido di raffreddamento. 
<intxreftitleoff1 refid = "AITAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Rabboccare il liquido di raffreddamento e ricontrollare la presenza di DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104022008">
<title>
Controllo del circuito sensore ECT
</title>
<test1>
<ptxt>
Controllare i circuiti del sensore ECT come indicato al passo 2 in 
<intxref refid = "AITAP70A1104023">DTC P0117 / P0118</intxref>
.
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104022009">
<title>
Controllo sensore ECT
</title>
<test1>
<ptxt>
Controllare il sensore ECT. 
<intxreftitleoff1 refid = "AITAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il sensore ECT.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104022010">
<title>
Controllo del termostato
</title>
<test1>
<ptxt>
Controllare il gruppo termostato. 
<intxreftitleoff1 refid = "AITAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il termostato.
</ptxt>
</action>
</testgroup>
</diag>
