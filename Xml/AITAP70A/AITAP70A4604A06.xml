<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A4604A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La spia EBD (spia dei freni) non si accende dopo aver posizionato l&#39;accensione su &#34;ON&#34;.
</title>
<diag type = "condition">
<condition>
<ptxt>
La spia EBD (spia dei freni) non si accende dopo aver posizionato l&#39;accensione su &#34;ON&#34;.
</ptxt>
</condition>
<ps>
<ptxt>
Malfunzionamento dell&#39;ESP<sup>®</sup>
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sistema ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "AITAP70A4604001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sistema di comunicazione CAN difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sistema di comunicazione CAN. 
<intxreftitleoff1 refid = "AITAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Circuito spia EBD difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il circuito spia EBD. 
<intxreftitleoff1 refid = "AITAP70A4604014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
