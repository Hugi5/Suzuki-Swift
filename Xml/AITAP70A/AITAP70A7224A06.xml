<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A7224A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
L’aria fredda esce soltanto se il ventilatore è sulla velocità massima
</title>
<diag type = "condition">
<condition>
<ptxt>
L’aria fredda esce soltanto se il ventilatore è sulla velocità massima
</ptxt>
</condition>
<ps>
<ptxt>
Condensatore occluso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il condensatore. 
<intxreftitleoff1 refid = "AITAP70A7226005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Carica di refrigerante insufficiente
</ptxt>
</ps>
<action>
<ptxt>
Controllare la quantità di refrigerante e l&#39;eventuale presenza di perdite dall&#39;impianto.
</ptxt>
</action>
<ps>
<ptxt>
Aria nell’impianto A/C
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il condensatore ed effettuare le procedure di spurgo e caricamento del sistema A/C. 
<intxreftitleoff1 refid = "AITAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Allentamento o rottura della cinghia di comando del compressore
</ptxt>
</ps>
<action>
<ptxt>
Controllare la cinghia di comando del compressore. 
<intxreftitleoff1 refid = "AITAP70A7226043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compressore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il compressore.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
