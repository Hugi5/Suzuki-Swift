<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A6304024" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Controllo forza sterzante
</title>
<s1>
<ptxt>
Parcheggiare il veicolo in piano e mettere il volante in posizione di marcia in linea retta.
</ptxt>
</s1>
<s1>
<ptxt>
Controllare che la pressione di gonfiaggio dei pneumatici sia corretta facendo riferimento alla targhetta dei pneumatici.
</ptxt>
</s1>
<s1>
<ptxt>
Avviare il motore.
</ptxt>
</s1>
<s1>
<ptxt>
Con il motore al regime minimo, misurare la forza sterzante utilizzando un dinamometro (1).
</ptxt>
<spec-sdm>
<sdm-title>
Forza sterzante
</sdm-title>
<sdm1>
<sdm-condition>
</sdm-condition>
<sdm-value>
34 N (3,5 kgf; 7,6 lbf)
</sdm-value>
</sdm1>
</spec-sdm>
<figure>
<graphic graphicname = "I8C50A630016.swf" width = "88.000mm" height = "42.846mm" ver = "01" gw = "0" gh = "0"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
