<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9506012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del gruppo alzacristalli porta anteriore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9506010">Componenti della porta anteriore</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A9506012001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il vetro della porta anteriore. 
<intxreftitleoff1 refid = "AITAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (3) del motorino alzacristalli elettrico.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo alzacristalli (2) del finestrino anteriore dopo aver tolto i dadi (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950032.jpg" width = "88.000mm" height = "64.165mm" ver = "03" gw = "225" gh = "165"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9506012002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9506013">Ispezione del gruppo alzacristalli finestrino anteriore</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ingrassare le parti scorrevoli del gruppo alzacristalli del finestrino anteriore.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E001" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Grasso
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Serrare i dadi dell&#39;alzacristalli anteriore nell&#39;ordine (da &#34;1&#34; a &#34;6&#34;) alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T9E003">
<t-part>
Dado alzacristalli anteriore*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950033.jpg" width = "88.000mm" height = "70.187mm" ver = "02" gw = "225" gh = "182"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
