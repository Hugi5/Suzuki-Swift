<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Surriscaldamento del motore (la ventola del radiatore non funziona)
</title>
<diag type = "condition">
<condition>
<ptxt>
Surriscaldamento del motore (la ventola del radiatore non funziona)
</ptxt>
</condition>
<ps>
<ptxt>
Fusibile bruciato
</ptxt>
</ps>
<action>
<ptxt>
Controllare il fusibile.
</ptxt>
</action>
<ps>
<ptxt>
Relè ventola di raffreddamento radiatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il relè della ventola di raffreddamento del radiatore. 
<intxreftitleoff1 refid = "AITAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensore ECT guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sensore ECT. 
<intxreftitleoff1 refid = "AITAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motorino ventola di raffreddamento del radiatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il motorino della ventola di raffreddamento del radiatore. 
<intxreftitleoff1 refid = "AITAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio o collegamento a massa difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare il cablaggio.
</ptxt>
</action>
<ps>
<ptxt>
ECM guasta
</ptxt>
</ps>
<action>
<ptxt>
Controllare l&#39;ECM e il relativo circuito. 
<intxreftitleoff1 refid = "AITAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
