<servinfosub id = "AITAP70AA204016003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Mettere l’interruttore luci in posizione &#34;AUTO&#34;.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA204016004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA204016005">
<testgroup id = "AITAP70AA204016006">
<title>
Controllo presenza DTC
</title>
<question>
Viene anche rilevato il DTC B1132?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204016009">
<title>
Controllo parametri
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il parametro &#34;Sensore sistema accensione automatica fari&#34; visualizzato sullo strumento di diagnosi SUZUKI. 
<intxreftitleoff1 refid = "AITAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204016007">
<title>
Controllo circuito sensore sistema d&#39;accensione automatica fari
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore del sensore sistema d&#39;accensione automatica dei fari e il connettore &#34;G05&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il collegamento al connettore del sensore sistema d&#39;accensione automatica dei fari e il connettore &#34;G05&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza dei circuiti &#34;A1&#34; e &#34;A2&#34;: meno di 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il circuito &#34;A1&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il circuito &#34;A2&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra i terminali dei circuiti &#34;A2&#34; e &#34;A3&#34; del connettore sensore sistema di accensione automatica dei fari: infinita
</ptxt>
</item>
<item>
<ptxt>
tensione dei circuiti &#34;A2&#34; e &#34;A3&#34;: 0 – 1 V (con accensione su &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204016008">
<title>
Controllo sensore sistema d&#39;accensione automatica fari
</title>
<test1>
<ptxt>
Controllare il sensore sistema d&#39;accensione automatica fari. 
<intxreftitleoff1 refid = "AITAP70A9206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il sensore sistema d&#39;accensione automatica fari. 
<intxreftitleoff1 refid = "AITAP70A9206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204016010">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Collegare il connettore del sensore sistema d&#39;accensione automatica dei fari e il connettore &#34;G05&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È rilevato il DTC B1148 corrente?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la BCM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
</testgroup>
</diag>
