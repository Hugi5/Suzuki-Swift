</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
P1611: Discrepanza password
</emph>
</ptxt>
<ptxt>
La password memorizzata non è corretta.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
È stata installata la centralina sistema di avviamento senza chiave o la ECM di un altro veicolo.
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Centralina sistema di avviamento senza chiave
</ptxt>
</item>
</list1>
</entry>
