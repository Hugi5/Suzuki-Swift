<servinfosub id = "AITAP70A8204052002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204052003">
<testgroup id = "AITAP70A8204052004">
<title>
Controllo tensione batteria
</title>
<test1>
<ptxt>
Controllare la tensione della batteria.
</ptxt>
</test1>
<question>
Il valore della tensione è compreso tra 9 e 16 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controllare l’impianto di ricarica della batteria e ripararlo. 
<intxreftitleoff1 refid = "AITAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204052005">
<title>
Controllo del collegamento della SDM
</title>
<test1>
<ptxt>
Controllare il collegamento al connettore SDM.
</ptxt>
</test1>
<question>
La connessione è salda?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Guasto intermittente. Controllo guasti intermittenti 
<intxreftitleoff1 refid = "AITAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Se OK, sostituire la SDM con una di provata affidabilità e ricontrollare il collegamento. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AITAP70A8204052006">
<title>
Controllo fusibili
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il fusibile &#34;A/B&#34;.
</ptxt>
</test1>
<question>
Il fusibile &#34;A/B&#34; è integro?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del pavimento e sostituire il fusibile &#34;A/B&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204052007">
<title>
Controllo circuito di alimentazione
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;L04&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la tensione tra il terminale &#34;L04-18&#34; e la massa.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B095">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820157.swf" width = "90.000mm" height = "34.401mm" ver = "01" gw = "194" gh = "81"/>
</testfigure>
</test1>
<question>
Il valore della tensione è compreso tra 10 e 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204052008">
<title>
Controllo circuito di massa
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la resistenza tra il terminale &#34;L04-23&#34; e la massa.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B096">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820158.swf" width = "90.000mm" height = "34.895mm" ver = "01" gw = "193" gh = "82"/>
</testfigure>
</test1>
<question>
Il valore della resistenza è pari o inferiore a 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
I circuiti di alimentazione e massa della SDM sono OK.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
</diag>
