<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1606008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del gruppo termostato (con sensore ECT integrato)
</title>
<servinfosub id = "AITAP70A1606008001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scaricare il liquido di raffreddamento. 
<intxreftitleoff1 refid = "AITAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il sensore CMP di scarico. 
<intxreftitleoff1 refid = "AITAP70A1306017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore del sensore ECT.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il tubo flessibile di ingresso radiatore (2) e il tubo flessibile d&#39;ingresso riscaldatore (3) dal gruppo termostato (1).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo termostato (1) dalla testata.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160003.swf" width = "88.000mm" height = "50.065mm" ver = "01" gw = "181" gh = "125"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1606008002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Usare una guarnizione nuova.
</ptxt>
</item>
<item>
<ptxt>
Riempire l&#39;impianto di raffreddamento con il liquido. 
<intxreftitleoff1 refid = "AITAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Controllare la presenza di perdite nell&#39;impianto di raffreddamento. 
<intxreftitleoff1 refid = "AITAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Controllare se il sensore CMP di scarico perde olio.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
