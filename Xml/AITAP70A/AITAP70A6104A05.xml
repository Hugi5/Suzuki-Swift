<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A6104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Deriva o instabilità dello sterzo
</title>
<diag type = "condition">
<condition>
<ptxt>
Deriva o instabilità dello sterzo
</ptxt>
</condition>
<ps>
<ptxt>
Pneumatici mal assortiti o pressione irregolare
</ptxt>
</ps>
<action>
<ptxt>
Sostituire o regolare la pressione dei pneumatici. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Giunto del braccio delle sospensioni e snodo del tirante allentati
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sostituire il braccio della sospensione o lo snodo del tirante.
</ptxt>
<ptxt>
Braccio delle sospensioni: 
<intxreftitleoff1 refid = "AITAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Snodo tirante: 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Gruppo o supporto dell&#39;ammortizzatore anteriore difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire l’ammortizzatore anteriore o riparare il supporto. 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Allentamento della barra stabilizzatrice
</ptxt>
</ps>
<action>
<ptxt>
Serrare o sostituire la barra stabilizzatrice o le boccole. 
<intxreftitleoff1 refid = "AITAP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Molla elicoidale rotta o insaccata
</ptxt>
</ps>
<action>
<ptxt>
Sostituire la molla elicoidale. 
<intxreftitleoff1 refid = "AITAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo ammortizzatore anteriore difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo ammortizzatore anteriore. 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Contatto denti non corretto tra corona e pignone
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare la coppia rotante dell’albero portapignone e corona. 
<intxreftitleoff1 refid = "AITAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
In caso di difetti, sostituire il gruppo scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Assetto ruote anteriori non corretto
</ptxt>
</ps>
<action>
<ptxt>
Controllare e regolare l&#39;assetto delle ruote anteriori. 
<intxreftitleoff1 refid = "AITAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo scatola guida difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
