<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A7216031" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del condotto posteriore (se in dotazione)
</title>
<servinfosub id = "AITAP70A7216031001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Disabilitare il sistema airbag. 
<intxreftitleoff1 refid = "AITAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i sedili anteriori. 
<intxreftitleoff1 refid = "AITAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la consolle a pavimento anteriore. 
<intxreftitleoff1 refid = "AITAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Staccare il tappeto quanto basta per scoprire completamente i condotti posteriori.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i condotti posteriori destro e sinistro (1).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il condotto centrale posteriore (2), se necessario.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721040.swf" width = "88.000mm" height = "71.569mm" ver = "01" gw = "238" gh = "186"/>
