<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Unità HVAC
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7216031002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
