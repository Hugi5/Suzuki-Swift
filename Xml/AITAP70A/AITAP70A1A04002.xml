<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1A04002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Diagnosi dell&#39;alternatore basata sui sintomi
</title>
<ptxt>
Un problema nell’impianto di ricarica della batteria si manifesta attraverso uno o più dei seguenti sintomi.
</ptxt>
<servinfosub id = "AITAP70A1A04002001" page = "1">
<title>
Funzionamento della spia di segnalazione di carica
</title>
<diag type = "condition" id = "AITAP70A1A04002002">
<condition>
<ptxt>
Mancata accensione spia alternatore con accensione su ON e motore spento
</ptxt>
</condition>
<ps>
<ptxt>
Fusibile bruciato
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il fusibile.
</ptxt>
</action>
<ps>
<ptxt>
Quadro strumenti difettoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sostituire il quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM difettosa
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare la BCM. 
</ptxt>
<ptxt>
Modello con commutatore di accensione: 
<intxreftitleoff1 refid = "AITAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: 
<intxreftitleoff1 refid = "AITAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Linea di comunicazione CAN guasta
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire la linea di comunicazione CAN. 
<intxreftitleoff1 refid = "AITAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire il cablaggio.
</ptxt>
</action>
<ps>
<ptxt>
Regolatore IC o bobina di campo difettoso/a
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Mancato spegnimento della spia alternatore a motore acceso (frequenti ricariche della batteria)
</ptxt>
</condition>
<ps>
<ptxt>
Cinghia di comando allentata o usurata
</ptxt>
</ps>
<action>
<ptxt>
Registrare o sostituire la cinghia di comando. 
<intxreftitleoff1 refid = "AITAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Quadro strumenti difettoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sostituire il quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM difettosa
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare la BCM. 
</ptxt>
<ptxt>
Modello con commutatore di accensione: 
<intxreftitleoff1 refid = "AITAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: 
<intxreftitleoff1 refid = "AITAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Regolatore IC o alternatore difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire il cablaggio.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AITAP70A1A04002003">
<title>
Guasto nella carica della batteria
</title>
<diag type = "condition" id = "AITAP70A1A04002004">
<condition>
<ptxt>
Batteria caricata in misura insufficiente
</ptxt>
</condition>
<ps>
<ptxt>
Cinghia di comando allentata o usurata
</ptxt>
</ps>
<action>
<ptxt>
Registrare o sostituire la cinghia di comando. 
<intxreftitleoff1 refid = "AITAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Terminale batteria allentato o corroso 
</ptxt>
</ps>
<action>
<ptxt>
Serrare il terminale della batteria o sostituire la batteria. 
<intxreftitleoff1 refid = "AITAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Raddrizzatore, rotore e/o regolatore IC difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Batteria caricata in misura eccessiva
</ptxt>
</condition>
<ps>
<ptxt>
Regolatore IC difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AITAP70A1A04002005">
<title>
Rumorosità
</title>
<diag type = "condition" id = "AITAP70A1A04002006">
<condition>
<ptxt>
Alternatore rumoroso
</ptxt>
</condition>
<ps>
<ptxt>
Bulloni di fissaggio laschi
</ptxt>
</ps>
<action>
<ptxt>
Serrare i bulloni di montaggio. 
<intxreftitleoff1 refid = "AITAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cuscinetti sporchi, usurati e/o difettosi
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rotore, diodo e/o statore difettosi
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
