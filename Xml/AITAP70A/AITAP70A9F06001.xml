<servinfo servinfosgmlid = "AITAP70A9F06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;unità audio
</title>
<servinfosub id = "AITAP70A9F06001001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la bocchetta di ventilazione centrale. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;unità audio (1) dal cruscotto dopo aver tolto le 2 viti di montaggio (2).
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare i connettori (3) dell&#39;unità audio.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0004.jpg" width = "88.000mm" height = "63.065mm" ver = "03" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9F06001002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
