<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del servofreno
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A4106020">Componenti servofreno</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A4106022001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare i tubi dei freni (1) dal gruppo centralina elettroidraulica ESP<sup>®</sup> (2), utilizzando l&#39;attrezzo speciale.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410035.swf" width = "88.000mm" height = "45.139mm" ver = "02" gw = "117" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo pompa freni dal servofreno.
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il tubo flessibile della depressione dal servofreno.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il fermaglio (1) e il perno di chiusura del maniglione (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410036.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il servofreno dal cruscotto dopo aver tolto i relativi dadi (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410037.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A4106022004">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A4106023">Controllo servofreno</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Allentare il dado (1) della staffa pedale freno e il bullone (2) rinforzo superiore cofano fisso.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Installare il servofreno sul pannello della plancia. Collegare quindi il maniglione stelo attuatore (3) al braccio del pedale tramite il perno di chiusura del maniglione (2) e il fermaglio (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410040.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Togliere il pannello del quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Serrare i dadi del servofreno alla coppia specificata.
</ptxt>
<torque>
<torqueitem id = "T4A006">
<t-part>
Dado del servofreno*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410041.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Serrare il bullone della staffa pedale del freno alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
Dado staffa pedale del freno
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Serrare il bullone rinforzo superiore cofano fisso alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
Bullone rinforzo superiore cofano fisso
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410042.swf" width = "88.000mm" height = "64.412mm" ver = "02" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Installare il quadro strumenti.
</ptxt>
</s1>
<s1>
<ptxt>
Collegare il tubo flessibile della depressione al servofreno.
</ptxt>
</s1>
<s1>
<ptxt>
Montare il gruppo pompa freni sul servofreno.
</ptxt>
</s1>
<s1>
<ptxt>
Collegare i tubi dei freni (1) al gruppo centralina elettroidraulica ESP<sup>®</sup> (2), utilizzando l&#39;attrezzo speciale.
</ptxt>
<torque>
<torqueitem id = "T4A009">
<t-part>
Dado svasato tubo freno
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410043.swf" width = "88.000mm" height = "46.684mm" ver = "02" gw = "119" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Dopo l&#39;installazione, spurgare l&#39;aria dall&#39;impianto dei freni. 
<intxreftitleoff1 refid = "AITAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controllare che non ci siano perdite di liquido freni da nessuno dei componenti installati.
</ptxt>
</s1>
<s1>
<ptxt>
Controllare il gioco del pedale del freno. 
<intxreftitleoff1 refid = "AITAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Accertare che l&#39;impianto dei freni funzioni correttamente senza perdite di liquido.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
