<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70AA506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione ricevitore sistema di apertura senza chiave
</title>
<servinfosub id = "AITAP70AA506011001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la consolle centrale. 
<intxreftitleoff1 refid = "AITAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1) ricevitore sistema di apertura senza chiave.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il ricevitore sistema di apertura senza chiave (2) dopo aver tolto la vite (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50030.swf" width = "88.000mm" height = "77.203mm" ver = "01" gw = "202" gh = "202"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA506011002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70AA506012">Ispezione del ricevitore sistema di apertura senza chiave</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
