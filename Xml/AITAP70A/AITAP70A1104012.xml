<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1104012" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
La spia MIL rimane accesa dopo l&#39;avviamento del motore.
</title>
<servinfosub id = "AITAP70A1104012001">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A1104012002">
<testgroup id = "AITAP70A1104012003">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Avviare il motore e ricontrollare la presenza di DTC nell&#39;ECM a motore in funzione.
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al funzionamento della spia MIL.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Sostituire il quadro strumenti con uno di provata affidabilità e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Se la spia MIL rimane accesa, sostituire la ECM e ripetere il controllo funzionale della MIL. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
