<servinfosub id = "AITAP70A8204050003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204050004">
<testgroup id = "AITAP70A8204050005">
<question>
È stato eseguito il &#34;Controllo del sistema diagnostico dell&#39;airbag&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204050006">
<title>
Controllo interruzione cablaggio pavimento
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare i connettori &#34;L04&#34; e &#34;L49&#34; o i connettori &#34;L05&#34; e &#34;L50&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza dei circuiti &#34;A1&#34; e &#34;A2&#34; (DTC B1392 / B1393): 1 &#937; o inferiore
</ptxt>
</item>
<item>
<ptxt>
resistenza dei circuiti &#34;A3&#34; e &#34;A4&#34; (DTC B1397 / B1398): 1 &#937; o inferiore
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B091">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820036.swf" width = "90.000mm" height = "67.074mm" ver = "02" gw = "214" gh = "174"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204050007">
<title>
Controllo circuito cablaggio pavimento
</title>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza tra i terminali &#34;L04-11&#34; e &#34;L04-12&#34; (DTC B1392 / B1393): infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra i terminali &#34;L05-11&#34; e &#34;L05-12&#34; (DTC B1397 / B1398): infinita
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B092">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820154.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204050008">
<title>
Controllo circuito cablaggio pavimento
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza tra ciascun circuito &#34;A1&#34; e &#34;A2&#34; e la massa (DTC B1392 / B1393): infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra ciascun circuito &#34;A3&#34; e &#34;A4&#34; e la massa (DTC B1397 / B1398): infinita
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B093">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820155.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204050009">
<title>
Controllo circuito cablaggio pavimento
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
tensione tra ciascun circuito &#34;A1&#34; e &#34;A2&#34; e la massa (DTC B1392 / B1393): circa 0 V
</ptxt>
</item>
<item>
<ptxt>
tensione tra ciascun circuito &#34;A3&#34; e &#34;A4&#34; e la massa (DTC B1397 / B1398): circa 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B094">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820156.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204050010">
<title>
Controllo sensore d’urto laterale posteriore
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Sostituire il sensore d’urto laterale posteriore. 
<intxreftitleoff1 refid = "AITAP70A8206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la SDM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Se presenti, cancellare gli eventuali DTC facendo riferimento a 
<intxref refid = "AITAP70A8204006">Cancellazione DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ripetere 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per verificare che il guasto sia stato effettivamente eliminato.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
