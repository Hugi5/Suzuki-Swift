<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A7226026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;attuatore controllo flusso aria
</title>
<servinfosub id = "AITAP70A7226026001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Disabilitare il sistema airbag. 
<intxreftitleoff1 refid = "AITAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il coperchio del foro del piantone. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il modulo di innesco airbag ginocchia. 
<intxreftitleoff1 refid = "AITAP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il piantone dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo pedale del freno. 
<intxreftitleoff1 refid = "AITAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;attuatore controllo flusso aria (2) dopo aver tolto le viti (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A722011.jpg" width = "88.000mm" height = "63.150mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7226026002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A7226027">Ispezione attuatore controllo flusso aria:Tipo automatico</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Inserire il perno di articolazione (2) nel foro (1) della leva dell&#39;attuatore controllo flusso aria.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722012.swf" width = "88.000mm" height = "68.493mm" ver = "02" gw = "234" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
