<servinfosub id = "AITAP70A8204021003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204021004">
<testgroup id = "AITAP70A8204021005">
<question>
È stato eseguito il &#34;Controllo del sistema diagnostico dell&#39;airbag&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204021006">
<title>
Controllo circuito cablaggio cruscotto
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare i connettori &#34;G347&#34; o &#34;G374&#34; e &#34;G11&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare la barra di cortocircuito interna al connettore dell&#39;SDM inserendo l&#39;apposito attrezzo facente parte dell&#39;attrezzo speciale (A).
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
tensione tra ciascun circuito &#34;A1&#34; e &#34;A2&#34; e la massa: circa 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B016">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820053.swf" width = "90.000mm" height = "57.786mm" ver = "02" gw = "207" gh = "147"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204021007">
<title>
Controllo circuito bobina di contatto
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Collegare il connettore &#34;G347&#34; o &#34;G374&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Rimuovere il modulo di innesco airbag guidatore dal piantone dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare la barra di cortocircuito interna al connettore dell&#39;SDM inserendo l&#39;apposito attrezzo facente parte dell&#39;attrezzo speciale (A).
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
tensione tra ciascun circuito &#34;A1&#34; e &#34;A2&#34; e la massa: circa 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B017">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820053.swf" width = "90.000mm" height = "57.786mm" ver = "02" gw = "207" gh = "147"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la SDM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il gruppo bobina di contatto. 
<intxreftitleoff1 refid = "AITAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Se presenti, cancellare gli eventuali DTC facendo riferimento a 
<intxref refid = "AITAP70A8204006">Cancellazione DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ripetere 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per verificare che il guasto sia stato effettivamente eliminato.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
