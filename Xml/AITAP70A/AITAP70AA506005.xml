<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70AA506005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dispositivo apertura portellone posteriore e interruttore di richiesta
</title>
<servinfosub id = "AITAP70AA506005001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la finitura del portellone posteriore. 
<intxreftitleoff1 refid = "AITAP70A9606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1) dispositivo apertura portellone posteriore e interruttore di richiesta e il fermaglio.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il cadenino inferiore portellone posteriore. 
<intxreftitleoff1 refid = "AITAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il dispositivo apertura portellone posteriore e l&#39;interruttore richiesta (1) dopo aver tolto le viti.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50023.swf" width = "88.000mm" height = "54.154mm" ver = "01" gw = "198" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA506005002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70AA506009">Ispezione dell&#39;interruttore di richiesta</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
