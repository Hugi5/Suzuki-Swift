<servinfosub id = "AITAP70A9304006003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A9304006004">
<testgroup id = "AITAP70A9304006005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Cancellare il DTC. 
<intxreftitleoff1 refid = "AITAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC B1810?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controllo guasti intermittenti 
<intxreftitleoff1 refid = "AITAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A9304006006">
<title>
Controllo sensore livello carburante
</title>
<test1>
<ptxt>
Controllare il sensore livello carburante. 
<intxreftitleoff1 refid = "AITAP70A1706018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Sostituire il sensore livello carburante e ripetere il controllo presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1706017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AITAP70A9304006007">
<title>
Controllo circuito sensore livello carburante
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare i connettori del quadro strumenti e del sensore livello carburante.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i collegamenti ai terminali del quadro strumenti e del sensore livello carburante.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono OK, controllare se il circuito tra il connettore del quadro strumenti e il sensore livello carburante è aperto, in corto a massa o in corto verso l&#39;alimentazione.
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il quadro strumenti e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare il cablaggio difettoso e ricontrollare la presenza di DTC.
</ptxt>
</action>
</testgroup>
</diag>
