<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;alternatore
</title>
<servinfosub id = "AITAP70A1A06005001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il riparo sotto al motore lato destro.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il tubo di scarico n. 1 
<intxreftitleoff1 refid = "AITAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la cinghia di comando pompa dell&#39;acqua/alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il filo del terminale &#34;B&#34; (1) e il connettore (2) dall’alternatore (3).
</ptxt>
</s1>
<s1>
<ptxt>
Staccare e sfilare l&#39;alternatore (3) dal vano motore facendolo passare tra il gruppo supporto sospensioni anteriori e il semiasse anteriore.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1005.jpg" width = "88.000mm" height = "66.800mm" ver = "01" gw = "237" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1A06005002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare il bullone e il perno dell’alternatore alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T1J003">
<t-part>
Bullone dell&#39;alternatore
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1J004">
<t-part>
Bullone perno alternatore
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Collegare il filo (1) all’alternatore come indicato in figura, quindi serrare il dado del terminale &#34;B&#34; alla coppia prescritta.
</ptxt>
<torque>
<torqueitem id = "T1J005">
<t-part>
Dado terminale &#34;B&#34;
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1A1006.jpg" width = "88.000mm" height = "61.151mm" ver = "02" gw = "237" gh = "157"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
