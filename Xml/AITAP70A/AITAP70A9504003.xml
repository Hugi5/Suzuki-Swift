<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A9504003" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnosi del sistema lunotto termico e riscaldatore specchietti retrovisori basata sui sintomi
</title>
<diag type = "condition" id = "AITAP70A9504003001">
<condition>
<ptxt>
Mancato funzionamento del lunotto termico
</ptxt>
</condition>
<ps>
<ptxt>
Guasto dei circuiti del sistema (compresi relè e fusibili)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A9501002">Descrizione del sistema lunotto termico del portellone posteriore e riscaldatore degli specchietti retrovisori</intxref>
 
</ptxt>
</action>
<ps>
<ptxt>
Interruttore lunotto termico difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A9506008">Ispezione dell&#39;interruttore del lunotto termico</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Lunotto termico difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A9506007">Ispezione del lunotto termico</intxref>
</ptxt>
</action>
<ps>
<ptxt>
BCM difettosa
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
&#34;Ispezione della BCM e dei relativi circuiti&#34;: nella SEZIONE 10B.
</ptxt>
<ptxt>
Modello con commutatore di accensione: 
<intxreftitleoff1 refid = "AITAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: 
<intxreftitleoff1 refid = "AITAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<condition>
<ptxt>
I riscaldatori degli specchietti retrovisori elettrici non funzionano
</ptxt>
</condition>
<ps>
<ptxt>
Fusibile bruciato
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il fusibile e controllare la presenza di cortocircuito.
</ptxt>
</action>
<ps>
<ptxt>
Guasto dell&#39;interruttore riscaldatore specchietto retrovisore
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A9506008">Ispezione dell&#39;interruttore del lunotto termico</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio o collegamento a massa difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare il cablaggio.
</ptxt>
</action>
<ps>
<ptxt>
BCM difettosa
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
&#34;Ispezione della BCM e dei relativi circuiti&#34;: nella SEZIONE 10B.
</ptxt>
<ptxt>
Modello con commutatore di accensione: 
<intxreftitleoff1 refid = "AITAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: 
<intxreftitleoff1 refid = "AITAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<condition>
<ptxt>
Il riscaldatore di uno degli specchietti retrovisori esterni non funziona
</ptxt>
</condition>
<ps>
<ptxt>
Riscaldatore specchietto retrovisore difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A9506021">Ispezione degli specchietti retrovisori elettrici esterni e dei riscaldatori a bordo del veicolo</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio o collegamento a massa difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare il cablaggio.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
