</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330003.jpg" width = "88.000mm" height = "51.805mm" ver = "01" gw = "213" gh = "130"/>
</figure>
<figure>
<graphic graphicname = "IAP70A320003.swf" width = "88.000mm" height = "33.813mm" ver = "01" gw = "80" gh = "79"/>
</figure>
</s1>
<s1>
<ptxt>
Installare il tubo di scarico n. 1. 
<intxreftitleoff1 refid = "AITAP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controllare se l’impianto di scarico presenta perdite di gas.
</ptxt>
</s1>
<s1>
<ptxt>
Controllare la presenza di perdite d’olio del rinvio.
</ptxt>
</s1>
