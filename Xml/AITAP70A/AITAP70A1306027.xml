<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1306027" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Ispezione della valvola OCV
</title>
<list1 type = "unordered">
<item>
<ptxt>
Rimuovere le valvole OCV (lato aspirazione e lato scarico). 
<intxreftitleoff1 refid = "AITAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Controllare le valvole OCV (lato aspirazione e lato scarico) come segue.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Controllare la resistenza tra i terminali del connettore della valvola OCV (1).
</ptxt>
<ptxt>
Se l&#39;esito del controllo non è soddisfacente, sostituire la valvola OCV.
</ptxt>
<spec>
<title>
Resistenza valvola OCV
</title>
<ptxt>
da 6,7 a 7,7 &#937; a 20 &#176; C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9T401132006.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "180" gh = "153"/>
</figure>
</item>
<item>
<ptxt>
Collegare la batteria al connettore OCV (1) come indicato in figura, quindi prestare attenzione al suono emesso dal movimento della valvola a spola (2).
</ptxt>
<figure>
<graphic graphicname = "I9T401132007.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "193" gh = "153"/>
</figure>
</item>
</list2>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
