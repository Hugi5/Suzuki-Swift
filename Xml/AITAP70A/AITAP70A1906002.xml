<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del motorino di avviamento
</title>
<servinfosub id = "AITAP70A1906002001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il collettore di aspirazione. 
<intxreftitleoff1 refid = "AITAP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la staffa del sensore di detonazione (1) dal monoblocco.
</ptxt>
<figure>
<graphic graphicname = "IAP70A190003.swf" width = "88.000mm" height = "58.388mm" ver = "01" gw = "172" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Scollegare il filo (1) del teleruttore e il cavo (2) del motorino di avviamento dal motorino di avviamento.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i bulloni di montaggio (3) del motorino di avviamento.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il motorino di avviamento (4).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A190005.swf" width = "183.000mm" height = "82.031mm" ver = "02" gw = "405" gh = "216"/>
</figure>
</servinfosub>
<servinfosub id = "AITAP70A1906002002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1906009">Ispezione del motorino di avviamento</intxrefpoff>
</ptxt>
<ptxt>
Effettuare le procedure di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare i bulloni di fissaggio e il dado del cavo del motorino di avviamento alle coppie indicate.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1I001">
<t-part>
Dado del cavo motorino di avviamento
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1I002">
<t-part>
Bullone di fissaggio motorino di avviamento
</t-part>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
