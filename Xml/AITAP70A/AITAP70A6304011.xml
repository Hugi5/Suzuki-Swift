<diag type = "test" id = "AITAP70A6304011003">
<testgroup id = "AITAP70A6304011004">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Avviare il motore e ricontrollare la presenza di DTC della centralina P/S.
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Eseguire 
<intxref refid = "AITAP70A6304003">Controllo presenza DTC</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304011005">
<title>
Controllo quadro strumenti
</title>
<test1>
<ptxt>
Sostituire il quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<question>
La spia P/S rimane accesa?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina P/S e ricontrollare. 
<intxreftitleoff1 refid = "AITAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
