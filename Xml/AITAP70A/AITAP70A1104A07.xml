<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1104A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Surriscaldamento del motore
</title>
<ptxt>
Eseguire la ricerca guasti facendo riferimento ai punti che seguono nel caso in cui non ci siano DTC memorizzati nell&#39;ECM e dai controlli descritti in 
<intxref refid = "AITAP70A1104008">Ispezione visiva</intxref>
 e 
<intxref refid = "AITAP70A1104009">Ispezione di base del motore</intxref>
 non siano emerse anomalie.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Surriscaldamento del motore
</ptxt>
</condition>
<ps>
<ptxt>
Termostato non funzionante
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1606009">Ispezione del gruppo termostato (con sensore ECT integrato)</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Pompa dell’acqua malfunzionante
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1606017">Ispezione della pompa dell&#39;acqua</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Il radiatore è occluso o perde
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1606014">Ispezione e pulizia del radiatore eseguita sul veicolo</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Olio motore inadeguato
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A0206004">Sostituzione di olio motore e filtro</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Occlusione del filtro olio o della succhieruola
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1504001">Controllo pressione dell&#39;olio</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Pompa dell’olio malfunzionante
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1504001">Controllo pressione dell&#39;olio</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Sistema di controllo ventola di raffreddamento radiatore difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1604002">Controllo del sistema della ventola di raffreddamento radiatore</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Strisciamento dei freni
</ptxt>
</ps>
<action>
<ptxt>
Condizione &#34;Strisciamento dei freni&#34; in 
<intxref refid = "AITAP70A4104001">Diagnosi dei freni basata sui sintomi</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Slittamento della frizione
</ptxt>
</ps>
<action>
<ptxt>
Condizione &#34;Slittamento della frizione&#34; in 
<intxref refid = "AITAP70A5304001">Diagnosi dell&#39;impianto della frizione basata sui sintomi</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Guarnizione della testata fusa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406029">Ispezione testata</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Aria nell&#39;impianto di raffreddamento
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1606006">Riempimento dell&#39;impianto di raffreddamento</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
