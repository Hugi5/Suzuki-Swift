<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A2104A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
In curva il veicolo tende ad inclinarsi o a sbandare
</title>
<diag type = "condition">
<condition>
<ptxt>
In curva il veicolo tende ad inclinarsi o a sbandare
</ptxt>
</condition>
<ps>
<ptxt>
Allentamento della barra stabilizzatrice
</ptxt>
</ps>
<action>
<ptxt>
Serrare bulloni o dadi della barra stabilizzatrice o sostituire le boccole. 
<intxreftitleoff1 refid = "AITAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo o supporto ammortizzatore anteriore difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo ammortizzatore anteriore o serrare il supporto. 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Molle elicoidali rotte o insaccate
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sostituire le molle elicoidali. 
</ptxt>
<ptxt>
Parte anteriore: 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Parte posteriore: 
<intxreftitleoff1 refid = "AITAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Sovraccaricamento del veicolo
</ptxt>
</ps>
<action>
<ptxt>
Controllare il carico.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
