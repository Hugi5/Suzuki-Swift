<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del gruppo tetto apribile
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9906001">Componenti del tetto apribile</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A9906002001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il rivestimento del tetto. 
<intxreftitleoff1 refid = "AITAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il vetro del tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare i 4 tubi flessibili di scarico (1) collegati al gruppo tetto apribile.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990005.jpg" width = "88.000mm" height = "75.169mm" ver = "01" gw = "227" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1) del motorino tetto apribile.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990006.jpg" width = "88.000mm" height = "69.556mm" ver = "01" gw = "225" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Staccare le fascette (1) e il cablaggio tetto apribile (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990007.jpg" width = "88.000mm" height = "61.392mm" ver = "01" gw = "227" gh = "158"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere i dadi (1) del vano tetto apribile, quindi togliere il gruppo tetto apribile (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990008.jpg" width = "88.000mm" height = "83.554mm" ver = "01" gw = "227" gh = "220"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AITAP70A9906002002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare ciascuna parte alla coppia specificata, facendo riferimento a 
<intxref refid = "AITAP70A9906001">Componenti del tetto apribile</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Serrare i dadi (1) del vano tetto apribile nell&#39;ordine da &#34;1&#34; a &#34;4&#34;, indicato in figura.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990009.jpg" width = "88.000mm" height = "82.828mm" ver = "01" gw = "227" gh = "218"/>
</figure>
</item>
<item>
<ptxt>
Collegare i 4 tubi flessibili di scarico (1) al gruppo tetto apribile. Fissare saldamente i tubi flessibili di scarico con le rispettive fascette (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990010.jpg" width = "88.000mm" height = "75.168mm" ver = "01" gw = "227" gh = "197"/>
</figure>
<figure>
<title>
Montante anteriore
</title>
<graphic graphicname = "I9P60A990011.swf" width = "88.000mm" height = "95.842mm" ver = "02" gw = "210" gh = "255"/>
</figure>
<figure>
<title>
Fiancata posteriore
</title>
<graphic graphicname = "I9P60A990013.swf" width = "88.000mm" height = "94.869mm" ver = "03" gw = "225" gh = "252"/>
</figure>
</item>
<item>
<ptxt>
Inizializzare il motorino tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dopo aver reinstallato il gruppo tetto apribile, avere cura di regolare il vetro. 
<intxreftitleoff1 refid = "AITAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
