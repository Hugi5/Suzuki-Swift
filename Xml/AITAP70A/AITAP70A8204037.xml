<servinfosub id = "AITAP70A8204037003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204037004">
<testgroup id = "AITAP70A8204037005">
<question>
È stato eseguito il &#34;Controllo del sistema diagnostico dell&#39;airbag&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204037006">
<title>
Controllo circuito cablaggio pavimento
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare i connettori &#34;L04&#34; e &#34;L47&#34; o i connettori &#34;L05&#34; e &#34;L48&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza dei circuiti &#34;A1&#34; e &#34;A2&#34; (DTC B1083 / B1084): 1 &#937; o inferiore
</ptxt>
</item>
<item>
<ptxt>
resistenza dei circuiti &#34;A3&#34; e &#34;A4&#34; (DTC B1093 / B1074): 1 &#937; o inferiore
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B064">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820029.swf" width = "90.000mm" height = "52.428mm" ver = "03" gw = "207" gh = "132"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204037007">
<title>
Controllo circuito cablaggio pavimento
</title>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza tra i terminali &#34;L04-9&#34; e &#34;L04-10&#34; (DTC B1083 / B1084): infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra i terminali &#34;L05-9&#34; e &#34;L05-10&#34; (DTC B1093 / B1094): infinita
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B065">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820139.swf" width = "90.000mm" height = "59.922mm" ver = "01" gw = "206" gh = "153"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204037008">
<title>
Controllo circuito cablaggio pavimento
</title>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza tra ciascun circuito &#34;A1&#34; e &#34;A2&#34; e la massa (DTC B1083 / B1084): infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra ciascun circuito &#34;A3&#34; e &#34;A4&#34; e la massa (DTC B1093 / B1094): infinita
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B066">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820140.swf" width = "90.000mm" height = "59.922mm" ver = "01" gw = "206" gh = "153"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204037009">
<title>
Controllo circuito cablaggio pavimento
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
tensione tra ciascun circuito &#34;A1&#34; e &#34;A2&#34; e la massa (DTC B1083 / B1084): circa 0 V
</ptxt>
</item>
<item>
<ptxt>
tensione tra ciascun circuito &#34;A3&#34; e &#34;A4&#34; e la massa (DTC B1093 / B1094): circa 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B067">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820141.swf" width = "90.000mm" height = "59.883mm" ver = "01" gw = "206" gh = "153"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204037010">
<title>
Controllo sensore d’urto laterale anteriore
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Sostituire il sensore d’urto laterale anteriore. 
<intxreftitleoff1 refid = "AITAP70A8206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la SDM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Se presenti, cancellare gli eventuali DTC facendo riferimento a 
<intxref refid = "AITAP70A8204006">Cancellazione DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ripetere 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per verificare che il guasto sia stato effettivamente eliminato.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
