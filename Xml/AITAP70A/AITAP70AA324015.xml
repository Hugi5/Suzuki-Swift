<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70AA324015" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1173
</title>
<servinfosub id = "AITAP70AA324015001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1173: Transponder non registrato
</emph>
</ptxt>
<ptxt>
Il codice del transponder integrato nel telecomando non è registrato.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Telecomando non registrato
</ptxt>
</item>
<item>
<ptxt>
Centralina sistema di avviamento senza chiave
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70AA324015002">
<title>
Ricerca guasti
</title>
<attention3>
<ptxt>
L&#39;impossibilità di registrare normalmente l&#39;immobilizzatore può essere causata da un guasto del telecomando.
</ptxt>
</attention3>
</servinfosub>
<diag type = "test" id = "AITAP70AA324015003">
<testgroup id = "AITAP70AA324015006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare la presenza di DTC nella centralina sistema di avviamento senza chiave. 
<intxreftitleoff1 refid = "AITAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono presenti DTC relativi alla rete CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA324015005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare il DTC relativo alla comunicazione CAN.
</ptxt>
</test1>
<question>
Sono presenti DTC relativi alla rete CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA324015004">
<title>
Registrazione telecomando
</title>
<test1>
<ptxt>
Eseguire &#34;Registrazione chiave immobilizzatore&#34;. 
<intxreftitleoff1 refid = "AITAP70AA326002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC B1173?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina sistema di avviamento senza chiave e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (telecomando non registrato)
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
