<servinfo servinfosgmlid = "AITAP70A7224025" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1544
</title>
<servinfosub id = "AITAP70A7224025001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.118in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.087in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1544: Dati non validi tra la centralina HVAC e il pannello A/C automatico
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
La centralina HVAC ha inviato un segnale non valido al pannello A/C automatico.
</ptxt>
</item>
<item>
<ptxt>
La centralina HVAC ha ricevuto un segnale non valido dal pannello A/C automatico.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Pannello A/C automatico
</ptxt>
</item>
<item>
<ptxt>
Centralina HVAC
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70A7224025002">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Avviare il motore ed attivare l&#39;impianto A/C.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7224025003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A7224025004">
<testgroup id = "AITAP70A7224025005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l’accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34; e controllare la presenza di DTC.
</ptxt>
</test1>
<question>
È ancora presente il DTC B1544?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire la centralina HVAC e/o il pannello A/C automatico con una/o di provata affidabilità e ricontrollare la presenza di DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Centralina HVAC: 
<intxreftitleoff1 refid = "AITAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pannello A/C automatico: 
<intxreftitleoff1 refid = "AITAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Guasto intermittente.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
