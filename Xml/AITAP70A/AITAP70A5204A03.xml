<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A5204A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Rumorosità
</title>
<diag type = "condition">
<condition>
<ptxt>
Rumorosità
</ptxt>
</condition>
<ps>
<ptxt>
Lubrificante inadeguato o insufficiente
</ptxt>
</ps>
<action>
<ptxt>
Rabboccare l&#39;olio del cambio manuale.
</ptxt>
</action>
<ps>
<ptxt>
Danneggiamento o usura dei cuscinetti
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire il cuscinetto.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Cuscinetto lato sinistro albero secondario:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Pista interna: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pista esterna: 
<intxreftitleoff1 refid = "AITAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Cuscinetto lato destro albero secondario:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Pista interna: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pista esterna: 
<intxreftitleoff1 refid = "AITAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Cuscinetti sinistro e destro dell&#39;albero primario: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Cuscinetto laterale differenziale:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Pista interna: 
<intxreftitleoff1 refid = "AITAP70A5206025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pista esterna lato destro: 
<intxreftitleoff1 refid = "AITAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pista esterna lato sinistro: 
<intxreftitleoff1 refid = "AITAP70A5206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Cuscinetto ad aghi:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Ingranaggi 1ª e 2ª dell&#39;albero secondario: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ingranaggi 3ª e 4ª dell&#39;albero primario: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ingranaggio 5ª marcia: 
<intxreftitleoff1 refid = "AITAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
</list1>
</action>
<ps>
<ptxt>
Danneggiamento o usura degli ingranaggi
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire l&#39;ingranaggio.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ingranaggi 1ª, 2ª, 3ª e 4ª dell&#39;albero secondario: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ingranaggi 1ª, 2ª, 3ª e 4ª dell&#39;albero primario: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ingranaggio 5ª dell’albero primario e ingranaggio 5ª dell&#39;albero secondario. 
<intxreftitleoff1 refid = "AITAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Danneggiamento o usura dei sincronizzatori
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire i sincronizzatori.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Sincronizzatori marce basse: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sincronizzatori marce alte: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sincronizzatori 5ª marcia: 
<intxreftitleoff1 refid = "AITAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
