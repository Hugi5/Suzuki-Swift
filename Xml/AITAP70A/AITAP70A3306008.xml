</materials>
<spec>
<title>
Posizione di installazione paraolio
</title>
<ptxt>
&#34;a&#34;: 20 – 21 mm (0,79 – 0,82 in.)
</ptxt>
<ptxt>
&#34;b&#34;: 3,5 – 4,5 mm (0,14 – 0,17 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330021.swf" width = "88.000mm" height = "67.725mm" ver = "01" gw = "185" gh = "175"/>
</figure>
</s1>
