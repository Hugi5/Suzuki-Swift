<servinfosub id = "AITAP70A6304014003">
<title>
Procedura di conferma DTC
</title>
<ptxt>
Tenere il motore al regime minimo per almeno 5 secondi.
</ptxt>
</servinfosub>
<servinfosub id = "AITAP70A6304014004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A6304014005">
<testgroup id = "AITAP70A6304014006">
<question>
È stato eseguito il &#34;Controllo del sistema P/S&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A6304001">Controllo del sistema P/S</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304014007">
<title>
Controllo circuiti di alimentazione principale e massa della centralina P/S 
</title>
<test1>
<ptxt>
Controllare i circuiti &#34;A1&#34; e &#34;A2&#34;. 
<intxreftitleoff1 refid = "AITAP70A6304021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304014008">
<title>
Controllo della tensione di alimentazione centralina servosterzo
</title>
<test1>
<ptxt>
Misurare la tensione della batteria con il motore in funzione al regime del minimo.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la tensione della batteria con il motore in funzione a 3.000 giri/min.
</ptxt>
</test1>
<question>
La tensione è compresa tra 9 V e 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina P/S e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controllare l’impianto di ricarica. 
<intxreftitleoff1 refid = "AITAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
