<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1606013" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Smontaggio e rimontaggio della ventola di raffreddamento radiatore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1606012">Rimozione e installazione del gruppo ventola di raffreddamento radiatore</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A1606013001">
<title>
Smontaggio
</title>
<s1 page = "2">
<ptxt>
Rimuovere la ventola (1) dal motorino ventola di raffreddamento (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Rimuovere il motorino della ventola di raffreddamento (2) dal riparo della ventola (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P160006.jpg" width = "88.000mm" height = "55.324mm" ver = "01" gw = "207" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1606013002" page = "2">
<title>
Rimontaggio
</title>
<ptxt>
Effettuare la procedura di smontaggio in senso inverso.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare il dado della ventola e i bulloni del motorino della ventola di raffreddamento del radiatore alla coppia specificata.
</ptxt>
<torque>
<torqueitem id = "T1F001">
<t-part>
Dado ventola
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
<torqueitem id = "T1F002">
<t-part>
Bullone motorino ventola di raffreddamento radiatore
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
4,0
</t-value1>
<t-value2>
0,41
</t-value2>
<t-value3>
3,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70P160010.jpg" width = "88.000mm" height = "51.127mm" ver = "03" gw = "223" gh = "128"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
