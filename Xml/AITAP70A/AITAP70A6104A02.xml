<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A6104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Troppo gioco nello sterzo
</title>
<diag type = "condition">
<condition>
<ptxt>
Troppo gioco nello sterzo
</ptxt>
</condition>
<ps>
<ptxt>
Cuscinetti delle ruote usurati
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il cuscinetto della ruota. 
<intxreftitleoff1 refid = "AITAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Allentamento bulloni della scatola guida
</ptxt>
</ps>
<action>
<ptxt>
Serrare i bulloni della scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo scatola guida difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Usura del giunto del piantone dello sterzo
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo piantone sterzo. 
<intxreftitleoff1 refid = "AITAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Usura dello snodo tirante o del giunto sferico del tirante
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sostituire lo snodo del tirante o il tirante stesso.
</ptxt>
<ptxt>
Snodo tirante: 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Tirante: 
<intxreftitleoff1 refid = "AITAP70A6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Giunto del braccio sospensioni usurato
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il braccio delle sospensioni. 
<intxreftitleoff1 refid = "AITAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Contatto denti non corretto tra corona e pignone
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare la coppia rotante dell’albero portapignone e corona. 
<intxreftitleoff1 refid = "AITAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
In caso di difetti, sostituire il gruppo scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
