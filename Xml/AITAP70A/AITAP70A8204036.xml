<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1082: Dati comunicazione sensore d&#39;urto laterale (lato guida) non validi
</emph>
</ptxt>
<ptxt>
