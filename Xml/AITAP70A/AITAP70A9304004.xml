<servinfosub id = "AITAP70A9304004003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A9304004004">
<testgroup id = "AITAP70A9304004005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Cancellare il DTC. 
<intxreftitleoff1 refid = "AITAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC B1802?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controllo guasti intermittenti 
<intxreftitleoff1 refid = "AITAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A9304004006">
<title>
Controllo circuiti di alimentazione e massa quadro strumenti
</title>
<test1>
<ptxt>
Controllare i circuiti di alimentazione e massa del quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A9304004007">
<title>
Controllo tensione del circuito di alimentazione quadro strumenti
</title>
<test1>
<ptxt>
Controllare la tensione di alimentazione con regime motore a 3.000 giri/min.
</ptxt>
</test1>
<question>
Il valore della tensione è tra 10 e 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il quadro strumenti e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controllare l’impianto di ricarica. 
<intxreftitleoff1 refid = "AITAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
