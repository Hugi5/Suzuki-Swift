<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70AA506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione cicalino esterno
</title>
<servinfosub id = "AITAP70AA506017001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il rivestimento parafango anteriore lato guida. 
<intxreftitleoff1 refid = "AITAP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1), quindi rimuovere il cicalino esterno (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50032.jpg" width = "88.000mm" height = "68.823mm" ver = "01" gw = "213" gh = "179"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA506017002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70AA506018">Ispezione del cicalino esterno</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
