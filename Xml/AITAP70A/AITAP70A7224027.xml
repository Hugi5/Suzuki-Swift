<servinfosub id = "AITAP70A7224027003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Avviare il motore ed attivare l&#39;impianto A/C.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7224027004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A7224027005">
<testgroup id = "AITAP70A7224027006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l’accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34; e controllare la presenza di DTC.
</ptxt>
</test1>
<question>
È ancora presente il DTC B1550-H o B1550-L?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Guasto intermittente.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A7224027007">
<title>
Controllo circuito di comunicazione
</title>
<test1>
<ptxt>
Scollegare i connettori &#34;G20&#34; e &#34;G227&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistenza del circuito del filo &#34;PNK/BLU&#34;: meno di 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Resistenza del circuito del filo &#34;PNK/BLU&#34; tra il pannello A/C automatico e la massa infinita
</ptxt>
</item>
</list1>
</test1>
<question>
I valori della resistenza sono nella norma?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire la centralina HVAC e/o il pannello A/C automatico con una/o di provata affidabilità e ricontrollare la presenza di DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Centralina HVAC: 
<intxreftitleoff1 refid = "AITAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pannello A/C automatico: 
<intxreftitleoff1 refid = "AITAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
