<servinfosub id = "AITAP70A7224023003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Avviare il motore ed attivare l&#39;impianto A/C.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7224023004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A7224023005">
<testgroup id = "AITAP70A7224023006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l’accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34; e controllare la presenza di DTC.
</ptxt>
</test1>
<question>
È ancora presente il DTC B1540?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Guasto intermittente.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A7224023008">
<title>
Controllo fusibili
</title>
<test1>
<ptxt>
Controllare il fusibile &#34;MTR&#34;.
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il fusibile &#34;MTR&#34; e controllare la presenza di cortocircuito a massa.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A7224023007">
<title>
Controllo circuito di alimentazione da batteria
</title>
<test1>
<ptxt>
Scollegare il connettore del pannello A/C automatico.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la tensione tra il terminale del connettore del pannello A/C automatico collegato al filo &#34;WHT/RED&#34; e la massa.
</ptxt>
</test1>
<question>
Il valore della tensione è tra 10 e 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il pannello A/C automatico. 
<intxreftitleoff1 refid = "AITAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
