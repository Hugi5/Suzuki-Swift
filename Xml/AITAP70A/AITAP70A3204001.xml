<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A3204001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnosi del differenziale posteriore basata sui sintomi
</title>
<diag type = "condition" id = "AITAP70A3204001001">
<condition>
<ptxt>
Rumorosità degli ingranaggi
</ptxt>
</condition>
<ps>
<ptxt>
Lubrificante annacquato o deteriorato
</ptxt>
</ps>
<action>
<ptxt>
Riparare e rabboccare. 
<intxreftitleoff1 refid = "AITAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lubrificante inadeguato o insufficiente
</ptxt>
</ps>
<action>
<ptxt>
Riparare e rabboccare. 
<intxreftitleoff1 refid = "AITAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gioco tra pignone e corona costituenti la coppia conica fuori registro
</ptxt>
</ps>
<action>
<ptxt>
Regolare a dovere. 
<intxreftitleoff1 refid = "AITAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Difettoso contatto tra i denti di pignone e corona costituenti la coppia conica
</ptxt>
</ps>
<action>
<ptxt>
Aggiustare o sostituire. 
<intxreftitleoff1 refid = "AITAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Bulloni di fissaggio ingranaggio conico allentati
</ptxt>
</ps>
<action>
<ptxt>
Sostituire o serrare. 
<intxreftitleoff1 refid = "AITAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pignoni del differenziale o ingranaggi planetari danneggiati
</ptxt>
</ps>
<action>
<ptxt>
Sostituire. 
<intxreftitleoff1 refid = "AITAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Rumorosità costante del cuscinetto 
</ptxt>
</condition>
<ps>
<ptxt>
Lubrificante annacquato o deteriorato
</ptxt>
</ps>
<action>
<ptxt>
Riparare e rabboccare. 
<intxreftitleoff1 refid = "AITAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lubrificante inadeguato o insufficiente
</ptxt>
</ps>
<action>
<ptxt>
Riparare e rabboccare. 
<intxreftitleoff1 refid = "AITAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Rumorosità del cuscinetto in fase di rallentamento
</ptxt>
</condition>
<ps>
<ptxt>
Cuscinetti del pignone danneggiati
</ptxt>
</ps>
<action>
<ptxt>
Sostituire. 
<intxreftitleoff1 refid = "AITAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Rumorosità del cuscinetto in fase di sterzata
</ptxt>
</condition>
<ps>
<ptxt>
Danneggiamento dei cuscinetti lato differenziale
</ptxt>
</ps>
<action>
<ptxt>
Sostituire. 
<intxreftitleoff1 refid = "AITAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Perdita d’olio
</ptxt>
</condition>
<ps>
<ptxt>
Tappo di sfiato intasato
</ptxt>
</ps>
<action>
<ptxt>
Pulire.
</ptxt>
</action>
<ps>
<ptxt>
Usura o danneggiamento del paraolio
</ptxt>
</ps>
<action>
<ptxt>
Sostituire. 
<intxreftitleoff1 refid = "AITAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Eccesso d’olio
</ptxt>
</ps>
<action>
<ptxt>
Correggere il livello dell’olio. 
<intxreftitleoff1 refid = "AITAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
