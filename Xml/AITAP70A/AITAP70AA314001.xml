<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70AA314001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Verifica del sistema di controllo immobilizzatore
</title>
<attention3>
<ptxt>
Prima di eseguire la verifica, leggere quanto riportato in 
<intxref refid = "AITAP70AA310002">Norme di sicurezza riguardanti il sistema immobilizzatore:Modello con commutatore di accensione</intxref>
.
</ptxt>
</attention3>
<diag type = "test" id = "AITAP70AA314001001">
<testgroup id = "AITAP70AA314001002">
<question>
Il motorino d’avviamento funziona?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1904001">Diagnosi dell&#39;impianto d’avviamento basata sui sintomi</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA314001003">
<title>
Controllo avviamento motore
</title>
<question>
Il motore si avvia?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA314001004">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Il sistema di controllo immobilizzatore è integro.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA314001005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA314001006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare il DTC relativo alla comunicazione CAN. 
</ptxt>
</test1>
<question>
Sono presenti DTC relativi alla rete CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1104009">Ispezione di base del motore</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
