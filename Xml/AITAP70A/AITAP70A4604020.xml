<servinfosub id = "AITAP70A4604020003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604020004">
<testgroup id = "AITAP70A4604020005">
<question>
È stato eseguito il &#34;Controllo sistema ESP<sup>®</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A4604001">Controllo sistema ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604020006">
<title>
Controllo interruttore ESP® OFF
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Rimuovere l&#39;interruttore ESP<sup>®</sup> OFF. 
<intxreftitleoff1 refid = "AITAP70A4606017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il collegamento su ciascun terminale dell&#39;interruttore ESP<sup>®</sup> OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono OK, controllare l&#39;interruttore ESP<sup>®</sup> OFF. 
<intxreftitleoff1 refid = "AITAP70A4606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire l&#39;interruttore ESP<sup>®</sup> OFF.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604020007">
<title>
Controllo circuito interruttore ESP® OFF
</title>
<test1>
<ptxt>
Scollegare il connettore &#34;E24&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare lo stato del collegamento al terminale &#34;E24-38&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se il collegamento è OK, controllare la resistenza tra il terminale &#34;E24-38&#34; e la massa.
</ptxt>
</test1>
<question>
La resistenza ha valore infinito?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il circuito “A1” se è in corto.
</ptxt>
</action>
</testgroup>
</diag>
