<servinfosub id = "AITAP70AA314009002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA314009003">
<testgroup id = "AITAP70AA314009004">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare il DTC relativo alla comunicazione CAN.
</ptxt>
</test1>
<question>
Sono presenti DTC relativi alla rete CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA314009005">
<title>
Controllo circuito di comunicazione CAN
</title>
<test1>
<ptxt>
Controllare il circuito di comunicazione CAN facendo riferimento a &#34;Procedura di diagnosi&#34; in 
<intxref refid = "AITAP70AA804004">Ricerca guasti per bus di comunicazione dati off</intxref>
.
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. Se il DTC P1642 è ancora presente, sostituire la BCM e ricontrollare la presenza di DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "AITAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
</diag>
