<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A4106023" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Controllo servofreno
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A4106022">Rimozione e installazione del servofreno</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Controllare se il servofreno è danneggiato.
</ptxt>
</item>
<item>
<ptxt>
Controllare il funzionamento del servofreno facendo riferimento a &#34;Controllo funzionale&#34; in 
<intxref refid = "AITAP70A4106021">Controllo funzionale del servofreno</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Controllare se la cuffia è danneggiata o deteriorata.
</ptxt>
</item>
<item>
<ptxt>
Controllare la lunghezza dello stelo attuatore.
</ptxt>
<ptxt>
Se l&#39;esito del controllo non corrisponde a quanto indicato, sostituire il servofreno.
</ptxt>
</item>
</list1>
<spec>
<title>
Lunghezza dello stelo attuatore
</title>
<ptxt>
&#34;a&#34;: 114,5 – 115,5 mm (4,507 – 4,547 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I3RM0A410056.swf" width = "88.000mm" height = "44.057mm" ver = "01" gw = "139" gh = "108"/>
</figure>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
