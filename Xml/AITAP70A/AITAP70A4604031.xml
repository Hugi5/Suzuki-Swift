<title>
DTC C1062
</title>
<servinfosub id = "AITAP70A4604031001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1062: Guasto funzionamento continuo elettrovalvola
</emph>
</ptxt>
<ptxt>
L&#39;elettrovalvola rimane attiva per oltre il lasso di tempo specificato utilizzando &#34;Prova attiva&#34; dello strumento di diagnosi SUZUKI.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Centralina ESP<sup>®</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70A4604031002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604031003">
<testgroup id = "AITAP70A4604031004">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Lasciar raffreddare il sistema ESP<sup>®</sup> montato sul veicolo, per oltre 5 minuti.
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70A4604005">Controllo presenza DTC</intxref>
.
</ptxt>
</test1>
<question>
È presente il DTC C1062?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
