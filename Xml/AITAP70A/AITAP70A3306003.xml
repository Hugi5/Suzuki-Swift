<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A3306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Smontaggio e rimontaggio del rinvio
</title>
<servinfosub id = "AITAP70A3306003001">
<title>
Smontaggio
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Scaricare i seguenti oli.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Olio cambio manuale: 
<intxreftitleoff1 refid = "AITAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Olio del rinvio: 
<intxreftitleoff1 refid = "AITAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo semiasse lato destro. 
<intxreftitleoff1 refid = "AITAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l’albero di trasmissione. 
<intxreftitleoff1 refid = "AITAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il telaio sospensioni anteriori. 
<intxreftitleoff1 refid = "AITAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il supporto posteriore del motore e la staffa supporto posteriore motore. 
<intxreftitleoff1 refid = "AITAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il rinforzo del rinvio (2) e i bulloni.
</ptxt>
</s1>
<s1>
<ptxt>
Separare il gruppo rinvio (1) dal cambio.
</ptxt>
<attention1>
<ptxt>
Durante la rimozione del gruppo rinvio, fare attenzione a non farlo cadere. Diversamente, il rinvio si danneggerebbe e si metterebbe a repentaglio la sicurezza personale.
</ptxt>
</attention1>
<figure>
<graphic graphicname = "IAP70A330004.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "213" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;O-ring (1) e il grano di riferimento (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330005.jpg" width = "88.000mm" height = "52.680mm" ver = "01" gw = "213" gh = "133"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AITAP70A3306003002">
<title>
Riattacco
</title>
<ptxt>
Effettuare la procedura di stacco in senso inverso, tenendo conto delle seguenti istruzioni:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utilizzare un O-ring e un dado del semiasse nuovi.
</ptxt>
</item>
<item>
<ptxt>
Ingrassare l’O-ring (1).
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C004" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasso
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A330006.jpg" width = "88.000mm" height = "50.958mm" ver = "02" gw = "213" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Serrare i bulloni del gruppo di rinvio alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T3C004">
<t-part>
Bullone del rinvio
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Serrare i bulloni del rinforzo del rinvio come segue.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Serrare a mano i bulloni &#34;2&#34; e &#34;3&#34; del rinforzo del rinvio.
</ptxt>
</item>
<item>
<ptxt>
Spingere il rinforzo sul rinvio e serrare i relativi bulloni alla coppia specificata, nell&#39;ordine numerico (&#34;1&#34; - &#34;5&#34;) in modo uniforme e graduale.
</ptxt>
<torque>
<torqueitem id = "T3C005">
<t-part>
Bullone del rinforzo del rinvio*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330007.jpg" width = "88.000mm" height = "56.283mm" ver = "01" gw = "213" gh = "143"/>
</figure>
<figure>
<graphic graphicname = "IAP70A330008.jpg" width = "88.000mm" height = "55.083mm" ver = "01" gw = "202" gh = "140"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Serrare i bulloni e dadi che seguono alla coppia indicata.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Bullone supporto posteriore motore e bullone staffa: 
<intxreftitleoff1 refid = "AITAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bullone di fissaggio telaio sospensioni anteriori: 
<intxreftitleoff1 refid = "AITAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Utilizzare un bullone di fissaggio telaio sospensioni nuovo.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Dado giunto barra stabilizzatrice: 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bullone giunto sferico del braccio delle sospensioni: 
<intxreftitleoff1 refid = "AITAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dado snodo tirante: 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bullone sensore di velocità della ruota anteriore: 
<intxreftitleoff1 refid = "AITAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bullone albero di trasmissione: 
<intxreftitleoff1 refid = "AITAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dado supporto centrale: 
<intxreftitleoff1 refid = "AITAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bullone tubo di scarico: 
<intxreftitleoff1 refid = "AITAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bullone rinforzo tubo di scarico n. 1: 
<intxreftitleoff1 refid = "AITAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dado semiasse: 
<intxreftitleoff1 refid = "AITAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Controllare di utilizzare un nuovo dado del semiasse.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Dado ruota: 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Ribadire il dado del semiasse. 
<intxreftitleoff1 refid = "AITAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rifornire i seguenti oli.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Olio cambio manuale: 
<intxreftitleoff1 refid = "AITAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
	Olio del rinvio: 
<intxreftitleoff1 refid = "AITAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Verificare che non ci sia alcuna perdita di olio e di gas di scarico dai vari raccordi.
</ptxt>
</item>
<item>
<ptxt>
Controllare la geometria dell’avantreno. 
<intxreftitleoff1 refid = "AITAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
