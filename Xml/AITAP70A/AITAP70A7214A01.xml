<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A7214A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Il motorino ventilatore non funziona.
</title>
<diag type = "condition">
<condition>
<ptxt>
Il motorino ventilatore non funziona.
</ptxt>
</condition>
<ps>
<ptxt>
Fusibile bruciato
</ptxt>
</ps>
<action>
<ptxt>
Verificare i fusibili interessati e controllare la presenza di cortocircuito a massa.
</ptxt>
</action>
<ps>
<ptxt>
Relè motorino ventilatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il relè del motorino ventilatore. 
<intxreftitleoff1 refid = "AITAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Resistore motorino ventilatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il resistore del motorino ventilatore. 
<intxreftitleoff1 refid = "AITAP70A7216012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Selettore di velocità del ventilatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il selettore di velocità del ventilatore. 
<intxreftitleoff1 refid = "AITAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio o collegamento a massa difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare il cablaggio.
</ptxt>
</action>
<ps>
<ptxt>
Motorino ventilatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il motorino ventilatore. 
<intxreftitleoff1 refid = "AITAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Presenza di corpi estranei
</ptxt>
</ps>
<action>
<ptxt>
Rimuovere i corpi estranei.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
