<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A7216043" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della valvola di sicurezza
</title>
<servinfosub id = "AITAP70A7216043001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Effettuare la procedura di recupero del refrigerante dall’impianto A/C usando l&#39;apposita apparecchiatura di recupero e riciclo, facendo riferimento a &#34;Recupero&#34; in 
<intxref refid = "AITAP70A7216001">Procedura di caricamento del fluido refrigerante:Tipo manuale</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il riparo sotto al motore lato destro.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la valvola di sicurezza (1) dal compressore.
</ptxt>
<figure>
<graphic graphicname = "I9P60A722038.swf" width = "88.000mm" height = "48.588mm" ver = "03" gw = "120" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7216043002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Usare un O-ring nuovo.
</ptxt>
</item>
<item>
<ptxt>
Applicare olio per compressore sull&#39;O-ring.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B107" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Olio compressore
</m-desc>
<m-number>
99000-99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Serrare la valvola di sicurezza alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T7B107">
<t-part>
Valvola di sicurezza
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,8
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A722039.swf" width = "88.000mm" height = "48.612mm" ver = "05" gw = "120" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Effettuare le procedure di evacuazione e caricamento dell’impianto A/C facendo riferimento a &#34;Evacuazione&#34; e &#34;Caricamento&#34; in 
<intxref refid = "AITAP70A7216001">Procedura di caricamento del fluido refrigerante:Tipo manuale</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
