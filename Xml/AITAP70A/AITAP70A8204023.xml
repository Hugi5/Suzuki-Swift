<servinfosub id = "AITAP70A8204023003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204023004">
<testgroup id = "AITAP70A8204023005">
<question>
È stato eseguito il &#34;Controllo del sistema diagnostico dell&#39;airbag&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204023006">
<title>
Controllo modulo di innesco airbag passeggero
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;G259&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Collegare il cablaggio &#34;VOLANTE&#34; (1) degli attrezzi speciali (A), (B) e (C) al connettore &#34;G259&#34;.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B023">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B024">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932–78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B025">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932–75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820021.swf" width = "90.000mm" height = "75.690mm" ver = "03" gw = "211" gh = "198"/>
</testfigure>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente il DTC B1042?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il modulo di innesco airbag passeggero. 
<intxreftitleoff1 refid = "AITAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204023007">
<title>
Controllo circuito modulo di innesco airbag del passeggero
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;G11&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare la barra di cortocircuito interna al connettore dell&#39;SDM inserendo l&#39;apposito attrezzo facente parte dell&#39;attrezzo speciale (A).
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza tra i terminali &#34;G11-18&#34; e &#34;G11-19&#34;: infinita
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B026">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820054.swf" width = "90.000mm" height = "53.574mm" ver = "02" gw = "200" gh = "135"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la SDM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204023008">
<title>
Controllo circuito cablaggio cruscotto
</title>
<test1>
<ptxt>
Scollegare il connettore &#34;G372&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare la barra di cortocircuito interna al connettore dell&#39;SDM inserendo l&#39;apposito attrezzo facente parte dell&#39;attrezzo speciale (A).
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza tra i terminali &#34;G11-18&#34; e &#34;G11-19&#34;: infinita
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B027">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820054.swf" width = "90.000mm" height = "53.574mm" ver = "02" gw = "200" gh = "135"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il cablaggio del modulo di innesco airbag passeggero.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Se presenti, cancellare gli eventuali DTC facendo riferimento a 
<intxref refid = "AITAP70A8204006">Cancellazione DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ripetere 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per verificare che il guasto sia stato effettivamente eliminato.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
