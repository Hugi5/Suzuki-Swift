<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A7224A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Il motorino ventilatore non funziona.
</title>
<diag type = "condition">
<condition>
<ptxt>
Il motorino ventilatore non funziona.
</ptxt>
</condition>
<ps>
<ptxt>
Fusibile bruciato
</ptxt>
</ps>
<action>
<ptxt>
Verificare i fusibili interessati e controllare la presenza di cortocircuito a massa.
</ptxt>
</action>
<ps>
<ptxt>
Centralina di controllo motorino ventilatore guasta
</ptxt>
</ps>
<action>
<ptxt>
Verificare la centralina di controllo motorino ventilatore. 
<intxreftitleoff1 refid = "AITAP70A7226014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Centralina HVAC guasta
</ptxt>
</ps>
<action>
<ptxt>
Controllare la centralina HVAC. 
<intxreftitleoff1 refid = "AITAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio o collegamento a massa difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare il cablaggio.
</ptxt>
</action>
<ps>
<ptxt>
Motorino ventilatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il motorino ventilatore. 
<intxreftitleoff1 refid = "AITAP70A7226014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Relè motorino ventilatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il relè del motorino ventilatore. 
<intxreftitleoff1 refid = "AITAP70A7226042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pannello A/C automatico guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare l&#39;impianto A/C automatico. 
<intxreftitleoff1 refid = "AITAP70A7224037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
