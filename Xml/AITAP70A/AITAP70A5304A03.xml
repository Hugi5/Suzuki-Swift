<servinfo servinfosgmlid = "AITAP70A5304A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La frizione vibra
</title>
<diag type = "condition">
<condition>
<ptxt>
La frizione vibra
</ptxt>
</condition>
<ps>
<ptxt>
Materiale d&#39;attrito della frizione liso (liscio come il vetro)
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire il disco frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Materiale d’attrito della frizione intriso d’olio
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il disco frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Il cuscinetto reggispinta non scorre regolarmente.
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo cilindro attuatore frizione. 
<intxreftitleoff1 refid = "AITAP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disco frizione eccentrico o difettoso contatto del materiale d’attrito
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il disco frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Affaticamento delle molle di torsione nel disco frizione
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il disco frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rivetti del disco frizione laschi
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il disco frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformazione dello spingidisco o del volano
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire coperchio frizione o volano.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Disco e coperchio frizione: 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Volano: 
<intxreftitleoff1 refid = "AITAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Allentamento o affaticamento di bulloni e/o dadi del supporto motore
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il supporto motore oppure serrare nuovamente i relativi bulloni e/o i dadi. 
<intxreftitleoff1 refid = "AITAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
