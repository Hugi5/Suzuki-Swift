<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1104045" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0606
</title>
<servinfosub id = "AITAP70A1104045001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.455in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.728in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0606: Processore centralina
</emph>
</ptxt>
<ptxt>
Il processore interno della ECM è guasto.
</ptxt>
<ptxt>
(Logica di rilevamento a 3 D/C)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Circuito di alimentazione e/o circuito di massa della ECM
</ptxt>
</item>
<item>
<ptxt>
Sensore A/F
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70A1104045002">
<title>
Descrizione del sistema
</title>
<ptxt>
Il microprocessore è installato nella ECM.
</ptxt>
</servinfosub>
<servinfosub id = "AITAP70A1104045003">
<title>
Procedura di conferma DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Eseguire innanzitutto la ricerca guasti dei DTC inattesi, rilevati in precedenza nella &#34;Procedura di conferma DTC&#34;.
</ptxt>
</item>
<item>
<ptxt>
Verificare che la &#34;Procedura di conferma DTC&#34; venga effettuata in presenza delle condizioni indicate di seguito.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tensione batteria &#62; 10,7 V
</ptxt>
</item>
<item>
<ptxt>
Non vengono rilevati i DTC P0030, P0031, P0032, P0131 e P0132.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Tenere il motore al regime minimo per 1 minuto.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1104045004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A1104045005">
<testgroup id = "AITAP70A1104045006">
<title>
Ricontrollo presenza di DTC
</title>
<test1>
<ptxt>
Cancellare il DTC. 
<intxreftitleoff1 refid = "AITAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire la procedura di conferma DTC e controllare i DTC.
</ptxt>
</test1>
<question>
È ancora presente il DTC P0606?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controllo guasti intermittenti 
<intxreftitleoff1 refid = "AITAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104045007">
<title>
Controllo del circuito di alimentazione e di massa dell&#39;ECM.
</title>
<test1>
<ptxt>
Controllare i circuiti di alimentazione e di massa dell&#39;ECM. 
<intxreftitleoff1 refid = "AITAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104045008">
<title>
Ricontrollo presenza di DTC
</title>
<test1>
<ptxt>
Sostituire il sensore A/F. 
<intxreftitleoff1 refid = "AITAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire la procedura di conferma DTC e controllare i DTC.
</ptxt>
</test1>
<question>
È ancora presente il DTC P0606?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
