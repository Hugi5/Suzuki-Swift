<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della luce della targa
</title>
<servinfosub id = "AITAP70A9206007001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il cadenino inferiore del portellone posteriore (2) dopo aver tolto le viti (1).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la luce della targa (3).
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore della luce della targa.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920001.jpg" width = "88.000mm" height = "80.485mm" ver = "01" gw = "211" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere la lampadina.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9206007002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare le viti del cadenino inferiore portellone posteriore alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T9B001">
<t-part>
Vite del cadenino inferiore portellone posteriore
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A920002.jpg" width = "88.000mm" height = "80.884mm" ver = "01" gw = "211" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
