<servinfo servinfosgmlid = "AITAP70A7216009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del motorino ventilatore
</title>
<servinfosub id = "AITAP70A7216009001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1) del motorino ventilatore (2).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere le viti (3).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il motorino ventilatore (2) dall’unità HVAC.
</ptxt>
<figure>
<graphic graphicname = "I4RS0B710005.swf" width = "88.000mm" height = "53.250mm" ver = "01" gw = "169" gh = "134"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7216009002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
