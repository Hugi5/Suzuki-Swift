<servinfosub id = "AITAP70AA314019003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34; per 10 secondi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA314019004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA314019005">
<testgroup id = "AITAP70AA314019006">
<title>
Controllo del circuito segnale centralina immobilizzatore
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare i connettori &#34;G17&#34; e &#34;G04&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare l&#39;integrità dei collegamenti dei terminali ai connettori &#34;G17&#34; e &#34;G04&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza dei circuiti &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34; e &#34;A4&#34;: meno di 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
resistenza tra ciascun circuito &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34; e &#34;A4&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il terminale del circuito &#34;A1&#34; e gli altri terminali del connettore &#34;G17&#34;:
</ptxt>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA314019007">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Sostituire la centralina dell&#39;immobilizzatore 
<intxreftitleoff1 refid = "AITAP70AA316001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70AA314019003">Procedura di conferma DTC</intxref>
 e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC B1189?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la BCM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (La centralina dell’immobilizzatore era difettosa)
</ptxt>
</action>
</testgroup>
</diag>
