<servinfo servinfosgmlid = "AITAP70A4604A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La spia ABS e/o ESP® non si accende dopo aver posizionato l&#39;accensione su &#34;ON&#34;.
</title>
<diag type = "condition">
<condition>
<ptxt>
La spia ABS e/o ESP<sup>®</sup> non si accende dopo aver posizionato l&#39;accensione su &#34;ON&#34;.
</ptxt>
</condition>
<ps>
<ptxt>
Malfunzionamento dell&#39;ESP<sup>®</sup>
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sistema ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "AITAP70A4604001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Malfunzionamento del sistema di comunicazione CAN
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sistema di comunicazione CAN. 
<intxreftitleoff1 refid = "AITAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Circuito spia ESP<sup>®</sup> difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il circuito della spia ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "AITAP70A4604010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Circuito spia ABS difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il circuito della spia dell&#39;ABS. 
<intxreftitleoff1 refid = "AITAP70A4604012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
