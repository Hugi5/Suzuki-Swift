<servinfosub id = "AITAP70AA104008003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA104008004">
<testgroup id = "AITAP70AA104008005">
<title>
Controllo parametri
</title>
<test1>
<ptxt>
Collegare lo strumento di diagnosi SUZUKI alla DLC quando l&#39;accensione è su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i valori di &#34;Interruttore CANCEL Cruise&#34;, &#34;Interruttore RES/ACC Cruise&#34;, &#34;Interruttore SET/COAST Cruise&#34; e &#34;Interruttore ON/OFF Cruise&#34; visualizzati sullo strumento di diagnosi SUZUKI. 
<intxreftitleoff1 refid = "AITAP70AA104006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA104008006">
<title>
Controllo circuito gruppo comandi Cruise control
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare i connettori &#34;C01&#34;, &#34;E01&#34; e &#34;G371&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare l&#39;integrità dei collegamenti dei terminali ai connettori &#34;C01&#34;, &#34;E01&#34; e &#34;G371&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza dei circuiti &#34;A1&#34; e &#34;A2&#34;: meno di 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il circuito &#34;A1&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il terminale del circuito &#34;A1&#34; e gli altri terminali del connettore &#34;G371&#34;: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il terminale del circuito &#34;A2&#34; e gli altri terminali del connettore &#34;G371&#34;: infinita
</ptxt>
</item>
<item>
<ptxt>
tensione dei circuiti &#34;A1&#34; e &#34;A2&#34;: 0 – 1 V (con accensione su &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA104008007">
<title>
Controllo gruppo comandi Cruise control
</title>
<test1>
<ptxt>
Controllare l&#39;interruttore Cruise control. 
<intxreftitleoff1 refid = "AITAP70AA106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il gruppo comandi Cruise control. 
<intxreftitleoff1 refid = "AITAP70AA106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
