<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A2104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Rumorosità anomala dell’avantreno
</title>
<diag type = "condition">
<condition>
<ptxt>
Rumorosità anomala dell’avantreno
</ptxt>
</condition>
<ps>
<ptxt>
Gruppo o supporti ammortizzatori anteriori difettosi
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire il gruppo o i supporti ammortizzatori anteriori. 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Usura, grippaggio o allentamento snodi dei tiranti
</ptxt>
</ps>
<action>
<ptxt>
Sostituire gli snodi dei tiranti. 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Usura o danneggiamento giunti dei bracci delle sospensioni
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il braccio delle sospensioni. 
<intxreftitleoff1 refid = "AITAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Usura, grippaggio o allentamento giunti sferici tiranti
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Usura, grippaggio o allentamento giunti dei semiassi
</ptxt>
</ps>
<action>
<ptxt>
Sostituire i giunti dei semiassi. 
<intxreftitleoff1 refid = "AITAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Boccole anteriori bracci sospensioni usurate
</ptxt>
</ps>
<action>
<ptxt>
Sostituire le boccole anteriori dei bracci delle sospensioni. 
<intxreftitleoff1 refid = "AITAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Boccole posteriori bracci sospensioni usurate
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il braccio delle sospensioni. 
<intxreftitleoff1 refid = "AITAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Allentamento della barra stabilizzatrice
</ptxt>
</ps>
<action>
<ptxt>
Serrare bulloni o dadi e/o sostituire le boccole. 
<intxreftitleoff1 refid = "AITAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Dadi delle ruote laschi
</ptxt>
</ps>
<action>
<ptxt>
Serrare i dadi delle ruote. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Allentamento dei bulloni o dei dadi delle sospensioni
</ptxt>
</ps>
<action>
<ptxt>
Serrare i bulloni o i dadi delle sospensioni. 
<intxreftitleoff1 refid = "AITAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rottura o danneggiamento dei cuscinetti delle ruote
</ptxt>
</ps>
<action>
<ptxt>
Sostituire i cuscinetti delle ruote. 
<intxreftitleoff1 refid = "AITAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Molle elicoidali rotte
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sostituire le molle elicoidali. 
</ptxt>
<ptxt>
Parte anteriore: 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Parte posteriore: 
<intxreftitleoff1 refid = "AITAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Mancanza di lubrificazione o usura dei cuscinetti degli ammortizzatori
</ptxt>
</ps>
<action>
<ptxt>
Sostituire i cuscinetti dell’ammortizzatore. 
<intxreftitleoff1 refid = "AITAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Malfunzionamento del servosterzo
</ptxt>
</ps>
<action>
<ptxt>
Controllare e riparare il difetto. 
<intxreftitleoff1 refid = "AITAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
