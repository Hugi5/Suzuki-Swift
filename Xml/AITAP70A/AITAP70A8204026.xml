<servinfosub id = "AITAP70A8204026003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204026004">
<testgroup id = "AITAP70A8204026005">
<question>
È stato eseguito il &#34;Controllo del sistema diagnostico dell&#39;airbag&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204026006">
<title>
Controllo pretensionatore cintura di sicurezza
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i collegamenti al connettore &#34;L283&#34; o &#34;L285&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;L283&#34; o &#34;L285&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Collegare il cablaggio &#34;VOLANTE&#34; (1) degli attrezzi speciali (A), (B) e (C) al connettore &#34;L283&#34; o &#34;L285&#34;.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B032">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B033">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932–78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B034">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932–75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820024.swf" width = "90.000mm" height = "65.296mm" ver = "03" gw = "233" gh = "169"/>
</testfigure>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente il DTC B1051 o DTC B1055?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il pretensionatore della cintura di sicurezza. 
<intxreftitleoff1 refid = "AITAP70A8106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204026007">
<title>
Controllo circuito cablaggio pavimento
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i collegamenti al connettore &#34;L04&#34; o &#34;L05&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;L04&#34;o &#34;L05&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare la barra di cortocircuito interna al connettore dell&#39;SDM inserendo l&#39;apposito attrezzo facente parte dell&#39;attrezzo speciale (A).
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza dei circuiti &#34;A1&#34; e &#34;A2&#34; (DTC B1051): 1 &#937; o inferiore
</ptxt>
</item>
<item>
<ptxt>
resistenza dei circuiti &#34;A3&#34; e &#34;A4&#34; (DTC B1055): 1 &#937; o inferiore
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B035">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820121.swf" width = "90.000mm" height = "95.901mm" ver = "01" gw = "234" gh = "255"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la SDM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio pavimento. 
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Se presenti, cancellare gli eventuali DTC facendo riferimento a 
<intxref refid = "AITAP70A8204006">Cancellazione DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ripetere 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per verificare che il guasto sia stato effettivamente eliminato.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
