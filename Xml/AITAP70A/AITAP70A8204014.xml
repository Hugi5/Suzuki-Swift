<servinfosub id = "AITAP70A8204014003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204014004">
<testgroup id = "AITAP70A8204014005">
<question>
È stato eseguito il &#34;Controllo del sistema diagnostico dell&#39;airbag&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204014006">
<title>
Controllo circuito indicatore disattivazione airbag passeggero
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i collegamenti al connettore &#34;G153&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;G153&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la tensione tra il terminale “G153-9” e la massa.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B004">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820109.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</test1>
<question>
Il valore della tensione è tra 10 e 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204014007">
<title>
Controllo circuito indicatore disattivazione airbag passeggero
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i collegamenti al connettore &#34;G11&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;G11&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la resistenza tra il terminale &#34;G153-10&#34; e il terminale &#34;G11-15&#34;.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B005">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820110.swf" width = "90.000mm" height = "48.716mm" ver = "01" gw = "188" gh = "122"/>
</testfigure>
</test1>
<question>
Il valore della resistenza misurata è pari o inferiore a 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204014008">
<title>
Controllo circuito indicatore disattivazione airbag passeggero
</title>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza tra la il terminale &#34;G153-10&#34; e la massa.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B006">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820111.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</item>
</list1>
</test1>
<question>
La resistenza misurata ha valore infinito?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204014009">
<title>
Controllo indicatore disattivazione airbag passeggero
</title>
<test1>
<ptxt>
Controllare l&#39;indicatore di disattivazione airbag passeggero. 
<intxreftitleoff1 refid = "AITAP70A8206029"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la SDM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire l&#39;interruttore luci di emergenza. 
<intxreftitleoff1 refid = "AITAP70A9206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Se presenti, cancellare gli eventuali DTC facendo riferimento a 
<intxref refid = "AITAP70A8204006">Cancellazione DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ripetere 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per verificare che il guasto sia stato effettivamente eliminato.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
