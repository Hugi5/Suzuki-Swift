<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9706007" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del sedile posteriore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9706006">Componenti del sedile posteriore</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A9706007001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il gruppo seduta posteriore. 
<intxreftitleoff1 refid = "AITAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i gruppi schienali posteriori dopo aver tolto i i bulloni della cerniera sedile posteriore. 
<intxreftitleoff1 refid = "AITAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Smontare e riparare il sedile posteriore secondo necessità. 
<intxreftitleoff1 refid = "AITAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9706007002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Fare riferimento a 
<intxref refid = "AITAP70A9706006">Componenti del sedile posteriore</intxref>
 per la coppia di serraggio.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
