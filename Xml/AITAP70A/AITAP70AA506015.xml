<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70AA506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione interruttore motore
</title>
<servinfosub id = "AITAP70AA506015001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il coperchio del foro del piantone. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la cornice dell&#39;interruttore motore. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;interruttore motore dalla relativa cornice.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA506015002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70AA506016">Ispezione dell&#39;interruttore motore</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
