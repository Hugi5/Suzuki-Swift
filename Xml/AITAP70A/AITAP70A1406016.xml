<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1406016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del gruppo motore
</title>
<servinfosub id = "AITAP70A1406016001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scaricare la pressione del carburante. 
<intxreftitleoff1 refid = "AITAP70A1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la batteria. 
<intxreftitleoff1 refid = "AITAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Staccare i connettori dell&#39;ECM. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la staffa della batteria completa di ECM. 
<intxreftitleoff1 refid = "AITAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i ripari sotto al motore lati destro e sinistro.
</ptxt>
</s1>
<s1>
<ptxt>
Se necessario, scaricare gli oli e i liquidi indicati di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Olio motore: 
<intxreftitleoff1 refid = "AITAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Olio cambio manuale: 
<intxreftitleoff1 refid = "AITAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Olio del rinvio: 
<intxreftitleoff1 refid = "AITAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Scaricare il liquido di raffreddamento. 
<intxreftitleoff1 refid = "AITAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo filtro dell’aria. 
<intxreftitleoff1 refid = "AITAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Con il tubo flessibile collegato, staccare il compressore A/C dalla sua staffa. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modello con A/C manuale: 
<intxreftitleoff1 refid = "AITAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modello con A/C automatico: 
<intxreftitleoff1 refid = "AITAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Appendere il compressore A/C rimosso in un posto ove non intralci le operazioni di rimozione e installazione del gruppo motore.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Scollegare i cavi elettrici/connettori indicati di seguito e le relative fascette.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Cavo di massa della batteria (1).
</ptxt>
</item>
<item>
<ptxt>
Connettori (2) nella scatola fusibili principale
</ptxt>
</item>
<item>
<ptxt>
Connettore (3) del sensore assorbimento di corrente elettrica
</ptxt>
</item>
<item>
<ptxt>
Connettore (4) nella scatola dei fusibili n. 1 di protezione dei singoli circuiti
</ptxt>
<figure>
<graphic graphicname = "I9P60A141043.jpg" width = "88.000mm" height = "60.102mm" ver = "01" gw = "199" gh = "154"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Scollegare i cavi elencati di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Cavo di comando selezione cambio (1)
</ptxt>
</item>
<item>
<ptxt>
Cavo di comando innesto cambio (2)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140002.jpg" width = "88.000mm" height = "62.413mm" ver = "01" gw = "199" gh = "160"/>
</figure>
</s1>
<s1>
<ptxt>
Scollegare i tubi flessibili elencati di seguito:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tubo flessibile del servofreno (1)
</ptxt>
</item>
<item>
<ptxt>
Tubi flessibili d&#39;entrata e d&#39;uscita del radiatore (2)
</ptxt>
</item>
<item>
<ptxt>
Tubi flessibili d&#39;entrata e d&#39;uscita del riscaldatore (3)
</ptxt>
</item>
<item>
<ptxt>
Tubo flessibile di mandata carburante (4)
</ptxt>
</item>
<item>
<ptxt>
Tubo flessibile liquido frizione (5) 
<intxreftitleoff1 refid = "AITAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140003.jpg" width = "88.000mm" height = "112.325mm" ver = "02" gw = "199" gh = "302"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Staccare l&#39;albero inferiore dello sterzo dall&#39;albero pignone. 
<intxreftitleoff1 refid = "AITAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i giunti dalla barra stabilizzatrice. 
<intxreftitleoff1 refid = "AITAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare lo snodo del tirante dal fuso a snodo dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare i giunti dei semiassi lato destro e lato sinistro dal fuso a snodo dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il tubo di scarico n. 1 e il tubo di scarico centrale. 
<intxreftitleoff1 refid = "AITAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo albero di trasmissione. 
<intxreftitleoff1 refid = "AITAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sorreggere con un martinetto il telaio delle sospensioni anteriori (1), la scatola del cambio (2) e il monoblocco (3).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i bulloni del telaio delle sospensioni anteriori (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A140004.jpg" width = "88.000mm" height = "55.276mm" ver = "01" gw = "199" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il bullone (1) e i dadi (2) della staffa supporto motore lato sinistro.
</ptxt>
<figure>
<graphic graphicname = "IAP70A140005.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.309in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.280in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.253in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.280in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lato superiore
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lato inferiore
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il bullone (1) e i dadi (2) della staffa supporto motore lato destro.
</ptxt>
<figure>
<graphic graphicname = "IAP70A140006.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1>
<ptxt>
Prima di rimuovere il motore, assicurarsi che tutti i tubi flessibili, i fili e i cavi elettrici siano stati scollegati dal motore.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Abbassare il motore completo di cambio, telaio delle sospensioni anteriori, semiassi e scatola guida P/S tutti insieme.
</ptxt>
<attention2>
<ptxt>
Prima di abbassare il motore, per evitare di danneggiare il compressore A/C, sollevare quest&#39;ultimo per creare uno spazio tra di esso e il motore.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Se necessario, scollegare il cablaggio motore dal motore e dal cambio.
</ptxt>
</s1>
<s1>
<ptxt>
Se necessario, rimuovere il gruppo semiasse anteriore. 
<intxreftitleoff1 refid = "AITAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Se necessario, rimuovere il telaio delle sospensioni anteriori.
</ptxt>
</s1>
<s1>
<ptxt>
Se necessario, rimuovere il rinvio. 
<intxreftitleoff1 refid = "AITAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Staccare il cambio dal motore, se necessario. 
<intxreftitleoff1 refid = "AITAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Qualora necessario, smontare il coperchio e il disco della frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Eventualmente, rimuovere il volano. 
<intxreftitleoff1 refid = "AITAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1406016002" page = "2">
<title>
Installazione
</title>
<s1>
<ptxt>
Installare il volano, se rimosso. 
<intxreftitleoff1 refid = "AITAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Se rimossi, installare il coperchio e il disco della frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Se rimosso, installare il cambio sul motore. 
<intxreftitleoff1 refid = "AITAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Installare il rinvio, se rimosso. 
<intxreftitleoff1 refid = "AITAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Se rimosso, installare il telaio delle sospensioni anteriori. 
<intxreftitleoff1 refid = "AITAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Se rimosso, installare il gruppo semiasse anteriore. 
<intxreftitleoff1 refid = "AITAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Installare il cablaggio motore sul motore e cambio, quindi, se rimosso, serrare il bullone di massa (1) del cablaggio motore alla coppia specifica.
</ptxt>
<torque>
<torqueitem id = "T1D008">
<t-part>
Bullone di massa del cablaggio motore
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140007.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Sollevare il motore completo di cambio, telaio delle sospensioni anteriori, semiassi e scatola guida P/S tutti insieme.
</ptxt>
<attention2>
<ptxt>
Prima di sollevare il motore, per evitare di danneggiare il compressore A/C, sollevare quest&#39;ultimo per creare uno spazio tra di esso e il motore.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Installare il bullone (1) e i dadi (2) della staffa supporto motore lato destro.
</ptxt>
<torque>
<torqueitem id = "T1D009">
<t-part>
Bullone e dado staffa supporto destro motore
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140008.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Serrare i bulloni (1) e i dadi (2) della staffa supporto sinistro motore alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T1D010">
<t-part>
Bullone e dado staffa supporto sinistro motore
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140009.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.428in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.100in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.363in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.309in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lato superiore
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lato inferiore
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Serrare i bulloni del telaio delle sospensioni alla coppia prescritta. 
<intxreftitleoff1 refid = "AITAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Installare il gruppo albero di trasmissione. 
<intxreftitleoff1 refid = "AITAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Installare il tubo di scarico n. 1 e il tubo di scarico centrale. 
<intxreftitleoff1 refid = "AITAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Collegare i giunti dei semiassi lato destro e lato sinistro al fuso a snodo dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Collegare lo snodo del tirante dal fuso a snodo dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Montare i giunti sulla barra stabilizzatrice. 
<intxreftitleoff1 refid = "AITAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Collegare l&#39;albero inferiore dello sterzo dall&#39;albero pignone. 
<intxreftitleoff1 refid = "AITAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Installare tutti gli altri fili elettrici, connettori e tubi flessibili rimossi nelle posizioni originali.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Serrare il bullone (1) del terminale di massa della batteria.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141052.jpg" width = "88.000mm" height = "60.441mm" ver = "02" gw = "199" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Collegare il cavo di comando innesto cambio. 
<intxreftitleoff1 refid = "AITAP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Installare il compressore A/C sulla sua staffa. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modello con A/C manuale 
<intxreftitleoff1 refid = "AITAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</item>
<item>
<ptxt>
Modello con A/C automatico 
<intxreftitleoff1 refid = "AITAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Installare la cinghia di comando compressore A/C.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modello con A/C manuale: 
<intxreftitleoff1 refid = "AITAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modello con A/C automatico: 
<intxreftitleoff1 refid = "AITAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Installare il gruppo filtro dell&#39;aria. 
<intxreftitleoff1 refid = "AITAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Accertare che tutte le parti rimosse in precedenza siano state rimontate. Reinstallare le eventuali parti mancanti.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Se necessario, rifornire gli oli e i liquidi indicati di seguito.
</ptxt>
<list1 type = "unordered">
