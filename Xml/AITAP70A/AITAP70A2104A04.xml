<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Effetto shimmy, scuotimento o vibrazioni
</title>
<diag type = "condition">
<condition>
<ptxt>
Effetto shimmy, scuotimento o vibrazioni
</ptxt>
</condition>
<ps>
<ptxt>
Ruota sbilanciata
</ptxt>
</ps>
<action>
<ptxt>
Bilanciare la ruota o sostituire il pneumatico e/o la ruota.
</ptxt>
</action>
<ps>
<ptxt>
Cuscinetti delle ruote laschi
</ptxt>
</ps>
<action>
<ptxt>
Sostituire i cuscinetti delle ruote. 
<intxreftitleoff1 refid = "AITAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Usura degli snodi dei tiranti
</ptxt>
</ps>
<action>
<ptxt>
Sostituire gli snodi dei tiranti. 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Giunti dei bracci delle sospensioni usurati
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il braccio delle sospensioni. 
<intxreftitleoff1 refid = "AITAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Eccessiva eccentricità del pneumatico o della ruota
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire la ruota e/o il pneumatico.
</ptxt>
</action>
<ps>
<ptxt>
Rigonfiamento o vescicatura del pneumatico
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il pneumatico. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Eccessiva eccentricità radiale del gruppo pneumatico/ruota
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il pneumatico o la ruota.
</ptxt>
</action>
<ps>
<ptxt>
Assetto ruote non corretto
</ptxt>
</ps>
<action>
<ptxt>
Controllare e regolare l&#39;assetto ruote. 
<intxreftitleoff1 refid = "AITAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Allentamento o usura della tiranteria dello sterzo
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sistema dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Allentamento bulloni della scatola guida
</ptxt>
</ps>
<action>
<ptxt>
Serrare i bulloni della scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
