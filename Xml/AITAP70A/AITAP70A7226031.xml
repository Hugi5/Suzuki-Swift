<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A7226031" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del sensore irraggiamento solare
</title>
<servinfosub id = "AITAP70A7226031001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Disabilitare il sistema airbag. 
<intxreftitleoff1 refid = "AITAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Rimuovere il cruscotto. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il sensore irraggiamento solare (1) dal cruscotto premendo la linguetta e spingendo il sensore verso l&#39;alto da sotto.
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore del sensore irraggiamento solare (2).
</ptxt>
<figure page = "2">
<graphic graphicname = "I7RW01722028.swf" width = "88.000mm" height = "40.458mm" ver = "01" gw = "238" gh = "98"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AITAP70A7226031002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A7226032">Ispezione del sensore irraggiamento solare:Tipo automatico</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Installare il sensore irraggiamento solare (1) nel cruscotto, montando le relative linguette (2) nelle scanalature (3) ricavate nel cruscotto, come indicato in figura.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723025.swf" width = "88.000mm" height = "35.371mm" ver = "01" gw = "209" gh = "84"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.674in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Senso di marcia del veicolo
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
