<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A9904001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnosi del sistema tetto apribile elettrico basata sui sintomi
</title>
<diag type = "condition" id = "AITAP70A9904001001">
<condition>
<ptxt>
Il tetto apribile non funziona (il motorino tetto apribile funziona)
</ptxt>
</condition>
<ps>
<ptxt>
Presenza di corpi estranei nel binario del tetto apribile
</ptxt>
</ps>
<action>
<ptxt>
Rimuovere i corpi estranei.
</ptxt>
</action>
<ps>
<ptxt>
Installazione errata del binario del tetto apribile
</ptxt>
</ps>
<action>
<ptxt>
Installare correttamente.
</ptxt>
</action>
<ps>
<ptxt>
Interferenza dei componenti del tetto apribile
</ptxt>
</ps>
<action>
<ptxt>
Eliminare l&#39;interferenza.
</ptxt>
</action>
<ps>
<ptxt>
Installazione errata del cavo di comando del tetto apribile
</ptxt>
</ps>
<action>
<ptxt>
Installare correttamente.
</ptxt>
</action>
<condition>
<ptxt>
Scorrimento e inclinazione automatici non funzionanti (solo funzionamento manuale)
</ptxt>
</condition>
<ps>
<ptxt>
Inizializzazione difettosa
</ptxt>
</ps>
<action>
<ptxt>
Inizializzare il motorino tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Posizione di installazione errata del vetro del tetto apribile
</ptxt>
</ps>
<action>
<ptxt>
Regolare la posizione di montaggio del vetro del tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Movimento errato di scorrimento dell&#39;unità tetto apribile
</ptxt>
</ps>
<action>
<ptxt>
Sostituire l&#39;unità tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motorino tetto apribile difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il motorino tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Il tetto apribile non funziona (impossibile azionare il motorino tetto apribile)
</ptxt>
</condition>
<ps>
<ptxt>
Fusibile bruciato
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il fusibile.
</ptxt>
</action>
<ps>
<ptxt>
Interruttore tetto apribile difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare l&#39;interruttore tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio o collegamento a massa difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il circuito. 
<intxreftitleoff1 refid = "AITAP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AITAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motorino tetto apribile difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il motorino tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Infiltrazione di pioggia
</ptxt>
</condition>
<ps>
<ptxt>
Posizione di installazione errata del vetro del tetto apribile
</ptxt>
</ps>
<action>
<ptxt>
Regolare la posizione di montaggio del vetro del tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vetro del tetto apribile difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il vetro del tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Tubo flessibile di scarico scollegato o intasato (anteriore / posteriore)
</ptxt>
</ps>
<action>
<ptxt>
Controllare il tubo flessibile di scarico (anteriore / posteriore).
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
