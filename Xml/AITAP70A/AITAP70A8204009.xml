<servinfosub id = "AITAP70A8204009002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204009003">
<testgroup id = "AITAP70A8204009004">
<title>
Controllo connettore SDM
</title>
<test1>
<ptxt>
Controllare il collegamento al connettore SDM.
</ptxt>
</test1>
<question>
Il collegamento è buono?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Collegare saldamente il connettore.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204009005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70A8204005">Controllo presenza DTC</intxref>
. 
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fare riferimento alla procedura diagnostica relativa al DTC rilevato.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204009006">
<title>
Controllo circuiti di alimentazione e massa SDM
</title>
<test1>
<ptxt>
Controllare i circuiti di alimentazione e di massa della SDM. 
<intxreftitleoff1 refid = "AITAP70A8204052"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
I circuiti sono integri?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare i circuiti di alimentazione e di massa della SDM.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204009007">
<title>
Controllo circuito di comunicazione CAN
</title>
<test1>
<ptxt>
Controllare il circuito di comunicazione CAN tra la SDM e il quadro strumenti.
</ptxt>
</test1>
<question>
Il circuito è integro?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204009008">
<title>
Controllo quadro strumenti
</title>
<test1>
<ptxt>
Sostituire il quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<question>
La spia AIRBAG resta accesa?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la SDM e ricontrollare il funzionamento della spia &#34;AIRBAG&#34;. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Ripetere 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per verificare che il guasto sia stato effettivamente eliminato.
</ptxt>
</item>
</list1>
</attention3>
