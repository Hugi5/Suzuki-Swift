<servinfosub id = "AITAP70A6304010002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A6304010003">
<testgroup id = "AITAP70A6304010004">
<title>
Controllo spia &#34;P/S&#34;
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<question>
Si accendono altre spie?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304010005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70A6304003">Controllo presenza DTC</intxref>
.
</ptxt>
</test1>
<question>
È presente il DTC U0073 o DTC U0155?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70AA804002">Tabella dei DTC relativi alla linea CAN (perdita di comunicazione e bus di comunicazione Off)</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304010006">
<title>
Controllo quadro strumenti
</title>
<test1>
<ptxt>
Sostituire il quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<question>
La spia P/S rimane spenta?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina P/S. 
<intxreftitleoff1 refid = "AITAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304010007">
<title>
Controllo fusibili
</title>
<question>
Il fusibile del circuito del quadro strumenti è in buone condizioni?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Sostituire il fusibile e controllare la presenza di cortocircuiti a massa.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AITAP70A6304010008">
<title>
Controllo circuito di comunicazione CAN
</title>
<test1>
<ptxt>
Controllare il circuito di comunicazione CAN tra il quadro strumenti e la centralina P/S. 
<intxreftitleoff1 refid = "AITAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Il circuito di comunicazione CAN è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Riparare o sostituire.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AITAP70A6304010009">
<title>
Controllo del circuito di alimentazione del quadro strumenti
</title>
<test1>
<ptxt>
Rimuovere il quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controllare se il collegamento al connettore del quadro strumenti è corretto.
</ptxt>
</test1>
<test1>
<ptxt>
Se l&#39;esito del controllo è OK, portare l’accensione in posizione &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare che la tensione tra il terminale &#34;G240-3&#34; e il terminale &#34;G240-5&#34; sia pari alla tensione della batteria.
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il quadro strumenti e ricontrollare. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 7.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304010010">
<title>
Controllo del circuito di massa del quadro strumenti
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare che la resistenza tra il terminale &#34;G240-5&#34; e la massa sia pari o inferiore a 1 Ω.
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Riparare o sostituire il circuito &#34;A1&#34;.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il circuito &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
