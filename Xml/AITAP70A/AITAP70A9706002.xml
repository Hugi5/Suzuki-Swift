<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9706002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del sedile anteriore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9706001">Componenti del sedile anteriore</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A9706002001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Disabilitare il sistema airbag. 
<intxreftitleoff1 refid = "AITAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare i connettori dal sedile anteriore.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo sedile dopo aver tolto i 4 bulloni di fissaggio.
</ptxt>
</s1>
<s1>
<ptxt>
Smontare e riparare le parti secondo necessità. 
<intxreftitleoff1 refid = "AITAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9706002002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Fare riferimento a 
<intxref refid = "AITAP70A9706001">Componenti del sedile anteriore</intxref>
 per la coppia di serraggio.
</ptxt>
</item>
<item>
<ptxt>
Abilitare il sistema airbag. 
<intxreftitleoff1 refid = "AITAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
