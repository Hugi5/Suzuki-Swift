<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1104A15" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Il funzionamento del motore al regime minimo non è regolare o il motore non tiene il regime minimo
</title>
<ptxt>
Eseguire la ricerca guasti facendo riferimento ai punti che seguono nel caso in cui non ci siano DTC memorizzati nell&#39;ECM e dai controlli descritti in 
<intxref refid = "AITAP70A1104008">Ispezione visiva</intxref>
 e 
<intxref refid = "AITAP70A1104009">Ispezione di base del motore</intxref>
 non siano emerse anomalie.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Il funzionamento del motore al regime minimo non è regolare o il motore non tiene il regime minimo
</ptxt>
</condition>
<ps>
<ptxt>
Candela difettosa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1806002">Ispezione delle candele di accensione</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Bobina d’accensione transistorizzata difettosa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1806004">Ispezione del gruppo bobine d’accensione</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Pressione del carburante non corretta
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1704005">Controllo della pressione del carburante</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Mancanza di tenuta della guarnizione del collettore, del corpo farfallato o della testata
</ptxt>
</ps>
<action>
<ptxt>
Controllo dell&#39;impianto di aspirazione.
</ptxt>
</action>
<ps>
<ptxt>
Impianto di controllo dell’emissione dei vapori difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1206002">Ispezione della valvola di spurgo canister EVAP</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Iniettore carburante difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1704003">Controllo circuito iniettori carburante</intxref>
 o 
<intxref refid = "AITAP70A1706009">Ispezione degli iniettori carburante</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Sensore ECT o sensore MAF malfunzionante
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306012">Ispezione del sensore ECT</intxref>
 o 
<intxref refid = "AITAP70A1306026">Ispezione del sensore MAF/IAT</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo corpo farfalla motorizzata difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306004">Ispezione del gruppo corpo della farfalla motorizzata a bordo del veicolo</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo sensore APP difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306008">Ispezione del sensore APP</intxref>
</ptxt>
</action>
<ps>
<ptxt>
ECM guasta
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1104070">Ispezione dell&#39;ECM e dei suoi circuiti</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Tubi flessibili della depressione laschi o scollegati
</ptxt>
</ps>
<action>
<ptxt>
Controllare il collegamento ai tubi flessibili della depressione.
</ptxt>
</action>
<ps>
<ptxt>
Valvola PCV malfunzionante
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1206006">Ispezione della valvola PCV</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Surriscaldamento del motore
</ptxt>
</ps>
<action>
<ptxt>
Condizione &#34;Surriscaldamento del motore&#34;
</ptxt>
</action>
<ps>
<ptxt>
Compressione insufficiente
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1404001">Controllo della compressione</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Alternatore e/o relativo circuito difettoso (difettosi)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1A04003">Prova dell&#39;alternatore</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Sistema di controllo posizione dell&#39;albero a camme (VVT) non a posto
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306027">Ispezione della valvola OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
