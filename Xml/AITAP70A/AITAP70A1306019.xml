<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1306019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del sensore CKP
</title>
<servinfosub id = "AITAP70A1306019001" page = "2">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore dal sensore CKP.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il sensore CKP (1) dal monoblocco.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A131017.jpg" width = "88.000mm" height = "57.392mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</servinfosub>
<servinfosub id = "AITAP70A1306019002" page = "2">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1306020">Ispezione del sensore CKP</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Lubrificare l&#39;O-ring del sensore con olio motore.
</ptxt>
</item>
<item>
<ptxt>
Serrare il bullone del sensore CKP alla coppia indicata.
</ptxt>
<attention2>
<ptxt>
Assicurarsi di usare bulloni pretrattati con rivestimento adesivo. Potrebbero allentarsi!
</ptxt>
</attention2>
<torque>
<torqueitem id = "T1C007">
<t-part>
Bullone sensore CKP
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131008.jpg" width = "88.000mm" height = "57.393mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</item>
<item>
<ptxt>
Collegare il connettore e fissare saldamente il cablaggio con la fascetta.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
