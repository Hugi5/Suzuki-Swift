<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della luce leggimappa (se in dotazione)
</title>
<servinfosub id = "AITAP70A9206010001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere la luce leggimappa (1) sganciando i fermi (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore dalla luce leggimappa.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920027.jpg" width = "88.000mm" height = "68.223mm" ver = "02" gw = "199" gh = "177"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il portalampada (1) dalla luce leggimappa (2), quindi togliere le lampadine.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920015.jpg" width = "88.000mm" height = "57.222mm" ver = "01" gw = "204" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9206010002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
