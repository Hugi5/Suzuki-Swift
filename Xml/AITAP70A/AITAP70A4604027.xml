<servinfosub id = "AITAP70A4604027003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604027004">
<testgroup id = "AITAP70A4604027005">
<question>
È stato eseguito il &#34;Controllo sistema ESP<sup>®</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A4604001">Controllo sistema ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604027006">
<title>
Controllo dei circuiti di alimentazione elettrovalvola e di massa della centralina ESP®
</title>
<test1>
<ptxt>
Controllare i circuiti di alimentazione e massa dell&#39;elettrovalvola in 
<intxref refid = "AITAP70A4604042">Controllo dei circuiti di alimentazione e di massa della centralina ESP®</intxref>
.
</ptxt>
</test1>
<question>
Gli esiti dei controlli sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
</diag>
