<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1306017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del sensore CMP
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1306016">Ispezione del sensore CMP a bordo del veicolo</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A1306017001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore dal sensore CMP di aspirazione (1) e dal sensore CMP di scarico (2).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il sensore CMP di aspirazione (1) e il sensore CMP di scarico (2) dalla testata.
</ptxt>
<figure>
<graphic graphicname = "I9P60A131006.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1306017002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1306018">Ispezione del sensore CMP</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Lubrificare l&#39;O-ring del sensore con olio motore.
</ptxt>
</item>
<item>
<ptxt>
Serrare il bullone del sensore CMP alla coppia indicata.
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Assicurarsi di usare bulloni pretrattati con rivestimento adesivo. Potrebbero allentarsi!
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1C005">
<t-part>
Bullone sensore CMP di aspirazione
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1C006">
<t-part>
Bullone sensore CMP di scarico
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131007.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
