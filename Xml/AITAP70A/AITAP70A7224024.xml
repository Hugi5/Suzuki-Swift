<servinfosub id = "AITAP70A7224024003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Portare l’accensione su &#34;OFF&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7224024004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A7224024005">
<testgroup id = "AITAP70A7224024006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l’accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34; e controllare la presenza di DTC.
</ptxt>
</test1>
<question>
È ancora presente il DTC B1541?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Guasto intermittente.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A7224024008">
<title>
Controllo fusibili
</title>
<test1>
<ptxt>
Controllare il fusibile &#34;MTR&#34;.
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il fusibile &#34;MTR&#34; e controllare la presenza di cortocircuito a massa.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A7224024007">
<title>
Controllo circuito di alimentazione da batteria
</title>
<test1>
<ptxt>
Scollegare il connettore &#34;G20&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la tensione tra il terminale del connettore &#34;G20&#34; collegato al filo &#34;WHT/RED&#34; e la massa.
</ptxt>
</test1>
<question>
Il valore della tensione è tra 10 e 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina HVAC e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
