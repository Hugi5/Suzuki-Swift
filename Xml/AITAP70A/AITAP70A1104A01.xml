<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Avviamento difficile (il motorino d’avviamento funziona regolarmente)
</title>
<ptxt>
Eseguire la ricerca guasti facendo riferimento ai punti che seguono nel caso in cui non ci siano DTC memorizzati nell&#39;ECM e dai controlli descritti in 
<intxref refid = "AITAP70A1104008">Ispezione visiva</intxref>
 e 
<intxref refid = "AITAP70A1104009">Ispezione di base del motore</intxref>
 non siano emerse anomalie.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Avviamento difficile (il motorino d’avviamento funziona regolarmente)
</ptxt>
</condition>
<ps>
<ptxt>
Candela difettosa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1806002">Ispezione delle candele di accensione</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Bobina d’accensione difettosa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1806004">Ispezione del gruppo bobine d’accensione</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Tubazioni del carburante sporche o occluse
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1704005">Controllo della pressione del carburante</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Pompa del carburante malfunzionante
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1704005">Controllo della pressione del carburante</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Trafilamento d’aria dalla guarnizione del collettore di aspirazione o dalla guarnizione del corpo farfallato
</ptxt>
</ps>
<action>
<ptxt>
Controllo dell&#39;impianto di aspirazione.
</ptxt>
</action>
<ps>
<ptxt>
Gruppo corpo farfalla motorizzata difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306004">Ispezione del gruppo corpo della farfalla motorizzata a bordo del veicolo</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo sensore APP difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306008">Ispezione del sensore APP</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Sensore ECT o sensore MAF difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306012">Ispezione del sensore ECT</intxref>
 o 
<intxref refid = "AITAP70A1306026">Ispezione del sensore MAF/IAT</intxref>
</ptxt>
</action>
<ps>
<ptxt>
ECM guasta
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1104070">Ispezione dell&#39;ECM e dei suoi circuiti</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Compressione insufficiente
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1404001">Controllo della compressione</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Candela lasca o guarnizione difettosa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1806001">Rimozione e installazione delle candele</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Perdita di compressione dalla sede della valvola
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406028">Ispezione delle valvole e dei guidavalvole</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Stelo della valvola incollato
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406028">Ispezione delle valvole e dei guidavalvole</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Molle delle valvola snervate o danneggiate
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406031">Ispezione della molla della valvola</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Perdita di compressione dalla guarnizione della testata
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406029">Ispezione testata</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Fascia elastica del pistone incollata o danneggiata
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406035">Ispezione di cilindri, pistoni e fasce elastiche dei pistoni</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Usura del pistone, della fascia elastica o del cilindro
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406035">Ispezione di cilindri, pistoni e fasce elastiche dei pistoni</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Valvola PCV malfunzionante
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1206006">Ispezione della valvola PCV</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Sistema di controllo posizione dell&#39;albero a camme (VVT) non a posto
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306027">Ispezione della valvola OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
