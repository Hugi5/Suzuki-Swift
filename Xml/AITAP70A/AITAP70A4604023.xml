<servinfosub id = "AITAP70A4604023003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604023004">
<testgroup id = "AITAP70A4604023005">
<question>
È stato eseguito il &#34;Controllo sistema ESP<sup>®</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A4604001">Controllo sistema ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604023006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70A4604005">Controllo presenza DTC</intxref>
.
</ptxt>
</test1>
<question>
Sono presenti altri DTC oltre il C1037, C1038 e C1057?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fare riferimento alla procedura diagnostica relativa al DTC rilevato.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604023007">
<title>
Controllo presenza DTC nella BCM
</title>
<test1>
<ptxt>
Controllare la presenza di DTC nella BCM. 
<intxreftitleoff1 refid = "AITAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente uno dei DTC U0073, U0121 e/o U0126?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fare riferimento alla procedura diagnostica relativa al DTC rilevato.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604023008">
<title>
Controllo fusibili
</title>
<test1>
<ptxt>
Controllare il fusibile &#34;ABS&#34;.
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il fusibile e controllare la presenza di cortocircuiti a massa.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604023009">
<title>
Controllo circuito di alimentazione sensore angolo sterzo
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore sensore angolo sterzo.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;G33&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il collegamento al sensore angolo sterzo.
</ptxt>
</test1>
<test1>
<ptxt>
Se il collegamento è OK, portare l’accensione in posizione &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la tensione tra il circuito &#34;A1&#34; e la massa.
</ptxt>
</test1>
<question>
La tensione è 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il circuito &#34;A1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604023010">
<title>
Controllo circuito di massa sensore angolo sterzo
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la resistenza tra il il terminale del circuito &#34;A2&#34; e la massa.
</ptxt>
</test1>
<question>
La resistenza è inferiore a 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il circuito &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604023011">
<title>
Controllo sensore angolo sterzo
</title>
<test1>
<ptxt>
Collegare il connettore sensore angolo sterzo.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il sensore angolo sterzo. 
<intxreftitleoff1 refid = "AITAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il sensore angolo sterzo e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
