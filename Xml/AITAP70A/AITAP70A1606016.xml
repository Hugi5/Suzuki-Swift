<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1606016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della pompa dell’acqua
</title>
<servinfosub id = "AITAP70A1606016001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Scaricare il liquido di raffreddamento. 
<intxreftitleoff1 refid = "AITAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la cinghia di comando pompa dell&#39;acqua/alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la puleggia (2) della pompa dell&#39;acqua.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo pompa dell&#39;acqua (1) completo di staffa (3) alternatore.
</ptxt>
<figure>
<graphic graphicname = "I7V20A161014.swf" width = "88.000mm" height = "66.198mm" ver = "01" gw = "211" gh = "171"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AITAP70A1606016002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1606017">Ispezione della pompa dell&#39;acqua</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Applicare sigillante sulla superficie di accoppiamento della pompa dell&#39;acqua come mostrato in figura.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1F001" uid = "41">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Materiale sigillante
</m-desc>
<m-number>
99000–31250
</m-number>
<m-name>
SUZUKI Bond No.1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I7V20A161015.swf" width = "88.000mm" height = "43.075mm" ver = "01" gw = "184" gh = "106"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.309in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.250in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.387in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;a&#34;:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
3 mm (0,12 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;b&#34;:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
2 mm (0,08 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Installare il gruppo pompa dell&#39;acqua (1) completo di staffa alternatore (3) sul monoblocco e serrare i bulloni e i dadi alla coppia specificata.
</ptxt>
<attention3>
<ptxt>
Per la procedura di installazione della staffa (3) alternatore, fare riferimento a 
<intxref refid = "AITAP70A1A06006">Rimozione e installazione della staffa dell&#39;alternatore</intxref>
 .
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1F003">
<t-part>
Bullone e dado della pompa dell&#39;acqua
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Montare la puleggia (2) della pompa dell&#39;acqua e serrare i bulloni alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T1F004">
<t-part>
Bullone della puleggia pompa dell&#39;acqua
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A161016.swf" width = "88.000mm" height = "66.198mm" ver = "02" gw = "211" gh = "171"/>
</figure>
</s1>
<s1>
<ptxt>
Installare la cinghia di comando della pompa dell&#39;acqua/alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Collegare il cavo negativo (–) alla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Riempire l&#39;impianto di raffreddamento con il liquido. 
<intxreftitleoff1 refid = "AITAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controllare la presenza di perdite nell&#39;impianto di raffreddamento. 
<intxreftitleoff1 refid = "AITAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
