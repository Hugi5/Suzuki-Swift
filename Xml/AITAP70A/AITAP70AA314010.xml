<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70AA314010" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1644
</title>
<servinfosub id = "AITAP70AA314010001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.166in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.039in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1644: Mancata corrispondenza ID immobilizzatore
</emph>
</ptxt>
<ptxt>
Errore di verifica tra ECM e BCM
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Chiave d’accensione
</ptxt>
</item>
<item>
<ptxt>
Il codice di identificazione della ECM non è stato registrato nella BCM.
</ptxt>
</item>
<item>
<ptxt>
La chiave di accensione non è stata registrata.
</ptxt>
</item>
<item>
<ptxt>
Circuito / connettore della centralina immobilizzatore
</ptxt>
</item>
<item>
<ptxt>
Centralina immobilizzatore
</ptxt>
</item>
<item>
<ptxt>
Circuito di alimentazione / massa della BCM
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70AA314010002">
<title>
Ricerca guasti
</title>
<attention3>
<ptxt>
Se la BCM è stata registrata su un altro veicolo (articolo usato), non è possibile registrare la chiave di accensione. In caso di sostituzione, installare sempre una BCM nuova.
</ptxt>
</attention3>
<diag type = "test" id = "AITAP70AA314010003">
<testgroup id = "AITAP70AA314010004">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare se nella memoria della BCM sono presenti DTC. 
<intxreftitleoff1 refid = "AITAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente il B1188, B1189 o B1190?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA314010005">
<title>
Controllo circuiti di alimentazione e massa della BCM
</title>
<test1>
<ptxt>
Controllare il circuito di alimentazione e di massa della BCM. 
<intxreftitleoff1 refid = "AITAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA314010006">
<title>
Registrazione della ECM
</title>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70AA316003">Registrazione della ECM:Modello con commutatore di accensione</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC P1644?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (l&#39;ECM non era stata registrata)
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA314010007">
<title>
Registrazione della chiave di accensione
</title>
<test1>
<ptxt>
Eseguire &#34;Registrazione chiave immobilizzatore&#34;. 
<intxreftitleoff1 refid = "AITAP70AA316002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC P1644?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. Se il DTC P1644 è ancora presente, sostituire la BCM e ricontrollare la presenza di DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "AITAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (la chiave di accensione non è stata registrata).
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
