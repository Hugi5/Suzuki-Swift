<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A3406005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Smontaggio e rimontaggio del giunto
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A3406004">Smontaggio e rimontaggio del gruppo albero di trasmissione</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A3406005001">
<title>
Smontaggio
</title>
<s1>
<ptxt>
Rimuovere il sieger dall&#39;albero del giunto utilizzando le pinze per anelli elastici.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il giunto viscoso (1) dal relativo albero (2) utilizzando la pressa idraulica (3) e l&#39;estrattore (4).
</ptxt>
<figure>
<graphic graphicname = "I5RS0D340007.swf" width = "88.000mm" height = "49.401mm" ver = "01" gw = "114" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A3406005002">
<title>
Rimontaggio
</title>
<s1>
<ptxt>
Installare il giunto viscosco (1) sull&#39;albero (2) usando l&#39;attrezzo speciale e la pressa idraulica.
</ptxt>
<servicetool>
<servicetoolitem id = "L3D001">
<s-part>
(A)
</s-part>
<s-number num = "09922-55131">
09922–55131
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A340010.swf" width = "88.000mm" height = "50.636mm" ver = "01" gw = "94" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Installare il sieger nuovo sull’albero centrale utilizzando le pinze per anelli elastici.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
