<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A4604A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La spia EBD (spia dei freni) rimane accesa per oltre 2 secondi dopo il posizionamento dell&#39;accensione su &#34;ON&#34;.
</title>
<diag type = "condition">
<condition>
<ptxt>
La spia EBD (spia dei freni) rimane accesa per oltre 2 secondi dopo il posizionamento dell&#39;accensione su &#34;ON&#34;.
</ptxt>
</condition>
<ps>
<ptxt>
Freno di stazionamento inserito
</ptxt>
</ps>
<action>
<ptxt>
Rilasciare il freno di stazionamento e controllare che la spia EBD (spia dei freni) si spenga.
</ptxt>
</action>
<ps>
<ptxt>
Livello del liquido freni troppo basso
</ptxt>
</ps>
<action>
<ptxt>
Controllo del livello del liquido freni. 
<intxreftitleoff1 refid = "AITAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Circuito interruttore del freno di stazionamento e/o circuito interruttore livello del liquido freni difettoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare la BCM e il relativo circuito.
</ptxt>
<ptxt>
Modello con commutatore di accensione: 
<intxreftitleoff1 refid = "AITAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: 
<intxreftitleoff1 refid = "AITAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Interruttore del freno di stazionamento e/o interruttore livello del liquido freni difettoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare l&#39;interruttore del freno di stazionamento e/o l&#39;interruttore livello del liquido freni.
</ptxt>
<ptxt>
Interruttore del freno di stazionamento: 
<intxreftitleoff1 refid = "AITAP70A4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Interruttore livello del liquido freni: 
<intxreftitleoff1 refid = "AITAP70A4106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Malfunzionamento sistema EBD
</ptxt>
</ps>
<action>
<ptxt>
Eseguire il controllo del sistema ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "AITAP70A4604001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Circuiti di alimentazione e di massa della centralina ESP<sup>®</sup> difettosi
</ptxt>
</ps>
<action>
<ptxt>
Controllare i circuiti di alimentazione e di massa della centralina ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "AITAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sistema di comunicazione CAN difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sistema di comunicazione CAN. 
<intxreftitleoff1 refid = "AITAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
BCM difettosa
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare la BCM e il relativo circuito.
</ptxt>
<ptxt>
Modello con commutatore di accensione: 
<intxreftitleoff1 refid = "AITAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: 
<intxreftitleoff1 refid = "AITAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Centralina ESP<sup>®</sup> guasta
</ptxt>
</ps>
<action>
<ptxt>
Sostituire la centralina ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Circuito spia EBD difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il circuito spia EBD. 
<intxreftitleoff1 refid = "AITAP70A4604015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
