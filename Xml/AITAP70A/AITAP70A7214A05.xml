<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A7214A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Non esce aria fredda (la frizione magnetica non funziona)
</title>
<diag type = "condition">
<condition>
<ptxt>
Non esce aria fredda (la frizione magnetica non funziona)
</ptxt>
</condition>
<ps>
<ptxt>
Mancanza di refrigerante
</ptxt>
</ps>
<action>
<ptxt>
Effettuare le procedure di recupero, spurgo e caricamento del refrigerante. 
<intxreftitleoff1 refid = "AITAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fusibile bruciato
</ptxt>
</ps>
<action>
<ptxt>
Verificare i fusibili interessati e controllare la presenza di cortocircuito a massa.
</ptxt>
</action>
<ps>
<ptxt>
Interruttore A/C anomalo
</ptxt>
</ps>
<action>
<ptxt>
Controllare l’interruttore dell’A/C. 
<intxreftitleoff1 refid = "AITAP70A7216034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Selettore di velocità del ventilatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il selettore di velocità del ventilatore. 
<intxreftitleoff1 refid = "AITAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensore temperatura evaporatore difettoso.
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sensore temperatura evaporatore. 
<intxreftitleoff1 refid = "AITAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensore della pressione del fluido refrigerante A/C guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sensore della pressione del fluido refrigerante A/C. 
<intxreftitleoff1 refid = "AITAP70A7216023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio o collegamento a massa difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare il cablaggio.
</ptxt>
</action>
<ps>
<ptxt>
ECM e relativo circuito difettosi
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare la centralina ECM. 
<intxreftitleoff1 refid = "AITAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Frizione magnetica difettosa
</ptxt>
</ps>
<action>
<ptxt>
Controllare la frizione magnetica. 
<intxreftitleoff1 refid = "AITAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Allentamento o rottura della cinghia di comando del compressore
</ptxt>
</ps>
<action>
<ptxt>
Controllare la cinghia di comando del compressore. 
<intxreftitleoff1 refid = "AITAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compressore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il compressore.
</ptxt>
</action>
<ps>
<ptxt>
Relè compressore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il relè del compressore. 
<intxreftitleoff1 refid = "AITAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
BCM difettosa
</ptxt>
</ps>
<action>
<ptxt>
Controllare la BCM. 
<intxreftitleoff1 refid = "AITAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
