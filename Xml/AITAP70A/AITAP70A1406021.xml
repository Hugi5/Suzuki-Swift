<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1406021" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del volano
</title>
<servinfosub id = "AITAP70A1406021001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il coperchio e il disco della frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Inserire l&#39;attrezzo speciale nei denti della corona per bloccare il volano o il disco conduttore, come mostrato in figura.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D015">
<s-part>
(A)
</s-part>
<s-number num = "09924-17811">
09924–17811
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I8C50A140045.swf" width = "88.000mm" height = "50.407mm" ver = "01" gw = "141" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il volano dall’albero motore.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1406021002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Installare bulloni del volano nuovi.
</ptxt>
</item>
<item>
<ptxt>
Inserire l&#39;attrezzo speciale nei denti della corona per bloccare il volano o il disco conduttore, come mostrato in figura.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L1D016">
<s-part>
(A)
</s-part>
<s-number num = "09924-17811">
09924–17811
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<list1 type = "unordered">
<item>
<ptxt>
Serrare i bulloni del volano alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T1D014">
<t-part>
Bullone volano
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
70
</t-value1>
<t-value2>
7,1
</t-value2>
<t-value3>
52,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50A140046.swf" width = "88.000mm" height = "50.407mm" ver = "01" gw = "141" gh = "126"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
