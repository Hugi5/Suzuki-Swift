<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del vetro porta anteriore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9506010">Componenti della porta anteriore</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A9506011001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Abbassare il vetro della porta anteriore a circa 150 mm (5,91 in.) dal bordo inferiore del vetro.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950023.jpg" width = "88.000mm" height = "45.882mm" ver = "02" gw = "225" gh = "114"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.331in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.870in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
circa 150 mm (5,91 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il cadenino interno (1) staffa telaio.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il coperchio (2) maniglia interna.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere le viti (3), il fermaglio (B) e la finitura della porta (4) tirando nella direzione della freccia.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950025.jpg" width = "88.000mm" height = "101.074mm" ver = "01" gw = "227" gh = "270"/>
</figure>
</s1>
<s1>
<ptxt>
Scollegare i connettori del cablaggio della porta.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la guarnizione di tenuta esterna (1) della porta anteriore spostandola nella direzione delle frecce (da &#34;1&#34; a &#34;2&#34;) come illustrato.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950026.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.071in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.783in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Griffa
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Pannello esterno porta anteriore
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere la staffa finitura della porta (1) e il coperchio ermetico della porta (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950027.jpg" width = "88.000mm" height = "91.845mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere le viti (1) e il vetro della porta anteriore (2) staccandola nella direzione delle frecce (da &#34;1&#34; a &#34;2&#34;) come illustrato.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950028.jpg" width = "88.000mm" height = "78.685mm" ver = "02" gw = "225" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9506011002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Se rimossi, installare i fermi (1) nella posizione specificata del vetro della porta (2).
</ptxt>
<spec>
<title>
Posizione di installazione del fermo vetro della porta anteriore
</title>
<ptxt>
&#34;a&#34;: 104 – 106 mm (4,10 – 4,17 in.)
</ptxt>
<ptxt>
&#34;b&#34;: 431,2 – 433,2 mm (16,98 – 17,05 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70P950015.jpg" width = "88.000mm" height = "46.523mm" ver = "01" gw = "191" gh = "115"/>
</figure>
</item>
<item>
<ptxt>
Serrare le viti del vetro porta anteriore nell&#39;ordine (da &#34;1&#34; a &#34;2&#34;) come illustrato in figura.
</ptxt>
</item>
<item>
<ptxt>
Serrare le viti del vetro della porta alla coppia prescritta.
</ptxt>
<torque>
<torqueitem id = "T9E002">
<t-part>
Vite del vetro porta anteriore*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950029.jpg" width = "88.000mm" height = "81.655mm" ver = "02" gw = "225" gh = "215"/>
</figure>
</item>
<item>
<ptxt>
Se la guida del vetro è deformata, ripararla o sostituirla con una nuova.
</ptxt>
</item>
<item>
<ptxt>
Fissare il coperchio ermetico della porta (1) con nastro butilico (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950031.jpg" width = "88.000mm" height = "81.028mm" ver = "01" gw = "215" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
