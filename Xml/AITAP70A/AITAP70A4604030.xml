<servinfosub id = "AITAP70A4604030003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604030004">
<testgroup id = "AITAP70A4604030005">
<question>
È stato eseguito il &#34;Controllo sistema ESP<sup>®</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A4604001">Controllo sistema ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604030006">
<title>
Controllo circuito di alimentazione centralina ESP®
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;E24&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare lo stato del collegamento al terminale &#34;E24-26&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se il collegamento è OK, misurare la tensione tra il terminale &#34;E24-26&#34; e la massa.
</ptxt>
</test1>
<question>
La tensione è 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il circuito &#34;A1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604030007">
<title>
Controllo circuito di massa della centralina ESP®
</title>
<test1>
<ptxt>
Misurare la resistenza tra ciascuno dei terminali &#34;E24-14&#34; e &#34;E24-27&#34; e la massa.
</ptxt>
</test1>
<question>
La resistenza è inferiore a 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire i circuiti &#34;B1&#34; e/o &#34;B2&#34;.
</ptxt>
</action>
</testgroup>
</diag>
