<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A7216029" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della bocchetta di ventilazione centrale
</title>
<servinfosub id = "AITAP70A7216029001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la bocchetta di ventilazione centrale dal cruscotto. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore dell’interruttore luci d’emergenza.
</ptxt>
</s1>
<s1>
<ptxt>
Sganciare le linguette (2) quindi rimuovere la bocchetta di ventilazione centrale (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A721028.swf" width = "88.000mm" height = "58.762mm" ver = "02" gw = "215" gh = "150"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7216029002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
