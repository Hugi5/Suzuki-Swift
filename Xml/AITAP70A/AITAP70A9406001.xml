<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9406001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del serbatoio e della pompa lavacristallo
</title>
<servinfosub id = "AITAP70A9406001001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il paraurti anteriore. 
<intxreftitleoff1 refid = "AITAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare le fascette (1) del cablaggio, i connettori (2) della pompa e le tubazioni flessibili (3) del lavacristallo.
</ptxt>
<figure>
<graphic graphicname = "IAP70P940004.jpg" width = "88.000mm" height = "67.662mm" ver = "01" gw = "209" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il serbatoio lavacristallo (2) dopo aver tolto i bulloni (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940005.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "180" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Tirare la pompa lavacristallo (1) e la pompa lavalunotto (2) nel senso della freccia per staccarle dal serbatoio lavacristallo (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940006.jpg" width = "88.000mm" height = "62.134mm" ver = "01" gw = "161" gh = "160"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9406001002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9406002">Ispezione della pompa lavacristallo</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Stringere i bulloni del serbatoio lavacristalli alla coppia indicata.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9D001">
<t-part>
Bullone serbatoio lavacristallo
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A940008.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "201" gh = "174"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
