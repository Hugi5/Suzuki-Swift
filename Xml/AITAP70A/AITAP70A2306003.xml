<section sectnbr = "2C">
<servcat sctnbr = "02" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A2306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;ammortizzatore posteriore
</title>
<servinfosub id = "AITAP70A2306003001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Sollevare il veicolo da terra e rimuovere le ruote posteriori. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il coperchio del foro di accesso (1) dalla finitura interna pannello laterale posteriore (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A230002.swf" width = "88.000mm" height = "52.091mm" ver = "01" gw = "165" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Sorreggere l’assale posteriore con un martinetto per impedire che si abbassi.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il dado inferiore (1) e la rondella inferiore (5) dell&#39;ammortizzatore posteriore.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il dado superiore (2), la rondella superiore (4) e l&#39;ammortizzatore posteriore (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A230002.swf" width = "88.000mm" height = "119.930mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere le boccole superiori (1) dell’ammortizzatore.
</ptxt>
<figure>
<graphic graphicname = "I9P60A230004.swf" width = "88.000mm" height = "81.823mm" ver = "01" gw = "147" gh = "215"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A2306003002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A2306004">Ispezione dell&#39;ammortizzatore posteriore</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Il dado superiore dell&#39;ammortizzatore posteriore è un dado di tipo autobloccante. Non riutilizzare il dado. Potrebbe allentarsi!
</ptxt>
</attention2>
<s1>
<ptxt>
Installare le boccole superiori (6), l&#39;ammortizzatore posteriore (1) e la rondella superiore (2), come indicato in figura.
</ptxt>
<ptxt>
A questo punto, serrare provvisoriamente il nuovo dado superiore (4) e il dado inferiore (5) dell’ammortizzatore posteriore.
</ptxt>
<attention3>
<ptxt>
Per il senso di montaggio corretto della rondella superiore (2) dell&#39;ammortizzatore, fare riferimento alla figura sotto.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A230003.swf" width = "88.000mm" height = "52.815mm" ver = "01" gw = "236" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.956in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Pannello della scocca
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Rimuovere il martinetto dall’assale posteriore.
</ptxt>
</s1>
<s1>
<ptxt>
Installare le ruote posteriori. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Serrare i dadi superiore e inferiore dell&#39;ammortizzatore posteriore alle coppie specificate.
</ptxt>
<attention3>
<ptxt>
Quando si serrano questi dadi, il veicolo non deve trovarsi sul ponte, né essere in ordine di marcia.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T2C001">
<t-part>
Dado superiore ammortizzatore posteriore
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
28
</t-value1>
<t-value2>
2,9
</t-value2>
<t-value3>
21,0
</t-value3>
</torqueitem>
<torqueitem id = "T2C002">
<t-part>
Dado inferiore ammortizzatore posteriore
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
90
</t-value1>
<t-value2>
9,2
</t-value2>
<t-value3>
66,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A230004.swf" width = "88.000mm" height = "119.931mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Installare il coperchio del foro di accesso dalla finitura interna pannello laterale posteriore.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
