<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del parafango anteriore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9A06004">Componenti parafango anteriore</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A9A06005001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il paraurti anteriore e il relativo supporto. 
<intxreftitleoff1 refid = "AITAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i cadenini frontale e laterale del cofano fisso. 
<intxreftitleoff1 refid = "AITAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo ottico. 
<intxreftitleoff1 refid = "AITAP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;indicatore di direzione laterale. 
<intxreftitleoff1 refid = "AITAP70A9206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il paraspruzzi soglia laterale. 
<intxreftitleoff1 refid = "AITAP70A9806007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il rivestimento del parafango anteriore.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il parafango anteriore e la relativa copertura.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9A06005002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Regolare il gioco del pannello parafango anteriore. 
<intxreftitleoff1 refid = "AITAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Se la vernice dei bulloni del parafango anteriore si è staccata, riverniciarli onde evitare la formazione di ruggine.
</ptxt>
</item>
<item>
<ptxt>
Dopo l&#39;installazione, effettuare l&#39;orientamento dei fari. 
<intxreftitleoff1 refid = "AITAP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
