<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9606014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;interruttore dispositivo apertura portellone posteriore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9606013">Ispezione del dispositivo apertura portellone posteriore a bordo del veicolo</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A9606014001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere la finitura del portellone posteriore. 
<intxreftitleoff1 refid = "AITAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1) dell&#39;interruttore di apertura portellone posteriore.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il cadenino inferiore portellone posteriore. 
<intxreftitleoff1 refid = "AITAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;interruttore (2) di apertura portellone posteriore dopo aver tolto le viti (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A960020.jpg" width = "88.000mm" height = "57.494mm" ver = "01" gw = "194" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9606014002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
