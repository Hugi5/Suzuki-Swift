<servinfosub id = "AITAP70AA504013005">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Premere il pedale frizione a fondo per almeno 3 secondi.
</ptxt>
</s1>
<s1>
<ptxt>
Rilasciare il pedale frizione per almeno 3 secondi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA504013008">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA504013018">
<testgroup id = "AITAP70AA504013019">
<title>
Controllo presenza DTC
</title>
<question>
Sono presenti DTC diversi da B1125?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA504013003">
<title>
Controllo parametri
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i parametri &#34;Interruttore posizione P / CPP2&#34; e &#34;Interruttore frizione / cambio&#34; visualizzati sullo strumento di diagnosi SUZUKI. 
<intxreftitleoff1 refid = "AITAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA504013020">
<title>
Controllo circuito segnale interruttore CPP 1
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare i connettori interruttore CPP 1, &#34;C01&#34;, &#34;E01&#34;, &#34;E25&#34; e &#34;L10&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Verificare che il collegamento ai connettori interruttore CPP 1, &#34;C01&#34;, &#34;E01&#34;, &#34;E25&#34; e &#34;L10&#34; sia corretto.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza del circuito &#34;A1&#34;: meno di 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il circuito &#34;A1&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il terminale del circuito &#34;A1&#34; e ciascun terminale del connettore interruttore CPP 1: infinita
</ptxt>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA504013021">
<title>
Controllo circuito segnale interruttore CPP 2
</title>
<test1>
<ptxt>
Scollegare il connettore dell&#39;interruttore CPP 2.
</ptxt>
</test1>
<test1>
<ptxt>
Verificare che il collegamento ai connettori interruttore CPP 2, &#34;E25&#34; e &#34;L10&#34; sia corretto.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza del circuito &#34;A2&#34;: meno di 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il circuito &#34;A2&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il terminale del circuito &#34;A2&#34; e ciascun terminale del connettore interruttore CPP 2: infinita
</ptxt>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA504013022">
<title>
Controllo interruttore CPP 1
</title>
<test1>
<ptxt>
Controllare l&#39;interruttore CPP 1. 
<intxreftitleoff1 refid = "AITAP70A5306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire l’interruttore CPP 1. 
<intxreftitleoff1 refid = "AITAP70A5306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA504013023">
<title>
Controllo interruttore CPP 2
</title>
<test1>
<ptxt>
Controllare l&#39;interruttore CPP 2. 
<intxreftitleoff1 refid = "AITAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire l’interruttore CPP 2. 
<intxreftitleoff1 refid = "AITAP70A5306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA504013006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Collegare i connettori interruttore CPP 1, CPP 2, &#34;C01&#34;, &#34;E01&#34;, &#34;E25&#34; e &#34;L10&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. (Controllo presenza DTC):
</ptxt>
</test1>
<question>
È rilevato il DTC B1125 corrente?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina sistema di avviamento senza chiave e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
