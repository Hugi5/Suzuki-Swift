<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A4604033" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1074 / C1075
</title>
<servinfosub id = "AITAP70A4604033001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1074: Calibrazione sensore G
</emph>
</ptxt>
<ptxt>
La calibrazione sensore di imbardata/sensore G non è completa.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
La calibrazione sensore di imbardata/sensore G non è completa.
</ptxt>
</item>
<item>
<ptxt>
Centralina ESP<sup>®</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1075: Calibrazione sensore angolo di sterzo
</emph>
</ptxt>
<ptxt>
La calibrazione del sensore angolo sterzo non è stata completata.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Sensore angolo sterzo
</ptxt>
</item>
<item>
<ptxt>
La calibrazione del sensore angolo sterzo non è completa.
</ptxt>
</item>
<item>
<ptxt>
Centralina ESP<sup>®</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70A4604033002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604033003">
<testgroup id = "AITAP70A4604033004">
<question>
È stato eseguito il &#34;Controllo sistema ESP<sup>®</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A4604001">Controllo sistema ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604033005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70A4604005">Controllo presenza DTC</intxref>
.
</ptxt>
</test1>
<question>
Sono presenti DTC diversi da C1074 o C1075?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fare riferimento alla procedura diagnostica relativa al DTC rilevato.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604033006">
<title>
Calibrazione del sensore
</title>
<test1>
<ptxt>
Calibrare tutti i sensori. 
<intxreftitleoff1 refid = "AITAP70A4606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
La calibrazione dei sensori è stata completata?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il sensore angolo sterzo. 
<intxreftitleoff1 refid = "AITAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604033007">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Cancellare tutti i DTC e ricontrollare se ricompaiono.
</ptxt>
</test1>
<question>
È ancora presente il DTC C1074 e/o C1075?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
DTC C1074: Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
DTC C1075: Sostituire il sensore angolo sterzo e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
