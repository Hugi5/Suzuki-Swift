<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A4106010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;interruttore luci stop
</title>
<servinfosub id = "AITAP70A4106010001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il coperchio del foro del piantone. 
<intxreftitleoff1 refid = "AITAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore dell&#39;interruttore luci stop (1).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;interruttore (2) luci stop dal gruppo pedale freno.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A410013.swf" width = "88.000mm" height = "51.187mm" ver = "01" gw = "167" gh = "129"/>
</figure>
</servinfosub>
<servinfosub id = "AITAP70A4106010002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A4106011">Ispezione dell&#39;interruttore luci stop</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Installare l&#39;interruttore luci stop per ottenere le seguenti condizioni: con gruppo pedale del freno (2) tirato verso il sedile del guidatore, la punta dell&#39;interruttore luci stop (1) tocca il gruppo pedale freno.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410045.swf" width = "88.000mm" height = "51.187mm" ver = "02" gw = "167" gh = "129"/>
</figure>
<attention3>
<ptxt>
Quando l&#39;interruttore luci stop è montato correttamente, la distanza &#34;a&#34; tra l&#39;interruttore luci stop e il pedale del freno sarà come segue:
</ptxt>
<ptxt>
1,1 – 2,1 mm (0,044 – 0,082 in.)
</ptxt>
<figure>
<graphic graphicname = "I9P60A410015.swf" width = "88.000mm" height = "51.402mm" ver = "01" gw = "142" gh = "129"/>
</figure>
</attention3>
</s1>
<s1>
<ptxt>
Collegare il connettore dell&#39;interruttore luci stop.
</ptxt>
</s1>
<s1>
<ptxt>
Installare il coperchio del piantone sterzo. 
<intxreftitleoff1 refid = "AITAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
