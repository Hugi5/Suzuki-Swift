<title>
DTC B1190
</title>
<servinfosub id = "AITAP70AA314020001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.602in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.602in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni rilevate
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1190: Malfunzionamento interruttore motore
</emph>
</ptxt>
<ptxt>
La centralina immobilizzatore è difettosa.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Centralina immobilizzatore
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70AA314020002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA314020003">
<testgroup id = "AITAP70AA314020004">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Cancellare il DTC. 
<intxreftitleoff1 refid = "AITAP70AA314004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC B1190?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina immobilizzatore e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA316001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
</testgroup>
