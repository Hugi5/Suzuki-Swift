<diag type = "test" id = "AITAP70A7224018005">
<testgroup id = "AITAP70A7224018006">
<title>
Controllo parametri sullo strumento di diagnosi
</title>
<test1>
<ptxt>
Controllare il parametro &#34;Sensore posizione miscelatore aria&#34; nella modalità &#34;Elenco dati&#34; dello strumento di diagnosi SUZUKI. 
<intxreftitleoff1 refid = "AITAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
La tensione è superiore a 4,8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Guasto intermittente.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A7224018007">
<title>
Controllo circuito segnale sensore di posizione attuatore sistema di controllo temperatura
</title>
<test1>
<ptxt>
Scollegare il connettore dell’attuatore sistema di controllo temperatura.
</ptxt>
</test1>
<test1>
<ptxt>
Collegare i terminali del connettore attuatore sistema di controllo temperatura collegati ai fili &#34;YEL&#34; e &#34;YEL/RED&#34; utilizzando un ponticello.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente il DTC B1511-L?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire l&#39;attuatore sistema di controllo temperatura. 
<intxreftitleoff1 refid = "AITAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A7224018008">
<title>
Controllo circuito segnale sensore di posizione attuatore sistema di controllo temperatura
</title>
<test1>
<ptxt>
Collegare i terminali del connettore &#34;G20&#34; collegati ai fili &#34;YEL&#34; e &#34;YEL/RED&#34; utilizzando un ponticello.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente il DTC B1511-L?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire la centralina HVAC e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
