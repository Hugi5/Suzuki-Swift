<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1104A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Eccessiva emissione di idrocarburi (HC) o di monossido di carbonio (CO)
</title>
<ptxt>
Eseguire la ricerca guasti facendo riferimento ai punti che seguono nel caso in cui non ci siano DTC memorizzati nell&#39;ECM e dai controlli descritti in 
<intxref refid = "AITAP70A1104008">Ispezione visiva</intxref>
 e 
<intxref refid = "AITAP70A1104009">Ispezione di base del motore</intxref>
 non siano emerse anomalie.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Eccessiva emissione di idrocarburi (HC) o di monossido di carbonio (CO)
</ptxt>
</condition>
<ps>
<ptxt>
Candela difettosa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1806002">Ispezione delle candele di accensione</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Bobina d’accensione transistorizzata difettosa
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1806004">Ispezione del gruppo bobine d’accensione</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Compressione insufficiente
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1404001">Controllo della compressione</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Marmitta catalitica trivalente contaminato da piombo
</ptxt>
</ps>
<action>
<ptxt>
Controllare se al bocchettone di immissione manca la restrizione che impedisce di inserire un erogatore di benzina con piombo.
</ptxt>
</action>
<ps>
<ptxt>
Impianto di controllo dell’emissione dei vapori difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1204001">Ispezione del sistema di spurgo canister EVAP</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Pressione del carburante non corretta
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1704005">Controllo della pressione del carburante</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Anomalia nel sistema di controllo a ciclo chiuso (compensazione retroattiva del rapporto A/F) (scarse prestazioni del sensore ECT o MAF)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306012">Ispezione del sensore ECT</intxref>
 o 
<intxref refid = "AITAP70A1306026">Ispezione del sensore MAF/IAT</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo corpo farfalla motorizzata difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306004">Ispezione del gruppo corpo della farfalla motorizzata a bordo del veicolo</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo sensore APP difettoso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306008">Ispezione del sensore APP</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Iniettori difettosi
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1704003">Controllo circuito iniettori carburante</intxref>
</ptxt>
</action>
<ps>
<ptxt>
ECM guasta
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1104070">Ispezione dell&#39;ECM e dei suoi circuiti</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Il motore non è in temperatura
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Filtro dell’aria occluso
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406003">Ispezione e pulizia filtro aria</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Dispersione di depressione
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1404002">Controllo della depressione del motore</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Sistema di controllo posizione dell&#39;albero a camme (VVT) non a posto
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1306027">Ispezione della valvola OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
