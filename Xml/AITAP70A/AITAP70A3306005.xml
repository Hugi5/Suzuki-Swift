<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A3306005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Smontaggio e rimontaggio del gruppo rinvio
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A3306003">Smontaggio e rimontaggio del rinvio</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AITAP70A3306004">Componenti gruppo rinvio</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A3306005001">
<title>
Smontaggio
</title>
<s1>
<ptxt>
Rimuovere il paraolio n. 1 (1) dalla scatola destra del rinvio usando l&#39;attrezzo speciale.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C001">
<s-part>
</s-part>
<s-number num = "09913-50121">
09913–50121
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;anello elastico (2) usando le apposite pinze.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;albero intermedio (4) con il relativo cuscinetto (3) dal gruppo rinvio.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il cuscinetto (3) dell&#39;albero intermedio da quest&#39;ultimo (4) utilizzando un estrattore e una pressa idraulica.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330008.swf" width = "88.000mm" height = "26.342mm" ver = "01" gw = "155" gh = "58"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo gabbia di uscita del rinvio (1) e lo spessore (3) togliendo i bulloni (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330010.swf" width = "88.000mm" height = "55.632mm" ver = "01" gw = "206" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere i bulloni (1) della scatola del rinvio.
</ptxt>
</s1>
<s1>
<ptxt>
Separare la scatola destra (2) dalla scatola sinistra (3) del rinvio utilizzando l&#39;attrezzo speciale.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C002">
<s-part>
</s-part>
<s-number num = "09912-34510">
09912–34510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330011.swf" width = "88.000mm" height = "57.119mm" ver = "02" gw = "143" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo ingranaggio di comando del riduttore (1) e il gruppo ingranaggio condotto del riduttore (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330012.swf" width = "88.000mm" height = "45.732mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere le piste esterne (1) e lo spessore (2) del cuscinetto.
</ptxt>
<attention3>
<ptxt>
Qualora si incontrassero delle difficoltà nel rimuovere le piste esterne dei cuscinetti dalle scatole, provare con un attrezzo speciale.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C003">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944–96011
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330013.swf" width = "88.000mm" height = "51.937mm" ver = "01" gw = "196" gh = "131"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A3306005002">
<title>
Rimontaggio
</title>
<s1>
<ptxt>
Scegliere lo spessore appropriato come indicato di seguito.
</ptxt>
<s2>
<ptxt>
Misurare la distanza &#34;a&#34; tra le piste esterne del cuscinetto a rullini conici del gruppo ingranaggio condotto del riduttore (1).
</ptxt>
</s2>
<s2>
<ptxt>
Misurare la profondità &#34;b&#34; della scatola sinistra (2) e &#34;c&#34; della scatola destra (3).
</ptxt>
</s2>
<s2>
<ptxt>
Calcolare la misura dello spessore di rasamento mediante l’equazione che segue.
</ptxt>
<ptxt>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "9" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.748in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.157in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.451in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.157in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.451in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.157in"/>
<colspec colnum = "7" colname = "7" colwidth = "0.560in"/>
<colspec colnum = "8" colname = "8" colwidth = "0.157in"/>
<colspec colnum = "9" colname = "9" colwidth = "0.591in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "middle" align = "center">
<ptxt>
Spessore di rasamento necessario
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
=
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Profondità &#34;b&#34;
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Profondità &#34;c&#34;
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
–
</ptxt>
</entry>
<entry colname = "7" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Distanza &#34;a&#34;
</ptxt>
</entry>
<entry colname = "8" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "9" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "middle" align = "center">
<ptxt>
0,1 mm (0,004 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<figure>
<graphic graphicname = "IAP70A330014.swf" width = "88.000mm" height = "40.526mm" ver = "02" gw = "225" gh = "98"/>
</figure>
</s2>
<c-change/>
<s2>
<ptxt>
Selezionare, tra le misure disponibili elencate di seguito, degli spessori la cui misura complessiva, cioè lato destro più lato sinistro, corrisponda al valore risultante dal calcolo.
</ptxt>
<ptxt>
<emph etype = "bold">
Ad esempio:
</emph>
</ptxt>
<ptxt>
Distanza di misurazione &#34;a&#34;: 101,75 mm (4,006 in.).
</ptxt>
<ptxt>
Profondità di misurazione &#34;b&#34;: 77,95 mm (3,069 in.).
</ptxt>
<ptxt>
Profondità di misurazione &#34;c&#34;: 25,80 mm (1,016 in.).
</ptxt>
<ptxt>
Dimensione dello spessore necessario = 77,95 mm (3,069 in.) + 25,80 mm (1,016 in.) – 101,75 mm (4,006 in.) + 0,1 mm (0,004 in.) = 2,10 mm (0,083 in.)
</ptxt>
<spec>
<title>
Spessori dell&#39;ingranaggio condotto del riduttore disponibili
</title>
<ptxt>
Lato destro:
</ptxt>
<ptxt>
0,60; 0,65; 0,70; 0,75; 0,80; 0,85; 0,90; 0,95; 1,00 e 1,05 mm (0,024; 0,026; 0,028; 0,030; 0,031; 0,033; 0,035; 0,037; 0,039 e 0,041 in.)
</ptxt>
<ptxt>
Lato sinistro:
</ptxt>
<ptxt>
1,00; 1,05; 1,10; 1,15; 1,20; 1,25; 1,30; 1,35; 1,40 e 1,45 mm (0,039; 0,041; 0,043; 0,045; 0,047; 0,049; 0,051; 0,053; 0,055 e 0,057 in.)
</ptxt>
</spec>
</s2>
</s1>
<s1>
<ptxt>
Pulire la superficie di accoppiamento delle scatole destra e sinistra, quindi applicare un cordone di sigillante del diametro di 1,2 mm (0,047 in.) sulla scatola destra (1) come mostrato in figura.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3C005" uid = "-491504098">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Materiale sigillante
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I5RW0A330011.swf" width = "88.000mm" height = "42.399mm" ver = "01" gw = "155" gh = "104"/>
</figure>
</s1>
<s1>
<ptxt>
Montare le seguenti parti nelle scatole destra e sinistra ripetendo al contrario la procedura di smontaggio.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Gruppo ingranaggio conduttore del riduttore (1)
</ptxt>
</item>
<item>
<ptxt>
Gruppo ingranaggio condotto del riduttore (2)
</ptxt>
</item>
<item>
<ptxt>
Piste esterne del cuscinetto (3)
</ptxt>
</item>
<item>
<ptxt>
Spessori ingranaggio condotto del riduttore (4)
</ptxt>
</item>
<item>
<ptxt>
Grano di riferimento (5)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A330015.jpg" width = "88.000mm" height = "60.349mm" ver = "01" gw = "213" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Serrare i bulloni della scatola del rinvio alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T3C006">
<t-part>
Bullone scatola rinvio
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330016.swf" width = "88.000mm" height = "61.238mm" ver = "01" gw = "169" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Selezionare lo spessore del pignone della coppia conica (1) facendo riferimento al passo 1) di &#34;Rimontaggio&#34; in 
<intxref refid = "AITAP70A3306009">Smontaggio e rimontaggio del gruppo gabbia di uscita del rinvio</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Controllare il contatto tra i denti facendo riferimento a 
<intxref refid = "AITAP70A3306011">Ispezione del contatto tra i denti delle corone</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Installare il gruppo gabbia di uscita del rinvio (2) completo di scatola sinistra del rinvio (3) insieme allo spessore del pignone della coppia conica (1) e serrare i bulloni della gabbia alla coppia specificata.
</ptxt>
<torque>
<torqueitem id = "T3C007">
<t-part>
Bullone gabbia di uscita del rinvio
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330017.swf" width = "88.000mm" height = "45.870mm" ver = "01" gw = "165" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Installare il bullone nel foro della flangia (2) e posizionare il tastatore del comparatore ad angolo retto rispetto al bullone (1), come mostrato in figura. Mantenendo l&#39;ingranaggio condotto del riduttore con la mano, misurare il gioco del pignone della corona coppia conica.
</ptxt>
<attention3>
<ptxt>
Se il gioco supera i valori specificati sotto, regolarlo cambiando il rapporto della dimensione degli spessori montati nelle scatola destra e sinistra al passo 3).
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C004">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900–20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3C005">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900–20701
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Gioco pignone coppia conica e corona coppia conica
</title>
<ptxt>
: 0,1 – 0,2 mm (0,0039 – 0,0078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330018.swf" width = "88.000mm" height = "39.091mm" ver = "01" gw = "157" gh = "94"/>
</figure>
</s1>
<s1>
<ptxt>
Installare il cuscinetto (1) sull&#39;albero intermedio (2) usando l&#39;attrezzo speciale.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C006">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913–84510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A330015.swf" width = "88.000mm" height = "48.692mm" ver = "01" gw = "71" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Installare l&#39;albero intermedio (2) con il cuscinetto (3) nel rinvio.
</ptxt>
</s1>
<s1>
<ptxt>
Installare il nuovo anello elastico (1) sulla scatola destra del rinvio usando le apposite pinze.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330016.swf" width = "88.000mm" height = "26.757mm" ver = "02" gw = "133" gh = "59"/>
</figure>
</s1>
<s1>
<ptxt>
Applicare il grasso sul labbro del nuovo paraolio n. 1 della scatola destra.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C006" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasso
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Inserire il paraolio n. 1 (1) nella scatola destra del rinvio (2) usando l&#39;attrezzo speciale e il martello.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C007">
<s-part>
(A)
</s-part>
<s-number num = "09925-16010">
09925–16010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Profondità di installazione paraolio di uscita albero intermedio
</title>
<ptxt>
&#34;a&#34;: 1,0 – 2,0 mm (0,039 – 0,078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330042.swf" width = "88.000mm" height = "45.592mm" ver = "01" gw = "201" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
