<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A9204A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Mancata accensione della luce plafoniera o della luce leggimappa
</title>
<diag type = "condition">
<condition>
<ptxt>
Mancata accensione della luce plafoniera o della luce leggimappa
</ptxt>
</condition>
<ps>
<ptxt>
BCM difettosa
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Fare riferimento a &#34;Ispezione della BCM e dei relativi circuiti&#34; nella SEZIONE 10B.
</ptxt>
<ptxt>
Modello con commutatore di accensione: 
<intxreftitleoff1 refid = "AITAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: 
<intxreftitleoff1 refid = "AITAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Guasto del circuito del sistema (compresi relè e fusibili)
</ptxt>
</ps>
<action>
<ptxt>
Riparare il circuito.
</ptxt>
</action>
<ps>
<ptxt>
Lampadine bruciate
</ptxt>
</ps>
<action>
<ptxt>
Sostituire le lampadine.
</ptxt>
</action>
<ps>
<ptxt>
Guasto interruttore porta
</ptxt>
</ps>
<action>
<ptxt>
Fare riferimento a 
<intxref refid = "AITAP70A9606008">Ispezione degli interruttori porte anteriori e posteriori</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
