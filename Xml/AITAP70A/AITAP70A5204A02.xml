<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Innesto marce faticoso
</title>
<diag type = "condition">
<condition>
<ptxt>
Innesto marce faticoso
</ptxt>
</condition>
<ps>
<ptxt>
Lubrificante inadeguato
</ptxt>
</ps>
<action>
<ptxt>
Rabboccare l&#39;olio del cambio manuale.
</ptxt>
</action>
<ps>
<ptxt>
Gioco pedale della frizione non corretto
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire il braccio del pedale della frizione o la pompa della frizione. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Braccio pedale della frizione: 
<intxreftitleoff1 refid = "AITAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pompa della frizione: 
<intxreftitleoff1 refid = "AITAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Deformazione o rottura del disco frizione
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il disco frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Spingidisco della frizione danneggiato
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il coperchio frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Anello sincronizzatore usurato
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire l&#39;anello sincronizzatore.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Anello sincronizzatore marce basse e anello sincronizzatore 2ª marcia: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Anello sincronizzatore marce alte: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Anello sincronizzatore 5ª marcia: 
<intxreftitleoff1 refid = "AITAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Usura dei denti smussati di manicotto o ingranaggio
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire il gruppo manicotto e mozzo del sincronizzatore unitamente all&#39;ingranaggio.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ingranaggi 1ª e 2ª dell&#39;albero secondario: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ingranaggi 3ª e 4ª dell&#39;albero primario: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ingranaggio 5ª marcia albero primario: 
<intxreftitleoff1 refid = "AITAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manicotto e mozzo sincronizzatore marce basse: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manicotto e mozzo sincronizzatore marce alte: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manicotto e mozzo sincronizzatore 5ª velocità: 
<intxreftitleoff1 refid = "AITAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Usura della boccola del giunto dell’albero di comando del cambio
</ptxt>
</ps>
<action>
<ptxt>
Sostituire la boccola del giunto dell’albero di comando del cambio. 
<intxreftitleoff1 refid = "AITAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformazione dell’albero di selezione
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire l&#39;albero o la forcella di selezione
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Albero di selezione marce basse: 
<intxreftitleoff1 refid = "AITAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Albero di selezione marce alte: 
<intxreftitleoff1 refid = "AITAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Forcella di selezione 5ª 
<intxreftitleoff1 refid = "AITAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Rottura dei cavi di comando selezione e innesto
</ptxt>
</ps>
<action>
<ptxt>
Sostituire i cavi di comando selezione e innesto delle marce. 
<intxreftitleoff1 refid = "AITAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
