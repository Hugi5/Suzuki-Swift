<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1306009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del sensore MAP
</title>
<servinfosub id = "AITAP70A1306009001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Staccare il connettore del sensore MAP.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il sensore MAP (1) dal collettore di aspirazione (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A131003.jpg" width = "88.000mm" height = "51.551mm" ver = "01" gw = "185" gh = "130"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1306009002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1306010">Ispezione del sensore MAP</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Verificare che l’O-ring non sia danneggiato.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
