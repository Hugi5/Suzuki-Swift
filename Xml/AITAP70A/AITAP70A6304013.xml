<title>
DTC C1141 / C1142 / C1143 / C1145
</title>
<servinfosub id = "AITAP70A6304013001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.347in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.778in"/>
<thead>
<row rowsep = "1">
