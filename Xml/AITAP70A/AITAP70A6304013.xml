<servinfosub id = "AITAP70A6304013003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Avviare il motore.
</ptxt>
</s1>
<s1>
<ptxt>
Girare il volante completamente, in entrambe le direzioni.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A6304013004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A6304013005">
<testgroup id = "AITAP70A6304013006">
<question>
È stato eseguito il &#34;Controllo sistema ESP&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A6304001">Controllo del sistema P/S</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304013007">
<title>
Controllo dei circuiti del motorino P/S e di uscita del motorino P/S
</title>
<test1>
<ptxt>
Con accensione su &#34;OFF&#34;, scollegare il connettore &#34;E12&#34; del motorino P/S dalla centralina P/S.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i collegamenti ai terminali del connettore &#34;E12&#34; del motorino P/S.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza tra i circuiti &#34;A1&#34; e &#34;A2&#34;: circa 1 Ω
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il circuito &#34;A1&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
tensione del circuito &#34;A1&#34;: 0 – 1 V (con accensione su &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Controllare il motorino P/S. 
<intxreftitleoff1 refid = "AITAP70A6306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina P/S e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il motorino P/S (gruppo piantone dello sterzo). 
<intxreftitleoff1 refid = "AITAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
