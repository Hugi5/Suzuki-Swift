<servinfosub id = "AITAP70A1104057003">
<title>
Procedura di conferma DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Eseguire innanzitutto la ricerca guasti dei DTC inattesi, rilevati in precedenza nella &#34;Procedura di conferma DTC&#34;.
</ptxt>
</item>
<item>
<ptxt>
Verificare che la &#34;Procedura di conferma DTC&#34; venga effettuata in presenza delle condizioni indicate di seguito.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tensione sistema &#62; 8 V
</ptxt>
</item>
<item>
<ptxt>
Non vengono rilevati i DTC P2122, P2123, P2127 e P2128.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Tenere il pedale dell’acceleratore completamente premuto per 2 secondi.
</ptxt>
</s1>
<s1>
<ptxt>
Tenere il pedale dell’acceleratore rilasciato per 2 secondi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1104057004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A1104057005">
<testgroup id = "AITAP70A1104057006">
<question>
È stata eseguita la procedura &#34;Verifica del sistema di controllo del motore e delle emissioni&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1104001">Verifica del sistema di controllo del motore e delle emissioni</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104057007">
<title>
Controllo del cablaggio
</title>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
circuiti &#34;A1&#34;, &#34;A2&#34; e &#34;A3&#34;: fare riferimento ai passi da 3 a 5 di 
<intxref refid = "AITAP70A1104054">DTC P2122 / P2123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
circuiti &#34;B1&#34;, &#34;B2&#34; e &#34;B3&#34;: fare riferimento ai passi da 3 a 5 di 
<intxref refid = "AITAP70A1104055">DTC P2127 / P2128</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104057008">
<title>
Controllo sensore APP
</title>
<test1>
<ptxt>
Controllare le prestazioni del sensore APP. 
<intxreftitleoff1 refid = "AITAP70A1306006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il gruppo sensore APP.
</ptxt>
</action>
</testgroup>
</diag>
