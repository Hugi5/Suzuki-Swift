<servinfosub id = "AITAP70A1104050003">
<title>
Procedura di conferma DTC
</title>
<attention3>
<ptxt>
Verificare che la &#34;Procedura di conferma DTC&#34; venga effettuata in presenza della condizione indicata di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tensione batteria &#62; 8,5 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Tenere il motore al regime minimo per 10 secondi.
</ptxt>
</s1>
<s1>
<ptxt>
Portare l&#39;interruttore A/C su ON per 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Portare l’interruttore A/C su OFF.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1104050004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A1104050005">
<testgroup id = "AITAP70A1104050006">
<question>
È stata eseguita la procedura &#34;Verifica del sistema di controllo del motore e delle emissioni&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1104001">Verifica del sistema di controllo del motore e delle emissioni</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104050007">
<title>
Controllo circuito di alimentazione relè compressore A/C (lato bobina)
</title>
<test1>
<ptxt>
Con accensione in posizione &#34;OFF&#34;, rimuovere il relè compressore A/C.
</ptxt>
</test1>
<test1>
<ptxt>
Verificare che il collegamento al connettore del relè compressore A/C sia corretto.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono OK, portare l&#39;accensione in posizione &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare che la tensione tra &#34;A1&#34; e la massa corrisponda alla tensione di batteria.
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104050008">
<title>
Controllo relè compressore A/C
</title>
<test1>
<ptxt>
Controllare il relè compressore A/C.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modello con A/C manuale: 
<intxreftitleoff1 refid = "AITAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modello con A/C automatico: 
<intxreftitleoff1 refid = "AITAP70A7226042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il relè del compressore A/C.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104050009">
<title>
Controllo circuito di comando del relè compressore A/C
</title>
<test1>
<ptxt>
Con accensione su &#34;OFF&#34;, scollegare i connettori &#34;C01&#34; e &#34;E01&#34; dalla ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare l&#39;integrità dei collegamenti dei terminali ai connettori &#34;C01&#34; e &#34;E01&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza del circuito &#34;B1&#34;: meno di 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il circuito &#34;B1&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il terminale del circuito &#34;B1&#34; e l&#39;altro terminale del connettore relè compressore A/C: infinita
</ptxt>
</item>
<item>
<ptxt>
tensione del circuito &#34;B1&#34;: 0 – 1 V (con accensione su &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
