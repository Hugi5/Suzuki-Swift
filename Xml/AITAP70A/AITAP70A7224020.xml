<diag type = "test" id = "AITAP70A7224020007">
<testgroup id = "AITAP70A7224020008">
<title>
Controllo parametri sullo strumento di diagnosi
</title>
<test1>
<ptxt>
Controllare il parametro &#34;Sensore posizione miscelatore aria&#34; nella modalità &#34;Elenco dati&#34; dello strumento di diagnosi SUZUKI. 
<intxreftitleoff1 refid = "AITAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Guasto intermittente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A7224020009">
<title>
Controllo circuito attuatore sistema di controllo temperatura
</title>
<test1>
<ptxt>
Scollegare i connettori &#34;G20&#34; e dell’attuatore sistema di controllo temperatura.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistenza dei circuiti dei fili &#34;GRY&#34; e &#34;LT BLU&#34;: meno di 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Resistenza dei circuiti dei fili &#34;GRY&#34; e &#34;LT BLU&#34; tra l&#39;attuatore sistema di controllo temperatura e la massa: infinita
</ptxt>
</item>
</list1>
</test1>
<question>
I valori della resistenza sono nella norma?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A7224020010">
<title>
Controllo attuatore sistema di controllo temperatura
</title>
<test1>
<ptxt>
Controllare l&#39;attuatore sistema di controllo temperatura. 
<intxreftitleoff1 refid = "AITAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’attuatore è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina HVAC e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire l&#39;attuatore sistema di controllo temperatura. 
<intxreftitleoff1 refid = "AITAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
