<servinfosub id = "AITAP70A4604029003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604029004">
<testgroup id = "AITAP70A4604029005">
<question>
È stato eseguito il &#34;Controllo sistema ESP<sup>®</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A4604001">Controllo sistema ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604029006">
<title>
Controllo dei circuiti di alimentazione e di massa della centralina ESP®
</title>
<test1>
<ptxt>
Controllare i circuiti di alimentazione e di massa della centralina ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "AITAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604029007">
<title>
Controllo tensione di alimentazione della centralina ESP®
</title>
<test1>
<ptxt>
Misurare la tensione della batteria con il motore in funzione a 3.000 giri/min.
</ptxt>
</test1>
<question>
La tensione è compresa tra 9,3 V e 16,8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Controllare l’impianto di ricarica. 
<intxreftitleoff1 refid = "AITAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
