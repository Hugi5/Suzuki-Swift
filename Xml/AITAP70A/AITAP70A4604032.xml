<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A4604032" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1069
</title>
<servinfosub id = "AITAP70A4604032001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.536in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.635in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1069: Specifiche sensore angolo sterzo non registrate
</emph>
</ptxt>
<ptxt>
La centralina ESP<sup>®</sup> rileva che è stato montato un sensore angolo sterzo in uso su un altro veicolo.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Centralina ESP<sup>®</sup>
</ptxt>
</item>
<item>
<ptxt>
Sensore angolo sterzo
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70A4604032002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604032003">
<testgroup id = "AITAP70A4604032004">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Sostituire il sensore angolo sterzo. 
<intxreftitleoff1 refid = "AITAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70A4604005">Controllo presenza DTC</intxref>
.
</ptxt>
</test1>
<question>
È presente il DTC C1069?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
