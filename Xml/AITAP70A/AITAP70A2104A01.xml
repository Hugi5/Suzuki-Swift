<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A2104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Il veicolo tira da un lato (sbanda)
</title>
<diag type = "condition">
<condition>
<ptxt>
Il veicolo tira da un lato (sbanda)
</ptxt>
</condition>
<ps>
<ptxt>
Pneumatici mal assortiti o usurati in maniera irregolare
</ptxt>
</ps>
<action>
<ptxt>
Sostituire i pneumatici. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pressione dei pneumatici erronea
</ptxt>
</ps>
<action>
<ptxt>
Regolare la pressione dei pneumatici.
</ptxt>
</action>
<ps>
<ptxt>
Molle elicoidali rotte o insaccate
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sostituire le molle elicoidali. 
</ptxt>
<ptxt>
Parte anteriore: 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Parte posteriore: 
<intxreftitleoff1 refid = "AITAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Forza laterale anomala creata dal pneumatico radiale
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il pneumatico. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Assetto ruote non corretto
</ptxt>
</ps>
<action>
<ptxt>
Controllare e regolare l&#39;assetto ruote. 
<intxreftitleoff1 refid = "AITAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Strisciamento del freno su una ruota
</ptxt>
</ps>
<action>
<ptxt>
Regolare o riparare il freno.
</ptxt>
</action>
<ps>
<ptxt>
Allentamento, deformazione o rottura di qualche componente delle sospensioni anteriore o posteriore
</ptxt>
</ps>
<action>
<ptxt>
Serrare o sostituire i componenti delle sospensioni difettosi. 
<intxreftitleoff1 refid = "AITAP70A2106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
