<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del gruppo alzacristalli porta posteriore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9506014">Componenti della porta posteriore</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A9506017001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il vetro della porta posteriore. 
<intxreftitleoff1 refid = "AITAP70A9506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1) del motorino alzacristalli elettrico.
</ptxt>
</s1>
<s1>
<ptxt>
Togliere i bulloni (2) quindi rimuovere il gruppo alzacristalli porta posteriore (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950048.jpg" width = "88.000mm" height = "61.700mm" ver = "02" gw = "217" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9506017002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9506018">Ispezione del gruppo alzacristalli finestrino posteriore</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ingrassare le parti scorrevoli del gruppo alzacristalli del finestrino posteriore.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E002" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Grasso
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Serrare i bulloni dell&#39;alzacristalli posteriore nell&#39;ordine (da &#34;1&#34; a &#34;4&#34;) alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T9E006">
<t-part>
Bullone dell&#39;alzacristalli posteriore*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,86
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950049.jpg" width = "88.000mm" height = "63.881mm" ver = "01" gw = "225" gh = "165"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
