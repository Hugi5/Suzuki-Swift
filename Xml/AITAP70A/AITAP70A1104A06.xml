<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Motore rumoroso – Rumore proveniente dall&#39;albero motore
</title>
<ptxt>
Eseguire la ricerca guasti facendo riferimento ai punti che seguono nel caso in cui non ci siano DTC memorizzati nell&#39;ECM e dai controlli descritti in 
<intxref refid = "AITAP70A1104008">Ispezione visiva</intxref>
 e 
<intxref refid = "AITAP70A1104009">Ispezione di base del motore</intxref>
 non siano emerse anomalie.
</ptxt>
<diag type = "condition">
<condition>
<paragroup>
<ptxt>
Motore rumoroso – Rumore proveniente dall&#39;albero motore
</ptxt>
<attention3>
<ptxt>
Prima di cercare la causa del rumore nelle parti meccaniche verificare che:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Il tipo di candela usato sia quello giusto.
</ptxt>
</item>
<item>
<ptxt>
Il carburante usato sia quello giusto.
</ptxt>
</item>
</list1>
</attention3>
</paragroup>
</condition>
<ps>
<ptxt>
Pressione dell’olio insufficiente
</ptxt>
</ps>
<action>
<ptxt>
Condizione &#34;Pressione dell’olio insufficiente&#34;
</ptxt>
</action>
<ps>
<ptxt>
Cuscinetto di banco usurato
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406041">Ispezione dei cuscinetti di banco</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Perno di banco usurato
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406040">Ispezione albero motore</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Bulloni cappelli cuscinetti laschi
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406041">Ispezione dei cuscinetti di banco</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Eccessivo gioco assiale dell’albero motore
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A1406040">Ispezione albero motore</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
