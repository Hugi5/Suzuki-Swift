<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0030: Circuito di comando riscaldatore HO2S (sensore 1)
</emph>
</ptxt>
<ptxt>
Il circuito di comando del riscaldatore sensore A/F è aperto.
</ptxt>
<ptxt>
(Logica di rilevamento a 3 D/C)
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
