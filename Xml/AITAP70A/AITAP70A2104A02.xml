<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Usura anomala o eccessiva
</title>
<diag type = "condition">
<condition>
<ptxt>
Usura anomala o eccessiva
</ptxt>
</condition>
<ps>
<ptxt>
Molle elicoidali rotte o insaccate
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Sostituire le molle elicoidali. 
</ptxt>
<ptxt>
Parte anteriore: 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Parte posteriore: 
<intxreftitleoff1 refid = "AITAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Ruota sbilanciata
</ptxt>
</ps>
<action>
<ptxt>
Bilanciare o sostituire il pneumatico.
</ptxt>
</action>
<ps>
<ptxt>
Assetto ruote non corretto
</ptxt>
</ps>
<action>
<ptxt>
Controllare e regolare l&#39;assetto ruote. 
<intxreftitleoff1 refid = "AITAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo ammortizzatore anteriore difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo ammortizzatore anteriore. 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Stile di guida gravoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire i pneumatici. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sovraccaricamento del veicolo
</ptxt>
</ps>
<action>
<ptxt>
Controllare il carico.
</ptxt>
</action>
<ps>
<ptxt>
Mancata rotazione dei pneumatici
</ptxt>
</ps>
<action>
<ptxt>
Sostituire o ruotare i pneumatici.
</ptxt>
</action>
<ps>
<ptxt>
Cuscinetto della ruota usurato o lasco
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il cuscinetto della ruota. 
<intxreftitleoff1 refid = "AITAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
La ruota o il pneumatico gira fuori piano
</ptxt>
</ps>
<action>
<ptxt>
Sostituire la ruota o il pneumatico.
</ptxt>
</action>
<ps>
<ptxt>
Pressione dei pneumatici erronea
</ptxt>
</ps>
<action>
<ptxt>
Regolare la pressione dei pneumatici.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
