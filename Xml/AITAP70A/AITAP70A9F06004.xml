<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9F06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;antenna radio
</title>
<servinfosub id = "AITAP70A9F06004001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il rivestimento del padiglione. 
<intxreftitleoff1 refid = "AITAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1) dell&#39;antenna radio.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il bullone (2) dell&#39;antenna radio.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la base (3) e l&#39;asta (4) dell&#39;antenna radio.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0007.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9F06004002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare il bullone dell&#39;antenna alla coppia specificata.
</ptxt>
<torque>
<torqueitem id = "T9O001">
<t-part>
Bullone antenna
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,0
</t-value1>
<t-value2>
0,7
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A9F0008.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
