<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A5304A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La frizione striscia
</title>
<diag type = "condition">
<condition>
<ptxt>
La frizione striscia
</ptxt>
</condition>
<ps>
<ptxt>
Gioco pedale della frizione non corretto
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire il braccio del pedale della frizione e/o la pompa della frizione.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Braccio pedale della frizione: 
<intxreftitleoff1 refid = "AITAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pompa della frizione: 
<intxreftitleoff1 refid = "AITAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Affaticamento della molla a diaframma o usura delle rispettive pinzette
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il coperchio frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Scanalature dell&#39;albero primario arrugginite
</ptxt>
</ps>
<action>
<ptxt>
Lubrificare le scanalature dell&#39;albero primario.
</ptxt>
</action>
<ps>
<ptxt>
Scanalature albero primario cambio danneggiate o usurate
</ptxt>
</ps>
<action>
<ptxt>
Sostituire l&#39;albero primario. 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disco frizione eccessivamente eccentrico
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il disco frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Materiale d’attrito della frizione rotto o intriso d’olio
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il disco frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Perdita di liquido
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire l&#39;impianto della frizione.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
