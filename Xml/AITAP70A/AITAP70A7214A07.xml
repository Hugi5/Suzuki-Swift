<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A7214A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Non esce aria fredda a sufficienza (la frizione magnetica funziona normalmente)
</title>
<diag type = "condition">
<condition>
<ptxt>
Non esce aria fredda a sufficienza (la frizione magnetica funziona normalmente)
</ptxt>
</condition>
<ps>
<ptxt>
Carica di refrigerante insufficiente o eccessiva
</ptxt>
</ps>
<action>
<ptxt>
Controllare la quantità di refrigerante e l&#39;eventuale presenza di perdite dall&#39;impianto.
</ptxt>
</action>
<ps>
<ptxt>
Condensatore occluso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il condensatore. 
<intxreftitleoff1 refid = "AITAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Evaporatore A/C occluso o congelato
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Controllare il sensore temperatura evaporatore A/C e l&#39;evaporatore A/C.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Evaporatore A/C: 
<intxreftitleoff1 refid = "AITAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sensore temperatura evaporatore: 
<intxreftitleoff1 refid = "AITAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Sensore temperatura evaporatore difettoso.
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sensore temperatura evaporatore. 
<intxreftitleoff1 refid = "AITAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Valvola d’espansione difettosa.
</ptxt>
</ps>
<action>
<ptxt>
Controllare la valvola d’espansione. 
<intxreftitleoff1 refid = "AITAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Allentamento o rottura della cinghia di comando del compressore
</ptxt>
</ps>
<action>
<ptxt>
Controllare la cinghia di comando del compressore. 
<intxreftitleoff1 refid = "AITAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slittamento della frizione magnetica 
</ptxt>
</ps>
<action>
<ptxt>
Controllare la frizione magnetica. 
<intxreftitleoff1 refid = "AITAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compressore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il compressore.
</ptxt>
</action>
<ps>
<ptxt>
Aria nell’impianto A/C
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il condensatore ed effettuare le procedure di spurgo e caricamento del refrigerante. 
<intxreftitleoff1 refid = "AITAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Perdita d’aria dall’unità HVAC o dal condotto dell’aria
</ptxt>
</ps>
<action>
<ptxt>
Riparare l&#39;unità HVAC o il condotto dell&#39;aria.
</ptxt>
</action>
<ps>
<ptxt>
Sistema di riscaldamento e ventilazione guasto.
</ptxt>
</ps>
<action>
<ptxt>
Controllare l’unità HVAC.
</ptxt>
</action>
<ps>
<ptxt>
Motorino ventilatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il motorino ventilatore. 
<intxreftitleoff1 refid = "AITAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Eccessiva quantità di olio del compressore nell’impianto A/C
</ptxt>
</ps>
<action>
<ptxt>
Scaricare l’olio del compressore in eccesso dal circuito dell’impianto A/C e dal compressore.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
