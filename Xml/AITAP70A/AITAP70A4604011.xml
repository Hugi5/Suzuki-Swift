<servinfosub id = "AITAP70A4604011002">
<title>
Descrizione del circuito
</title>
<ptxt>
Fare riferimento a &#34;Descrizione del circuito&#34; in 
<intxref refid = "AITAP70A4604010">La spia ESP® non si accende quando l&#39;accensione viene messa in posizione &#34;ON&#34;</intxref>
.
</ptxt>
</servinfosub>
<servinfosub id = "AITAP70A4604011003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604011004">
<testgroup id = "AITAP70A4604011005">
<title>
Controllo connettore centralina ESP®
</title>
<test1>
<ptxt>
Controllare il collegamento al connettore della centralina ESP<sup>®</sup>.
</ptxt>
</test1>
<question>
Il collegamento è buono?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Collegare saldamente il connettore.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604011006">
<title>
Controllo presenza di DTC nel sistema ESP®
</title>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70A4604005">Controllo presenza DTC</intxref>
.
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fare riferimento alla procedura diagnostica relativa al DTC rilevato.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604011007">
<title>
Controllo dei circuiti di alimentazione e di massa della centralina ESP®
</title>
<test1>
<ptxt>
Controllare i circuiti di alimentazione e di massa della centralina ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "AITAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
I circuiti sono integri?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604011008">
<title>
Controllo quadro strumenti
</title>
<test1>
<ptxt>
Sostituire il quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<question>
La spia rimane accesa?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ripetere il controllo funzionale della spia. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
