<servinfosub id = "AITAP70A8204018003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204018004">
<testgroup id = "AITAP70A8204018005">
<question>
È stato eseguito il &#34;Controllo del sistema diagnostico dell&#39;airbag&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204018006">
<title>
Controllo modulo di innesco airbag guidatore 
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i collegamenti al connettore &#34;G347&#34; o &#34;G374&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;G347&#34; o &#34;G374&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Collegare il cablaggio &#34;VOLANTE&#34; (1) degli attrezzi speciali (A) e (B) al connettore &#34;G347&#34; o &#34;G374&#34;.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B008">
<s-part>
(A)
</s-part>
<s-number num = "09932-77320">
09932–77320
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B009">
<s-part>
(B)
</s-part>
<s-number num = "09932-75010">
09932–75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820006.swf" width = "90.000mm" height = "63.681mm" ver = "03" gw = "208" gh = "164"/>
</testfigure>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente il DTC B1031?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204018007">
<title>
Controllo circuito cablaggio cruscotto
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i collegamenti al connettore &#34;G11&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;G11&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare la barra di cortocircuito interna al connettore dell&#39;SDM inserendo l&#39;apposito attrezzo facente parte dell&#39;attrezzo speciale (A).
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza dei circuiti &#34;A1&#34; e &#34;A2&#34;: 1 &#937; o inferiore
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B010">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820007.swf" width = "90.000mm" height = "63.596mm" ver = "01" gw = "200" gh = "164"/>
</testfigure>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la SDM con una nuova. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204018008">
<title>
Controllo circuito bobina di contatto
</title>
<test1>
<ptxt>
Controllare il circuito della bobina di contatto. 
<intxreftitleoff1 refid = "AITAP70A8204053"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Il circuito della bobina di contatto è integro?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il modulo di innesco airbag guidatore. 
<intxreftitleoff1 refid = "AITAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il gruppo bobina di contatto. 
<intxreftitleoff1 refid = "AITAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Se presenti, cancellare gli eventuali DTC facendo riferimento a 
<intxref refid = "AITAP70A8204006">Cancellazione DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ripetere 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per verificare che il guasto sia stato effettivamente eliminato.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
