<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "1">
<servinfo servinfosgmlid = "AITAP70A9601004" svcinfotypenbr = "03" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Descrizione del funzionamento del sistema chiusura centralizzata porte
</title>
<ptxt>
Il bloccaggio / lo sbloccaggio delle porte avviene azionando i particolari riportati nella tabella sottostante.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.883in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.763in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.602in"/>
<colspec colnum = "4" colname = "4" colwidth = "4.965in"/>
<thead>
<row rowsep = "1">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Particolare
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Serratura porta attivata
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry namest = "1" nameend = "3" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Telecomando o trasmettitore
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Premere il pulsante LOCK una volta e tutte le porte si bloccano.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Premere il pulsante UNLOCK una volta e la porta lato guida si sblocca.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Premere il pulsante UNLOCK due volte e tutte le porte si sbloccano.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Interruttore di richiesta su porta
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Operazione
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Blocco
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Premere l&#39;interruttore di richiesta una volta e tutte le porte si bloccano.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "3" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Sblocco
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Premere l&#39;interruttore di richiesta una volta e la porta il cui interruttore è stato premuto si blocca.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Premere l&#39;interruttore di richiesta due volte e tutte le porte si sbloccano.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Interruttore chiusura centralizzata (porta lato guida)
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Tutte le porte
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "3" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Cilindretto serratura
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Girare una volta la chiave nel cilindretto in posizione LOCK e tutte le porte si bloccano.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Girare una volta la chiave nel cilindretto in posizione UNLOCK e la porta lato guida si blocca.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Girare due volte la chiave nel cilindretto in posizione UNLOCK e tutte le porte si sbloccano.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Leva chiusura porta
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Azionata su ciascuna porta
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
