<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70AA316001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione centralina dell’immobilizzatore
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Poiché che la centralina immobilizzatore contiene componenti di precisione, fare attenzione a non esporla ad urti eccessivi.
</ptxt>
</item>
<item>
<ptxt>
Non smontare la centralina immobilizzatore.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AITAP70AA316001001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i coperchi superiore e inferiore del piantone sterzo. 
<intxreftitleoff1 refid = "AITAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Scollegare il connettore (1) dalla centralina immobilizzatore (2).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la vite (3) dalla centralina immobilizzatore.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la centralina immobilizzatore dal gruppo bloccasterzo, come indicato in figura.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA31004.jpg" width = "88.000mm" height = "60.854mm" ver = "01" gw = "197" gh = "156"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA316001002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
