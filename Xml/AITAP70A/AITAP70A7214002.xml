<ptxt>
Entrambi i manometri LO e HI indicano valori bassi.
</ptxt>
<ptxt>
L’aria in uscita è appena appena fresca.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
