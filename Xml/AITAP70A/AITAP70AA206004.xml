<servinfo servinfosgmlid = "AITAP70AA206004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del sensore di temperatura aria esterna
</title>
<servinfosub id = "AITAP70AA206004001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il paraurti anteriore. 
<intxreftitleoff1 refid = "AITAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1) dal sensore di temperatura aria esterna.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il sensore di temperatura aria esterna (2) dalla traversa del paraurti anteriore.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20018.jpg" width = "88.000mm" height = "67.914mm" ver = "01" gw = "210" gh = "176"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA206004002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70AA206005">Ispezione del sensore di temperatura aria esterna</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
