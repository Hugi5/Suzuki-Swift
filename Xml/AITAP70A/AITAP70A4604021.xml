<title>
DTC C1028
</title>
<servinfosub id = "AITAP70A4604021001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.510in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.653in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1028: Tensione circuito sensore di pressione pompa freni
</emph>
</ptxt>
<ptxt>
Il segnale del sensore di pressione pompa freni non è nell&#39;intervallo specificato.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Impianto frenante
</ptxt>
</item>
<item>
<ptxt>
Centralina ESP<sup>®</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70A4604021002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604021003">
<testgroup id = "AITAP70A4604021004">
<question>
È stato eseguito il &#34;Controllo sistema ESP<sup>®</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A4604001">Controllo sistema ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604021005">
<title>
Controllo impianto frenante
</title>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Perdita di liquido freni o aria nell&#39;impianto idraulico dei freni.
</ptxt>
</item>
<item>
<ptxt>
Distanza tra pastiglia dei freni e disco troppo grande. 
</ptxt>
</item>
</list1>
</test1>
<question>
Gli esiti dei controlli sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare, sostituire o regolare l&#39;impianto frenante.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
