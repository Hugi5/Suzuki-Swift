<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1806003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del gruppo bobine d&#39;accensione
</title>
<servinfosub id = "AITAP70A1806003001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo filtro dell’aria. 
<intxreftitleoff1 refid = "AITAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare i connettori delle bobine d&#39;accensione.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i gruppi bobine d’accensione (2) dopo aver tolto i bulloni (1) delle bobine d&#39;accensione.
</ptxt>
<figure>
<graphic graphicname = "I7V20A180004.swf" width = "88.000mm" height = "54.310mm" ver = "01" gw = "212" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1806003002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1806004">Ispezione del gruppo bobine d’accensione</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare il bullone della bobina d&#39;accensione alla coppia specificata.
</ptxt>
<torque>
<torqueitem id = "T1H002">
<t-part>
Bullone della bobina d&#39;accensione
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
