<servinfosub id = "AITAP70AA204014003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA204014004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA204014005">
<testgroup id = "AITAP70AA204014006">
<title>
Controllo presenza DTC
</title>
<question>
Viene anche rilevato il DTC B1132?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204014009">
<title>
Controllo parametri
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il parametro &#34;Temperatura aria esterna&#34; visualizzato sullo strumento di diagnosi SUZUKI. 
<intxreftitleoff1 refid = "AITAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204014007">
<title>
Controllo circuito sensore di temperatura aria esterna
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il sensore di sensore di temperatura aria esterna e i seguenti connettori.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modello con commutatore di accensione: Connettore &#34;E04&#34;
</ptxt>
</item>
<item>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: Connettore &#34;E05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Controllare che il collegamento al sensore di temperatura aria esterna e ai seguenti connettori sia corretto.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modello con commutatore di accensione: Connettore &#34;E04&#34;
</ptxt>
</item>
<item>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: Connettore &#34;E05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza dei circuiti &#34;A1&#34; e &#34;A2&#34;: meno di 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il circuito &#34;A1&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra i terminali dei circuiti &#34;A1&#34; e &#34;A2&#34; del connettore del sensore della temperatura dell&#39;aria esterna: infinita
</ptxt>
</item>
<item>
<ptxt>
tensione dei circuiti &#34;A1&#34; e &#34;A2&#34;: 0 – 1 V (con accensione su &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204014008">
<title>
Controllo sensore di temperatura aria esterna
</title>
<test1>
<ptxt>
Controllare il sensore di temperatura aria esterna. 
<intxreftitleoff1 refid = "AITAP70AA206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il sensore di temperatura aria esterna. 
<intxreftitleoff1 refid = "AITAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204014010">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Collegare il sensore di sensore di temperatura aria esterna e i seguenti connettori.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modello con commutatore di accensione: Connettore &#34;E04&#34;
</ptxt>
</item>
<item>
<ptxt>
Modello con sistema di avviamento motore a pulsante senza chiave: Connettore &#34;E05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente il DTC B1141 o B1142?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la BCM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
