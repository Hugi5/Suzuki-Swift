<servinfosub id = "AITAP70AA204017003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA204017004">
<testgroup id = "AITAP70AA204017005">
<title>
Ricontrollo presenza di DTC
</title>
<test1>
<ptxt>
Cancellare il DTC. 
<intxreftitleoff1 refid = "AITAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70AA204017002">Procedura di conferma DTC</intxref>
 e ricontrollare la presenza di DTC.
</ptxt>
</test1>
<question>
È ancora presente il DTC B1157?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (L&#39;airbag è già esploso in passato. (DTC non cancellato))
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204017006">
<title>
Ricontrollo presenza di DTC
</title>
<test1>
<ptxt>
Sostituire il modulo SDM. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70AA204017002">Procedura di conferma DTC</intxref>
 e ricontrollare la presenza di DTC.
</ptxt>
</test1>
<question>
È ancora presente il DTC B1157?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la BCM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (La SDM era difettosa)
</ptxt>
</action>
</testgroup>
</diag>
