</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<figure>
<graphic graphicname = "IAP70A520025.swf" width = "88.000mm" height = "102.012mm" ver = "01" gw = "134" gh = "272"/>
<callout>
