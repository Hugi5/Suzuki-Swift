<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A3126003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione gruppo semiasse posteriore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A3126001">Componenti semiasse posteriore:Posteriore</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AITAP70A3126002">Ispezione del gruppo semiasse posteriore a bordo del veicolo:Posteriore</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A3126003001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Sollevare il veicolo da terra e rimuovere la ruota posteriore. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Togliere la ribaditura (1) e rimuovere il dado del semiasse (2) con il pedale del freno premuto.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312002.swf" width = "88.000mm" height = "53.091mm" ver = "01" gw = "177" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo semiasse posteriore dopo aver tolto i dadi della flangia (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A312003.swf" width = "88.000mm" height = "47.465mm" ver = "01" gw = "177" gh = "118"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A3126003002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare il nuovo dado del semiasse (1) alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T3A202">
<t-part>
Dado semiasse
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Ribadire il dado del semiasse (1) come mostrato in figura.
</ptxt>
<attention2>
<ptxt>
Durante la ribaditura, fare attenzione a non incrinare questa zona (2) del dado del semiasse. Se si incrinasse, sostituire con una parte nuova.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A312004.swf" width = "88.000mm" height = "52.301mm" ver = "01" gw = "159" gh = "132"/>
</figure>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Serrare i dadi della flangia semiasse posteriore alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T3A203">
<t-part>
Dado flangia semiasse posteriore
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A312005.swf" width = "88.000mm" height = "49.964mm" ver = "01" gw = "177" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Applicare il grasso sulla superficie di accoppiamento del gruppo mozzo e del semiasse della ruota posteriore.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A202" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasso
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A312006.swf" width = "88.000mm" height = "54.175mm" ver = "02" gw = "227" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Serrare i dadi della ruota alla coppia indicata. 
<intxreftitleoff1 refid = "AITAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
