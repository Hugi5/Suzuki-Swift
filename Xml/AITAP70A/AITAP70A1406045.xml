<servinfo servinfosgmlid = "AITAP70A1406045" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Ispezione volano
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1406021">Rimozione e installazione del volano</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A1406045001">
<title>
Ispezione visiva
</title>
<list1 type = "unordered">
<item>
<ptxt>
Se la corona dentata è danneggiata, incrinata o usurata, sostituire il volano.
</ptxt>
</item>
<item>
<ptxt>
Se la superficie a contatto con il disco della frizione è danneggiata o usurata eccessivamente, sostituire il volano.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "AITAP70A1406045002">
<title>
Eccentricità faccia volano
</title>
<ptxt>
Controllare l’eccentricità della faccia del volano con un comparatore. 
</ptxt>
<ptxt>
Se l’eccentricità supera il limite, sostituire il volano.
</ptxt>
<spec>
<title>
Eccentricità della faccia del volano / disco conduttore
</title>
<ptxt>
Limite: 0,2 mm (0,0079 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I2RH01140198.swf" width = "88.000mm" height = "42.110mm" ver = "01" gw = "183" gh = "102"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
