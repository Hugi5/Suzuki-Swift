<servinfo servinfosgmlid = "AITAP70A9206012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della luce del bagagliaio
</title>
<servinfosub id = "AITAP70A9206012001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere la luce del bagagliaio (1) tirandola nella direzione del freccia, sganciando il fermo (2).
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore dalla luce del bagagliaio.
</ptxt>
</s1>
<s1>
<ptxt>
Eventualmente, rimuovere la lampadina (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A920016.jpg" width = "88.000mm" height = "62.981mm" ver = "04" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9206012002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
