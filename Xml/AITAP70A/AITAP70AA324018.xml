<servinfosub id = "AITAP70AA324018003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Tenere il motore al regime del minimo per almeno 10 secondi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA324018004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA324018005">
<testgroup id = "AITAP70AA324018006">
<title>
Controllo circuito segnale interruttore motore
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare i connettori &#34;G140&#34; e &#34;G28&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare l&#39;integrità dei collegamenti dei terminali ai connettori &#34;G140&#34; e &#34;G28&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza dei circuiti &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34; e &#34;A4&#34;: meno di 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
resistenza tra ciascun circuito &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34; e &#34;A4&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il terminale del circuito &#34;A1&#34; e gli altri terminali del connettore &#34;G140&#34;: infinita
</ptxt>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA324018007">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Sostituire l’interruttore motore. 
<intxreftitleoff1 refid = "AITAP70AA506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70AA324018003">Procedura di conferma DTC</intxref>
 e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC B1189?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina sistema di avviamento senza chiave e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (l&#39;interruttore motore era difettoso)
</ptxt>
</action>
</testgroup>
</diag>
