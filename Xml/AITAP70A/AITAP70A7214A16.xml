<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A7214A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Quando il compressore è in funzione, si sente una certa vibrazione.
</title>
<servinfosub id = "AITAP70A7214004003">
<title>
Rumori anomali generati dalla frizione magnetica
</title>
<diag type = "condition">
<condition>
<ptxt>
Quando il compressore è in funzione, si sente una certa vibrazione.
</ptxt>
</condition>
<ps>
<ptxt>
Gioco della frizione magnetica inadeguato (eccessivo)
</ptxt>
</ps>
<action>
<ptxt>
Registrare il gioco della frizione magnetica. 
<intxreftitleoff1 refid = "AITAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Superficie d&#39;attrito della frizione magnetica usurata
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo frizione magnetica. 
<intxreftitleoff1 refid = "AITAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Superficie d&#39;attrito contaminata da olio del compressore trafilato dalla tenuta dell&#39;albero
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo corpo compressore. 
<intxreftitleoff1 refid = "AITAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
