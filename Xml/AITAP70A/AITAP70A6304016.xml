<servinfosub id = "AITAP70A6304016002">
<title>
Procedura di conferma DTC
</title>
<topic id = "AITAP70A6304016003">
<title>
DTC C1161
</title>
<list1 type = "unordered">
<item>
<ptxt>
Fare riferimento alla Procedura di conferma del DTC P0500 Sensore &#34;A&#34; velocità veicolo. 
<intxreftitleoff1 refid = "AITAP70A1104039"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</topic>
<topic id = "AITAP70A6304016004">
<title>
DTC C1162
</title>
<list1 type = "unordered">
<item>
<ptxt>
Fare riferimento alla Procedura di conferma del DTC P0335 Sensore &#34;A&#34; di posizione dell&#39;albero motore. 
<intxreftitleoff1 refid = "AITAP70A1104033"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</topic>
</servinfosub>
<servinfosub id = "AITAP70A6304016005">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A6304016006">
<testgroup id = "AITAP70A6304016007">
<question>
È stato eseguito il &#34;Controllo del sistema P/S&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A6304001">Controllo del sistema P/S</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304016008">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
 Controllare se nella memoria dell&#39;ECM sono presenti DTC. 
<intxreftitleoff1 refid = "AITAP70A6304003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente. (relativo all&#39;ECM) 
<intxreftitleoff1 refid = "AITAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire la centralina P/S e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
