<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A7226024" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;attuatore sistema di controllo temperatura
</title>
<servinfosub id = "AITAP70A7226024001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Disabilitare il sistema airbag. 
<intxreftitleoff1 refid = "AITAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il coperchio del foro del piantone. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il modulo di innesco airbag ginocchia. 
<intxreftitleoff1 refid = "AITAP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;attuatore sistema di controllo temperatura (2) dopo aver tolto le viti (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A722007.jpg" width = "88.000mm" height = "63.150mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7226024002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A7226025">Ispezione dell&#39;attuatore sistema di controllo temperatura:Tipo automatico</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Inserire la spina delle leva attuatore sistema di controllo temperatura (1) nella scanalatura (2) della leveraggio.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722008.swf" width = "88.000mm" height = "63.358mm" ver = "01" gw = "141" gh = "163"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
