<servinfosub id = "AITAP70A7214004007">
<title>
Rumori anomali generati dal gruppo condensatore
</title>
<diag type = "condition">
<condition>
<ptxt>
Il gruppo condensatore vibra notevolmente
</ptxt>
</condition>
<ps>
