<servinfosub id = "AITAP70A8204042003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A8204042004">
<testgroup id = "AITAP70A8204042005">
<question>
È stato eseguito il &#34;Controllo del sistema diagnostico dell&#39;airbag&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204042006">
<title>
Controllo interruttore di disattivazione airbag passeggero
</title>
<test1>
<ptxt>
Rimuovere l&#39;interruttore di disattivazione airbag passeggero.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i collegamenti al connettore &#34;G168&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ispezionare l&#39;interruttore di disattivazione airbag passeggero. 
<intxreftitleoff1 refid = "AITAP70A8206027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L&#39;interruttore di disattivazione airbag passeggero è integro?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire l&#39;interruttore di disattivazione airbag passeggero.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204042007">
<title>
Controllo circuito interruttore di disattivazione airbag passeggero
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare il connettore &#34;G11&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il collegamento ai terminali &#34;G11-16&#34; e &#34;G11-17&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la resistenza tra i terminali &#34;G11-16&#34; e &#34;G168-1&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la resistenza tra i terminali &#34;G11-17&#34; e &#34;G168-2&#34;.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B078">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820029.swf" width = "90.000mm" height = "56.862mm" ver = "01" gw = "217" gh = "145"/>
</testfigure>
</test1>
<question>
Il valore della resistenza misurata è pari o inferiore a 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A8204042008">
<title>
Controllo circuito interruttore di disattivazione airbag passeggero
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare quanto segue:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
tensione tra ciascuno dei terminali &#34;G11-16&#34; e &#34;G11-17&#34; e la massa: circa 0 V
</ptxt>
<servicetool>
<servicetoolitem id = "L8B079">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820056.swf" width = "90.000mm" height = "55.764mm" ver = "01" gw = "203" gh = "142"/>
</testfigure>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la SDM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il cablaggio del cruscotto.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Al termine dell&#39;ispezione e dell&#39;intervento, eseguire le operazioni descritte di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ricollegare tutti i componenti del sistema airbag e verificarne la corretta installazione.
</ptxt>
</item>
<item>
<ptxt>
Se presenti, cancellare gli eventuali DTC facendo riferimento a 
<intxref refid = "AITAP70A8204006">Cancellazione DTC</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Ripetere 
<intxref refid = "AITAP70A8204001">Controllo del sistema diagnostico dell&#39;airbag</intxref>
 per verificare che il guasto sia stato effettivamente eliminato.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
