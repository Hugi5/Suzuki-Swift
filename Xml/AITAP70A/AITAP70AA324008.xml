<diag type = "test" id = "AITAP70AA324008003">
<testgroup id = "AITAP70AA324008004">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC P1622?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
