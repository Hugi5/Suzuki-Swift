<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70AA504012" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1123
</title>
<servinfosub id = "AITAP70AA504012001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.461in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.744in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1123: Malfunzionamento circuito di alimentazione permanente
</emph>
</ptxt>
<ptxt>
La tensione del circuito di alimentazione permanente proveniente dal fusibile &#34;DOME&#34; rimane costantemente inferiore al valore specificato.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Fusibile &#34;DOME&#34;
</ptxt>
</item>
<item>
<ptxt>
Ciascun sistema collegato attraverso il fusibile &#34;DOME&#34;
</ptxt>
</item>
<item>
<ptxt>
Centralina sistema di avviamento senza chiave
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70AA504012002">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA504012003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA504012004">
<testgroup id = "AITAP70AA504012005">
<title>
Controllo fusibili
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il fusibile &#34;DOME&#34;.
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la centralina sistema di avviamento senza chiave e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il fusibile &#34;DOME&#34; e andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA504012006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC B1123?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA504012007">
<title>
Ciascun controllo sistema collegato attraverso il fusibile &#34;DOME&#34;
</title>
<test1>
<ptxt>
Controllare ciascun sistema collegato attraverso il fusibile &#34;DOME&#34;, ad eccezione della centralina sistema di avviamento senza chiave.
</ptxt>
</test1>
<question>
L&#39;esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il fusibile &#34;DOME&#34; e sostituire la centralina sistema di avviamento senza chiave, quindi ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il componente guasto e/o il cablaggio, quindi sostituire il fusibile &#34;DOME&#34; e ricontrollare la presenza di DTC.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
