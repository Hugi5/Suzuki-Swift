<servinfosub id = "AITAP70A4604017003">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A4604017004">
<testgroup id = "AITAP70A4604017005">
<question>
È stato eseguito il &#34;Controllo sistema ESP<sup>®</sup>&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A4604001">Controllo sistema ESP®</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604017006">
<title>
Controllo presenza DTC nel sistema ESP®
</title>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70A4604005">Controllo presenza DTC</intxref>
.
</ptxt>
</test1>
<question>
Sono presenti il DTC U0073 e/o il DTC U0100?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fare riferimento alla procedura diagnostica relativa al DTC rilevato.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A4604017007">
<title>
Controllo interruttore e circuito luci stop
</title>
<test1>
<ptxt>
Controllare l&#39;Interruttore luci stop e i relativi circuiti facendo riferimento ai passi da 2 a 4 in 
<intxref refid = "AITAP70A1104040">DTC P0504</intxref>
 .
</ptxt>
</test1>
<question>
Gli esiti dei controlli sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup> e ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire.
</ptxt>
</action>
</testgroup>
