<diag type = "test" id = "AITAP70A6304021002">
<testgroup id = "AITAP70A6304021003">
<title>
Controllo fusibile di protezione circuito
</title>
<test1>
<ptxt>
Verificare che l&#39;accensione sia in posizione &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Scollegare i connettori &#34;E13&#34; e &#34;G50&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare l&#39;integrità dei collegamenti dei terminali ai connettori &#34;G50&#34; e &#34;E13&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono OK, controllare se il fusibile &#34;P/S&#34; e il fusibile &#34;IG1 SIG&#34; sono integri.
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il fusibile (o i fusibili) e controllare la presenza di corto a massa nei circuiti ad esso (o ad essi) collegati.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304021004">
<title>
Controllo alimentazione principale per circuito centralina P/S
</title>
<test1>
<ptxt>
Misurare la tensione tra il terminale &#34;E13-1&#34; e la massa.
</ptxt>
</test1>
<question>
Il valore della tensione è tra 10 e 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Il circuito &#34;A1&#34; è aperto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304021005">
<title>
Controllo circuito di alimentazione IG1 per centralina P/S
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Misurare la tensione tra il terminale &#34;G50-3&#34; e la massa.
</ptxt>
</test1>
<question>
Il valore della tensione è tra 10 e 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Il circuito &#34;A2&#34; è aperto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A6304021006">
<title>
Controllo massa per circuito centralina P/S
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare la resistenza tra il terminale &#34;E13-2&#34; e la massa.
</ptxt>
</test1>
<question>
Il valore della resistenza è pari o inferiore a 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Il circuito &#34;A3&#34; è aperto oppure la sua resistenza è troppo alta.
</ptxt>
</action>
</testgroup>
