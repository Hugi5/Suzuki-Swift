<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A5306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della pompa della frizione
</title>
<servinfosub id = "AITAP70A5306011001">
<title>
Rimozione
</title>
<s1 page = "2">
<ptxt>
Pulire intorno al tappo del serbatoio della pompa freni ed estrarre il liquido con una siringa o qualcosa di analogo.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Staccare il tubo del liquido della frizione dalla pompa della frizione. 
<intxreftitleoff1 refid = "AITAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Scollegare il tubo flessibile (1) del serbatoio della frizione.
</ptxt>
<figure>
<graphic graphicname = "IAP70A530007.swf" width = "88.000mm" height = "49.059mm" ver = "01" gw = "141" gh = "123"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Rimuovere l&#39;asta di spinta (1) dal pedale della frizione (2).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la pompa della frizione (4), dopo aver tolto i dadi (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530008.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A5306011002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A5306012">Ispezione della pompa della frizione</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Applicare il grasso sulla punta dell&#39;asta di spinta.
</ptxt>
<materials>
<materialitem name = "SUZUKI Silicone Grease" id = "M5C001" uid = "21">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasso
</m-desc>
<m-number>
99000–25100
</m-number>
<m-name>
SUZUKI Silicone Grease
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Serrare i dadi (1) della pompa della frizione alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T5C004">
<t-part>
Dado della pompa della frizione
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A531013.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
