<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A6104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Sbandamento in frenata
</title>
<diag type = "condition">
<condition>
<ptxt>
Sbandamento in frenata
</ptxt>
</condition>
<ps>
<ptxt>
Cuscinetto(i) ruota usurato(i)
</ptxt>
</ps>
<action>
<ptxt>
Sostituire i cuscinetti delle ruote. 
<intxreftitleoff1 refid = "AITAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Molla elicoidale rotta o insaccata
</ptxt>
</ps>
<action>
<ptxt>
Sostituire la molla elicoidale. 
<intxreftitleoff1 refid = "AITAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo ammortizzatore anteriore difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo ammortizzatore anteriore. 
<intxreftitleoff1 refid = "AITAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pressione dei pneumatici non uniforme
</ptxt>
</ps>
<action>
<ptxt>
Regolare la pressione dei pneumatici. 
</ptxt>
</action>
<ps>
<ptxt>
Assetto ruote anteriori non corretto
</ptxt>
</ps>
<action>
<ptxt>
Controllare e regolare l&#39;assetto delle ruote anteriori. 
<intxreftitleoff1 refid = "AITAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Azione frenante non uniforme
</ptxt>
</ps>
<action>
<ptxt>
Controllare e riparare l&#39;impianto frenante. 
<intxreftitleoff1 refid = "AITAP70A4101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disco del freno anteriore sporco di liquido freni
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire il disco del freno anteriore. 
<intxreftitleoff1 refid = "AITAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disco secondo deformato
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il disco del freno anteriore. 
<intxreftitleoff1 refid = "AITAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pastiglia dei freni fortemente usurata
</ptxt>
</ps>
<action>
<ptxt>
Sostituire la pastiglia dei freni anteriori. 
<intxreftitleoff1 refid = "AITAP70A4206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
