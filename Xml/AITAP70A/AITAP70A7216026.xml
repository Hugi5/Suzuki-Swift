<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A7216026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;attuatore controllo presa aria
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A7216020">Componenti della centralina HVAC:Tipo manuale</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A7216026001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il cassetto portaoggetti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il condotto aria diretta ai piedi lato passeggero. 
<intxreftitleoff1 refid = "AITAP70A7216011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore dell’attuatore controllo presa aria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere le viti (1).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;attuatore controllo presa aria (2) dall&#39;unità HVAC.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721028.jpg" width = "88.000mm" height = "68.236mm" ver = "01" gw = "142" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A7216026002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A7216027">Ispezione dell&#39;attuatore controllo presa aria:Tipo manuale</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Inserire il perno di articolazione (1) nella scanalatura (2) dell&#39;attuatore controllo presa aria.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721029.swf" width = "88.000mm" height = "49.668mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
