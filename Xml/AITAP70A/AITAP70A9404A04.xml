<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A9404A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Lavalunotto malfunzionante
</title>
<servinfosub id = "AITAP70A9404002003">
<title>
Tergi/lavalunotto
</title>
<diag type = "condition">
<condition>
<ptxt>
Lavalunotto malfunzionante
</ptxt>
</condition>
<ps>
<ptxt>
Tubo flessibile lavacristallo (compresa la valvola di ritegno e il connettore) o ugello malfunzionante
</ptxt>
</ps>
<action>
<ptxt>
Controllare se il tubo flessibile o l&#39;ugello del lavacristallo sono intasati e piegati.
</ptxt>
</action>
<ps>
<ptxt>
Pompa lavalunotto malfunzionante
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A9406002">Ispezione della pompa lavacristallo</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Interruttore tergi/lavalunotto malfunzionante (interruttore lavaggio)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AITAP70A9406008">Ispezione dell&#39;interruttore tergi/lavacristallo</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio o collegamento a massa difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare il cablaggio.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
