<servinfo servinfosgmlid = "AITAP70A5204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Le marce si disinnestano
</title>
<diag type = "condition">
<condition>
<ptxt>
Le marce si disinnestano
</ptxt>
</condition>
<ps>
<ptxt>
Usura dell’albero forcella di selezione
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire l&#39;albero o la forcella di selezione
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Albero di selezione marce basse: 
<intxreftitleoff1 refid = "AITAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Albero di selezione marce alte: 
<intxreftitleoff1 refid = "AITAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Forcella di selezione 5ª 
<intxreftitleoff1 refid = "AITAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Usura della forcella di selezione o del manicotto sincronizzatore
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire la forcella di selezione, l&#39;albero di selezione oppure il gruppo manicotto e mozzo sincronizzatore.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Albero di selezione marce basse: 
<intxreftitleoff1 refid = "AITAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Albero di selezione marce alte: 
<intxreftitleoff1 refid = "AITAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Forcella di selezione 5ª 
<intxreftitleoff1 refid = "AITAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manicotto e mozzo sincronizzatore marce basse: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manicotto e mozzo sincronizzatore marce alte: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manicotto e mozzo sincronizzatore 5ª velocità: 
<intxreftitleoff1 refid = "AITAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Molle di centraggio snervate o danneggiate
</ptxt>
</ps>
<action>
<ptxt>
Sostituire la molla di centraggio. 
<intxreftitleoff1 refid = "AITAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Usura dei cuscinetti dell&#39;albero primario o secondario
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire il cuscinetto dell&#39;albero primario o il cuscinetto dell&#39;albero secondario.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Cuscinetto lato sinistro albero secondario:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Pista interna: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pista esterna: 
<intxreftitleoff1 refid = "AITAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Cuscinetto lato destro albero secondario:
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Pista interna: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pista esterna: 
<intxreftitleoff1 refid = "AITAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Cuscinetti sinistro e destro dell&#39;albero primario: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Usura del dente smussato di manicotto e ingranaggio
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire il gruppo manicotto e mozzo del sincronizzatore unitamente all&#39;ingranaggio.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Ingranaggi 1ª e 2ª dell&#39;albero secondario: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ingranaggi 3ª e 4ª dell&#39;albero primario: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ingranaggio 5ª marcia albero primario: 
<intxreftitleoff1 refid = "AITAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manicotto e mozzo sincronizzatore marce basse: 
<intxreftitleoff1 refid = "AITAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manicotto e mozzo sincronizzatore marce alte: 
<intxreftitleoff1 refid = "AITAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manicotto e mozzo sincronizzatore 5ª velocità: 
<intxreftitleoff1 refid = "AITAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
