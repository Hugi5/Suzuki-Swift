<servinfo servinfosgmlid = "AITAP70A5306001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;interruttore CPP 1 (se in dotazione)
</title>
<servinfosub id = "AITAP70A5306001001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Con l&#39;accensione in posizione &#34;OFF&#34;, scollegare il connettore dell&#39;interruttore CPP 1 (1).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l’interruttore CPP 1 (1) dalla staffa del pedale della frizione.
</ptxt>
<figure>
<graphic graphicname = "I9P60A531003.swf" width = "88.000mm" height = "79.324mm" ver = "01" gw = "104" gh = "208"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A5306001002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A5306002">Ispezione e regolazione dell&#39;interruttore CPP 1 (se in dotazione)</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Installare l’interruttore CPP 1 sulla staffa del pedale della frizione.
</ptxt>
</s1>
<s1>
<ptxt>
Regolare la posizione dell&#39;interruttore. 
<intxreftitleoff1 refid = "AITAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Collegare saldamente il connettore all’interruttore CPP 1.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
