<servinfosub id = "AITAP70A9806010002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare i bulloni di montaggio di ciascun sedile alla coppia indicata.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Sedile anteriore: 
<intxreftitleoff1 refid = "AITAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Sedile posteriore: 
<intxreftitleoff1 refid = "AITAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</servinfosub>
