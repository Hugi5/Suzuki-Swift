<servinfosub id = "AITAP70A1104019003">
<title>
Procedura di conferma DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Eseguire innanzitutto la ricerca guasti dei DTC inattesi, rilevati in precedenza nella &#34;Procedura di conferma DTC&#34;.
</ptxt>
</item>
<item>
<ptxt>
Verificare che la &#34;Procedura di conferma DTC&#34; venga effettuata in presenza della condizione indicata di seguito.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Non vengono rilevati i DTC P0107, P0108, P2119, P2135, P2138, P2228, P2229.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Tenere il motore al regime minimo per 30 secondi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1104019004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A1104019005">
<testgroup id = "AITAP70A1104019006">
<question>
È stata eseguita la procedura &#34;Verifica del sistema di controllo del motore e delle emissioni&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1104001">Verifica del sistema di controllo del motore e delle emissioni</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104019007">
<title>
Controllo impianto d&#39;aspirazione
</title>
<test1>
<ptxt>
Controllare se l&#39;impianto di aspirazione è intasato o presenta perdite.
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire l’impianto d’aspirazione.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104019008">
<title>
Controllo circuito sensore MAP
</title>
<test1>
<ptxt>
Controllare i circuiti del sensore MAP secondo quanto descritti nei passi da 2 a 4 in 
<intxref refid = "AITAP70A1104020">DTC P0107 / P0108</intxref>
 .
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104019009">
<title>
Controllo sensore MAP
</title>
<test1>
<ptxt>
Controllare il sensore MAP. 
<intxreftitleoff1 refid = "AITAP70A1306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il sensore MAP.
</ptxt>
</action>
</testgroup>
</diag>
