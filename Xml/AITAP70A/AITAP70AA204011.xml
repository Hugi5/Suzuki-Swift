<servinfosub id = "AITAP70AA204011003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA204011004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA204011005">
<testgroup id = "AITAP70AA204011009">
<title>
Controllo parametri
</title>
<test1>
<ptxt>
Collegare lo strumento di diagnosi SUZUKI alla DLC quando l&#39;accensione è su &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare i parametri &#34;Tensione batteria&#34;, &#34;Commutatore di accensione 1&#34; e &#34;Interruttore ACC&#34; visualizzati sullo strumento di diagnosi SUZUKI. 
<intxreftitleoff1 refid = "AITAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fine (Guasto intermittente)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204011006">
<title>
Controllo fusibile di protezione circuito
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34;, quindi staccare il fusibile &#34;DOME&#34; e il fusibile &#34;HAZ&#34; dalla J/B.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare il fusibile &#34;DOME&#34; e il fusibile &#34;HAZ&#34;.
</ptxt>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire i fusibili del circuito.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204011007">
<title>
Controllo del circuito di alimentazione permanente della BCM
</title>
<test1>
<ptxt>
Scollegare i connettori &#34;E323&#34; e &#34;E324&#34; dalla scatola di derivazione.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare l&#39;integrità dei collegamenti dei terminali ai connettori &#34;E323&#34; e &#34;E324&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
tensione tra il circuito &#34;A1&#34; e la massa: Tensione batteria
</ptxt>
</item>
<item>
<ptxt>
tensione tra il circuito &#34;A2&#34; e la massa: Tensione batteria
</ptxt>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controllare se il filo &#34;WHT/BLK&#34; o &#34;WHT&#34; è aperto o in corto.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA204011008">
<title>
Controllo circuito di alimentazione permanente della BCM
</title>
<test1>
<ptxt>
Scollegare il connettore &#34;E04&#34; dalla BCM.
</ptxt>
</test1>
<test1>
<ptxt>
Verificare che il collegamento al connettore &#34;E04&#34; sia corretto.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
tensione tra il circuito &#34;A3&#34; e la massa: Tensione batteria
</ptxt>
</item>
<item>
<ptxt>
tensione tra il circuito &#34;A4&#34; e la massa: Tensione batteria
</ptxt>
</item>
</list1>
</test1>
<question>
Sono OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la BCM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controllare se i fili &#34;BRN&#34; e/o &#34;BLK/RED&#34; sono aperti o in corto a massa.
</ptxt>
</action>
</testgroup>
</diag>
