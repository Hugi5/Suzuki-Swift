<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70AA206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione BCM
</title>
<servinfosub id = "AITAP70AA206003001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Disabilitare il sistema airbag. 
<intxreftitleoff1 refid = "AITAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il coperchio del foro sul piantone dello sterzo, facendo riferimento al passo 4) di 
<intxref refid = "AITAP70A6206009">Rimozione e installazione del piantone dello sterzo</intxref>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la finitura laterale della plancia. 
<intxreftitleoff1 refid = "AITAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare i connettori (1) e le fascette dalla J/B (2).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i dadi (3), quindi staccare la J/B.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20016.jpg" width = "88.000mm" height = "78.207mm" ver = "01" gw = "202" gh = "205"/>
</figure>
</s1>
<s1>
<ptxt>
Scollegare i connettori (1) dalla BCM (2).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i dadi (3) della BCM, quindi staccare la BCM.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20017.jpg" width = "88.000mm" height = "82.962mm" ver = "01" gw = "198" gh = "219"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70AA206003002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.	
</ptxt>
</servinfosub>
<list1 type = "unordered">
<item>
<ptxt>
Serrare i dadi della BCM alla coppia specificata.
</ptxt>
<torque>
<torqueitem id = "T10B001">
<t-part>
Dado della BCM
</t-part>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Abilitare il sistema airbag. 
<intxreftitleoff1 refid = "AITAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
In caso di sostituzione della BCM, eseguire quanto riportato in 
<intxref refid = "AITAP70AA206002">Registrazione della BCM (modello con commutatore di accensione)</intxref>
 .
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
