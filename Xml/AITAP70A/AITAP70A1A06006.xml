<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1A06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della staffa dell&#39;alternatore
</title>
<servinfosub id = "AITAP70A1A06006001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il riparo sotto al motore lato destro.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la cinghia di comando pompa dell&#39;acqua/alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la puleggia (1) della pompa dell&#39;acqua. 
<intxreftitleoff1 refid = "AITAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il bullone (2) dell&#39;alternatore.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la staffa dell&#39;alternatore (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1007.jpg" width = "88.000mm" height = "70.982mm" ver = "01" gw = "192" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1A06006002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Installare la staffa dell&#39;alternatore secondo la procedura che segue.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Posizionare la staffa (1) dell&#39;alternatore.
</ptxt>
</item>
<item>
<ptxt>
Serrare senza stringere il bullone (2) dell&#39;alternatore.
</ptxt>
</item>
<item>
<ptxt>
Serrare i dadi della staffa alternatore (3) alla coppia indicata. 
<intxreftitleoff1 refid = "AITAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
<figure>
<graphic graphicname = "I9P60A1A1016.swf" width = "88.000mm" height = "68.664mm" ver = "01" gw = "188" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
