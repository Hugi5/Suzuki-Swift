<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A6104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Sterzo duro
</title>
<diag type = "condition">
<condition>
<ptxt>
Sterzo duro
</ptxt>
</condition>
<ps>
<ptxt>
Pressione insufficiente dei pneumatici
</ptxt>
</ps>
<action>
<ptxt>
Regolare la pressione dei pneumatici.
</ptxt>
</action>
<ps>
<ptxt>
Malfunzionamento dell&#39;impianto servosterzo
</ptxt>
</ps>
<action>
<ptxt>
Controllare e riparare. 
<intxreftitleoff1 refid = "AITAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Grippaggio del giunto sferico dello snodo del tirante
</ptxt>
</ps>
<action>
<ptxt>
Sostituire lo snodo del tirante. 
<intxreftitleoff1 refid = "AITAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Grippaggio del giunto sferico del braccio delle sospensioni
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il braccio delle sospensioni. 
<intxreftitleoff1 refid = "AITAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Assetto ruote anteriori non corretto
</ptxt>
</ps>
<action>
<ptxt>
Controllare e regolare l&#39;assetto delle ruote anteriori. 
<intxreftitleoff1 refid = "AITAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Grippaggio del piantone dello sterzo
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il piantone dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Contatto denti non corretto tra corona e pignone
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare la coppia rotante dell’albero portapignone e corona. 
<intxreftitleoff1 refid = "AITAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
In caso di difetti, sostituire il gruppo scatola guida. 
<intxreftitleoff1 refid = "AITAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
