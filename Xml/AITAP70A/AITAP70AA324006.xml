<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70AA324006" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1610
</title>
<servinfosub id = "AITAP70AA324006001">
<title>
Condizioni che generano il DTC e possibili aree di guasto
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.281in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.924in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condizioni che generano il DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Possibili aree di guasto
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1610: Codice ID immobilizzatore non registrato
</emph>
</ptxt>
<ptxt>
Il codice di identificazione dell&#39;immobilizzatore non è stato registrato.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Il codice ID della ECM non è registrato nella centralina sistema di avviamento senza chiave.
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Circuito / connettore comunicazione CAN
</ptxt>
</item>
<item>
<ptxt>
Centralina collegata tramite la linea di comunicazione CAN
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AITAP70AA324006002">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70AA324006003">
<testgroup id = "AITAP70AA324006005">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare la presenza di DTC nella centralina sistema di avviamento senza chiave. 
<intxreftitleoff1 refid = "AITAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È presente il B1173, B1175 o B1176?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA324006004">
<title>
Registrazione della ECM
</title>
<test1>
<ptxt>
Eseguire 
<intxref refid = "AITAP70AA326003">Registrazione della ECM:Modello con sistema di avviamento motore a pulsante senza chiave</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Ricontrollare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
È ancora presente il DTC P1610?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine (l&#39;ECM non era stata registrata)
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA324006006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare il DTC relativo alla comunicazione CAN.
</ptxt>
</test1>
<question>
Sono presenti DTC relativi alla rete CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
