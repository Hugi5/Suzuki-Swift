<servinfosub id = "AITAP70A1104020003">
<title>
Procedura di conferma DTC
</title>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34; per 10 secondi.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1104020004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A1104020005">
<testgroup id = "AITAP70A1104020006">
<question>
È stata eseguita la procedura &#34;Verifica del sistema di controllo del motore e delle emissioni&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1104001">Verifica del sistema di controllo del motore e delle emissioni</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104020007">
<title>
Controllo circuito di alimentazione sensore MAP
</title>
<test1>
<ptxt>
Con accensione in posizione &#34;OFF&#34;, staccare il connettore dal sensore MAP.
</ptxt>
</test1>
<test1>
<ptxt>
Verificare che il collegamento al connettore del sensore MAP sia corretto.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono OK, portare l&#39;accensione in posizione &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare che la tensione tra &#34;A1&#34; e &#34;A3&#34; sia di circa 5 V.
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104020008">
<title>
Controllo circuito di massa sensore MAP
</title>
<test1>
<ptxt>
Controllare che la tensione tra &#34;A1&#34; e la massa sia di circa 5 V.
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Riparare il circuito &#34;A3&#34;.
</ptxt>
<ptxt>
Se viene rilevato nuovamente questo DTC, sostituire la ECM e ripetere il controllo presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare il circuito &#34;A1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104020009">
<title>
Controllo circuito segnale del sensore MAP
</title>
<test1>
<ptxt>
Con accensione su OFF, scollegare i connettori &#34;C01&#34; e &#34;E01&#34; dalla ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Controllare l&#39;integrità dei collegamenti dei terminali ai connettori &#34;C01&#34; e &#34;E01&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Se i collegamenti sono in ordine, controllare i seguenti punti:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
resistenza del circuito &#34;A2&#34;: meno di 1 Ω
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il circuito &#34;A2&#34; e la massa: infinita
</ptxt>
</item>
<item>
<ptxt>
resistenza tra il terminale del circuito &#34;A2&#34; e l&#39;altro terminale del connettore del sensore MAP: infinita
</ptxt>
</item>
<item>
<ptxt>
tensione del circuito &#34;A2&#34;: 0 – 1 V (con accensione su &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare o sostituire il cablaggio difettoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104020010">
<title>
Controllo sensore MAP
</title>
<test1>
<ptxt>
Controllare il sensore MAP. 
<intxreftitleoff1 refid = "AITAP70A1306010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il sensore MAP.
</ptxt>
</action>
</testgroup>
</diag>
