<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A3206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Stacco e riattacco del gruppo differenziale posteriore
</title>
<servinfosub id = "AITAP70A3206003001">
<title>
Smontaggio
</title>
<s1>
<ptxt>
Mettere il veicolo sul ponte e rimuovere le ruote.
</ptxt>
</s1>
<s1>
<ptxt>
Se necessario, scaricare l&#39;olio dal differenziale posteriore. 
<intxreftitleoff1 refid = "AITAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i semiassi posteriori. 
<intxreftitleoff1 refid = "AITAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;albero di trasmissione dal differenziale posteriore. 
<intxreftitleoff1 refid = "AITAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Staccare il tubo flessibile di sfiato (1) dal differenziale posteriore.
</ptxt>
</s1>
<s1>
<ptxt>
Posizionare il martinetto in modo che il gruppo differenziale non si inclini. 
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere i bulloni (2) del braccio anteriore del differenziale.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il bullone (3) del supporto posteriore del differenziale.
</ptxt>
<figure>
<graphic graphicname = "IAP70A320007.swf" width = "88.000mm" height = "57.146mm" ver = "02" gw = "186" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Abbassare il martinetto con il gruppo differenziale posteriore.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A3206003002">
<title>
Riattacco
</title>
<ptxt>
Effettuare la procedura di stacco in senso inverso, tenendo conto delle seguenti istruzioni:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare ciascun bullone alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T3B004">
<t-part>
Bullone braccio anteriore differenziale
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
<torqueitem id = "T3B005">
<t-part>
Bullone supporto posteriore del differenziale
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
80
</t-value1>
<t-value2>
8,2
</t-value2>
<t-value3>
59,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320008.swf" width = "88.000mm" height = "52.572mm" ver = "02" gw = "186" gh = "133"/>
</figure>
</item>
<item>
<ptxt>
Se scaricato, introdurre l&#39;olio del differenziale posteriore, 
<intxreftitleoff1 refid = "AITAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
