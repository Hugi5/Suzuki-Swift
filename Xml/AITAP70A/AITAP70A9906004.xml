<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A9906004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del vetro del tetto apribile
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9906001">Componenti del tetto apribile</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A9906004001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Aprire completamente il parasole (1) e sollevare il tetto apribile.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990022.swf" width = "88.000mm" height = "43.115mm" ver = "01" gw = "138" gh = "106"/>
</figure>
</s1>
<s1>
<ptxt>
Scollegare il cavo negativo (–) dalla batteria.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il vetro del tetto apribile dopo aver tolto i bulloni di fissaggio (TORX <sup>®</sup> T25) (1).
</ptxt>
<figure>
<graphic graphicname = "I5JB0A990003.swf" width = "88.000mm" height = "45.253mm" ver = "01" gw = "185" gh = "112"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9906004002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare i bulloni di fissaggio del vetro del tetto apribile alle coppie indicate. 
<intxreftitleoff1 refid = "AITAP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Regolare la posizione di montaggio del vetro del tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Inizializzare il motorino tetto apribile. 
<intxreftitleoff1 refid = "AITAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
