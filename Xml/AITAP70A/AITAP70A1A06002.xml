<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1A06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della batteria
</title>
<servinfosub id = "AITAP70A1A06002001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Scollegare il cavo negativo (–) (1) dalla batteria (4).
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il cavo positivo (+) (2) dalla batteria (4).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il fermo (3).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la batteria (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0001.swf" width = "88.000mm" height = "71.286mm" ver = "01" gw = "171" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il portabatteria (1).
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la ECM (2). 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Eventualmente, rimuovere la staffa (3) della batteria.
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0002.jpg" width = "88.000mm" height = "55.738mm" ver = "02" gw = "199" gh = "141"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1A06002002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Serrare saldamente i cavi della batteria.
</ptxt>
</item>
<item>
<ptxt>
Eventualmente, inizializzare i dispositivi elettrici.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
