<servinfo servinfosgmlid = "AITAP70A9F06008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione della presa USB
</title>
<servinfosub id = "AITAP70A9F06008001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere la consolle centrale. 
<intxreftitleoff1 refid = "AITAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere la protezione laterale centrale. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1), quindi rimuovere la presa USB (2) dal cruscotto (3) liberando i fermi (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0014.jpg" width = "88.000mm" height = "55.000mm" ver = "02" gw = "206" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A9F06008002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A9F06009">Ispezione della presa USB</intxrefpoff>
</ptxt>
<ptxt>
Eseguire la procedura di rimozione in senso inverso.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
