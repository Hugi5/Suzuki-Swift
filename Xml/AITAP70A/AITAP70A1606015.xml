<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A1606015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del radiatore
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A1606014">Ispezione e pulizia del radiatore eseguita sul veicolo</intxrefpoff>
</ptxt>
<servinfosub id = "AITAP70A1606015001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il gruppo ventola di raffreddamento radiatore. 
<intxreftitleoff1 refid = "AITAP70A1606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Rimuovere il gruppo condensatore A/C. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modello con A/C manuale: 
<intxreftitleoff1 refid = "AITAP70A7216006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modello con A/C automatico: 
<intxreftitleoff1 refid = "AITAP70A7226006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Rimuovere il tubo flessibile d’uscita dal radiatore.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere le staffe superiori (1) del radiatore.
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il radiatore (2) dal veicolo.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160007.jpg" width = "88.000mm" height = "62.569mm" ver = "01" gw = "193" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1606015002">
<title>
Installazione
</title>
<ptxt>
Eseguire la procedura di rimozione in senso inverso, tenendo conto delle istruzioni fornite di seguito.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Riempire l&#39;impianto di raffreddamento con il liquido. 
<intxreftitleoff1 refid = "AITAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Controllare la presenza di perdite nell&#39;impianto di raffreddamento. 
<intxreftitleoff1 refid = "AITAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
