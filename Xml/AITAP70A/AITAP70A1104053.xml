<servinfosub id = "AITAP70A1104053003">
<title>
Procedura di conferma DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Eseguire innanzitutto la ricerca guasti dei DTC inattesi, rilevati in precedenza nella &#34;Procedura di conferma DTC&#34;.
</ptxt>
</item>
<item>
<ptxt>
Verificare che la &#34;Procedura di conferma DTC&#34; venga effettuata in presenza delle condizioni indicate di seguito.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tensione batteria &#62; 8 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
IAT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
Non vengono rilevati i DTC P0122, P0123, P0222, P0223, P2135 e P2176.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Tenere il pedale dell’acceleratore completamente premuto per 2 secondi.
</ptxt>
</s1>
<s1>
<ptxt>
Tenere il pedale dell’acceleratore rilasciato per 2 secondi.
</ptxt>
</s1>
<s1>
<ptxt>
Portare l&#39;accensione su &#34;OFF&#34; per 1 min, quindi su &#34;ON&#34;.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A1104053004">
<title>
Ricerca guasti
</title>
<diag type = "test" id = "AITAP70A1104053005">
<testgroup id = "AITAP70A1104053006">
<question>
È stata eseguita la procedura &#34;Verifica del sistema di controllo del motore e delle emissioni&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1104001">Verifica del sistema di controllo del motore e delle emissioni</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104053007">
<title>
Ricontrollo presenza di DTC
</title>
<test1>
<ptxt>
Cancellare il DTC.
</ptxt>
</test1>
<test1>
<ptxt>
Eseguire la calibrazione sistema di controllo farfalla motorizzata. 
<intxreftitleoff1 refid = "AITAP70A1306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Ricontrollare la presenza di DTC.
</ptxt>
</test1>
<question>
Il DTC P2101 / P2119 è ancora presente?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fine
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104053008">
<title>
Controllo circuito di comando attuatore farfalla
</title>
<test1>
<ptxt>
Controllare i circuiti di comando dell&#39;attuatore farfalla facendo riferimento al passo 2 di 
<intxref refid = "AITAP70A1104052">DTC P2100</intxref>
.
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Riparare il circuito di comando attuatore farfalla.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70A1104053009">
<title>
Controllo gruppo corpo farfalla motorizzata
</title>
<test1>
<ptxt>
Controllare il funzionamento del corpo farfalla motorizzata. 
<intxreftitleoff1 refid = "AITAP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
L’esito del controllo è OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sostituire la ECM e ripetere il controllo della presenza DTC. 
<intxreftitleoff1 refid = "AITAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sostituire il gruppo corpo farfalla motorizzata.
</ptxt>
</action>
</testgroup>
</diag>
