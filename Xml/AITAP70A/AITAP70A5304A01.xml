<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Slittamento
</title>
<diag type = "condition">
<condition>
<ptxt>
Slittamento
</ptxt>
</condition>
<ps>
<ptxt>
Gioco pedale della frizione non corretto
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire il braccio del pedale della frizione e/o la pompa della frizione.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Braccio pedale della frizione: 
<intxreftitleoff1 refid = "AITAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Pompa della frizione: 
<intxreftitleoff1 refid = "AITAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Materiale d’attrito disco frizione usurato o intriso d’olio
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il disco frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformazione del disco, dello spingidisco o del volano
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sostituire disco, coperchio frizione o volano.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Disco e coperchio frizione: 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Volano: 
<intxreftitleoff1 refid = "AITAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Affaticamento della molla a diaframma
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il coperchio frizione. 
<intxreftitleoff1 refid = "AITAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Mancato ritorno del pistone pompa freni o della guarnizione di tenuta
</ptxt>
</ps>
<action>
<ptxt>
Sostituire la pompa della frizione. 
<intxreftitleoff1 refid = "AITAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
