<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1604A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Surriscaldamento del motore (la ventola del radiatore è in funzione). 
</title>
<diag type = "condition">
<condition>
<ptxt>
Surriscaldamento del motore (la ventola del radiatore è in funzione). 
</ptxt>
</condition>
<ps>
<ptxt>
Cinghia pompa dell&#39;acqua lasca o rotta
</ptxt>
</ps>
<action>
<ptxt>
Registrare o sostituire la cinghia della pompa dell&#39;acqua. 
<intxreftitleoff1 refid = "AITAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Carenza di liquido di raffreddamento
</ptxt>
</ps>
<action>
<ptxt>
Controllare il livello del liquido di raffreddamento e rabboccarlo qualora necessario. 
<intxreftitleoff1 refid = "AITAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Termostato difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo termostato. 
<intxreftitleoff1 refid = "AITAP70A1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pompa dell&#39;acqua difettosa
</ptxt>
</ps>
<action>
<ptxt>
Sostituire la pompa dell&#39;acqua. 
<intxreftitleoff1 refid = "AITAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Alette del radiatore sporche o deformate
</ptxt>
</ps>
<action>
<ptxt>
Pulire o riparare. 
<intxreftitleoff1 refid = "AITAP70A1606014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Perdita di liquido di raffreddamento dall’impianto di raffreddamento
</ptxt>
</ps>
<action>
<ptxt>
Controllare la presenza di perdite nell&#39;impianto di raffreddamento. 
<intxreftitleoff1 refid = "AITAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radiatore intasato
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il radiatore. 
<intxreftitleoff1 refid = "AITAP70A1606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Tappo del radiatore difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il tappo del radiatore. 
<intxreftitleoff1 refid = "AITAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Strisciamento dei freni
</ptxt>
</ps>
<action>
<ptxt>
Controllare il freno. 
<intxreftitleoff1 refid = "AITAP70A4104001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slittamento della frizione
</ptxt>
</ps>
<action>
<ptxt>
Verificare la frizione. 
<intxreftitleoff1 refid = "AITAP70A5304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Batteria scarica
</ptxt>
</ps>
<action>
<ptxt>
Controllare la batteria. 
<intxreftitleoff1 refid = "AITAP70A1A04001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Mancata produzione idonea di carica da parte dell&#39;alternatore
</ptxt>
</ps>
<action>
<ptxt>
Controllare l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensore ECT guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sensore ECT. 
<intxreftitleoff1 refid = "AITAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motorino ventola di raffreddamento del radiatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il motorino della ventola di raffreddamento del radiatore. 
<intxreftitleoff1 refid = "AITAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ECM guasta
</ptxt>
</ps>
<action>
<ptxt>
Controllare l&#39;ECM e il relativo circuito. 
<intxreftitleoff1 refid = "AITAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Relè ventola di raffreddamento radiatore guasto
</ptxt>
</ps>
<action>
<ptxt>
Controllare il relè della ventola di raffreddamento del radiatore. 
<intxreftitleoff1 refid = "AITAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cablaggio o collegamento a massa difettoso
</ptxt>
</ps>
<action>
<ptxt>
Riparare il cablaggio.
</ptxt>
</action>
<ps>
<ptxt>
Troppi dispositivi elettrici opzionali
</ptxt>
</ps>
<action>
<ptxt>
Rimuovere i dispositivi elettrici.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
