<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A8206026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione dell&#39;interruttore di disattivazione airbag passeggero
</title>
<servinfosub id = "AITAP70A8206026001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Rimuovere il cassetto portaoggetti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scollegare il connettore (1) dell&#39;interruttore di disattivazione airbag passeggero.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820078.swf" width = "88.000mm" height = "87.000mm" ver = "01" gw = "231" gh = "230"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;interruttore di disattivazione airbag passeggero (1) rilasciando i fermi (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820079.swf" width = "88.000mm" height = "59.573mm" ver = "02" gw = "207" gh = "152"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A8206026002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A8206027">Ispezione dell&#39;interruttore di disattivazione airbag passeggero</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Installare l&#39;interruttore di disattivazione airbag passeggero (1) allineando la sporgenza (2) nell&#39;intaglio (3) sul cruscotto.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820080.swf" width = "88.000mm" height = "64.695mm" ver = "01" gw = "207" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Collegare il connettore dell&#39;interruttore di disattivazione airbag passeggero.
</ptxt>
</s1>
<s1>
<ptxt>
Installare il cassetto portaoggetti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
