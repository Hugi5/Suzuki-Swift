<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A9204A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Le luci della retromarcia non si accendono
</title>
<diag type = "condition">
<condition>
<ptxt>
Le luci della retromarcia non si accendono
</ptxt>
</condition>
<ps>
<ptxt>
Guasto del circuito del sistema (compresi relè e fusibili)
</ptxt>
</ps>
<action>
<ptxt>
Riparare il circuito.
</ptxt>
</action>
<ps>
<ptxt>
Lampadine bruciate
</ptxt>
</ps>
<action>
<ptxt>
Sostituire le lampadine.
</ptxt>
</action>
<ps>
<ptxt>
Interruttore luci di retromarcia difettoso
</ptxt>
</ps>
<action>
<ptxt>
Fare riferimento a 
<intxref refid = "AITAP70A5206008">Ispezione dell&#39;interruttore luci retromarcia</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
