<graphic graphicname = "IAP70A330031.swf" width = "88.000mm" height = "78.564mm" ver = "01" gw = "175" gh = "206"/>
</figure>
</s2>
<c-change/>
<s2>
<ptxt>
Calcolare la misura dello spessore di rasamento mediante l’equazione che segue.
</ptxt>
<ptxt>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "7" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.857in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.157in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.653in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.157in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.695in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.157in"/>
<colspec colnum = "7" colname = "7" colwidth = "0.771in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "middle" align = "center">
<ptxt>
Misura dello spessore necessario &#34;f&#34;
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
=
</ptxt>
</entry>
<entry colname = "3" morerows = "1" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Distanza &#34;c&#34;
</ptxt>
</entry>
<entry colname = "4" morerows = "1" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "0" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Valore di distanza &#34;d&#34;
</ptxt>
</entry>
<entry colname = "6" morerows = "1" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
