</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "5" border-top = "0" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
74,0 mm (2,913 in.)
</ptxt>
</entry>
<entry colname = "7" border-top = "0" border-bottom = "1" border-left = "0" border-right = "1" valign = "middle" align = "center">
<ptxt>
105,95 mm (4,171 in.)
</ptxt>
