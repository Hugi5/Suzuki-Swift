<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A1A04A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Alternatore rumoroso
</title>
<ptxt>
Un problema nell’impianto di ricarica della batteria si manifesta attraverso uno o più dei seguenti sintomi.
</ptxt>
<servinfosub id = "AITAP70A1A04002005">
<title>
Rumorosità
</title>
<diag type = "condition">
<condition>
<ptxt>
Alternatore rumoroso
</ptxt>
</condition>
<ps>
<ptxt>
Bulloni di fissaggio laschi
</ptxt>
</ps>
<action>
<ptxt>
Serrare i bulloni di montaggio. 
<intxreftitleoff1 refid = "AITAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cuscinetti sporchi, usurati e/o difettosi
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rotore, diodo e/o statore difettosi
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire l’alternatore. 
<intxreftitleoff1 refid = "AITAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
