<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AITAP70A4106006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rimozione e installazione del gruppo pedale freno
</title>
<attention2>
<ptxt>
Non smontare il gruppo pedale freno dotato di meccanismo di protezione del piede.
</ptxt>
<ptxt>
In caso di smontaggio ne verrà pregiudicato il corretto funzionamento. In caso di malfunzionamento, sostituire l’intero gruppo.
</ptxt>
</attention2>
<servinfosub id = "AITAP70A4106006001">
<title>
Rimozione
</title>
<s1>
<ptxt>
Togliere il pannello del quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il coperchio del foro del piantone. 
<intxreftitleoff1 refid = "AITAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l&#39;Interruttore luci stop. 
<intxreftitleoff1 refid = "AITAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere l’albero inferiore dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il fermaglio, il perno di chiusura maniglione e i dadi del servofreno. 
<intxreftitleoff1 refid = "AITAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rimuovere il dado (1) della staffa pedale freno e il bullone (2) rinforzo superiore cofano fisso.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Rimuovere il gruppo pedale del freno.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AITAP70A4106006002">
<title>
Installazione
</title>
<ptxt>
<intxrefpoff refid = "AITAP70A4106022">Rimozione e installazione del servofreno</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Installare il gruppo pedale del freno e installare il servofreno.
</ptxt>
</s1>
<s1>
<ptxt>
Serrare i dadi del servofreno alla coppia specificata.
</ptxt>
<torque>
<torqueitem id = "T4A001">
<t-part>
Dado del servofreno*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410009.swf" width = "88.000mm" height = "63.332mm" ver = "01" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Serrare il bullone della staffa pedale del freno alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T4A002">
<t-part>
Dado staffa pedale freno*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Serrare il bullone rinforzo superiore cofano fisso alla coppia indicata.
</ptxt>
<torque>
<torqueitem id = "T4A003">
<t-part>
Bullone rinforzo superiore cofano fisso
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410010.swf" width = "88.000mm" height = "64.412mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Installare il fermaglio e il perno di chiusura maniglione. 
<intxreftitleoff1 refid = "AITAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Montare l&#39;albero inferiore dello sterzo. 
<intxreftitleoff1 refid = "AITAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Spurgare l&#39;aria dall&#39;impianto frenante. 
<intxreftitleoff1 refid = "AITAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controllare l&#39;altezza del pedale freno e il gioco.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Altezza pedale del freno: 
<intxreftitleoff1 refid = "AITAP70A4106007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Gioco pedale del freno: 
<intxreftitleoff1 refid = "AITAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Installare l&#39;interruttore luci stop. 
<intxreftitleoff1 refid = "AITAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controllare se tutti i collegamenti presentano perdite di liquido e verificare che l&#39;impianto dei freni funzioni a dovere.
</ptxt>
</s1>
<s1>
<ptxt>
Installare il coperchio del foro del piantone sterzo. 
<intxreftitleoff1 refid = "AITAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Installare il pannello del quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
