<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A4104A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
La spia dei freni rimane accesa (per oltre 2 secondi) dopo l&#39;accensione
</title>
<diag type = "condition">
<condition>
<ptxt>
La spia dei freni rimane accesa (per oltre 2 secondi) dopo l&#39;accensione
</ptxt>
</condition>
<ps>
<ptxt>
Connettore della centralina ESP<sup>®</sup> non collegato correttamente
</ptxt>
</ps>
<action>
<ptxt>
Collegare nuovamente il connettore della centralina ESP<sup>®</sup>.
</ptxt>
</action>
<ps>
<ptxt>
Freno di stazionamento inserito
</ptxt>
</ps>
<action>
<ptxt>
Rilasciare il freno di stazionamento e controllare che la spia si spenga.
</ptxt>
</action>
<ps>
<ptxt>
Livello del liquido freni troppo basso
</ptxt>
</ps>
<action>
<ptxt>
Controllo del livello del liquido freni. 
<intxreftitleoff1 refid = "AITAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Modalità di lampeggio della spia ABS
</ptxt>
</ps>
<action>
<ptxt>
Individuare il guasto e ripararlo. 
<intxreftitleoff1 refid = "AITAP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Interruttore del freno di stazionamento e/o interruttore livello del liquido freni difettoso
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controllare l&#39;interruttore del freno di stazionamento e/o l&#39;interruttore livello del liquido freni.
</ptxt>
<ptxt>
Interruttore del freno di stazionamento: 
<intxreftitleoff1 refid = "AITAP70A4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Interruttore livello del liquido freni: 
<intxreftitleoff1 refid = "AITAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Sistema di comunicazione CAN difettoso
</ptxt>
</ps>
<action>
<ptxt>
Controllare il sistema di comunicazione CAN. 
<intxreftitleoff1 refid = "AITAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Quadro strumenti difettoso
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il quadro strumenti. 
<intxreftitleoff1 refid = "AITAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Centralina elettroidraulica ESP<sup>®</sup>
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo centralina elettroidraulica ESP<sup>®</sup>. 
<intxreftitleoff1 refid = "AITAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
