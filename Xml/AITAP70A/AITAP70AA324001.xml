<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70AA324001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Verifica del sistema di controllo immobilizzatore
</title>
<diag type = "test" id = "AITAP70AA324001001">
<testgroup id = "AITAP70AA324001003">
<title>
Controllo accensione inserita
</title>
<test1>
<ptxt>
Portare l&#39;accensione su &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Premere il pedale del freno.
</ptxt>
</test1>
<question>
Le spie ON e PUSH si accendono?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70AA504001">Controllo del sistema di avviamento senza chiave</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA324001004">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare la presenza di DTC. 
<intxreftitleoff1 refid = "AITAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sono presenti DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA324001006">
<title>
Controllo presenza DTC
</title>
<test1>
<ptxt>
Controllare il DTC relativo alla comunicazione CAN.
</ptxt>
</test1>
<question>
Sono presenti DTC relativi alla rete CAN?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare alla ricerca guasti relativa al DTC corrispondente.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare al passo 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA324001005">
<question>
Il motorino d’avviamento funziona?
</question>
<result type = "yes"/>
<action>
<ptxt>
Andare al passo 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1904001">Diagnosi dell&#39;impianto d’avviamento basata sui sintomi</intxref>
&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AITAP70AA324001002">
<title>
Controllo avviamento motore
</title>
<question>
Il motore si avvia?
</question>
<result type = "yes"/>
<action>
<ptxt>
Il sistema di controllo immobilizzatore è integro.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Andare a 
<intxref refid = "AITAP70A1104009">Ispezione di base del motore</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
