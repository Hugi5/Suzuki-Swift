<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AITAP70A2104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Pneumatici ovalizzati
</title>
<diag type = "condition">
<condition>
<ptxt>
Pneumatici ovalizzati
</ptxt>
</condition>
<ps>
<ptxt>
Assetto ruote non corretto
</ptxt>
</ps>
<action>
<ptxt>
Controllare e regolare l&#39;assetto ruote. 
<intxreftitleoff1 refid = "AITAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gruppo montante anteriore difettoso 
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il gruppo montante anteriore. 
<intxreftitleoff1 refid = "AITAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cuscinetti delle ruote usurati
</ptxt>
</ps>
<action>
<ptxt>
Sostituire i cuscinetti delle ruote. 
<intxreftitleoff1 refid = "AITAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Eccessiva eccentricità del pneumatico o della ruota
</ptxt>
</ps>
<action>
<ptxt>
Riparare o sostituire il pneumatico e/o la ruota.
</ptxt>
</action>
<ps>
<ptxt>
Giunti dei bracci delle sospensioni usurati
</ptxt>
</ps>
<action>
<ptxt>
Sostituire il braccio delle sospensioni. 
<intxreftitleoff1 refid = "AITAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ruota sbilanciata
</ptxt>
</ps>
<action>
<ptxt>
Bilanciare o sostituire il pneumatico.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
