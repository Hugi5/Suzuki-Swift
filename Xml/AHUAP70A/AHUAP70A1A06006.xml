<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1A06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Generátortartó le- és felszerelése
</title>
<servinfosub id = "AHUAP70A1A06006001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki a motor jobb oldali alsó burkolatát.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a vízszivattyú / generátor hajtószíját. 
<intxreftitleoff1 refid = "AHUAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a vízszivattyú szíjtárcsát (1). 
<intxreftitleoff1 refid = "AHUAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a generátor csavarját (2).
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a generátortartót (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1007.jpg" width = "88.000mm" height = "70.982mm" ver = "01" gw = "192" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A1A06006002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Szerelje fel a generátortartót a következő eljárás szerint.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Tegye a helyére a generátortartót (1).
</ptxt>
</item>
<item>
<ptxt>
Húzza meg lazán a generátor csavarját (2).
</ptxt>
</item>
<item>
<ptxt>
Húzza meg a generátortartó anyáit (3) az előírt nyomatékkal. 
<intxreftitleoff1 refid = "AHUAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
<figure>
<graphic graphicname = "I9P60A1A1016.swf" width = "88.000mm" height = "68.664mm" ver = "01" gw = "188" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
