<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A9F06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rádióantenna le- és felszerelése
</title>
<servinfosub id = "AHUAP70A9F06004001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a tető borítását. 
<intxreftitleoff1 refid = "AHUAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a rádióantenna-csatlakozót (1).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a rádióantenna csavarját (2).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a rádióantenna talpát (3) és a rádióantenna pálcáját (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0007.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9F06004002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg az antenna csavarját az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T9O001">
<t-part>
Antennacsavar
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,0
</t-value1>
<t-value2>
0,7
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A9F0008.jpg" width = "88.000mm" height = "64.793mm" ver = "01" gw = "199" gh = "167"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
