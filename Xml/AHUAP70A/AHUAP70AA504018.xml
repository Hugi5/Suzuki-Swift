<title>
DTC B1161 / B1163
</title>
<servinfosub id = "AHUAP70AA504018001">
<title>
DTC észlelésének körülményei és a hiba helye
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.816in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.388in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC észlelésének körülményei
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
