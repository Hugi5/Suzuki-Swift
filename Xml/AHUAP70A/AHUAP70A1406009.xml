<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1406009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
A szívócsonk le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1406005">A fojtószeleptest és a szívócsonk elemei</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A1406009001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Vegye ki a levegőszűrő egységet. 
<intxreftitleoff1 refid = "AHUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Csatlakoztatott hűtőfolyadéktömlők mellett szerelje le az elektromos fojtószelep egységet a szívócsonkról.
</ptxt>
</s1>
<s1>
<ptxt>
Kösse le a MAP érzékelő csatlakozóját (1).
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le az alábbi tömlőket:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
A fékrásegítő tömlőjét (2) a fékrásegítőről
</ptxt>
</item>
<item>
<ptxt>
A PCV tömlőt (3) a PCV szelepről
</ptxt>
<figure>
<graphic graphicname = "I7V20A141039.swf" width = "88.000mm" height = "53.078mm" ver = "01" gw = "221" gh = "134"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Lazítsa meg a fűtés bevezető csövének csavarját (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141022.jpg" width = "88.000mm" height = "51.297mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje le a szívócsonkot (1) és a tömítését.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141040.swf" width = "88.000mm" height = "57.944mm" ver = "01" gw = "183" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Válassza le a hűtővízcsövet (1). 
<intxreftitleoff1 refid = "AHUAP70A1606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a távtartót (2) és a tömítést a hengerfejről.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141023.jpg" width = "88.000mm" height = "57.901mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A1406009002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Új tömítést használjon.
</ptxt>
</item>
<item>
<ptxt>
Ellenőrizze, hogy minden leszerelt alkatrész visszakerült-e a helyére.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
