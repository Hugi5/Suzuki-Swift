<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A1704001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Az üzemanyag-ellátó rendszer vizsgálata
</title>
<diag type = "test" id = "AHUAP70A1704001001">
<testgroup id = "AHUAP70A1704001002">
<title>
Az üzemanyag-szivattyú ellenőrzése
</title>
<test1>
<ptxt>
Vegye le az üzemanyag-töltőnyílás sapkáját, és állítsa a gyújtást „ON” állásba.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze, hogy hallatszik-e az üzemanyag-szivattyú működési hangja az üzemanyag-töltőnyílás felől 2 másodpercig, majd megszűnik-e.
</ptxt>
</test1>
<question>
Az ellenőrzés eredménye megfelelő?
</question>
<result type = "yes"/>
<action>
<ptxt>
Folytassa a 2. lépéssel.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ellenőrizze az üzemanyag-szivattyú áramkörét. 
<intxreftitleoff1 refid = "AHUAP70A1704004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A1704001003">
<title>
Üzemanyagnyomás ellenőrzése
</title>
<test1>
<ptxt>
Ellenőrizze az üzemanyagnyomást. 
<intxreftitleoff1 refid = "AHUAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Az ellenőrzés eredménye megfelelő?
</question>
<result type = "yes"/>
<action>
<ptxt>
Folytassa a 3. lépéssel.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Javítsa meg a hibás alkatrészt.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A1704001004">
<title>
Teljesítmény-egyensúly próba
</title>
<test1>
<ptxt>
Ellenőrizze a teljesítmény-egyensúlyt. 
<intxreftitleoff1 refid = "AHUAP70A1704002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Az ellenőrzés eredménye megfelelő?
</question>
<result type = "yes"/>
<action>
<ptxt>
Az üzemanyag-ellátó rendszer áramkörének állapota megfelelő.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Folytassa a 4. lépéssel.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A1704001005">
<title>
Üzemanyag-befecskendező áramkörének ellenőrzése
</title>
<test1>
<ptxt>
Ellenőrizze az üzemanyag-befecskendező áramkörét. 
<intxreftitleoff1 refid = "AHUAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Az ellenőrzés eredménye megfelelő?
</question>
<result type = "yes"/>
<action>
<ptxt>
Folytassa az 5. lépéssel.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Javítsa meg a hibás alkatrészt.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A1704001006">
<title>
Üzemanyag-befecskendező ellenőrzése
</title>
<test1>
<ptxt>
Ellenőrizze az üzemanyag-befecskendezőt. 
<intxreftitleoff1 refid = "AHUAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Az ellenőrzés eredménye megfelelő? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Cserélje ki az ECM-et, és ismételje meg a DTC-k ellenőrzését. 
<intxreftitleoff1 refid = "AHUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Cserélje ki az üzemanyag-befecskendezőt. 
<intxreftitleoff1 refid = "AHUAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
