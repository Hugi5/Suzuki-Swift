<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A2104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
A jármű az egyik oldalra húz (sodródik)
</title>
<diag type = "condition">
<condition>
<ptxt>
A jármű az egyik oldalra húz (sodródik)
</ptxt>
</condition>
<ps>
<ptxt>
Nem összeillő vagy egyenetlenük kopott gumiabroncsok
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a gumiabroncsokat. 
<intxreftitleoff1 refid = "AHUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A gumiabroncsok nyomása nem megfelelő
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be a gumiabroncsok nyomását.
</ptxt>
</action>
<ps>
<ptxt>
Törött vagy megereszkedett tekercsrugók
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Cserélje ki a tekercsrugókat. 
</ptxt>
<ptxt>
Első: 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hátsó: 
<intxreftitleoff1 refid = "AHUAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Rendellenes oldalirányú radiálabroncs miatt
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a gumiabroncsot. 
<intxreftitleoff1 refid = "AHUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Elállítódott kerékbeállítás
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a kerékbeállítást, és ha kell, állítsa be újra. 
<intxreftitleoff1 refid = "AHUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Az egyik kerék fékje súrlódik vagy akad
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be vagy javítsa a féket.
</ptxt>
</action>
<ps>
<ptxt>
Kilazult, meggörbült vagy törött első vagy hátsó felfüggesztő elemek
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg a rögzítést vagy cserélje ki a felfüggesztő elemet. 
<intxreftitleoff1 refid = "AHUAP70A2106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
