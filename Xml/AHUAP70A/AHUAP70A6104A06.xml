<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A6104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Bizonytalan kormányzás fékezéskor
</title>
<diag type = "condition">
<condition>
<ptxt>
Bizonytalan kormányzás fékezéskor
</ptxt>
</condition>
<ps>
<ptxt>
Kopott kerékcsapágy(ak)
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kerékcsapágya(ka)t. 
<intxreftitleoff1 refid = "AHUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Törött vagy megereszkedett tekercsrugó
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tekercsrugót. 
<intxreftitleoff1 refid = "AHUAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Meghibásodott első rugóstag (lengéscsillapító)
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az első rugóstagot (lengéscsillapító). 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nem egyforma nyomás az abroncsokban
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be a gumiabroncsok nyomását. 
</ptxt>
</action>
<ps>
<ptxt>
Elállítódott az első kerékbeállítás
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze az első kerekek beállítását, és ha kell, állítsa be újra. 
<intxreftitleoff1 refid = "AHUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A fékek működése nincs összehangolva
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze és javítsa meg a fékrendszert. 
<intxreftitleoff1 refid = "AHUAP70A4101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Az első féktárcsák fékfolyadékkal szennyezettek
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki az első féktárcsát. 
<intxreftitleoff1 refid = "AHUAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformálódott féktárcsa
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tárcsát. 
<intxreftitleoff1 refid = "AHUAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Erősen kopott fékbetét
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az első fékbetét. 
<intxreftitleoff1 refid = "AHUAP70A4206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
