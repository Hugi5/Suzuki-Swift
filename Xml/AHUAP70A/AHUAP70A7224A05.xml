<servinfo servinfosgmlid = "AHUAP70A7224A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nem áramlik ki időnként hideg levegő
</title>
<diag type = "condition">
<condition>
<ptxt>
Nem áramlik ki időnként hideg levegő
</ptxt>
</condition>
<ps>
<ptxt>
Hibás vezeték-csatlakozás
</ptxt>
</ps>
<action>
<ptxt>
Ha szükséges, javítsa meg a vezetékeket.
</ptxt>
</action>
<ps>
<ptxt>
Hibás expanziós szelep
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze az expanziós szelepet. 
<intxreftitleoff1 refid = "AHUAP70A7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Túl sok nedvesség az A/C rendszerben
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az A/C hűtőt, majd végezze el az ürítést, és a töltést. 
<intxreftitleoff1 refid = "AHUAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás mágneses tengelykapcsoló
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a mágneses tengelykapcsolót. 
<intxreftitleoff1 refid = "AHUAP70A7226047"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Túl sok a hűtőközeg
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a hűtőközeg mennyiségét.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
