<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A9406001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Ablakmosó tartály és ablakmosó szivattyú le- és felszerelése
</title>
<servinfosub id = "AHUAP70A9406001001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Szerelje le az első lökhárítót. 
<intxreftitleoff1 refid = "AHUAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a vezetékköteg bilincseit (1), az ablakmosó szivattyú csatlakozóit (2) és az ablakmosótömlőket (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940004.jpg" width = "88.000mm" height = "67.662mm" ver = "01" gw = "209" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el az ablakmosó tartály csavarjait (1), majd vegye le az ablakmosó tartályt (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940005.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "180" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Húzza az ablakmosó szivattyút (1) és a hátsó ablakmosó szivattyút (2) a nyíl irányába, hogy leválassza őket az ablakmosótartályról (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940006.jpg" width = "88.000mm" height = "62.134mm" ver = "01" gw = "161" gh = "160"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9406001002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A9406002">Ablakmosó szivattyú ellenőrzése</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg az ablakmosó tartály csavarjait az előírt nyomatékkal.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9D001">
<t-part>
Ablakmosótartály csavarja
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A940008.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "201" gh = "174"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
