<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70AA504011" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1122
</title>
<servinfosub id = "AHUAP70AA504011001">
<title>
DTC észlelésének körülményei és a hiba helye
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.161in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.043in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC észlelésének körülményei
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
A hiba helye
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1122: Tartalék áramforrás hibás működése
</emph>
</ptxt>
<ptxt>
A &#34;BCM&#34; biztosítéktól érkező biztonsági tápáramkör feszültsége alacsonyabb az előírt értéknél.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
“BCM” biztosíték
</ptxt>
</item>
<item>
<ptxt>
Kulcsnélküli indítás vezérlőmodulja
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHUAP70AA504011002">
<title>
DTC megerősítési eljárás
</title>
<s1>
<ptxt>
Állítsa a gyújtást „ON” állásba.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70AA504011003">
<title>
DTC hibakeresés
</title>
<diag type = "test" id = "AHUAP70AA504011004">
<testgroup id = "AHUAP70AA504011005">
<title>
A biztosíték ellenőrzése
</title>
<test1>
<ptxt>
Győződjön meg arról, hogy a gyújtáskapcsoló „OFF” helyzetben van.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze a &#34;BCM&#34; biztosítékot.
</ptxt>
</test1>
<question>
Megfelelő az állapota?
</question>
<result type = "yes"/>
<action>
<ptxt>
Cserélje ki a kulcsnélküli indítás vezérlőmodulját, és ismételje meg a DTC ellenőrzést. 
<intxreftitleoff1 refid = "AHUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Cserélje ki a „BCM&#34; biztosítékot, majd folytassa a 2. lépéssel.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70AA504011006">
<title>
DTC ellenőrzése
</title>
<test1>
<ptxt>
Állítsa a gyújtást „ON” állásba.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze a DTC-t. 
<intxreftitleoff1 refid = "AHUAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Továbbra is észleli a B1122 számú hibakódot?
</question>
<result type = "yes"/>
<action>
<ptxt>
Cserélje ki a „BCM&#34; biztosítékot és a kulcsnélküli indítás vezérlőmodulját, és ismételje meg a DTC ellenőrzést. 
<intxreftitleoff1 refid = "AHUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vége.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
