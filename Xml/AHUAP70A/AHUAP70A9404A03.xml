<servinfo servinfosgmlid = "AHUAP70A9404A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Az ablaktörlő hibásan működik
</title>
<servinfosub id = "AHUAP70A9404002003">
<title>
Hátsó ablaktörlő és ablakmosó
</title>
<diag type = "condition">
<condition>
<ptxt>
Az ablaktörlő hibásan működik
</ptxt>
</condition>
<ps>
<ptxt>
Meghibásodott hátsó ablaktörlő motor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHUAP70A9406006">Hátsó ablaktörlőmotor ellenőrzése</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Hibás ablaktörlő és ablakmosó kapcsoló (ablaktörlő kapcsoló)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHUAP70A9406008">Ablaktörlő és ablakmosó kapcsolójának ellenőrzése</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Hibás vezeték vagy testelés
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a vezetékeket.
</ptxt>
</action>
<ps>
<ptxt>
Hibás BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
„BCM és áramköreinek ellenőrzése”, 10B fejezet
</ptxt>
<ptxt>
Gyújtáskapcsolóval szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Nyomógombos indítórendszerrel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
