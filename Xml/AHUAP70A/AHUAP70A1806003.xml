<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1806003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Gyújtótekercs egység le- és felszerelése
</title>
<servinfosub id = "AHUAP70A1806003001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Vegye ki a levegőszűrő egységet. 
<intxreftitleoff1 refid = "AHUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a gyújtótekercs csatlakozóit.
</ptxt>
</s1>
<s1>
<ptxt>
Vegye ki a gyújtótekercs csavarjait (1), majd húzza ki a gyújtótekercs egységeket (2).
</ptxt>
<figure>
<graphic graphicname = "I7V20A180004.swf" width = "88.000mm" height = "54.310mm" ver = "01" gw = "212" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A1806003002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1806004">Gyújtótekercs egység vizsgálata</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg a gyújtótekercs csavarját az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T1H002">
<t-part>
Gyújtótekercs csavar
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
