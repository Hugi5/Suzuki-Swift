<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1406007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Az elektromos fojtószelep egység le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1406005">A fojtószeleptest és a szívócsonk elemei</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHUAP70A1406006">A fojtószeleptest ellenőrzése beszerelt állapotban</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Soha ne szerelje szét az elektromos fojtószelepet. Ha hibásnak találja, cserélje ki egy újra.
</ptxt>
</attention2>
<servinfosub id = "AHUAP70A1406007001" page = "2">
<title>
Leszerelés
</title>
<s1 page = "2">
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Engedje le a hűtőfolyadékot. 
<intxreftitleoff1 refid = "AHUAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Vegye ki a levegőszűrő egységet. 
<intxreftitleoff1 refid = "AHUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Válassza le a hűtőfolyadék tömlőit (1) és a csatlakozót (2) az elektromos fojtószeleptest egységről (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Szerelje le az elektromos fojtószeleptest egységet és a levegőszűrő tartót (4) a szívócsonkról.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A1406007002" page = "2">
<title>
Felszerelés
</title>
<s1 page = "2">
<ptxt>
Tisztítsa meg az illeszkedő felületeket, és helyezze a fojtószeleptest új tömítését (1) a szívócsonkra.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141038.swf" width = "88.000mm" height = "58.059mm" ver = "01" gw = "212" gh = "148"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Szerelje fel az elektromos fojtószeleptest egységet (3) és a levegőszűrő tartóját (4) a szívócsonkra.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Csatlakoztassa a csatlakozót (2) és a hűtőfolyadék tömlőket (1) az elektromos fojtószeleptest egységre (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Szerelje fel a levegőszűrő egységet. 
<intxreftitleoff1 refid = "AHUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Csatlakoztassa a negatív (–) kábelt az akkumulátorhoz.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Töltse újra a hűtőfolyadékot. 
<intxreftitleoff1 refid = "AHUAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ellenőrizze a hűtőfolyadék szivárgását. 
<intxreftitleoff1 refid = "AHUAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
