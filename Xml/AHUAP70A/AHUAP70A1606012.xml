<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
A hűtőventilátor egység le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1606010">Hűtőventilátor egység ellenőrzése beszerelt állapotban</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A1606012001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Engedje le a hűtőfolyadékot. 
<intxreftitleoff1 refid = "AHUAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a hűtőventilátor motorjának csatlakozóját (1).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a tartályt (2).
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a hűtő bevezető tömlőjét (3) a hűtőről.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160005.swf" width = "88.000mm" height = "70.920mm" ver = "01" gw = "221" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el a hűtőventilátor egységet a hűtőről.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AHUAP70A1606012002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Töltse fel a rendszert hűtőfolyadékkal. 
<intxreftitleoff1 refid = "AHUAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ellenőrizze a hűtőrendszer szivárgását. 
<intxreftitleoff1 refid = "AHUAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
