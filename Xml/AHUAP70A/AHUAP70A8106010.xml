<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A8106010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Hátsó középső biztonsági öv le- és felszerelése
</title>
<servinfosub id = "AHUAP70A8106010001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Távolítsa el a hátsó ülés üléspárnáját. 
<intxreftitleoff1 refid = "AHUAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a csavart és az anyát, majd vegye ki a hátsó középső biztonsági övet. 
<intxreftitleoff1 refid = "AHUAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A8106010002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A8106003">Első biztonsági öv egység csatja</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Győződjön meg arról, hogy az üléstámla keretén található csap (3) az övbehúzó (1) hosszú furatában (2) található.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810016.swf" width = "88.000mm" height = "77.820mm" ver = "02" gw = "236" gh = "204"/>
</figure>
</item>
<item>
<ptxt>
Húzza meg a hátsó középső ülés középső biztonsági övének csavarjait az előírt nyomatékkal. 
<intxreftitleoff1 refid = "AHUAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ne lépjen a jármű peremére (2), amikor a rögzítőlemezt (1) felszereli.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810017.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
