<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A2104A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
A jármű kanyarban megdől vagy kileng
</title>
<diag type = "condition">
<condition>
<ptxt>
A jármű kanyarban megdől vagy kileng
</ptxt>
</condition>
<ps>
<ptxt>
Kilazult stabilizátorrúd
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg a stabilizátorrúd csavarjait, vagy cserélje ki a perselyeket. 
<intxreftitleoff1 refid = "AHUAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás első rugóstag (lengéscsillapító) vagy rögzítés
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az első rugóstagot (lengéscsillapító), vagy húzza meg a rögzítését. 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Törött vagy megereszkedett tekercsrugók
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Cserélje ki a tekercsrugókat. 
</ptxt>
<ptxt>
Első: 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hátsó: 
<intxreftitleoff1 refid = "AHUAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Túlterhelt jármű
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a terhelést.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
