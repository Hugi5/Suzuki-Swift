<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A9404A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Az ablakmosó hibásan működik
</title>
<servinfosub id = "AHUAP70A9404002003">
<title>
Hátsó ablaktörlő és ablakmosó
</title>
<diag type = "condition">
<condition>
<ptxt>
Az ablakmosó hibásan működik
</ptxt>
</condition>
<ps>
<ptxt>
Hibás ablakmosótömlő (beleértve a visszacsapószelepet és a csatlakozót) vagy fúvóka
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrzze az ablakmosótömlőt vagy az ablakmosó fúvókát eltömődés és meghajlás szempontjából.
</ptxt>
</action>
<ps>
<ptxt>
Hibás mosószivattyú
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHUAP70A9406002">Ablakmosó szivattyú ellenőrzése</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Hibás ablaktörlő és ablakmosó kapcsoló (ablakmosó kapcsoló)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHUAP70A9406008">Ablaktörlő és ablakmosó kapcsolójának ellenőrzése</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Hibás vezeték vagy testelés
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a vezetékeket.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
