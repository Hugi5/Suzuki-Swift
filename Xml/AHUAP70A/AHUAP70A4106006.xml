<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A4106006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Fékpedál egység le- és felszerelése
</title>
<attention2>
<ptxt>
Soha ne szerelje szét a lábvédő mechanizmussal ellátott fékpedál egységet.
</ptxt>
<ptxt>
Ha szétszereli az egységet, az alkalmatlanná válik eredeti funkciójának betöltésére. Ha valamilyen hibát talál, egész egységként cserélje ki.
</ptxt>
</attention2>
<servinfosub id = "AHUAP70A4106006001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Távolítsa el a műszeregység paneljét. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vegye le a kormányoszlop üregének burkolatát. 
<intxreftitleoff1 refid = "AHUAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki a féklámpakapcsolót. 
<intxreftitleoff1 refid = "AHUAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki az alsó kormánytengelyt. 
<intxreftitleoff1 refid = "AHUAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a rögzítőkapocsot, a kengyelcsapszeget és a fékrásegítő anyáit. 
<intxreftitleoff1 refid = "AHUAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a fékpedáltartó anyáját (1) és a motortérburkolat felső merevítőcsavarját (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el a fékpedál egységet.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A4106006002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A4106022">Fékrásegítő le- és felszerelése</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Szerelje fel a fékpedál egységet, majd szerelje be a fékrásegítőt.
</ptxt>
</s1>
<s1>
<ptxt>
Húzza meg a fékrásegítő anyáit az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T4A001">
<t-part>
Fékrásegítő anya*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410009.swf" width = "88.000mm" height = "63.332mm" ver = "01" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Húzza meg a fékpedáltartó anyáját az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T4A002">
<t-part>
Fékpedáltartó anyája*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Húzza meg a motortérburkolat felső merevítőcsavarját az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T4A003">
<t-part>
Motortérburkolat merevítőcsavarja
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410010.swf" width = "88.000mm" height = "64.412mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje fel a rögzítőkapcsot és a kengyelt. 
<intxreftitleoff1 refid = "AHUAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje be az alsó kormánytengelyt. 
<intxreftitleoff1 refid = "AHUAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Légtelenítse a fékrendszert. 
<intxreftitleoff1 refid = "AHUAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ellenőrizze a fékpedál szabad magasságát és játékát.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
A fékpedál szabad magassága: 
<intxreftitleoff1 refid = "AHUAP70A4106007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Fékpedál holtjátéka: 
<intxreftitleoff1 refid = "AHUAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Szerelje fel a féklámpakapcsolót. 
<intxreftitleoff1 refid = "AHUAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ellenőrizzen minden csatlakozást folyadékszivárgás szempontjából és győződjön meg arról, hogy a fékrendszer megfelelően működik.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje fel a kormányoszlop-üreg burkolatát. 
<intxreftitleoff1 refid = "AHUAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje fel a műszeregység paneljét. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
