<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A4104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Túl nagy pedálút (a pedál túl hosszú úton jár)
</title>
<diag type = "condition">
<condition>
<ptxt>
Túl nagy pedálút (a pedál túl hosszú úton jár)
</ptxt>
</condition>
<ps>
<ptxt>
A fékrendszer részleges meghibásodása
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a fékrendszert, és szükség esetén javítsa meg.
</ptxt>
</action>
<ps>
<ptxt>
Szivárog a fékfolyadék
</ptxt>
</ps>
<action>
<ptxt>
Szüntesse meg a szivárgást, és végezzen légtelenítést.
</ptxt>
</action>
<ps>
<ptxt>
A rendszer levegős (puha / süppedős pedál)
</ptxt>
</ps>
<action>
<ptxt>
Légtelenítse a rendszert.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
