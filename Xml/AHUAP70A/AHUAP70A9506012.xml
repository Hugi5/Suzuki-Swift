<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A9506012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Első elektromos ablakemelő le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A9506010">Első ajtó elemei</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A9506012001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Vegye ki az első ajtó üvegét. 
<intxreftitleoff1 refid = "AHUAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le az elektromos ablakemelő motor csatlakozóját (3).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az első ablakemelő csavarjait (1), és szerelje ki az első elektromos ablakemelőt (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950032.jpg" width = "88.000mm" height = "64.165mm" ver = "03" gw = "225" gh = "165"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9506012002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A9506013">Első elektromos ablakemelő ellenőrzése</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kenje meg kenőzsírral az első ablakemelő egység csúszó részeit.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E001" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Kenőzsír
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Húzza meg az első ablakemelő csavarjait sorrendben 1-től 6-ig, az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T9E003">
<t-part>
Első ablakemelő anyája*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950033.jpg" width = "88.000mm" height = "70.187mm" ver = "02" gw = "225" gh = "182"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
