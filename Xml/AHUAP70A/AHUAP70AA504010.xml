<servinfosub id = "AHUAP70AA504010002">
<title>
DTC megerősítési eljárás
</title>
<s1>
<ptxt>
Állítsa a gyújtást „ON” állásba.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70AA504010003">
<title>
DTC hibakeresés
</title>
<diag type = "test" id = "AHUAP70AA504010004">
<testgroup id = "AHUAP70AA504010005">
<title>
DTC-újraellenőrzés
</title>
<test1>
<ptxt>
Törölje a DTC-t. 
<intxreftitleoff1 refid = "AHUAP70AA504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Állítsa a gyújtást „OFF” állásba.
</ptxt>
</test1>
<test1>
<ptxt>
Hajtsa végre a következőket: 
<intxref refid = "AHUAP70AA504010002">DTC megerősítési eljárás</intxref>
, majd újból kérdezze le a DTC-ket.
</ptxt>
</test1>
<question>
Továbbra is észlelhető a B1120 vagy a B1170 hibakód?
</question>
<result type = "yes"/>
<action>
<ptxt>
Cserélje ki a kulcsnélküli indítás vezérlőmodulját, és ismételje meg a DTC ellenőrzést. 
<intxreftitleoff1 refid = "AHUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vége.
</ptxt>
</action>
</testgroup>
</diag>
