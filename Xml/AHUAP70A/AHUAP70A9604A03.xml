<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A9604A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Egyik ajtó sem zárható / nyitható csak a kulcsnélküli ajtónyitó rendszer jeladójával vagy a távirányítóval
</title>
<diag type = "condition">
<condition>
<ptxt>
Egyik ajtó sem zárható / nyitható csak a kulcsnélküli ajtónyitó rendszer jeladójával vagy a távirányítóval
</ptxt>
</condition>
<ps>
<ptxt>
Hibás BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Lásd „BCM és áramköreinek ellenőrzése”, 10B fejezet.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Gyújtáskapcsolóval szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nyomógombos indítórendszerrel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Meghibásodott a kulcsnélküli indítás vezérlőmodulja (nyomógombos indítórendszerrel szerelt modell esetén)
</ptxt>
</ps>
<action>
<ptxt>
Lásd: 
<intxref refid = "AHUAP70AA504031">Kulcsnélküli indításvezérlő modul és áramköreinek ellenőrzése</intxref>
 .
</ptxt>
</action>
<ps>
<ptxt>
Hibás rendszer áramkör (a reléket és a biztosítékokat is beleértve)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Hibás jeladó (gyújtáskapcsolóval szerelt modell)
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az akkumulátort. 
<intxreftitleoff1 refid = "AHUAP70A9606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás távirányító (nyomógombos indítórendszerrel szerelt modell)
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az akkumulátort. 
<intxreftitleoff1 refid = "AHUAP70AA506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás kulcsnélküli ajtónyitó rendszer vevő
</ptxt>
</ps>
<action>
<ptxt>
Lásd: 
<intxref refid = "AHUAP70A9606016">Kulcsnélküli ajtónyitó rendszer vevőjének ellenőrzése</intxref>
 .
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
