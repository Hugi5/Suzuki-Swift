<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A3126003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Hátsó féltengely egység le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A3126001">Hátsó féltengely elemei:Hátsó</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AHUAP70A3126002">Hátsó féltengely-egység ellenőrzése a járművön:Hátsó</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A3126003001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Emelje meg a járművet, és szerelje le a hátsó kereket. 
<intxreftitleoff1 refid = "AHUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Oldja ki a biztosítást (1), és távolítsa el a féltengelyanyát (2), miközben a fékpedált benyomva tartja.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312002.swf" width = "88.000mm" height = "53.091mm" ver = "01" gw = "177" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el a hátsó féltengely karimás anyáit (1), majd a hátsó féltengely egységet.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312003.swf" width = "88.000mm" height = "47.465mm" ver = "01" gw = "177" gh = "118"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A3126003002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg az új féltengelyanyát (1) az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T3A202">
<t-part>
Féltengelyanya
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Rögzítse a féltengely rögzítőanyát (1) az ábrának megfelelően.
</ptxt>
<attention2>
<ptxt>
Vigyázzon, nehogy megrepessze a féltengelyanya biztosító részét (2), miközben biztosítja. Ha megrepedt, cserélje ki.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A312004.swf" width = "88.000mm" height = "52.301mm" ver = "01" gw = "159" gh = "132"/>
</figure>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg a hátsó féltengely csatlakozóperemének anyáit az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T3A203">
<t-part>
Hátsó féltengely csatlakozóperemének anyája
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A312005.swf" width = "88.000mm" height = "49.964mm" ver = "01" gw = "177" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Kenje be zsírral a hátsó kerékagy szerelvény és a hátsó féltengely illeszkedő felületét.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A202" uid = "1126491901">
<m-part>
„A”
</m-part>
<m-desc>
Kenőzsír
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A312006.swf" width = "88.000mm" height = "54.175mm" ver = "02" gw = "227" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Húzza meg a kerékanyákat az előírt nyomatékkal. 
<intxreftitleoff1 refid = "AHUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
