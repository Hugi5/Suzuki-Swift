<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1071: ESP<sup>®</sup> vezérlőmodul belső hibája
</emph>
</ptxt>
<ptxt>
A rendszer az ESP<sup>®</sup> vezérlőmodulban belső hibát észlelt.
</ptxt>
</entry>
