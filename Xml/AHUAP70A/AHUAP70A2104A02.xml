<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Gumiabroncs túlzott kopása
</title>
<diag type = "condition">
<condition>
<ptxt>
Gumiabroncs túlzott kopása
</ptxt>
</condition>
<ps>
<ptxt>
Törött vagy megereszkedett tekercsrugók
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Cserélje ki a tekercsrugókat. 
</ptxt>
<ptxt>
Első: 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hátsó: 
<intxreftitleoff1 refid = "AHUAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
A kerék nincs kiegyensúlyozva
</ptxt>
</ps>
<action>
<ptxt>
Egyensúlyozza ki vagy cserélje ki a gumiabroncsot.
</ptxt>
</action>
<ps>
<ptxt>
Elállítódott kerékbeállítás
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a kerékbeállítást, és ha kell, állítsa be újra. 
<intxreftitleoff1 refid = "AHUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Meghibásodott első rugóstag (lengéscsillapító)
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az első rugóstagot (lengéscsillapító). 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kemény vezetési stílus
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a gumiabroncsokat. 
<intxreftitleoff1 refid = "AHUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Túlterhelt jármű
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a terhelést.
</ptxt>
</action>
<ps>
<ptxt>
Az abroncsok nem voltak egymás között cserélve
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az abroncsokat, vagy végezzen rotációs abroncscserét.
</ptxt>
</action>
<ps>
<ptxt>
Kopott vagy lógó kerékcsapágy
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kerékcsapágyat. 
<intxreftitleoff1 refid = "AHUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A kerék vagy a gumiabroncs szitál
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kereket vagy a gumiabroncsot.
</ptxt>
</action>
<ps>
<ptxt>
A gumiabroncsok nyomása nem megfelelő
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be a gumiabroncsok nyomását.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
