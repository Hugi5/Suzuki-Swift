<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A7214A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Rezgő zaj hallatszik, amikor a kompresszor működik
</title>
<servinfosub id = "AHUAP70A7214004003">
<title>
Rendellenes zaj a mágneses tengelykapcsolóból
</title>
<diag type = "condition">
<condition>
<ptxt>
Rezgő zaj hallatszik, amikor a kompresszor működik
</ptxt>
</condition>
<ps>
<ptxt>
Hibás mágneses tengelykapcsoló hézag (a hézag túl nagy)
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be a mágneses tengelykapcsoló hézagát. 
<intxreftitleoff1 refid = "AHUAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott mágneses tengelykapcsoló dörzsfelület.
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a mágneses tengelykapcsoló egységet. 
<intxreftitleoff1 refid = "AHUAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kompresszorolaj szivárog a tengely tömítéséből és elszennyezi a dörzsfelületet.
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kompresszorház egységet. 
<intxreftitleoff1 refid = "AHUAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
