<servinfo servinfosgmlid = "AHUAP70A9506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Hátsó elektromos ablakemelő le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A9506014">Hátsó ajtó elemei</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A9506017001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Vegye ki a csomagtér ajtó üvegét. 
<intxreftitleoff1 refid = "AHUAP70A9506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le az elektromos ablakemelő motor csatlakozóját (1).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a hátsó ablakemelő csavarjait (2), és szerelje ki a hátsó ablakemelő egységet (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950048.jpg" width = "88.000mm" height = "61.700mm" ver = "02" gw = "217" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9506017002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A9506018">Hátsó elektromos ablakemelő ellenőrzése</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kenje meg kenőzsírral a hátsó ablakemelő egység csúszó részeit.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E002" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Kenőzsír
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Húzza meg a hátsó ablakemelő csavarjait sorrendben 1-től 4-ig, az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T9E006">
<t-part>
Hátsó ablakemelő csavarja*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,86
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950049.jpg" width = "88.000mm" height = "63.881mm" ver = "01" gw = "225" gh = "165"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
