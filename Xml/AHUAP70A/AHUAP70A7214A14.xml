<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A7214A14" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hangos zörgés hallatszik a motor alacsony fordulatszámánál
</title>
<servinfosub id = "AHUAP70A7214004001">
<title>
Rendellenes zaj a kompresszorból
</title>
<diag type = "condition">
<condition>
<ptxt>
Hangos zörgés hallatszik a motor alacsony fordulatszámánál
</ptxt>
</condition>
<ps>
<ptxt>
Lazítsa meg a kompresszor tengelykapcsoló tárcsájának anyáját
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Húzza meg újra a tengelykapcsoló lemez anyáját. 
<intxreftitleoff1 refid = "AHUAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Cserélje ki a kompresszort, ha sokáig működött zörögve.
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
