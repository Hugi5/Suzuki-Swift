<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A2104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Rendellenes zaj az első futóműből
</title>
<diag type = "condition">
<condition>
<ptxt>
Rendellenes zaj az első futóműből
</ptxt>
</condition>
<ps>
<ptxt>
Sérült első rugóstag egység (lengéscsillapító) vagy rögzítések
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a sérült első rugóstag egységet (lengéscsillapító) vagy a rögzítéseket. 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott, beragadt vagy laza kormányösszekötő gömbfejek
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kormányösszekötő gömbfejeket. 
<intxreftitleoff1 refid = "AHUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott vagy sérült lengőkar gömbfejek
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a lengőkart. 
<intxreftitleoff1 refid = "AHUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott, beragadt vagy laza kormányösszekötő rúd csuklók
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kormányműház egységet. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott, beragadt vagy laza féltengely-csuklók
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a féltengelycsuklókat. 
<intxreftitleoff1 refid = "AHUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopottak a lengőkarok első perselyei
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a lengőkarok első perselyeit. 
<intxreftitleoff1 refid = "AHUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopottak a lengőkarok hátsó perselyei
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a lengőkart. 
<intxreftitleoff1 refid = "AHUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kilazult stabilizátorrúd
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg a rögzítőcsavarokat vagy anyákat és/vagy cserélje ki a perselyeket. 
<intxreftitleoff1 refid = "AHUAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lazítsa meg a kerékanyákat
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg a kerékanyákat. 
<intxreftitleoff1 refid = "AHUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lazák a futómű csavarjai vagy anyái
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg a futómű csavarjait vagy anyáit. 
<intxreftitleoff1 refid = "AHUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Törött vagy sérült kerékcsapágy
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kerékcsapágyakat. 
<intxreftitleoff1 refid = "AHUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Törött tekercsrugók
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Cserélje ki a tekercsrugókat. 
</ptxt>
<ptxt>
Első: 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hátsó: 
<intxreftitleoff1 refid = "AHUAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Elégtelenül kent vagy kopott toronycsapágyak
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a toronycsapágyakat. 
<intxreftitleoff1 refid = "AHUAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A szervokormányrendszer működési hibája
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze és javítsa ki a hibát. 
<intxreftitleoff1 refid = "AHUAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
