<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70AA316001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Indításgátló vezérlőegység le- és felszerelése
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Az indításgátló vezérlőegység precíziós alkatrészeket tartalmaz, ezért óvja a nagyobb ütésektől.
</ptxt>
</item>
<item>
<ptxt>
Ne szerelje szét az indításgátló vezérlőegységet.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AHUAP70AA316001001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Állítsa a gyújtást „OFF” állásba.
</ptxt>
</s1>
<s1>
<ptxt>
Vegye le a kormányoszlop felső és alsó burkolatát. 
<intxreftitleoff1 refid = "AHUAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Válassza le a csatlakozót (1) az indításgátló vezérlőegységről (2).
</ptxt>
</s1>
<s1>
<ptxt>
Vegye ki a csavart (3) az indításgátló vezérlőegységből.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki az indításgátló vezérlőmodult a kormányzár egységről az ábra szerint.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA31004.jpg" width = "88.000mm" height = "60.854mm" ver = "01" gw = "197" gh = "156"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70AA316001002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
