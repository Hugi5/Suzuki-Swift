<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A7214A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
A szellőztetőmotor nem működik
</title>
<diag type = "condition">
<condition>
<ptxt>
A szellőztetőmotor nem működik
</ptxt>
</condition>
<ps>
<ptxt>
Kiolvadt biztosíték
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a megfelelő biztosítékokat, majd azt, hogy nincs-e testzárlat.
</ptxt>
</action>
<ps>
<ptxt>
Hibás szellőztetőmotor relé
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a szellőztetőmotor reléjét. 
<intxreftitleoff1 refid = "AHUAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás szellőztetőmotor ellenállás
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a szellőztetőmotor-ellenállását. 
<intxreftitleoff1 refid = "AHUAP70A7216012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás ventilátor fordulatszám-választó
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a szellőztetőventilátor-sebességválasztóját. 
<intxreftitleoff1 refid = "AHUAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás vezeték vagy testelés
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a vezetékeket.
</ptxt>
</action>
<ps>
<ptxt>
Hibás szellőztetőmotor
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a szellőztetőmotort. 
<intxreftitleoff1 refid = "AHUAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Idegen anyag van jelen
</ptxt>
</ps>
<action>
<ptxt>
Távolítsa el az idegen anyagot.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
