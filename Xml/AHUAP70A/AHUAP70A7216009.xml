<servinfo servinfosgmlid = "AHUAP70A7216009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Szellőztetőmotor le- és felszerelése
</title>
<servinfosub id = "AHUAP70A7216009001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a szellőztetőmotor (2) csatlakozóját (1).
</ptxt>
</s1>
<s1>
<ptxt>
Csavarja ki a csavarokat (3).
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a szellőztetőmotort (2) a HVAC egységről.
</ptxt>
<figure>
<graphic graphicname = "I4RS0B710005.swf" width = "88.000mm" height = "53.250mm" ver = "01" gw = "169" gh = "134"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A7216009002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
