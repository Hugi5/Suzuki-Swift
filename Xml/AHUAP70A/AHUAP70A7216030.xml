<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A7216030" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Oldalsó szellőzőnyílás le- és felszerelése
</title>
<servinfosub id = "AHUAP70A7216030001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Vezetőoldali: Vegye ki a műszeregység paneljét a műszerfalból. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Utasoldali: Vegye le az utasoldali légzsák fedelét. 
<intxreftitleoff1 refid = "AHUAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el oldalsó szellőzőnyílást. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Oldja ki a füleket (1), majd válassza le az oldalsó szellőzőnyílást (2) a műszerfal oldalpaneléről (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A721039.swf" width = "88.000mm" height = "68.687mm" ver = "01" gw = "177" gh = "178"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A7216030002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
