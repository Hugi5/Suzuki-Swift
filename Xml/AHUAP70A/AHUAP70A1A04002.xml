<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A1A04002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Hibajelenségek diagnosztizálása a generátornál
</title>
<ptxt>
A töltőrendszer zavarát az alábbi körülmények jelezhetik.
</ptxt>
<servinfosub id = "AHUAP70A1A04002001" page = "1">
<title>
Töltésre figyelmeztető lámpa működése
</title>
<diag type = "condition" id = "AHUAP70A1A04002002">
<condition>
<ptxt>
Bekapcsolt gyújtás és álló motor mellett a töltés figyelmeztető lámpa nem ég
</ptxt>
</condition>
<ps>
<ptxt>
Kiolvadt biztosíték
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a biztosítékot.
</ptxt>
</action>
<ps>
<ptxt>
Hibás műszeregység
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Cserélje ki a műszeregységet. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Hibás BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ellenőrizze a BCM-et. 
</ptxt>
<ptxt>
Gyújtáskapcsolóval szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Nyomógombos indítórendszerrel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Hibás CAN kommunikációs vezeték
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg, vagy cserélje ki a CAN kommunikációs vezetéket. 
<intxreftitleoff1 refid = "AHUAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás vezetékek
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a vezetéket.
</ptxt>
</action>
<ps>
<ptxt>
Hibás IC szabályozó vagy gerjesztőtekercs
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a generátort. 
<intxreftitleoff1 refid = "AHUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
A töltés figyelmeztető lámpa nem kapcsol ki, ha a motor jár (az akkumulátornak gyakori újratöltésre van szüksége).
</ptxt>
</condition>
<ps>
<ptxt>
Laza vagy kopott hajtószíj
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be vagy cserélje ki a hajtószíjat. 
<intxreftitleoff1 refid = "AHUAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás műszeregység
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Cserélje ki a műszeregységet. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Hibás BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ellenőrizze a BCM-et. 
</ptxt>
<ptxt>
Gyújtáskapcsolóval szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Nyomógombos indítórendszerrel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Hibás IC szabályozó vagy generátor
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a generátort. 
<intxreftitleoff1 refid = "AHUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás vezetékek
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a vezetéket.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHUAP70A1A04002003">
<title>
Akkumulátor töltési hiba
</title>
<diag type = "condition" id = "AHUAP70A1A04002004">
<condition>
<ptxt>
Gyenge akkumulátor
</ptxt>
</condition>
<ps>
<ptxt>
Laza vagy kopott hajtószíj
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be vagy cserélje ki a hajtószíjat. 
<intxreftitleoff1 refid = "AHUAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Laza vagy korrodált az akkumulátor érintkezője 
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg az akkumulátor érintkezőjét, vagy cserélje ki az akkumulátort. 
<intxreftitleoff1 refid = "AHUAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás egyenirányító, forgórész és/vagy IC szabályozó
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a generátort. 
<intxreftitleoff1 refid = "AHUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Túltöltött akkumulátor
</ptxt>
</condition>
<ps>
<ptxt>
Hibás IC szabályozó
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a generátort. 
<intxreftitleoff1 refid = "AHUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AHUAP70A1A04002005">
<title>
Zaj
</title>
<diag type = "condition" id = "AHUAP70A1A04002006">
<condition>
<ptxt>
Zajos generátor
</ptxt>
</condition>
<ps>
<ptxt>
Laza rögzítőcsavarok
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg a rögzítőcsavarokat. 
<intxreftitleoff1 refid = "AHUAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Szennyezett, kopott és/vagy hibás csapágyak
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a generátort. 
<intxreftitleoff1 refid = "AHUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Meghibásodott forgórész, dióda és/vagy állórész
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a generátort. 
<intxreftitleoff1 refid = "AHUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
