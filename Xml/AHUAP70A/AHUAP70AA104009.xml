<item>
<ptxt>
CAN kommunikációs áramkör
</ptxt>
</item>
<item>
<ptxt>
Műszeregység
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
