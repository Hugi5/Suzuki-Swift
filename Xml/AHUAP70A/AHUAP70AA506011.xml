<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70AA506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Kulcsnélküli ajtónyitó rendszer vevőjének le- és felszerelése
</title>
<servinfosub id = "AHUAP70AA506011001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a váltókonzolrekeszt. 
<intxreftitleoff1 refid = "AHUAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a kulcsnélküli ajtónyitó rendszer csatlakozóját (1).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a csavart (3), azután a kulcsnélküli ajtónyitó rendszer vevőegységét (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50030.swf" width = "88.000mm" height = "77.203mm" ver = "01" gw = "202" gh = "202"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70AA506011002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70AA506012">Kulcsnélküli ajtónyitó rendszer vevőjének ellenőrzése</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
