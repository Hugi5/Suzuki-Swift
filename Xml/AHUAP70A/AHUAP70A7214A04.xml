<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A7214A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nem jön meleg levegő, vagy a fűtés elégtelen (Nem megfelelő hőmérséklet-szabályozás)
</title>
<diag type = "condition">
<condition>
<ptxt>
Nem jön meleg levegő, vagy a fűtés elégtelen (Nem megfelelő hőmérséklet-szabályozás)
</ptxt>
</condition>
<ps>
<ptxt>
Megtört vagy hajlott hőmérséklet-szabályozó bowden
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a hőmérséklet-szabályozó bowdent.
</ptxt>
</action>
<ps>
<ptxt>
Hibás hőmérséklet-választó
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a hőmérséklet-választót.
</ptxt>
</action>
<ps>
<ptxt>
A hőmérséklet-szabályozó kábel helytelen beszerelése
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a bowden pozícióját, és ha szükséges, állítsa be azt.
</ptxt>
</action>
<ps>
<ptxt>
Törött hőmérséklet-szabályozó csappantyú egység
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a hőmérséklet-szabályozó csappantyút.
</ptxt>
</action>
<ps>
<ptxt>
Eltömődött légcsatornák
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a légcsatornákat.
</ptxt>
</action>
<ps>
<ptxt>
Szivárgó vagy eltömődött fűtőtest
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a fűtőtestet.
</ptxt>
</action>
<ps>
<ptxt>
Szivárgó vagy eltömődött fűtéstömlők
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a fűtés tömlőit.
</ptxt>
</action>
<ps>
<ptxt>
Hibás termosztát
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a termosztátot. 
<intxreftitleoff1 refid = "AHUAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás ECT érzékelő
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze az ECT érzékelőt. 
<intxreftitleoff1 refid = "AHUAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
