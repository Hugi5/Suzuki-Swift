<colspec colnum = "1" colname = "1" colwidth = "3.463in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Hézagolóalátét vastagsága = „b” mélység + „c” mélység – „a” távolság
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
