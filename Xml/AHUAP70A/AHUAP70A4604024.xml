<servinfosub id = "AHUAP70A4604024002">
<title>
DTC hibakeresés
</title>
<diag type = "test" id = "AHUAP70A4604024003">
<testgroup id = "AHUAP70A4604024004">
<question>
Végrehajtásra került az „ESP<sup>®</sup> rendszer ellenőrzése”?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 2. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Folytassa a következővel: 
<intxref refid = "AHUAP70A4604001">ESP® rendszer ellenőrzése</intxref>
 .
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A4604024005">
<title>
DTC ellenőrzése
</title>
<test1>
<ptxt>
Hajtsa végre a következőket: 
<intxref refid = "AHUAP70A4604005">DTC ellenőrzése</intxref>
.
</ptxt>
</test1>
<question>
Észlelt a C1038 hibakódon kívül más kívül hibakódot?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a vonatkozó DTC-hibaelhárítással.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Folytassa a 3. lépéssel.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A4604024006">
<title>
Kormányszög-érzékelő ellenőrzése
</title>
<test1>
<ptxt>
Győződjön meg arról, hogy a gyújtáskapcsoló „OFF” helyzetben van.
</ptxt>
</test1>
<test1>
<ptxt>
Cserélje ki a kormányszög-érzékelőt. 
<intxreftitleoff1 refid = "AHUAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Állítsa a gyújtást „ON” állásba.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze a DTC-t.
</ptxt>
</test1>
<question>
Észlelhető C1038 hibakód?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Cserélje ki az ESP<sup>®</sup> hidraulikaegységet / vezérlőmodul egységet, majd újból kérdezze le a DTC-ket. 
<intxreftitleoff1 refid = "AHUAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Vége.
</ptxt>
</action>
</testgroup>
</diag>
