<diag type = "test" id = "AHUAP70A7224023005">
<testgroup id = "AHUAP70A7224023006">
<title>
DTC ellenőrzése
</title>
<test1>
<ptxt>
Állítsa a gyújtást „ON” állásba.
</ptxt>
</test1>
<test1>
<ptxt>
Állítsa a gyújtást „OFF” helyzetbe.
</ptxt>
</test1>
<test1>
<ptxt>
Állítsa a gyújtást „ON” állásba, és ellenőrizze a DTC-ket.
</ptxt>
</test1>
<question>
Továbbra is észlelhető a B1540 DTC?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 2. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Időszakos hiba.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A7224023008">
<title>
A biztosíték ellenőrzése
</title>
<test1>
<ptxt>
Ellenőrizze az &#34;MTR&#34; biztosítékot.
</ptxt>
</test1>
<question>
Megfelelő az állapota?
</question>
<result>
Igen
</result>
<action>
<ptxt>
