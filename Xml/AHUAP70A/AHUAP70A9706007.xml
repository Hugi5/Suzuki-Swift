<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A9706007" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Hátsó ülés le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A9706006">Hátsó ülés elemei</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A9706007001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Távolítsa el a hátsó üléspárna egységek. 
<intxreftitleoff1 refid = "AHUAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az üléstámla egységeket. Ehhez szerelje ki a hátsó ülés csuklópántjának csavarjait. 
<intxreftitleoff1 refid = "AHUAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje szét és javítsa meg a hátsó ülést, ha szükséges. 
<intxreftitleoff1 refid = "AHUAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9706007002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
A meghúzási nyomatékokat lásd: 
<intxref refid = "AHUAP70A9706006">Hátsó ülés elemei</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
