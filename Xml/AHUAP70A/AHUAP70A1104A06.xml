</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHUAP70A1406041">Forgattyústengely-csapágyak ellenőrzése</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kopott forgattyústengelycsap
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHUAP70A1406040">A forgattyústengely ellenőrzése</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Laza csapágyfedél-csavarok
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AHUAP70A1406041">Forgattyústengely-csapágyak ellenőrzése</intxref>
</ptxt>
</action>
<ps>
<ptxt>
