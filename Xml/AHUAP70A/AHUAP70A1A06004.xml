<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1A06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Vízszivattyú/generátor hajtószíj ki- és beszerelése
</title>
<servinfosub id = "AHUAP70A1A06004001" page = "2">
<title>
Leszerelés
</title>
<s1 page = "2">
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki a motor jobb oldali alsó burkolatát.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Mielőtt eltávolítaná a vízszivattyú / generátor hajtószíját (1), távolítsa el a kompresszor hajtószíját.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manuális A/C-vel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Automata A/C-vel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Lazítsa meg a generátor csavart (2) és a generátorcsap-csavart (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Lazítsa meg a generátorrögzítő csavart (4), majd távolítsa el a vízszivattyú generátor hajtószíját.
</ptxt>
<figure>
<graphic graphicname = "I7V20A1A1008.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "148" gh = "123"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A1A06004002" page = "2">
<title>
Felszerelés
</title>
<s1 page = "2">
<ptxt>
Szerelje fel a vízszivattyú / generátor hajtószíjszíját (1), a vízszivattyú szíjtárcsájára (2), a forgattyústengely szíjtárcsájára (3) és a generátor szíjtárcsájára (4).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Állítsa be a szíj feszességét. 
<intxreftitleoff1 refid = "AHUAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje fel az A/C kompresszor hajtószíját.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manuális A/C-vel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Automata A/C-vel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Győződjön meg arról, hogy a hajtószíj megfelelően illeszkedik az egyes szíjtárcsák hornyaiba.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I7V20A1A1009.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "140" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje vissza a motor jobb oldali alsó burkolatát.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Csatlakoztassa a negatív (–) kábelt az akkumulátorhoz.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
