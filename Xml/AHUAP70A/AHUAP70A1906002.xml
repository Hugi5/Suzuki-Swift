<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Indítómotor le- és felszerelése
</title>
<servinfosub id = "AHUAP70A1906002001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Vegye le a szívócsonkot. 
<intxreftitleoff1 refid = "AHUAP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a kopogásérzékelő tartóját (1) a motorblokkról.
</ptxt>
<figure>
<graphic graphicname = "IAP70A190003.swf" width = "88.000mm" height = "58.388mm" ver = "01" gw = "172" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Válassza le a mágneskapcsoló fővezetékét (1) és az indítómotor kábelt (2) az indítómotorról.
</ptxt>
</s1>
<s1>
<ptxt>
Vegye ki az indítómotor rögzítőcsavarokat (3).
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le az indítómotort (4).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A190005.swf" width = "183.000mm" height = "82.031mm" ver = "02" gw = "405" gh = "216"/>
</figure>
</servinfosub>
<servinfosub id = "AHUAP70A1906002002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1906009">Az indítómotor ellenőrzése</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg az indítómotor rögzítőcsavarjait és az indítómotor kábelének anyáját az előírt nyomatékkal.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1I001">
<t-part>
Indítómotor-kábel anya
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1I002">
<t-part>
Indítómotor-rögzítőcsavar
</t-part>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
