<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A4104A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
A fék figyelmeztető lámpa (több mint 2 másodpercre) égve marad a gyújtás „ON” állásba kapcsolása után
</title>
<diag type = "condition">
<condition>
<ptxt>
A fék figyelmeztető lámpa (több mint 2 másodpercre) égve marad a gyújtás „ON” állásba kapcsolása után
</ptxt>
</condition>
<ps>
<ptxt>
Az ESP<sup>®</sup> vezérlőmodul csatlakozója nincs megfelelően csatlakoztatva
</ptxt>
</ps>
<action>
<ptxt>
Csatlakoztassa ismét az ESP<sup>®</sup> vezérlőmodul csatlakozóját.
</ptxt>
</action>
<ps>
<ptxt>
A rögzítőfék be van húzva
</ptxt>
</ps>
<action>
<ptxt>
Engedje ki a rögzítőféket, és ellenőrizze, hogy a figyelmeztető lámpa kialszik-e.
</ptxt>
</action>
<ps>
<ptxt>
Kevés a fékfolyadék
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a fékfolyadékszintet. 
<intxreftitleoff1 refid = "AHUAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Az ABS figyelmeztető lámpája villog
</ptxt>
</ps>
<action>
<ptxt>
Határozza meg a hiba helyét, majd javítsa ki a hibát. 
<intxreftitleoff1 refid = "AHUAP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás rögzítőfék kapcsoló és/vagy fékfolyadékszint-kapcsoló
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ellenőrizze a rögzítőfék kapcsolóját és/vagy a fékfolyadékszint-kapcsolót.
</ptxt>
<ptxt>
Rögzítőfék-kapcsoló: 
<intxreftitleoff1 refid = "AHUAP70A4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Fékfolyadékszint-kapcsoló: 
<intxreftitleoff1 refid = "AHUAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Hiba a CAN kommunikációs rendszerben
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a CAN kommunikációs rendszert. 
<intxreftitleoff1 refid = "AHUAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás műszeregység
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a műszeregységet. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Meghibásodott ESP<sup>®</sup> hidraulikaegység / vezérlőmodul
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az ESP<sup>®</sup> hidraulikaegységet / vezérlőmodult. 
<intxreftitleoff1 refid = "AHUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
