<servinfo servinfosgmlid = "AHUAP70A7216037" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
A kompresszor hajtószíjának le- és felszerelése
</title>
<servinfosub id = "AHUAP70A7216037004">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Lazítsa meg a szíjfeszítő tárcsa csavarját (1).
</ptxt>
</s1>
<s1>
<ptxt>
A szíjfeszítő tárcsa beállító csavarjának (2) lazításával lazítson a szíj feszességén.
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a kompresszor hajtószíjat (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A722023.swf" width = "88.000mm" height = "57.807mm" ver = "08" gw = "182" gh = "147"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A7216037001">
<title>
Felszerelés
</title>
<s1>
<ptxt>
Szerelje fel a kompresszor hajtószíját.
</ptxt>
</s1>
<s1>
<ptxt>
Állítsa be a szíj feszességét. 
<intxreftitleoff1 refid = "AHUAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
