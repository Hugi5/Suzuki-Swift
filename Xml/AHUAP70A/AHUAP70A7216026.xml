<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A7216026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Levegőbeszívás-szabályozó aktuátorának le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A7216020">HVAC vezérlőegység elemei:Manuális típus</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A7216026001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Távolítsa el a kesztyűtartót. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az utasoldali lábhoz vezető légcsatornát (2). 
<intxreftitleoff1 refid = "AHUAP70A7216011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a levegőbeszívás-szabályozó aktuátor csatlakozóját.
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a csavarokat (1).
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki a levegőbeszívás-szabályozó aktuátort (2) a HVAC egységről.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721028.jpg" width = "88.000mm" height = "68.236mm" ver = "01" gw = "142" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A7216026002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A7216027">Levegőbeszívás-szabályozó aktuátor ellenőrzése:Manuális típus</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Helyezze az összekötő-csapszeget (1) a levegőbeszívás-szabályozó aktuátorának hornyába (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A721029.swf" width = "88.000mm" height = "49.668mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
