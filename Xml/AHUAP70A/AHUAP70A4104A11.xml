<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A4104A11" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Az ESP® figyelmeztető lámpa (több mint 2 másodpercre) égve marad a gyújtás „ON” állásba kapcsolása után”
</title>
<diag type = "condition">
<condition>
<ptxt>
Az ESP® figyelmeztető lámpa (több mint 2 másodpercre) égve marad a gyújtás „ON” állásba kapcsolása után”
</ptxt>
</condition>
<ps>
<ptxt>
Meghibásodott ESP<sup>®</sup>
</ptxt>
</ps>
<action>
<ptxt>
Végezze el az ESP<sup>®</sup> rendszer ellenőrzését. 
<intxreftitleoff1 refid = "AHUAP70A4604001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ESP<sup>®</sup> vezérlőmodul táp- és testáramköri hiba
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze az ESP<sup>®</sup> vezérlőmodul táp- és testáramkörét. 
<intxreftitleoff1 refid = "AHUAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás műszeregység
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a műszeregységet. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Meghibásodott ESP<sup>®</sup> hidraulikaegység / vezérlőmodul
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az ESP<sup>®</sup> hidraulikaegységet / vezérlőmodult. 
<intxreftitleoff1 refid = "AHUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
