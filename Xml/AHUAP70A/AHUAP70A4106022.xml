<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Fékrásegítő le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A4106020">Fékrásegítő elemei</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A4106022001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Célszerszám használatával válassza le a fékcsöveket (1) az ESP<sup>®</sup> hidraulikaegység / vezérlőmodul egységről (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410035.swf" width = "88.000mm" height = "45.139mm" ver = "02" gw = "117" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el a főfékhenger egységet a fékrásegítőről.
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a vákuumtömlőt a fékrásegítőről.
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a rögzítőkapcsot (1) és a kengyelcsapszeget (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410036.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje ki a fékrásegítő anyáit (1), hogy eltávolíthassa a fékrásegítőt a szerelvényfalról.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410037.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A4106022004">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A4106023">Fékrásegítő vizsgálata</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Lazítsa meg a fékpedáltartó anyáját (1) és a motortérburkolat felső merevítőcsavarját (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje fel a fékrásegítőt a műszerfalra. Ezután csatlakoztassa a nyomórúdkengyelt (3) a fékpedálkarhoz a kengyelcsapszeg (2) és a rögzítőkapocs (1) segítségével.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410040.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el a műszeregység paneljét. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Húzza meg a fékrásegítő anyáit az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T4A006">
<t-part>
Fékrásegítő anya*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410041.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Húzza meg a fékpedáltartó anyáját az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
Fékpedáltartó anyája
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Húzza meg a motortérburkolat felső merevítőcsavarját az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
Motortérburkolat merevítőcsavarja
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410042.swf" width = "88.000mm" height = "64.412mm" ver = "02" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje fel a műszeregység paneljét.
</ptxt>
</s1>
<s1>
<ptxt>
Csatlakoztassa a vákuumtömlőt a fékrásegítőre.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje be a főfékhenger egységet a fékrásegítőre.
</ptxt>
</s1>
<s1>
<ptxt>
Csatlakoztassa a fékcsöveket (1) az ESP<sup>®</sup> hidraulikaegységhez / vezérlőmodul egységhez (2) célszerszám segítségével.
</ptxt>
<torque>
<torqueitem id = "T4A009">
<t-part>
Fékcső hollandi anya
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410043.swf" width = "88.000mm" height = "46.684mm" ver = "02" gw = "119" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Felszerelés után légtelenítse a fékrendszert. 
<intxreftitleoff1 refid = "AHUAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ellenőrizze, hogy nem szivárog-e a fékfolyadék a felszerelt alkatrészeknél.
</ptxt>
</s1>
<s1>
<ptxt>
Ellenőrizze a fékpedál holtjátékát. 
<intxreftitleoff1 refid = "AHUAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Győződjön meg arról, hogy a fékrendszer megfelelően működik, és nem szivárog a fékfolyadék.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
