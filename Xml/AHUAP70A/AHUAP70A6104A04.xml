<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A6104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
A kormányzás zajjal jár (kopogás vagy kotyogás)
</title>
<diag type = "condition">
<condition>
<ptxt>
A kormányzás zajjal jár (kopogás vagy kotyogás)
</ptxt>
</condition>
<ps>
<ptxt>
Kilazult kormányműház csavar
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg a kormányműház csavarját. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nem megfelelő a fogasléc és a fogaskerék fogainak kapcsolódása
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ellenőrizze a fogasléc és a fogaskerék tengelyének forgatónyomatékát. 
<intxreftitleoff1 refid = "AHUAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ha sérültek az alkatrészek, cserélje ki a kormányműház egységet. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Hibás kormányműház egység
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kormányműház egységet. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Törött vagy sérült kerékcsapágy(ak)
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kerékcsapágya(ka)t. 
<intxreftitleoff1 refid = "AHUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott kormányösszekötő gömbfej vagy kormányösszekötő rúd belső gömbcsukló
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Cserélje ki a kormányösszekötő gömbfejet vagy a kormányösszekötő rudat.
</ptxt>
<ptxt>
Kormányösszekötő gömbfej: 
<intxreftitleoff1 refid = "AHUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Kormányösszekötő rúd: 
<intxreftitleoff1 refid = "AHUAP70A6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
