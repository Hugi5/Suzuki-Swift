<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A7214A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
A levegőbeszívást szabályozó csappantyú helyzete a levegőbeszívás módjának megváltoztatásakor sem változik
</title>
<diag type = "condition">
<condition>
<ptxt>
A levegőbeszívást szabályozó csappantyú helyzete a levegőbeszívás módjának megváltoztatásakor sem változik
</ptxt>
</condition>
<ps>
<ptxt>
Kiolvadt biztosíték
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a megfelelő biztosítékokat, majd azt, hogy nincs-e testzárlat.
</ptxt>
</action>
<ps>
<ptxt>
Eltörött a levegőbeszívás-szabályozó csappantyú
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a levegőbeszívást szabályozó csappantyút.
</ptxt>
</action>
<ps>
<ptxt>
Hibás levegőbeszívás-szabályozó aktuátor
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a levegőbeszívó-szabályozó aktuátorát. 
<intxreftitleoff1 refid = "AHUAP70A7216027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás levegőbeszívás-kapcsoló
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a levegőbeszívás-kapcsolót. 
<intxreftitleoff1 refid = "AHUAP70A7216025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás vezeték vagy testelés
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a vezetékeket.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
