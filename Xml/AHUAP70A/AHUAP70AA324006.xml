<servinfo servinfosgmlid = "AHUAP70AA324006" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1610
</title>
<servinfosub id = "AHUAP70AA324006001">
<title>
DTC észlelésének körülményei és a hiba helye
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.281in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.924in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC észlelésének körülményei
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
A hiba helye
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1610: Az indításgátló azonosítója nem regisztrált
</emph>
</ptxt>
<ptxt>
Az indításgátlóazonosító kódja nincs regisztrálva.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Az ECM azonosító kódja nincs regisztrálva a kulcsnélküli indítás vezérlőmodulban
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
CAN kommunikációs áramkör / csatlakozó
</ptxt>
</item>
<item>
<ptxt>
A CAN kommunikációs vezetékhez csatlakoztatott vezérlőmodul
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHUAP70AA324006002">
<title>
DTC hibakeresés
</title>
<diag type = "test" id = "AHUAP70AA324006003">
<testgroup id = "AHUAP70AA324006005">
<title>
DTC ellenőrzése
</title>
<test1>
<ptxt>
Ellenőrizze a DTC-t a kulcsnélküli indítás vezérlőmodulban. 
<intxreftitleoff1 refid = "AHUAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Továbbra is észlelhető a DTC B1173, B1175 vagy B1176?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa az érintett DTC-hez tartozó hibaelhárítással.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Folytassa a 2. lépéssel.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70AA324006004">
<title>
ECM regisztrálása
</title>
<test1>
<ptxt>
Hajtsa végre a következőket: 
<intxref refid = "AHUAP70AA326003">ECM regisztrálása:Nyomógombos indítórendszerrel szerelt modell</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze újból a DTC-t. 
<intxreftitleoff1 refid = "AHUAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Továbbra is észlelhető a P1610 DTC?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 3. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Vége. (Nem került ECM regisztrálásra)
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70AA324006006">
<title>
DTC ellenőrzése
</title>
<test1>
<ptxt>
Ellenőrizze a CAN kommunikációval kapcsolatos DTC-ket.
</ptxt>
</test1>
<question>
Észlelt valamilyen CAN hibakódot?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa az érintett DTC-hez tartozó hibaelhárítással.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Cserélje ki az ECM-et, és ismételje meg a DTC-k ellenőrzését. 
<intxreftitleoff1 refid = "AHUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
