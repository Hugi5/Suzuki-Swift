<ptxt>
Nem áramlik ki időnként hideg levegő
</ptxt>
</condition>
<ps>
<ptxt>
Hibás vezeték-csatlakozás
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a vezetékeket.
</ptxt>
</action>
<ps>
<ptxt>
