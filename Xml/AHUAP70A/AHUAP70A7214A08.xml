<intxreftitleoff1 refid = "AHUAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Túl sok a hűtőközeg
</ptxt>
</ps>
<action>
<ptxt>
