<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1A06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Az akkumulátor le- és felszerelése
</title>
<servinfosub id = "AHUAP70A1A06002001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt (1) az akkumulátorról (4).
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a pozitív (+) kábelt (2) az akkumulátorról (4).
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a rögzítőt (3).
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le az akkumulátort (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0001.swf" width = "88.000mm" height = "71.286mm" ver = "01" gw = "171" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje le az akkumulátortálcát (1).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az ECM-et (2). 
<intxreftitleoff1 refid = "AHUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az akkumulátortartó konzolt (3), ha szükséges.
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0002.jpg" width = "88.000mm" height = "55.738mm" ver = "02" gw = "199" gh = "141"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A1A06002002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg erősen az akkumulátorkábeleket.
</ptxt>
</item>
<item>
<ptxt>
Szükség esetén állítsa be az elektromos berendezések alaphelyzetét.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
