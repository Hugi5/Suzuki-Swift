<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1606015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
A hűtő le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1606014">A járműre szerelt hűtő ellenőrzése és tisztítása</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A1606015001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Vegye le a hűtőventilátor egységet. 
<intxreftitleoff1 refid = "AHUAP70A1606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Távolítsa el az A/C hűtő egységet. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manuális A/C-vel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70A7216006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Automata A/C-vel szerelt modell: 
<intxreftitleoff1 refid = "AHUAP70A7226006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Szerelje le a hűtő kivezető tömlőjét a hűtőről.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a hűtő felső tartókonzoljait (1).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el hűtőt (2) a járműből.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160007.jpg" width = "88.000mm" height = "62.569mm" ver = "01" gw = "193" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A1606015002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Töltse fel a rendszert hűtőfolyadékkal. 
<intxreftitleoff1 refid = "AHUAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ellenőrizze a hűtőrendszer szivárgását. 
<intxreftitleoff1 refid = "AHUAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
