<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A2104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kagylósan kopott gumiabroncsok
</title>
<diag type = "condition">
<condition>
<ptxt>
Kagylósan kopott gumiabroncsok
</ptxt>
</condition>
<ps>
<ptxt>
Elállítódott kerékbeállítás
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a kerékbeállítást, és ha kell, állítsa be újra. 
<intxreftitleoff1 refid = "AHUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás első rugóstag 
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az első rugóstagot. 
<intxreftitleoff1 refid = "AHUAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott kerékcsapágyak
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kerékcsapágyakat. 
<intxreftitleoff1 refid = "AHUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Túl nagy gumiabroncs- vagy kerékütés
</ptxt>
</ps>
<action>
<ptxt>
Javítsa vagy cserélje ki a gumiabroncsot és/vagy a kereket.
</ptxt>
</action>
<ps>
<ptxt>
Kopott lengőkar gömbfejek
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a lengőkart. 
<intxreftitleoff1 refid = "AHUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A kerék nincs kiegyensúlyozva
</ptxt>
</ps>
<action>
<ptxt>
Egyensúlyozza ki vagy cserélje ki a gumiabroncsot.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
