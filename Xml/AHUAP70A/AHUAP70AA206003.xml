<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70AA206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
BCM le- és felszerelése
</title>
<servinfosub id = "AHUAP70AA206003001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Iktassa ki a légzsákrendszert. 
<intxreftitleoff1 refid = "AHUAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a kormányoszlop üregének burkolatát, lásd: 
<intxref refid = "AHUAP70A6206009">Kormányoszlop le- és felszerelése</intxref>
 , 4. lépés.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a műszerfal oldalsó burkolatot. 
<intxreftitleoff1 refid = "AHUAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a csatlakozókat (1) és a bilincseket az elosztódobozról (2).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az anyákat (3) és ezután vegye ki az elosztódobozt.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20016.jpg" width = "88.000mm" height = "78.207mm" ver = "01" gw = "202" gh = "205"/>
</figure>
</s1>
<s1>
<ptxt>
Válassza le a csatlakozókat (1) a BCM-ről (2).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a BCM anyáit (3), majd vegye ki a BCM-et.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20017.jpg" width = "88.000mm" height = "82.962mm" ver = "01" gw = "198" gh = "219"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70AA206003002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.	
</ptxt>
</servinfosub>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg a BCM összes anyáját az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T10B001">
<t-part>
BCM anya
</t-part>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Helyezze üzembe a légzsákrendszert. 
<intxreftitleoff1 refid = "AHUAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ha kicseréli a BCM-et, hajtsa végre a következőt: 
<intxref refid = "AHUAP70AA206002">BCM regisztrálás (gyújtáskapcsolóval szerelt modell)</intxref>
 .
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
