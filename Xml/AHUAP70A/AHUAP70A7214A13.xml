<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A7214A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Zaj hallható bizonyos fordulatszámon, a sebességtől függetlenül
</title>
<servinfosub id = "AHUAP70A7214004001">
<title>
Rendellenes zaj a kompresszorból
</title>
<diag type = "condition">
<condition>
<ptxt>
Zaj hallható bizonyos fordulatszámon, a sebességtől függetlenül
</ptxt>
</condition>
<ps>
<ptxt>
Laza vagy hibás kompresszor hajtószíj
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a kompresszor hajtószíját. 
<intxreftitleoff1 refid = "AHUAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lazítsa meg a kompresszor felerősítő csavarjait.
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg újra a felerősítő csavarokat. 
<intxreftitleoff1 refid = "AHUAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
