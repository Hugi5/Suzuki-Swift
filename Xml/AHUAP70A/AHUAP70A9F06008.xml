<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A9F06008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
USB aljzat le- és felszerelése
</title>
<servinfosub id = "AHUAP70A9F06008001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Szerelje le a váltókonzolrekeszt. 
<intxreftitleoff1 refid = "AHUAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a középső oldalfedelet. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le az USB aljzat csatlakozóját (1), majd szerelje ki az USB aljzatot (2) a műszerfalból (3), a reteszek kioldásával (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0014.jpg" width = "88.000mm" height = "55.000mm" ver = "02" gw = "206" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9F06008002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A9F06009">USB aljzat átvizsgálása</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
