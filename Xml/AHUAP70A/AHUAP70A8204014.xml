<servinfosub id = "AHUAP70A8204014003">
<title>
DTC hibakeresés
</title>
<diag type = "test" id = "AHUAP70A8204014004">
<testgroup id = "AHUAP70A8204014005">
<question>
Megtörtént a “Légzsák diagnosztikai rendszerének ellenőrzése”?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 2. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Folytassa a következővel: 
<intxref refid = "AHUAP70A8204001">Légzsák diagnosztikai rendszerének ellenőrzése</intxref>
 .
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A8204014006">
<title>
Utasoldali légzsák kiiktatás visszajelző lámpa áramkörének ellenőrzése
</title>
<test1>
<ptxt>
Győződjön meg arról, hogy a gyújtás „OFF” állásban található.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze, hogy megfelelő-e az érintkezés a „G153” csatlakozónál.
</ptxt>
</test1>
<test1>
<ptxt>
Válassza le a „G153” csatlakozót.
</ptxt>
</test1>
<test1>
<ptxt>
Állítsa a gyújtást „ON” állásba.
</ptxt>
</test1>
<test1>
<ptxt>
Mérje meg a feszültséget a „G153-9” érintkező és a testelés között.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B004">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820109.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</test1>
<question>
A mért feszültség 10 – 14 V?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 3. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Cserélje ki a műszerfal vezetékkötegét.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A8204014007">
<title>
Utasoldali légzsák kiiktatás visszajelző lámpa áramkörének ellenőrzése
</title>
<test1>
<ptxt>
Állítsa a gyújtást „OFF” állásba.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze, hogy megfelelő-e az érintkezés a „G11” csatlakozónál.
</ptxt>
</test1>
<test1>
<ptxt>
Válassza le a “G11” csatlakozót.
</ptxt>
</test1>
<test1>
<ptxt>
Mérje meg az ellenállást a „G153-10” és a „G11-15” érintkező között.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B005">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820110.swf" width = "90.000mm" height = "48.716mm" ver = "01" gw = "188" gh = "122"/>
</testfigure>
</test1>
