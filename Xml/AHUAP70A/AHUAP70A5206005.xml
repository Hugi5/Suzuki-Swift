<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A5206005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Sebességváltó kar és kábel le- és felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A5206004">Sebességváltó kar és bowdenek alkatrészei</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A5206005001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Távolítsa el az ECM-et az akkumulátortálcáról. 
<intxreftitleoff1 refid = "AHUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki az akkumulátort és az akkumulátor-tálcát. 
<intxreftitleoff1 refid = "AHUAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az első padlóbeli váltókonzolrekeszt. 
<intxreftitleoff1 refid = "AHUAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a fokozatkapcsoló és fokozatválasztó bowdenek végeit (5) a sebességváltó kar egység csapjáról (6).
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a fokozatkapcsoló és fokozatválasztó bowdeneket (1) a sebességváltó kar egységről (2), miközben a gyorscsatlakozót (4) az ábrán látható nyíl irányába húzza.
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az anyákat (3), majd a szerelje le a sebességváltó kar egységet a padlólemezről.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520038.swf" width = "88.000mm" height = "74.693mm" ver = "01" gw = "187" gh = "195"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.933in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
7.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Csapszeg
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Válassza le a fokozatkapcsoló és fokozatválasztó bowdeneit a sebességváltóról.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki a bowden-átvezető csavarját, majd szerelje ki a fokozatkapcsoló és fokozatválasztó kábeleket a padlólemezről.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A5206005002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg az összes csavart és anyát az előírt nyomatékkal. 
<intxreftitleoff1 refid = "AHUAP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Állítsa be a fokozatválasztó bowdent. 
<intxreftitleoff1 refid = "AHUAP70A5206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
