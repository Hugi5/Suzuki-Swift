<servinfo servinfosgmlid = "AHUAP70A7214A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
A rendszer nem fúj hideg levegőt (a hűtőventilátor motorja nem működik)
</title>
<diag type = "condition">
<condition>
<ptxt>
A rendszer nem fúj hideg levegőt (a hűtőventilátor motorja nem működik)
</ptxt>
</condition>
<ps>
<ptxt>
Kiolvadt biztosíték
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a megfelelő biztosítékokat, majd azt, hogy nincs-e testzárlat.
</ptxt>
</action>
<ps>
<ptxt>
Hibás vezeték vagy testelés
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a vezetékeket.
</ptxt>
</action>
<ps>
<ptxt>
Hibás a hűtőventilátor motorjának reléje
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a hűtőventilátor relét. 
<intxreftitleoff1 refid = "AHUAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A hűtőventilátor motorja meghibásodott.
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ellenőrizze a hűtőventilátor motort. 
<intxreftitleoff1 refid = "AHUAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Hibás ECM
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze az ECM-et. 
<intxreftitleoff1 refid = "AHUAP70A7214017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
