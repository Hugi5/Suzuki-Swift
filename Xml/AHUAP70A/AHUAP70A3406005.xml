<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A3406005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Tengelykapcsoló szét- és összeszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A3406004">Kardántengely egység szét- és összeszerelése</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A3406005001">
<title>
Szétszerelés
</title>
<s1>
<ptxt>
Távolítsa el a rögzítőgyűrűt a tengelykapcsoló tengelyéről rögzítőgyűrű-fogóval.
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a viszkózus tengelykapcsolót (1) a tengelykapcsoló tengelyéről (2) hidraulikus prés (3) és lehúzó segítségével (4).
</ptxt>
<figure>
<graphic graphicname = "I5RS0D340007.swf" width = "88.000mm" height = "49.401mm" ver = "01" gw = "114" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A3406005002">
<title>
Összeszerelés
</title>
<s1>
<ptxt>
Célszerszám és hidraulikus prés segítségével szerelje fel a viszkózus tengelykapcsolót (1) a tengelykapcsoló tengelyére (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L3D001">
<s-part>
(A)
</s-part>
<s-number num = "09922-55131">
09922-55131
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A340010.swf" width = "88.000mm" height = "50.636mm" ver = "01" gw = "94" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Szereljen fel új rögzítőgyűrűt a középső tengelyre rögzítő-gyűrűfogóval.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
