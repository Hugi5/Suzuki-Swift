<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A7226009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Automatikus A/C paneljének le- és felszerelése
</title>
<servinfosub id = "AHUAP70A7226009001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az első padlóbeli váltókonzolrekeszt. 
<intxreftitleoff1 refid = "AHUAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a műszeregység paneljét és a középső szellőzőnyílást. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki az audioegységet. 
<intxreftitleoff1 refid = "AHUAP70A9F06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vegye ki az utasoldali légzsák (felfúvó) modult. 
<intxreftitleoff1 refid = "AHUAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a középső oldalfedeleket. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az automatikus A/C paneljét (1) a műszerfalból.
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le az automatikus A/C panel csatlakozóját.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723013.swf" width = "88.000mm" height = "64.865mm" ver = "03" gw = "233" gh = "167"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A7226009002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
