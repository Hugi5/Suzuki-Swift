<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A9606014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Csomagtérajtó nyitókapcsoló le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A9606013">Csomagtérajtó nyitókapcsoló ellenőrzése beszerelt állapotban</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A9606014001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Vegye le a csomagtérajtó burkolatát. 
<intxreftitleoff1 refid = "AHUAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a csomagtérajtó nyitókapcsolójának csatlakozóját (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el a csomagtérajtó alsó panelét. 
<intxreftitleoff1 refid = "AHUAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a csavarokat (1), majd a csomagtérajtó nyitókapcsolóját (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A960020.jpg" width = "88.000mm" height = "57.494mm" ver = "01" gw = "194" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9606014002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
