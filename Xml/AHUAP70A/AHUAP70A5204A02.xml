<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nehéz kapcsolás
</title>
<diag type = "condition">
<condition>
<ptxt>
Nehéz kapcsolás
</ptxt>
</condition>
<ps>
<ptxt>
Nem megfelelő kenőanyag
</ptxt>
</ps>
<action>
<ptxt>
Töltsön be kézi sebességváltóhoz való olaj.
</ptxt>
</action>
<ps>
<ptxt>
Nem megfelelő a tengelykapcsoló pedál holtjátéka
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Cserélje ki a tengelykapcsoló pedál karját vagy a tengelykapcsoló-főhengert. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tengelykapcsoló pedál kar: 
<intxreftitleoff1 refid = "AHUAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tengelykapcsoló-főhenger: 
<intxreftitleoff1 refid = "AHUAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Elgörbült vagy törött tengelykapcsoló-tárcsa
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tengelykapcsoló-tárcsát. 
<intxreftitleoff1 refid = "AHUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sérült a tengelykapcsoló nyomólapja
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tengelykapcsoló-fedelet. 
<intxreftitleoff1 refid = "AHUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott szinkrongyűrű
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Cserélje ki a szinkrongyűrűt.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Alacsony sebesség fokozatok szinkrongyűrűje és 2. fokozat szinkrongyűrűje: 
<intxreftitleoff1 refid = "AHUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Magas sebesség fokozatok szinkrongyűrűje: 
<intxreftitleoff1 refid = "AHUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5. fokozat szinkrongyűrűje: 
<intxreftitleoff1 refid = "AHUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Kopott leélezett fogazás a hüvelyen vagy a fogaskeréken
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Cserélje ki a szinkronhüvely-agy egységet és a fogaskereket.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Előtéttengely 1. fogaskerék és 2. fogaskerék: 
<intxreftitleoff1 refid = "AHUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Behajtótengely 3. és 4. fogaskereke: 
<intxreftitleoff1 refid = "AHUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Behajtótengely 5. fogaskereke: 
<intxreftitleoff1 refid = "AHUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Alacsony sebességfokozatok szinkron kapcsolóhüvelye és agya: 
<intxreftitleoff1 refid = "AHUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Magas sebesség fokozatok szinkronhüvelye és agya: 
<intxreftitleoff1 refid = "AHUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5. fokozat szinkronhüvelye és agya: 
<intxreftitleoff1 refid = "AHUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
A kapcsolótengely csuklójának perselye elhasználódott
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kapcsolótengely csuklójának perselyét. 
<intxreftitleoff1 refid = "AHUAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformálódott kapcsolótengely
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Cserélje ki a kapcsolóvillát vagy a kapcsolótengelyt.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Alacsony sebességfokozatok kapcsolótengelye: 
<intxreftitleoff1 refid = "AHUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Magas sebességfokozatok kapcsolótengelye: 
<intxreftitleoff1 refid = "AHUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5. fokozat kapcsolóvilla: 
<intxreftitleoff1 refid = "AHUAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Törött fokozatkapcsoló / fokozatválasztó bowdenek
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a fokozatkapcsoló és fokozatválasztó bowdeneket. 
<intxreftitleoff1 refid = "AHUAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
