<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A7214A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nem áramlik ki hideg levegő vagy elégtelen a hűtés (a mágneskapcsoló megfelelően működik)
</title>
<diag type = "condition">
<condition>
<ptxt>
Nem áramlik ki hideg levegő vagy elégtelen a hűtés (a mágneskapcsoló megfelelően működik)
</ptxt>
</condition>
<ps>
<ptxt>
Elégtelen vagy túlzott mennyiségű hűtőközeg
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a hűtőközeg mennyiségét és a rendszert szivárgás szempontjából.
</ptxt>
</action>
<ps>
<ptxt>
Eltömődött kondenzátor
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze az A/C hűtőt. 
<intxreftitleoff1 refid = "AHUAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Eltömődött vagy befagyott A/C párologtató
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Ellenőrizze az A/C párologtatót és a párologtató hőmérséklet-érzékelőjét.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
A/C párologtató: 
<intxreftitleoff1 refid = "AHUAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Párologtató hőmérséklet-érzékelő: 
<intxreftitleoff1 refid = "AHUAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Hibás párologtató hőmérséklet-érzékelő
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a párologtató hőmérséklet-érzékelőjét. 
<intxreftitleoff1 refid = "AHUAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás expanziós szelep
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze az expanziós szelepet. 
<intxreftitleoff1 refid = "AHUAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Laza vagy szakadt a kompresszor hajtószíja
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a kompresszor hajtószíját. 
<intxreftitleoff1 refid = "AHUAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A mágneses tengelykapcsoló csúszik
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a mágneses tengelykapcsolót. 
<intxreftitleoff1 refid = "AHUAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás kompresszor
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a kompresszort.
</ptxt>
</action>
<ps>
<ptxt>
Levegő az A/C rendszerben
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az A/C hűtőt, majd végezze el az ürítést, és a hűtőközeg feltöltését. 
<intxreftitleoff1 refid = "AHUAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Levegő szivárog a HVAC egységből vagy a légcsatornából
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a HVAC egységet vagy a légcsatornát.
</ptxt>
</action>
<ps>
<ptxt>
Hibás fűtő és hűtőrendszer
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a HVAC egységet.
</ptxt>
</action>
<ps>
<ptxt>
Hibás szellőztetőmotor
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a szellőztetőmotort. 
<intxreftitleoff1 refid = "AHUAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Túl sok kompresszorolaj az A/C rendszerben
</ptxt>
</ps>
<action>
<ptxt>
Eressze le a felesleges kompresszorolajat az A/C körből és a kompresszorból.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
