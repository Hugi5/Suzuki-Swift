<emph etype = "bold">
B1188: Transzponder kommunikációs hiba
</emph>
</ptxt>
<ptxt>
Ellenőrzési hiba a gyújtáskulcs és a BCM között.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
A gyújtáskulcs nincs regisztrálva
</ptxt>
</item>
<item>
<ptxt>
Gyújtáskulcs 
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
