<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A6306006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Kormányműház perselyének le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A6306001">Kormányműház egység elemei</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
A kormányműház egyik perselyének cseréjekor a másik oldali perselyt is mindig cserélje ki.
</ptxt>
</attention2>
<servinfosub id = "AHUAP70A6306006001">
<title>
Leszerelés 
</title>
<s1>
<ptxt>
Távolítsa el a kormányműház egységet. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vágja le késsel a kormányműház mindegyik perselyének peremes (gumi) részét (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A630023.swf" width = "88.000mm" height = "51.406mm" ver = "01" gw = "234" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Tolja ki a kormányműház perselyét (1) hidraulikus prés (2) és célszerszám segítségével.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C004">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C005">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630024.swf" width = "88.000mm" height = "49.527mm" ver = "01" gw = "104" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A6306006002">
<title>
Felszerelés
</title>
<s1>
<ptxt>
Sajtolja be a kormányműház perselyét (1) célszerszámok és hidraulikus prés (2) segítségével.
</ptxt>
<attention2>
<ptxt>
Ne használja fel újra a kormányműház perselyét.
</ptxt>
</attention2>
<servicetool>
<servicetoolitem id = "L6C006">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C007">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<attention3>
<ptxt>
Felszerelés előtt kenje meg szappanos vízzel a kormányműház perselyét, mert ez megkönnyíti a behelyezést.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A630025.swf" width = "88.000mm" height = "51.452mm" ver = "01" gw = "104" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
A kormányműház perselyét (1) úgy sajtolja a helyére, hogy az ábrán jelölt „a” és „b” távolságok megegyezzenek egymással.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje fel a kormányműház egységet. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
