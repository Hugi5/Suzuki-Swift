<servinfo servinfosgmlid = "AHUAP70A1406045" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Lendítőkerék ellenőrzése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1406021">Lendítőkerék le- és felszerelése</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A1406045001">
<title>
Szemrevételezés
</title>
<list1 type = "unordered">
<item>
<ptxt>
Ha a fogaskoszorú sérült, repedt vagy kopott, cserélje ki a lendkereket.
</ptxt>
</item>
<item>
<ptxt>
Ha a tengelykapcsoló-tárcsával érintkező felület sérült vagy túlzottan kopott, cserélje ki a lendkereket.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "AHUAP70A1406045002">
<title>
Lendítőkerék homloksíkjának ütése
</title>
<ptxt>
Indikátorórával ellenőrizze a lendkerék homloksíkjának ütését. 
</ptxt>
<ptxt>
Ha az ütés meghaladja a határértéket, cserélje ki a lendkereket.
</ptxt>
<spec>
<title>
Lendítőkerék/hajtótárcsa homloksíkjának ütése
</title>
<ptxt>
Határérték: 0,2 mm (0,0079 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I2RH01140198.swf" width = "88.000mm" height = "42.110mm" ver = "01" gw = "183" gh = "102"/>
</figure>
</servinfosub>
</servinfo>
