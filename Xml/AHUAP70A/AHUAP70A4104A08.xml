<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A4104A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Fékezési zaj
</title>
<diag type = "condition">
<condition>
<ptxt>
Fékezési zaj
</ptxt>
</condition>
<ps>
<ptxt>
Kifényesedett fékbetét
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a fékbetéteket és/vagy a fékpofákat.
</ptxt>
</action>
<ps>
<ptxt>
Kilazult első és/vagy hátsó kerékcsapágyak
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kerékagyat.
</ptxt>
</action>
<ps>
<ptxt>
A fékpajzslemezek elgörbültek vagy a rögzítőcsavarok kilazultak
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki vagy húzza meg a rögzítőcsavarokat.
</ptxt>
</action>
<ps>
<ptxt>
A kopásjelző a féktárcsához ér
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a fékbetéteket.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
