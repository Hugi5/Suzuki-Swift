</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141003.swf" width = "88.000mm" height = "64.914mm" ver = "01" gw = "140" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje be az üzemanyag-befecskendezőket. 
<intxreftitleoff1 refid = "AHUAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje be a kipufogócsonkot. 
<intxreftitleoff1 refid = "AHUAP70A1B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
