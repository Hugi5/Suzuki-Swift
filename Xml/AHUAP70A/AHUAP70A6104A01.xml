<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A6104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Nehéz kormányzás
</title>
<diag type = "condition">
<condition>
<ptxt>
Nehéz kormányzás
</ptxt>
</condition>
<ps>
<ptxt>
Elégtelen abroncsnyomás
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be a gumiabroncsok nyomását.
</ptxt>
</action>
<ps>
<ptxt>
A szervokormányrendszer működési hibája
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze és javítsa ki. 
<intxreftitleoff1 refid = "AHUAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Szorul a kormányösszekötő gömbfej csuklója
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kormányösszekötő gömbfejet. 
<intxreftitleoff1 refid = "AHUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Szorul a lengőkar gömbcsuklója
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a lengőkart. 
<intxreftitleoff1 refid = "AHUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Elállítódott az első kerékbeállítás
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze az első kerekek beállítását, és ha kell, állítsa be újra. 
<intxreftitleoff1 refid = "AHUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Szorul a kormányoszlop
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kormányoszlopot. 
<intxreftitleoff1 refid = "AHUAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nem megfelelő a fogasléc és a fogaskerék fogainak kapcsolódása
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ellenőrizze a fogasléc és a fogaskerék tengelyének forgatónyomatékát. 
<intxreftitleoff1 refid = "AHUAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ha sérültek az alkatrészek, cserélje ki a kormányműház egységet. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
