<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A5304A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Súrlódó tengelykapcsoló
</title>
<diag type = "condition">
<condition>
<ptxt>
Súrlódó tengelykapcsoló
</ptxt>
</condition>
<ps>
<ptxt>
Nem megfelelő a tengelykapcsoló pedál holtjátéka
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Cserélje ki a tengelykapcsoló pedált és/vagy a tengelykapcsoló-főhengert.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tengelykapcsoló pedál kar: 
<intxreftitleoff1 refid = "AHUAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tengelykapcsoló-főhenger: 
<intxreftitleoff1 refid = "AHUAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Meggyengült hasított tányérrugó, vagy kopottak a rugólamellák végei
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tengelykapcsoló-fedelet. 
<intxreftitleoff1 refid = "AHUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A behajtótengely bordái rozsdásak
</ptxt>
</ps>
<action>
<ptxt>
Kenje meg a behajtótengely bordáit.
</ptxt>
</action>
<ps>
<ptxt>
A sebességváltó behajtótengelyének bordái sérültek vagy kopottak
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a behajtótengelyt. 
<intxreftitleoff1 refid = "AHUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Erősen imbolygó tengelykapcsoló-tárcsa
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tengelykapcsoló-tárcsát. 
<intxreftitleoff1 refid = "AHUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A tengelykapcsoló-tárcsa felületei repedtek vagy olajosak
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tengelykapcsoló-tárcsát. 
<intxreftitleoff1 refid = "AHUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Folyadékszivárgás
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a tengelykapcsoló rendszert.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
