<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A7224010" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
DTC törlése
</title>
<servinfosub id = "AHUAP70A7224010001">
<title>
SUZUKI vizsgálókészülék használatával
</title>
<s1>
<ptxt>
Állítsa a gyújtást „OFF” helyzetbe.
</ptxt>
</s1>
<s1>
<ptxt>
Csatlakoztassa a SUZUKI vizsgálókészüléket a DLC (1) csatlakozóhoz, amely a vezető oldalán, a műszerfal alatt található.
</ptxt>
<servicetool>
<servicetoolitem id = "L7B209">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI vizsgálókészülék (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A723002.jpg" width = "88.000mm" height = "67.502mm" ver = "03" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Állítsa a gyújtást „ON” állásba.
</ptxt>
</s1>
<s1>
<ptxt>
Törölje a DTC-t a SUZUKI vizsgálókészüléken megjelenő utasításoknak megfelelően.
</ptxt>
<attention3>
<ptxt>
A SUZUKI vizsgálókészülék használatával kapcsolatban lásd annak használati útmutatóját.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Miután törölte a DTC-t, végezze el a következő műveletet: „DTC ellenőrzés”, majd győződjön meg arról, hogy normál DTC (No code) kerül kijelzésre.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Kapcsolja a gyújtást „OFF” állásba, azután válassza le a SUZUKI vizsgálókészüléket a DLC-ről.
</ptxt>
</s1>
</servinfosub>
<c-change/>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
