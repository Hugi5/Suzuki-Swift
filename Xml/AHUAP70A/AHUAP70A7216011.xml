<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A7216011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Szellőztetőmotor-ellenállás le- és felszerelése
</title>
<servinfosub id = "AHUAP70A7216011001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki a kesztyűtartót a műszerfalból. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le az utasoldali lábhoz vezető légcsatornát (2) a HVAC egységről. Ehhez csavarja ki a csavart (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A721036.jpg" width = "88.000mm" height = "94.268mm" ver = "01" gw = "199" gh = "251"/>
</figure>
</s1>
<s1>
<ptxt>
Válassza le a csatlakozót (1) a szellőztetőmotor-ellenállásról (2), majd távolítsa el a szellőztetőmotor-ellenállást a HVAC egységről, a csavarok (3) eltávolításával.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A710010.swf" width = "88.000mm" height = "53.049mm" ver = "01" gw = "183" gh = "134"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A7216011002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
