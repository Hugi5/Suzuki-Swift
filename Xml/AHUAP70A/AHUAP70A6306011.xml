<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A6306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Szervokormány-vezérlő modul le- és felszerelése
</title>
<servinfosub id = "AHUAP70A6306011001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a műszerfalat. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a fékpedál egységet. 
<intxreftitleoff1 refid = "AHUAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a csatlakozókat (1) a szervokormány-vezérlő modulról (2).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a szervokormány-vezérlő modul csavarjait (3) a kormánytámaszról.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630037.swf" width = "88.000mm" height = "94.023mm" ver = "01" gw = "148" gh = "250"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el a szervokormány-vezérlő modult.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A6306011002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg a szervokormány-vezérlő modul csavarjait az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T6C006">
<t-part>
Szervokormány-vezérlő modul rögzítőcsavarja
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,0
</t-value1>
<t-value2>
0,51
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A630034.swf" width = "88.000mm" height = "98.099mm" ver = "02" gw = "148" gh = "262"/>
</figure>
</item>
<item>
<ptxt>
Szerelje be a fékpedál egységet. 
<intxreftitleoff1 refid = "AHUAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
