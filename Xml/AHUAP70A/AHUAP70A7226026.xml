<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A7226026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Levegőbeszívás-szabályozó aktuátorának le- és felszerelése
</title>
<servinfosub id = "AHUAP70A7226026001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Iktassa ki a légzsákrendszert. 
<intxreftitleoff1 refid = "AHUAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vegye le a kormányoszlop üregének burkolatát. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a térdlégzsák (felfúvó) modult. 
<intxreftitleoff1 refid = "AHUAP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki a kormányoszlopot. 
<intxreftitleoff1 refid = "AHUAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a fékpedál egységet. 
<intxreftitleoff1 refid = "AHUAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a csavarokat (1), azután szerelje ki a légáram-szabályozó aktuátort (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A722011.jpg" width = "88.000mm" height = "63.150mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A7226026002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A7226027">Légáram-szabályozó aktuátor ellenőrzése:Automata típus</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Helyezze az összekötő csapszeget (2) a légáram-szabályozó aktuátor karjának furatába (1).
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722012.swf" width = "88.000mm" height = "68.493mm" ver = "02" gw = "234" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
