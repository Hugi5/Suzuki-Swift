<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70AA504012" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1123
</title>
<servinfosub id = "AHUAP70AA504012001">
<title>
DTC észlelésének körülményei és a hiba helye
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.461in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.744in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC észlelésének körülményei
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
A hiba helye
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1123: Tartalék áramforrás hibás működése
</emph>
</ptxt>
<ptxt>
A &#34;DOME&#34; biztosítéktól érkező biztonsági tápáramkör feszültsége alacsonyabb az előírt értéknél.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
„DOME” biztosíték
</ptxt>
</item>
<item>
<ptxt>
Minden rendszer a &#34;DOME&#34; biztosítékon át csatlakozik
</ptxt>
</item>
<item>
<ptxt>
Kulcsnélküli indítás vezérlőmodulja
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHUAP70AA504012002">
<title>
DTC megerősítési eljárás
</title>
<s1>
<ptxt>
Állítsa a gyújtást „ON” állásba.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70AA504012003">
<title>
DTC hibakeresés
</title>
<diag type = "test" id = "AHUAP70AA504012004">
<testgroup id = "AHUAP70AA504012005">
<title>
A biztosíték ellenőrzése
</title>
<test1>
<ptxt>
Győződjön meg arról, hogy a gyújtáskapcsoló „OFF” helyzetben van.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze a &#34;DOME&#34; biztosítékot.
</ptxt>
</test1>
<question>
Megfelelő az állapota?
</question>
<result type = "yes"/>
<action>
<ptxt>
Cserélje ki a kulcsnélküli indítás vezérlőmodulját, és ismételje meg a DTC ellenőrzést. 
<intxreftitleoff1 refid = "AHUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Cserélje ki a „DOME&#34; biztosítékot, majd folytassa a 2. lépéssel.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70AA504012006">
<title>
DTC ellenőrzése
</title>
<test1>
<ptxt>
Állítsa a gyújtást „ON” állásba.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze a DTC-t. 
<intxreftitleoff1 refid = "AHUAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Továbbra is észleli a B1123 számú hibakódot?
</question>
<result type = "yes"/>
<action>
<ptxt>
Folytassa a 3. lépéssel.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vége.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70AA504012007">
<title>
Minden rendszer ellenőrzése a &#34;DOME&#34; biztosítékon át csatlakozik
</title>
<test1>
<ptxt>
Ellenőrizze a &#34;DOME&#34; biztosítékkal összekapcsolt rendszereket, a kulcsnélküli indítás vezérlőmodult kivéve.
</ptxt>
</test1>
<question>
Megfelelő az állapota?
</question>
<result type = "yes"/>
<action>
<ptxt>
Cserélje ki a „DOME&#34; biztosítékot és a kulcsnélküli indítás vezérlőmodulját, és ismételje meg a DTC ellenőrzést. 
<intxreftitleoff1 refid = "AHUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a hibás alkatrészt és/vagy vezetékköteget, majd cserélje ki a &#34;DOME&#34; biztosítékot, és ellenőrizze újra a DTC-t.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
