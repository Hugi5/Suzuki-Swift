<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1306019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
CKP érzékelő le- és felszerelése
</title>
<servinfosub id = "AHUAP70A1306019001" page = "2">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a generátort. 
<intxreftitleoff1 refid = "AHUAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vegye le a CKP érzékelő csatlakozóját.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a CKP érzékelőt (1) a motorblokkról.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A131017.jpg" width = "88.000mm" height = "57.392mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</servinfosub>
<servinfosub id = "AHUAP70A1306019002" page = "2">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1306020">CKP érzékelő ellenőrzése</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kenje be motorolajjal az érzékelő O-gyűrűjét.
</ptxt>
</item>
<item>
<ptxt>
Húzza meg a CKP érzékelő csavarját az előírt nyomatékkal.
</ptxt>
<attention2>
<ptxt>
Ügyeljen arra, hogy új, előzetesen ragasztóval bevont csavarokat használjon. Ellenkező esetben a csavarok kilazulhatnak.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T1C007">
<t-part>
CKP érzékelő csavar
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131008.jpg" width = "88.000mm" height = "57.393mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</item>
<item>
<ptxt>
Tegye vissza a csatlakozót, és a bilinccsel szilárdan rögzítse a vezetékköteget.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
