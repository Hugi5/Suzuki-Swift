<servinfo servinfosgmlid = "AHUAP70A4104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Elégtelen fékerő
</title>
<diag type = "condition">
<condition>
<ptxt>
Elégtelen fékerő
</ptxt>
</condition>
<ps>
<ptxt>
Fékfolyadék szivárog a fékvezetékekből
</ptxt>
</ps>
<action>
<ptxt>
Keresse meg a szivárgás helyét, és javítsa ki.
</ptxt>
</action>
<ps>
<ptxt>
A féktárcsa, vagy betét foltokban szennyezett folyadékkal, zsírral, vagy más olajjal
</ptxt>
</ps>
<action>
<ptxt>
Tisztítsa meg vagy cserélje ki.
</ptxt>
</action>
<ps>
<ptxt>
A fékek túlmelegedtek
</ptxt>
</ps>
<action>
<ptxt>
Keresse meg az okot, és javítsa ki.
</ptxt>
</action>
<ps>
<ptxt>
Erősen kopott fékbetétek
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki.
</ptxt>
</action>
<ps>
<ptxt>
Féknyereg-egység működési hibája
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg vagy cserélje ki.
</ptxt>
</action>
<ps>
<ptxt>
A rendszer levegős
</ptxt>
</ps>
<action>
<ptxt>
Légtelenítse a fékrendszert.
</ptxt>
</action>
<ps>
<ptxt>
Fékrásegítő belső hibája
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a fékrásegítőt.
</ptxt>
</action>
<ps>
<ptxt>
A fékrásegítő vákuumnyomása elégtelen
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a motor állapotát és a vákuumtömlőt.
</ptxt>
</action>
<ps>
<ptxt>
ESP<sup>®</sup> működési hiba
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze, és szükség esetén cserélje ki a rendszer.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
