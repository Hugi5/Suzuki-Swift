<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Csúszás
</title>
<diag type = "condition">
<condition>
<ptxt>
Csúszás
</ptxt>
</condition>
<ps>
<ptxt>
Nem megfelelő a tengelykapcsoló pedál holtjátéka
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Cserélje ki a tengelykapcsoló pedált és/vagy a tengelykapcsoló-főhengert.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tengelykapcsoló pedál kar: 
<intxreftitleoff1 refid = "AHUAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tengelykapcsoló-főhenger: 
<intxreftitleoff1 refid = "AHUAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Kopott vagy olajos a tengelykapcsoló-tárcsa felülete
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tengelykapcsoló-tárcsát. 
<intxreftitleoff1 refid = "AHUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Deformálódott a tengelykapcsoló-tárcsa, a nyomólap vagy a lendítőkerék felülete
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Cserélje ki a tengelykapcsoló-tárcsát, a tengelykapcsoló-fedelet vagy a lendítőkereket.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tengelykapcsoló-tárcsa és fedél: 
<intxreftitleoff1 refid = "AHUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Lendítőkerék: 
<intxreftitleoff1 refid = "AHUAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Meggyengült hasított tányérrugó
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tengelykapcsoló-fedelet. 
<intxreftitleoff1 refid = "AHUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A főhenger dugattyúja vagy a dugattyútömítés beszorult
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tengelykapcsoló-főhengert. 
<intxreftitleoff1 refid = "AHUAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
