<servinfo servinfosgmlid = "AHUAP70A5206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Tolatólámpa-kapcsoló le- és felszerelése
</title>
<servinfosub id = "AHUAP70A5206007001">
<title>
Leszerelés
</title>
<s1 page = "2">
<ptxt>
Távolítsa el az ECM-et az akkumulátortálcáról. 
<intxreftitleoff1 refid = "AHUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki az akkumulátort és az akkumulátor-tálcát. 
<intxreftitleoff1 refid = "AHUAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a tolatólámpa-kapcsoló csatlakozóját (1).
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki a tolatólámpa-kapcsolót (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A520006.jpg" width = "88.000mm" height = "56.038mm" ver = "01" gw = "199" gh = "142"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A5206007002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A5206008">Tolatólámpa-kapcsoló ellenőrzése</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Kenje be olajjal az új O-gyűrűt (1), és húzza meg a tolatólámpa-kapcsolót (2) az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T5B004">
<t-part>
Tolatólámpa-kapcsoló
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I3RH0A520006.swf" width = "88.000mm" height = "31.317mm" ver = "01" gw = "148" gh = "73"/>
</figure>
</s1>
<s1>
<ptxt>
Csatlakoztassa a tolatólámpa-kapcsoló csatlakozóját.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje be az akkumulátortálcát és az akkumulátort. 
<intxreftitleoff1 refid = "AHUAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje az ECM-et az akkumulátortálcára. 
<intxreftitleoff1 refid = "AHUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
