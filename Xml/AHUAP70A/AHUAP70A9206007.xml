<servinfo servinfosgmlid = "AHUAP70A9206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rendszámtábla-világítás le- és felszerelése
</title>
<servinfosub id = "AHUAP70A9206007001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Távolítsa el a csomagtérajtó alsó panelének csavarjait (1), majd vegye le a csomagtérajtó alsó panelét (2).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a rendszámtábla-világítást (3).
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a rendszámtábla-világítás csatlakozóját.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920001.jpg" width = "88.000mm" height = "80.485mm" ver = "01" gw = "211" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el az izzót.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9206007002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg a csomagtérajtó alsó panelének csavarjait az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T9B001">
<t-part>
Csomagtérajtó alsó panelének csavarja
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A920002.jpg" width = "88.000mm" height = "80.884mm" ver = "01" gw = "211" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
