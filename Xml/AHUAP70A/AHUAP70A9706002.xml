<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A9706002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Első ülés le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A9706001">Első ülés elemei</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A9706002001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Iktassa ki a légzsákrendszert. 
<intxreftitleoff1 refid = "AHUAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le a csatlakozókat az első ülésről.
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a 4 db rögzítőcsavart, majd szerelje ki az ülés egységet.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje szét és javítsa meg az alkatrészeket, ha szükséges. 
<intxreftitleoff1 refid = "AHUAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9706002002">
<title>
Felszerelés
</title>
<ptxt>
A felszerelést a leszerelés műveleteinek a fordított sorrendjében hajtsa végre, figyelembe véve az alábbiakat.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
A meghúzási nyomatékokat lásd: 
<intxref refid = "AHUAP70A9706001">Első ülés elemei</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Helyezze üzembe a légzsákrendszert. 
<intxreftitleoff1 refid = "AHUAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
