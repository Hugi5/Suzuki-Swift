<intxreftitleoff1 refid = "AHUAP70A1906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A fogaskoszorú fogai elkoptak
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a lendítőkereket. 
<intxreftitleoff1 refid = "AHUAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
