<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A6104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Félrehúzás vagy nem megfelelő úttartás
</title>
<diag type = "condition">
<condition>
<ptxt>
Félrehúzás vagy nem megfelelő úttartás
</ptxt>
</condition>
<ps>
<ptxt>
Nem összeillő abroncsok vagy nem egyforma abroncsnyomások
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az abroncsot vagy állítsa be az abroncsnyomást. 
<intxreftitleoff1 refid = "AHUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kilazult lengőkarcsukló és kormányösszekötő gömbfej
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Cserélje ki a lengőkart vagy a kormányösszekötő gömbfejet.
</ptxt>
<ptxt>
Lengőkar: 
<intxreftitleoff1 refid = "AHUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Kormányösszekötő gömbfej: 
<intxreftitleoff1 refid = "AHUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Meghibásodott az első rugóstag vagy annak rögzítése
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az első rugóstag egységet, vagy javítsa meg a rögzítését. 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kilazult stabilizátorrúd
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg vagy cserélje ki a stabilizátorrudat vagy a perselyt. 
<intxreftitleoff1 refid = "AHUAP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Törött vagy megereszkedett tekercsrugó
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a tekercsrugót. 
<intxreftitleoff1 refid = "AHUAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Meghibásodott első rugóstag (lengéscsillapító)
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki az első rugóstagot (lengéscsillapító). 
<intxreftitleoff1 refid = "AHUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nem megfelelő a fogasléc és a fogaskerék fogainak kapcsolódása
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ellenőrizze a fogasléc és a fogaskerék tengelyének forgatónyomatékát. 
<intxreftitleoff1 refid = "AHUAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ha sérültek az alkatrészek, cserélje ki a kormányműház egységet. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Elállítódott az első kerékbeállítás
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze az első kerekek beállítását, és ha kell, állítsa be újra. 
<intxreftitleoff1 refid = "AHUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás kormányműház egység
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kormányműház egységet. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
