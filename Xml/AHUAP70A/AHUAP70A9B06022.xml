<servinfo servinfosgmlid = "AHUAP70A9B06022" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Hátsó padló hátsó panel le- és felszerelése
</title>
<attention3>
<ptxt>
Az alábbi ábrán mutatott állapotban a következő alkatrészek le vannak szerelve.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Első sárvédő 
<intxreftitleoff1 refid = "AHUAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hátpanel 
<intxreftitleoff1 refid = "AHUAP70A9B06021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0166.jpg" width = "88.000mm" height = "48.926mm" ver = "02" gw = "227" gh = "122"/>
</figure>
<servinfosub id = "AHUAP70A9B06022001">
<title>
Kiszerelés
</title>
<s1>
<ptxt>
Fúrja ki a hegesztési pontokat, és távolítsa el a hátsó padló hátsó paneljét.
</ptxt>
<attention3>
<ptxt>
Hajtsa ki a hátsó padlólemez középső panel peremének mindkét végét, ha szükséges.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A9B0018.jpg" width = "183.000mm" height = "184.007mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A9B06022002">
<title>
Felszerelés
</title>
<attention3>
<ptxt>
Mielőtt a hegesztést megkezdené, ellenőrizze a felszerelendő alkatrészek felszerelési helyzetét és állapotát. 
<intxreftitleoff1 refid = "AHUAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1 page = "1">
<ptxt>
Szerelje fel a pótkeréktartót és a szerszámtáska-tartót.
</ptxt>
</s1>
<s1 page = "1">
<ptxt>
Végezzen ellenállás-ponthegesztést.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0168.jpg" width = "183.000mm" height = "100.573mm" ver = "01" gw = "495" gh = "269"/>
</figure>
</s1>
<s1 page = "1">
<ptxt>
Szerelje fel a hátsó padlólemez hátsó paneljét.
</ptxt>
<attention3>
<ptxt>
Hajtsa be a hátsó padlólemez középső panel peremének mindkét végét, ha szükséges.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Végezzen ellenállás-ponthegesztést és lyukhegesztést.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0019.jpg" width = "183.000mm" height = "183.872mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
