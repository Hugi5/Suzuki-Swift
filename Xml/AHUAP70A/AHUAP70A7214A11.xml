<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A7214A11" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Elégtelen mennyiségű hideg levegő
</title>
<diag type = "condition">
<condition>
<ptxt>
Elégtelen mennyiségű hideg levegő
</ptxt>
</condition>
<ps>
<ptxt>
Eltömődött vagy befagyott A/C párologtató
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ellenőrizze az A/C párologtatót és a párologtató hőmérséklet-érzékelőjét.
</ptxt>
<ptxt>
- A/C párologtatója: 
<intxreftitleoff1 refid = "AHUAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Párologtató hőmérséklet-érzékelő: 
<intxreftitleoff1 refid = "AHUAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Levegő szivárog a HVAC egységből vagy a légcsatornából
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a HVAC egységet vagy a légcsatornát.
</ptxt>
</action>
<ps>
<ptxt>
Hibás szellőztetőmotor
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a szellőztetőmotort. 
<intxreftitleoff1 refid = "AHUAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibás vezeték vagy testelés
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg a vezetékeket.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
