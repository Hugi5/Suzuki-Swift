<servinfo servinfosgmlid = "AHUAP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Differenciálmű oldalsó szimeringjének cseréje
</title>
<s1>
<ptxt>
Emelje fel a járművet, és eressze le a sebességváltó-olajat.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje ki a bal oldali féltengely-egységet. 
<intxreftitleoff1 refid = "AHUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a szimeringet (1) célszerszámot használva.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522004.swf" width = "88.000mm" height = "48.454mm" ver = "01" gw = "146" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje be az új szimeringet (1) célszerszám használatával.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Ügyeljen arra, hogy a szimeringet a rugós részével befelé szerelje be.
</ptxt>
</item>
<item>
<ptxt>
Ügyeljen arra, hogy a szimeringet a bal házfél (2) felületével párhuzamosan szereli be.
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
09944-88220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
A ház felülete és a szimering közötti távolság
</title>
<ptxt>
„a”: 0 – 1,0 mm (0 – 0,04 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Kenje be zsírral a szimering peremét, és ellenőrizze, hogy a féltengely szimeringgel érintkező része sima-e.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B004" uid = "22">
<m-part>
„A”
</m-part>
<m-desc>
Kenőzsír
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A522005.swf" width = "88.000mm" height = "44.718mm" ver = "02" gw = "110" gh = "110"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje be a bal oldali féltengely egységet. 
<intxreftitleoff1 refid = "AHUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Töltse fel a sebességváltót olajjal. 
<intxreftitleoff1 refid = "AHUAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
