<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A3204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Fogaskerékzaj
</title>
<diag type = "condition">
<condition>
<ptxt>
Fogaskerékzaj
</ptxt>
</condition>
<ps>
<ptxt>
Elhasználódott vagy vízzel keveredett kenőanyag
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg, és pótolja a kenőanyagot. 
<intxreftitleoff1 refid = "AHUAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nem megfelelő vagy nem elegendő kenőanyag
</ptxt>
</ps>
<action>
<ptxt>
Javítsa meg, és pótolja a kenőanyagot. 
<intxreftitleoff1 refid = "AHUAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hibásan beállított foghézag a kis kúpkerék és a tányér-kúpkerék között
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be az előírás szerint. 
<intxreftitleoff1 refid = "AHUAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nem megfelelő fogérintkezés a kis kúpkerék és a tányér-kúpkerék kapcsolódásánál
</ptxt>
</ps>
<action>
<ptxt>
Állítsa be vagy cserélje ki. 
<intxreftitleoff1 refid = "AHUAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Laza tányér-kúpkerék-rögzítőcsavarok
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki, vagy húzza meg. 
<intxreftitleoff1 refid = "AHUAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sérült oldalsó fogaskerekek vagy bolygókerekek
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki. 
<intxreftitleoff1 refid = "AHUAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
