<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A4604034" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1090 / C1091 / C1094
</title>
<servinfosub id = "AHUAP70A4604034001">
<title>
DTC észlelésének körülményei és a hiba helye
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.780in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.399in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC észlelésének körülményei
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
A hiba helye
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1090: Az ECM körbefordulás számlálási hibát észlel az ESP<sup>®</sup> vezérlőmodulból
</emph>
</ptxt>
<ptxt>
Az ESP<sup>®</sup> vezérlőmodul érvénytelen CAN adatokat küld az ECM-nek.
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
CAN kommunikációs áramkör
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>®</sup> vezérlőmodul
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1091: Érvénytelen CAN adat az ECM-től
</emph>
</ptxt>
<ptxt>
Az ECM-re vonatkozó DTC észlelhető.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1094: Nyomaték igény elutasítási állapot
</emph>
</ptxt>
<ptxt>
Az ESP<sup>®</sup> vezérlőmodul érvénytelen CAN adatokat fogad az ECM-től. (a motor nyomaték-vezérlésével kapcsolatban).
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AHUAP70A4604034002">
<title>
DTC hibakeresés
</title>
<diag type = "test" id = "AHUAP70A4604034003">
<testgroup id = "AHUAP70A4604034004">
<question>
Végrehajtásra került az „ESP<sup>®</sup> rendszer ellenőrzése”?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 2. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Folytassa a következővel: 
<intxref refid = "AHUAP70A4604001">ESP® rendszer ellenőrzése</intxref>
 .
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A4604034005">
<title>
DTC ellenőrzése
</title>
<test1>
<ptxt>
Hajtsa végre a következőket: 
<intxref refid = "AHUAP70A4604005">DTC ellenőrzése</intxref>
.
</ptxt>
</test1>
<question>
Található a C1090, C1091 vagy C1094 hibakódon kívül más kívül más DTC is?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a vonatkozó DTC-hibaelhárítással.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Folytassa a 3. lépéssel.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A4604034006">
<title>
Ellenőrizze az ECM DTC-it.
</title>
<test1>
<ptxt>
Ellenőrizze a DTC-t az ECM-ben. 
<intxreftitleoff1 refid = "AHUAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
DTC U0073 vagy U0121 észlelhető?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Lásd: 
<intxref refid = "AHUAP70AA804004">Hibaelhárítás „Kommunikációs busz kikapcsolva” állapot esetén</intxref>
 vagy 
<intxref refid = "AHUAP70AA804003">Hibaelhárítás Nincs kommunikáció esetén</intxref>
.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Cserélje ki az ESP<sup>®</sup> hidraulikaegységet / vezérlőmodul egységet, majd újból kérdezze le a DTC-ket. 
<intxreftitleoff1 refid = "AHUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
