<graphic graphicname = "I9P60A531019.swf" width = "88.000mm" height = "78.419mm" ver = "02" gw = "238" gh = "206"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Kicsit zsírozza meg a behajtótengelyt (1), majd illessze össze a kézi sebességváltót a motorral. 
<intxreftitleoff1 refid = "AHUAP70A5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
