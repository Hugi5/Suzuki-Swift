<servinfo servinfosgmlid = "AHUAP70A1104011" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
A MIL lámpa nem gyullad ki, amikor a gyújtás „ON” helyzetben van és a motor áll (de a motort el lehet indítani)
</title>
<servinfosub id = "AHUAP70A1104011001">
<title>
Hibaelhárítás
</title>
<diag type = "test" id = "AHUAP70A1104011002">
<testgroup id = "AHUAP70A1104011003">
<title>
DTC ellenőrzése
</title>
<test1>
<ptxt>
Ellenőrizze a CAN kommunikációval kapcsolatos DTC-ket.
</ptxt>
</test1>
<question>
Észlelt valamilyen CAN hibakódot?
</question>
<result type = "yes"/>
<action>
<ptxt>
Folytassa az érintett DTC-hez tartozó hibaelhárítással.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Folytassa a 2. lépéssel.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A1104011004">
<title>
DTC ellenőrzése
</title>
<test1>
<ptxt>
Ellenőrizze a műszeregységre vonatkozó DTC-ket.
</ptxt>
</test1>
<question>
Észlelhető valamilyen DTC?
</question>
<result type = "yes"/>
<action>
<ptxt>
Folytassa az érintett DTC-hez tartozó hibaelhárítással.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Cserélje ki az ECM-et, és ismételje meg a MIL működésének ellenőrzését. 
<intxreftitleoff1 refid = "AHUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
