<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1406020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
OCV le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1406017">A vezérműlánc-burkolat elemei</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A1406020001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le az szívó oldali OCV csatlakozót (fekete) (1) és a kipufogó oldali OCV csatlakozót (kék) (2).
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a szívó oldali OCV-t (3) és a kipufogó oldali OCV-t (4) a vezérműlánc-burkolatról.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141060.jpg" width = "88.000mm" height = "58.155mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A1406020002">
<title>
Felszerelés
</title>
<ptxt>
A felszereléshez fordított sorrendben hajtsa végre a leszerelés műveleteit, figyelembe véve az alábbiakat:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Húzza meg az OCV csavarjait az előírt nyomatékkal.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1D013">
<t-part>
OCV csavar
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
