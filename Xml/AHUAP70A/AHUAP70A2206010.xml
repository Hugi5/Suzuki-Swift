<section sectnbr = "2B">
<servcat sctnbr = "02" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A2206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Lengőkar első perselyének le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A2206008">Lengőkar le- és felszerelése</intxrefpoff>
</ptxt>
<attention3>
<ptxt>
A lengőkar hátsó perselye külön nem cserélhető. Ha a persely tönkrement, cserélje ki a lengőkart.
</ptxt>
</attention3>
<servinfosub id = "AHUAP70A2206010001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Vágja le késsel az első lengőkar első perselyének (gumi) (1) peremét (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A220022.jpg" width = "88.000mm" height = "56.949mm" ver = "01" gw = "238" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Tolja ki az első lengőkar első perselyét (1) hidraulikus prés (2) és célszerszámok segítségével.
</ptxt>
<servicetool>
<servicetoolitem id = "L2B003">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L2B004">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A220023.swf" width = "88.000mm" height = "48.435mm" ver = "01" gw = "173" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A2206010002">
<title>
Felszerelés
</title>
<s1>
<ptxt>
Sajtolja a helyére a lengőkar első perselyét (1) célszerszámok és hidraulikus prés (2) használatával.
</ptxt>
<attention2>
<ptxt>
Ne használja fel újra a perselyt.
</ptxt>
</attention2>
<attention3>
<ptxt>
Felszerelés előtt kenje meg szappanos vízzel a persely kerületét, mert ez megkönnyíti a behelyezést.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L2B005">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L2B006">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A220024.swf" width = "88.000mm" height = "48.773mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Préselje a helyére a perselyt (1) úgy, hogy az ábrán jelölt „a” és „b&#34; méretek megegyezzenek egymással.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
