<servinfosub id = "AHUAP70A4604020003">
<title>
DTC hibakeresés
</title>
<diag type = "test" id = "AHUAP70A4604020004">
<testgroup id = "AHUAP70A4604020005">
<question>
Végrehajtásra került az „ESP<sup>®</sup> rendszer ellenőrzése”?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 2. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Folytassa a következővel: 
<intxref refid = "AHUAP70A4604001">ESP® rendszer ellenőrzése</intxref>
 .
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A4604020006">
<title>
ESP® kiiktató kapcsoló ellenőrzése
</title>
<test1>
<ptxt>
Győződjön meg arról, hogy a gyújtáskapcsoló „OFF” helyzetben van.
</ptxt>
</test1>
<test1>
<ptxt>
Távolítsa el az ESP<sup>®</sup> kiiktató kapcsolóját. 
<intxreftitleoff1 refid = "AHUAP70A4606017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze az ESP<sup>®</sup> kiiktató kapcsoló egyes érintkezőinek megfelelő csatlakozását.
</ptxt>
</test1>
<test1>
<ptxt>
Ha a csatlakozások megfelelők, ellenőrizze az ESP<sup>®</sup> kiiktató kapcsolót. 
<intxreftitleoff1 refid = "AHUAP70A4606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Az ellenőrzés eredménye megfelelő?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 3. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Cserélje ki az ESP<sup>®</sup> kiiktató kapcsolót.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A4604020007">
<title>
ESP® kiiktató kapcsoló áramkörének ellenőrzése
</title>
<test1>
<ptxt>
Válassza le az „E24” csatlakozót.
</ptxt>
</test1>
<test1>
<ptxt>
Ellenőrizze, hogy megfelelő-e a csatlakozás az „E24-38” érintkezőhöz.
</ptxt>
</test1>
<test1>
<ptxt>
Ha a csatlakozás megfelelő, ellenőrizze az ellenállást az „E24-38” érintkező és a testelés között.
</ptxt>
</test1>
<question>
Az ellenállás végtelen nagy?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Cserélje ki az ESP<sup>®</sup> hidraulikaegységet / vezérlőmodul egységet, majd újból kérdezze le a DTC-ket. 
<intxreftitleoff1 refid = "AHUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Javítsa meg vagy cserélje ki az „A1” áramkört, ha az zárlatos.
</ptxt>
</action>
</testgroup>
</diag>
