<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AHUAP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Oldalirányú kilengés (szitálás), rázkódás vagy rezgés
</title>
<diag type = "condition">
<condition>
<ptxt>
Oldalirányú kilengés (szitálás), rázkódás vagy rezgés
</ptxt>
</condition>
<ps>
<ptxt>
A kerék nincs kiegyensúlyozva
</ptxt>
</ps>
<action>
<ptxt>
Egyensúlyozza ki a kereke(ke)t, vagy cseréljen gumiabroncso(ka)t és/vagy kereke(ke)t.
</ptxt>
</action>
<ps>
<ptxt>
Lógó kerékcsapágyak
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kerékcsapágyakat. 
<intxreftitleoff1 refid = "AHUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott kormányösszekötő gömbfej
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a kormányösszekötő gömbfejeket. 
<intxreftitleoff1 refid = "AHUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kopott lengőkar gömbfejek
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a lengőkart. 
<intxreftitleoff1 refid = "AHUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Túl nagy gumiabroncs- vagy kerékütés
</ptxt>
</ps>
<action>
<ptxt>
Javítsa vagy cserélje ki a kereket és/vagy a gumiabroncsot.
</ptxt>
</action>
<ps>
<ptxt>
Hólyag vagy kidudorodás a gumiabroncson
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a gumiabroncsot. 
<intxreftitleoff1 refid = "AHUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A gumiabroncs / kerék egység túlzott sugárirányú ütése
</ptxt>
</ps>
<action>
<ptxt>
Cserélje ki a gumiabroncsot vagy a kereket.
</ptxt>
</action>
<ps>
<ptxt>
Elállítódott kerékbeállítás
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a kerékbeállítást, és ha kell, állítsa be újra. 
<intxreftitleoff1 refid = "AHUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kilazult vagy kopott kormányrudazat
</ptxt>
</ps>
<action>
<ptxt>
Ellenőrizze a kormányrendszert. 
<intxreftitleoff1 refid = "AHUAP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kilazultak a kormányműház csavarjai
</ptxt>
</ps>
<action>
<ptxt>
Húzza meg a kormányműház csavarjait. 
<intxreftitleoff1 refid = "AHUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
