<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A1506004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Olajteknő és olajszivattyú-szűrő le- és felszerelése
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A1506003">Az olajteknő és az olajszivattyú-szűrő elemei</intxrefpoff>
</ptxt>
<servinfosub id = "AHUAP70A1506004001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Vegye ki a nívópálcát.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Szerelje ki a motor jobb oldali alsó burkolatát.
</ptxt>
</s1>
<s1>
<ptxt>
A leeresztőcsavar kiszerelésével eressze le a motorolajat.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le az 1. sz. kipufogócsövet. 
<intxreftitleoff1 refid = "AHUAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az osztóművet. 
<intxreftitleoff1 refid = "AHUAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el az olajszűrőt. 
<intxreftitleoff1 refid = "AHUAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Távolítsa el a sebességváltó csavarjait (1) és az olajteknő csavarjait (2).
</ptxt>
<figure>
<graphic graphicname = "I7V20A151012.swf" width = "88.000mm" height = "49.208mm" ver = "01" gw = "227" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje ki az olajteknőt (1) a motorblokkból célszerszám és kalapács segítségével.
</ptxt>
<servicetool>
<servicetoolitem id = "L1E005">
<s-part>
(A)
</s-part>
<s-number num = "09921-96510">
09921-96510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A151013.swf" width = "88.000mm" height = "49.206mm" ver = "02" gw = "230" gh = "123"/>
</figure>
</s1>
<c-change/>
<s1 page = "2">
<ptxt>
Vegye ki az olajszivattyú szűrőjét, ha szükséges.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Vegye ki az olajteknő terelőlemezét és az olajteknő terelőlemez tőcsavarjait, ha szükséges.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A1506004002">
<title>
Felszerelés
</title>
<s1>
<ptxt>
Ha eltávolította, szerelje vissza az olajteknő terelőlemezének tőcsavarját (1), majd húzza meg az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T1E004">
<t-part>
Olajteknő terelőlemez tőcsavarja
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Szerelje fel az olajteknő terelőlemezét (2), majd húzza meg az olajteknő terelőlemezének csavarjait (3) az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T1E005">
<t-part>
Az olajteknő-terelőlemez csavarja
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure page = "2">
<graphic graphicname = "I9P60A151002.swf" width = "88.000mm" height = "50.955mm" ver = "01" gw = "177" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Kenje be motorolajjal az új O-gyűrűt (1), majd szerelje be az olajszivattyú-szűrőbe (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Szerelje fel az olajszivattyú-szűrőt az O-gyűrűvel együtt az olajszivattyúra, majd húzza meg először a csavart (3) aztán az anyát (4) az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T1E006">
<t-part>
Olajszivattyú-szűrő csavarja
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1E007">
<t-part>
Olajszivattyúszűrő-foglalat anyája*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151003.jpg" width = "88.000mm" height = "61.290mm" ver = "01" gw = "199" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje fel az illesztőcsapokat (1) az olajteknőre és a motorblokkra.
</ptxt>
<figure>
<graphic graphicname = "I9P60A151004.jpg" width = "88.000mm" height = "67.299mm" ver = "01" gw = "207" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Kenje meg motorolajjal az új O-gyűrűt (1), majd szerelje fel az ábrán látható helyre.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Kenje be tömítőanyaggal az olajteknő érintkező felületeit az ábrának megfelelően.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Mielőtt felvinné a tömítőanyagot, győződjön meg arról, hogy az illeszkedő felületek tiszták és szárazak.
</ptxt>
</item>
<item>
<ptxt>
Törölje le a felesleges tömítőanyagot.
</ptxt>
</item>
<item>
<ptxt>
Szerelje fel az olajteknőt a tömítőanyag felvitele után 2 percen belül.
</ptxt>
</item>
</list1>
</attention3>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1E002" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Tömítőanyag
</m-desc>
<m-number>
99000-31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<spec>
<title>
A tömítőanyag mennyisége az olajteknőn
</title>
<ptxt>
“a” szélesség: 3 mm (0,12 in.)
</ptxt>
<ptxt>
“b” magasság: 2 mm (0,08 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151017.swf" width = "88.000mm" height = "59.875mm" ver = "01" gw = "146" gh = "153"/>
</figure>
</s1>
<s1>
<ptxt>
Szerelje fel az olajteknőt a motorblokkra, és húzza meg az olajteknő csavarjait a számozásuk szerinti sorrendben (“1” – “17”), egyenletesen és fokozatosan az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T1E008">
<t-part>
Olajteknő csavarja*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151005.swf" width = "88.000mm" height = "63.567mm" ver = "01" gw = "227" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Húzza meg a sebességváltó csavarjait (1) az előírt nyomatékkal.
</ptxt>
<torque>
<torqueitem id = "T1E009">
<t-part>
Sebességváltó csavar
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151006.swf" width = "88.000mm" height = "46.039mm" ver = "01" gw = "227" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Helyezze fel az olajszűrőt. 
<intxreftitleoff1 refid = "AHUAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje fel az osztóművet. 
<intxreftitleoff1 refid = "AHUAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje be az 1. sz. kipufogócsövet. 
<intxreftitleoff1 refid = "AHUAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje vissza a motor jobb oldali alsó burkolatát.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje be a leeresztőcsavart, és töltse fel ismét a motort motorolajjal. 
<intxreftitleoff1 refid = "AHUAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Tegye be a nívópálcát.
</ptxt>
</s1>
<s1>
<ptxt>
Ellenőrizze, hogy a csatlakozásoknál nem szivárog-e a motorolaj vagy a kipufogógáz.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
