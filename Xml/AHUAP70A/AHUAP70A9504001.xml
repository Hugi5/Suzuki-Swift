</ptxt>
<ptxt>
Első: 
<intxreftitleoff1 refid = "AHUAP70A9506012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hátsó: 
<intxreftitleoff1 refid = "AHUAP70A9506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
