<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70A8206026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Utasoldali légzsák kiiktató kapcsoló kapcsoló le- és felszerelése
</title>
<servinfosub id = "AHUAP70A8206026001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Vegye ki a kesztyűtartót. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Válassza le az utasoldali légzsák kiiktató kapcsoló csatlakozóját (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820078.swf" width = "88.000mm" height = "87.000mm" ver = "01" gw = "231" gh = "230"/>
</figure>
</s1>
<s1>
<ptxt>
Távolítsa el az utasoldali légzsák kiiktató kapcsolót (1) miközben oldja a reteszeket (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820079.swf" width = "88.000mm" height = "59.573mm" ver = "02" gw = "207" gh = "152"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70A8206026002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70A8206027">Utasoldali légzsák kiiktató kapcsoló ellenőrzése</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Szerelje fel az utasoldali légzsák kiiktató kapcsolót (1), irányát (2) a műszerfal kivágásához (3) igazítva.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820080.swf" width = "88.000mm" height = "64.695mm" ver = "01" gw = "207" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Csatlakoztassa az utasoldali légzsák kiiktató kapcsoló csatlakozóját.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje be a kesztyűtartót. 
<intxreftitleoff1 refid = "AHUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
