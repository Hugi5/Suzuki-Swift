<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AHUAP70AA506007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Középső belső antenna le- és felszerelése
</title>
<servinfosub id = "AHUAP70AA506007001">
<title>
Leszerelés
</title>
<s1>
<ptxt>
Válassza le a negatív (–) kábelt az akkumulátorról.
</ptxt>
</s1>
<s1>
<ptxt>
Szerelje le a váltókonzolrekeszt. 
<intxreftitleoff1 refid = "AHUAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Távolítsa el a csatlakozót (1), majd szerelje le a középső belső antennát (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50026.swf" width = "88.000mm" height = "59.622mm" ver = "01" gw = "196" gh = "153"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AHUAP70AA506007002">
<title>
Felszerelés
</title>
<ptxt>
<intxrefpoff refid = "AHUAP70AA506010">Antenna ellenőrzése</intxrefpoff>
</ptxt>
<ptxt>
A felszerelést a leszerelés műveleteinek fordított sorrendjében hajtsa végre.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
