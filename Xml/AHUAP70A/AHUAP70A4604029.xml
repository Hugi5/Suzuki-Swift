<servinfosub id = "AHUAP70A4604029003">
<title>
DTC hibakeresés
</title>
<diag type = "test" id = "AHUAP70A4604029004">
<testgroup id = "AHUAP70A4604029005">
<question>
Végrehajtásra került az „ESP<sup>®</sup> rendszer ellenőrzése”?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 2. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Folytassa a következővel: 
<intxref refid = "AHUAP70A4604001">ESP® rendszer ellenőrzése</intxref>
 .
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A4604029006">
<title>
ESP® vezérlőmodul táp- és testáramkörének ellenőrzése
</title>
<test1>
<ptxt>
Ellenőrizze az ESP<sup>®</sup> vezérlőmodul tápáramkörét és testáramkörét. 
<intxreftitleoff1 refid = "AHUAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Megfelelő állapotban vannak?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Folytassa a 3. lépéssel.
</ptxt>
</action>
<result>
Nem
</result>
<action>
<ptxt>
Javítsa meg vagy cserélje ki a hibás vezetékköteget.
</ptxt>
</action>
</testgroup>
<testgroup id = "AHUAP70A4604029007">
<title>
ESP® vezérlőmodul tápfeszültségének ellenőrzése
</title>
<test1>
<ptxt>
Mérje meg az akkumulátorfeszültséget 3000 f/perc motorfordulatszámon.
</ptxt>
</test1>
<question>
A feszültség 9,3 V és 16,8 V között van?
</question>
<result>
Igen
</result>
<action>
<ptxt>
Cserélje ki az ESP<sup>®</sup> hidraulikaegységet / vezérlőmodul egységet, majd újból kérdezze le a DTC-ket. 
<intxreftitleoff1 refid = "AHUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result>
Nem
</result>
<action>
<paragroup>
<ptxt>
Ellenőrizze a töltőrendszert. 
<intxreftitleoff1 refid = "AHUAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
