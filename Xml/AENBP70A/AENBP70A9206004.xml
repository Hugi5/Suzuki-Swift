<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9206004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Front Fog Light Removal and Installation
</title>
<attention3>
<ptxt>
After any of the following services, be sure to aim fog lights. 
<intxreftitleoff1 refid = "AENBP70A9206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front fog light bulb replacement.
</ptxt>
</item>
<item>
<ptxt>
Front fog light removal and installation.
</ptxt>
</item>
</list1>
</attention3>
<servinfosub id = "AENBP70A9206004001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B920019.swf" width = "88.000mm" height = "76.903mm" ver = "03" gw = "228" gh = "201"/>
</figure>
</s1>
<s1>
<ptxt>
Remove front fog lamp bezel (2). 
<intxreftitleoff1 refid = "AENBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove fog light screws (3) and then remove front fog light (4).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from front fog light.
</ptxt>
</s1>
<s1>
<ptxt>
Turn socket (5) counterclockwise to remove bulb, If necessary.
</ptxt>
<figure>
<graphic graphicname = "IBP60B920028.jpg" width = "88.000mm" height = "84.651mm" ver = "01" gw = "205" gh = "223"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9206004002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
