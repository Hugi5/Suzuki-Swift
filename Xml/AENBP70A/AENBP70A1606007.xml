<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1606007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Thermostat Removal and Installation
</title>
<servinfosub id = "AENBP70A1606007001">
<title>
Removal
</title>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENBP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly, suction hose and resonator. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove radiator inlet hose (1) from thermostat cap (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove thermostat cap from thermostat case (3).
</ptxt>
<figure>
<graphic graphicname = "IBP60B160007.jpg" width = "88.000mm" height = "76.125mm" ver = "01" gw = "214" gh = "199"/>
</figure>
</s1>
<s1>
<ptxt>
Remove thermostat (1) from thermostat case (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B160008.jpg" width = "88.000mm" height = "63.912mm" ver = "02" gw = "171" gh = "165"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1606007002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1606008">Thermostat Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Install thermostat (1) to thermostat case (2) by aligning air bleed valve (4) of thermostat with mark (3) of thermostat case.
</ptxt>
<figure>
<graphic graphicname = "IBP60B160013.jpg" width = "88.000mm" height = "82.434mm" ver = "01" gw = "231" gh = "217"/>
</figure>
</item>
<item>
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENBP70A1606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check cooling system for leakage. 
<intxreftitleoff1 refid = "AENBP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
