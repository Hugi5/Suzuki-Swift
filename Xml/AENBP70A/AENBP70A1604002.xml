<servinfosub id = "AENBP70A1604002002">
<title>
Troubleshooting
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
For details about engine cooling fan operation, refer to 
<intxref refid = "AENBP70A1601003">Cooling Fan Operation Description</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Before beginning troubleshooting, be sure to read 
<intxref refid = "AENBP70A1000001">Precautions for Engine</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
When measuring circuit voltage, resistance and/or pulse signal of ECM, refer to 
<intxref refid = "AENBP70A1104067">Inspection of ECM and Its Circuits</intxref>
.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
<diag type = "test" id = "AENBP70A1604002003">
<testgroup id = "AENBP70A1604002004">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition OFF and connect SUZUKI scan tool to DLC.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON and check DTC.
</ptxt>
</test1>
<question>
Is there DTC(s)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting and recheck DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1604002005">
<title>
Radiator cooling fan low-speed operation control check
</title>
<test1>
<ptxt>
Check radiator cooling fan control for low-speed operation. 
<intxreftitleoff1 refid = "AENBP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1604002006">
<title>
Radiator cooling fan high-speed operation control check
</title>
<test1>
<ptxt>
Check radiator cooling fan control for high-speed operation. 
<intxreftitleoff1 refid = "AENBP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Radiator cooling fan control system is in good condition.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 8.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1604002007">
<title>
Radiator cooling fan relay No.1 power supply circuit (switch side) check
</title>
<test1>
<ptxt>
Set ignition OFF and remove “RDTR” fuse from individual circuit fuse box No.1.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to radiator cooling fan relay No.1 at each terminal.
</ptxt>
</test1>
<test1>
<ptxt>
If OK, measure voltage between “A1” circuit and ground.
</ptxt>
</test1>
<question>
Is it 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair “A1” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1604002008">
<title>
Radiator cooling fan relay No.1 check
</title>
<test1>
<ptxt>
 Check radiator cooling fan relay No.1. 
<intxreftitleoff1 refid = "AENBP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace radiator cooling fan relay No.1.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1604002009">
<title>
Radiator cooling fan motor drive circuit (low speed) check
</title>
<test1>
<ptxt>
Set ignition OFF and disconnect radiator cooling fan motor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to radiator cooling fan motor at each terminal.
</ptxt>
</test1>
<test1>
<ptxt>
If OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B1” circuit: 3 Ω or less
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B1” circuit: 0 – 1 V (with ignition ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair “B1” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1604002010">
<title>
Radiator cooling fan motor ground circuit check
</title>
<test1>
<ptxt>
Measure resistance between “C1” circuit and ground.
</ptxt>
</test1>
<question>
Is resistance 3 Ω or less?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 16.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair “C1” circuit.
</ptxt>
</action>
</testgroup>
