<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A6304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Steering wheel feels heavy
</title>
<ptxt>
This section describes trouble diagnosis of the P/S system parts whose trouble is not indicated using SUZUKI scan tool. When no malfunction is indicated by the SUZUKI scan tool and steering basic parts as described in 
<intxref refid = "AENBP70A6104001">Steering Symptom Diagnosis</intxref>
 are all in good condition, check the following power steering system parts which may be possible causes for each trouble symptom of steering.
</ptxt>
<attention3>
<ptxt>
Perform 
<intxref refid = "AENBP70A6304024">Steering Force Check</intxref>
 and 
<intxref refid = "AENBP70A2206001">Front Wheel Alignment Inspection and Adjustment</intxref>
 before diagnosis.
</ptxt>
</attention3>
<diag type = "condition">
<condition>
<ptxt>
Steering wheel feels heavy
</ptxt>
</condition>
<ps>
<ptxt>
Steering wheel installed improperly
</ptxt>
</ps>
<action>
<ptxt>
Install steering wheel correctly. 
<intxreftitleoff1 refid = "AENBP70A6206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poor performance of torque sensor
</ptxt>
</ps>
<action>
<ptxt>
Check torque sensor. 
<intxreftitleoff1 refid = "AENBP70A6306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Poor performance of P/S motor
</ptxt>
</ps>
<action>
<ptxt>
Check motor. 
<intxreftitleoff1 refid = "AENBP70A6306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Steering gear case assembly malfunction
</ptxt>
</ps>
<action>
<ptxt>
Replace steering gear case assembly. 
<intxreftitleoff1 refid = "AENBP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vehicle speed data provided through CAN communication
</ptxt>
</ps>
<action>
<ptxt>
Check vehicle speed data. 
<intxreftitleoff1 refid = "AENBP70A6304007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
