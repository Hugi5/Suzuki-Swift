<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1406018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
OCV Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1406015">Timing Chain Cover Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1406018001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, disconnect gear shift and gear select control cables from transaxle. 
<intxreftitleoff1 refid = "AENBP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
For CVT model, disconnect select cable from transaxle. 
<intxreftitleoff1 refid = "AENBP70A5506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove right lamp support member (1).
</ptxt>
<figure>
<graphic graphicname = "IBP70A140019.jpg" width = "88.000mm" height = "68.908mm" ver = "01" gw = "214" gh = "179"/>
</figure>
</s1>
<s1>
<ptxt>
Support engine assembly using chain hoist (1).
</ptxt>
<figure>
<graphic graphicname = "IBP70A140020.jpg" width = "88.000mm" height = "81.124mm" ver = "01" gw = "185" gh = "213"/>
</figure>
</s1>
<s1>
<ptxt>
Remove engine right mounting (1) and engine right mounting stiffener (2).
</ptxt>
<figure>
<graphic graphicname = "IBP70A140021.jpg" width = "88.000mm" height = "64.213mm" ver = "01" gw = "199" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect connector from OCV.
</ptxt>
</s1>
<s1>
<ptxt>
Lift up engine 25 mm (0.98 in.), remove oil gallery pipe No.1 (1) and OCV (2) from timing chain cover (3).
</ptxt>
<attention4>
<ptxt>
Lifting up the engine higher than the specified value may cause damage to the engine rear mounting and engine left mounting.
</ptxt>
<ptxt>
When lifting up the engine, do not lift it up higher than the specified value.
</ptxt>
</attention4>
<figure>
<graphic graphicname = "IBP70A140026.swf" width = "88.000mm" height = "62.607mm" ver = "01" gw = "131" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1406018002">
<title>
Installation
</title>
<ptxt>
Reference: “OCV Inspection”
</ptxt>
<s1>
<ptxt>
Install new OCV gasket (1) to OCV (2).
</ptxt>
</s1>
<s1>
<ptxt>
Install OCV to timing chain cover (3), and then tighten OCV mounting nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D021">
<t-part>
OCV mounting nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A140022.swf" width = "88.000mm" height = "49.395mm" ver = "01" gw = "129" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Install oil gallery pipe No.1 (1) and new gaskets (2) to timing chain cover, and then tighten oil gallery pipe No.1 bolts (3) by hand.
</ptxt>
<figure>
<graphic graphicname = "IBP70A140023.jpg" width = "88.000mm" height = "62.051mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten oil gallery pipe No.1 bolts to specified torque using special tool as follows.
</ptxt>
<attention4>
<ptxt>
If the oil gallery pipe No.1 bolts are tightened using the special tool until the torque wrench reads the specified torque below, the oil gallery pipe No.1 bolt may be damaged.
</ptxt>
<ptxt>
Be sure to follow the steps below to tighten the bolts to the specified torque using the special tool.
</ptxt>
</attention4>
<servicetool>
<servicetoolitem id = "L1D015">
<s-part>
(A)
</s-part>
<s-number num = "09911-05120">
09911–05120
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T1D022">
<t-part>
Oil gallery pipe No.1 bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
30
</t-value1>
<t-value2>
3.1
</t-value2>
<t-value3>
22.5
</t-value3>
</torqueitem>
</torque>
<s2>
<ptxt>
Measure length (L) of torque wrench (1).
</ptxt>
</s2>
<s2>
<ptxt>
Calculate reading value (M) of the torque wrench using the following formula.
</ptxt>
<spec>
<title>
Formula for torque wrench reading value when using special tool
</title>
<ptxt>
M = T x L ÷ (L + “a”)
</ptxt>
<ptxt>
M: Torque wrench reading value when using special tool
</ptxt>
<ptxt>
T: Specified torque
</ptxt>
<ptxt>
L: Torque wrench length
</ptxt>
<ptxt>
“a”: Dimension of special tool (18 mm (0.71 in.))
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP70A140024.swf" width = "88.000mm" height = "28.591mm" ver = "01" gw = "207" gh = "65"/>
</figure>
</s2>
<s2>
<ptxt>
Tighten oil gallery pipe No.1 bolts (1) until torque wrench reads the value obtained in the above step b).
</ptxt>
<figure>
<graphic graphicname = "IBP70A140025.jpg" width = "88.000mm" height = "111.184mm" ver = "02" gw = "197" gh = "299"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.856in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.800in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Upper side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lower side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
</s1>
<s1>
<ptxt>
Connect connector to OCV.
</ptxt>
</s1>
<s1>
<ptxt>
Install engine right mounting (1) and stiffener (2), and tighten the following bolts and nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D023">
<t-part>
Engine right mounting bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D024">
<t-part>
Engine right mounting nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D025">
<t-part>
Engine right mounting stiffener bolt
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D026">
<t-part>
Engine right mounting stiffener nut
</t-part>
<t-part1>
d
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A140013.jpg" width = "88.000mm" height = "57.562mm" ver = "02" gw = "199" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Remove chain hoist from engine assembly.
</ptxt>
</s1>
<s1>
<ptxt>
Install right lamp support member (1).
</ptxt>
<figure>
<graphic graphicname = "IBP70A140019.jpg" width = "88.000mm" height = "68.908mm" ver = "01" gw = "214" gh = "179"/>
</figure>
</s1>
<s1>
<ptxt>
For CVT model, connect select cable from transaxle. 
<intxreftitleoff1 refid = "AENBP70A5506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
For M/T model, connect gear shift and gear select control cables from transaxle. 
<intxreftitleoff1 refid = "AENBP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect negative (–) cable at battery.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
