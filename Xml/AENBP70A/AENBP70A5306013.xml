<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5306013" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Clutch Operating Cylinder Assembly Removal and Installation
</title>
<attention4>
<list1 type = "unordered">
<item>
<ptxt>
Brake fluid is extremely damaging to painted surfaces.
</ptxt>
<ptxt>
If brake fluid contacts a painted surface, immediately wipe it off and flush the surface thoroughly with water.
</ptxt>
</item>
<item>
<ptxt>
The clutch operating cylinder may lose its original performance if it is disassembled and reassembled.
</ptxt>
<ptxt>
Do not try to disassemble and repair the clutch operating cylinder.
</ptxt>
</item>
</list1>
</attention4>
<servinfosub id = "AENBP70A5306013001">
<title>
Removal
</title>
<s1>
<ptxt>
Dismount transaxle assembly. 
<intxreftitleoff1 refid = "AENBP70A5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove clamp (1), to disconnect clutch pipe joint (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B530007.jpg" width = "88.000mm" height = "59.110mm" ver = "02" gw = "215" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Loosen clutch fluid pipe flare nut (1) of clutch operating cylinder assembly (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove clutch pipe joint sleeve (3) from transaxle, and then remove clutch fluid pipe (4).
</ptxt>
</s1>
<s1>
<ptxt>
Remove clutch operating cylinder assembly from transaxle.
</ptxt>
<figure>
<graphic graphicname = "IBP60B530008.jpg" width = "88.000mm" height = "67.456mm" ver = "01" gw = "228" gh = "175"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5306013002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5306014">Clutch Operating Cylinder Assembly Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install clutch operating cylinder assembly (1) to transaxle. Tighten new clutch operating cylinder assembly bolts (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5C005">
<t-part>
Clutch operating cylinder assembly bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect clutch fluid pipe (3) to clutch operating cylinder assembly temporarily.
</ptxt>
</s1>
<s1>
<ptxt>
Install clutch pipe joint sleeve (4) to transaxle securely and then tighten clutch fluid pipe flare nut (5) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5C006">
<t-part>
Clutch fluid pipe flare nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1.6
</t-value2>
<t-value3>
12.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B530009.jpg" width = "88.000mm" height = "66.607mm" ver = "01" gw = "241" gh = "172"/>
</figure>
</s1>
<s1>
<ptxt>
Connect clutch pipe joint (2), and install clamp (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B530007.jpg" width = "88.000mm" height = "59.110mm" ver = "02" gw = "215" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Remount manual transaxle assembly. 
<intxreftitleoff1 refid = "AENBP70A5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Bleed clutch system and check clutch pedal free travel. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Air bleeding of clutch system: 
<intxreftitleoff1 refid = "AENBP70A5306007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Clutch pedal free travel: 
<intxreftitleoff1 refid = "AENBP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
