<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A3116003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Front Drive Shaft Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A3116001">Front Drive Shaft Components:Front</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENBP70A3116002">Front Drive Shaft Assembly On-Vehicle Inspection:Front</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A3116003001">
<title>
Removal
</title>
<s1 page = "2">
<ptxt>
Hoist vehicle and remove front wheel. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Release caulking (1) and remove drive shaft nut (2) with brake pedal depressed.
</ptxt>
<figure>
<graphic graphicname = "IBP70A311003.swf" width = "88.000mm" height = "54.100mm" ver = "01" gw = "182" gh = "137"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Drain transaxle oil (M/T model) or CVT fluid (CVT model).
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
M/T model: 
<intxreftitleoff1 refid = "AENBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
CVT model: 
<intxreftitleoff1 refid = "AENBP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Remove front wheel speed sensor from steering knuckle. 
<intxreftitleoff1 refid = "AENBP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Disconnect suspension arm joint from steering knuckle. 
<intxreftitleoff1 refid = "AENBP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Pull out drive shaft joint (2) using tire lever (1) or plastic hammer (3).
</ptxt>
<attention3>
<ptxt>
Turning drive shaft while pulling out drive shaft joint may facilitate release of the snap ring fitting of joint spline.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IBP60B311017.jpg" width = "88.000mm" height = "44.979mm" ver = "01" gw = "213" gh = "111"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.280in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.541in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.246in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Left side shaft
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Right side shaft
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove drive shaft assembly.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENBP70A3116003002">
<title>
Installation
</title>
<attention4>
<ptxt>
Failure to take proper precautions when installing the drive shaft may result in damage to or breakage of the drive shaft assembly.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Before inserting drive shaft (1), confirm that there is no foreign materials around encoder (2) on wheel bearing.
</ptxt>
<figure>
<graphic graphicname = "IBP60B311021.jpg" width = "88.000mm" height = "46.313mm" ver = "01" gw = "185" gh = "115"/>
</figure>
</item>
<item>
<ptxt>
Be careful not to damage the oil seals and boots.
</ptxt>
</item>
<item>
<ptxt>
Insert joints only by hand. Never hit joint boots with a hammer.
</ptxt>
</item>
<item>
<ptxt>
Make sure that the differential-side joint is fully inserted and the snap ring is seated in position.
</ptxt>
</item>
</list1>
</attention4>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new differential side joint circlip.
</ptxt>
</item>
<item>
<ptxt>
Tighten new drive shaft nut (1) to specified torque.
</ptxt>
<attention4>
<ptxt>
Reusing the drive shaft nut can cause it to loosen, because the removed nut no longer has the necessary fastening performance.
</ptxt>
<ptxt>
Be sure to use the new drive shaft nut.
</ptxt>
</attention4>
<torque>
<torqueitem id = "T3A101">
<t-part>
Drive shaft nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
200
</t-value1>
<t-value2>
20.4
</t-value2>
<t-value3>
147.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Caulk drive shaft nut as shown.
</ptxt>
<figure>
<graphic graphicname = "IBP70A311004.swf" width = "88.000mm" height = "54.099mm" ver = "01" gw = "172" gh = "137"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Caulking part
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Connect suspension arm joint. 
<intxreftitleoff1 refid = "AENBP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Install front wheel speed sensor. 
<intxreftitleoff1 refid = "AENBP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Install front wheel. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Fill transaxle with transaxle oil as specified. 
<intxreftitleoff1 refid = "AENBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check front wheel alignment. 
<intxreftitleoff1 refid = "AENBP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
