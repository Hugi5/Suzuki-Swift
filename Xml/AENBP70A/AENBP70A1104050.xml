<servinfosub id = "AENBP70A1104050003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery voltage &#62; 8.5 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Start engine at idle for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1104050004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A1104050005">
<testgroup id = "AENBP70A1104050006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104050007">
<title>
IMT valve actuator drive circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C01” and “E01” connectors of ECM and IMT valve actuator connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors and IMT valve actuator connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” and “A2” circuits: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A1” and “A2” circuits and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit terminal and “A2” circuit terminal at IMT valve actuator connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A1” and “A2” circuits: approx. 0 V (When ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104050008">
<title>
IMT valve actuator check
</title>
<test1>
<ptxt>
Check IMT valve actuator. 
<intxreftitleoff1 refid = "AENBP70A1306023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace IMT valve actuator. 
<intxreftitleoff1 refid = "AENBP70A1406010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
