<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0660: Intake Manifold Tuning Valve Control Circuit / Open
</emph>
</ptxt>
<ptxt>
IMT valve actuator and/or its circuit malfunction (open, short to power supply or short to ground) is detected.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic but mil does not light up)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic but mil does not light up)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
IMT valve actuator and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
