<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Shimmy, shake or vibration
</title>
<diag type = "condition">
<condition>
<ptxt>
Shimmy, shake or vibration
</ptxt>
</condition>
<ps>
<ptxt>
Wheel out of balance
</ptxt>
</ps>
<action>
<ptxt>
Balance wheel(s) or replace tire(s) and/or wheel(s).
</ptxt>
</action>
<ps>
<ptxt>
Loose wheel bearings
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace wheel bearings.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENBP70A3116009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENBP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Worn tie-rod ends
</ptxt>
</ps>
<action>
<ptxt>
Replace tie-rod ends. 
<intxreftitleoff1 refid = "AENBP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn suspension arm joints
</ptxt>
</ps>
<action>
<ptxt>
Replace suspension arm. 
<intxreftitleoff1 refid = "AENBP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Excessive tire or wheel run-out
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace wheel and/or tire. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Blister or bump on tire
</ptxt>
</ps>
<action>
<ptxt>
Replace tire. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Excessive radial runout of tire / wheel assembly
</ptxt>
</ps>
<action>
<ptxt>
Replace tire or wheel. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disturbed wheel alignment
</ptxt>
</ps>
<action>
<ptxt>
Check and adjust wheel alignment. 
<intxreftitleoff1 refid = "AENBP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose or worn steering linkage
</ptxt>
</ps>
<action>
<ptxt>
Inspect steering system. 
<intxreftitleoff1 refid = "AENBP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose steering gear case bolts
</ptxt>
</ps>
<action>
<ptxt>
Tighten steering gear case bolts. 
<intxreftitleoff1 refid = "AENBP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
