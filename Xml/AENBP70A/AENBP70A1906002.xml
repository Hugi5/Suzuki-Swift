<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Starting Motor Removal and Installation
</title>
<servinfosub id = "AENBP70A1906002001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust No.2 pipe. 
<intxreftitleoff1 refid = "AENBP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery and battery bracket. 
<intxreftitleoff1 refid = "AENBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, disconnect gear shift and select control cable from cable bracket of transaxle. 
<intxreftitleoff1 refid = "AENBP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For CVT model, disconnect select cable from cable bracket of transaxle. 
<intxreftitleoff1 refid = "AENBP70A5506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove cable bracket from transaxle.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
M/T model: 
<intxreftitleoff1 refid = "AENBP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
CVT model: 
<intxreftitleoff1 refid = "AENBP70A5506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Disconnect magnetic switch lead wire (1) and starting motor cable (2) from starting motor (4).
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, remove starting motor mounting bolt (3) and nut (5).
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, remove starting motor mounting bolts (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove starting motor (4).
</ptxt>
</s1>
<figure>
<title>
M/T model
</title>
<graphic graphicname = "IBP70A190001.jpg" width = "183.000mm" height = "84.432mm" ver = "02" gw = "383" gh = "223"/>
</figure>
<figure>
<title>
CVT model
</title>
<graphic graphicname = "IBP70A190002.jpg" width = "183.000mm" height = "83.674mm" ver = "02" gw = "409" gh = "221"/>
</figure>
</servinfosub>
<servinfosub id = "AENBP70A1906002002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1906005">Starting Motor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedures, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten starting motor mounting bolts and starting motor cable nut to specified torques.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1I001">
<t-part>
Starting motor cable nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
<torqueitem id = "T1I002">
<t-part>
Starting motor mounting bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
<torqueitem id = "T1I003">
<t-part>
Starting motor mounting nut
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
</torque>
<figure>
<title>
M/T model
</title>
<graphic graphicname = "IBP70A190003.jpg" width = "183.000mm" height = "79.344mm" ver = "02" gw = "390" gh = "208"/>
</figure>
<figure>
<title>
CVT model
</title>
<graphic graphicname = "IBP70A190004.jpg" width = "183.000mm" height = "84.407mm" ver = "02" gw = "430" gh = "223"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
