<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Headlight Washer Nozzle Removal and Installation
</title>
<servinfosub id = "AENBP70A9406005001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect washer hose (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove headlight washer clamp (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B940004.swf" width = "88.000mm" height = "74.839mm" ver = "01" gw = "182" gh = "196"/>
</figure>
</s1>
<s1>
<ptxt>
Remove headlight cleaner base (1) and then remove headlight washer nozzle (2).
</ptxt>
<figure>
<graphic graphicname = "IBP70A940004.swf" width = "88.000mm" height = "74.838mm" ver = "01" gw = "187" gh = "196"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9406005002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
