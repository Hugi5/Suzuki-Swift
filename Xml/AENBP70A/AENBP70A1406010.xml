<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1406010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
IMT Valve Actuator Removal and Installation
</title>
<servinfosub id = "AENBP70A1406010001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect IMT valve actuator connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove IMT valve actuator (1) and O-ring (2) from intake manifold (3).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IBP60B140068.jpg" width = "88.000mm" height = "41.173mm" ver = "01" gw = "183" gh = "100"/>
</figure>
</servinfosub>
<servinfosub id = "AENBP70A1406010002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new O-ring (1).
</ptxt>
</item>
<item>
<ptxt>
Tighten IMT valve actuator bolts (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D003">
<t-part>
IMT valve actuator bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
<figure>
<graphic graphicname = "IBP60B140069.jpg" width = "88.000mm" height = "41.173mm" ver = "01" gw = "183" gh = "100"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
