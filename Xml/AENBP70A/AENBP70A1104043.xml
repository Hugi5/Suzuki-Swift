<servinfosub id = "AENBP70A1104043003">
<title>
DTC Confirmation Procedure
</title>
<topic id = "AENBP70A1104043004">
<title>
P0560:
</title>
<s1>
<ptxt>
Set ignition ON for 1 min.
</ptxt>
</s1>
</topic>
<topic id = "AENBP70A1104043005">
<title>
P0562 / P0563:
</title>
<s1>
<ptxt>
Run engine at 2,500 rpm or more for 1 min.
</ptxt>
</s1>
</topic>
</servinfosub>
<servinfosub id = "AENBP70A1104043006">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A1104043007">
<testgroup id = "AENBP70A1104043008">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104043009">
<title>
ECM power supply and ground circuit check
</title>
<test1>
<ptxt>
Check ECM power supply and ground circuits. 
<intxreftitleoff1 refid = "AENBP70A1104068"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair ECM power supply and/or ground circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104043010">
<title>
Charging system check
</title>
<test1>
<ptxt>
Check that charging system is working properly. 
<intxreftitleoff1 refid = "AENBP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
</diag>
