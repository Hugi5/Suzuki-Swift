<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Generator Removal and Installation
</title>
<servinfosub id = "AENBP70A1A06005001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust No.2 pipe. 
<intxreftitleoff1 refid = "AENBP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump / generator drive belt. 
<intxreftitleoff1 refid = "AENBP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect “B” terminal wire (1) and connector (2) from generator (4).
</ptxt>
</s1>
<s1>
<ptxt>
Remove generator adjusting arm (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove generator and generator brackets (5) together.
</ptxt>
</s1>
<s1>
<ptxt>
Remove generator brackets from generator.
</ptxt>
<figure>
<graphic graphicname = "IBP60B1A0002.jpg" width = "88.000mm" height = "77.525mm" ver = "02" gw = "229" gh = "203"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1A06005002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten generator adjusting arm bolt, generator bracket bolt and “B” terminal nut to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1J004">
<t-part>
Generator adjusting arm bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
<torqueitem id = "T1J005">
<t-part>
Generator bracket bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
<torqueitem id = "T1J006">
<t-part>
“B” terminal nut
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7.9
</t-value1>
<t-value2>
0.81
</t-value2>
<t-value3>
6.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A1A0001.jpg" width = "88.000mm" height = "76.443mm" ver = "02" gw = "233" gh = "200"/>
</figure>
</item>
<item>
<ptxt>
Tighten generator pivot bolt according to the following procedure.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Measure length (L) of torque wrench (1).
</ptxt>
</item>
<item>
<ptxt>
Calculate reading value of torque wrench (M) by formula.
</ptxt>
<servicetool>
<servicetoolitem id = "L1J004">
<s-part>
(A)
</s-part>
<s-number num = "09911-78010">
09911–78010
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Formula for reading value of torque wrench.
</title>
<ptxt>
(M) = T x L ÷ (L + “a”)
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
(M): Reading value using extension special tool
</ptxt>
</item>
<item>
<ptxt>
T (50 N&#183;m (5.1 kgf-m, 37.0 lbf-ft)): Specified torque
</ptxt>
</item>
<item>
<ptxt>
L: Torque wrench length
</ptxt>
</item>
<item>
<ptxt>
“a” (0.05 m (1.96 in.)): Dimension of special tool
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IBP60B1A0006.swf" width = "88.000mm" height = "27.196mm" ver = "03" gw = "196" gh = "61"/>
</figure>
</spec>
</item>
<item>
<ptxt>
Tighten generator pivot bolt (1) to reading value of torque wrench using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L1J005">
<s-part>
(A)
</s-part>
<s-number num = "09911-78010">
09911–78010
</s-number>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T1J007">
<t-part>
Generator pivot bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B1A0007.swf" width = "88.000mm" height = "51.078mm" ver = "01" gw = "173" gh = "128"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Adjust belt tension. 
<intxreftitleoff1 refid = "AENBP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten exhaust pipe No.2 bolts to specified torque. 
<intxreftitleoff1 refid = "AENBP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
