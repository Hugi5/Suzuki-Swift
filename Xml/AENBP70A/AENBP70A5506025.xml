<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5506025" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Primary Pulley Speed Sensor Removal and Installation
</title>
<servinfosub id = "AENBP70A5506025001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove engine coolant reservoir.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector (1) from primary pulley speed sensor.
</ptxt>
</s1>
<s1>
<ptxt>
Remove primary pulley speed sensor (2) from transaxle.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5506025002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5506027">Primary Pulley Speed Sensor and Secondary Pulley Speed Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply CVT fluid to new O-ring of sensor.
</ptxt>
</item>
<item>
<ptxt>
Tighten primary pulley speed sensor bolt (3) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5E014">
<t-part>
Primary pulley speed sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.9
</t-value1>
<t-value2>
0.60
</t-value2>
<t-value3>
4.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Connect connector and fix wire harness with clamp securely.
</ptxt>
<figure>
<graphic graphicname = "IBP70A550074.swf" width = "88.000mm" height = "54.484mm" ver = "02" gw = "175" gh = "138"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
