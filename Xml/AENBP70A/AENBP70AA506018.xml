<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70AA506018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Outside Warning Buzzer Removal and Installation
</title>
<servinfosub id = "AENBP70AA506018001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove driver side front fender lining. 
<intxreftitleoff1 refid = "AENBP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector (1), and then remove outside warning buzzer (2).
</ptxt>
<figure>
<graphic graphicname = "IBP70AA50007.jpg" width = "88.000mm" height = "65.351mm" ver = "01" gw = "239" gh = "169"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70AA506018002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70AA506019">Outside Warning Buzzer Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
