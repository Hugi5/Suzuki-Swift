<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206036" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Side Ventilation Louver Removal and Installation
</title>
<servinfosub id = "AENBP70A7206036001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Driver side: Remove combination meter cluster panel from instrument panel. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Passenger side: Remove passenger air bag door. 
<intxreftitleoff1 refid = "AENBP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove side ventilation louver. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Release tabs (1) and then separate side demister nozzle (2) from instrument panel side garnish (3).
</ptxt>
</s1>
<s1>
<ptxt>
Release tabs (4) and then separate side ventilation louver (5) from instrument panel side garnish.
</ptxt>
<attention3>
<ptxt>
Side demister nozzle and side ventilation louver is fitted to instrument panel side garnish with six clips.
</ptxt>
<ptxt>
When removing nozzle and louver from instrument panel side garnish, be careful not to break them.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A721031.swf" width = "88.000mm" height = "68.687mm" ver = "01" gw = "177" gh = "178"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7206036002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
