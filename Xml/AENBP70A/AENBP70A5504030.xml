<servinfosub id = "AENBP70A5504030003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed with two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<ptxt>
Check that the following conditions are satisfied in this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
DTC P0705 or P0707 is not detected.
</ptxt>
</item>
<item>
<ptxt>
11 V &#60; Battery voltage &#60; 15 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Start engine and drive vehicle in M range at 40 km/h (25 mile/h) for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5504030004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A5504030005">
<testgroup id = "AENBP70A5504030006">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504030007">
<title>
Vehicle speed sensor power supply circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C60” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C60” connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check that “A1” circuit is battery voltage.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504030008">
<title>
Vehicle speed sensor signal circuit and ground circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B1” and “C1” circuits: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit terminal and other terminal at “C60” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “C1” circuit terminal and other terminal at “C60” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B1” and “C1” circuits: approx. 0 (when ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504030009">
<title>
Vehicle speed sensor check
</title>
<test1>
<ptxt>
Check vehicle speed sensor. 
<intxreftitleoff1 refid = "AENBP70A5506038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace vehicle speed sensor. 
<intxreftitleoff1 refid = "AENBP70A5506037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
