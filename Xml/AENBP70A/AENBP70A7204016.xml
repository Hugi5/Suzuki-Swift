</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7204016004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A7204016005">
<testgroup id = "AENBP70A7204016006">
<title>
Scan tool parameter check
</title>
<test1>
<ptxt>
Check “Sun Load” using “Data list” mode on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENBP70A7204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is sun load value over 2440 W/m<sup>2</sup> (Sunload sensor signal voltage is lower than 0.1 V)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A7204016007">
<title>
Sunload sensor signal circuit check
</title>
<test1>
<ptxt>
Disconnect sunload sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENBP70A7204008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1504-H detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace sunload sensor. 
<intxreftitleoff1 refid = "AENBP70A7206029"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A7204016008">
<title>
Sunload sensor signal circuit check
</title>
<test1>
<ptxt>
Disconnect “G20” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between the “PNK” wire terminal and ground is approx. 0 V with ignition ON.
</ptxt>
</test1>
<question>
Is voltage as specified?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace HVAC control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A7206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
</diag>
