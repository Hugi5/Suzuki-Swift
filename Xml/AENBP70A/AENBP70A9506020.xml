<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9506020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Door Mirror Removal and Installation
</title>
<servinfosub id = "AENBP70A9506020001">
<title>
Removal
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A9506019">Power Door Mirror On-Vehicle Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Remove sash bracket inner garnish and from door trim. 
<intxreftitleoff1 refid = "AENBP70A9506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect power door mirror connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove door mirror nuts (1) and remove door mirror assembly (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove door mirror (3), mirror visor cove (4) and door mirror turn signal light (5), if necessary.
</ptxt>
<figure>
<graphic graphicname = "IAP70B950005.jpg" width = "88.000mm" height = "63.153mm" ver = "01" gw = "199" gh = "163"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.750in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
6.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Claw
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
7.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Door mirror turn signal light connector (If equipped)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9506020002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Insert claws (2) securely when installing mirror (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70B950006.jpg" width = "88.000mm" height = "63.153mm" ver = "01" gw = "199" gh = "163"/>
</figure>
</item>
<item>
<ptxt>
Tighten door mirror nuts in order (“1” to “3”) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9E007">
<t-part>
Door mirror nut*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7.9
</t-value1>
<t-value2>
0.81
</t-value2>
<t-value3>
6.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950057.jpg" width = "88.000mm" height = "63.396mm" ver = "01" gw = "225" gh = "163"/>
</figure>
</item>
<item>
<ptxt>
Check operation of door mirror after installation.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
