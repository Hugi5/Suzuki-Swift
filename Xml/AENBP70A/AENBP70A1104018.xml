<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0112: Intake Air Temperature Sensor 1 Circuit Low
</emph>
</ptxt>
<ptxt>
Output voltage of IAT sensor signal circuit is lower than 0.04 V for 10 sec.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
IAT sensor and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0113: Intake Air Temperature Sensor 1 Circuit High
</emph>
</ptxt>
<ptxt>
Output voltage of IAT sensor signal circuit is higher than 4.9 V for 10 sec.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
