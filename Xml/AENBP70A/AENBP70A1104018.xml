<servinfosub id = "AENBP70A1104018003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following DTCs are not detected in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
ECT sensor (P0116, P0117 and P0118)
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Run engine at idle for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1104018004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A1104018005">
<testgroup id = "AENBP70A1104018006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104018007">
<title>
IAT sensor signal circuit and ground circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C01” and “E01” connectors of ECM and MAF and IAT sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors and MAF and IAT sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B1” and “C1” circuits: less than 1Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “B1” and “C1” circuits and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit terminal and other terminal at MAF and IAT sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “C1” circuit terminal and other terminal at MAF and IAT sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B1” and “C1” circuits: approx. 0 V (When ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104018008">
<title>
IAT sensor check
</title>
<test1>
<ptxt>
Check IAT sensor. 
<intxreftitleoff1 refid = "AENBP70A1306022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace MAF and IAT sensor.
</ptxt>
</action>
</testgroup>
