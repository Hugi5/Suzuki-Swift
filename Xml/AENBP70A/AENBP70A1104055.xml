<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P2127: Throttle / Pedal Position Sensor / Switch “E” Circuit Low
</emph>
</ptxt>
<ptxt>
Output voltage of APP sensor (sub) signal circuit is lower than 0.30 V.
</ptxt>
<ptxt>
(1 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
