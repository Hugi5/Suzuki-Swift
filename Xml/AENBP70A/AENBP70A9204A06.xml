<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A9204A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Fog lights do not light up
</title>
<diag type = "condition">
<condition>
<ptxt>
Fog lights do not light up
</ptxt>
</condition>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
Repair circuit and replace relay and/or fuse.
</ptxt>
</action>
<ps>
<ptxt>
Blown bulbs
</ptxt>
</ps>
<action>
<ptxt>
Replace bulbs.
</ptxt>
</action>
<ps>
<ptxt>
Faulty fog light switch
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Front fog light switch: refer to 
<intxref refid = "AENBP70A9206024">Front Fog Light Switch Inspection</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Rear fog light switch: refer to 
<intxref refid = "AENBP70A9206020">Lighting and Turn Signal Switch Inspection</intxref>
.
</ptxt>
</item>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
