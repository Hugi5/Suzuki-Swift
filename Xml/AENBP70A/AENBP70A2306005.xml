<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2C">
<servcat sctnbr = "02" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A2306005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Rear Coil Spring and Spring Seat Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A2306002">Rear Suspension Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A2306005001">
<title>
Removal
</title>
<s1>
<ptxt>
Hoist vehicle and remove rear wheels. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear vehicle height sensor bracket from rear axle. 
<intxreftitleoff1 refid = "AENBP70A9206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Support both ends of rear axle (1) using two floor jacks (2) to prevent it from lowering.
</ptxt>
<figure>
<graphic graphicname = "IBP60B230008.swf" width = "88.000mm" height = "49.740mm" ver = "01" gw = "163" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Remove rear shock absorber lower nut and lower washer. 
<intxreftitleoff1 refid = "AENBP70A2306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Detach lower ends of right and left shock absorber (1) from rear axle.
</ptxt>
</s1>
<s1>
<ptxt>
Lower rear axle gradually as far down if necessary for removing coil spring (2).
</ptxt>
<attention4>
<ptxt>
Lowering the rear axle too much may cause damage to the flexible brake hose, wheel speed sensor lead wire and parking brake cable.
</ptxt>
<ptxt>
Be sure to limit the distance that you lower the rear axle to the minimum distance necessary.
</ptxt>
</attention4>
</s1>
<s1>
<ptxt>
Remove coil spring(s) (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B230009.jpg" width = "88.000mm" height = "67.513mm" ver = "01" gw = "180" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Remove spring upper seat(s) (1) from vehicle body and spring lower seat(s) (2) from rear axle.
</ptxt>
<figure>
<graphic graphicname = "I9P60A230011.swf" width = "88.000mm" height = "81.349mm" ver = "01" gw = "197" gh = "214"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A2306005002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A2306006">Rear Coil Spring and Spring Seat Check</intxrefpoff>
</ptxt>
<attention4>
<ptxt>
The shock absorber lower nut is pre-coated with friction stabilizer. If the nut is reused, it may work loose.
</ptxt>
<ptxt>
Never reuse the shock absorber lower nut.
</ptxt>
</attention4>
<s1>
<ptxt>
Install rear spring lower seat to rear axle. At this time, fit protrusion (5) of rear spring lower seat (2) into hole (6) in rear axle.
</ptxt>
</s1>
<s1>
<ptxt>
Install rear spring upper seat (1) to vehicle body.
</ptxt>
</s1>
<s1>
<ptxt>
Install rear coil spring (3). At this time, contact rear coil spring end (4) with protrusion (7) of rear spring lower seat.
</ptxt>
<figure>
<graphic graphicname = "IBP70A230005.swf" width = "88.000mm" height = "94.658mm" ver = "01" gw = "173" gh = "252"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.009in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.354in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.025in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Left side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[r]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Vehicle rightward
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Right side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[u]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Vehicle upward
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[f]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Vehicle forward
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0">
<ptxt>
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Jack up rear axle and then install shock absorber (1) lower end to rear axle.
</ptxt>
</s1>
<s1>
<ptxt>
Install lower washers and tighten new shock absorber lower nuts (2) temporarily by hand.
</ptxt>
<figure>
<graphic graphicname = "IBP60B230010.jpg" width = "88.000mm" height = "67.755mm" ver = "01" gw = "175" gh = "176"/>
</figure>
</s1>
<s1>
<ptxt>
Remove floor jacks from rear axle.
</ptxt>
</s1>
<s1>
<ptxt>
Install rear wheels. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Lower hoist and bounce vehicle up and down several times to stabilize suspension.
</ptxt>
</s1>
<s1>
<ptxt>
Tighten shock absorber lower nuts to specified torque.
</ptxt>
<attention3>
<ptxt>
When tightening these nuts, be sure that vehicle is not on hoist and in unloaded condition.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T2C003">
<t-part>
Rear shock absorber lower nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
90
</t-value1>
<t-value2>
9.2
</t-value2>
<t-value3>
66.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B230011.jpg" width = "88.000mm" height = "54.864mm" ver = "01" gw = "144" gh = "139"/>
</figure>
</s1>
<s1>
<ptxt>
Install rear vehicle height sensor bracket to rear axle. 
<intxreftitleoff1 refid = "AENBP70A9206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
