<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A9504A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
One of the power window cannot operate
</title>
<diag type = "condition">
<condition>
<ptxt>
One of the power window cannot operate
</ptxt>
</condition>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty power window regulator and/or motor
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENBP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENBP70A9506016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty power window main switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A9506017">Power Window Main Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty power window sub switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A9506018">Power Window Sub Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Window lock switch is pushed (lock position)
</ptxt>
</ps>
<action>
<ptxt>
Turn off window lock switch.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
