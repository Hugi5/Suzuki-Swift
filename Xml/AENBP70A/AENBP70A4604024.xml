<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A4604024" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1038
</title>
<servinfosub id = "AENBP70A4604024001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.259in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.896in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1038: Steering Angle Sensor Detect Rolling Counter Failure
</emph>
</ptxt>
<ptxt>
Steering angle sensor detects invalid CAN data from ESP<sup>®</sup> control module.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
CAN communication circuit
</ptxt>
</item>
<item>
<ptxt>
Steering angle sensor
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>®</sup> control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENBP70A4604024002">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A4604024003">
<testgroup id = "AENBP70A4604024004">
<question>
Was “ESP<sup>®</sup> System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A4604001">ESP® System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604024005">
<title>
DTC check
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENBP70A4604005">DTC Check</intxref>
.
</ptxt>
</test1>
<question>
Is any DTC(s) detected other than C1038?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604024006">
<title>
Steering angle sensor check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Replace steering angle sensor. 
<intxreftitleoff1 refid = "AENBP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC.
</ptxt>
</test1>
<question>
Is DTC C1038 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ESP<sup>®</sup> hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
