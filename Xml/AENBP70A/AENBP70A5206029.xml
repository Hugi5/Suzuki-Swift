</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Spring washer
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install new differential pinion shaft pin from right side until it is flat with differential case surface.
</ptxt>
</s1>
<s1>
<ptxt>
Press-fit left bearing (1) using special tool and hydraulic press.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B046">
<s-part>
(A)
</s-part>
<s-number num = "09913-70123">
09913–70123
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH01520074.swf" width = "88.000mm" height = "73.733mm" ver = "01" gw = "139" gh = "192"/>
