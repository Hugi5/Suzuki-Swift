<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1406012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Cylinder Head Cover Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1406011">Cylinder Head Cover Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1406012001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove ignition coil assemblies. 
<intxreftitleoff1 refid = "AENBP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect engine harness clamps.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner bracket (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil level gauge (2).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect PCV hose (3) from PCV valve (4).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect breather hose (5) from cylinder head cover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove PCV valve from cylinder head cover, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Loosen cylinder head cover mounting bolts in numerical order (“1” – “7”) evenly and gradually.
</ptxt>
<figure>
<graphic graphicname = "I8RW0A140009.jpg" width = "88.000mm" height = "63.965mm" ver = "02" gw = "199" gh = "165"/>
</figure>
</s1>
<s1>
<ptxt>
Remove cylinder head cover (1) with gasket (2).
</ptxt>
<figure>
<graphic graphicname = "I6RS0B141004.swf" width = "88.000mm" height = "54.133mm" ver = "01" gw = "126" gh = "136"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1406012002">
<title>
Installation
</title>
<s1>
<ptxt>
Remove oil, old sealant and dust from sealing surfaces on cylinder head and cover.
</ptxt>
</s1>
<s1>
<ptxt>
Install new gasket (2) to cylinder head cover (1).
</ptxt>
<figure>
<graphic graphicname = "I6RS0B141005.swf" width = "88.000mm" height = "89.947mm" ver = "01" gw = "193" gh = "238"/>
</figure>
</s1>
<s1>
<ptxt>
Apply sealant “A” to the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Cylinder head cover gasket (1) sealing surface area (2) as shown.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1D001" uid = "41">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31250
</m-number>
<m-name>
SUZUKI Bond No.1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I2RH0B140036.swf" width = "88.000mm" height = "48.630mm" ver = "01" gw = "145" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Timing chain cover (1) and cylinder head (2) mating surface as shown.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1D002" uid = "41">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31250
</m-number>
<m-name>
SUZUKI Bond No.1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I2RH0B140037.swf" width = "88.000mm" height = "49.645mm" ver = "01" gw = "184" gh = "124"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Install cylinder head cover to cylinder head.
</ptxt>
<attention3>
<ptxt>
When installing cylinder head cover, use care so that cylinder head cover gasket will not get out of place or fall off.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Tighten cylinder head cover bolts according to the following procedure:
</ptxt>
<s2>
<ptxt>
Tighten cylinder head cover bolts to 3.0 N&#183;m (0.31 kgf-m, 2.5 lbf-ft) in numerical order (“1” – “7”) evenly and gradually.
</ptxt>
</s2>
<s2>
<ptxt>
Retighten them to 5.0 N&#183;m (0.51 kgf-m, 4.0 lbf-ft) in the same manner as in Step a).
</ptxt>
</s2>
<s2>
<ptxt>
Retighten them to 7.5 N&#183;m (0.76 kgf-m, 5.5 lbf-ft) in the same manner as in Step a).
</ptxt>
<torque>
<torqueitem id = "T1D004">
<t-part>
Cylinder head cover bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-note>
3.0 N&#183;m → 5.0 N&#183;m → 7.5 N&#183;m (0.31 kgf-m → 0.51 kgf-m→ 0.76 kgf-m, 2.5 lbf-ft → 4.0 lbf-ft → 5.5 lbf-ft)
</t-note>
</torqueitem>
</torque>
</s2>
<figure>
<graphic graphicname = "IBP60B140015.jpg" width = "88.000mm" height = "42.176mm" ver = "01" gw = "178" gh = "103"/>
</figure>
</s1>
<s1>
<ptxt>
Apply sealant to thread part of PCV valve (1), if removed.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1D003" uid = "41">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31250
</m-number>
<m-name>
SUZUKI Bond No.1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IBP60B140016.jpg" width = "88.000mm" height = "38.671mm" ver = "01" gw = "179" gh = "93"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.940in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
a.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
6 mm (0.24 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install PCV valve (1) to cylinder head cover and tighten PCV valve to specified torque, if removed.
</ptxt>
<torque>
<torqueitem id = "T1D005">
<t-part>
PCV valve
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
27
</t-value1>
<t-value2>
2.8
</t-value2>
<t-value3>
20.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect PCV hose (2) to PCV valve.
</ptxt>
</s1>
<s1>
<ptxt>
Connect breather hose (3) to cylinder head cover.
</ptxt>
</s1>
<s1>
<ptxt>
Install oil level gauge (4).
</ptxt>
</s1>
<s1>
<ptxt>
Install air cleaner bracket (5).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140017.jpg" width = "88.000mm" height = "63.965mm" ver = "02" gw = "199" gh = "165"/>
</figure>
</s1>
<s1>
<ptxt>
Install ignition coil assemblies. 
<intxreftitleoff1 refid = "AENBP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect engine harness clamps.
</ptxt>
</s1>
<s1>
<ptxt>
Install air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect negative (–) cable at battery.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
