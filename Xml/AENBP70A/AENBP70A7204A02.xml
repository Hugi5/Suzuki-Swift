<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A7204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Warm air dose not come out or insufficient heating
</title>
<diag type = "condition">
<condition>
<ptxt>
Warm air dose not come out or insufficient heating
</ptxt>
</condition>
<ps>
<ptxt>
Clogged air ducts
</ptxt>
</ps>
<action>
<ptxt>
Repair air ducts.
</ptxt>
</action>
<ps>
<ptxt>
Leaky or clogged heater core
</ptxt>
</ps>
<action>
<ptxt>
Replace heater core.
</ptxt>
</action>
<ps>
<ptxt>
Leaky or clogged heater hoses
</ptxt>
</ps>
<action>
<ptxt>
Replace heater hoses.
</ptxt>
</action>
<ps>
<ptxt>
Clogged air filter
</ptxt>
</ps>
<action>
<ptxt>
Replace air filter
</ptxt>
</action>
<ps>
<ptxt>
Faulty temperature control door assembly
</ptxt>
</ps>
<action>
<ptxt>
Check HVAC unit.
</ptxt>
</action>
<ps>
<ptxt>
Faulty temperature control actuator
</ptxt>
</ps>
<action>
<ptxt>
Check temperature control actuator. 
<intxreftitleoff1 refid = "AENBP70A7206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty evaporator temperature sensor
</ptxt>
</ps>
<action>
<ptxt>
Check evaporator temperature sensor. 
<intxreftitleoff1 refid = "AENBP70A7206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty inside air temperature sensor, outside air temperature sensor or sunload sensor
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check inside air temperature sensor, outside air temperature sensor or sunload sensor.
</ptxt>
<ptxt>
• Inside air temperature sensor: 
<intxreftitleoff1 refid = "AENBP70A7206034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
• Outside air temperature sensor: 
<intxreftitleoff1 refid = "AENBP70A7206032"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
• Sunload sensor: 
<intxreftitleoff1 refid = "AENBP70A7206030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<ptxt>
Check BCM. 
<intxreftitleoff1 refid = "AENBP70AA204022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty auto A/C panel
</ptxt>
</ps>
<action>
<ptxt>
Check auto A/C panel. 
<intxreftitleoff1 refid = "AENBP70A7204034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty HVAC control module
</ptxt>
</ps>
<action>
<ptxt>
Check HVAC control module. 
<intxreftitleoff1 refid = "AENBP70A7204035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
