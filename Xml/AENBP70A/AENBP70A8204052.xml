<servinfosub id = "AENBP70A8204052002">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENBP70A8204052003">
<testgroup id = "AENBP70A8204052004">
<title>
Battery voltage check
</title>
<test1>
<ptxt>
Check battery voltage.
</ptxt>
</test1>
<question>
Is voltage in 9 – 16 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check charging system and repair it. 
<intxreftitleoff1 refid = "AENBP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204052005">
<title>
SDM connection check
</title>
<test1>
<ptxt>
Check SDM connector for proper connection.
</ptxt>
</test1>
<question>
Is it connected securely?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Intermittent trouble. Check for intermittent trouble. 
<intxreftitleoff1 refid = "AENBP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If OK, substitute a known-good SDM and recheck connection. 
<intxreftitleoff1 refid = "AENBP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AENBP70A8204052006">
<title>
Fuse check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Check “A/B” fuse.
</ptxt>
</test1>
<question>
Is “A/B” fuse in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness and then replace “A/B” fuse.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204052007">
<title>
Power circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “L04” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Measure voltage between “L04-18” terminal and ground.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B090">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820157.swf" width = "90.000mm" height = "34.401mm" ver = "01" gw = "194" gh = "81"/>
</testfigure>
</test1>
<question>
Is voltage in 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204052008">
<title>
Ground circuit check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Measure resistance between “L04-23” terminal and ground.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B091">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820158.swf" width = "90.000mm" height = "34.895mm" ver = "01" gw = "193" gh = "82"/>
</testfigure>
</test1>
<question>
Is resistance 1 Ω or less?
</question>
<result type = "yes"/>
<action>
<ptxt>
SDM power circuit and ground circuit are in good condition.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
</diag>
