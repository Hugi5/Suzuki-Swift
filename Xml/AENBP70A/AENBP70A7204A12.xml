<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A7204A12" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Loud noise is heard at certain rpm, irrespective of greatness of speed in
</title>
<servinfosub id = "AENBP70A7204004001">
<title>
Abnormal Noise from A/C Compressor
</title>
<diag type = "condition">
<condition>
<ptxt>
Loud noise is heard at certain rpm, irrespective of greatness of speed in
</ptxt>
</condition>
<ps>
<ptxt>
Loose or broken compressor drive belt
</ptxt>
</ps>
<action>
<ptxt>
Check compressor drive belt. 
<intxreftitleoff1 refid = "AENBP70A7206041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose compressor mounting bolts
</ptxt>
</ps>
<action>
<ptxt>
Retighten mounting bolts. 
<intxreftitleoff1 refid = "AENBP70A7206043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
