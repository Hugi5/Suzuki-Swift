<ptxt>
HO2S-1 heater
</ptxt>
</item>
<item>
<ptxt>
Air intake system
</ptxt>
</item>
<item>
<ptxt>
Exhaust system
</ptxt>
</item>
<item>
<ptxt>
Fuel system
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
