<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70AA304001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "1">
<title>
Immobilizer Control System Check
</title>
<diag type = "test" id = "AENBP70AA304001001">
<testgroup id = "AENBP70AA304001002">
<title>
Ignition ON check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Depress clutch pedal (M/T model) or brake pedal (CVT model).
</ptxt>
</test1>
<question>
Do “ON” indicator light and push indicator light come on?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70AA504001">Keyless Start System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA304001003">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENBP70AA304003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is there any DTC detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA304001004">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC related to CAN communication.
</ptxt>
</test1>
<question>
Is there any CAN-DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for CAN-DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA304001005">
<question>
Is engine cranked?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A1904001">Cranking System Symptom Diagnosis</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA304001006">
<title>
Engine start check
</title>
<question>
Does engine start?
</question>
<result type = "yes"/>
<action>
<ptxt>
Immobilizer control system is in good condition.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A1104009">Engine Basic Inspection</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
