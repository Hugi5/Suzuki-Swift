<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9806011" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Head Lining Removal and Installation
</title>
<servinfosub id = "AENBP70A9806011001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENBP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove sun visors (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove spot light (2) and dome light (3).
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Spot light: 
<intxreftitleoff1 refid = "AENBP70A9206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dome light: 
<intxreftitleoff1 refid = "AENBP70A9206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove the following trims. 
<intxreftitleoff1 refid = "AENBP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front pillar trims
</ptxt>
</item>
<item>
<ptxt>
Center pillar upper trims
</ptxt>
</item>
<item>
<ptxt>
Quarter inner upper trims
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove assist grips (4).
</ptxt>
</s1>
<s1>
<ptxt>
Remove clips and remove head lining (5).
</ptxt>
<figure>
<graphic graphicname = "IBP70A980009.jpg" width = "183.000mm" height = "108.773mm" ver = "01" gw = "456" gh = "292"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9806011002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Enable air bag system. 
<intxreftitleoff1 refid = "AENBP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
