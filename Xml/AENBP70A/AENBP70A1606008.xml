<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1606008" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Thermostat Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1606007">Thermostat Removal and Installation</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check that air bleed valve (1) is clean.
</ptxt>
</item>
<item>
<ptxt>
Check that valve seat (2) is free from foreign matter that would prevent valve from seating tight.
</ptxt>
</item>
<item>
<ptxt>
Check thermostat seal (3) for breakage, deterioration or any other damage.
</ptxt>
<figure>
<graphic graphicname = "I3RM0A160008.swf" width = "88.000mm" height = "42.703mm" ver = "01" gw = "130" gh = "104"/>
</figure>
</item>
<item>
<ptxt>
Check thermostat operation as follows.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Immerse thermostat (1) in water, and heat water gradually.
</ptxt>
</item>
<item>
<ptxt>
Check that wax pellet starts to open at specific temperature.
</ptxt>
<spec>
<title>
Temperature at which valve starts to open (lift 0.05 mm (0.002 in)):
</title>
<ptxt>
86 – 90 &#176;C (186.8 – 194.0 &#176;F)
</ptxt>
</spec>
<spec>
<title>
Temperature at which valve becomes fully open:
</title>
<ptxt>
100 – 102 &#176;C (212.0 – 215.6 &#176;F)
</ptxt>
</spec>
<spec>
<title>
Valve lift:
</title>
<ptxt>
More than 8 mm (0.31 in) at 100 &#176;C (212 &#176;F)
</ptxt>
</spec>
<figure page = "2">
<graphic graphicname = "I2RH01160012.swf" width = "88.000mm" height = "55.869mm" ver = "01" gw = "111" gh = "141"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.291in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.328in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.265in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Thermometer
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Heater
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list2>
<item>
<ptxt>
If check result is not satisfactory, replace thermostat. 
<intxreftitleoff1 refid = "AENBP70A1606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
