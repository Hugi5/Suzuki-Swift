<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A5504063" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1704 / P1712
</title>
<servinfosub id = "AENBP70A5504063001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.771in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.431in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1704: Internal Control Module FLASH Memory Error
</emph>
</ptxt>
<ptxt>
TCM internal failure (backup error).
</ptxt>
<ptxt>
(1 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
TCM power supply circuit and/or ground circuit
</ptxt>
</item>
<item>
<ptxt>
CVT relay
</ptxt>
</item>
<item>
<ptxt>
TCM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1712: CVT Power Relay Control Circuit
</emph>
</ptxt>
<ptxt>
TCM power supply voltage from CVT relay is lower than specified value for specified time.
</ptxt>
<ptxt>
(1 D/C detection logic)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENBP70A5504063002">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition ON.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5504063003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A5504063004">
<testgroup id = "AENBP70A5504063005">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504063006">
<title>
DTC check 
</title>
<question>
Is there any DTC(s) other than P1704 or P1712?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504063007">
<title>
TCM power supply circuit, ground circuit and CVT relay check
</title>
<test1>
<ptxt>
Check TCM power supply circuit, ground circuit and CVT relay. 
<intxreftitleoff1 refid = "AENBP70A5504054"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
