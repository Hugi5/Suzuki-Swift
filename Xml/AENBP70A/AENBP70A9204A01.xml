<title>
Only one low-beam headlight lights up
</title>
<diag type = "condition">
<condition>
<ptxt>
Only one low-beam headlight lights up
</ptxt>
</condition>
<ps>
<ptxt>
Blown bulb
</ptxt>
</ps>
<action>
<ptxt>
Replace bulb.
</ptxt>
</action>
<ps>
<ptxt>
Faulty ballast or igniter
</ptxt>
</ps>
<action>
<ptxt>
Replace ballast or igniter.
</ptxt>
</action>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
Repair circuit and replace relay and/or fuse.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
