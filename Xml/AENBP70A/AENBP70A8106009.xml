<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A8106009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Side Seat Belt Assembly Removal and Installation
</title>
<servinfosub id = "AENBP70A8106009001">
<title>
Removal
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A8106008">Rear Seat Belt Components</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Remove rear seatback. 
<intxreftitleoff1 refid = "AENBP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove quarter inner upper trim. 
<intxreftitleoff1 refid = "AENBP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove bolts and then remove rear side seat belt assembly. 
<intxreftitleoff1 refid = "AENBP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A8106009002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A8106008">Rear Seat Belt Components</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check that pins (3) on body are inserted in long holes (2) in retractor (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A810014.swf" width = "88.000mm" height = "66.076mm" ver = "01" gw = "206" gh = "171"/>
</figure>
</item>
<item>
<ptxt>
Tighten bolts of rear side seat belt in numerical order to specified torque. 
<intxreftitleoff1 refid = "AENBP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Install each anchor plate (1) without interference with bead (2) on floor paneling.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810015.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
