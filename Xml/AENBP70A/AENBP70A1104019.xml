<servinfosub id = "AENBP70A1104019003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following DTC is not detected in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
ECT sensor (P0118)
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Warm up engine to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Run engine at idle for 5 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1104019004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A1104019005">
<testgroup id = "AENBP70A1104019006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104019007">
<title>
Coolant level check
</title>
<test1>
<ptxt>
Check coolant level. 
<intxreftitleoff1 refid = "AENBP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Add coolant and recheck DTC.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104019008">
<title>
ECT sensor circuit check
</title>
<test1>
<ptxt>
Check ECT sensor circuits according to Step 2 under 
<intxref refid = "AENBP70A1104020">DTC P0117 / P0118</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104019009">
<title>
ECT sensor check
</title>
<test1>
<ptxt>
Check ECT sensor. 
<intxreftitleoff1 refid = "AENBP70A1306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace ECT sensor.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104019010">
<title>
Thermostat check
</title>
<test1>
<ptxt>
Check thermostat. 
<intxreftitleoff1 refid = "AENBP70A1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace thermostat.
</ptxt>
</action>
</testgroup>
