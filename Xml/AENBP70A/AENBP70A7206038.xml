<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206038" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
HVAC Air Filter Removal and Installation
</title>
<servinfosub id = "AENBP70A7206038001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove glove box. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove HVAC air filter cover (2) from HVAC unit.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air filter (1) from HVAC unit.
</ptxt>
<figure>
<graphic graphicname = "IBP70A720015.swf" width = "88.000mm" height = "59.699mm" ver = "01" gw = "223" gh = "153"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENBP70A7206038002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Position air filter (1) directing its arrow mark (2) upward.
</ptxt>
<figure>
<graphic graphicname = "IBP70A720016.swf" width = "88.000mm" height = "58.839mm" ver = "01" gw = "190" gh = "150"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
