<servinfo servinfosgmlid = "AENBP70A8204003" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
AIR BAG Warning Light Check
</title>
<s1>
<ptxt>
Set ignition ON.
</ptxt>
</s1>
<s1>
<ptxt>
Make sure that AIR BAG warning light (1) is on for 6 seconds. If AIR BAG warning light is not on, refer to 
<intxref refid = "AENBP70A8204010">AIR BAG Warning Light Does Not Come ON</intxref>
. If AIR BAG warning light is kept on and no DTC is detected in SDM, refer to 
<intxref refid = "AENBP70A8204009">AIR BAG Warning Light Comes ON Steady</intxref>
.
</ptxt>
<figure>
<graphic graphicname = "IBP70A820005.swf" width = "88.000mm" height = "64.787mm" ver = "01" gw = "228" gh = "167"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
