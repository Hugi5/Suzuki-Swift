<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10H">
<servcat sctnbr = "10" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70AA804001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
CAN Communication Check
</title>
<ptxt>
Using SUZUKI scan tool, execute “Communication Malfunction DTC” under “Bus check” and check DTCs of all control modules, etc. connected to CAN Communication Bus.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "3" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.854in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.854in"/>
<colspec colnum = "3" colname = "3" colwidth = "1.457in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Action
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Reference
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Only history DTC was detected in either of system
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Check DTC as follows:
</ptxt>
<list1 type = "ordered">
<item>
<ptxt>
Disconnect and connect all control module and sensor connectors connected to the CAN communication line.
</ptxt>
</item>
<item>
<ptxt>
Check all control module power sources (including fuses) connected to the CAN communication line.
</ptxt>
</item>
<item>
<ptxt>
Start the engine and check DTC while idling.
</ptxt>
<ptxt>
If the detected DTC is a history DTC, there may be a temporary malfunction due to poor connection at the connector or faulty power supply.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
—
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
“Control Module Bus Off” was detected in either of system (current DTC)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Perform “Troubleshooting for Communication Bus Off”.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
<intxreftitleoff1 refid = "AENBP70AA804004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Only “Lost Communication” was detected in either of system (current DTC)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Perform “Troubleshooting for Lost Communication”.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
<intxreftitleoff1 refid = "AENBP70AA804003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
No display on SUZUKI scan tool (It is not possible to communicate with all systems.)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Check if SUZUKI scan tool is communicable by connecting it to another vehicle.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
—
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Perform “Troubleshooting for Lost Communication”.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
<intxreftitleoff1 refid = "AENBP70AA804003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
