<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1506003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Oil Cooler Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1506001">Oil Cooler Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENBP70A1506002">Oil Cooler On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1506003001">
<title>
Removal
</title>
<s1>
<ptxt>
Drain engine oil by removing drain plug.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Drain engine coolant. 
<intxreftitleoff1 refid = "AENBP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust manifold. 
<intxreftitleoff1 refid = "AENBP70A1B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil cooler inlet hose (1) and outlet hose No.1 (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150008.jpg" width = "88.000mm" height = "71.517mm" ver = "01" gw = "225" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Remove oil cooler stand bolt (1).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove oil cooler (2), gasket (3) and O-ring (4).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150009.jpg" width = "88.000mm" height = "72.799mm" ver = "02" gw = "222" gh = "190"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove oil filter adapter case (1) and its gasket (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150010.jpg" width = "88.000mm" height = "69.127mm" ver = "01" gw = "218" gh = "179"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1506003002">
<title>
Installation
</title>
<s1>
<ptxt>
Install oil filter adapter case (1) and new gasket (2) and then tighten oil filter adapter case bolts (3) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E002">
<t-part>
Oil filter adapter case bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B150011.jpg" width = "88.000mm" height = "68.856mm" ver = "01" gw = "217" gh = "179"/>
</figure>
</s1>
<s1>
<ptxt>
Apply engine oil to new O-ring (1) and install it to oil cooler (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150012.jpg" width = "88.000mm" height = "62.642mm" ver = "01" gw = "208" gh = "161"/>
</figure>
</s1>
<s1>
<ptxt>
Install oil cooler (1) aligning projection (2) of oil cooler in rib (3) of oil filter adapter as shown in figure.
</ptxt>
</s1>
<s1>
<ptxt>
Install new gasket and oil cooler stand bolt (4) and then tighten oil cooler stand bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E003">
<t-part>
Oil cooler stand bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
22
</t-value1>
<t-value2>
2.2
</t-value2>
<t-value3>
16.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B150013.jpg" width = "88.000mm" height = "108.581mm" ver = "02" gw = "226" gh = "291"/>
</figure>
</s1>
<s1>
<ptxt>
Install oil cooler inlet hose (1) and outlet hose No.1 (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150008.jpg" width = "88.000mm" height = "71.517mm" ver = "01" gw = "225" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Install exhaust manifold. 
<intxreftitleoff1 refid = "AENBP70A1B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install drain plug and refill engine with engine oil. 
<intxreftitleoff1 refid = "AENBP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENBP70A1606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check for any leakage of coolant, engine oil and exhaust gas.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Coolant leak: 
<intxreftitleoff1 refid = "AENBP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
