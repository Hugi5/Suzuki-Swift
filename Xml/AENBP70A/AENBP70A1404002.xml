<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A1404002" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Engine Vacuum Check
</title>
<s1>
<ptxt>
Warm up engine to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, place gear shift lever in “Neutral” and apply parking brake.
</ptxt>
<ptxt>
For CVT model, place select lever in “P” and apply parking brake.
</ptxt>
</s1>
<s1>
<ptxt>
Stop engine and turn off all electric switches.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove PCV hose (1) from PCV valve (2).
</ptxt>
<figure>
<graphic graphicname = "I8RW0A140003.jpg" width = "88.000mm" height = "62.477mm" ver = "01" gw = "199" gh = "161"/>
</figure>
</s1>
<s1>
<ptxt>
Connect special tool to PCV hose (1).
</ptxt>
<servicetool>
<servicetoolitem id = "L1D004">
<s-part>
(A)
</s-part>
<s-number num = "09915-67311">
09915–67311
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Close PCV valve (2) using tape (3) or the like.
</ptxt>
</s1>
<s1>
<ptxt>
Install air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I8RW0A140004.jpg" width = "88.000mm" height = "64.476mm" ver = "01" gw = "199" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Run engine at specified idle speed. 
<intxreftitleoff1 refid = "AENBP70A1106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Read vacuum gauge. Vacuum should be within specification.
</ptxt>
<spec>
<title>
Vacuum specification (at sea level)
</title>
<ptxt>
–56 to –70 kPa (–0.6 to –0.7 kgf/cm<sup>2</sup>, –8.13 to –10.15 psi, –0.56 to –0.70 bar) or less at specified idle speed
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect special tool from PCV hose.
</ptxt>
</s1>
<s1>
<ptxt>
Pull off tape from PCV valve.
</ptxt>
</s1>
<s1>
<ptxt>
Install air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
