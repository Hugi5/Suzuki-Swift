<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1506002" svcinfotypenbr = "08" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
Oil Cooler On-Vehicle Inspection
</title>
<list1 type = "unordered">
<item>
<ptxt>
Check oil cooler for deformation, wear or damage.
</ptxt>
</item>
<item>
<ptxt>
Check oil cooler for coolant leakage and oil leakage.
</ptxt>
</item>
</list1>
<ptxt>
If any defect is found, replace O-ring, stand bolt gasket and/or oil cooler.
</ptxt>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
