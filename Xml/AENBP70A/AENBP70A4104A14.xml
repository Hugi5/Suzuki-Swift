<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A4104A14" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Brake warning light does not turn on after setting ignition ON
</title>
<diag type = "condition">
<condition>
<ptxt>
Brake warning light does not turn on after setting ignition ON
</ptxt>
</condition>
<ps>
<ptxt>
Faulty combination meter power supply and ground circuit
</ptxt>
</ps>
<action>
<ptxt>
Check combination meter and its circuit. 
<intxreftitleoff1 refid = "AENBP70A9304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty combination meter
</ptxt>
</ps>
<action>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ABS warning light is flashing
</ptxt>
</ps>
<action>
<ptxt>
Detect malfunction and repair. 
<intxreftitleoff1 refid = "AENBP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ESP<sup>®</sup> control module
</ptxt>
</ps>
<action>
<ptxt>
Replace ESP<sup>®</sup> control module. 
<intxreftitleoff1 refid = "AENBP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
