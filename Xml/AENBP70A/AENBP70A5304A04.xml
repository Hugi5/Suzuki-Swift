<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A5304A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Noisy clutch
</title>
<diag type = "condition">
<condition>
<ptxt>
Noisy clutch
</ptxt>
</condition>
<ps>
<ptxt>
Worn or broken release bearing
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch operating cylinder assembly. 
<intxreftitleoff1 refid = "AENBP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Excessive rattle of clutch disc hub
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cracked clutch disc
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pressure plate and diaphragm spring rattling
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch cover. 
<intxreftitleoff1 refid = "AENBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
