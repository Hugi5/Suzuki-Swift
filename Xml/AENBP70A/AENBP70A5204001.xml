<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A5204001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "1">
<title>
Manual Transaxle Symptom Diagnosis
</title>
<diag type = "condition" id = "AENBP70A5204001001">
<condition>
<ptxt>
Gears slipping out of mesh
</ptxt>
</condition>
<ps>
<ptxt>
Worn shift shaft
</ptxt>
</ps>
<action>
<ptxt>
Replace shift shaft. 
<intxreftitleoff1 refid = "AENBP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn shift fork or synchronizer sleeve
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace shift fork or synchronizer sleeve.
</ptxt>
<ptxt>
Shift fork: 
<intxreftitleoff1 refid = "AENBP70A5206026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Input shaft: 
<intxreftitleoff1 refid = "AENBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Countershaft: 
<intxreftitleoff1 refid = "AENBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Weak or damaged gear locating spring
</ptxt>
</ps>
<action>
<ptxt>
Replace gear locating spring. 
<intxreftitleoff1 refid = "AENBP70A5206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn bearings on input shaft or countershaft
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace input shaft bearing or countershaft bearing.
</ptxt>
<ptxt>
Input shaft bearing: 
<intxreftitleoff1 refid = "AENBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Countershaft bearing: 
<intxreftitleoff1 refid = "AENBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Worn chamfered tooth on sleeve and gear
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace synchronizer sleeve and gear.
</ptxt>
<ptxt>
Input shaft: 
<intxreftitleoff1 refid = "AENBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
<ptxt>
Countershaft: 
<intxreftitleoff1 refid = "AENBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<condition>
<ptxt>
Hard shifting
</ptxt>
</condition>
<ps>
<ptxt>
Insufficient lubricant
</ptxt>
</ps>
<action>
<ptxt>
Replenish manual transaxle oil. 
<intxreftitleoff1 refid = "AENBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Improper clutch pedal free travel
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace clutch operating cylinder or master cylinder
</ptxt>
<ptxt>
 Clutch operating cylinder: 
<intxreftitleoff1 refid = "AENBP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Clutch master cylinder: 
<intxreftitleoff1 refid = "AENBP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
