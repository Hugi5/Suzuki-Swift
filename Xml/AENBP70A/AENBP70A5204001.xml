</ptxt>
</ps>
<action>
<ptxt>
Replace gear shift and select cable. 
<intxreftitleoff1 refid = "AENBP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Noise
</ptxt>
</condition>
<ps>
<ptxt>
Insufficient lubricant
</ptxt>
</ps>
<action>
<ptxt>
Replenish manual transaxle oil. 
<intxreftitleoff1 refid = "AENBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Damaged or worn bearing(s)
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace bearing.
</ptxt>
<ptxt>
Input shaft: 
<intxreftitleoff1 refid = "AENBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Countershaft: 
<intxreftitleoff1 refid = "AENBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Damaged or worn gear(s)
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace gear.
</ptxt>
<ptxt>
Input shaft: 
<intxreftitleoff1 refid = "AENBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Countershaft: 
<intxreftitleoff1 refid = "AENBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
