<servinfosub id = "AENBP70A1706002007" page = "2">
<title>
Quick Joint Connections 
</title>
<topic id = "AENBP70A1706002008">
<title>
Disconnection
</title>
<s1>
<ptxt>
Remove mud, dust and/or foreign material between pipe (1) and quick joint (2) using compressed air.
</ptxt>
</s1>
<s1>
<ptxt>
Unlock joint lock by inserting special tool between pipe and quick joint.
</ptxt>
</s1>
<servicetool>
<servicetoolitem id = "L1G008">
<s-part>
(A)
</s-part>
<s-number num = "09919-47020">
09919–47020
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<s1>
<ptxt>
Disconnect quick joint from pipe.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A170019.swf" width = "88.000mm" height = "35.194mm" ver = "01" gw = "137" gh = "84"/>
</figure>
</s1>
</topic>
<topic id = "AENBP70A1706002009">
<title>
Reconnection
</title>
<ptxt>
Insert quick joint to fuel pipe until a click is heard, and confirm that quick joint is not disconnected by hand.
</ptxt>
</topic>
</servinfosub>
</servinfo>
