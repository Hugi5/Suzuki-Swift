<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1306014" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
CMP Sensor Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1306013">CMP Sensor Removal and Installation</intxrefpoff>
</ptxt>
<s1 page = "2">
<ptxt>
Remove CMP sensor. 
<intxreftitleoff1 refid = "AENBP70A1306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
O-ring (1) is free from damage.
</ptxt>
</item>
<item>
<ptxt>
End face of CMP sensor and signal rotor teeth are free from any metal particles and damage.
</ptxt>
<figure>
<graphic graphicname = "IBP60B130011.jpg" width = "88.000mm" height = "40.076mm" ver = "01" gw = "137" gh = "97"/>
</figure>
</item>
</list1>
</s1>
<c-change/>
<s1 page = "2">
<ptxt>
Check CMP sensor as follows.
</ptxt>
<ptxt>
If faulty condition is found, replace CMP sensor. 
<intxreftitleoff1 refid = "AENBP70A1306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<s2>
<ptxt>
Connect battery (1) and ohmmeter (3) to CMP sensor as shown in figure.
</ptxt>
</s2>
<s2>
<ptxt>
Check that CMP sensor resistance varies as specified below by passing ferromagnetic material (iron) (2) in front of CMP sensor.
</ptxt>
</s2>
<attention3>
<ptxt>
Be sure to keep approximately 1 mm (0.03 in) gap “a” between ferromagnetic material (iron) and end face of CMP sensor.
</ptxt>
</attention3>
<spec>
<title>
CMP sensor resistance
</title>
<ptxt>
Resistance alternates between 220 Ω or smaller and infinity.
</ptxt>
<figure>
<graphic graphicname = "IBP60B130012.jpg" width = "88.000mm" height = "46.219mm" ver = "02" gw = "190" gh = "115"/>
</figure>
</spec>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
