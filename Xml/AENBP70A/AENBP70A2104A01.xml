<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A2104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Vehicle pulls to one side (leads)
</title>
<diag type = "condition">
<condition>
<ptxt>
Vehicle pulls to one side (leads)
</ptxt>
</condition>
<ps>
<ptxt>
Mismatched or unevenly worn tires
</ptxt>
</ps>
<action>
<ptxt>
Replace tires. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Tires not adequately inflated
</ptxt>
</ps>
<action>
<ptxt>
Adjust tire pressure.
</ptxt>
</action>
<ps>
<ptxt>
Broken or sagging coil springs
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace coil springs.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENBP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENBP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Abnormal lateral force created by radial tire
</ptxt>
</ps>
<action>
<ptxt>
Replace tire. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disturbed wheel alignment
</ptxt>
</ps>
<action>
<ptxt>
Check and adjust wheel alignment. 
<intxreftitleoff1 refid = "AENBP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Brake dragging in one road wheel
</ptxt>
</ps>
<action>
<ptxt>
Adjust or repair brake.
</ptxt>
</action>
<ps>
<ptxt>
Loose, bent or broken front or rear suspension parts
</ptxt>
</ps>
<action>
<ptxt>
Tighten or replace related suspension parts. 
<intxreftitleoff1 refid = "AENBP70A2106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
