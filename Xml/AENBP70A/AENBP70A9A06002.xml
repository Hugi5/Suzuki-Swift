<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9A06002" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Hood Inspection and Adjustment
</title>
<servinfosub id = "AENBP70A9A06002001">
<title>
Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A9A06001">Hood Removal and Installation</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check that hood opens and closes smoothly and properly. Lubricate it if necessary.
</ptxt>
</item>
<item>
<ptxt>
Check that hood stops in secondary latch position properly when hood lock is released.
</ptxt>
</item>
<item>
<ptxt>
Check that hood closes completely in full latch position.
</ptxt>
</item>
<item>
<ptxt>
Adjust hood lock position if necessary.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "AENBP70A9A06002002">
<title>
Adjustment
</title>
<topic id = "AENBP70A9A06002003">
<title>
Horizontal adjustment of hood
</title>
<ptxt>
Loosen hood hinge bolts and adjust installation position of hood. 
<intxreftitleoff1 refid = "AENBP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</topic>
<topic id = "AENBP70A9A06002004">
<title>
Vertical adjustment of hood
</title>
<ptxt>
Turn hood cushion (1) if there is a step between hood and front fender.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9A0003.jpg" width = "88.000mm" height = "56.000mm" ver = "01" gw = "227" gh = "142"/>
</figure>
</topic>
<topic id = "AENBP70A9A06002005">
<title>
Hood lock position adjustment
</title>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Loosen hood latch bolts (1) and adjust height of hood latch (2).
</ptxt>
</s1>
<s1>
<ptxt>
Tighten hood latch bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9J001">
<t-part>
Hood latch bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A9A0004.jpg" width = "88.000mm" height = "56.000mm" ver = "01" gw = "227" gh = "142"/>
</figure>
</s1>
<s1>
<ptxt>
Make sure hood is locked smoothly and securely.
</ptxt>
</s1>
</topic>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
