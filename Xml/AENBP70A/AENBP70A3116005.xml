<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A3116005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Drive Intermediate Shaft Assembly Removal and Installation
</title>
<attention4>
<ptxt>
Oil leaks will occur if the oil seal lip is damaged.
</ptxt>
<ptxt>
Do not pull out or push in the drive intermediate shaft at an angle. Slide the shaft in axial direction.
</ptxt>
</attention4>
<servinfosub id = "AENBP70A3116005001">
<title>
Removal
</title>
<s1>
<ptxt>
Drain transaxle oil. 
<intxreftitleoff1 refid = "AENBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove right side front drive shaft assembly. 
<intxreftitleoff1 refid = "AENBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For CVT model, remove engine harness ground terminal (1) from intermediate shaft bearing support.
</ptxt>
<figure>
<graphic graphicname = "IBP70A311006.jpg" width = "88.000mm" height = "60.695mm" ver = "02" gw = "199" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Remove intermediate support bolts (1) and drive intermediate shaft assembly (2) from transaxle.
</ptxt>
<figure>
<graphic graphicname = "IBP70A311007.jpg" width = "88.000mm" height = "74.762mm" ver = "02" gw = "185" gh = "195"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A3116005002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new circlip.
</ptxt>
</item>
<item>
<ptxt>
Tighten intermediate support bolts (1) by hand first in order of “1” to “3” indicated in figure and them to specified torque in order of “4” – “6”.
</ptxt>
<torque>
<torqueitem id = "T3A102">
<t-part>
Intermediate support bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A311008.jpg" width = "88.000mm" height = "72.596mm" ver = "02" gw = "185" gh = "189"/>
</figure>
</item>
<item>
<ptxt>
For CVT model, tighten engine harness ground bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T3A103">
<t-part>
Engine harness ground bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A311009.jpg" width = "88.000mm" height = "58.155mm" ver = "02" gw = "199" gh = "148"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
