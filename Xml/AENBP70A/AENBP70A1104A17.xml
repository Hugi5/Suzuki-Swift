<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A1104A17" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Excessive nitrogen oxides (NOx) emission
</title>
<ptxt>
Perform troubleshooting referring to the following points when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENBP70A1104008">Visual Inspection</intxref>
 and 
<intxref refid = "AENBP70A1104009">Engine Basic Inspection</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Excessive nitrogen oxides (NOx) emission
</ptxt>
</condition>
<ps>
<ptxt>
Improper ignition timing
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1806005">Ignition Timing Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Lead contamination of TWC
</ptxt>
</ps>
<action>
<ptxt>
Check for absence of filler neck restrictor.
</ptxt>
</action>
<ps>
<ptxt>
Fuel pressure out of specification
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1704005">Fuel Pressure Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty closed-loop system (A/F feedback compensation) (Poor performance of ECT sensor or MAF sensor)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1306009">ECT Sensor Inspection</intxref>
 or 
<intxref refid = "AENBP70A1306022">MAF and IAT Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty electric throttle body assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1306003">Electric Throttle Body Assembly On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty APP sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1306007">APP Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty injector
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1704003">Fuel Injector Circuit Check</intxref>
 or 
<intxref refid = "AENBP70A1706009">Fuel Injector Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1104067">Inspection of ECM and Its Circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
VVT system out of order
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
VVT actuator: 
<intxref refid = "AENBP70A1406025">VVT Actuator, Camshaft, Tappet and Shim Inspection</intxref>
</ptxt>
</item>
<item>
<ptxt>
Valve timing: 
<intxref refid = "AENBP70A1406022">Timing Chain and Chain Tensioner Inspection</intxref>
</ptxt>
</item>
<item>
<ptxt>
OCV oil circuit: 
<intxref refid = "AENBP70A1406017">Timing Chain Cover Inspection</intxref>
</ptxt>
</item>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
