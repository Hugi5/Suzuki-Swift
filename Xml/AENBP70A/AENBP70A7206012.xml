<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206012" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Blower Motor Inspection
</title>
<list1 type = "unordered">
<item>
<ptxt>
Check resistance between two blower motor terminals as shown.
</ptxt>
<ptxt>
If there is no continuity, replace blower motor.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721013.swf" width = "88.000mm" height = "42.472mm" ver = "01" gw = "219" gh = "104"/>
</figure>
</item>
<item>
<ptxt>
Check blower motor for operation and current.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Put blower motor (1) in a soft-jawed vise.
</ptxt>
</item>
<item>
<ptxt>
Connect battery to blower motor as shown.
</ptxt>
</item>
<item>
<ptxt>
Check if blower motor operates smoothly without noise.
</ptxt>
</item>
<item>
<ptxt>
Check that the ammeter indicates specified current when the voltage is applied for 1 min.
</ptxt>
<ptxt>
If check result is not as specified, replace blower motor.
</ptxt>
<spec>
<title>
Blower motor specified current at 12 V
</title>
<ptxt>
16 A maximum at 20 – 25 &#176;C (68 – 77 &#176;F)
</ptxt>
<figure>
<graphic graphicname = "I9P60A721039.swf" width = "88.000mm" height = "44.463mm" ver = "01" gw = "206" gh = "110"/>
</figure>
</spec>
</item>
</list2>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
