<servinfosub id = "AENBP70A5504037003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed with two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<ptxt>
Check that the following conditions are satisfied in this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
DTC P0717 or P0793 is not detected.
</ptxt>
</item>
<item>
<ptxt>
CVT fluid temperature &#62; –20 &#176;C (–4 &#176;F)
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Drive vehicle at 10 km/h (6 mile/h).
</ptxt>
</s1>
<s1>
<ptxt>
Decelerate vehicle at least twice. (Release accelerator pedal, press accelerator pedal again before vehicle comes to stop, and then release accelerator pedal again.)
</ptxt>
</s1>
<s1>
<ptxt>
Stop vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition OFF, and leave ignition OFF for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 1) through 2) twice.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5504037004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A5504037005">
<testgroup id = "AENBP70A5504037006">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504037007">
<title>
Line pressure control solenoid valve drive circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C142”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C142”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A2” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit terminal and other terminal at “C142” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A2” circuit: approx. 0 V (when ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504037008">
<title>
Line pressure control solenoid valve check
</title>
<test1>
<ptxt>
Check resistance of line pressure control solenoid valve. 
<intxreftitleoff1 refid = "AENBP70A5506028"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace line pressure control solenoid valve (CVT assembly). 
<intxreftitleoff1 refid = "AENBP70A5506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504037009">
<title>
Line pressure control solenoid valve drive circuit signal check
</title>
<test1>
<ptxt>
Connect “C142”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Connect an oscilloscope between “A2” and ground, and then check line pressure control solenoid valve drive circuit signals. 
<intxreftitleoff1 refid = "AENBP70A5504053"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace CVT assembly. 
<intxreftitleoff1 refid = "AENBP70A5506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
