<servinfosub id = "AENBP70A5504059003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Check that the following conditions are satisfied in this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
CVT fluid temperature &#62; –20 &#176;C (–4 &#176;F)
</ptxt>
</item>
<item>
<ptxt>
11 V &#60; Battery voltage &#60; 15 V
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Set ignition ON for 5 sec. or more.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5504059004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A5504059005">
<testgroup id = "AENBP70A5504059006">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504059007">
<title>
Secondary pressure sensor drive circuit signal check
</title>
<test1>
<ptxt>
With ignition OFF, connect SUZUKI scan tool to DLC.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Line pressure” parameter displayed on SUZUKI scan tool while engine is idling or when performing stall test.
</ptxt>
</test1>
<question>
Is displayed parameter 6 MPa or more?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504059008">
<title>
Secondary pressure sensor ground circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C142” connector. 
<intxreftitleoff1 refid = "AENBP70A5506036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check voltage between “A1” and “A3” circuit.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace CVT assembly. 
<intxreftitleoff1 refid = "AENBP70A5506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</action>
</testgroup>
<testgroup id = "AENBP70A5504059009">
<title>
Secondary pressure sensor signal circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C142”, “C09” and “E19” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “A2” circuit terminal and other terminal at “C142” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A2” circuit: approx. 0 V (when ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504059010">
<title>
Secondary pressure sensor check
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENBP70A5506039">Secondary Pressure Sensor Inspection</intxref>
.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace secondary pressure sensor (CVT assembly). 
<intxreftitleoff1 refid = "AENBP70A5506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</action>
</testgroup>
</diag>
