<servinfosub id = "AENBP70A6304010002">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENBP70A6304010003">
<testgroup id = "AENBP70A6304010004">
<title>
P/S warning light check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<question>
Do other warning lights come on?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304010005">
<title>
DTC check
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENBP70A6304003">DTC Check</intxref>
.
</ptxt>
</test1>
<question>
Is there DTC U0073 or DTC U0155?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70AA804002">CAN DTC (Lost Communication and Communication Bus Off) Table</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304010006">
<title>
Combination meter check
</title>
<test1>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<question>
Does P/S warning light stay off?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace P/S control module. 
<intxreftitleoff1 refid = "AENBP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304010007">
<title>
Fuse check
</title>
<question>
Is “MTR” fuse for combination meter in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Replace “MTR” fuse and check for short circuit to ground.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AENBP70A6304010008">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Check CAN communication circuit between combination meter and P/S control module. 
<intxreftitleoff1 refid = "AENBP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is CAN communication circuit in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Repair or replace.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AENBP70A6304010009">
<title>
Combination meter power source circuit check
</title>
<test1>
<ptxt>
Remove combination meter. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
If check result are OK, set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check voltage between “G240-3” terminal and “G240-5” terminal is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Repair combination meter and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Go to Step 7.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AENBP70A6304010010">
<title>
Combination meter ground circuit check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Check resistance between “G240-5” terminal and ground is 1 Ω or less.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Repair or replace “A1” circuit.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace “A2” circuit.
</ptxt>
</action>
</testgroup>
</diag>
