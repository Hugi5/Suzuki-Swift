<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1306015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
CKP Sensor Removal and Installation
</title>
<attention4>
<ptxt>
The CKP sensor bolt is pre-coated with adhesive. If the bolt is reused, it may work loose.
</ptxt>
<ptxt>
Be sure to replace the CKP sensor bolt with a new one.
</ptxt>
</attention4>
<servinfosub id = "AENBP70A1306015001" page = "2">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove generator drive belt, loosen pivot bolt and move generator rearward.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from CKP sensor.
</ptxt>
</s1>
<s1>
<ptxt>
Remove CKP sensor (1) from cylinder block.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B130012.swf" width = "88.000mm" height = "42.406mm" ver = "01" gw = "187" gh = "103"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1306015002" page = "2">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1306016">CKP Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply engine oil to O-ring of CKP sensor.
</ptxt>
</item>
<item>
<ptxt>
Tighten CKP sensor bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1C008">
<t-part>
CKP sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I4RS0A130007.swf" width = "88.000mm" height = "51.378mm" ver = "01" gw = "164" gh = "130"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
