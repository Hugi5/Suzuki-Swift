<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206048" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Relief Valve Removal and Installation
</title>
<servinfosub id = "AENBP70A7206048001">
<title>
Removal
</title>
<s1>
<ptxt>
Run engine at idle with A/C system on for 10 minutes.
</ptxt>
</s1>
<s1>
<ptxt>
Stop engine.
</ptxt>
</s1>
<s1>
<ptxt>
Recover refrigerant from the A/C system using recovery and recycling equipment referring to “Recovery” in 
<intxref refid = "AENBP70A7206001">Operation Procedure for Refrigerant Charge</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove relief valve (1) from A/C compressor.
</ptxt>
<figure>
<graphic graphicname = "IBP60B720024.swf" width = "88.000mm" height = "56.203mm" ver = "01" gw = "179" gh = "143"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7206048002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new O-ring.
</ptxt>
</item>
<item>
<ptxt>
Apply compressor oil to O-ring.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B007" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Compressor oil
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Tighten relief valve to specified torque.
</ptxt>
<torque>
<torqueitem id = "T7B009">
<t-part>
Relief valve
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B720025.swf" width = "88.000mm" height = "56.324mm" ver = "01" gw = "179" gh = "143"/>
</figure>
</item>
<item>
<ptxt>
Evacuate and charge the A/C system referring to “Evacuation” and “Charge” in 
<intxref refid = "AENBP70A7206001">Operation Procedure for Refrigerant Charge</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
