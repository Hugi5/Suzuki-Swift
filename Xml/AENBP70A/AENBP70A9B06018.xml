<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9B06018" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Rear Floor Rear Panel Removal and Installation
</title>
<attention3>
<ptxt>
The figure below shows condition where following parts are removed.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front fender 
<intxreftitleoff1 refid = "AENBP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Back Panel 
<intxreftitleoff1 refid = "AENBP70A9B06017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0166.jpg" width = "88.000mm" height = "48.926mm" ver = "02" gw = "227" gh = "122"/>
</figure>
<servinfosub id = "AENBP70A9B06018001">
<title>
Removal
</title>
<s1>
<ptxt>
Drill out welding spots and remove rear floor rear panel.
</ptxt>
<attention3>
<ptxt>
Bend open both ends of rear floor center panel flange, if necessary.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IBP70A9B0008.jpg" width = "183.000mm" height = "185.294mm" ver = "01" gw = "481" gh = "509"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9B06018002">
<title>
Installation
</title>
<attention3>
<ptxt>
Before conducting any weld, check installation position and condition for installation part(s). 
<intxreftitleoff1 refid = "AENBP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1 page = "1">
<ptxt>
Install spare tire bracket and tool box bracket.
</ptxt>
</s1>
<s1 page = "1">
<ptxt>
Conduct resistance spot weld.
</ptxt>
<figure>
<graphic graphicname = "IBP70A9B0009.jpg" width = "183.000mm" height = "99.902mm" ver = "01" gw = "493" gh = "267"/>
</figure>
</s1>
<s1 page = "1">
<ptxt>
Install rear floor rear panel.
</ptxt>
<attention3>
<ptxt>
Bend in both ends of rear floor center panel flange, if necessary.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Conduct resistance spot weld and plug weld.
</ptxt>
<figure>
<graphic graphicname = "IBP70A9B0010.jpg" width = "183.000mm" height = "185.372mm" ver = "01" gw = "481" gh = "509"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
