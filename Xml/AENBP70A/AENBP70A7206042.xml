<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206042" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Compressor Drive Belt Removal and Installation
</title>
<servinfosub id = "AENBP70A7206042001">
<title>
Removal
</title>
<s1>
<ptxt>
Loosen tension pulley nut (1).
</ptxt>
</s1>
<s1>
<ptxt>
Loosen belt tension by loosening tension pulley adjusting bolt (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove compressor drive belt (3).
</ptxt>
<figure>
<graphic graphicname = "IBP60B720016.swf" width = "88.000mm" height = "74.143mm" ver = "03" gw = "180" gh = "194"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7206042002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Adjust belt tension. 
<intxreftitleoff1 refid = "AENBP70A7206041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
