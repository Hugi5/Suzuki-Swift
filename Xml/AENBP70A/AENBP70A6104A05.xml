<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A6104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Wander or poor steering stability
</title>
<diag type = "condition">
<condition>
<ptxt>
Wander or poor steering stability
</ptxt>
</condition>
<ps>
<ptxt>
Mismatched tire or uneven tire pressure
</ptxt>
</ps>
<action>
<ptxt>
Replace or adjust tire pressure. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose suspension arm joint and tie-rod end
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace suspension arm or tie-rod end.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Suspension arm: 
<intxreftitleoff1 refid = "AENBP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tie-rod end: 
<intxreftitleoff1 refid = "AENBP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Faulty front strut assembly or mounting
</ptxt>
</ps>
<action>
<ptxt>
Replace front strut assembly or repair mounting. 
<intxreftitleoff1 refid = "AENBP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose stabilizer bar
</ptxt>
</ps>
<action>
<ptxt>
Tighten or replace stabilizer bar or bushing. 
<intxreftitleoff1 refid = "AENBP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Broken or sagging coil spring
</ptxt>
</ps>
<action>
<ptxt>
Replace coil spring. 
<intxreftitleoff1 refid = "AENBP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty front strut assembly (shock absorber)
</ptxt>
</ps>
<action>
<ptxt>
Replace front strut assembly (shock absorber). 
<intxreftitleoff1 refid = "AENBP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Improper tooth contact between rack and pinion
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check rack and pinion shaft rotation torque. 
<intxreftitleoff1 refid = "AENBP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If defective, replace steering gear case assembly. 
<intxreftitleoff1 refid = "AENBP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Disturbed front wheel alignment
</ptxt>
</ps>
<action>
<ptxt>
Check and adjust front wheel alignment. 
<intxreftitleoff1 refid = "AENBP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty steering gear case assembly
</ptxt>
</ps>
<action>
<ptxt>
Replace steering gear case assembly. 
<intxreftitleoff1 refid = "AENBP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
