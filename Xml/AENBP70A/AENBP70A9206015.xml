<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9206015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Headlight Auto Leveling and Washer Control Module Removal and Installation
</title>
<attention3>
<ptxt>
After any of the following service, be sure to initialize headlight auto leveling system. 
<intxreftitleoff1 refid = "AENBP70A9206018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Replacement of the headlight auto leveling control module.
</ptxt>
</item>
<item>
<ptxt>
Replacement of the rear vehicle height sensor.
</ptxt>
</item>
<item>
<ptxt>
Removal of the rear vehicle height sensor.
</ptxt>
</item>
</list1>
</attention3>
<servinfosub id = "AENBP70A9206015001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove glove box. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect headlight auto leveling and washer control module connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (2) and then headlight auto leveling and washer control module (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A920008.swf" width = "88.000mm" height = "112.297mm" ver = "01" gw = "222" gh = "302"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9206015002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
