<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A6304004" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
DTC Clearance
</title>
<s1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Connect SUZUKI scan tool to DLC (1) located around bottom of instrument panel on driver’s seat side.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C002">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI scan tool (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A121001.jpg" width = "88.000mm" height = "67.502mm" ver = "02" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Set ignition ON.
</ptxt>
</s1>
<s1>
<ptxt>
Clear DTC according to instructions displayed on SUZUKI scan tool. For further details, refer to operator’s manual for SUZUKI scan tool.
</ptxt>
</s1>
<s1>
<ptxt>
When ignition is OFF, disconnect SUZUKI scan tool from DLC after completing clearance.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
