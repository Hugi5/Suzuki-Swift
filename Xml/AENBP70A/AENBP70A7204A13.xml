<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A7204A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Loud rattle is heard at low engine rpm
</title>
<servinfosub id = "AENBP70A7204004001">
<title>
Abnormal Noise from A/C Compressor
</title>
<diag type = "condition">
<condition>
<ptxt>
Loud rattle is heard at low engine rpm
</ptxt>
</condition>
<ps>
<ptxt>
Loose armature plate nut
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Retighten armature plate nut. 
<intxreftitleoff1 refid = "AENBP70A7206046"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Replace compressor drive belt and A/C compressor if it has been operated in rattling condition for a long time.
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
