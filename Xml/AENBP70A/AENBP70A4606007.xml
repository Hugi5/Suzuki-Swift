<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A4606007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Front Wheel Speed Sensor Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A4606006">Front and Rear Wheel Speed Sensor On-Vehicle Inspection</intxrefpoff>
</ptxt>
<attention4>
<ptxt>
Failure to take proper precautions when removing and installing the wheel speed sensor may lead to damaged to the wheel speed sensor harness.
</ptxt>
<ptxt>
Do not pull on or twist the wire harness when removing and installing the sensor.
</ptxt>
</attention4>
<servinfosub id = "AENBP70A4606007001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Hoist vehicle a little and remove wheel.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front fender lining. 
<intxreftitleoff1 refid = "AENBP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove clips (1) and disconnect front wheel speed sensor connector (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove front wheel speed sensor bolt (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove front wheel speed sensor (4) from steering knuckle.
</ptxt>
<figure>
<graphic graphicname = "IAP70A460016.swf" width = "88.000mm" height = "95.015mm" ver = "01" gw = "196" gh = "253"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.964in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.800in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Right side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Individual circuit fuse box No.1
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Left side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0">
<ptxt>
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A4606007002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A4606009">Front and Rear Wheel Speed Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedures noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check that no iron powder attaches to sensing area of wheel speed sensor (1).
</ptxt>
</item>
<item>
<ptxt>
Tighten wheel sensor bolt (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4F004">
<t-part>
Front wheel speed sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Confirm that there is no space between front wheel speed sensor and steering knuckle (3).
</ptxt>
<figure>
<graphic graphicname = "I9W10P460009.swf" width = "88.000mm" height = "31.167mm" ver = "02" gw = "186" gh = "72"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.816in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.816in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
OK
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
NG
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Install wheel. 
<intxreftitleoff1 refid = "AENBP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
