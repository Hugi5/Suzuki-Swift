<servinfosub id = "AENBP70A8204050003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A8204050004">
<testgroup id = "AENBP70A8204050005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204050006">
<title>
Floor harness open check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “L04” and “L49” connectors or “L05” and “L50” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” and “A2” circuits (DTC B1392 / B1393): 1 Ω or less
</ptxt>
</item>
<item>
<ptxt>
Resistance of “A3” and “A4” circuits (DTC B1397 / B1398): 1 Ω or less
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B086">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820036.swf" width = "90.000mm" height = "67.074mm" ver = "02" gw = "214" gh = "174"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204050007">
<title>
Floor harness circuit check
</title>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “L04-11” and “L04-12” terminals (DTC B1392 / B1393): infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “L05-11” and “L05-12” terminals (DTC B1397 / B1398): infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B087">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820154.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204050008">
<title>
Floor harness circuit check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between each of “A1” and “A2” circuits and ground (DTC B1392 / B1393): infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A3” and “A4” circuits and ground (DTC B1397 / B1398): infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B088">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820155.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204050009">
<title>
Floor harness circuit check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voltage between each of “A1” and “A2” circuits and ground (DTC B1392 / B1393): 0 V
</ptxt>
</item>
<item>
<ptxt>
Voltage between each of “A3” and “A4” circuits and ground (DTC B1397 / B1398): 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B089">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820156.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204050010">
<title>
Rear side-impact sensor check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Replace rear side-impact sensor. 
<intxreftitleoff1 refid = "AENBP70A8206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENBP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs, referring to 
<intxref refid = "AENBP70A8204006">DTC Clearance</intxref>
 if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENBP70A8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
