<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1306013" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
CMP Sensor Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1306012">CMP Sensor On-Vehicle Inspection</intxrefpoff>
</ptxt>
<attention4>
<ptxt>
The CMP sensor bolt is pre-coated with adhesive. If the bolt is reused, it may work loose.
</ptxt>
<ptxt>
Be sure to replace the CMP sensor bolt with a new one.
</ptxt>
</attention4>
<servinfosub id = "AENBP70A1306013001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from CMP sensor.
</ptxt>
</s1>
<s1>
<ptxt>
Remove intake CMP sensor (1) from cylinder head.
</ptxt>
<figure>
<graphic graphicname = "IBP60B130009.jpg" width = "88.000mm" height = "67.401mm" ver = "01" gw = "199" gh = "175"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1306013002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1306014">CMP Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply engine oil to O-ring of CMP sensor.
</ptxt>
</item>
<item>
<ptxt>
Tighten CMP sensor bolt (1) to specified torque.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1C007">
<t-part>
CMP sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B130010.jpg" width = "88.000mm" height = "67.401mm" ver = "01" gw = "199" gh = "175"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
