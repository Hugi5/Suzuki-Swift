<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1406004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Air Cleaner Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1406001">Air Cleaner Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1406004001" page = "2">
<title>
Removal
</title>
<s1 page = "2">
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Disconnect MAF and IAT sensor connector (1).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove air cleaner bolts (2).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect air cleaner suction hose (3) from air cleaner assembly (4).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Loosen air cleaner outlet hose No.1 clamp bolt (5) and remove air cleaner assembly.
</ptxt>
<figure>
<graphic graphicname = "IBP60B140005.jpg" width = "88.000mm" height = "75.455mm" ver = "01" gw = "227" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Remove air cleaner suction hose (1), resonator (2) and air cleaner suction pipe (3).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140006.jpg" width = "88.000mm" height = "74.569mm" ver = "01" gw = "214" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect breather pipe (1) from air cleaner outlet hose (2).
</ptxt>
</s1>
<s1>
<ptxt>
Loosen air cleaner outlet hose No.2 clamp bolt (3) and remove air cleaner outlet hose.
</ptxt>
<figure>
<graphic graphicname = "IBP60B140007.jpg" width = "88.000mm" height = "67.807mm" ver = "01" gw = "214" gh = "176"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1406004002" page = "2">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten air cleaner outlet hose No.1 clamp bolt and air cleaner outlet hose No.2 clamp bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D001">
<t-part>
Air cleaner outlet hose No.1 clamp bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
1.3
</t-value1>
<t-value2>
0.13
</t-value2>
<t-value3>
1.0
</t-value3>
</torqueitem>
<torqueitem id = "T1D002">
<t-part>
Air cleaner outlet hose No.2 clamp bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
3.1
</t-value1>
<t-value2>
0.32
</t-value2>
<t-value3>
2.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B140008.jpg" width = "88.000mm" height = "67.373mm" ver = "01" gw = "176" gh = "174"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
