<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Blower Motor Removal and Installation
</title>
<servinfosub id = "AENBP70A7206011001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector (1) from blower motor (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove blower motor (2) from HVAC unit.
</ptxt>
<figure>
<graphic graphicname = "I4RS0B710005.swf" width = "88.000mm" height = "53.250mm" ver = "01" gw = "169" gh = "134"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7206011002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
