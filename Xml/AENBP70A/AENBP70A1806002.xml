<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1806002" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Spark Plug Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1806001">Spark Plug Removal and Installation</intxrefpoff>
</ptxt>
<attention4>
<ptxt>
The iridium spark plug has a slender center electrode that is made of a material sensitive to mechanical forces. It may be damaged if handled carelessly.
</ptxt>
<ptxt>
Do not touch the center electrode of an iridium spark plug. Avoid cleaning it or adjusting its electrode gap.
</ptxt>
</attention4>
<ptxt>
Inspect spark plug for:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Electrode wear
</ptxt>
</item>
<item>
<ptxt>
Carbon deposits
</ptxt>
</item>
<item>
<ptxt>
Insulator damage
</ptxt>
</item>
</list1>
<ptxt>
If any abnormality is found with iridium spark plug, replace it with new plug.
</ptxt>
<spec-sdm>
<sdm-title>
Spark plug air gap
</sdm-title>
<sdm-part>
“a”
</sdm-part>
<sdm1>
<sdm-condition>
</sdm-condition>
<sdm-value>
1.0 to 1.1 mm (0.040 to 0.043 in.)
</sdm-value>
</sdm1>
</spec-sdm>
<spec-sdm>
<sdm-title>
Spark plug type
</sdm-title>
<sdm1>
<sdm-condition>
NGK
</sdm-condition>
<sdm-value>
SILFR6A11 (Iridium)
</sdm-value>
</sdm1>
</spec-sdm>
<figure>
<graphic graphicname = "I8T401182005.swf" width = "88.000mm" height = "63.673mm" ver = "01" gw = "98" gh = "164"/>
</figure>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
