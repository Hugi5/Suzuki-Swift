<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1306008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
ECT Sensor Removal and Installation
</title>
<servinfosub id = "AENBP70A1306008001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENBP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from ECT sensor (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B130003.jpg" width = "88.000mm" height = "63.743mm" ver = "01" gw = "199" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Remove ECT sensor from thermostat case.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1306008002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1306009">ECT Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Clean mating surfaces of ECT sensor and thermostat case.
</ptxt>
</item>
<item>
<ptxt>
Check O-ring for damage and replace, if necessary.
</ptxt>
</item>
<item>
<ptxt>
Tighten ECT sensor (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1C004">
<t-part>
ECT sensor
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B130004.jpg" width = "88.000mm" height = "63.743mm" ver = "01" gw = "199" gh = "164"/>
</figure>
</item>
<item>
<ptxt>
Connect connector to ECT sensor.
</ptxt>
</item>
<item>
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENBP70A1606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check cooling system for leakage. 
<intxreftitleoff1 refid = "AENBP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
