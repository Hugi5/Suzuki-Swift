<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5506038" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Vehicle Speed Sensor Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5506037">Vehicle Speed Sensor Removal and Installation</intxrefpoff>
</ptxt>
<s1>
<ptxt>
 Check the following point:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sensing part of sensor is free of any metal particles and damage.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IBP70A550086.swf" width = "88.000mm" height = "29.322mm" ver = "02" gw = "157" gh = "67"/>
</figure>
</s1>
<s1>
<ptxt>
Check sensor by the following procedure:
</ptxt>
<s2>
<ptxt>
Connect service wires (1) between vehicle speed sensor (2) and vehicle speed sensor connector (3) and connect voltmeter (4) as follows.
</ptxt>
<figure>
<graphic graphicname = "IBP70A550107.swf" width = "88.000mm" height = "50.269mm" ver = "01" gw = "187" gh = "126"/>
</figure>
</s2>
<s2>
<ptxt>
Set ignition ON, and check that the indicator on the voltmeter fluctuates between 0 and 12 V when the iron (1) is moved in arrow direction as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IBP70A550108.swf" width = "88.000mm" height = "35.676mm" ver = "01" gw = "195" gh = "85"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.017in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Sensing part
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
</s1>
<s1>
<ptxt>
If output voltage does not vary, replace vehicle speed sensor.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
