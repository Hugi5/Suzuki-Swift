<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1406007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Electric Throttle Body Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1406005">Throttle Body and Intake Manifold Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENBP70A1406006">Throttle Body On-Vehicle Inspection</intxrefpoff>
</ptxt>
<attention4>
<ptxt>
The electric throttle body will lose its original performance if it is disassembled.
</ptxt>
<ptxt>
Do not try to disassemble the electric throttle body.
</ptxt>
<ptxt>
If any faulty condition is found, replace the electric throttle body with a new one.
</ptxt>
</attention4>
<servinfosub id = "AENBP70A1406007001" page = "2">
<title>
Removal
</title>
<s1 page = "2">
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENBP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove air cleaner assembly with air cleaner outlet hose. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Disconnect engine coolant hoses (1) and connector (2) from electric throttle body assembly (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove electric throttle body assembly from intake manifold.
</ptxt>
<figure>
<graphic graphicname = "IBP60B140010.jpg" width = "88.000mm" height = "54.175mm" ver = "01" gw = "155" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1406007002" page = "2">
<title>
Installation
</title>
<s1 page = "2">
<ptxt>
Clean mating surfaces and install new electric throttle body gasket (1) to intake manifold.
</ptxt>
<figure>
<graphic graphicname = "IBP60B140011.jpg" width = "88.000mm" height = "63.404mm" ver = "01" gw = "160" gh = "163"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Install electric throttle body assembly (1) to intake manifold.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Connect connector (2) and coolant hoses (3) to electric throttle body assembly.
</ptxt>
<figure>
<graphic graphicname = "IBP60B140012.jpg" width = "88.000mm" height = "54.175mm" ver = "01" gw = "155" gh = "137"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Install air cleaner assembly with air cleaner outlet hose. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Connect negative (–) cable at battery.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Refill coolant. 
<intxreftitleoff1 refid = "AENBP70A1606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check for coolant leakage. 
<intxreftitleoff1 refid = "AENBP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
