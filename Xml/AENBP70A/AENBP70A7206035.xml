<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206035" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Center Ventilation Louver Removal and Installation
</title>
<servinfosub id = "AENBP70A7206035001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove center ventilation louver from instrument panel. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Release tabs (2) and then remove center ventilation louver (1).
</ptxt>
<attention3>
<ptxt>
Center ventilation louver is fitted to instrument panel center upper box and hazard switch with twelve clips. When removing louver from instrument panel center upper box, be careful not to break these clips.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A721028.swf" width = "88.000mm" height = "58.762mm" ver = "02" gw = "215" gh = "150"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7206035002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
