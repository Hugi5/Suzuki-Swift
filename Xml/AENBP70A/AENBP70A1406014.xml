<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1406014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Engine Assembly Removal and Installation
</title>
<attention4>
<ptxt>
The A/C compressor may be damaged if there is not adequate clearance when the engine is lowered.
</ptxt>
<ptxt>
Before lowering the engine, move the A/C compressor to vehicle body side to ensure that there is adequate clearance when the engine is lowered.
</ptxt>
</attention4>
<servinfosub id = "AENBP70A1406014001">
<title>
Removal
</title>
<ptxt>
</ptxt>
<s1>
<ptxt>
Relieve fuel pressure. 
<intxreftitleoff1 refid = "AENBP70A1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery, battery bracket and ECM together. 
<intxreftitleoff1 refid = "AENBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove right and left engine undercovers.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front bumper lower absorber. 
<intxreftitleoff1 refid = "AENBP70A9806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front center cover (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150001.jpg" width = "88.000mm" height = "71.620mm" ver = "01" gw = "174" gh = "187"/>
</figure>
</s1>
<s1>
<ptxt>
Drain the following oils.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Engine oil: 
<intxreftitleoff1 refid = "AENBP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manual transaxle oil (M/T model): 
<intxreftitleoff1 refid = "AENBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
CVT fluid (CVT model): 
<intxreftitleoff1 refid = "AENBP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENBP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove reservoir (1) and its bracket (2).
</ptxt>
<figure>
<graphic graphicname = "IBP70A140002.jpg" width = "88.000mm" height = "58.980mm" ver = "01" gw = "161" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
For M/T model, disconnect clutch hose from clutch pipe joint. 
<intxreftitleoff1 refid = "AENBP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect the following electric wires/connectors and each clamps.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Electric load current sensor connector (1)
</ptxt>
</item>
<item>
<ptxt>
Battery ground cable (2)
</ptxt>
</item>
<item>
<ptxt>
Connectors (3) in main fuse box
</ptxt>
</item>
<item>
<ptxt>
Connector (4) in individual circuit fuse box No.1
</ptxt>
</item>
<item>
<ptxt>
Engine harness ground cable (5)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IBP70A140004.jpg" width = "88.000mm" height = "65.953mm" ver = "02" gw = "217" gh = "170"/>
</figure>
</s1>
<s1>
<ptxt>
For CVT model, disconnect TCM connectors, and then pull out engine harness from cabin to engine compartment.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect the following cables. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Gear select control cable (M/T model) (1)
</ptxt>
</item>
<item>
<ptxt>
Gear shift control cable (M/T model) (2)
</ptxt>
</item>
<item>
<ptxt>
Select cable (CVT model) (3)
</ptxt>
</item>
</list1>
<figure>
<title>
M/T model
</title>
<graphic graphicname = "IBP70A140007.jpg" width = "88.000mm" height = "61.523mm" ver = "02" gw = "199" gh = "158"/>
</figure>
<figure>
<title>
CVT model
</title>
<graphic graphicname = "IBP70A140008.jpg" width = "88.000mm" height = "64.800mm" ver = "02" gw = "199" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect the following hoses.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Radiator inlet hose (1)
</ptxt>
</item>
<item>
<ptxt>
Radiator outlet hose (2)
</ptxt>
</item>
<item>
<ptxt>
Brake booster hose (3)
</ptxt>
</item>
<item>
<ptxt>
Heater inlet hose (4)
</ptxt>
</item>
<item>
<ptxt>
Heater outlet hose (5)
</ptxt>
</item>
<item>
<ptxt>
Fuel feed hose (6)
</ptxt>
</item>
<item>
<ptxt>
Canister purge hose (7)
</ptxt>
</item>
<item>
<ptxt>
CVT fluid cooler hoses (CVT model) (8)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IBP70A140005.jpg" width = "88.000mm" height = "70.873mm" ver = "02" gw = "207" gh = "184"/>
</figure>
<figure>
<graphic graphicname = "IBP70A140006.jpg" width = "88.000mm" height = "57.141mm" ver = "02" gw = "199" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
With hose connected, detach A/C compressor from its bracket. 
<intxreftitleoff1 refid = "AENBP70A7206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention4>
<ptxt>
The A/C compressor may be damaged if it hits against or interferes with other parts.
</ptxt>
<ptxt>
Suspend the removed A/C compressor in a place where no damage will be caused during removal and installation of the engine assembly.
</ptxt>
</attention4>
</s1>
<s1 page = "2">
<ptxt>
Disconnect steering lower shaft from pinion shaft. 
<intxreftitleoff1 refid = "AENBP70A6206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove stabilizer bar joints from stabilizer bar. 
<intxreftitleoff1 refid = "AENBP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect tie-rod end from steering knuckle. 
<intxreftitleoff1 refid = "AENBP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect right and left drive shaft joints from steering knuckle. 
<intxreftitleoff1 refid = "AENBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust No.1 pipe, No.2 pipe and center pipe. 
<intxreftitleoff1 refid = "AENBP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove suspension frame members (1).
</ptxt>
</s1>
<s1>
<ptxt>
Support front suspension frame (2), transaxle (3) and engine assembly (4) using jack.
</ptxt>
<figure>
<graphic graphicname = "IBP60B140025.jpg" width = "88.000mm" height = "75.747mm" ver = "02" gw = "175" gh = "198"/>
</figure>
</s1>
<s1>
<ptxt>
Remove right lamp support member (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140026.jpg" width = "88.000mm" height = "68.908mm" ver = "01" gw = "214" gh = "179"/>
</figure>
</s1>
<s1>
<ptxt>
Remove engine right mounting (1) and engine right mounting stiffener (2).
</ptxt>
<attention3>
<ptxt>
As engine mounting stud bolts (3) are installed at an angle on the engine, removal of engine right mounting facilitates dismounting the engine.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IBP70A140009.jpg" width = "88.000mm" height = "64.213mm" ver = "02" gw = "207" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Remove engine left mounting No.1 bracket bolts (1) and nuts (2).
</ptxt>
<figure>
<title>
M/T model
</title>
<graphic graphicname = "IBP60B140031.jpg" width = "88.000mm" height = "68.908mm" ver = "01" gw = "214" gh = "179"/>
</figure>
<figure>
<title>
CVT model
</title>
<graphic graphicname = "IBP70A140010.jpg" width = "88.000mm" height = "54.006mm" ver = "02" gw = "199" gh = "137"/>
</figure>
</s1>
<s1>
<ptxt>
Remove front suspension frame bolts (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140030.jpg" width = "88.000mm" height = "67.807mm" ver = "01" gw = "238" gh = "176"/>
</figure>
</s1>
<s1>
<ptxt>
Before removing engine, make sure that all hoses, electric wires and cables are disconnected from engine.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Lower engine, transaxle, front suspension frame, drive shafts and P/S gear case assembly all together.
</ptxt>
</s1>
<s1>
<ptxt>
Remove engine harness from engine and transaxle, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front suspension frame, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect transaxle from engine, if necessary.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
M/T model: 
<intxreftitleoff1 refid = "AENBP70A5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
CVT model: 
<intxreftitleoff1 refid = "AENBP70A5506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
For M/T model, remove clutch cover and clutch disc, if necessary. 
<intxreftitleoff1 refid = "AENBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, remove flywheel, if necessary. 
<intxreftitleoff1 refid = "AENBP70A1406019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For CVT model, remove drive plate, if necessary. 
<intxreftitleoff1 refid = "AENBP70A1406019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1406014002" page = "2">
<title>
Installation
</title>
<s1>
<ptxt>
For M/T model, install flywheel, if removed. 
<intxreftitleoff1 refid = "AENBP70A1406019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For CVT model, install drive plate, if removed. 
<intxreftitleoff1 refid = "AENBP70A1406019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
For M/T model, install clutch cover and clutch disc, if removed. 
<intxreftitleoff1 refid = "AENBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install transaxle to engine, if removed.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
M/T model: 
<intxreftitleoff1 refid = "AENBP70A5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
CVT model: 
<intxreftitleoff1 refid = "AENBP70A5506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Install front suspension frame, if removed. 
<intxreftitleoff1 refid = "AENBP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install engine harness to engine and transaxle and then tighten engine harness ground bolts to specified torque, if removed.
</ptxt>
<torque>
<torqueitem id = "T1D006">
<t-part>
Engine harness ground bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<title>
M/T model
</title>
<graphic graphicname = "IBP70A140011.jpg" width = "88.000mm" height = "59.381mm" ver = "02" gw = "199" gh = "152"/>
</figure>
<figure>
<title>
CVT model
</title>
<graphic graphicname = "IBP70A140012.jpg" width = "88.000mm" height = "60.189mm" ver = "02" gw = "199" gh = "154"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Lift up engine, transaxle, front suspension frame, drive shafts and P/S gear case assembly all together.
</ptxt>
</s1>
<s1>
<ptxt>
Install engine right mounting (1) and stiffener (2), and tighten the following bolts and nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D007">
<t-part>
Engine right mounting bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D008">
<t-part>
Engine right mounting nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D009">
<t-part>
Engine right mounting stiffener bolt
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D010">
<t-part>
Engine right mounting stiffener nut
</t-part>
<t-part1>
d
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A140013.jpg" width = "88.000mm" height = "57.562mm" ver = "02" gw = "199" gh = "147"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Tighten engine left mounting No.1 bracket bolts and nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D011">
<t-part>
Engine left mounting No.1 bracket bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D012">
<t-part>
Engine left mounting No.1 bracket nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<title>
M/T model
</title>
<graphic graphicname = "IBP60B140034.jpg" width = "88.000mm" height = "68.908mm" ver = "01" gw = "226" gh = "179"/>
</figure>
<figure>
<title>
CVT model
</title>
<graphic graphicname = "IBP70A140014.jpg" width = "88.000mm" height = "54.006mm" ver = "02" gw = "199" gh = "137"/>
</figure>
</s1>
<s1>
<ptxt>
Install right lamp support member (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140035.jpg" width = "88.000mm" height = "68.908mm" ver = "01" gw = "214" gh = "179"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Tighten suspension frame bolts to specified torque. 
<intxreftitleoff1 refid = "AENBP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install suspension frame members. 
<intxreftitleoff1 refid = "AENBP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install exhaust No.1 pipe, No.2 pipe and center pipe. 
<intxreftitleoff1 refid = "AENBP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect right and left drive shaft joints to steering knuckle. 
<intxreftitleoff1 refid = "AENBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect tie-rod end to steering knuckle. 
<intxreftitleoff1 refid = "AENBP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install stabilizer bar joints to stabilizer bar. 
<intxreftitleoff1 refid = "AENBP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Connect steering lower shaft to pinion shaft. 
<intxreftitleoff1 refid = "AENBP70A6206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install all other removed electric wires, connectors and hoses to original locations.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Tighten battery ground terminal bolt (1) and engine harness ground terminal bolt (2).
</ptxt>
<torque>
<torqueitem id = "T1D013">
<t-part>
Battery ground terminal bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D014">
<t-part>
Engine harness ground terminal bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A140015.jpg" width = "88.000mm" height = "62.781mm" ver = "02" gw = "199" gh = "161"/>
</figure>
</s1>
<s1>
<ptxt>
For M/T model, connect gear shift control cable. 
<intxreftitleoff1 refid = "AENBP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For CVT model, connect select cable. 
<intxreftitleoff1 refid = "AENBP70A5506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install A/C compressor to its bracket. 
<intxreftitleoff1 refid = "AENBP70A7206043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install A/C compressor drive belt. 
<intxreftitleoff1 refid = "AENBP70A7206042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install reservoir (1) and its bracket (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140020.jpg" width = "88.000mm" height = "58.980mm" ver = "03" gw = "161" gh = "151"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Install air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
