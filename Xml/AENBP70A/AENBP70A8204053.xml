<servinfosub id = "AENBP70A8204053002">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENBP70A8204053003">
<testgroup id = "AENBP70A8204053004">
<title>
Driver air bag (inflator) module circuit check
</title>
<test1>
<ptxt>
Remove driver air bag (inflator) module from steering column. 
<intxreftitleoff1 refid = "AENBP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G11” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector inserting release tool included in special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Check the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “G11-5” and “G11-6” terminals: infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B092">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820057.swf" width = "90.000mm" height = "55.937mm" ver = "01" gw = "200" gh = "142"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check for defective wire harness. If check result is OK, replace contact coil assembly. 
<intxreftitleoff1 refid = "AENBP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204053005">
<title>
Contact coil circuit (driver air bag (inflator) module circuit) check
</title>
<test1>
<ptxt>
Remove contact coil assembly. 
<intxreftitleoff1 refid = "AENBP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Check the following point.
</ptxt>
<ptxt>
M/T model without hands-free system:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Measure resistance between “S121 –1” to “S172-2” and “S121-2” to “S172-1” terminals.
</ptxt>
</item>
</list1>
<ptxt>
CVT model and M/T model with hands-free system:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Measure resistance between “S121 –1” to “S174-2” and “S121-2” to “S174-1” terminals.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B093">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IBP70A820012.swf" width = "90.000mm" height = "72.384mm" ver = "01" gw = "196" gh = "189"/>
</testfigure>
</test1>
<question>
Is resistance 1 Ω or less?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace contact coil assembly. 
<intxreftitleoff1 refid = "AENBP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204053006">
<title>
Contact coil circuit (horn circuit) check
</title>
<test1>
<ptxt>
Check the following point.
</ptxt>
<ptxt>
M/T model without hands-free system:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Measure resistance between “S61-1” and “S171-1” terminals.
</ptxt>
</item>
</list1>
<ptxt>
CVT model and M/T model with hands-free system:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Measure resistance between “S62-4” and “S173-4” terminals.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B094">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820019.swf" width = "90.000mm" height = "85.625mm" ver = "02" gw = "225" gh = "226"/>
</testfigure>
</test1>
<question>
Is resistance 1 Ω or less?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace contact coil assembly. 
<intxreftitleoff1 refid = "AENBP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204053007">
<title>
Contact coil circuit check
</title>
<test1>
<ptxt>
Measure resistance between each terminal of contact coil and other terminals.
</ptxt>
</test1>
<question>
Is each measured resistance infinite?
</question>
<result type = "yes"/>
<action>
<ptxt>
Contact coil and its circuit are in good condition.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace contact coil assembly. 
<intxreftitleoff1 refid = "AENBP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
