<servinfosub id = "AENBP70AA504013005">
<title>
DTC Confirmation Procedure
</title>
<topic id = "AENBP70AA504013006">
<title>
CVT model
</title>
<s1>
<ptxt>
Set ignition ON and leave ignition ON for 30 seconds.
</ptxt>
</s1>
</topic>
<topic id = "AENBP70AA504013007">
<title>
M/T model
</title>
<s1>
<ptxt>
Set ignition ON.
</ptxt>
</s1>
<s1>
<ptxt>
Depress clutch pedal fully for 3 seconds or more.
</ptxt>
</s1>
<s1>
<ptxt>
Release clutch pedal for 3 seconds or more.
</ptxt>
</s1>
</topic>
</servinfosub>
<servinfosub id = "AENBP70AA504013008">
<title>
DTC Troubleshooting
</title>
<topic id = "AENBP70AA504013009">
<title>
CVT model
</title>
<diag type = "test" id = "AENBP70AA504013010">
<testgroup id = "AENBP70AA504013011">
<title>
DTC check
</title>
<question>
Is any DTC other than B1125 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504013012">
<title>
Parameter check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check “P position / CPP 2 Switch” and “Clutch / Shift Switch” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENBP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504013013">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC in TCM. 
<intxreftitleoff1 refid = "AENBP70A5504011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is there any DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504013014">
<title>
Transmission range sensor signal circuit check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect transmission range sensor, “C01”, “E01”, “E25” and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to transmission range sensor, “C01”, “E01”, “E25” and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit terminal and each terminal at transmission range sensor connector: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504013015">
<title>
P position switch signal circuit check
</title>
<test1>
<ptxt>
Check “A2” circuit according to Step 2 of 
<intxref refid = "AENBP70AA504014">DTC B1126</intxref>
.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504013016">
<title>
Transmission range sensor check
</title>
<test1>
<ptxt>
Check transmission range sensor. 
<intxreftitleoff1 refid = "AENBP70A5506022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace transmission range sensor. 
<intxreftitleoff1 refid = "AENBP70A5506024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504013017">
<title>
P position switch check
</title>
<test1>
<ptxt>
Check P position switch. 
<intxreftitleoff1 refid = "AENBP70A5506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace select lever. 
<intxreftitleoff1 refid = "AENBP70A5506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504013018">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Connect transmission range sensor, select lever, “C01”, “E01”, “E25” and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON and shift select lever to each of P, N and P ranges.
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENBP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is current DTC B1125 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70AA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
</testgroup>
</diag>
</topic>
