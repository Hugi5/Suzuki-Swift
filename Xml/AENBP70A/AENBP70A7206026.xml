<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Air Intake Control Actuator Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A7206007">HVAC Unit Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A7206026001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove glove box from instrument panel. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For LHD, remove foot duct (2) from HVAC unit by removing screw (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A721036.jpg" width = "88.000mm" height = "94.268mm" ver = "01" gw = "199" gh = "251"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect air intake control actuator connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (2) then remove air intake control actuator (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A720014.jpg" width = "88.000mm" height = "69.738mm" ver = "02" gw = "142" gh = "181"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7206026002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A7206027">Air Intake Control Actuator Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to insert linkage pin (1) into groove (2) of air intake control actuator.
</ptxt>
<figure>
<graphic graphicname = "IAP70B721005.swf" width = "88.000mm" height = "54.558mm" ver = "01" gw = "201" gh = "138"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
