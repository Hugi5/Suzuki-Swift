<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A9504A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Power door mirrors cannot move smoothly
</title>
<diag type = "condition">
<condition>
<ptxt>
Power door mirrors cannot move smoothly
</ptxt>
</condition>
<ps>
<ptxt>
Faulty power door mirror actuator
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A9506019">Power Door Mirror On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Some object is pinched in power mirror
</ptxt>
</ps>
<action>
<ptxt>
Remove foreign bodies
</ptxt>
</action>
<ps>
<ptxt>
Mirror comes out of position
</ptxt>
</ps>
<action>
<ptxt>
Install mirror in position. 
<intxreftitleoff1 refid = "AENBP70A9506020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
