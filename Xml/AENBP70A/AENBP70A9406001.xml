<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9406001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Windshield and Rear Washer Tank and Washer Pump Removal and Installation
</title>
<servinfosub id = "AENBP70A9406001001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect wire harness clamps (1), washer pump connectors (2) and washer hoses (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940004.jpg" width = "88.000mm" height = "67.662mm" ver = "01" gw = "209" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Remove washer tank bolts (1) and remove washer tank (2).
</ptxt>
<figure>
<graphic graphicname = "IBP70A940002.jpg" width = "88.000mm" height = "67.553mm" ver = "01" gw = "181" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Pull windshield washer pump (1) and rear washer pump (2) in direction of arrow to remove them from washer tank (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P940006.jpg" width = "88.000mm" height = "62.134mm" ver = "01" gw = "161" gh = "160"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9406001002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A9406003">Washer Pump Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<ptxt>
Tighten washer tank bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9D001">
<t-part>
Washer tank bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6.0
</t-value1>
<t-value2>
0.61
</t-value2>
<t-value3>
4.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A940003.jpg" width = "88.000mm" height = "67.553mm" ver = "01" gw = "181" gh = "175"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
