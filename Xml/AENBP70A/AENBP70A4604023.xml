<servinfosub id = "AENBP70A4604023003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A4604023004">
<testgroup id = "AENBP70A4604023005">
<question>
Was “ESP<sup>®</sup> System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A4604001">ESP® System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604023006">
<title>
DTC check
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENBP70A4604005">DTC Check</intxref>
.
</ptxt>
</test1>
<question>
Is there DTC(s) other than C1037, C1038 and C1057?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604023007">
<title>
DTC check for BCM
</title>
<test1>
<ptxt>
Check DTC for BCM. 
<intxreftitleoff1 refid = "AENBP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is any of DTC U0073, U0121 and/or U0126 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604023008">
<title>
Fuse check
</title>
<test1>
<ptxt>
Check “ABS” fuse.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace fuse and check for short circuit to ground.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604023009">
<title>
Steering angle sensor power supply circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect steering angle sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G33” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to steering angle sensor.
</ptxt>
</test1>
<test1>
<ptxt>
If connection is OK, set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Measure voltage between “A1” circuit and ground.
</ptxt>
</test1>
<question>
Is it 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace “A1” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604023010">
<title>
Steering angle sensor ground circuit check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Measure resistance between “A2” circuit and ground.
</ptxt>
</test1>
<question>
Is it less than 2 Ω?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace “A2” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604023011">
<title>
Steering angle sensor check
</title>
<test1>
<ptxt>
Connect steering angle sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check steering angle sensor. 
<intxreftitleoff1 refid = "AENBP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ESP<sup>®</sup> hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace steering angle sensor and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
