<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Window Regulator Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A9506012">Rear Door Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A9506015001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear door glass. 
<intxreftitleoff1 refid = "AENBP70A9506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect power window motor connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove window regulator bolts (2) and remove rear window regulator assembly (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950048.jpg" width = "88.000mm" height = "61.700mm" ver = "02" gw = "217" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9506015002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A9506016">Rear Window Regulator Assembly Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply grease to sliding parts of rear window regulator assembly.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E002" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Tighten rear window regulator bolts in order (“1” to “4”) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9E006">
<t-part>
Rear window regulator bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8.4
</t-value1>
<t-value2>
0.86
</t-value2>
<t-value3>
6.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950049.jpg" width = "88.000mm" height = "63.881mm" ver = "01" gw = "225" gh = "165"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
