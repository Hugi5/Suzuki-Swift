<servinfosub id = "AENBP70AA504025003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Start engine.
</ptxt>
</s1>
<s1>
<ptxt>
Stop engine.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 1) and 2) once.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70AA504025004">
<title>
DTC Troubleshooting
</title>
<attention3>
<ptxt>
This DTC might be detected when battery is run down or the voltage is very low.
</ptxt>
</attention3>
<diag type = "test" id = "AENBP70AA504025005">
<testgroup id = "AENBP70AA504025006">
<title>
DTC check
</title>
<question>
Is DTC B1125 detected together?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504025007">
<title>
Parameter check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Starting motor Relay” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENBP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504025008">
<title>
Fuse check
</title>
<test1>
<ptxt>
Check “ST” and “ST SIG2” fuse.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace “ST” and/or “ST SIG2” fuse.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504025009">
<title>
Starting motor control relay check
</title>
<test1>
<ptxt>
Check starting motor control relay. 
<intxreftitleoff1 refid = "AENBP70AA206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace starting motor control relay.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504025010">
<title>
Starting motor control relay signal circuit check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “C01”, “E01”, “E25” and starting motor connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01”, “E01”, “E25” and starting motor connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” and “A2” circuits: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A1” and “A2” circuits and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit terminal and each terminal at starting motor control relay connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit terminal and each terminal at starting motor control relay connector: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504025011">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Connect “L10” connector and install starting motor control relay.
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENBP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is current DTC B1194 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70AA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
