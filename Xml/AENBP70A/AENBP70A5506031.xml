<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5506031" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Differential Side Oil Seal Replacement
</title>
<s1>
<ptxt>
Hoist vehicle and drain CVT fluid. 
<intxreftitleoff1 refid = "AENBP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove the following parts.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front drive shaft assembly: 
<intxreftitleoff1 refid = "AENBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Drive intermediate shaft: 
<intxreftitleoff1 refid = "AENBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove differential side oil seal (1) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L5E009">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913–50121
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IBP70A550092.swf" width = "88.000mm" height = "132.778mm" ver = "01" gw = "181" gh = "360"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.865in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.830in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Right side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Left side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Apply grease to new differential side oil seal lip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease C" id = "M5E003" uid = "23">
<m-part>
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25030
</m-number>
<m-name>
SUZUKI Super Grease C
</m-name>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Using special tool, install new differential side oil seals (1) at specified position as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L5E010">
<s-part>
(A)
</s-part>
<s-number num = "09925-17910">
09925–17910
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5E011">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Differential side oil seal installing depth
</title>
<ptxt>
Right side “a”: 1.3 to 2.3 mm (0.052 to 0.090 in.)
</ptxt>
<ptxt>
Left side “b”: 1.3 to 2.3 mm (0.052 to 0.090 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP70A550093.swf" width = "88.000mm" height = "83.192mm" ver = "02" gw = "225" gh = "219"/>
</figure>
<figure>
<graphic graphicname = "IBP70A550094.swf" width = "88.000mm" height = "85.500mm" ver = "02" gw = "207" gh = "226"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.320in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.873in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.320in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.807in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Right side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Left side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install drive intermediate shaft assembly. 
<intxreftitleoff1 refid = "AENBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install front drive shaft assembly. 
<intxreftitleoff1 refid = "AENBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Replenish CVT fluid. 
<intxreftitleoff1 refid = "AENBP70A5506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check CVT fluid level. 
<intxreftitleoff1 refid = "AENBP70A5506002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check for fluid leakage.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
