<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A4604040" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1092
</title>
<servinfosub id = "AENBP70A4604040001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.780in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.399in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1092: CAN Invalid Data from TCM
</emph>
</ptxt>
<ptxt>
DTC concerned with TCM is detected.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
CAN communication circuit
</ptxt>
</item>
<item>
<ptxt>
TCM
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>®</sup> control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENBP70A4604040002">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A4604040003">
<testgroup id = "AENBP70A4604040004">
<question>
Was “ESP<sup>®</sup> System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A4604001">ESP® System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604040005">
<title>
DTC check
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENBP70A4604005">DTC Check</intxref>
.
</ptxt>
</test1>
<question>
Is there DTC(s) other than C1092?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to applicable DTC troubleshooting.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A4604040006">
<title>
DTC check for TCM
</title>
<test1>
<ptxt>
Check DTC for TCM. 
<intxreftitleoff1 refid = "AENBP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC U0073 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70AA804004">Troubleshooting for Communication Bus Off</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace ESP<sup>®</sup> hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
