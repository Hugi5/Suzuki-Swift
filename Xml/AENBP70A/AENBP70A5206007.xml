<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Back Up Light Switch Removal and Installation
</title>
<servinfosub id = "AENBP70A5206007001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove battery, battery tray and battery bracket with ECM. 
<intxreftitleoff1 refid = "AENBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect back up light switch connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove back up light switch.
</ptxt>
<figure>
<graphic graphicname = "IBP60B520012.jpg" width = "88.000mm" height = "55.163mm" ver = "01" gw = "197" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5206007002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5206008">Back Up Light Switch Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Apply transaxle oil to new O-ring (1) and tighten back up light switch (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5B004">
<t-part>
Back up light switch
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1.9
</t-value2>
<t-value3>
14.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I3RH0A520006.swf" width = "88.000mm" height = "31.317mm" ver = "01" gw = "148" gh = "73"/>
</figure>
</s1>
<s1>
<ptxt>
Connect back up light switch connector.
</ptxt>
</s1>
<s1>
<ptxt>
Install battery bracket with ECM, battery tray and battery. 
<intxreftitleoff1 refid = "AENBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
