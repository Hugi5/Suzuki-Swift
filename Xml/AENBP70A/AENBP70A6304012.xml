<servinfosub id = "AENBP70A6304012003">
<title>
DTC Confirmation Procedure
</title>
<ptxt>
Upon completion of initial check, turn steering wheel in both directions (fully when stopped and turning while driving).
</ptxt>
</servinfosub>
<servinfosub id = "AENBP70A6304012004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A6304012005">
<testgroup id = "AENBP70A6304012006">
<question>
Was “P/S System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A6304001">P/S System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304012007">
<title>
Torque sensor circuit wire check
</title>
<test1>
<ptxt>
Visually check circuit between torque sensor connector and torque sensor for open circuit and short to ground.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace torque sensor (Steering column assembly). 
<intxreftitleoff1 refid = "AENBP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304012008">
<title>
9 V power supply and 3.3 V reference power supply for torque sensor circuit voltage check
</title>
<test1>
<ptxt>
With ignition in ON, measure voltage between P/S control module (torque sensor) connector terminal and ground.
</ptxt>
<ptxt>
P/S control module (torque sensor) connector terminal “E11-8” and ground is approx. 9 V.
</ptxt>
<ptxt>
P/S control module (torque sensor) connector terminal “E11-1” and ground is approx. 3.3 V.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace P/S control module. 
<intxreftitleoff1 refid = "AENBP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304012009">
<title>
Torque sensor signal ground circuit check
</title>
<test1>
<ptxt>
Measure voltage between P/S control module (torque sensor) connector terminals “E11-1” and “E11-3”.
</ptxt>
</test1>
<question>
Is voltage approx. 3.3 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace P/S control module. 
<intxreftitleoff1 refid = "AENBP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304012010">
<title>
Torque sensor check
</title>
<test1>
<ptxt>
Check for torque sensor. 
<intxreftitleoff1 refid = "AENBP70A6306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is the sensor in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace P/S control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace torque sensor (steering column assembly). 
<intxreftitleoff1 refid = "AENBP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
