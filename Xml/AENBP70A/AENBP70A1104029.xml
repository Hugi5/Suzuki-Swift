<servinfosub id = "AENBP70A1104029003">
<title>
DTC Confirmation Procedure
</title>
<topic id = "AENBP70A1104029004">
<title>
P0222
</title>
<attention3>
<ptxt>
Confirm that the following DTC is not detected in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
TP sensor (P0223)
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Set ignition ON for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Keep accelerator pedal at fully depressed position for 2 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Release accelerator pedal for 2 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 2) through Step 3) 3 times.
</ptxt>
</s1>
</topic>
<topic id = "AENBP70A1104029005">
<title>
P0223
</title>
<s1>
<ptxt>
Set ignition ON for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Keep accelerator pedal at fully depressed position for 2 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Release accelerator pedal for 2 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 2) through Step 3) 3 times.
</ptxt>
</s1>
</topic>
</servinfosub>
<p-change/>
<servinfosub id = "AENBP70A1104029006">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A1104029007">
<testgroup id = "AENBP70A1104029008">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104029009">
<title>
TP sensor power supply circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect electric throttle body assembly connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to electric throttle body assembly connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “B1” and “B4” is approx. 5 V.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104029010">
<title>
TP sensor ground circuit check
</title>
<test1>
<ptxt>
Check that voltage between “B1” and ground is approx. 5 V.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Repair “B4” circuit.
</ptxt>
<ptxt>
If this DTC is detected again, replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Repair “B1” circuit.
</ptxt>
<ptxt>
If this DTC is detected again, replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AENBP70A1104029011">
<title>
TP sensor (sub) signal circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B3” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B3” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B3” circuit terminal and other terminal at electric throttle body assembly connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B3” circuit: approx. 0 V (When ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair TP sensor (sub) signal circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104029012">
<title>
TP sensor check
</title>
<test1>
<ptxt>
Check TP sensor for performance. 
<intxreftitleoff1 refid = "AENBP70A1306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace electric throttle body assembly.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
