<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1506010" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Oil Pump Assembly Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1506009">Oil Pump Assembly Removal and Installation</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1506010001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove rotor plate (1) by removing rotor plate mounting bolts.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B150018.swf" width = "88.000mm" height = "55.276mm" ver = "01" gw = "190" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Remove outer rotor (1) and inner rotor (2).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B150019.swf" width = "88.000mm" height = "52.990mm" ver = "01" gw = "194" gh = "133"/>
</figure>
</s1>
<s1>
<ptxt>
Remove relief valve (1), relief valve spring (2) and retainer (3) by removing circlip (4).
</ptxt>
<figure>
<graphic graphicname = "I2RH0B150020.swf" width = "88.000mm" height = "46.301mm" ver = "01" gw = "92" gh = "114"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1506010002">
<title>
Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1506011">Oil Pump Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Wash clean and then dry all disassembled parts.
</ptxt>
</s1>
<s1>
<ptxt>
Apply thin coat of engine oil to the following parts.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Inner rotor
</ptxt>
</item>
<item>
<ptxt>
Outer rotor
</ptxt>
</item>
<item>
<ptxt>
Inside surfaces of timing chain cover.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Install outer rotor (1) and inner rotor (2) to timing chain cover.
</ptxt>
<attention3>
<ptxt>
When installing the outer rotor (1), face the front mark (3) upward.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IBP60B150036.swf" width = "88.000mm" height = "52.990mm" ver = "02" gw = "194" gh = "133"/>
</figure>
</s1>
<s1>
<ptxt>
Apply engine oil to relief valve (1) and relief valve spring (2), and install them with retainer (3) and new circlip (4) to rotor plate (5).
</ptxt>
<figure>
<graphic graphicname = "I3RM0A150005.swf" width = "88.000mm" height = "48.756mm" ver = "01" gw = "78" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Install rotor plate and tighten rotor plate bolts to specified torque. After installing plate, check that rotors can be turned smoothly by hand (Torque: 0.3 N&#183;m (0.03 kgf-m, 0.25 lbf-ft) or less).
</ptxt>
<torque>
<torqueitem id = "T1E014">
<t-part>
Oil pump rotor plate bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I2RH0B150022.swf" width = "88.000mm" height = "37.665mm" ver = "01" gw = "135" gh = "90"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
