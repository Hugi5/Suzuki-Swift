<section sectnbr = "9H">
<servcat sctnbr = "09" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9806005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Cowl Top Garnish / Front Cowl Upper Panel Removal and Installation
</title>
<servinfosub id = "AENBP70A9806005001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove windshield wiper arms. 
<intxreftitleoff1 refid = "AENBP70A9406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove cowl top garnish (1) with cowl top side garnishes (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove washer hose. 
<intxreftitleoff1 refid = "AENBP70A9403001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove washer nozzle from cowl top garnish if necessary. 
<intxreftitleoff1 refid = "AENBP70A9403001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove windshield wiper motor and wiper motor harness from front cowl upper panel (2). 
<intxreftitleoff1 refid = "AENBP70A9406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front cowl upper panel.
</ptxt>
<attention3>
<ptxt>
The figure shows LHD. For RHD, parts with (*) are installed at the opposite side.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70B980006.jpg" width = "183.000mm" height = "175.380mm" ver = "01" gw = "507" gh = "481"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "6" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.674in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.311in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.674in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.315in"/>
<colspec colnum = "6" colname = "6" colwidth = "1.674in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Cowl vent cover
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Hood rear seal
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
6.
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Cowl front silencer
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9806005002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
