<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1K">
<servcat sctnbr = "01" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1B06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Exhaust Manifold Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1B06001">Exhaust System Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1B06002001" page = "2">
<title>
Removal
</title>
<attention4>
<ptxt>
Applying a shock to the exhaust manifold may cause damage to the three-way catalytic converter inside the exhaust manifold.
</ptxt>
<ptxt>
Handle the exhaust manifold carefully. Be careful not to drop it or hit it against something.
</ptxt>
</attention4>
<s1 page = "2">
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner bracket (1).
</ptxt>
<figure>
<graphic graphicname = "IBP70A1B0001.jpg" width = "88.000mm" height = "61.208mm" ver = "02" gw = "199" gh = "157"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove exhaust manifold cover (1).
</ptxt>
<figure page = "2">
<graphic graphicname = "IBP60B1B0002.jpg" width = "88.000mm" height = "65.390mm" ver = "01" gw = "186" gh = "169"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Disconnect HO2S-1 connector (1) and then detach from their stay.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove HO2S-1 (2), if necessary. 
</ptxt>
<figure page = "2">
<graphic graphicname = "IBP70A1B0002.jpg" width = "88.000mm" height = "56.123mm" ver = "02" gw = "206" gh = "143"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Loosen exhaust manifold stiffener bolts (1).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove exhaust No.1 pipe bolts (2) from exhaust manifold.
</ptxt>
<figure page = "2">
<graphic graphicname = "IBP60B1B0004.jpg" width = "88.000mm" height = "76.505mm" ver = "03" gw = "214" gh = "200"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove exhaust manifold (1) and its gasket (2) from cylinder head.
</ptxt>
<figure page = "2">
<graphic graphicname = "IBP60B1B0005.jpg" width = "88.000mm" height = "72.407mm" ver = "01" gw = "214" gh = "189"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1B06002002" page = "2">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new gasket.
</ptxt>
</item>
<item>
<ptxt>
Tighten bolts and nuts to specified torque. 
<intxreftitleoff1 refid = "AENBP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten exhaust No.1 pipe bolts (1) to specified torque, and then exhaust manifold stiffener bolts (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1K001">
<t-part>
Exhaust No.1 pipe bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
<torqueitem id = "T1K002">
<t-part>
Exhaust manifold stiffener bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B1B0007.jpg" width = "88.000mm" height = "63.498mm" ver = "02" gw = "224" gh = "163"/>
</figure>
</item>
<item>
<ptxt>
Install HO2S-1 if removed. 
<intxreftitleoff1 refid = "AENBP70A1306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Run engine and check for exhaust gas leakage.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
