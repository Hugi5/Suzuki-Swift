<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70AA504011" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1122
</title>
<servinfosub id = "AENBP70AA504011001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.161in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.043in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1122: Backup Power Supply Malfunction
</emph>
</ptxt>
<ptxt>
Backup power supply circuit voltage from “BCM” fuse is lower than specified value.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
“BCM” fuse
</ptxt>
</item>
<item>
<ptxt>
Keyless start control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENBP70AA504011002">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition ON.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70AA504011003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70AA504011004">
<testgroup id = "AENBP70AA504011005">
<title>
Fuse check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Check “BCM” fuse.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70AA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace “BCM” fuse and go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504011006">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENBP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1122 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace “BCM” fuse and replace keyless start control module, and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70AA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
