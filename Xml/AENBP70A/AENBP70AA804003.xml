<topic id = "AENBP70AA804003005">
<title>
Diagnosis flow: [a]
</title>
<diag type = "test" id = "AENBP70AA804003006">
<testgroup id = "AENBP70AA804003007">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to DLC and combination meter.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check CAN communication circuit [a] between DLC and combination meter connector for open circuit.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA804003008">
<title>
Combination meter terminating resistance check
</title>
<test1>
<ptxt>
Connect combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect ECM connector “E01”.
</ptxt>
</test1>
<test1>
<ptxt>
Measure resistance between “G211-11” and “G211-3” terminals of DLC.
</ptxt>
</test1>
<question>
Is resistance 114 – 134 Ω?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70AA804004">Troubleshooting for Communication Bus Off</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace combination meter and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</topic>
