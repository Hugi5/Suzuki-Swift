<servinfosub id = "AENBP70A1104038001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<attention3>
<ptxt>
For type distinction of OBD system, refer to “Discrimination for OBD System” under 
<intxref refid = "AENBP70A1101003">OBD System Description</intxref>
.
</ptxt>
</attention3>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.592in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.603in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0481: Fan 2 Control Circuit
</emph>
</ptxt>
<ptxt>
Radiator cooling fan relay No.2 and/or No.3 drive circuit is shorted to ground or open.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic but mil does not light up)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic but mil does not light up)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Radiator cooling fan relay No.1 (switch side) and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
Radiator cooling fan relay No.2 (coil side) and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
Radiator cooling fan relay No.3 (coil side) and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
P0694: Fan 2 Control Circuit High
</emph>
</ptxt>
<ptxt>
Radiator cooling fan relay No.2 and/or No.3 drive circuit is shorted to power supply.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic but mil does not light up)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic but mil does not light up)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
