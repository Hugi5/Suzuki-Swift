<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9406002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Headlight Washer Tank and Headlight Washer Pump Removal and Installation
</title>
<servinfosub id = "AENBP70A9406002001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove the following parts.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front bumper: 
<intxreftitleoff1 refid = "AENBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Left side headlight unit: 
<intxreftitleoff1 refid = "AENBP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Disconnect connector (1) and washer hose (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove washer tank bolts (3).
</ptxt>
<figure>
<graphic graphicname = "IBP60B940003.swf" width = "88.000mm" height = "133.399mm" ver = "04" gw = "196" gh = "362"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Headlight washer tank
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove holder (1) from hood lock member while pushing claw (2) in arrow direction as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IBP60B940010.swf" width = "88.000mm" height = "63.666mm" ver = "01" gw = "162" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Remove headlight washer tank (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove bolt (2) and then remove headlight washer pump (3).
</ptxt>
<figure>
<graphic graphicname = "IBP60B940011.swf" width = "88.000mm" height = "68.412mm" ver = "01" gw = "197" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9406002002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<ptxt>
Tighten washer tank bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9D002">
<t-part>
Washer tank bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6.0
</t-value1>
<t-value2>
0.61
</t-value2>
<t-value3>
4.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B940008.swf" width = "88.000mm" height = "82.015mm" ver = "01" gw = "197" gh = "216"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
