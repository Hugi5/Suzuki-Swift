<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206043" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
A/C Compressor Assembly Removal and Installation
</title>
<servinfosub id = "AENBP70A7206043001">
<title>
Removal
</title>
<s1>
<ptxt>
Run engine at idle with A/C system on for 10 minutes.
</ptxt>
</s1>
<s1>
<ptxt>
Stop engine.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect negative (-) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Recover refrigerant from A/C system using recovery and recycling equipment referring to “Recovery” in 
<intxref refid = "AENBP70A7206001">Operation Procedure for Refrigerant Charge</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove compressor drive belt. 
<intxreftitleoff1 refid = "AENBP70A7206041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect magnet clutch lead wire connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect discharge hose (2) and suction hose (3) from A/C compressor (4).
</ptxt>
<attention3>
<ptxt>
Cap open fittings immediately to keep moisture out of the system.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Remove compressor mounting bolts (5), and then remove A/C compressor from its bracket.
</ptxt>
<figure>
<graphic graphicname = "IBP60B720019.swf" width = "88.000mm" height = "50.716mm" ver = "01" gw = "163" gh = "127"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENBP70A7206043002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A7206045">Magnet Clutch Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
If A/C compressor is replaced, pour new compressor oil referring to “Replenishing Compressor Oil” in 
<intxref refid = "AENBP70A7206001">Operation Procedure for Refrigerant Charge</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Apply compressor oil to new O-ring of discharge hose and liquid pipe.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B006" uid = "1078878149">
<m-desc>
Compressor oil
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Tighten compressor mounting bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T7B007">
<t-part>
Compressor mounting bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B720020.swf" width = "88.000mm" height = "50.804mm" ver = "01" gw = "155" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Evacuate and charge A/C system referring to “Evacuation” and “Charge” in 
<intxref refid = "AENBP70A7206001">Operation Procedure for Refrigerant Charge</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Adjust drive belt tension. 
<intxreftitleoff1 refid = "AENBP70A7206041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
