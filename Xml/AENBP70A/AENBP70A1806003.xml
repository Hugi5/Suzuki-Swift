<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1806003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Ignition Coil Assembly Removal and Installation
</title>
<servinfosub id = "AENBP70A1806003001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect ignition coil connectors.
</ptxt>
</s1>
<s1>
<ptxt>
Remove ignition coil bolts (1) and then pull out ignition coil assemblies (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B180005.jpg" width = "88.000mm" height = "64.307mm" ver = "01" gw = "214" gh = "166"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1806003002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1806004">Ignition Coil Assembly Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten ignition coil bolts (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1H002">
<t-part>
Ignition coil bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B180006.jpg" width = "88.000mm" height = "55.671mm" ver = "01" gw = "214" gh = "141"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
