<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Select Cable Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5506014">Select Cable Components</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Touching a hot exhaust system component will cause a burn.
</ptxt>
<ptxt>
Do not perform any service work on the select cable until the exhaust system is cool.
</ptxt>
</attention2>
<servinfosub id = "AENBP70A5506015001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove floor console front box. 
<intxreftitleoff1 refid = "AENBP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect select cable from select lever and then detach it from bracket. 
<intxreftitleoff1 refid = "AENBP70A5506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove clip of select cable and disconnect select cable from manual select lever.
</ptxt>
</s1>
<s1>
<ptxt>
Remove select cable retainer and bracket from floor tunnel.
</ptxt>
</s1>
<s1>
<ptxt>
Remove select cable from select cable clamp.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5506015002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5506017">Select Cable Adjustment</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply grease to pin and cable joint. 
<intxreftitleoff1 refid = "AENBP70A5506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Use new clip.
</ptxt>
</item>
<item>
<ptxt>
Tighten bolts to specified torque. 
<intxreftitleoff1 refid = "AENBP70A5506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Adjust select cable. 
<intxreftitleoff1 refid = "AENBP70A5506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
