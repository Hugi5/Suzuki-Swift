<servinfosub id = "AENBP70A9304006003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A9304006004">
<testgroup id = "AENBP70A9304006005">
<title>
DTC check
</title>
<test1>
<ptxt>
Clear DTC. 
<intxreftitleoff1 refid = "AENBP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENBP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1810 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check for intermittent trouble. 
<intxreftitleoff1 refid = "AENBP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A9304006006">
<title>
Fuel level sensor check
</title>
<test1>
<ptxt>
Check fuel level sensor. 
<intxreftitleoff1 refid = "AENBP70A1706018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Replace fuel level sensor and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1706017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AENBP70A9304006007">
<title>
Fuel level sensor circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect combination meter and fuel level sensor connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to combination meter and fuel level sensor terminals.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check circuit between combination meter connector and fuel level sensor for open circuit, short to ground or short to power supply.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace combination meter and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair defective wire harness and recheck DTC.
</ptxt>
</action>
</testgroup>
</diag>
