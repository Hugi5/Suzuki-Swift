<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Manual Transaxle Unit Dismounting and Remounting
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5206009">Manual Transaxle Unit Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A5206010001">
<title>
Dismounting
</title>
<s1>
<ptxt>
Remove engine and transaxle together. 
<intxreftitleoff1 refid = "AENBP70A1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove left drive shaft assembly and drive intermediate shaft assembly.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Left drive shaft assembly: 
<intxreftitleoff1 refid = "AENBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Intermediate shaft assembly: 
<intxreftitleoff1 refid = "AENBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove engine harness clamp bolt (1) and engine harness ground bolt (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B520027.jpg" width = "88.000mm" height = "67.952mm" ver = "01" gw = "191" gh = "176"/>
</figure>
</s1>
<s1>
<ptxt>
Remove starting motor. 
<intxreftitleoff1 refid = "AENBP70A1906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove engine rear mounting No.2 bracket. 
<intxreftitleoff1 refid = "AENBP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove other attached parts from transaxle, if any.
</ptxt>
</s1>
<s1>
<ptxt>
Remove transaxle-engine bolts and nut. 
<intxreftitleoff1 refid = "AENBP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Pull out transaxle from engine.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5206010002">
<title>
Remounting
</title>
<ptxt>
Reverse dismounting procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten engine harness clamp bolt (1) and engine harness ground bolt (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5B005">
<t-part>
Engine harness clamp bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
<torqueitem id = "T5B006">
<t-part>
Engine harness ground bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B520028.jpg" width = "88.000mm" height = "68.305mm" ver = "01" gw = "191" gh = "177"/>
</figure>
</item>
<item>
<ptxt>
Tighten each bolt and nut to specified torque.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Manual transaxle bolts and nut: 
<intxreftitleoff1 refid = "AENBP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Engine rear mounting No.2 bracket bolts: 
<intxreftitleoff1 refid = "AENBP70A1406013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Front drive shaft nut: 
<intxreftitleoff1 refid = "AENBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Intermediate support bolts: 
<intxreftitleoff1 refid = "AENBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Starting motor mounting bolt and nut: 
<intxreftitleoff1 refid = "AENBP70A1906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Set each clamp for wiring securely.
</ptxt>
</item>
<item>
<ptxt>
Check function of engine, clutch and transaxle.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
