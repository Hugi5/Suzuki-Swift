<servinfosub id = "AENBP70A5504021002">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed with two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<ptxt>
Check that the following condition is satisfied in this procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
DTC U0073 or U0100 is not detected.
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Drive vehicle at more than 30 km/h (19 mile/h) for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Stop vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition OFF, and leave ignition OFF for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 1) through 3).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5504021003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A5504021004">
<testgroup id = "AENBP70A5504021005">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A5504001">CVT System Check</intxref>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504021006">
<title>
DTC check
</title>
<question>
Is there any DTC(s) other than P0703?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504021007">
<title>
Brake light switch input signal to TCM check
</title>
<test1>
<ptxt>
With ignition OFF, connect SUZUKI scan tool to DLC.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Brake switch” parameter displayed on SUZUKI scan tool with brake pedal operating.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504021008">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Clear DTC. 
<intxreftitleoff1 refid = "AENBP70A5504012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure, and check DTC.
</ptxt>
</test1>
<question>
Is DTC P0703 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504021009">
<title>
Brake light switch input signal to ECM check
</title>
<test1>
<ptxt>
Check brake light switch input signal to ECM. 
<intxreftitleoff1 refid = "AENBP70A1104067"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Repair or replace defective wire harness or brake light switch.
</ptxt>
<ptxt>
If this DTC is detected again, replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
