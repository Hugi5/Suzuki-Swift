<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206024" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Air Flow Control Actuator Removal and Installation
</title>
<servinfosub id = "AENBP70A7206024001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENBP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For LHD, remove the following parts.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Steering column hole cover: 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Knee air bag (Inflator) module (if equipped): 
<intxreftitleoff1 refid = "AENBP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Steering column: 
<intxreftitleoff1 refid = "AENBP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Brake pedal assembly: 
<intxreftitleoff1 refid = "AENBP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
For RHD, remove the following parts.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Glove box: 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Foot duct (2)
</ptxt>
<figure>
<graphic graphicname = "IBP70A720011.jpg" width = "88.000mm" height = "93.954mm" ver = "01" gw = "182" gh = "250"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Screw
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Disconnect air flow control actuator connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Release screws (2) then remove air flow control actuator (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A720013.jpg" width = "88.000mm" height = "63.066mm" ver = "02" gw = "185" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7206024002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A7206025">Air Flow Control Actuator Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to insert linkage pin (2) into hole (1) of air flow control actuator arm.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722012.swf" width = "88.000mm" height = "68.493mm" ver = "02" gw = "234" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
