<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206030" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Sunload Sensor Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A7206029">Sunload Sensor Removal and Installation</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Light sunload sensor vertically with an incandescent light of approximately 100 W. The distance between sunload sensor and light should be approximately 100 mm (3.94 in.).
</ptxt>
</s1>
<s1>
<ptxt>
Measure voltage between terminals “1” and “2” of sunload sensor as shown in figure.
</ptxt>
<ptxt>
If check result is not as specified, replace sunload sensor.
</ptxt>
<spec>
<title>
Sunload sensor voltage specification
</title>
<ptxt>
Approx. 0.38 – 0.42 V
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A723014.swf" width = "88.000mm" height = "34.835mm" ver = "04" gw = "165" gh = "82"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
