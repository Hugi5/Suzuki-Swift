<servinfosub id = "AENBP70A1104028001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<attention3>
<ptxt>
For type distinction of OBD system, refer to “Discrimination for OBD System” under 
<intxref refid = "AENBP70A1101003">OBD System Description</intxref>
.
</ptxt>
</attention3>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.857in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.348in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0201: Injector Circuit / Open – Cylinder 1
</emph>
</ptxt>
<ptxt>
Fuel injector No.1 and/or its circuit is open with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "11" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Fuel injector and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0202: Injector Circuit / Open – Cylinder 2
</emph>
</ptxt>
<ptxt>
Fuel injector No.2 and/or its circuit is open with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0203: Injector Circuit / Open – Cylinder 3
</emph>
</ptxt>
<ptxt>
Fuel injector No.3 and/or its circuit is open with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0204: Injector Circuit / Open – Cylinder 4
</emph>
</ptxt>
<ptxt>
Fuel injector No.4 and/or its circuit is open with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0261: Cylinder 1 Injector Circuit Low
</emph>
</ptxt>
<ptxt>
Fuel injector No.1 drive circuit is shorted to ground with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0262: Cylinder 1 Injector Circuit High
</emph>
</ptxt>
<ptxt>
Fuel injector No.1 drive circuit is shorted to power supply with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0264: Cylinder 2 Injector Circuit Low
</emph>
</ptxt>
<ptxt>
Fuel injector No.2 drive circuit is shorted to ground with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0265: Cylinder 2 Injector Circuit High
</emph>
</ptxt>
<ptxt>
Fuel injector No.2 drive circuit is shorted to power supply with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0267: Cylinder 3 Injector Circuit Low
</emph>
</ptxt>
<ptxt>
Fuel injector No.3 drive circuit is shorted to ground with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0268: Cylinder 3 Injector Circuit High
</emph>
</ptxt>
<ptxt>
Fuel injector No.3 drive circuit is shorted to power supply with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0270: Cylinder 4 Injector Circuit Low
</emph>
</ptxt>
<ptxt>
Fuel injector No.4 drive circuit is shorted to ground with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0271: Cylinder 4 Injector Circuit High
</emph>
</ptxt>
<ptxt>
Fuel injector No.4 drive circuit is shorted to power supply with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
