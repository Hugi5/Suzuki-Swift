<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70AA206002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Outside Air Temperature Sensor Removal and Installation
</title>
<servinfosub id = "AENBP70AA206002001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front bumper. 
<intxreftitleoff1 refid = "AENBP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector (1) from outside air temperature sensor.
</ptxt>
</s1>
<s1>
<ptxt>
Remove outside air temperature sensor (2) from front bumper member.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20018.jpg" width = "88.000mm" height = "67.914mm" ver = "01" gw = "210" gh = "176"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70AA206002002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70AA206003">Outside Air Temperature Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
