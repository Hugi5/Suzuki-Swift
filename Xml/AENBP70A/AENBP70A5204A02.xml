<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hard shifting
</title>
<diag type = "condition">
<condition>
<ptxt>
Hard shifting
</ptxt>
</condition>
<ps>
<ptxt>
Insufficient lubricant
</ptxt>
</ps>
<action>
<ptxt>
Replenish manual transaxle oil. 
<intxreftitleoff1 refid = "AENBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Improper clutch pedal free travel
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace clutch operating cylinder or master cylinder
</ptxt>
<ptxt>
 Clutch operating cylinder: 
<intxreftitleoff1 refid = "AENBP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Clutch master cylinder: 
<intxreftitleoff1 refid = "AENBP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Distorted or broken clutch disc
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Damaged clutch pressure plate
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch cover. 
<intxreftitleoff1 refid = "AENBP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn synchronizer ring
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace synchronizer ring.
</ptxt>
<ptxt>
Input shaft: 
<intxreftitleoff1 refid = "AENBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Countershaft: 
<intxreftitleoff1 refid = "AENBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Worn chamfered tooth on sleeve or gear
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace synchronizer sleeve and gear.
</ptxt>
<ptxt>
Input shaft: 
<intxreftitleoff1 refid = "AENBP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Countershaft: 
<intxreftitleoff1 refid = "AENBP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Worn select lever bushing
</ptxt>
</ps>
<action>
<ptxt>
Replace select lever bushing. 
<intxreftitleoff1 refid = "AENBP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Distorted shift shaft
</ptxt>
</ps>
<action>
<ptxt>
Replace shift shaft. 
<intxreftitleoff1 refid = "AENBP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Broken gear shift / select control cables
</ptxt>
</ps>
<action>
<ptxt>
Replace gear shift and select cable. 
<intxreftitleoff1 refid = "AENBP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
