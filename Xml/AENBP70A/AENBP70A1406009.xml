<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1406009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Intake Manifold Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1406005">Throttle Body and Intake Manifold Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1406009001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front cowl upper panel. 
<intxreftitleoff1 refid = "AENBP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
With engine coolant hoses connected, remove electric throttle body assembly from intake manifold. 
<intxreftitleoff1 refid = "AENBP70A1406007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect the following connectors and each clamps.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
IMT valve actuator (1)
</ptxt>
</item>
<item>
<ptxt>
EVAP canister purge valve (2)
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Disconnect the following hoses:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Brake booster hose (3) from brake booster
</ptxt>
</item>
<item>
<ptxt>
PCV hose (4) from PCV valve
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove EVAP canister purge valve (5).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140013.jpg" width = "88.000mm" height = "63.827mm" ver = "02" gw = "222" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Remove intake manifold (1) and its gasket.
</ptxt>
<figure>
<graphic graphicname = "I8RW0A140016.jpg" width = "88.000mm" height = "55.349mm" ver = "01" gw = "198" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1406009002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new gasket.
</ptxt>
</item>
<item>
<ptxt>
Check that all removed parts are back in place.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
