<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6B">
<servcat sctnbr = "06" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A6206012" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Steering Column Lower Shaft Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A6206009">Steering Column Removal and Installation</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Adjust distance “a” between yoke centers of steering lower shaft bearing to 259 mm (10.20 in.).
</ptxt>
</item>
<item>
<ptxt>
Then check that steering lower shaft retracts by 25 mm (0.98 in.) and extends by 5 mm (0.20 in.) from distance “a”.
</ptxt>
<figure>
<graphic graphicname = "I9P60A620025.swf" width = "88.000mm" height = "37.001mm" ver = "01" gw = "206" gh = "88"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.525in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.396in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.988in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Retracts by 25 mm (0.98 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Yoke
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[b]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Extends by 5 mm (0.20 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Check steering lower shaft for smooth rotation.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
