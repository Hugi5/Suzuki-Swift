<servinfosub id = "AENBP70A8204016003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A8204016004">
<testgroup id = "AENBP70A8204016005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204016006">
<title>
SDM power voltage check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “L04” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Start engine and set engine idle speed.
</ptxt>
</test1>
<test1>
<ptxt>
Measure voltage between “L04-18” terminal and ground.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B005">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820120.swf" width = "90.000mm" height = "58.650mm" ver = "01" gw = "204" gh = "150"/>
</testfigure>
</test1>
<question>
Is voltage 8 V or more?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check charging system and repair “RED” circuit. 
<intxreftitleoff1 refid = "AENBP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204016007">
<title>
DTC check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Connect “L04” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<question>
Is DTC B1017 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble. Check for intermittent. 
<intxreftitleoff1 refid = "AENBP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs, referring to 
<intxref refid = "AENBP70A8204006">DTC Clearance</intxref>
 if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENBP70A8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
