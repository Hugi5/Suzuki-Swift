<servinfosub id = "AENBP70A5504057003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed with two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
 If other DTC than P0841 is newly detected during this “DTC Confirmation Procedure”, troubleshoot the newly detected DTC first.
</ptxt>
</item>
<item>
<ptxt>
Check that the following conditions are satisfied in this procedure.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Other DTC is not detected.
</ptxt>
</item>
<item>
<ptxt>
11 V &#60; Battery voltage &#60; 15 V
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Start engine and drive vehicle in D range with accelerator depressed to 10 to 15% for 5 sec. or more.
</ptxt>
</s1>
<s1>
<ptxt>
Stop vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition OFF, and leave ignition OFF for 10 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 1) through 3).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5504057004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A5504057005">
<testgroup id = "AENBP70A5504057006">
<question>
Was “CVT System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A5504001">CVT System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504057007">
<title>
Secondary pressure sensor drive circuit signal check
</title>
<test1>
<ptxt>
With ignition OFF, connect SUZUKI scan tool to DLC.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Line pressure” parameter displayed on SUZUKI scan tool while engine is idling or when performing stall test.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504057008">
<title>
Secondary pressure sensor and its circuit check
</title>
<test1>
<ptxt>
Check secondary pressure sensor and its circuit according to Step 3 through 4 of 
<intxref refid = "AENBP70A5504058">DTC P0842</intxref>
 and 
<intxref refid = "AENBP70A5504059">DTC P0843</intxref>
.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A5504057009">
<title>
Secondary pressure sensor check
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENBP70A5506039">Secondary Pressure Sensor Inspection</intxref>
.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known-good TCM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace secondary pressure sensor (CVT assembly). 
<intxreftitleoff1 refid = "AENBP70A5506019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
