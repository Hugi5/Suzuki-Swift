</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9204013004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A9204013005">
<testgroup id = "AENBP70A9204013006">
<title>
DTC check
</title>
<test1>
<ptxt>
Clear DTC. 
<intxreftitleoff1 refid = "AENBP70A9204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G14” and “G275” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connections to “G14” and “G275” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, connect “G14” and “G275” connectors securely.
</ptxt>
</test1>
<test1>
<ptxt>
Perform “DTC Confirmation Procedure” and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9204002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1951 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A9204013007">
<title>
Headlight auto leveling and washer control module circuit check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G14” and “G275” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check “A1” circuit between “G14” connector and “G275” connector for open circuit, short to ground or short to power supply.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective harness and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9204002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A9204013008">
<title>
Headlight auto leveling and washer control module power supply voltage check
</title>
<test1>
<ptxt>
Check “A1” circuit voltage with engine idle speed or running at 3,000 rpm.
</ptxt>
</test1>
<question>
Is voltage 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace headlight auto leveling and washer control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check charging system. 
<intxreftitleoff1 refid = "AENBP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
