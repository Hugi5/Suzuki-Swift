<ptxt>
<emph etype = "bold">
B1191: Accessory Relay Malfunction
</emph>
</ptxt>
<ptxt>
Inconsistency between input voltage via “ACC” fuse and ACC relay control condition continuous for longer than specified time.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ACC relay circuit / connector
</ptxt>
</item>
<item>
<ptxt>
ACC relay
</ptxt>
</item>
<item>
<ptxt>
“IGN” fuse
</ptxt>
</item>
<item>
<ptxt>
“ACC” fuse
</ptxt>
</item>
<item>
<ptxt>
Keyless start control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
