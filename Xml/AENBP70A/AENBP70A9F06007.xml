<servinfo servinfosgmlid = "AENBP70A9F06007" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Steering Switch (Audio Control Switch and Hands-Free Switch) Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A9F06006">Steering Switch Removal and Installation</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Remove driver air bag (inflator) module. 
<intxreftitleoff1 refid = "AENBP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect steering switch connector.
</ptxt>
</s1>
<s1>
<ptxt>
Measure resistance between the following terminals under each condition in the table.
</ptxt>
</s1>
<s1>
<ptxt>
Check for continuity between the following terminals.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
For vehicles not equipped with hands-free switch: between terminals “4” and “10”
</ptxt>
</item>
<item>
<ptxt>
For vehicles equipped with hands-free switch: between connectors [A] and [B]
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Set tester at diode range when measuring between terminals “4” and “10”, “4” and (1), “10” and (4), (1) and (4).
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
If check result is not satisfactory, replace audio control switch.
</ptxt>
<figure>
<graphic graphicname = "IBP70A9F0003.jpg" width = "88.000mm" height = "111.093mm" ver = "02" gw = "221" gh = "298"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.956in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Steering switch connector (to contact coil)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Steering switch connector (to hands-free switch) (if equipped)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[1]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
With audio switch only
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[2]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
With hands-free switch and shift paddle switch
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[3]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Audio control switch
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
