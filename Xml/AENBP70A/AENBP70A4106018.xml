<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A4106018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Brake Master Cylinder Reservoir Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A4106015">Brake Master Cylinder Components</intxrefpoff>
</ptxt>
<attention4>
<ptxt>
Brake fluid is extremely damaging to painted surfaces.
</ptxt>
<ptxt>
If brake fluid contacts a painted surface, immediately wipe it off and flush the surface thoroughly with water.
</ptxt>
</attention4>
<servinfosub id = "AENBP70A4106018001">
<title>
Removal
</title>
<s1>
<ptxt>
Clean outside surface of reservoir.
</ptxt>
</s1>
<s1>
<ptxt>
Remove master cylinder together with reservoir from brake booster. 
<intxreftitleoff1 refid = "AENBP70A4106017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove spring pin (1) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A004">
<s-part>
(A)
</s-part>
<s-number num = "09916-44310">
09916–44310
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A410013.swf" width = "88.000mm" height = "50.801mm" ver = "01" gw = "138" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Remove reservoir (1) and grommets (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410014.swf" width = "88.000mm" height = "70.866mm" ver = "01" gw = "152" gh = "184"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A4106018002">
<title>
Installation
</title>
<s1>
<ptxt>
When using new grommets, lubricate them with the same fluid as the one to fill reservoir with before fitting grommets into master cylinder.
</ptxt>
</s1>
<s1>
<ptxt>
Install reservoir to master cylinder.
</ptxt>
</s1>
<s1>
<ptxt>
Install spring pin (2) using special tool, until both of its ends at the right and left of reservoir (1) becomes the same length.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A005">
<s-part>
(A)
</s-part>
<s-number num = "09916-44310">
09916–44310
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I8C50A410025.swf" width = "88.000mm" height = "44.650mm" ver = "01" gw = "193" gh = "110"/>
</figure>
</s1>
<s1>
<ptxt>
Install master cylinder with reservoir to brake booster. 
<intxreftitleoff1 refid = "AENBP70A4106017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
