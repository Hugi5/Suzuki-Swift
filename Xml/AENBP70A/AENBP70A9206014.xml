<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9206014" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Headlight Leveling Actuator Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A9206001">Headlight Unit Removal and Installation</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Disconnect headlight levering actuator connector.
</ptxt>
</s1>
<s1>
<ptxt>
Arrange 3 new 1.5 V batteries (1) in series (check that total voltage is 4.5 – 5.0 V), and connect it as shown in figure. Check that reflector of headlight moves downward.
</ptxt>
<figure>
<graphic graphicname = "IAP70P920016.jpg" width = "88.000mm" height = "88.910mm" ver = "01" gw = "212" gh = "236"/>
</figure>
</s1>
<s1>
<ptxt>
Arrange 5 new 1.5 V batteries (1) in series (check that total voltage is 7.5 – 8.0 V) and connect it as shown in figure. Check that reflector of headlight moves upward.
</ptxt>
<figure>
<graphic graphicname = "IAP70P920017.jpg" width = "88.000mm" height = "87.800mm" ver = "01" gw = "210" gh = "232"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
