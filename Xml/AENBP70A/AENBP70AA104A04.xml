<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10A">
<servcat sctnbr = "10" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70AA104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Cruise control cannot be canceled
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Perform cruise control system check referring to 
<intxref refid = "AENBP70AA104001">Cruise Control System Check</intxref>
 before performing this “Cruise Control System Symptom Diagnosis”.
</ptxt>
</item>
<item>
<ptxt>
Check each part in the order from the top of the following list.
</ptxt>
</item>
</list1>
</attention3>
<diag type = "condition">
<condition>
<ptxt>
Cruise control cannot be canceled
</ptxt>
</condition>
<ps>
<ptxt>
Faulty CANCEL switch
</ptxt>
</ps>
<action>
<ptxt>
Check CANCEL switch for function referring to 
<intxref refid = "AENBP70AA106002">Cruise Control Switch Inspection</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty brake light switch
</ptxt>
</ps>
<action>
<ptxt>
Check brake light switch for function referring to 
<intxref refid = "AENBP70AA106006">Brake Light Switch Inspection</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty CPP No.2 switch (M/T model)
</ptxt>
</ps>
<action>
<ptxt>
Check CPP No.2 switch for function referring to 
<intxref refid = "AENBP70AA106004">CPP No.2 Switch Inspection (M/T Model)</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair.
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
Replace after making sure that none of above parts is faulty.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
