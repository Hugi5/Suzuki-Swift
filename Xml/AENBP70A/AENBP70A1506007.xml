<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1506007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Oil Pan and Oil Pump Strainer Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1506006">Oil Pan and Oil Pump Strainer Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1506007001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove oil level gauge.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Drain engine oil by removing drain plug.
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil filter, if necessary. 
<intxreftitleoff1 refid = "AENBP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust No.1 pipe and No.2 pipe. 
<intxreftitleoff1 refid = "AENBP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove clutch housing lower plate (1).
</ptxt>
<figure>
<graphic graphicname = "I5RW0A150002.swf" width = "88.000mm" height = "48.709mm" ver = "01" gw = "172" gh = "122"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove transaxle bolts (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150021.jpg" width = "88.000mm" height = "68.933mm" ver = "01" gw = "207" gh = "179"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove oil pan bolts (1) and nuts (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150022.jpg" width = "88.000mm" height = "55.560mm" ver = "01" gw = "213" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Remove oil pan (1) from cylinder block using special tool and hammer.
</ptxt>
<servicetool>
<servicetoolitem id = "L1E006">
<s-part>
(A)
</s-part>
<s-number num = "09921-96510">
09921–96510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IBP60B150037.jpg" width = "88.000mm" height = "45.052mm" ver = "01" gw = "189" gh = "111"/>
</figure>
</s1>
<c-change/>
<s1 page = "2">
<ptxt>
Remove oil pump strainer (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150023.jpg" width = "88.000mm" height = "67.807mm" ver = "01" gw = "214" gh = "176"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove oil pan baffle plate (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B150025.jpg" width = "88.000mm" height = "49.180mm" ver = "01" gw = "202" gh = "123"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1506007002">
<title>
Installation
</title>
<s1>
<ptxt>
Clean sealing surface between oil pan and cylinder block.
</ptxt>
<ptxt>
Remove oil, old sealant and dust from sealing surface.
</ptxt>
</s1>
<s1>
<ptxt>
Clean oil pump strainer screen (1), if necessary.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B150016.swf" width = "88.000mm" height = "37.877mm" ver = "01" gw = "78" gh = "90"/>
</figure>
</s1>
<s1>
<ptxt>
Install oil pan baffle plate (1) and then tighten oil pan baffle plate bolts (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E006">
<t-part>
Oil pan baffle plate bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure page = "2">
<graphic graphicname = "IBP60B150026.jpg" width = "88.000mm" height = "51.016mm" ver = "01" gw = "208" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Apply engine oil to new O-rings (1) and then install O-rings to oil pump strainer (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install oil pump strainer with O-ring to oil pump assembly and tighten oil pump strainer bolt (3) first and then oil pump strainer bracket bolt (4) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E007">
<t-part>
Oil pump strainer bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
<torqueitem id = "T1E008">
<t-part>
Oil pump strainer bracket bolt*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A150001.swf" width = "88.000mm" height = "49.857mm" ver = "02" gw = "176" gh = "124"/>
</figure>
</s1>
<s1>
<ptxt>
Confirm dowel pin (1) in installed onto oil pan.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A150005.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "184" gh = "128"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Apply sealant to mating surface of oil pan as shown in figure.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Before applying sealant, make sure mating surface is clean and dry.
</ptxt>
</item>
<item>
<ptxt>
Wipe off excessive sealant.
</ptxt>
</item>
<item>
<ptxt>
Install oil pan within 2 minutes after applying sealant.
</ptxt>
</item>
</list1>
</attention3>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1E002" uid = "-491504098">
<m-part>
(A)
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<spec>
<title>
Sealant amount for oil pan
</title>
<ptxt>
Width “a”: 3 mm (0.12 in.)
</ptxt>
<ptxt>
Height “b”: 2 mm (0.08 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP60B150030.swf" width = "88.000mm" height = "58.197mm" ver = "01" gw = "156" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Install oil pan to cylinder block temporarily.
</ptxt>
</s1>
<s1>
<ptxt>
Insert dowel pin (1) in hole (2) of oil pan in order to position oil pan precisely.
</ptxt>
<attention3>
<ptxt>
Dowel pin is available as a spare part (parts number: 04211–13189).
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I4RS0A150007.swf" width = "88.000mm" height = "48.876mm" ver = "01" gw = "175" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten oil pan bolts in numerical order (“1” – “20”) evenly and gradually to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E009">
<t-part>
Oil pan bolt (M6)*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
<torqueitem id = "T1E010">
<t-part>
Oil pan nut*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
<torqueitem id = "T1E011">
<t-part>
Oil pan bolt (M10)*
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B150032.jpg" width = "88.000mm" height = "59.014mm" ver = "01" gw = "236" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten transaxle bolts (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E012">
<t-part>
Transaxle bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B150033.jpg" width = "88.000mm" height = "68.933mm" ver = "01" gw = "207" gh = "179"/>
</figure>
</s1>
<s1>
<ptxt>
Remove dowel pin inserted in Step 9).
</ptxt>
</s1>
<s1>
<ptxt>
Install clutch housing lower plate (1) and tighten clutch housing lower plate bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1E013">
<t-part>
Clutch housing lower plate bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I5RW0A150003.swf" width = "88.000mm" height = "48.709mm" ver = "01" gw = "172" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Install exhaust pipe No.1 and No.2. 
<intxreftitleoff1 refid = "AENBP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install oil filter, if removed. 
<intxreftitleoff1 refid = "AENBP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install drain plug and refill engine with engine oil. 
<intxreftitleoff1 refid = "AENBP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install right engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Install oil level gauge.
</ptxt>
</s1>
<s1>
<ptxt>
Verify that there is no engine oil leakage and exhaust gas leakage at each connection.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
