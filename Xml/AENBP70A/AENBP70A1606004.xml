<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1606004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Cooling System Draining
</title>
<ptxt>
Before performing the following procedure, observe 
<intxref refid = "AENBP70A1600001">Precautions for Cooling System</intxref>
.
</ptxt>
<s1>
<ptxt>
Remove radiator cap.
</ptxt>
</s1>
<s1>
<ptxt>
Insert hose (1) to service holes (2).
</ptxt>
<attention3>
<ptxt>
Use hose as specified below for installing to service hole.
</ptxt>
<figure>
<graphic graphicname = "IBP60B160005.swf" width = "88.000mm" height = "25.884mm" ver = "02" gw = "171" gh = "57"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.069in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
Outside diameter “a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
16 mm (0.63 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
Inside diameter “b”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
12 – 14 mm (0.48 – 0.55 in,)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
Length “c”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
More than 150 mm (5.91 in,)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</attention3>
</s1>
<s1>
<ptxt>
Drain coolant from radiator drain plug (3).
</ptxt>
</s1>
<s1>
<ptxt>
After draining coolant, be sure to tighten drain plug securely.
</ptxt>
<figure>
<graphic graphicname = "IBP60B160006.jpg" width = "88.000mm" height = "60.877mm" ver = "01" gw = "195" gh = "156"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
