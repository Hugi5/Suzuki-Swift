<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1606011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Radiator Cooling Fan Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1606009">Radiator Cooling Fan Assembly On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1606011001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly, suction pipe, resonator and suction hose. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENBP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove reservoir (1).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect radiator inlet hose (2) from radiator.
</ptxt>
<figure>
<graphic graphicname = "IBP70A160005.jpg" width = "88.000mm" height = "61.611mm" ver = "01" gw = "218" gh = "158"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect radiator cooling fan motor connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove radiator cooling fan assembly from radiator.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENBP70A1606011002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
If there is matchmark on each of hose and pipe, install the hose aligning matchmark on hose with matchmark on pipe and then install each clamp in proper position.
</ptxt>
</item>
<item>
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENBP70A1606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check cooling system for leakage. 
<intxreftitleoff1 refid = "AENBP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
