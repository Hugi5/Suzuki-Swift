<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A8106007" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Passenger Seat Belt Reminder Light Inspection (If Equipped)
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A8106006">Passenger Seat Belt Reminder Light Removal and Installation (If Equipped)</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Remove hazard warning switch (1). 
<intxreftitleoff1 refid = "AENBP70A9206021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect battery to the hazard warning switch as shown.
</ptxt>
</s1>
<s1>
<ptxt>
Check that passenger seat belt reminder light (2) lights up.
</ptxt>
<ptxt>
If passenger seat belt reminder light does not light up, replace the hazard warning switch.
</ptxt>
<figure>
<graphic graphicname = "IBP70A810002.swf" width = "88.000mm" height = "98.282mm" ver = "01" gw = "233" gh = "262"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
