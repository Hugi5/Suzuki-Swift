<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9206008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
License Plate Light Removal and Installation
</title>
<servinfosub id = "AENBP70A9206008001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear end door lower garnish bolts (1), and then remove rear end door lower garnish (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove license plate light (3).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect license plate light connector.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920012.jpg" width = "88.000mm" height = "78.583mm" ver = "02" gw = "210" gh = "206"/>
</figure>
</s1>
<s1>
<ptxt>
Remove bulb, If necessary.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9206008002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten rear end door lower garnish bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9B001">
<t-part>
Rear end door lower garnish bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.5
</t-value1>
<t-value2>
0.56
</t-value2>
<t-value3>
4.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A920029.jpg" width = "88.000mm" height = "78.583mm" ver = "01" gw = "210" gh = "206"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
