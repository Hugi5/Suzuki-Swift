<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206013" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Blower Motor Controller Removal and Installation
</title>
<servinfosub id = "AENBP70A7206013001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove glove box from instrument panel. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove foot duct (2) from HVAC unit by removing screw (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A721036.jpg" width = "88.000mm" height = "94.268mm" ver = "01" gw = "199" gh = "251"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect connector (1) from blower motor controller (2), and then remove blower motor controller from HVAC unit by removing screws (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A720022.swf" width = "88.000mm" height = "50.799mm" ver = "01" gw = "187" gh = "127"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7206013002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
