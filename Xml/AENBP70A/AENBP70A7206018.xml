<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A7206018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Expansion Valve Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A7206007">HVAC Unit Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A7206018001">
<title>
Removal
</title>
<s1>
<ptxt>
Run engine at idle with A/C system on for 10 minutes.
</ptxt>
</s1>
<s1>
<ptxt>
Stop engine.
</ptxt>
</s1>
<s1>
<ptxt>
Recover refrigerant from the A/C system with recovery and recycling equipment referring to “Recovery” in 
<intxref refid = "AENBP70A7206001">Operation Procedure for Refrigerant Charge</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Loosen bolt (1), then remove liquid pipe and suction hose from expansion valve (2).
</ptxt>
</s1>
<s1>
<ptxt>
Loosen bolts (3) and remove expansion valve.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A720028.swf" width = "88.000mm" height = "43.902mm" ver = "01" gw = "173" gh = "109"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7206018002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A7206019">Expansion Valve Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply compressor oil to O-ring of expansion valve and pipes.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B004" uid = "1078878149">
<m-desc>
Compressor oil
</m-desc>
<m-number>
99000–99095–00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Tighten expansion valve bolts and liquid pipe and suction hose bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T7B002">
<t-part>
Expansion valve bolt
</t-part>
<t-value1>
7.0
</t-value1>
<t-value2>
0.71
</t-value2>
<t-value3>
5.5
</t-value3>
</torqueitem>
<torqueitem id = "T7B003">
<t-part>
Liquid pipe and suction hose bolt
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Evacuate and charge the A/C system referring to “Evacuation” and “Charge” in 
<intxref refid = "AENBP70A7206001">Operation Procedure for Refrigerant Charge</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
