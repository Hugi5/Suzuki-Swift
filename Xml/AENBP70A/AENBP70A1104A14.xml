<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A1104A14" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Poor engine power
</title>
<ptxt>
Perform troubleshooting referring to the following points when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENBP70A1104008">Visual Inspection</intxref>
 and 
<intxref refid = "AENBP70A1104009">Engine Basic Inspection</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Poor engine power
</ptxt>
</condition>
<ps>
<ptxt>
Faulty spark plug
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1806002">Spark Plug Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ignition coil with ignitor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1806004">Ignition Coil Assembly Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty knock sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1306017">Knock Sensor On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Clogged fuel hoses or pipes
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1704005">Fuel Pressure Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Malfunctioning fuel pump
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1704004">Fuel Pump and Its Circuit Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Air drawn in through intake manifold gasket or throttle body gasket
</ptxt>
</ps>
<action>
<ptxt>
Check air intake system.
</ptxt>
</action>
<ps>
<ptxt>
Engine overheating
</ptxt>
</ps>
<action>
<ptxt>
Condition “Engine overheating”
</ptxt>
</action>
<ps>
<ptxt>
Poor performance of ECT sensor or MAF sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1306009">ECT Sensor Inspection</intxref>
 or 
<intxref refid = "AENBP70A1306022">MAF and IAT Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty electric throttle body assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1306003">Electric Throttle Body Assembly On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty APP sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1306007">APP Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty fuel injector
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1704003">Fuel Injector Circuit Check</intxref>
 or 
<intxref refid = "AENBP70A1706009">Fuel Injector Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1104067">Inspection of ECM and Its Circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Dragging brakes
</ptxt>
</ps>
<action>
<ptxt>
Condition “Dragging brakes (A very light drag is present in all brakes immediately after pedal is released)” in 
<intxref refid = "AENBP70A4104001">Brakes Symptom Diagnosis</intxref>
 
</ptxt>
</action>
<ps>
<ptxt>
Slipping clutch (M/T model)
</ptxt>
</ps>
<action>
<ptxt>
Condition “Slipping” in 
<intxref refid = "AENBP70A5304001">Clutch System Symptom Diagnosis</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Low compression
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A1404001">Compression Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
VVT system out of order
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
VVT actuator: 
<intxref refid = "AENBP70A1406025">VVT Actuator, Camshaft, Tappet and Shim Inspection</intxref>
</ptxt>
</item>
<item>
<ptxt>
Valve timing: 
<intxref refid = "AENBP70A1406022">Timing Chain and Chain Tensioner Inspection</intxref>
</ptxt>
</item>
<item>
<ptxt>
OCV oil circuit: 
<intxref refid = "AENBP70A1406017">Timing Chain Cover Inspection</intxref>
</ptxt>
</item>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
