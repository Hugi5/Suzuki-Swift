<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A9604A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
All door cannot be locked / unlocked by only remote controller
</title>
<diag type = "condition">
<condition>
<ptxt>
All door cannot be locked / unlocked by only remote controller
</ptxt>
</condition>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENBP70AA204022">Inspection of BCM and Its Circuits</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty keyless start control module
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENBP70AA504031">Inspection of Keyless Start Control Module and Its Circuits</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Faulty remote controller
</ptxt>
</ps>
<action>
<ptxt>
Replace battery. 
<intxreftitleoff1 refid = "AENBP70AA506020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty keyless entry receiver
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENBP70A9606016">Keyless Entry Receiver Inspection</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
