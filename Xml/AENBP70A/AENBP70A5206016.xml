<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5206016" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Transaxle Right Case Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5206010">Manual Transaxle Unit Dismounting and Remounting</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENBP70A5206014">Manual Transaxle Assembly Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A5206016001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove differential side oil seal from transaxle right case, if necessary. 
<intxreftitleoff1 refid = "AENBP70A5206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove differential side bearing outer race (1) using brass bar (2), if necessary.
</ptxt>
<figure>
<graphic graphicname = "IAY301520029.swf" width = "88.000mm" height = "70.092mm" ver = "02" gw = "206" gh = "182"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Remove input shaft oil seal using special tool, if necessary.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B008">
<s-part>
(A)
</s-part>
<s-number num = "09913-75830">
09913–75830
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A520026.swf" width = "88.000mm" height = "47.005mm" ver = "01" gw = "190" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Break oil channel (1) with flat-bladed screwdriver or the like and remove it.
</ptxt>
<figure>
<graphic graphicname = "IAY301520030.swf" width = "88.000mm" height = "51.720mm" ver = "01" gw = "186" gh = "130"/>
</figure>
</s1>
<s1>
<ptxt>
Remove countershaft right bearing outer race using special tools, if necessary.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B009">
<s-part>
(A)
</s-part>
<s-number num = "09942-15511">
09942–15511
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B010">
<s-part>
(B)
</s-part>
<s-number num = "09944-96011">
09944–96011
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAY301520031.swf" width = "88.000mm" height = "55.919mm" ver = "01" gw = "194" gh = "142"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5206016002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Install new input shaft oil seal (1) facing its spring side upward, if removed. Use special tool and hammer for installation and apply grease to oil seal lip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B007" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<servicetool>
<servicetoolitem id = "L5B011">
<s-part>
(A)
</s-part>
<s-number num = "09913-75830">
09913–75830
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Distance from case surface to input shaft oil seal
</title>
<ptxt>
“a”: 1.0 – 2.0 mm (0.04 – 0.07 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP60B520019.jpg" width = "88.000mm" height = "68.749mm" ver = "02" gw = "206" gh = "178"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Install countershaft right bearing outer race and new countershaft oil channel using special tool, if removed.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B012">
<s-part>
(A)
</s-part>
<s-number num = "09913-85210">
09913–85210
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAY301520032.swf" width = "88.000mm" height = "55.223mm" ver = "01" gw = "190" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Install differential side bearing outer race using special tools and hammer, if removed.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B013">
<s-part>
(A)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B014">
<s-part>
(B)
</s-part>
<s-number num = "09925-14520">
09925–14520
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A520030.swf" width = "88.000mm" height = "48.631mm" ver = "01" gw = "182" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Install new differential side oil seal to right case, if removed. 
<intxreftitleoff1 refid = "AENBP70A5206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
