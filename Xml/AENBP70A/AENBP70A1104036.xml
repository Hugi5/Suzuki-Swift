<servinfosub id = "AENBP70A1104036001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<attention3>
<ptxt>
For type distinction of OBD system, refer to “Discrimination for OBD System” under 
<intxref refid = "AENBP70A1101003">OBD System Description</intxref>
.
</ptxt>
</attention3>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.855in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.349in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0443: Evaporative Emission System Purge Control Valve Circuit
</emph>
</ptxt>
<ptxt>
EVAP canister purge valve drive circuit is open with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
EVAP canister purge valve and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0458: Evaporative Emission System Purge Control Valve Circuit Low
</emph>
</ptxt>
<ptxt>
EVAP canister purge valve drive circuit is shorted to ground with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0459: Evaporative Emission System Purge Control Valve Circuit High
</emph>
</ptxt>
<ptxt>
EVAP canister purge valve drive circuit is shorted to power supply with engine running.
</ptxt>
<ptxt>
(Type A and C: 3 D/C detection logic)
</ptxt>
<ptxt>
(Type B: 2 D/C detection logic)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
