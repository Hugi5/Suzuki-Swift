<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A7204A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Air outlet port does not change or does not agree even if “MODE” (air flow) switch is changed
</title>
<diag type = "condition">
<condition>
<ptxt>
Air outlet port does not change or does not agree even if “MODE” (air flow) switch is changed
</ptxt>
</condition>
<ps>
<ptxt>
Faulty air flow control door assembly
</ptxt>
</ps>
<action>
<ptxt>
Check HVAC unit.
</ptxt>
</action>
<ps>
<ptxt>
Faulty air flow control actuator
</ptxt>
</ps>
<action>
<ptxt>
Check air flow control actuator. 
<intxreftitleoff1 refid = "AENBP70A7206025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty inside air temperature sensor, outside air temperature sensor or sunload sensor
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check inside air temperature sensor, outside air temperature sensor or sunload sensor.
</ptxt>
<ptxt>
• Inside air temperature sensor: 
<intxreftitleoff1 refid = "AENBP70A7206034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
• Outside air temperature sensor: 
<intxreftitleoff1 refid = "AENBP70A7206032"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
• Sunload sensor: 
<intxreftitleoff1 refid = "AENBP70A7206030"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<ptxt>
Check BCM. 
<intxreftitleoff1 refid = "AENBP70AA204022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty auto A/C panel
</ptxt>
</ps>
<action>
<ptxt>
Check auto A/C panel. 
<intxreftitleoff1 refid = "AENBP70A7204034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty HVAC control module
</ptxt>
</ps>
<action>
<ptxt>
Check HVAC control module. 
<intxreftitleoff1 refid = "AENBP70A7204035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
