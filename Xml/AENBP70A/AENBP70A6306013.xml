<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A6306013" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
P/S Motor Inspection
</title>
<s1>
<ptxt>
With ignition OFF, disconnect “E12” connector (1) from P/S control module. 
</ptxt>
</s1>
<s1>
<ptxt>
Check resistance between terminals “1” and “2” of “E12” connector (1).
</ptxt>
<ptxt>
If check result is not as specified, replace steering column assembly.
</ptxt>
<spec>
<title>
Motor circuit resistance
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.202in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.264in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Between “1” and “2”
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Approx. 1 Ω
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</s1>
<s1>
<ptxt>
Check continuity between terminal “1” of “E12” connector and ground.
</ptxt>
<ptxt>
If check result is not as specified, replace steering column assembly.
</ptxt>
<spec>
<title>
Motor circuit resistance
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.254in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.221in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
“1” and ground
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
No continuity 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<figure>
<graphic graphicname = "I9P60A630036.swf" width = "88.000mm" height = "40.047mm" ver = "01" gw = "160" gh = "97"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.445in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
“E12” connector (View: [a])
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Hoist vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
With ignition OFF, connect “E12” connector (1) to P/S control module (2).
</ptxt>
</s1>
<s1>
<ptxt>
Using ammeter (3), check that P/S motor current with engine idling is as indicated below. If check result is not as specified, check P/S control module. 
<intxreftitleoff1 refid = "AENBP70A6304022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If check result is as specified, replace steering column assembly.
</ptxt>
<spec>
<title>
Motor current at hoisted vehicle
</title>
<table frame = "all" colsep = "1" rowsep = "1" page = "2">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.708in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.863in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.934in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.960in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
When steering wheel is at straight position: [A]
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
When steering wheel is turned left or right at turning speed of 90&#176; /sec.: [B]
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
When steering wheel is kept fully turned left or right until it stops.: [C]
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Motor current
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Approx. 0 A
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Approx.
</ptxt>
<ptxt>
3.0 to 4.2 A
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Approx. 45 to 60 A
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<figure>
<graphic graphicname = "I8C50A630034.swf" width = "88.000mm" height = "87.925mm" ver = "01" gw = "192" gh = "233"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
