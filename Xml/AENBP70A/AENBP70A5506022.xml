<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5506022" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Transmission Range Sensor Inspection
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery and battery tray with ECM. 
<intxreftitleoff1 refid = "AENBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Shift select lever to N range and remove manual select lever nut (1), manual select lever (2) and washer (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A550102.swf" width = "88.000mm" height = "62.854mm" ver = "01" gw = "167" gh = "162"/>
</figure>
</s1>
<s1>
<ptxt>
Check that neutral position of transmission range sensor and shift shaft is in correct position referring to Step 5) of 
<intxref refid = "AENBP70A5506023">Transmission Range Sensor Adjustment</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Use new washer (1) and nut (2), install manual select lever (3) and tighten manual select lever nut to specified torque.
</ptxt>
<attention4>
<ptxt>
Reusing the manual select lever washer can cause manual select lever nut to loosen, because the removed washer no longer has sufficient fastening performance.
</ptxt>
<ptxt>
Be sure to use a new manual select lever washer.
</ptxt>
</attention4>
<torque>
<torqueitem id = "T5E009">
<t-part>
Manual select lever nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
17
</t-value1>
<t-value2>
1.73
</t-value2>
<t-value3>
12.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A550063.swf" width = "88.000mm" height = "62.854mm" ver = "02" gw = "176" gh = "162"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.621in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Transmission range sensor
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Disconnect transmission range sensor connector (1).
</ptxt>
<figure>
<graphic graphicname = "IBP70A550064.swf" width = "88.000mm" height = "70.457mm" ver = "02" gw = "173" gh = "183"/>
</figure>
</s1>
<s1>
<ptxt>
Check for continuity between terminals of transmission range sensor connector over each range shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IBP70A550065.swf" width = "88.000mm" height = "65.362mm" ver = "01" gw = "223" gh = "169"/>
</figure>
</s1>
<s1>
<ptxt>
Connect transmission range sensor connector.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
