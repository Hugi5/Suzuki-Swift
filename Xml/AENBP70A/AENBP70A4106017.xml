<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A4106017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Brake Master Cylinder Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A4106015">Brake Master Cylinder Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENBP70A4106016">Brake Master Cylinder Assembly On-Vehicle Inspection</intxrefpoff>
</ptxt>
<attention4>
<list1 type = "unordered">
<item>
<ptxt>
The master cylinder and brake booster will lose their original performance if they are disassembled and reassembled.
</ptxt>
<ptxt>
If any faulty condition is found with the master cylinder or brake booster, replace the part rather than trying to disassemble and repair it.
</ptxt>
</item>
<item>
<ptxt>
Brake fluid is extremely damaging to painted surfaces.
</ptxt>
<ptxt>
If brake fluid contacts a painted surface, immediately wipe it off and flush the surface thoroughly with water.
</ptxt>
</item>
</list1>
</attention4>
<servinfosub id = "AENBP70A4106017001">
<title>
Removal
</title>
<s1>
<ptxt>
For LHD, remove battery and battery tray. 
<intxreftitleoff1 refid = "AENBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Clean external surface of brake master cylinder.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect brake fluid level switch connector (1) on reservoir.
</ptxt>
<figure>
<graphic graphicname = "IBP70A410006.swf" width = "88.000mm" height = "110.230mm" ver = "01" gw = "165" gh = "296"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.273in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.772in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.273in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.772in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
LHD
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
RHD
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Drain brake fluid in reservoir.
</ptxt>
</s1>
<s1>
<ptxt>
For M/T model, disconnect clutch reservoir hose from reservoir.
</ptxt>
</s1>
<s1>
<ptxt>
Using special tool, loosen flare nuts and disconnect brake pipes (1) from brake master cylinder.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A002">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Remove brake master cylinder fixing nuts (2).
</ptxt>
<figure>
<graphic graphicname = "IBP70A410007.swf" width = "88.000mm" height = "119.074mm" ver = "01" gw = "168" gh = "321"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.273in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.772in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.273in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.772in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
LHD
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
RHD
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove brake master cylinder from brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
Remove O-ring (2) from brake master cylinder (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410022.swf" width = "88.000mm" height = "46.292mm" ver = "01" gw = "137" gh = "115"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A4106017002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A4106019">Brake Master Cylinder Assembly Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install new O-ring (2) to brake master cylinder (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410026.swf" width = "88.000mm" height = "46.292mm" ver = "01" gw = "137" gh = "115"/>
</figure>
</s1>
<s1>
<ptxt>
Install brake master cylinder to brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
Tighten brake master cylinder fixing nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A004">
<t-part>
Brake master cylinder fixing nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
18
</t-value1>
<t-value2>
1.8
</t-value2>
<t-value3>
13.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect brake pipes (1) to brake master cylinder and tighten flare nuts to specified torque using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A003">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T4A005">
<t-part>
Brake pipe flare nut (M12)
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1.9
</t-value2>
<t-value3>
14.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A410008.swf" width = "88.000mm" height = "119.074mm" ver = "01" gw = "168" gh = "321"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.273in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.772in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.273in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.772in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
LHD
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
RHD
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
For M/T model, connect clutch reservoir hose to reservoir.
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Connect brake fluid level switch connector.
</ptxt>
</s1>
<s1>
<ptxt>
For LHD, install battery tray and battery. 
<intxreftitleoff1 refid = "AENBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
After installation, bleed brake system. 
<intxreftitleoff1 refid = "AENBP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check installed parts for brake fluid leakage.
</ptxt>
</s1>
<s1>
<ptxt>
Check brake pedal for play. 
<intxreftitleoff1 refid = "AENBP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Make sure that brake system operates properly without fluid leakage.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
