<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
High Mount Stop Light Removal and Installation
</title>
<servinfosub id = "AENBP70A9206010001">
<title>
Removal
</title>
<attention3>
<ptxt>
High mount stoplight bulb is LED.
</ptxt>
<ptxt>
High mount stoplight bulbs an integral part of high mount stoplight assembly. Replace high mount stoplight assembly if high mount stoplight bulb is defective.
</ptxt>
</attention3>
<s1>
<ptxt>
Remove rear spoiler. 
<intxreftitleoff1 refid = "AENBP70A9806015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove high mount stop light screws (1), and then remove high mount stop light (2).
</ptxt>
<figure>
<graphic graphicname = "IBP60B920014.swf" width = "88.000mm" height = "50.694mm" ver = "01" gw = "226" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect high mount stop light connector (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B920015.swf" width = "88.000mm" height = "50.065mm" ver = "01" gw = "226" gh = "125"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9206010002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
