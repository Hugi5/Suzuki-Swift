<servinfosub id = "AENBP70A9204014003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Park vehicle on level surface and set ignition OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Run engine at idle speed for 10 sec. or more.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9204014004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A9204014005">
<testgroup id = "AENBP70A9204014006">
<title>
DTC check
</title>
<test1>
<ptxt>
Clear DTC. 
<intxreftitleoff1 refid = "AENBP70A9204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Perform “DTC Confirmation Procedure” and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9204002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1956 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A9204014007">
<title>
Rear vehicle height sensor circuit check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G14” and “L37” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connections to “G14” and “L37” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check “A1”, “A2” and “A3” circuit between “G14” connector and “L37” connector for open circuit, short to ground or short to power supply.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective harness and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9204002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A9204014008">
<title>
Rear vehicle height sensor check
</title>
<test1>
<ptxt>
Check rear vehicle height sensor. 
<intxreftitleoff1 refid = "AENBP70A9206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace headlight auto leveling and washer control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace rear vehicle height sensor and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
