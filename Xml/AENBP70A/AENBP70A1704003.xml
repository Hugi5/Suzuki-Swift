<servinfosub id = "AENBP70A1704003002">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENBP70A1704003003">
<testgroup id = "AENBP70A1704003004">
<title>
Fuel injector check for operating sound
</title>
<test1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENBP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Using sound scope, check each fuel injector for operating sound at engine cranking.
</ptxt>
</test1>
<question>
Do all fuel injectors make operating sound?
</question>
<result type = "yes"/>
<action>
<ptxt>
Fuel injectors circuit is in good condition.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1704003005">
<title>
Fuel injector resistance check
</title>
<test1>
<ptxt>
When ignition is OFF, disconnect connectors from fuel injectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to fuel injector connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If OK, check all fuel injectors for resistance. 
<intxreftitleoff1 refid = "AENBP70A1706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace fuel injector. 
<intxreftitleoff1 refid = "AENBP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1704003006">
<title>
Fuel injector insulation resistance check
</title>
<test1>
<ptxt>
Check that resistance between each fuel injector terminal and ground is infinity.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace fuel injector. 
<intxreftitleoff1 refid = "AENBP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1704003007">
<title>
Fuel injector power supply circuit check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between each of “A2”, “B2”, “C2” and “D2” and ground is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Repair fuel injector power supply circuit.
</ptxt>
<ptxt>
If it is in good condition, go to 
<intxref refid = "AENBP70A1104068">ECM Power Supply and Ground Circuit Check</intxref>
.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AENBP70A1704003008">
<title>
Fuel injector drive circuit check
</title>
<test1>
<ptxt>
When ignition is OFF, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1”, “B1”, “C1” and “D1”: less than 3 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A1”, “B1”, “C1” and “D1” circuits and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A1” circuit terminal and other terminal at fuel injector connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “B1” circuit terminal and other terminal at fuel injector connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “C1” circuit terminal and other terminal at fuel injector connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “D1” circuit terminal and other terminal at fuel injector connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A1” – “D1” circuits: 0 – 1 V (when ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair fuel injector drive circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1704003009">
<title>
Fuel injector check
</title>
<test1>
<ptxt>
Check fuel injector. 
<intxreftitleoff1 refid = "AENBP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace fuel injector. 
<intxreftitleoff1 refid = "AENBP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
