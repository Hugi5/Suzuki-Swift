<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9506007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Inner Rear View Mirror Removal and Installation
</title>
<servinfosub id = "AENBP70A9506007001">
<title>
Removal
</title>
<ptxt>
Remove inner rear view mirror bolt (TORX<sup>®</sup> T20) (1) and slide mirror (2) in arrow direction.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950021.swf" width = "88.000mm" height = "49.005mm" ver = "01" gw = "227" gh = "122"/>
</figure>
</servinfosub>
<servinfosub id = "AENBP70A9506007002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten inner rear view mirror bolt to specified torque.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9E001">
<t-part>
Inner rear view mirror bolt
</t-part>
<t-value1>
3.5
</t-value1>
<t-value2>
0.36
</t-value2>
<t-value3>
2.5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
