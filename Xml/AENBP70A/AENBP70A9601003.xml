<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "1">
<servinfo servinfosgmlid = "AENBP70A9601003" svcinfotypenbr = "03" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Power Door Lock Operation Description
</title>
<ptxt>
Locking / unlocking of doors is conducted by operation of the items shown in the following table.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Market codes E06, E24 and E30
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.888in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.271in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Item
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Activated door lock(s)
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Remote controller
</ptxt>
</entry>
<entry colname = "2" morerows = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
All doors
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Door request switch
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Power door lock switch (Driver side)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Key cylinder
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Door lock lever
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Operated each door
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Market codes E05, E10, E35, E38, E43, E71 and E96
</title>
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.799in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.799in"/>
<colspec colnum = "4" colname = "4" colwidth = "4.271in"/>
<thead>
<row rowsep = "1">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Item
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Activated door lock(s)
</ptxt>
</entry>
</row>
</thead>
<tbody valign = "middle">
<row rowsep = "1">
<entry namest = "1" nameend = "3" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Remote controller
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Push the LOCK button once and all doors are locked
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Push the UNLOCK button once and driver side door is unlocked
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Push the UNLOCK button twice and all doors are unlocked
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Door request switch
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Operation
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Lock
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Push the request switch once and all doors are locked
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "3" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Unlock
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Push the request switch once and operated door is unlocked
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Push the request switch twice and all doors are unlocked
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Power door lock switch (Driver side)
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
All doors
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "3" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Key cylinder
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Turn the key cylinder to LOCK position once and all doors are locked
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Turn the key cylinder to UNLOCK position once and driver side door is unlocked
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Turn the key cylinder to UNLOCK position twice and all doors are unlocked
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Door lock lever
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Operated each door
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
