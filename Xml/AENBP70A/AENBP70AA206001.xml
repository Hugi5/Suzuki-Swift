<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70AA206001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
BCM Removal and Installation
</title>
<servinfosub id = "AENBP70AA206001001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENBP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering column hole cover referring to Step 4) of 
<intxref refid = "AENBP70A6206009">Steering Column Removal and Installation</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove dash side trim. 
<intxreftitleoff1 refid = "AENBP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connectors (1) and clamps from J/B (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove nuts (3), and then remove J/B.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20016.jpg" width = "88.000mm" height = "78.207mm" ver = "01" gw = "202" gh = "205"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect connectors (1) from BCM (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove nuts (3), and then remove BCM.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20017.jpg" width = "88.000mm" height = "82.962mm" ver = "01" gw = "198" gh = "219"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70AA206001002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
</servinfosub>
<list1 type = "unordered">
<item>
<ptxt>
Tighten BCM nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T10B001">
<t-part>
BCM nut
</t-part>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Enable air bag system. 
<intxreftitleoff1 refid = "AENBP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
