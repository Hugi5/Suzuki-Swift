<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9F06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Steering Switch Removal and Installation
</title>
<servinfosub id = "AENBP70A9F06006001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove steering wheel referring to 
<intxref refid = "AENBP70A6206002">Steering Wheel Removal and Installation</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove 3 screws and disconnect connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering wheel cover (2) and hands-free switch (3) (if equipped) from steering wheel.
</ptxt>
</s1>
<s1>
<ptxt>
Remove audio control switch (4) and cruise control switch (5) (if equipped) from steering wheel.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IBP60B9F0007.jpg" width = "88.000mm" height = "67.943mm" ver = "01" gw = "232" gh = "176"/>
</figure>
</servinfosub>
<servinfosub id = "AENBP70A9F06006002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A9F06007">Steering Switch (Audio Control Switch and Hands-Free Switch) Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
