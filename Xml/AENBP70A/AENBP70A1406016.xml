<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1406016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Timing Chain Cover Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1406015">Timing Chain Cover Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A1406016001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove engine assembly from vehicle. 
<intxreftitleoff1 refid = "AENBP70A1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump / generator drive belt. 
<intxreftitleoff1 refid = "AENBP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove crankshaft pulley bolt (1).
</ptxt>
<ptxt>
To lock crankshaft pulley (2), use special tool as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D010">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917–68221
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IBP60B140081.jpg" width = "88.000mm" height = "67.946mm" ver = "02" gw = "146" gh = "176"/>
</figure>
</s1>
<s1>
<ptxt>
Remove crankshaft pulley (1).
</ptxt>
<ptxt>
If it can not be removed by hand, use special tools as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D011">
<s-part>
(A)
</s-part>
<s-number num = "09944-36011">
09944–36011
</s-number>
</servicetoolitem>
<servicetoolitem id = "L1D012">
<s-part>
(B)
</s-part>
<s-number num = "09926-58010">
09926–58010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B140052.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "170" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Remove cylinder head cover. 
<intxreftitleoff1 refid = "AENBP70A1406012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil pan. 
<intxreftitleoff1 refid = "AENBP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump pulley.
</ptxt>
</s1>
<s1>
<ptxt>
Remove compressor bracket from cylinder block and timing chain cover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil gallery pipes No.2 (1) and No.3 (2).
</ptxt>
<figure>
<graphic graphicname = "I3RH0B140021.swf" width = "88.000mm" height = "46.515mm" ver = "01" gw = "113" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Remove water outlet cap (1) and oil cooler water pipe (2) from timing chain cover (3).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140038.jpg" width = "88.000mm" height = "45.424mm" ver = "01" gw = "186" gh = "112"/>
</figure>
</s1>
<s1>
<ptxt>
Remove timing chain cover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove OCV from timing chain cover. 
<intxreftitleoff1 refid = "AENBP70A1406018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil pump from timing chain cover. 
<intxreftitleoff1 refid = "AENBP70A1506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1406016002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1406017">Timing Chain Cover Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Clean sealing surface of timing chain cover, cylinder block and cylinder head.
</ptxt>
<ptxt>
Remove oil, old sealant and dust from sealing surface.
</ptxt>
</s1>
<s1>
<ptxt>
Install oil pump to timing chain cover. 
<intxreftitleoff1 refid = "AENBP70A1506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check oil seal (1) lip for fault or other damage.
</ptxt>
<ptxt>
Replace oil seal, if necessary.
</ptxt>
<attention3>
<ptxt>
When installing new oil seal, press-fit to timing chain cover (2) using special tool as shown in figure.
</ptxt>
</attention3>
<spec>
<title>
Depth
</title>
<ptxt>
“a”: 0.5 – 1.0 mm (0.020 – 0.039 in.)
</ptxt>
</spec>
<servicetool>
<servicetoolitem id = "L1D013">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913–75810
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B140058.swf" width = "88.000mm" height = "55.022mm" ver = "01" gw = "182" gh = "139"/>
</figure>
</s1>
<s1>
<ptxt>
Install OCV and new OCV gasket to timing chain cover. 
<intxreftitleoff1 refid = "AENBP70A1406018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Apply sealant “A” to mating surface of cylinder block and cylinder head as shown in figure.
</ptxt>
</s1>
<s1>
<ptxt>
Apply sealant “B” to mating surface of timing chain cover as shown in figure.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207B" id = "M1D004" uid = "29">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31140
</m-number>
<m-name>
SUZUKI Bond No.1207B
</m-name>
<ptxt>
</ptxt>
</materialitem>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1D005" uid = "-491504098">
<m-part>
“B”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<spec>
<title>
Sealant amount for timing chain cover
</title>
<ptxt>
Width “a”: 3 mm (0.12 in.)
</ptxt>
<ptxt>
Height “b”: 2 mm (0.08 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I3RH0B140025.swf" width = "88.000mm" height = "101.504mm" ver = "01" gw = "198" gh = "271"/>
</figure>
</s1>
<s1>
<ptxt>
Apply engine oil to new O-rings (1) and then install O-rings to rotor plate (2).
</ptxt>
</s1>
<s1>
<ptxt>
Confirm that dowel pins (3) are installed to timing chain cover (4).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140039.jpg" width = "88.000mm" height = "53.258mm" ver = "01" gw = "221" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Apply engine oil to oil seal lip and then install timing chain cover.
</ptxt>
</s1>
<s1>
<ptxt>
Install new water outlet cap No.1 O-ring (1) and new water outlet cap No.2 O-ring (2) to water outlet cap (3) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IBP60B140085.jpg" width = "88.000mm" height = "48.926mm" ver = "01" gw = "96" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Install new O-ring (1) to oil cooler water pipe (2).
</ptxt>
</s1>
<s1>
<ptxt>
Install water outlet cap (3) and oil cooler water pipe to timing chain cover (4).
</ptxt>
<figure>
<graphic graphicname = "IBP60B140070.jpg" width = "88.000mm" height = "50.365mm" ver = "03" gw = "214" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten water outlet cap bolts, timing chain cover bolts and nut in numerical order (“1” – “18”) evenly and gradually to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D015">
<t-part>
Timing chain cover bolt*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D016">
<t-part>
Timing chain cover nut*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D017">
<t-part>
Water outlet cap bolt*
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B140040.jpg" width = "88.000mm" height = "69.651mm" ver = "02" gw = "174" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Apply engine oil to new O-ring (1) and then install O-ring to oil gallery pipes No.2 (2) and No.3 (3).
</ptxt>
</s1>
<s1>
<ptxt>
Install oil gallery pipes No.2 and No.3 to cylinder head (4) and timing chain cover (5).
</ptxt>
<ptxt>
Tighten oil gallery pipe No.2 bolts and oil gallery pipe No.3 bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D018">
<t-part>
Oil gallery pipe No.2 bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
<torqueitem id = "T1D019">
<t-part>
Oil gallery pipe No.3 bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B140071.swf" width = "88.000mm" height = "52.057mm" ver = "01" gw = "106" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Install compressor bracket. 
<intxreftitleoff1 refid = "AENBP70A7206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install water pump pulley. 
<intxreftitleoff1 refid = "AENBP70A1606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install cylinder head cover. 
<intxreftitleoff1 refid = "AENBP70A1406012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install oil pan. 
<intxreftitleoff1 refid = "AENBP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install crankshaft pulley (1). Tighten crankshaft pulley bolt (2) to specified torque. To lock crankshaft pulley, use special tool as shown in figure.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D014">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917–68221
</s-number>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T1D020">
<t-part>
Crankshaft pulley bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
150
</t-value1>
<t-value2>
15.3
</t-value2>
<t-value3>
111.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B140082.jpg" width = "88.000mm" height = "67.946mm" ver = "02" gw = "146" gh = "176"/>
</figure>
</s1>
<s1>
<ptxt>
Install water pump / generator drive belt. 
<intxreftitleoff1 refid = "AENBP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install engine assembly to vehicle. 
<intxreftitleoff1 refid = "AENBP70A1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
