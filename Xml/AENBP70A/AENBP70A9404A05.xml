<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A9404A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Washer malfunctions
</title>
<servinfosub id = "AENBP70A9404003005">
<title>
Headlight Washer
</title>
<diag type = "condition">
<condition>
<ptxt>
Washer malfunctions
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Replace fuse and check for short circuit.
</ptxt>
</action>
<ps>
<ptxt>
Faulty washer hose (including connector) or nozzle.
</ptxt>
</ps>
<action>
<ptxt>
Check washer hose or nozzle for clogging and bend.
</ptxt>
</action>
<ps>
<ptxt>
Faulty headlight washer switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A9406011">Headlight Washer Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiper and washer switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A9406013">Wiper and Washer Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty headlight washer pump
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A9406003">Washer Pump Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair circuit.
</ptxt>
</action>
<ps>
<ptxt>
Faulty headlight auto leveling and washer control module
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENBP70A9204009">Inspection of Headlight Auto Leveling and Washer Control Module and Its Circuit</intxref>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
