<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A8206001" svcinfotypenbr = "08" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
Disabling Air Bag System
</title>
<ptxt>
When servicing air bag system, related parts and working around air bag (inflator) module, disable air bag (inflator) modules as follows.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.597in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.597in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Servicing item
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Disabling procedure
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
When disconnecting or connecting air bag system connectors.
</ptxt>
</item>
<item>
<ptxt>
When removing or installing air bag system components.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Disconnect negative (–) cable at battery. 
<intxreftitleoff1 refid = "AENBP70A8206001001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
When servicing air bag system, related parts or working around air bag (inflator) module with ignition OFF.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
When servicing air bag system, related parts or working around air bag (inflator) module with ignition ON.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Remove “A/B” fuse. 
<intxreftitleoff1 refid = "AENBP70A8206001002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
When performing electric welding.
</ptxt>
</item>
<item>
<ptxt>
When there is a possibility that air bag system or related parts would be heated up with 93 &#176;C (200 &#176;F) and more by electric welding or paint baking process.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Disconnect negative (–) cable at battery, and remove all air bag (inflator) modules. 
<intxreftitleoff1 refid = "AENBP70A8206001003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<servinfosub id = "AENBP70A8206001001">
<title>
Disabling Procedure (Disconnecting Negative (–) Battery Cable)
</title>
<s1>
<ptxt>
Set front wheels in straight-ahead position.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Wait for at least 90 seconds after performing Step 3), and then start working. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A8206001002">
<title>
Disabling Procedure (Removing “A/B” Fuse)
</title>
<attention3>
<ptxt>
AIR BAG warning light will light if “A/B” fuse is disconnected, but this is normal and DTC for air bag system will not be detected.
</ptxt>
</attention3>
<s1>
<ptxt>
Set ignition OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Remove “A/B” fuse from J/B.
</ptxt>
</s1>
<s1>
<ptxt>
Wait for at least 90 seconds after performing Step 2).
</ptxt>
</s1>
<s1>
<ptxt>
Start working and change ignition mode to ON.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A8206001003">
<title>
Disabling Procedure (Disconnecting Negative (–) Battery Cable and Removing All Air Bag (Inflator) Modules)
</title>
<s1>
<ptxt>
Set front wheels in straight-ahead position.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition OFF.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Wait for at least 90 seconds after performing Step 3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove all air bag (inflator) modules and start working after.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
