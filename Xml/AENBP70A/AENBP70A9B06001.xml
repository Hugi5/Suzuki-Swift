<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9B06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Hood Lock Member, Lamp Support Member and Lamp Support Brace Removal and Installation
</title>
<attention3>
<ptxt>
The figure below shows condition where following parts are removed.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front fender 
<intxreftitleoff1 refid = "AENBP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "IAP70P9B0057.jpg" width = "88.000mm" height = "55.699mm" ver = "01" gw = "227" gh = "141"/>
</figure>
<servinfosub id = "AENBP70A9B06001001">
<title>
General Notes
</title>
<ptxt>
Welding method and number of welding points are the same on both sides. This repair instruction shows procedure for left side.
</ptxt>
</servinfosub>
<servinfosub id = "AENBP70A9B06001002">
<title>
Removal
</title>
<s1>
<ptxt>
Unscrew 12 bolts.
</ptxt>
</s1>
<s1>
<ptxt>
Remove hood lock member and lamp support member.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0003.jpg" width = "183.000mm" height = "157.046mm" ver = "02" gw = "347" gh = "429"/>
</figure>
</s1>
<s1>
<ptxt>
Drill out welding spots and remove lamp support brace.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0022.jpg" width = "183.000mm" height = "123.642mm" ver = "02" gw = "497" gh = "334"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9B06001003">
<title>
Installation
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Before conducting any weld, check installation position and condition for installation part(s). 
<intxreftitleoff1 refid = "AENBP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Proceed repair while taking into consideration installation of parts that affect appearance. 
<intxreftitleoff1 refid = "AENBP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Install lamp support brace.
</ptxt>
</s1>
<s1>
<ptxt>
Conduct resistance spot weld or plug weld.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0023.jpg" width = "183.000mm" height = "123.642mm" ver = "02" gw = "497" gh = "334"/>
</figure>
</s1>
<s1>
<ptxt>
Install hood lock member.
</ptxt>
</s1>
<s1>
<ptxt>
Tighten 4 bolts to specified torque.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0006.jpg" width = "183.000mm" height = "154.844mm" ver = "04" gw = "364" gh = "422"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.465in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
23 N&#183;m (2.3 kgf-m, 17.0 lbf-ft)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Apply painting and coatings to repaired or replace parts.
</ptxt>
</s1>
<s1>
<ptxt>
Install painted lamp support member.
</ptxt>
</s1>
<s1>
<ptxt>
Tighten 6 bolts to specified torque.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0024.jpg" width = "183.000mm" height = "81.918mm" ver = "02" gw = "511" gh = "216"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.465in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
8.8 N&#183;m (0.90 kgf-m, 6.5 lbf-ft)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
