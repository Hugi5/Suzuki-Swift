<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A7204028" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1580 / B1902
</title>
<servinfosub id = "AENBP70A7204028001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.922in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.288in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1580: EEPROM Error
</emph>
</ptxt>
<ptxt>
EEPROM error has occurred in HVAC control module.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
HVAC control module
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1902: Control Module Programming Error
</emph>
</ptxt>
<ptxt>
Error has occurred to program in HVAC control module.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENBP70A7204028002">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Start engine and operate A/C system.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A7204028003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A7204028004">
<testgroup id = "AENBP70A7204028005">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON and check DTC.
</ptxt>
</test1>
<question>
Is DTC B1580 or B1902 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace HVAC control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A7206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
