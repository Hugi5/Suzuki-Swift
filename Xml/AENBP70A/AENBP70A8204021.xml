<servinfosub id = "AENBP70A8204021003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A8204021004">
<testgroup id = "AENBP70A8204021005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204021006">
<title>
Instrument panel harness circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G347” or “G374” and “G11” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector inserting release tool included in special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voltage between each of “A1” and “A2” circuits and ground: 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B014">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820053.swf" width = "90.000mm" height = "57.786mm" ver = "02" gw = "207" gh = "147"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A8204021007">
<title>
Contact coil circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Connect “G347” or “G374” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Remove driver air bag (inflator) module from steering column. 
<intxreftitleoff1 refid = "AENBP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector inserting release tool included in special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voltage between each of “A1” and “A2” circuits and ground: 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B015">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820053.swf" width = "90.000mm" height = "57.786mm" ver = "02" gw = "207" gh = "147"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace contact coil assembly. 
<intxreftitleoff1 refid = "AENBP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs, referring to 
<intxref refid = "AENBP70A8204006">DTC Clearance</intxref>
 if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENBP70A8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
