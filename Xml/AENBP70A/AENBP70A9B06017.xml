<title>
Removal
</title>
<s1>
<ptxt>
Drill out welding spots.
</ptxt>
</s1>
<s1>
<ptxt>
Unscrew 4 bolts and remove back panel.
</ptxt>
<figure>
<graphic graphicname = "IBP70A9B0004.jpg" width = "183.000mm" height = "159.679mm" ver = "01" gw = "492" gh = "436"/>
</figure>
