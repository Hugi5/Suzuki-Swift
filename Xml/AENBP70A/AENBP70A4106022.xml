<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Brake Booster Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A4106020">Brake Booster Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A4106022001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect brake pipes (1) from ESP<sup>®</sup> hydraulic unit/control module assembly (2) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410035.swf" width = "88.000mm" height = "45.139mm" ver = "02" gw = "117" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Remove brake master cylinder assembly from brake booster. 
<intxreftitleoff1 refid = "AENBP70A4106017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For RHD, remove intake manifold. 
<intxreftitleoff1 refid = "AENBP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For RHD, disconnect brake pipe (1) from ESP® hydraulic unit/control module assembly using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
For RHD, remove brake pipe (1) from clamp (2).
</ptxt>
</s1>
<s1>
<ptxt>
For RHD, remove suction hose bracket bolt (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A410003.jpg" width = "88.000mm" height = "64.759mm" ver = "01" gw = "207" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect vacuum hose from brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
Remove clip (1) and push rod clevis pin (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410036.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Remove brake booster nuts (1) to remove brake booster from dash panel.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410037.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A4106022002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A4106023">Brake Booster Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Remove combination meter cluster panel. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Loosen brake pedal bracket nut (1) and cowl upper stiffener bolt (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Install brake booster to dash panel. Then connect push rod clevis (3) to pedal arm with clevis pin (2) and clip (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410040.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten brake booster nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A006">
<t-part>
Brake booster nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410041.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten brake pedal bracket nut to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
Brake pedal bracket nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Tighten cowl upper stiffener bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
Cowl upper stiffener bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410042.swf" width = "88.000mm" height = "64.412mm" ver = "02" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Install combination meter panel. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect vacuum hose to brake booster.
</ptxt>
</s1>
<s1>
<ptxt>
For RHD, install suction hose bracket bolt (3).
</ptxt>
</s1>
<s1>
<ptxt>
For RHD, connect brake pipe (1) to clamp (2).
</ptxt>
</s1>
<s1>
<ptxt>
For RHD, connect brake pipe (1) to ESP<sup>&#174;</sup> hydraulic unit/control module assembly and tighten brake pipe flare nut to specified torque using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A014">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T4A009">
<t-part>
Brake pipe flare nut (M10)
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1.6
</t-value2>
<t-value3>
12.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A410004.jpg" width = "88.000mm" height = "64.759mm" ver = "01" gw = "208" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
For RHD, install intake manifold. 
<intxreftitleoff1 refid = "AENBP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install brake master cylinder assembly to brake booster. 
<intxreftitleoff1 refid = "AENBP70A4106017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect brake pipes (1) to ESP<sup>®</sup> hydraulic unit/control module assembly (2) using special tool.
</ptxt>
<torque>
<torqueitem id = "T4A010">
<t-part>
Brake pipe flare nut (M12)
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1.9
</t-value2>
<t-value3>
14.0
</t-value3>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A015">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410043.swf" width = "88.000mm" height = "46.684mm" ver = "02" gw = "119" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
After installation, bleed brake system. 
<intxreftitleoff1 refid = "AENBP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check installed parts for brake fluid leakage.
</ptxt>
</s1>
<s1>
<ptxt>
Check brake pedal for play. 
<intxreftitleoff1 refid = "AENBP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Make sure that brake system operates properly without brake fluid leakage.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
