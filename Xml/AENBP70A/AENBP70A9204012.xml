<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENBP70A9204012" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1950
</title>
<servinfosub id = "AENBP70A9204012001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.194in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.010in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1950: Control Module Programming Error
</emph>
</ptxt>
<ptxt>
Headlight auto leveling and washer control module internal failure.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Headlight auto leveling and washer control module
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENBP70A9204012002">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Be sure to troubleshoot first unexpected DTCs previously detected in “DTC Confirmation Procedure”.
</ptxt>
</attention3>
<s1>
<ptxt>
Set ignition ON.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9204012003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A9204012004">
<testgroup id = "AENBP70A9204012005">
<title>
DTC check
</title>
<test1>
<ptxt>
Clear DTC. 
<intxreftitleoff1 refid = "AENBP70A9204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Perform “DTC Confirmation Procedure” and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9204002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1950 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace Headlight auto leveling and washer control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A9206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
