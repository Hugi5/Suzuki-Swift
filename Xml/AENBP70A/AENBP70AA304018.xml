<servinfosub id = "AENBP70AA304018003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Run engine at idle speed for 10 seconds or more.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70AA304018004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70AA304018005">
<testgroup id = "AENBP70AA304018006">
<title>
Engine switch signal circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G140” and “G28” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “G140” and “G28” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1”, “A2”, “A3” and “A4” circuits: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A1”, “A2”, “A3” and “A4” circuits and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between circuit terminal and other terminals at “G140” connector: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA304018007">
<title>
DTC check
</title>
<test1>
<ptxt>
Replace engine switch. 
<intxreftitleoff1 refid = "AENBP70AA506016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Perform 
<intxref refid = "AENBP70AA304018003">DTC Confirmation Procedure</intxref>
 and then recheck DTC. 
<intxreftitleoff1 refid = "AENBP70AA304003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1189 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70AA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Engine switch was faulty)
</ptxt>
</action>
</testgroup>
</diag>
