<servinfosub id = "AENBP70A1406029004" page = "2">
<title>
Valve
</title>
<topic id = "AENBP70A1406029005">
<title>
Visual inspection
</title>
<list1 type = "unordered">
<item>
<ptxt>
Remove all carbon deposits from valve (1).
</ptxt>
</item>
<item>
<ptxt>
Check each valve for wear, burn or distortion at its face and valve stem and, if necessary, replace it.
</ptxt>
</item>
<item>
<ptxt>
Measure valve protrusion length “a”.
</ptxt>
<ptxt>
If measured length is out of standard value, replace valve.
</ptxt>
<spec>
<title>
Valve protrusion length “a” Standard
</title>
<ptxt>
IN: 36.78 – 37.38 mm (1.449 – 1.471 in.)
</ptxt>
<ptxt>
EX: 36.68 – 37.28 mm (1.445 – 1.467 in.)
</ptxt>
<figure>
<graphic graphicname = "I9T401142024.swf" width = "88.000mm" height = "77.883mm" ver = "01" gw = "162" gh = "204"/>
