<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A9B06021" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Roof Panel Removal and Installation
</title>
<attention3>
<ptxt>
The figure below shows condition where following parts are removed.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front fender 
<intxreftitleoff1 refid = "AENBP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0181.jpg" width = "88.000mm" height = "55.869mm" ver = "02" gw = "227" gh = "142"/>
</figure>
<servinfosub id = "AENBP70A9B06021001">
<title>
General Notes
</title>
<ptxt>
Roof carrier brackets are to be reused.
</ptxt>
</servinfosub>
<servinfosub id = "AENBP70A9B06021002">
<title>
Removal
</title>
<s1>
<ptxt>
Drill out welding spots and remove 4 roof carrier brackets and roof panel.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IBP70A9B0011.jpg" width = "183.000mm" height = "114.204mm" ver = "01" gw = "467" gh = "307"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.472in"/>
<colspec colnum = "2" colname = "2" colwidth = "6.422in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
When heating around sealer application portion to detach body sealer, be sure that temperature of said portion does not reach 170 &#176;C (338 &#176;F).
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
<servinfosub id = "AENBP70A9B06021003">
<title>
Installation
</title>
<attention3>
<ptxt>
Before conducting any weld, check installation position and condition for installation part(s). 
<intxreftitleoff1 refid = "AENBP70A9B04005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AENBP70A9B04008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1>
<ptxt>
Conduct tack welding to roof panel center No. 2 member, roof panel center No. 3 member and roof panel center No.4 member.
</ptxt>
</s1>
<s1>
<ptxt>
Apply body sealer to roof front inner rail, roof panel center No. 2 member, roof panel center No.1 member, roof panel center No.3 member, roof panel center No.4 member and roof back inner member.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0054.jpg" width = "183.000mm" height = "114.204mm" ver = "03" gw = "426" gh = "307"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.596in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Applied part of body sealer.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install roof panel and 4 roof carrier brackets.
</ptxt>
</s1>
<s1>
<ptxt>
Conduct resistance spot weld.
</ptxt>
</s1>
<s1>
<ptxt>
Conduct plug weld.
</ptxt>
<figure>
<graphic graphicname = "IBP70A9B0012.jpg" width = "183.000mm" height = "161.593mm" ver = "01" gw = "460" gh = "442"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.083in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.510in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Conduct resistance spot weld as three panel thickness.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Punch mark
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
