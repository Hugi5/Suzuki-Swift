<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5506037" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Vehicle Speed Sensor Removal and Installation
</title>
<servinfosub id = "AENBP70A5506037001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from vehicle speed sensor.
</ptxt>
</s1>
<s1>
<ptxt>
Remove vehicle speed sensor (1) from transaxle.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A5506037002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5506038">Vehicle Speed Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply CVT fluid to new O-ring of vehicle speed sensor.
</ptxt>
</item>
<item>
<ptxt>
Tighten vehicle speed sensor bolt (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5E016">
<t-part>
Vehicle speed sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5.9
</t-value1>
<t-value2>
0.60
</t-value2>
<t-value3>
4.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP70A550085.swf" width = "88.000mm" height = "55.159mm" ver = "01" gw = "120" gh = "140"/>
</figure>
</item>
<item>
<ptxt>
Connect connector and fix wire harness with clamp securely.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
