<servinfosub id = "AENBP70A1104057003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
System voltage &#62; 8 V
</ptxt>
</item>
</list2>
<item>
<ptxt>
Confirm that the following DTCs are not detected in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
APP sensor (P2122, P2123, P2127 and P2128)
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Set ignition ON.
</ptxt>
</s1>
<s1>
<ptxt>
Keep accelerator pedal at fully depressed position for 2 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Release accelerator pedal for 2 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Step 2) through 3) 3 times.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1104057004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A1104057005">
<testgroup id = "AENBP70A1104057006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104057007">
<title>
Wire harness check
</title>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
“A1”, “A2” and “A3” circuits: Refer to Step 3 through 5 under 
<intxref refid = "AENBP70A1104054">DTC P2122 / P2123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
“B1”, “B2” and “B3” circuits: Refer to Step 3 through 5 under 
<intxref refid = "AENBP70A1104055">DTC P2127 / P2128</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104057008">
<title>
APP sensor check
</title>
<test1>
<ptxt>
Check APP sensor for performance. 
<intxreftitleoff1 refid = "AENBP70A1306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace accelerator pedal assembly.
</ptxt>
</action>
</testgroup>
</diag>
