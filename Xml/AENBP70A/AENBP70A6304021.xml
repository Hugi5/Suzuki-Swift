<servinfosub id = "AENBP70A6304021002">
<title>
Troubleshooting
</title>
<diag type = "test" id = "AENBP70A6304021003">
<testgroup id = "AENBP70A6304021004">
<title>
Circuit fuse check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “E13” and “G50” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to “G50-3” and “E13-1” terminals.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check “P/S” fuse and “IG1 SIG” fuse for blowing.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace fuse(s) and check for short to ground in circuits connected to fuse(s).
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304021005">
<title>
P/S control module power supply circuit check
</title>
<test1>
<ptxt>
Check voltage between “E13-1” terminal and ground.
</ptxt>
</test1>
<question>
Is voltage 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace “A1” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304021006">
<title>
IG1 power supply for P/S control module circuit check
</title>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check voltage between “G50-3” terminal and ground.
</ptxt>
</test1>
<question>
Is voltage 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace “A2” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A6304021007">
<title>
P/S control module ground circuit check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Check resistance between “E13-2” terminal and ground.
</ptxt>
</test1>
<question>
Is resistance 1 Ω or less?
</question>
<result type = "yes"/>
<action>
<ptxt>
End.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace “A3” circuit.
</ptxt>
</action>
</testgroup>
</diag>
