<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5506017" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Select Cable Adjustment
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5506015">Select Cable Removal and Installation</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENBP70A5506016">Select Cable Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Apply parking brake and block wheels.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition ON and shift select lever to N range.
</ptxt>
</s1>
<s1>
<ptxt>
Remove floor console front box. 
<intxreftitleoff1 refid = "AENBP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove adjuster case (cable end) from select lever pin of select lever assembly. 
<intxreftitleoff1 refid = "AENBP70A5506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Release lock plate (1) which restricts moving of lock piece (2).
</ptxt>
</s1>
<s1>
<ptxt>
Pull out lock piece (2) from adjuster case (3) using pliers or the like to disengage cable.
</ptxt>
<figure>
<graphic graphicname = "I8C50B510062.swf" width = "88.000mm" height = "69.832mm" ver = "01" gw = "146" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Check that neutral position of transmission range sensor is suitable position. 
<intxreftitleoff1 refid = "AENBP70A5506023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Shift select lever to N range.
</ptxt>
</s1>
<s1>
<ptxt>
Apply grease to select lever pin, and then install adjuster case into select lever pin securely.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5E001" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Push lock piece (1) in arrow direction [a] as shown in figure.
</ptxt>
</s1>
<s1>
<ptxt>
Slide lock plate (2) in arrow direction [b] as shown in figure, until it gets over the claw (3).
</ptxt>
<figure>
<graphic graphicname = "IBP70A550054.swf" width = "88.000mm" height = "87.312mm" ver = "01" gw = "232" gh = "231"/>
</figure>
</s1>
<s1>
<ptxt>
After installing select cable, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Perform 
<intxref refid = "AENBP70A5504008">P Range Test</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Check that back up light turns on when shifting select lever to R range.
</ptxt>
</item>
<item>
<ptxt>
Check that shift position indicated in information display is consistent with select lever range.
</ptxt>
</item>
<item>
<ptxt>
Check that engine starts in P and N ranges but does not start in other than P and N ranges.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Install floor console front box. 
<intxreftitleoff1 refid = "AENBP70A9806013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
