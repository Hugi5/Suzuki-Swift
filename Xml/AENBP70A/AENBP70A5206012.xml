<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5206012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Gear Shift and Select Shaft Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5206011">Gear Shift and Select Shaft Assembly Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENBP70A5206012001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove battery, battery tray and battery bracket with ECM. 
<intxreftitleoff1 refid = "AENBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect gear shift and gear select control cables from transaxle. 
<intxreftitleoff1 refid = "AENBP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove left side engine undercover.
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery ground bracket (1).
</ptxt>
<figure>
<graphic graphicname = "IBP60B520015.jpg" width = "88.000mm" height = "52.786mm" ver = "01" gw = "173" gh = "133"/>
</figure>
</s1>
<s1>
<ptxt>
Remove gear shift interlock bolt (1) and gear shift locating spring (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove gear shift &#38; select shaft assembly (3).
</ptxt>
<figure>
<graphic graphicname = "IAY301520022.jpg" width = "88.000mm" height = "55.074mm" ver = "01" gw = "180" gh = "140"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENBP70A5206012002">
<title>
Installation
</title>
<s1>
<ptxt>
Clean mating surface of guide case (1) and transaxle left case (5), apply sealant to transaxle left case as shown in figure. Diameter of applied sealant is 1.5 mm (0.059 in.).
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M5B003" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Mate guide case with transaxle left case.
</ptxt>
</s1>
<s1>
<ptxt>
Apply sealant to thread of guide case No.2 bolts (2), and then tighten guide case No.1 bolts (4) and guide case No.2 bolts to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M5B004" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<torque>
<torqueitem id = "T5B007">
<t-part>
Guide case No.1 bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
<torqueitem id = "T5B008">
<t-part>
Guide case No.2 bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Apply sealant to thread of gear shift interlock bolt (3) and gear shift locating spring (6), and then tighten them to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M5B005" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<torque>
<torqueitem id = "T5B009">
<t-part>
Gear shift inter lock bolt
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
<torqueitem id = "T5B010">
<t-part>
Gear shift locating spring
</t-part>
<t-part1>
d
</t-part1>
<t-value1>
28
</t-value1>
<t-value2>
2.9
</t-value2>
<t-value3>
21.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAY301520023.jpg" width = "88.000mm" height = "101.030mm" ver = "03" gw = "182" gh = "270"/>
</figure>
</s1>
<s1>
<ptxt>
Install battery ground bracket (1) and then tighten battery ground bracket bolt (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5B011">
<t-part>
Battery ground bracket bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IBP60B520016.jpg" width = "88.000mm" height = "52.786mm" ver = "02" gw = "183" gh = "133"/>
</figure>
</s1>
<s1>
<ptxt>
Connect gear shift and gear select control cables to transaxle.
</ptxt>
</s1>
<s1>
<ptxt>
Install battery bracket, battery tray and battery with ECM. 
<intxreftitleoff1 refid = "AENBP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
