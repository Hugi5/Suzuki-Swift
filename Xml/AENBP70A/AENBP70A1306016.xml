<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1306016" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
CKP Sensor Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1306015">CKP Sensor Removal and Installation</intxrefpoff>
</ptxt>
<s1 page = "2">
<ptxt>
Remove CKP sensor. 
<intxreftitleoff1 refid = "AENBP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
O-ring (1) is free from damage.
</ptxt>
</item>
<item>
<ptxt>
End face of CKP sensor and sensor plate teeth are free from any metal particles and damage.
</ptxt>
<figure>
<graphic graphicname = "IBP60B130013.jpg" width = "88.000mm" height = "39.979mm" ver = "01" gw = "133" gh = "97"/>
</figure>
</item>
</list1>
</s1>
<c-change/>
<s1 page = "2">
<ptxt>
Check CKP sensor as follows.
</ptxt>
<ptxt>
If faulty condition is found, replace CKP sensor. 
<intxreftitleoff1 refid = "AENBP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<s2>
<ptxt>
Connect battery (1) and ohmmeter (3) to CKP sensor as shown in figure.
</ptxt>
</s2>
<s2>
<ptxt>
Check that CKP sensor resistance varies as specified below by passing ferromagnetic material (iron) (2).
</ptxt>
</s2>
<attention3>
<ptxt>
Be sure to keep approximately 1 mm (0.03 in) gap “a” between ferromagnetic material (iron) and end face of CKP sensor.
</ptxt>
</attention3>
<spec>
<title>
CKP sensor resistance
</title>
<ptxt>
Resistance alternates between 220 Ω or smaller and infinity.
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP60B130014.jpg" width = "88.000mm" height = "46.217mm" ver = "02" gw = "190" gh = "115"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
