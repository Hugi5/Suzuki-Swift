<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Differential Side Oil Seal Replacement
</title>
<s1>
<ptxt>
Hoist vehicle and drain transaxle oil. 
<intxreftitleoff1 refid = "AENBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove the following parts.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front drive shaft assembly: 
<intxreftitleoff1 refid = "AENBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Drive intermediate shaft assembly: 
<intxreftitleoff1 refid = "AENBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove oil seal (1) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913–50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A520006.swf" width = "88.000mm" height = "48.410mm" ver = "02" gw = "146" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Install new oil seal (1) to specified position using special tool.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
When installing oil seal, face its spring side inward.
</ptxt>
</item>
<item>
<ptxt>
Install oil seal exactly to the specified height.
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
09944–88220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09944-66010">
09944–66010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B004">
<s-part>
(C)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Distance from case surface to left oil seal
</title>
<ptxt>
“a”: 1.0 – 2.0 mm (0.04 – 0.07 in.)
</ptxt>
</spec>
<spec>
<title>
Distance from case surface to right oil seal
</title>
<ptxt>
“b”: 8.5 – 9.5 mm (0.34 – 0.37 in.)
</ptxt>
</spec>
</s1>
<c-change/>
<s1>
<ptxt>
Apply grease to oil seal lip and at the same time check smoothness of area where drive shaft contacts oil seal.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B001" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IBP60B520005.swf" width = "88.000mm" height = "51.231mm" ver = "01" gw = "219" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Install the following parts.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Front Drive Shaft: 
<intxreftitleoff1 refid = "AENBP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Drive intermediate shaft: 
<intxreftitleoff1 refid = "AENBP70A3116005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Pour transaxle oil. 
<intxreftitleoff1 refid = "AENBP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
