<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1306025" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Electric Load Current Sensor On-Vehicle Inspection
</title>
<servinfosub id = "AENBP70A1306025001">
<title>
Battery Current
</title>
<topic id = "AENBP70A1306025002">
<title>
Using SUZUKI scan tool
</title>
<s1>
<ptxt>
With ignition OFF, connect SUZUKI scan tool to DLC.
</ptxt>
<servicetool>
<servicetoolitem id = "L1C001">
<s-part>
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI scan tool (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Check that battery current value displayed on SUZUKI scan tool changes to values indicated below as electric load increases.
</ptxt>
<spec>
<title>
Battery current (Reference)
</title>
<ptxt>
Ignition ON: 2 to 8 A
</ptxt>
<ptxt>
Ignition ON and headlight ON: 10 to 24 A
</ptxt>
<ptxt>
Ignition ON, headlight ON and blower speed selector in MAX position: 24 to 33 A
</ptxt>
</spec>
<ptxt>
If check result is not satisfactory, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Electric load current sensor circuits (power, ground and output)
</ptxt>
</item>
<item>
<ptxt>
Battery negative (–) cable
</ptxt>
</item>
<item>
<ptxt>
Following charging system components
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Battery 
<intxreftitleoff1 refid = "AENBP70A1A04001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Generator 
<intxreftitleoff1 refid = "AENBP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Generator output circuit
</ptxt>
</item>
<item>
<ptxt>
Generator field coil measured signal circuit according to Step 2 under 
<intxref refid = "AENBP70A1104047">DTC P0622</intxref>
</ptxt>
</item>
<item>
<ptxt>
Generator control signal circuit according to Step 3 under 
<intxref refid = "AENBP70A1104046">DTC P0620</intxref>
</ptxt>
</item>
</list2>
</list1>
<ptxt>
If electric load current sensor circuits and charging system are in good condition, replace electric load current sensor (1).
</ptxt>
<figure>
<graphic graphicname = "IBP70A130003.jpg" width = "88.000mm" height = "63.997mm" ver = "01" gw = "199" gh = "165"/>
</figure>
</s1>
</topic>
<topic id = "AENBP70A1306025003">
<title>
Without using SUZUKI scan tool
</title>
<s1>
<ptxt>
With ignition OFF, disconnect electric load current sensor connector.
</ptxt>
</s1>
<s1>
<ptxt>
Using service wires (1), connect electric load current sensor (2) and electric load current sensor connector (3).
</ptxt>
</s1>
<s1>
<ptxt>
With ignition ON, check that voltage varies depending on electric load referring to 
<intxref refid = "AENBP70A1104067">Inspection of ECM and Its Circuits</intxref>
.
</ptxt>
<figure>
<graphic graphicname = "I9P60A131022.jpg" width = "88.000mm" height = "54.916mm" ver = "01" gw = "210" gh = "139"/>
</figure>
<ptxt>
If check result is not satisfactory, check the following parts and circuits.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Electric load current sensor circuits (power, ground and output)
</ptxt>
</item>
<item>
<ptxt>
Battery negative (–) cable
</ptxt>
</item>
<item>
<ptxt>
Following charging system components
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Battery 
<intxreftitleoff1 refid = "AENBP70A1A04001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Generator 
<intxreftitleoff1 refid = "AENBP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Generator output circuit
</ptxt>
</item>
<item>
<ptxt>
Generator field coil measured signal circuit according to Step 2 under 
<intxref refid = "AENBP70A1104047">DTC P0622</intxref>
</ptxt>
</item>
<item>
<ptxt>
Generator control signal circuit according to Step 3 under 
<intxref refid = "AENBP70A1104046">DTC P0620</intxref>
</ptxt>
</item>
</list2>
</list1>
<ptxt>
If electric load current sensor circuits and charging system are in good condition, replace electric load current sensor.
</ptxt>
</s1>
</topic>
</servinfosub>
<servinfosub id = "AENBP70A1306025004">
<title>
Temperature
</title>
<s1>
<ptxt>
With ignition OFF, disconnect electric load current sensor connector.
</ptxt>
</s1>
<s1>
<ptxt>
Connect ohmmeter to electric load current sensor (1) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IBP70A130004.jpg" width = "88.000mm" height = "63.997mm" ver = "01" gw = "219" gh = "165"/>
</figure>
</s1>
<s1>
<ptxt>
Check that resistance varies depending on battery temperature as indicated graph below.
</ptxt>
<ptxt>
If check result is not satisfactory, replace electric load current sensor.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I8C50B130012.swf" width = "88.000mm" height = "61.865mm" ver = "03" gw = "187" gh = "159"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.096in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.096in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Resistance
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[b]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Temperature
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
