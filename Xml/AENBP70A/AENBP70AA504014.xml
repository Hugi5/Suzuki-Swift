<servinfosub id = "AENBP70AA504014003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Drive vehicle at 10 km/h (6 mph) or more for 1 minute.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70AA504014004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70AA504014005">
<testgroup id = "AENBP70AA504014006">
<title>
Parameter check
</title>
<test1>
<ptxt>
Connect SUZUKI scan tool to DLC when ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON.
</ptxt>
</test1>
<test1>
<ptxt>
Check “P position / CPP 2 Switch” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENBP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504014007">
<title>
P position switch signal circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect select lever and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to select lever and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit terminal and each terminal at select lever connector: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504014008">
<title>
P position switch check
</title>
<test1>
<ptxt>
Check P position switch. 
<intxreftitleoff1 refid = "AENBP70A5506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace select lever. 
<intxreftitleoff1 refid = "AENBP70A5506009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70AA504014009">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Connect select lever and “L10” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition ON and shift select lever to each of P, N and P ranges.
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENBP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is current DTC B1126 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70AA506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
</testgroup>
</diag>
