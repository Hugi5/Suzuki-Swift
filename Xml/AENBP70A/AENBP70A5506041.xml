<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5E">
<servcat sctnbr = "05" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A5506041" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Slope Sensor Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A5506040">Slope Sensor Removal and Installation</intxrefpoff>
</ptxt>
<attention4>
<ptxt>
The slope sensor could not function if strong impact is applied.
</ptxt>
<ptxt>
Handle it with care so as not to drop it. Use hand tools instead of air tools when removing/installing it.
</ptxt>
</attention4>
<s1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
There is no abnormality with installation position or angle of slope sensor.
</ptxt>
</item>
<item>
<ptxt>
There is no deformation of TCM mounting bracket.
</ptxt>
</item>
<item>
<ptxt>
There is no foreign matter interposed between the TCM mounting bracket and slope sensor.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove slope sensor. 
<intxreftitleoff1 refid = "AENBP70A5506040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check slope sensor by the following procedure:
</ptxt>
<s2>
<ptxt>
Arrange 3 new 1.5 V batteries (1) in series, and check that total voltage is 4.5 to 5.0 V.
</ptxt>
</s2>
<s2>
<ptxt>
Connect voltmeter (2) and batteries to slope sensor (3) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IBP70A550090.jpg" width = "88.000mm" height = "80.117mm" ver = "02" gw = "200" gh = "211"/>
</figure>
</s2>
<s2>
<ptxt>
Check that voltage changes continuously without any skipping as shown in figure when the sensor connector side is gradually tilted in the direction of either [a] or [b] within the range shown by the arrows.
</ptxt>
</s2>
<attention3>
<ptxt>
The figure shows the sensor output voltage when 5.0 V is applied.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IBP70A550091.jpg" width = "88.000mm" height = "90.119mm" ver = "02" gw = "222" gh = "239"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.378in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.378in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Connector side is upward.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[c]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Sensor is on level surface.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[b]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Connector side is downward.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[d]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Slope sensor output voltage
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install slope sensor. 
<intxreftitleoff1 refid = "AENBP70A5506040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Perform 
<intxref refid = "AENBP70A5506042">Slope Sensor Calibration</intxref>
. 
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
