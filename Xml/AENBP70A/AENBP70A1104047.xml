<servinfosub id = "AENBP70A1104047003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Warm up engine to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Confirm that the following conditions are met.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Blower motor: OFF
</ptxt>
</item>
<item>
<ptxt>
Headlight: OFF
</ptxt>
</item>
<item>
<ptxt>
Rear defogger: OFF
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Keep engine running at idle for 5 min. and confirm that the following conditions are met.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Blower speed selector: Max position
</ptxt>
</item>
<item>
<ptxt>
Headlight: ON
</ptxt>
</item>
<item>
<ptxt>
Rear defogger: ON
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Keep engine speed at 4,000 rpm for 30 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A1104047004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENBP70A1104047005">
<testgroup id = "AENBP70A1104047006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENBP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104047007">
<title>
Generator field coil measured signal circuit check
</title>
<test1>
<ptxt>
With ignition OFF, disconnect “C01” and “E01” connectors of ECM and generator connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors and generator connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B1” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit terminal and other terminal at generator connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B1” circuit: approx. 0 V (When ignition is ON)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENBP70A1104047008">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Replace generator. 
<intxreftitleoff1 refid = "AENBP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC.
</ptxt>
</test1>
<question>
Is DTC P0622 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENBP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
