<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70AA506004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Keyless Start Control Module Removal and Installation
</title>
<servinfosub id = "AENBP70AA506004001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove glove box. 
<intxreftitleoff1 refid = "AENBP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For CVT model, remove TCM. 
<intxreftitleoff1 refid = "AENBP70A5506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect keyless start control module connectors (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove nuts (2), and then remove keyless start control module (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50022.swf" width = "88.000mm" height = "82.127mm" ver = "01" gw = "180" gh = "216"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70AA506004002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten keyless start control module nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T10E001">
<t-part>
keyless start control module nut
</t-part>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
If keyless start control module is replaced, perform 
<intxref refid = "AENBP70AA506002">Keyless Start Control Module Registration</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
