<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENBP70A1306024" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
OCV Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENBP70A1406018">OCV Removal and Installation</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Remove OCV. 
<intxreftitleoff1 refid = "AENBP70A1406018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check OCV as follows.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Check resistance between terminals of OCV connector (1).
</ptxt>
<ptxt>
If measured resistance is out of specified range, replace OCV (2). 
<intxreftitleoff1 refid = "AENBP70A1406018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<spec>
<title>
OCV resistance
</title>
<ptxt>
6.7 to 7.7 Ω at 20 &#176;C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IBP60B130021.swf" width = "88.000mm" height = "35.878mm" ver = "02" gw = "144" gh = "85"/>
</figure>
</item>
<item>
<ptxt>
Connect battery to OCV connector (1) as shown in figure, and check that operating sound caused by movement of spool valve (2).
</ptxt>
<ptxt>
If check result is not satisfactory, replace OCV. 
<intxreftitleoff1 refid = "AENBP70A1406018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "IBP60B130022.swf" width = "88.000mm" height = "50.097mm" ver = "01" gw = "221" gh = "125"/>
</figure>
</item>
</list2>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
