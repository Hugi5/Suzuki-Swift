<title>
Rear Fog Light Assembly Removal and Installation
</title>
<servinfosub id = "AENBP70A9206006001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect connector (1) and clamps (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear fog light nuts (3), and remove rear fog light assembly.
</ptxt>
<figure>
<graphic graphicname = "IBP70A920005.jpg" width = "88.000mm" height = "107.827mm" ver = "02" gw = "239" gh = "289"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENBP70A9206006002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
