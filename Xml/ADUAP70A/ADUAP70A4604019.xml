<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A4604019" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1024
</title>
<servinfosub id = "ADUAP70A4604019001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.328in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.861in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1024: Prestaties van het circuit van de stuurhoeksensor
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
De CPU in de stuurhoeksensor neemt een interne storing waar.
</ptxt>
</item>
<item>
<ptxt>
Het signaal van de stuurhoeksensor valt buiten het voorgeschreven bereik.
</ptxt>
</item>
<item>
<ptxt>
Signaal van de stuurhoeksensor wijzigt niet, hoewel het voertuig naar rechts of links draait.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Stuurhoeksensor
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup>-regelapparaat
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A4604019002">
<title>
DTC-storingzoeken
</title>
<attention2>
<ptxt>
Waarneming van zowel DTC C1024 als C1075 betekent een interne storing in de stuurhoeksensor. Vervang de stuurhoeksensor. 
<intxreftitleoff1 refid = "ADUAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention2>
<diag type = "test" id = "ADUAP70A4604019003">
<testgroup id = "ADUAP70A4604019004">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604019005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A4604005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Worden DTC U0073 en/of U0126 waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604019006">
<question>
Worden zowel DTC C1024 als C1075 waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de stuurhoeksensor. 
<intxreftitleoff1 refid = "ADUAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604019007">
<title>
Onderzoek in het voertuig van de stuurhoeksensor
</title>
<test1>
<ptxt>
Controleer de stuurhoeksensor. 
<intxreftitleoff1 refid = "ADUAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de stuurhoeksensor. 
<intxreftitleoff1 refid = "ADUAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
