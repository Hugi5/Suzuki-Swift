<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70AA506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de motorschakelaar
</title>
<servinfosub id = "ADUAP70AA506015001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het stuurkolomopeningsdeksel. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de motorschakelaaromlijsting. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de motorschakelaar uit de motorschakelaaromlijsting.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA506015002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70AA506016">Onderzoek van de motorschakelaar</intxrefpoff>
</ptxt>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
