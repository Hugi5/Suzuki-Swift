<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9706002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de voorstoel
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9706001">Componenten van de voorstoel</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A9706002001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Stel het airbagsysteem buiten werking. 
<intxreftitleoff1 refid = "ADUAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbindingen van de voorstoel los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de 4 montagebouten en verwijder daarna het stoelsamenstel.
</ptxt>
</s1>
<s1>
<ptxt>
Demonteer en repareer onderdelen indien nodig. 
<intxreftitleoff1 refid = "ADUAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9706002002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zie 
<intxref refid = "ADUAP70A9706001">Componenten van de voorstoel</intxref>
 voor het aanhaalkoppel.
</ptxt>
</item>
<item>
<ptxt>
Activeer het airbagsysteem. 
<intxreftitleoff1 refid = "ADUAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
