<servinfosub id = "ADUAP70AA104008003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70AA104008004">
<testgroup id = "ADUAP70AA104008005">
<title>
Controle van de parameter
</title>
<test1>
<ptxt>
Sluit het SUZUKI-uitleesapparaat op de DLC aan met de ontsteking uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de &#34;Cruise CANCEL-schakelaar&#34;, de &#34;Cruise RES/ACC-schakelaar&#34;, de &#34;Cruise SET/COAST-schakelaar&#34; en de &#34;Cruise ON/OFF-schakelaar&#34; op het SUZUKI-uitleesapparaat. 
<intxreftitleoff1 refid = "ADUAP70AA104006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Einde. (Sporadische storing.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA104008006">
<title>
Circuitcontrole van de cruise-controlschakelaar
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de stekkerverbindingen &#34;C01&#34;, &#34;E01&#34; en &#34;G371&#34; los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de aansluitklem goed op de stekkerverbindingen &#34;C01&#34;, &#34;E01&#34; en &#34;G371&#34; is aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Als de aansluitingen in orde zijn, controleer dan de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van circuit &#34;A1&#34; en &#34;A2&#34;: minder dan 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuit &#34;A1&#34; en de massa: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;A1&#34; en andere aansluitklemmen aan de stekkerverbinding &#34;G371&#34;: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;A2&#34; en andere aansluitklemmen aan de stekkerverbinding &#34;G371&#34;: oneindig
</ptxt>
</item>
<item>
<ptxt>
Spanning van elk van de circuits &#34;A1&#34; en &#34;A2&#34;: 0 – 1 V (als de ontsteking is ingeschakeld)
</ptxt>
</item>
</list1>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA104008007">
<title>
Controle van de cruise-controlschakelaar
</title>
<test1>
<ptxt>
Controleer de cruise-controlschakelaar. 
<intxreftitleoff1 refid = "ADUAP70AA106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is hij in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de cruise-controlschakelaar. 
<intxreftitleoff1 refid = "ADUAP70AA106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
