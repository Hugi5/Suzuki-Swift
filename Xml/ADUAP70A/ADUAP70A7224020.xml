<diag type = "test" id = "ADUAP70A7224020007">
<testgroup id = "ADUAP70A7224020008">
<title>
Controle van de uitleesapparaatparameters
</title>
<test1>
<ptxt>
Controleer de &#34;Luchtmengselpositiesensor&#34; in de &#34;Datalijst&#34;-modus van het SUZUKI-uitleesapparaat. 
<intxreftitleoff1 refid = "ADUAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is hij in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sporadische storing.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224020009">
<title>
Controle van het circuit van de stelmotor van de temperatuurregeling
</title>
<test1>
<ptxt>
Maak de stekkerverbinding &#34;G20&#34; en de stekkerverbinding van de stelmotor van de temperatuurregeling los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van de draadcircuits &#34;GRY&#34; en &#34;LT BLU&#34;: minder dan 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand van de draadcircuits &#34;GRY&#34; en &#34;LT BLU&#34; tussen de stelmotor van de temperatuurregeling en de massa: oneindig
</ptxt>
</item>
</list1>
</test1>
<question>
Zijn de weerstandswaarden zoals voorgeschreven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224020010">
<title>
Controle stelmotor van de temperatuurregeling
</title>
<test1>
<ptxt>
Controleer de stelmotor van de temperatuurregeling. 
<intxreftitleoff1 refid = "ADUAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is de stelmotor in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het HVAC-regelapparaat en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de stelmotor van de temperatuurregeling. 
<intxreftitleoff1 refid = "ADUAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
