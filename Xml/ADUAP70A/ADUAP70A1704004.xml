<servinfosub id = "ADUAP70A1704004002">
<title>
Storingzoeken
</title>
<diag type = "test" id = "ADUAP70A1704004003">
<testgroup id = "ADUAP70A1704004004">
<title>
Controle werking van het brandstofpompregelsysteem
</title>
<test1>
<ptxt>
Verwijder de brandstoftankdop.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of het bedrijfsgeluid van de brandstofpomp uit de brandstoftank-vulhals ongeveer 2 seconden lang wordt gehoord en vervolgens stopt.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Het brandstofpompcircuit is in orde. Monteer de brandstoftankdop opnieuw.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704004005">
<title>
Controle van het voedingscircuit van het brandstofpomprelais
</title>
<test1>
<ptxt>
Monteer de brandstoftankdop opnieuw.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Verwijder het brandstofpomprelais van de zekeringenkast van het afzonderlijke circuit nr. 1.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of alle aansluitklemmen goed op de stekkerverbinding van het brandstofpomprelais zijn aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in indien OK.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de spanning tussen &#34;A1&#34; en &#34;A2&#34; en de massa accuspanning is.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer het voedingscircuit van het brandstofpomprelais.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704004006">
<title>
Controle van het brandstofpomprelais
</title>
<test1>
<ptxt>
Controleer het brandstofpomprelais. 
<intxreftitleoff1 refid = "ADUAP70AA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het brandstofpomprelais.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704004007">
<title>
Controle stuurkring van het brandstofpomprelais
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de stekkerverbindingen &#34;C01&#34; en &#34;E01&#34; van de ECM los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de aansluitklem goed op de stekkerverbindingen &#34;C01&#34; en &#34;E01&#34; is aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Als de aansluitingen in orde zijn, controleer dan de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van circuit &#34;B1&#34;: minder dan 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuit &#34;B1&#34; en de massa: oneindig
</ptxt>
</item>
<item>
<ptxt>
Spanning van circuit &#34;B1&#34;: 0 – 1 V (als de ontsteking is ingeschakeld)
</ptxt>
</item>
</list1>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer de stuurkring van het brandstofpomprelais.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704004008">
<title>
Controle stuurkringsignaal van het brandstofpomprelais
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Sluit de stekkerverbindingen &#34;C01&#34; en &#34;E01&#34; op de ECM aan.
</ptxt>
</test1>
<test1>
<ptxt>
Sluit het brandstofpomprelais met verbindingsdraad aan.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de spanning tussen &#34;B1&#34; en de massa 0 – 1 V is gedurende 2 sec nadat de ontsteking is ingeschakeld.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de ECM en controleer de werking van de brandstofpomp opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704004009">
<title>
Controle voedingscircuit van de brandstofpomp
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Verwijder de brandstoftank.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de brandstofpompstekker los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de weerstand tussen &#34;B2&#34; en de massa oneindig is.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer het voedingscircuit van de brandstofpomp.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704004010">
<title>
Controle voedingscircuit van de brandstofpomp
</title>
<test1>
<ptxt>
Sluit de verbindingsdraad tussen &#34;B1&#34; en de massa aan.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de spanning tussen &#34;B2&#34; en de massa accuspanning is.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer het voedingscircuit van de brandstofpomp.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704004011">
<title>
Controle massacircuit van de brandstofpomp
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de weerstand tussen &#34;B3&#34; en de massa minder dan 1 &#937; is.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de brandstofpomp. 
<intxreftitleoff1 refid = "ADUAP70A1706015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer het massacircuit van de brandstofpomp
</ptxt>
</action>
</testgroup>
</diag>
