<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de achterruitwisser
</title>
<servinfosub id = "ADUAP70A9406005001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de kap van de achterruitwisserarm (1), de achterruitwisserarmmoer (2), de achterruitwisserarm met bladsamenstel (3) de wisserspilkap (4), de achterruitwissermoer (5) en de achterruitwisserafdichting (6).
</ptxt>
<figure>
<graphic graphicname = "I9P60A940013.swf" width = "88.000mm" height = "45.733mm" ver = "01" gw = "174" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de achterklepbekleding. 
<intxreftitleoff1 refid = "ADUAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de achterruitwissermotor.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding (1) van de achterruitwissermotor met een platte schroevendraaier (2) zoals afgebeeld los.
</ptxt>
<figure>
<graphic graphicname = "I7V10A940003.swf" width = "88.000mm" height = "79.003mm" ver = "01" gw = "161" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9406005002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9406006">Onderzoek van de achterruitwissermotor</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de achterruitwissermotorbouten met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9D004">
<t-part>
Achterruitwissermotorbout
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I5RW0A940011.swf" width = "88.000mm" height = "56.315mm" ver = "01" gw = "172" gh = "143"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.373in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Achterruitwissermotor
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Monteer de afdichting (1) van de achterruitwisser en haal de bout van de achterruitwisser met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9D005">
<t-part>
Moer van de achterruitwisser
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,3
</t-value1>
<t-value2>
0,54
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940014.swf" width = "88.000mm" height = "34.877mm" ver = "02" gw = "116" gh = "82"/>
