<servinfosub id = "ADUAP70A4604020003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604020004">
<testgroup id = "ADUAP70A4604020005">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604020006">
<title>
Controle van de ESP&#174; OFF-schakelaar
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Verwijder de ESP<sup>&#174;</sup> OFF-schakelaar. 
<intxreftitleoff1 refid = "ADUAP70A4606017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of alle aansluitklemmen van de ESP<sup>&#174;</sup> OFF-schakelaar goed zijn aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de ESP<sup>&#174;</sup> OFF-schakelaar als de aansluitingen in orde zijn. 
<intxreftitleoff1 refid = "ADUAP70A4606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de ESP<sup>&#174;</sup> OFF-schakelaar.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604020007">
<title>
Controle van het ESP&#174; OFF-schakelaarcircuit
</title>
<test1>
<ptxt>
Maak stekkerverbinding &#34;E24&#34; los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of aansluitklem &#34;E24-38&#34; juist is aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Als de aansluiting in orde is, controleer dan de weerstand tussen aansluitklem &#34;E24-38&#34; en de massa.
</ptxt>
</test1>
<question>
Is de weerstand oneindig?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang circuit &#34;A1&#34; bij kortsluiting.
</ptxt>
</action>
</testgroup>
</diag>
