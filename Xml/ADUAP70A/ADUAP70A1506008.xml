<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1506008" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Onderzoek van de oliepomp
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1506007">Demontage en hermontage van het oliepompsamenstel</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1506008001">
<title>
Oliekeerring
</title>
<ptxt>
Controleer de oliekeerringlip op defecten en schade. Vervang als er een defect is.
</ptxt>
<figure>
<graphic graphicname = "I2RH0B150023.swf" width = "88.000mm" height = "51.085mm" ver = "01" gw = "184" gh = "128"/>
</figure>
</servinfosub>
<servinfosub id = "ADUAP70A1506008002">
<title>
Oliepomp
</title>
<list1 type = "unordered">
<item>
<ptxt>
Controleer de buitenste (1) en binnenste rotor (2), de rotorplaat en het oliepomphuis op buitensporige slijtage en schade.
</ptxt>
<figure>
<graphic graphicname = "I8C50A150028.swf" width = "88.000mm" height = "53.524mm" ver = "01" gw = "134" gh = "135"/>
</figure>
</item>
<item>
<ptxt>
Controleer of de ontlastklep (1) niet overmatig versleten of beschadigd is en soepel werkt.
</ptxt>
<figure>
<graphic graphicname = "I8C50A150029.swf" width = "88.000mm" height = "64.979mm" ver = "01" gw = "112" gh = "168"/>
</figure>
</item>
</list1>
<c-change/>
<topic id = "ADUAP70A1506008003">
<title>
Toelaatbare radiale speling
</title>
<ptxt>
Controleer met een voelermaat de radiale speling tussen de buitenste rotor (1) en het huis (2).
</ptxt>
<ptxt>
Vervang het oliepompsamenstel als de speling buiten het voorgeschreven bereik valt.
</ptxt>
<spec>
<title>
Toelaatbare radiale speling tussen de buitenste rotor en het oliepomphuis
</title>
<ptxt>
Standaard: 0,120 – 0,190 mm (0,0047 – 0,0075 in.)
</ptxt>
<ptxt>
Grenswaarde: 0,210 mm (0,0083 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151026.swf" width = "88.000mm" height = "49.550mm" ver = "01" gw = "171" gh = "124"/>
</figure>
</topic>
<topic id = "ADUAP70A1506008004">
<title>
Toelaatbare axiale speling
</title>
<ptxt>
Meet de axiale speling met behulp van een richtliniaal (1) en een voelermaat (2).
</ptxt>
<ptxt>
Vervang het oliepompsamenstel als de axiale speling de grenswaarde overschrijdt.
</ptxt>
<spec>
<title>
Toelaatbare axiale speling van de binnenste rotor van de oliepomp
</title>
<ptxt>
Standaard: 0,045 – 0,100 mm (0,0018 – 0,0039 in.)
</ptxt>
<ptxt>
Grenswaarde: 0,120 mm (0,0047 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151027.swf" width = "88.000mm" height = "52.842mm" ver = "01" gw = "185" gh = "133"/>
</figure>
</topic>
<c-change/>
<topic id = "ADUAP70A1506008005" page = "2">
<title>
Speling van de rotorplaat
</title>
<ptxt>
Controleer de toelaatbare speling tussen de binnenste rotor (1) en de rotorplaat (2) als volgt.
</ptxt>
<s1 page = "2">
<ptxt>
Meet met een micrometer de buitendiameter &#34;a&#34; van de binnenste rotor (1).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Meet met een micrometer de binnendiameter &#34;b&#34; van de rotorplaat (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Bereken het verschil tussen de meetwaarden in stap 1) en stap 2).
</ptxt>
</s1>
<ptxt>
Vervang het oliepompsamenstel als de speling buiten het voorgeschreven bereik valt.
</ptxt>
