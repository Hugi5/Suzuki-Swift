<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1606007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van koelvloeistofleidingen of -slangen
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1606001">Componenten van koelsysteem</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ADUAP70A1606009">Onderzoek van het thermostaatsamenstel (geïntegreerd met ECT-sensor)</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1606007001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Tap de koelvloeistof af. 
<intxreftitleoff1 refid = "ADUAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Om koelwaterleidingen of -slangen te verwijderen, moet u de klem op elke slang losmaken en het slanguiteinde lostrekken.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1606007002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal iedere klem stevig aan in de juiste richting. 
<intxreftitleoff1 refid = "ADUAP70A1606001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vul het koelsysteem met koelvloeistof bij. 
<intxreftitleoff1 refid = "ADUAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Controleer het koelsysteem op lekkage. 
<intxreftitleoff1 refid = "ADUAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
