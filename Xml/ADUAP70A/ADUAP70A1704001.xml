<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A1704001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Onderzoek van het brandstofsysteem
</title>
<diag type = "test" id = "ADUAP70A1704001001">
<testgroup id = "ADUAP70A1704001002">
<title>
Onderzoek van de brandstofpomp
</title>
<test1>
<ptxt>
Verwijder de brandstoftankdop en schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of u gedurende ongeveer 2 seconden het bedrijfsgeluid van de brandstofpomp via de brandstoftankvulopening hoort, waarna de pomp stopt.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controleer het brandstofpompcircuit. 
<intxreftitleoff1 refid = "ADUAP70A1704004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704001003">
<title>
Controle van de brandstofdruk
</title>
<test1>
<ptxt>
Controleer de brandstofdruk. 
<intxreftitleoff1 refid = "ADUAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer het defecte onderdeel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704001004">
<title>
Vermogensbalanstest
</title>
<test1>
<ptxt>
Controleer de vermogensbalans. 
<intxreftitleoff1 refid = "ADUAP70A1704002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Het brandstofsysteem is in orde.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704001005">
<title>
Controle van het brandstofverstuivercircuit
</title>
<test1>
<ptxt>
Controleer het brandstofverstuivercircuit. 
<intxreftitleoff1 refid = "ADUAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer het defecte onderdeel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1704001006">
<title>
Controle van de brandstofverstuiver
</title>
<test1>
<ptxt>
Controleer de brandstofverstuiver. 
<intxreftitleoff1 refid = "ADUAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de brandstofverstuiver. 
<intxreftitleoff1 refid = "ADUAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
