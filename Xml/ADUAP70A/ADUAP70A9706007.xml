<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9706007" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de achterbank of achterstoelen
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9706006">Componenten van de achterbank/achterstoelen</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A9706007001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het zitkussensamenstel van de achterbank. 
<intxreftitleoff1 refid = "ADUAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de rugleuningsamenstellen van de achterbank door de achterbankscharnierbouten te verwijderen. 
<intxreftitleoff1 refid = "ADUAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demonteer en repareer de achterbank indien nodig. 
<intxreftitleoff1 refid = "ADUAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9706007002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zie 
<intxref refid = "ADUAP70A9706006">Componenten van de achterbank/achterstoelen</intxref>
 voor het aanhaalkoppel.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
