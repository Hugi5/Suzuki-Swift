<servinfosub id = "ADUAP70A9806010001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de stoel.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voorstoel: 
<intxreftitleoff1 refid = "ADUAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Achterbank: 
<intxreftitleoff1 refid = "ADUAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Verwijder de volgende lijsten en bekledingen. 
<intxreftitleoff1 refid = "ADUAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
