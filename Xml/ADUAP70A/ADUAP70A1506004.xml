<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1506004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van oliecarter en oliepompzeef
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1506003">Onderdelen van het oliecarter en de oliepompzeef</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1506004001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de oliepeilmeter.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder de rechtse beschermplaat aan de onderkant van de motor.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de aftapplug en tap de motorolie af.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder uitlaatpijp nr. 1. 
<intxreftitleoff1 refid = "ADUAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de tussenbak. 
<intxreftitleoff1 refid = "ADUAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de oliefilter. 
<intxreftitleoff1 refid = "ADUAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder de transaxlebouten (1) en de bouten van het oliecarter (2).
</ptxt>
<figure>
<graphic graphicname = "I7V20A151012.swf" width = "88.000mm" height = "49.208mm" ver = "01" gw = "227" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het oliecarter (1) van het cilinderblok met speciaal gereedschap en een hamer.
</ptxt>
<servicetool>
<servicetoolitem id = "L1E005">
<s-part>
(A)
</s-part>
<s-number num = "09921-96510">
09921-96510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A151013.swf" width = "88.000mm" height = "49.206mm" ver = "02" gw = "230" gh = "123"/>
</figure>
</s1>
<c-change/>
<s1 page = "2">
<ptxt>
Verwijder indien nodig de oliepompzeef.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder indien nodig het oliecarterkeerschot en de tapeindbouten van het oliecarterkeerschot.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1506004002">
<title>
Inbouw
</title>
<s1>
<ptxt>
Monteer de tapeindbout (1) van het oliecarterkeerschot indien deze is verwijderd en haal dan de tapeindbout van het oliecarterkeerschot met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1E004">
<t-part>
Tapeindbout van het oliecarterkeerschot
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Monteer het oliecarterkeerschot (2) en haal dan de bouten (3) van het oliecarterkeerschot met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1E005">
<t-part>
Bout van het oliecarterkeerschot
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure page = "2">
<graphic graphicname = "I9P60A151002.swf" width = "88.000mm" height = "50.955mm" ver = "01" gw = "177" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Breng motorolie op de nieuwe O-ring (1) aan en monteer dan de O-ringen op de oliepompzeef (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Monteer de oliepompzeef met de O-ring op de oliepomp en haal eerst de bout (3) en daarna de moer (4) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1E006">
<t-part>
Bout van de oliepompzeef*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1E007">
<t-part>
Beugelmoer van de oliepompzeef*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151003.jpg" width = "88.000mm" height = "61.290mm" ver = "01" gw = "199" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de paspennen (1) op het oliecarter en het cilinderblok.
</ptxt>
<figure>
<graphic graphicname = "I9P60A151004.jpg" width = "88.000mm" height = "67.299mm" ver = "01" gw = "207" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Breng motorolie op de nieuwe O-ring (1) aan en monteer dan de O-ring op de plaats die op de afbeelding wordt aangeduid.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Breng afdichtmiddel op het pasvlak van het oliecarter aan zoals op de afbeelding.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Zorg ervoor dat het pasvlak schoon en droog is alvorens afdichtmiddel aan te brengen.
</ptxt>
</item>
<item>
<ptxt>
Veeg overtollig afdichtmiddel weg.
</ptxt>
</item>
<item>
<ptxt>
Monteer het oliecarter binnen 2 minuten na het aanbrengen van afdichtmiddel.
</ptxt>
</item>
</list1>
</attention3>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1E002" uid = "-491504098">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Afdichtmiddel
</m-desc>
<m-number>
99000-31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<spec>
<title>
Hoeveelheid afdichtmiddel voor oliecarter
</title>
<ptxt>
Breedte &#34;a&#34;: 3 mm (0,12 in.)
</ptxt>
<ptxt>
Hoogte &#34;b&#34;: 2 mm (0,08 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151017.swf" width = "88.000mm" height = "59.875mm" ver = "01" gw = "146" gh = "153"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer het oliecarter op het cilinderblok en haal dan de bouten van het oliecarter gelijkmatig en geleidelijk in numerieke volgorde (&#34;1&#34; – &#34;17&#34;) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1E008">
<t-part>
Bout van het oliecarter*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151005.swf" width = "88.000mm" height = "63.567mm" ver = "01" gw = "227" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Haal de transaxlebouten (1) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1E009">
<t-part>
Transaxlebout
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151006.swf" width = "88.000mm" height = "46.039mm" ver = "01" gw = "227" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de oliefilter. 
<intxreftitleoff1 refid = "ADUAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de tussenbak. 
<intxreftitleoff1 refid = "ADUAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer uitlaatpijp nr. 1. 
<intxreftitleoff1 refid = "ADUAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de rechtse beschermplaat aan de onderkant van de motor.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de aftapplug en vul de motor bij met motorolie. 
<intxreftitleoff1 refid = "ADUAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de oliepeilmeter.
</ptxt>
</s1>
<s1>
<ptxt>
Controleer of er geen motorolie- en uitlaatgaslekkage is bij elke verbinding.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
