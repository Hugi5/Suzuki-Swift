<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A3126003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de achterste aandrijfas
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A3126001">Componenten van de achterste aandrijfas:Achterkant</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ADUAP70A3126002">Onderzoek in het voertuig van het achterste aandrijfassamenstel:Achterkant</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A3126003001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Krik het voertuig omhoog en verwijder het achterwiel. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de dichtstuiking (1) los en verwijder de aandrijfasmoer (2) met ingedrukt rempedaal.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312002.swf" width = "88.000mm" height = "53.091mm" ver = "01" gw = "177" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de flensmoeren van de achterste aandrijfas (1) en verwijder daarna het achterste aandrijfassamenstel.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312003.swf" width = "88.000mm" height = "47.465mm" ver = "01" gw = "177" gh = "118"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A3126003002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Draai de nieuwe aandrijfasmoer (1) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T3A202">
<t-part>
Aandrijfasmoer
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Stuik de aandrijfasmoer (1) dicht zoals op de afbeelding.
</ptxt>
<attention2>
<ptxt>
Zorg ervoor dat het dicht te stuiken deel (2) van de aandrijfasmoer niet barst bij het dichtstuiken. Vervang ze door een nieuw exemplaar als ze gebarsten is.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A312004.swf" width = "88.000mm" height = "52.301mm" ver = "01" gw = "159" gh = "132"/>
</figure>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Haal de flensmoeren van de achterste aandrijfas met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T3A203">
<t-part>
Flensmoer van de achterste aandrijfas
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A312005.swf" width = "88.000mm" height = "49.964mm" ver = "01" gw = "177" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Breng vet op het pasvlak van het achterwielnaafsamenstel en de achterste aandrijfas aan.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A202" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A312006.swf" width = "88.000mm" height = "54.175mm" ver = "02" gw = "227" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Haal de wielmoeren met het voorgeschreven koppel aan. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
