<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70AA206004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de buitenluchttemperatuursensor
</title>
<servinfosub id = "ADUAP70AA206004001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de voorbumper. 
<intxreftitleoff1 refid = "ADUAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding (1) van de buitenluchttemperatuursensor los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de buitenluchttemperatuursensor (2) van de voorbumperdraagbalk.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20018.jpg" width = "88.000mm" height = "67.914mm" ver = "01" gw = "210" gh = "176"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA206004002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70AA206005">Onderzoek van de buitenluchttemperatuursensor</intxrefpoff>
</ptxt>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
