<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A4604033" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1074 / C1075
</title>
<servinfosub id = "ADUAP70A4604033001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1074: IJking van de G-sensor 
</emph>
</ptxt>
<ptxt>
IJking van gierratio- / G-sensor is niet voltooid.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
De ijking van de gierratio- / G-sensor is niet voltooid
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup>-regelapparaat
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1075: IJking van de stuurhoeksensor
</emph>
</ptxt>
<ptxt>
De ijking van de stuurhoeksensor is niet voltooid.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Stuurhoeksensor
</ptxt>
</item>
<item>
<ptxt>
De stuurhoeksensor is niet volledig geijkt
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup>-regelapparaat
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A4604033002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604033003">
<testgroup id = "ADUAP70A4604033004">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604033005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A4604005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Worden er behalve C1074 of C1075 nog andere DTC&#39;s weergegeven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604033006">
<title>
Sensorijking
</title>
<test1>
<ptxt>
Alle sensors moeten geijkt worden. 
<intxreftitleoff1 refid = "ADUAP70A4606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is de sensorijking voltooid?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de stuurhoeksensor. 
<intxreftitleoff1 refid = "ADUAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604033007">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Wis alle DTC&#39;s en controleer op DTC&#39;s.
</ptxt>
</test1>
<question>
Worden DTC C1074 en/of C1075 nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
DTC C1074: Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
DTC C1075: Vervang de stuurhoeksensor en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
