<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1406018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van het distributiekettingdeksel
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1406017">Componenten van het distributiekettingdeksel</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Houd de werktafel, gereedschappen en handen schoon tijdens de revisie.
</ptxt>
</item>
<item>
<ptxt>
Wees uiterst voorzichtig om aluminiumonderdelen niet te beschadigen.
</ptxt>
</item>
<item>
<ptxt>
Verwijderde onderdelen niet aan stof blootstellen. Houd ze altijd schoon.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "ADUAP70A1406018001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de motor uit het voertuig. 
<intxreftitleoff1 refid = "ADUAP70A1406016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de waterpomp / dynamoaandrijfriem. 
<intxreftitleoff1 refid = "ADUAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bout van de de krukaspoelie.
</ptxt>
<ptxt>
Gebruik het speciale gereedschap om de krukaspoelie (1) vast te zetten zoals op de afbeelding.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Gebruik speciaal gereedschap om te vermijden dat onnodige belasting wordt uitgeoefend op de distributieketting, de kettingwielen en alle verwante onderdelen.
</ptxt>
</item>
<item>
<ptxt>
Gebruik de hieronder voorgeschreven bouten om het speciale gereedschap op de krukaspoelie te monteren.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I8T401142029.swf" width = "88.000mm" height = "32.640mm" ver = "01" gw = "126" gh = "76"/>
</figure>
<table frame = "all" colsep = "1" rowsep = "1">
<title>
Bevestigingsbout speciaal gereedschap
</title>
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.573in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.573in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Boutmaat
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
M8
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Spoed
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
1,25 mm (0,05 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Lengte &#34;a&#34;
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
25 mm (0,98 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Sterkte
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
7T
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</attention2>
<attention3>
<ptxt>
Gebruik het speciale gereedschap met verwijderde pennen, indien nodig.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1D010">
<s-part>
(A)
</s-part>
<s-number num = "09917-68221">
09917-68221
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141049.swf" width = "88.000mm" height = "49.174mm" ver = "01" gw = "163" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de krukaspoelie (1).
</ptxt>
<ptxt>
Gebruik speciaal gereedschap zoals op de afbeelding als deze zich moeilijk laat verwijderen.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D011">
<s-part>
(A)
</s-part>
<s-number num = "09926-37610-001">
09926-37610-001
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L1D012">
<s-part>
(B)
</s-part>
<s-number num = "09926-58010">
09926-58010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH0B140052.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "170" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het kleppendeksel. 
<intxreftitleoff1 refid = "ADUAP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het oliecarter. 
<intxreftitleoff1 refid = "ADUAP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de waterpomppoelie.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bouten van het distributiekettingdeksel en verwijder vervolgens het distributiekettingdeksel.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder indien nodig de krukas-oliekeerring van het distributiekettingdeksel met een platte schroevendraaier of iets dergelijks.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder indien nodig de OCV van het distributiekettingdeksel. 
<intxreftitleoff1 refid = "ADUAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Demonteer het distributiekettingdeksel en de oliepomp indien nodig. 
<intxreftitleoff1 refid = "ADUAP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1406018002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1406019">Onderzoek van het distributiekettingdeksel</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Reinig het afdichtingsoppervlak op het distributiekettingdeksel, het cilinderblok en de cilinderkop.
</ptxt>
<ptxt>
Verwijder olie, oud afdichtmiddel en stof van het afdichtingsoppervlak.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het distributiekettingdeksel en de oliepomp opnieuw, indien verwijderd. 
<intxreftitleoff1 refid = "ADUAP70A1506007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de OCV, indien verwijderd. 
<intxreftitleoff1 refid = "ADUAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controleer de oliekeerringlip (1) op defecten en schade.
</ptxt>
<ptxt>
Vervang zo nodig de oliekeerring.
</ptxt>
<attention3>
<ptxt>
Bij het monteren van een nieuwe oliekeerring, deze vastdrukken op het distributiekettingdeksel (2) met het speciale gereedschap (A) zoals op de afbeelding.
</ptxt>
</attention3>
<spec>
<title>
Diepte
</title>
<ptxt>
&#34;a&#34;: 1,5 mm (0,06 in.)
</ptxt>
</spec>
<servicetool>
<servicetoolitem id = "L1D013">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913-75810
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A141050.swf" width = "88.000mm" height = "52.484mm" ver = "01" gw = "179" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer een nieuwe O-ring (1) op de oliepomp (2).
</ptxt>
</s1>
<s1>
<ptxt>
Monteer een nieuwe pakking (3) op het distributiekettingdeksel (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141055.jpg" width = "88.000mm" height = "67.189mm" ver = "01" gw = "144" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer paspennen (1) op het cilinderblok als deze verwijderd zijn.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141056.swf" width = "88.000mm" height = "58.478mm" ver = "01" gw = "131" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Breng afdichtmiddel &#34;A&#34; op het pasvlak van de cilinder en cilinderkop aan en &#34;B&#34; op het pasvlak van het distributiekettingdeksel zoals op de afbeelding.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207B" id = "M1D002" uid = "29">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Afdichtmiddel
</m-desc>
<m-number>
99000-31140
</m-number>
<m-name>
SUZUKI Bond No.1207B
</m-name>
</materialitem>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1D003" uid = "-491504098">
<m-part>
&#34;B&#34;
</m-part>
<m-desc>
Afdichtmiddel
</m-desc>
<m-number>
99000-31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<spec>
<title>
Afdichtmiddelhoeveelheid voor distributiekettingdeksel
</title>
<ptxt>
Breedte &#34;a&#34;: 3 mm (0,12 in.)
</ptxt>
<ptxt>
Hoogte &#34;b&#34;: 2 mm (0,08 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A141057.jpg" width = "88.000mm" height = "49.092mm" ver = "01" gw = "220" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Smeer motorolie op de oliekeerringlip, monteer daarna het distributiekettingdeksel (1). Haal de bouten geleidelijk in numerieke volgorde van &#34;1&#34; tot en met &#34;15&#34; met het voorgeschreven koppel aan.
</ptxt>
<attention3>
<ptxt>
Controleer of de pen stevig vastzit alvorens het distributiekettingdeksel te monteren.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1D011">
<t-part>
Bout van het distributiekettingdeksel
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A141058.jpg" width = "88.000mm" height = "72.952mm" ver = "01" gw = "169" gh = "190"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de waterpomppoelie.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het kleppendeksel. 
<intxreftitleoff1 refid = "ADUAP70A1406011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het oliecarter. 
<intxreftitleoff1 refid = "ADUAP70A1506004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de krukaspoelie (1). Haal de krukaspoeliebout met het voorgeschreven koppel aan. Gebruik het speciale gereedschap zoals op de afbeelding om de krukaspoelie vast te zetten.
</ptxt>
<attention2>
