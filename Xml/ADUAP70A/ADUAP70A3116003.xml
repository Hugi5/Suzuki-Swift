<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A3116003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de voorste aandrijfas
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A3116001">Componenten van de voorste aandrijfas:Voorkant</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ADUAP70A3116002">Onderzoek op het voertuig van de voorste aandrijfas:Voorkant</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A3116003001">
<title>
Uitbouw
</title>
<s1 page = "2">
<ptxt>
Krik het voertuig omhoog en verwijder het voorwiel. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Maak de dichtstuiking (1) los en verwijder de aandrijfasmoer (2) met ingedrukt rempedaal.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311002.swf" width = "88.000mm" height = "54.100mm" ver = "01" gw = "182" gh = "137"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Tap de transaxle-olie en tussenbakolie af.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Transaxle-olie: 
<intxreftitleoff1 refid = "ADUAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tussenbakolie: 
<intxreftitleoff1 refid = "ADUAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Verwijder de voorwieltoerentalsensor van de fusee. 
<intxreftitleoff1 refid = "ADUAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Maak de wieldraagarmkoppeling van de fusee los. 
<intxreftitleoff1 refid = "ADUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Gebruik bandenlichter (1) of kunststofhamer (3) om aandrijfaskoppeling (2) naar buiten te trekken.
</ptxt>
<attention3>
<ptxt>
Het draaien van de aandrijfas bij het naar buiten trekken van de aandrijfas kan het losmaken van het veerringpasstuk van de koppelingsspie vergemakkelijken.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A311004.swf" width = "88.000mm" height = "41.941mm" ver = "01" gw = "197" gh = "102"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.298in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.298in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Linkeras
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Rechteras
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het aandrijfassamenstel.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ADUAP70A3116003002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Wees voorzichtig en beschadig geen oliedichtingen en stofhoezen tijdens het inbouwen van de aandrijfas.
</ptxt>
</item>
<item>
<ptxt>
Klop niet met een hamer op een koppelingshoes. De koppeling mag uitsluitend met de hand ingestoken worden.
</ptxt>
</item>
<item>
<ptxt>
Zorg ervoor dat de koppeling aan differentieelzijde volledig is ingestoken en dat de bijbehorende borgveer zoals voorheen is aangebracht.
</ptxt>
</item>
<item>
<ptxt>
Controleer voor het plaatsen van de aandrijfas (1) of er zich geen vreemd materiaal rond de codeerinrichting (2) op het wiellager bevindt.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311003.swf" width = "88.000mm" height = "51.493mm" ver = "01" gw = "203" gh = "129"/>
</figure>
</item>
</list1>
</attention2>
<list1 type = "unordered">
<item>
<ptxt>
Gebruik een nieuwe koppelingsborgveer aan de zijkant van het differentieel.
</ptxt>
</item>
<item>
<ptxt>
Breng vet op het pasvlak van de voorwielnaaf en de aandrijfas aan.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A101" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A311005.jpg" width = "88.000mm" height = "67.700mm" ver = "01" gw = "230" gh = "175"/>
</figure>
</item>
<item>
<ptxt>
Haal de aandrijfasmoer (1) met het voorgeschreven koppel aan.
</ptxt>
<attention2>
<ptxt>
Gebruik een nieuwe aandrijfasmoer.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T3A101">
<t-part>
Aandrijfasmoer
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Stuik de aandrijfasmoer (1) dicht zoals op de afbeelding.
</ptxt>
<attention2>
<ptxt>
Zorg ervoor dat het dicht te stuiken deel (2) van de aandrijfasmoer niet barst bij het dichtstuiken. Vervang ze door een nieuw exemplaar als ze gebarsten is.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A311006.swf" width = "88.000mm" height = "54.205mm" ver = "01" gw = "172" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Sluit de wieldraagarmkoppeling aan. 
<intxreftitleoff1 refid = "ADUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Monteer de voorwieltoerentalsensor. 
<intxreftitleoff1 refid = "ADUAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Monteer het voorwiel. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vul transaxle-olie bij. 
<intxreftitleoff1 refid = "ADUAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vul tussenbakolie bij. 
<intxreftitleoff1 refid = "ADUAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Controleer de voorwieluitlijning. 
<intxreftitleoff1 refid = "ADUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
