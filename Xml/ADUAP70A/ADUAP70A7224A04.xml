<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A7224A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Er wordt geen koele lucht uitgeblazen of de koeling is onvoldoende (magneetkoppeling werkt normaal)
</title>
<diag type = "condition">
<condition>
<ptxt>
Er wordt geen koele lucht uitgeblazen of de koeling is onvoldoende (magneetkoppeling werkt normaal)
</ptxt>
</condition>
<ps>
<ptxt>
Te veel of te weinig koelmiddel
</ptxt>
</ps>
<action>
<ptxt>
Controleer de hoeveelheid koelmiddel en controleer het systeem op lekken.
</ptxt>
</action>
<ps>
<ptxt>
Verstopte condensor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de condensor. 
<intxreftitleoff1 refid = "ADUAP70A7226005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
De A/C-verdamper is verstopt of bevroren
</ptxt>
</ps>
<action>
<ptxt>
Controleer de A/C-verdamper en de verdampertemperatuursensor. 
<intxreftitleoff1 refid = "ADUAP70A7226017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 en 
<intxreftitleoff1 refid = "ADUAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte verdampertemperatuursensor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de verdampertemperatuursensor. 
<intxreftitleoff1 refid = "ADUAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte expansieklep
</ptxt>
</ps>
<action>
<ptxt>
Controleer de expansieklep. 
<intxreftitleoff1 refid = "ADUAP70A7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verstopt ontwateringsmiddel
</ptxt>
</ps>
<action>
<ptxt>
Controleer het ontwateringsmiddel en de kap samen met de filter.
</ptxt>
</action>
<ps>
<ptxt>
Losse of kapotte compressoraandrijfriem
</ptxt>
</ps>
<action>
<ptxt>
Controleer de compressoraandrijfriem. 
<intxreftitleoff1 refid = "ADUAP70A7226043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slippende magneetkoppeling
</ptxt>
</ps>
<action>
<ptxt>
Controleer de magneetkoppeling. 
<intxreftitleoff1 refid = "ADUAP70A7226047"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte compressor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de compressor.
</ptxt>
</action>
<ps>
<ptxt>
Lucht in het A/C-systeem
</ptxt>
</ps>
<action>
<ptxt>
Vervang de condensor, zuig vacuüm en vul bij. 
<intxreftitleoff1 refid = "ADUAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Er lekt lucht uit de HVAC-eenheid of het luchtkanaal
</ptxt>
</ps>
<action>
<ptxt>
Repareer de HVAC-eenheid of het luchtkanaal.
</ptxt>
</action>
<ps>
<ptxt>
Defect verwarmingssysteem en ventilatiesysteem
</ptxt>
</ps>
<action>
<ptxt>
Controleer de HVAC-eenheid.
</ptxt>
</action>
<ps>
<ptxt>
Defect HVAC-regelapparaat
</ptxt>
</ps>
<action>
<ptxt>
Controleer het HVAC-regelapparaat. 
<intxreftitleoff1 refid = "ADUAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte stelmotor van de temperatuurregeling
</ptxt>
</ps>
<action>
<ptxt>
Controleer de stelmotor van de temperatuurregeling. 
<intxreftitleoff1 refid = "ADUAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte aanjagermotor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aanjagermotor. 
<intxreftitleoff1 refid = "ADUAP70A7226012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Te veel compressorolie in het A/C-systeem
</ptxt>
</ps>
<action>
<ptxt>
Tap overtollige compressorolie uit het A/C-systeemcircuit en de compressor af.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
