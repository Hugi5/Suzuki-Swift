<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9406001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de sproeivloeistoftank en de ruitensproeierpomp
</title>
<servinfosub id = "ADUAP70A9406001001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de voorbumper. 
<intxreftitleoff1 refid = "ADUAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de bedradingsbundelklemmen (1), sproeierpompstekkers (2) en sproeierslangen (3) los.
</ptxt>
<figure>
<graphic graphicname = "IAP70P940004.jpg" width = "88.000mm" height = "67.662mm" ver = "01" gw = "209" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de sproeivloeistoftankbouten (1) en verwijder de sproeivloeistoftank (2) zelf.
</ptxt>
<figure>
<graphic graphicname = "IAP70P940005.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "180" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Trek de voorruitsproeierpomp (1) en de achterruitsproeierpomp (2) in de richting van de pijl om de sproeivloeistoftank (3) te verwijderen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P940006.jpg" width = "88.000mm" height = "62.134mm" ver = "01" gw = "161" gh = "160"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9406001002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9406002">Onderzoek van de ruitensproeierpomp</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de bouten van de sproeivloeistoftank met het voorgeschreven koppel aan.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9D001">
<t-part>
Bout van de sproeivloeistoftank
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A940008.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "201" gh = "174"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
