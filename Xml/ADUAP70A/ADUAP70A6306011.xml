<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A6306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van het P/S-regelapparaat
</title>
<servinfosub id = "ADUAP70A6306011001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het instrumentenpaneel. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het rempedaalsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbindingen (1) los van het P/S-regelapparaat (2).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bouten (3) van het PS-regelapparaat van de steunbalk van de stuurinrichting.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630037.swf" width = "88.000mm" height = "94.023mm" ver = "01" gw = "148" gh = "250"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het P/S-regelapparaat.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A6306011002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de bouten van het P/S-regelapparaat met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T6C006">
<t-part>
Montagebout van het P/S-regelapparaat
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,0
</t-value1>
<t-value2>
0,51
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A630034.swf" width = "88.000mm" height = "98.099mm" ver = "02" gw = "148" gh = "262"/>
</figure>
</item>
<item>
<ptxt>
Monteer het rempedaalsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
