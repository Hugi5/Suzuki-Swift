<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
13&#176;
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;b&#34;: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
70 mm (2,8 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Stuik meer dan 4 plaatsen dicht met een kleine beitel.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311020.swf" width = "88.000mm" height = "52.911mm" ver = "01" gw = "186" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Dichtstuiking
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Druk de wielnaaf (1) in het wiellager (2) met speciaal gereedschap en een hydraulische pers vast.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A114">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913-75810
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3A115">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311017.swf" width = "88.000mm" height = "57.910mm" ver = "01" gw = "203" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Verbind de aandrijfas met de fusee. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de fusee aan de wieldraagarm vast. 
<intxreftitleoff1 refid = "ADUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de bouten en moeren van de veerpootbeugel. 
<intxreftitleoff1 refid = "ADUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de voorwieltoerentalsensor. 
<intxreftitleoff1 refid = "ADUAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verbind het trekstanguiteinde met de fusee. 
<intxreftitleoff1 refid = "ADUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de remschijf en het remzadel. 
<intxreftitleoff1 refid = "ADUAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Haal de aandrijfasmoer met het voorgeschreven koppel aan en stuik de aandrijfasmoer dicht. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Gebruik een nieuwe aandrijfasmoer.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Monteer het voorwiel. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controleer de voorwieluitlijning. 
<intxreftitleoff1 refid = "ADUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
