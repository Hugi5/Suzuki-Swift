<servinfosub id = "ADUAP70A7224029002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A7224029003">
<testgroup id = "ADUAP70A7224029005">
<title>
Controle van uitleesapparaatgegevens
</title>
<test1>
<ptxt>
Sluit het uitleesapparaat aan met de ontsteking uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in en kies de &#34;DATALIJST&#34;-modus.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer &#34;Motortype&#34; op het uitleesapparaat.
</ptxt>
</test1>
<question>
Wordt het motortype juist aangeduid in &#34;Parameterlijst&#34;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Monteer een goed bevonden HVAC-regelapparaat en controleer opnieuw.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sluit een goed bevonden ECM aan en controleer opnieuw.
</ptxt>
</action>
