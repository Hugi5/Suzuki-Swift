<title>
De luchtinlaatklep verandert niet, zelfs als de luchtinlaatmodus veranderd wordt.
</title>
<diag type = "condition">
<condition>
<ptxt>
De luchtinlaatklep verandert niet, zelfs als de luchtinlaatmodus veranderd wordt.
</ptxt>
</condition>
<ps>
<ptxt>
Gesprongen zekering
</ptxt>
</ps>
<action>
<ptxt>
Controleer de betrokken zekeringen en controleer op kortsluitingen aan de massa.
</ptxt>
</action>
<ps>
<ptxt>
Kapotte luchtinlaatklep
</ptxt>
</ps>
<action>
<ptxt>
Repareer de luchtinlaatklep.
</ptxt>
</action>
<ps>
<ptxt>
Defecte stelmotor van de luchtinlaatregeling
</ptxt>
</ps>
<action>
<ptxt>
Controleer de stelmotor van de luchtinlaatregeling. 
<intxreftitleoff1 refid = "ADUAP70A7216027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte luchtinlaatschakelaar
</ptxt>
</ps>
<action>
<ptxt>
Controleer de luchtinlaatschakelaar. 
<intxreftitleoff1 refid = "ADUAP70A7216025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading
</ptxt>
</action>
</diag>
