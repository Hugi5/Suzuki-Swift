<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A3206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Demontage en hermontage van het achterasdifferentieelsamenstel
</title>
<servinfosub id = "ADUAP70A3206003001">
<title>
Demontage
</title>
<s1>
<ptxt>
Breng het voertuig omhoog en verwijder de wielen.
</ptxt>
</s1>
<s1>
<ptxt>
Tap olie van het achterasdifferentieel af indien nodig. 
<intxreftitleoff1 refid = "ADUAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de achterste aandrijfassen. 
<intxreftitleoff1 refid = "ADUAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de cardanas van het achterasdifferentieel. 
<intxreftitleoff1 refid = "ADUAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de ontluchtingsslang (1) van het achterasdifferentieel.
</ptxt>
</s1>
<s1>
<ptxt>
Plaats de krik zo dat het differentieelsamenstel niet kantelt.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bouten van de voorste arm van het differentieel (2).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de achterste montagebout van het differentieel (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A320007.swf" width = "88.000mm" height = "57.146mm" ver = "02" gw = "186" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Laat de krik met het achterasdifferentieelsamenstel zakken.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A3206003002">
<title>
Hermontage
</title>
<ptxt>
Voer de demontageprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal iedere bout met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T3B004">
<t-part>
Bout van de voorste arm van het differentieel
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
<torqueitem id = "T3B005">
<t-part>
Achterste montagebout van het differentieel
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
80
</t-value1>
<t-value2>
8,2
</t-value2>
<t-value3>
59,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320008.swf" width = "88.000mm" height = "52.572mm" ver = "02" gw = "186" gh = "133"/>
</figure>
</item>
<item>
<ptxt>
Vul met achterasdifferentieelolie als deze werd afgetapt, 
<intxreftitleoff1 refid = "ADUAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
