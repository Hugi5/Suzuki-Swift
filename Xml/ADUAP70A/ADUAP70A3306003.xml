<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A3306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de tussenbak
</title>
<servinfosub id = "ADUAP70A3306003001">
<title>
Demontage
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Tap de volgende oliën af.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Handgeschakelde-transaxle-olie: 
<intxreftitleoff1 refid = "ADUAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tussenbakolie: 
<intxreftitleoff1 refid = "ADUAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Verwijder het aandrijfassamenstel aan de rechterzijde. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de cardanas. 
<intxreftitleoff1 refid = "ADUAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het voorste hulpchassis. 
<intxreftitleoff1 refid = "ADUAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de achterste motorophanging en de achterste motorophangsteun. 
<intxreftitleoff1 refid = "ADUAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de tussenbakverstevigingsplaat (2) en de tussenbakbouten.
</ptxt>
</s1>
<s1>
<ptxt>
Scheid de tussenbak (1) van de transaxle.
</ptxt>
<attention1>
<ptxt>
Zorg ervoor dat u de tussenbak niet laat vallen tijdens het verwijderen. Anders kan de tussenbak beschadigd worden of kan er lichamelijk letsel opgelopen worden.
</ptxt>
</attention1>
<figure>
<graphic graphicname = "IAP70A330004.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "213" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de O-ring (1) en de paspen (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330005.jpg" width = "88.000mm" height = "52.680mm" ver = "01" gw = "213" gh = "133"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ADUAP70A3306003002">
<title>
Hermontage
</title>
<ptxt>
Keer de demontageprocedure om en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Gebruik een nieuwe O-ring en aandrijfasmoer.
</ptxt>
</item>
<item>
<ptxt>
Breng vet op de O-ring (1) aan.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C004" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A330006.jpg" width = "88.000mm" height = "50.958mm" ver = "02" gw = "213" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Haal de tussenbakbouten met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T3C004">
<t-part>
Tussenbakbout
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Haal de bouten van de tussenbakverstevigingsplaat als volgt aan.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Haal de bouten van de tussenbakverstevigingsplaat &#34;2&#34; en &#34;3&#34; met de hand aan.
</ptxt>
</item>
<item>
<ptxt>
Druk de tussenbakverstevigingsplaat tegen de tussenbak en haal de bouten van de tussenbakverstevigingsplaat in numerieke volgorde (&#34;1&#34;- &#34;5&#34;) gelijkmatig en geleidelijk met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T3C005">
<t-part>
Tussenbakverstevigingsplaatbout*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330007.jpg" width = "88.000mm" height = "56.283mm" ver = "01" gw = "213" gh = "143"/>
</figure>
<figure>
<graphic graphicname = "IAP70A330008.jpg" width = "88.000mm" height = "55.083mm" ver = "01" gw = "202" gh = "140"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Haal de volgende bouten en moeren met het voorgeschreven koppel aan.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Bout van de achterste motorophanging en steunbout: 
<intxreftitleoff1 refid = "ADUAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Montagebout van het voorste hulpchassis: 
<intxreftitleoff1 refid = "ADUAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Gebruik een nieuwe montagebout van het hulpchassis.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Stabilisatorkoppelingsmoer: 
<intxreftitleoff1 refid = "ADUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kogelgewrichtbout van de wieldraagarm: 
<intxreftitleoff1 refid = "ADUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Moer van het trekstanguiteinde: 
<intxreftitleoff1 refid = "ADUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bout van de voorwieltoerentalsensor: 
<intxreftitleoff1 refid = "ADUAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Cardanasbout: 
<intxreftitleoff1 refid = "ADUAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Middensteunmoer: 
<intxreftitleoff1 refid = "ADUAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Uitlaatpijpbout: 
<intxreftitleoff1 refid = "ADUAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bout van uitlaatpijpverstevigingsplaat nr. 1: 
<intxreftitleoff1 refid = "ADUAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Moer aandrijfas: 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Gebruik een nieuwe aandrijfasmoer.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Wielmoer: 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Stuik de aandrijfasmoer dicht. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vul de volgende oliën bij.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Handgeschakelde-transaxle-olie: 
<intxreftitleoff1 refid = "ADUAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
	Tussenbakolie: 
<intxreftitleoff1 refid = "ADUAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Controleer bij elke aansluiting of er geen olie- en uitlaatgaslekkage is.
</ptxt>
</item>
<item>
<ptxt>
Controleer de voorwieluitlijning. 
<intxreftitleoff1 refid = "ADUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
