<title>
DTC B1544
</title>
<servinfosub id = "ADUAP70A7224025001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.118in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.087in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1544: Ongeldige gegevens tussen het HVAC-regelapparaat en het paneel van de automatische A/C
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Het HVAC-regelapparaat heeft een ongeldig signaal naar het paneel van de automatische A/C gezonden.
</ptxt>
</item>
<item>
<ptxt>
Het HVAC-regelapparaat heeft een ongeldig signaal van het paneel van de automatische A/C ontvangen.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Paneel van de automatische A/C
</ptxt>
</item>
<item>
<ptxt>
HVAC-regelapparaat
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A7224025002">
<title>
DTC-controleprocedure
</title>
<s1>
<ptxt>
Start de motor en bedien het A/C-systeem.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7224025003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A7224025004">
<testgroup id = "ADUAP70A7224025005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in en controleer de DTC.
</ptxt>
</test1>
<question>
Wordt DTC B1544 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Monteer een goed bevonden HVAC-regelapparaat en/of paneel van de automatische A/C en controleer de DTC opnieuw.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
HVAC-regelapparaat: 
<intxreftitleoff1 refid = "ADUAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Paneel van de automatische A/C: 
<intxreftitleoff1 refid = "ADUAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Sporadische storing.
</ptxt>
</action>
</testgroup>
</diag>
