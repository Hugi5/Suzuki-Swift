<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1406020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de OCV
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1406017">Componenten van het distributiekettingdeksel</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1406020001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de OCV-stekkerverbinding van de inlaat (zwart) (1) en de OCV-stekkerverbinding van de uitlaat (blauw) (2) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de OCV van de inlaat (3) en de OCV van de uitlaat (4) van het distributiekettingdeksel.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141060.jpg" width = "88.000mm" height = "58.155mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1406020002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij het volgende punt in acht: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de OCV-bouten met het voorgeschreven koppel aan.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1D013">
<t-part>
OCV-bout
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
