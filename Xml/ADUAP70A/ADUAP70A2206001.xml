<sdm-title>
Sporing vooraan (totaal)
</sdm-title>
<sdm-part>
&#34;b&#34; – &#34;a&#34;
</sdm-part>
<sdm1>
<sdm-condition>
</sdm-condition>
<sdm-value>
IN 1 &#177; 1 mm (IN 0,04 &#177; 0,04 in.)
</sdm-value>
</sdm1>
</spec-sdm>
