<servinfo servinfosgmlid = "ADUAP70AA504011" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1122
</title>
<servinfosub id = "ADUAP70AA504011001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.161in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.043in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1122: Storing in de reservevoeding  
</emph>
</ptxt>
<ptxt>
De circuitspanning van de reservevoeding vanuit de &#34;BCM&#34;-zekering is lager dan de voorgeschreven waarde.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
&#34;BCM&#34;-zekering
</ptxt>
</item>
<item>
<ptxt>
Regelapparaat van het startsysteem met afstandsbediening
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70AA504011002">
<title>
DTC-controleprocedure
</title>
<s1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA504011003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70AA504011004">
<testgroup id = "ADUAP70AA504010005">
<title>
Zekeringcontrole
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de &#34;BCM&#34;-zekering.
</ptxt>
</test1>
<question>
Is het in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het regelapparaat van het startsysteem met afstandsbediening en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de &#34;BCM&#34;-zekering en ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA504010006">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC B1122 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de &#34;BCM&#34;-zekering en vervang het regelapparaat van het startsysteem met afstandsbediening en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
