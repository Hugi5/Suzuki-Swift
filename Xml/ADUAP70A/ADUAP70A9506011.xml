<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de voorportierruit
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9506010">Componenten van het voorportier</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A9506011001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Laat de voorportierruit zakken tot ongeveer 150 mm (5,91 in.) van de onderrand van de ruit.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950023.jpg" width = "88.000mm" height = "45.882mm" ver = "02" gw = "225" gh = "114"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.331in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.870in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Ongeveer 150 mm (5,91 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de binnenbekleding van de schuifraamsteun (1).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de kap van de kruk aan de binnenzijde (2).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de schroeven (3), klem (B) en vervolgens de portierbekleding (4) door in de richting van de pijl eraan te trekken.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950025.jpg" width = "88.000mm" height = "101.074mm" ver = "01" gw = "227" gh = "270"/>
</figure>
</s1>
<s1>
<ptxt>
Maak de stekkerverbindingen van de portierbedradingsbundel los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het buitenafdichtrubber van het voorportier (1) door het in volgorde in de richting van de pijlen (&#34;1&#34; tot &#34;2&#34;) zoals op de afbeelding te bewegen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950026.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.071in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.783in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Klauw
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Voorportier-buitenpaneel
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de beugel van de portierbekleding (1) en de portierafdichtkap (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950027.jpg" width = "88.000mm" height = "91.845mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de schroeven (1) en verwijder de voorportierruit (2) door ze in de richting van de pijlen te bewegen in de volgorde (&#34;1&#34; tot &#34;2&#34;) zoals op de afbeelding.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950028.jpg" width = "88.000mm" height = "78.685mm" ver = "02" gw = "225" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9506011002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Monteer de portierruithouders (1) in de voorgeschreven positie van de voorportierruit (2) als deze van de voorportierruit verwijderd worden.
</ptxt>
<spec>
<title>
Montagepositie van de voorportierruithouder
</title>
<ptxt>
&#34;a&#34;: 104 – 106 mm (4,10 – 4,17 in.)
</ptxt>
<ptxt>
&#34;b&#34;: 431,2 – 433,2 mm (16,98 – 17,05 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70P950015.jpg" width = "88.000mm" height = "46.523mm" ver = "01" gw = "191" gh = "115"/>
</figure>
</item>
<item>
<ptxt>
Haal de voorportierruitschroeven in volgorde (&#34;1&#34; tot &#34;2&#34;) zoals op de afbeelding aan.
</ptxt>
</item>
<item>
<ptxt>
Haal de schroeven van de voorruit met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9E002">
<t-part>
Schroef van de voorportierruit*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950029.jpg" width = "88.000mm" height = "81.655mm" ver = "02" gw = "225" gh = "215"/>
</figure>
</item>
<item>
<ptxt>
Repareer de ruitgeleider of vervang deze door een nieuw exemplaar als deze vervormd is.
</ptxt>
</item>
<item>
<ptxt>
Bevestig de portierafdichtkap (1) met butylband (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950031.jpg" width = "88.000mm" height = "81.028mm" ver = "01" gw = "215" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
