<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70AA506005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de achterklepopener en regelschakelaar
</title>
<servinfosub id = "ADUAP70AA506005001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de achterklepbekleding. 
<intxreftitleoff1 refid = "ADUAP70A9606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de achterklepopener, de stekkerverbinding van de regelschakelaar (1) en de klem los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de onderste bekleding van de achterklep. 
<intxreftitleoff1 refid = "ADUAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de schroeven en vervolgens de achterklepopener en de regelschakelaar (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50023.swf" width = "88.000mm" height = "54.154mm" ver = "01" gw = "198" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA506005002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70AA506009">Onderzoek van de regelschakelaar</intxrefpoff>
</ptxt>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
