<servinfosub id = "ADUAP70A7224028002">
<title>
DTC-controleprocedure
</title>
<attention3>
<ptxt>
Controleer bij deze procedure of aan de volgende voorwaarde is voldaan.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
U0073, U0100, U0140 en/of U0155 zijn niet waargenomen
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Start de motor en bedien het A/C-systeem.
</ptxt>
</s1>
<s1>
<ptxt>
B1557: Rijd gedurende ongeveer 1 minuut.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7224028003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A7224028004">
<testgroup id = "ADUAP70A7224028005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer de DTC&#39;s van de ECM. 
<intxreftitleoff1 refid = "ADUAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC. 
<intxreftitleoff1 refid = "ADUAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het HVAC-regelapparaat en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
