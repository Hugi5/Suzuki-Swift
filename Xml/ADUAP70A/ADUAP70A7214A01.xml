<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A7214A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
De aanjagermotor werkt niet
</title>
<diag type = "condition">
<condition>
<ptxt>
De aanjagermotor werkt niet
</ptxt>
</condition>
<ps>
<ptxt>
Gesprongen zekering
</ptxt>
</ps>
<action>
<ptxt>
Controleer de betrokken zekeringen en controleer op kortsluitingen aan de massa.
</ptxt>
</action>
<ps>
<ptxt>
Defect aanjagermotorrelais
</ptxt>
</ps>
<action>
<ptxt>
Controleer het aanjagermotorrelais. 
<intxreftitleoff1 refid = "ADUAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte aanjagermotorweerstand
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aanjagermotorweerstand. 
<intxreftitleoff1 refid = "ADUAP70A7216012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte aanjagerdebiet-keuzeschakelaar
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aanjagerdebiet-keuzeschakelaar. 
<intxreftitleoff1 refid = "ADUAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
<ps>
<ptxt>
Defecte aanjagermotor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aanjagermotor. 
<intxreftitleoff1 refid = "ADUAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Er is vreemd materiaal aanwezig
</ptxt>
</ps>
<action>
<ptxt>
Verwijder het vreemde materiaal.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
