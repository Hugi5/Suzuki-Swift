<servinfo servinfosgmlid = "ADUAP70A9306006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Onderzoek van de parkeersensor (indien uitgerust)
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9306005">Uit- en inbouw van de parkeersensor (indien uitgerust)</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Controleer de parkeersensor op beschadiging.
</ptxt>
</item>
<item>
<ptxt>
Controleer de parkeersensorstekker op beschadiging.
</ptxt>
</item>
<item>
<ptxt>
Controleer de parkeersensorstekker op verbuiging, roest of corrosie.
</ptxt>
<ptxt>
Vervang de parkeersensor als er een defect wordt vastgesteld.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
