<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70AA314010" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1644
</title>
<servinfosub id = "ADUAP70AA314010001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.166in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.039in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1644: Startblokkerings-ID niet passend
</emph>
</ptxt>
<ptxt>
Controlefout tussen de ECM en de BCM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Contactsleutel
</ptxt>
</item>
<item>
<ptxt>
De ID-code van de ECM is niet in de BCM geregistreerd
</ptxt>
</item>
<item>
<ptxt>
Contactsleutel is niet geregistreerd
</ptxt>
</item>
<item>
<ptxt>
Regelapparaatcircuit/stekkerverbinding van het startblokkeersysteem
</ptxt>
</item>
<item>
<ptxt>
Regelapparaat van het startblokkeersysteem
</ptxt>
</item>
<item>
<ptxt>
BCM-voedings-/massacircuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70AA314010002">
<title>
DTC-storingzoeken
</title>
<attention3>
<ptxt>
Als de BCM met een ander (gebruikt) voertuig is geregistreerd, kan de contactsleutel niet geregistreerd worden. Monteer altijd een nieuwe BCM als vervanging noodzakelijk is.
</ptxt>
</attention3>
<diag type = "test" id = "ADUAP70AA314010003">
<testgroup id = "ADUAP70AA314010004">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Lees de DTC&#39;s in de BCM af. 
<intxreftitleoff1 refid = "ADUAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1188, B1189 of B1190 waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA314010005">
<title>
Controle van het BCM-voedings- en -massacircuit
</title>
<test1>
<ptxt>
Controleer het voedings- en massacircuit van de BCM. 
<intxreftitleoff1 refid = "ADUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA314010006">
<title>
ECM-registratie
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70AA316003">ECM-registratie:Model met contactslot</intxref>
 uit.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC P1644 nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (De ECM was niet geregistreerd)
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA314010007">
<title>
Contactsleutelregistratie
</title>
<test1>
<ptxt>
Voer &#34;Sleutelregistratie startblokkering&#34; uit. 
<intxreftitleoff1 refid = "ADUAP70AA316002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC P1644 nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. Als DTC P1644 nog steeds wordt waargenomen, vervang dan de BCM en controleer de DTC opnieuw.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "ADUAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (Contactsleutel werd niet geregistreerd)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
