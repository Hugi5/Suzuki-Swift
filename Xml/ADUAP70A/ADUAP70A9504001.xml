<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A9504001" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Diagnose van de symptomen van de elektrisch bediende ruit
</title>
<diag type = "condition" id = "ADUAP70A9504001001">
<condition>
<ptxt>
Er werkt geen enkele elektrisch bediende ruit
</ptxt>
</condition>
<ps>
<ptxt>
Defecte bedrading
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
<ps>
<ptxt>
Defecte hoofdschakelaar van de elektrisch bediende ruit
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9506019">Onderzoek van de hoofdschakelaar van de elektrisch bediende ruit</intxref>
</ptxt>
</action>
<condition>
<ptxt>
Een van de elektrisch bediende ruiten werkt niet
</ptxt>
</condition>
<ps>
<ptxt>
Defecte bedrading
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
<ps>
<ptxt>
Defect(e) openingsmechanisme en/of motor van de elektrisch bediende ruit
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Voor: 
<intxreftitleoff1 refid = "ADUAP70A9506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Achter: 
<intxreftitleoff1 refid = "ADUAP70A9506018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Defecte hoofdschakelaar van de elektrisch bediende ruit
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9506019">Onderzoek van de hoofdschakelaar van de elektrisch bediende ruit</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte hulpschakelaar van de elektrisch bediende ruit
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9506020">Onderzoek van de hulpschakelaar van de elektrisch bediende ruit</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Ruitvergrendelschakelaar wordt ingedrukt (vergrendelstand)
</ptxt>
</ps>
<action>
<ptxt>
Schakel de ruitvergrendelschakelaar uit.
</ptxt>
</action>
<condition>
<ptxt>
Automatische functie omlaag werkt niet
</ptxt>
</condition>
<ps>
<ptxt>
Defecte hoofdschakelaar van de elektrisch bediende ruit
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9506019">Onderzoek van de hoofdschakelaar van de elektrisch bediende ruit</intxref>
</ptxt>
</action>
<condition>
<ptxt>
Abnormaal geluid
</ptxt>
</condition>
<ps>
<ptxt>
Montagebouten van het ruitopeningsmechanisme zitten los
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Haal de montagebouten van het ruitopeningsmechanisme aan.
</ptxt>
<ptxt>
Voor: 
<intxreftitleoff1 refid = "ADUAP70A9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Achter: 
<intxreftitleoff1 refid = "ADUAP70A9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Glijdende en draaiende onderdelen van het openingsmechanisme van de elektrisch bediende ruit zijn versleten of kapot
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vervang het ruitopeningsmechanisme.
</ptxt>
<ptxt>
Voor: 
<intxreftitleoff1 refid = "ADUAP70A9506012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Achter: 
<intxreftitleoff1 refid = "ADUAP70A9506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Slechte smering
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Smeren.
</ptxt>
<ptxt>
Voor: 
<intxreftitleoff1 refid = "ADUAP70A9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Achter: 
<intxreftitleoff1 refid = "ADUAP70A9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
