<item>
<ptxt>
Bedradingsbundel en aansluitingen
</ptxt>
</item>
<item>
<ptxt>
MAF-sensor 
<intxreftitleoff1 refid = "ADUAP70A1306026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
