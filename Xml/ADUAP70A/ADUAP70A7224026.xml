<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A7224026" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1546
</title>
<servinfosub id = "ADUAP70A7224026001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.937in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.274in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1546: Storing in de A/C-koelmiddeldruk
</emph>
</ptxt>
<ptxt>
De A/C-koelmiddeldruk is lager dan de voorgeschreven waarde, ookal is de buitentemperatuur hoger dan de voorgeschreven waarde.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
A/C-koelmiddeldruksensor
</ptxt>
</item>
<item>
<ptxt>
Buitenluchttemperatuursensor
</ptxt>
</item>
<item>
<ptxt>
Onvoldoende koelmiddel
</ptxt>
</item>
<item>
<ptxt>
HVAC-regelapparaat
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A7224026002">
<title>
DTC-controleprocedure
</title>
<s1>
<ptxt>
Start de motor en bedien het A/C-systeem.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7224026003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A7224026004">
<testgroup id = "ADUAP70A7224026005">
<title>
Controle A/C-koelmiddeldruk
</title>
<test1>
<ptxt>
Draai de A/C-schakelaar om en bedien de A/C-compressor.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de &#34;koelmiddeldruk&#34; met de &#34;Datalijst&#34;-modus op het SUZUKI-uitleesapparaat. 
<intxreftitleoff1 refid = "ADUAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is de druk hoger dan 0,34 Mpa?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vul koelmiddel bij en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224026006">
<title>
Controle van de A/C-koelmiddeldruksensor
</title>
<test1>
<ptxt>
Controleer de A/C-koelmiddeldruksensor. 
<intxreftitleoff1 refid = "ADUAP70A7226022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is de sensor in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de A/C-koelmiddeldruksensor. 
<intxreftitleoff1 refid = "ADUAP70A7226023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224026007">
<title>
Controle van de buitenluchttemperatuursensor
</title>
<test1>
<ptxt>
Controleer de buitenluchttemperatuursensor. 
<intxreftitleoff1 refid = "ADUAP70AA206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is de sensor in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de buitenluchttemperatuursensor. 
<intxreftitleoff1 refid = "ADUAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224026008">
<title>
Controle van het A/C-systeem
</title>
<test1>
<ptxt>
Controleer het A/C-systeem. 
<intxreftitleoff1 refid = "ADUAP70A7224001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het systeem in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het HVAC-regelapparaat en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Voer 
<intxref refid = "ADUAP70A7224002">Storingsdiagnose bij abnormale druk:Automatisch type</intxref>
 uit en controleer opnieuw op DTC&#39;s.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
