<servinfo servinfosgmlid = "ADUAP70A9204A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Stadslichten, achterlichten of kentekenplaatverlichting gaan niet branden
</title>
<diag type = "condition">
<condition>
<ptxt>
Stadslichten, achterlichten of kentekenplaatverlichting gaan niet branden
</ptxt>
</condition>
<ps>
<ptxt>
Defect systeemcircuit (inclusief relais en zekeringen)
</ptxt>
</ps>
<action>
<ptxt>
Repareer het circuit.
</ptxt>
</action>
<ps>
<ptxt>
Gesprongen gloeilampen
</ptxt>
</ps>
<action>
<ptxt>
Vervang de gloeilampen.
</ptxt>
</action>
<ps>
<ptxt>
Defecte licht- en richtingaanwijzerschakelaar
</ptxt>
</ps>
<action>
<ptxt>
Zie 
<intxref refid = "ADUAP70A9206015">Onderzoek van de licht- en richtingaanwijzerschakelaar</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Defecte BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Zie &#34;Onderzoek van de BCM en de bijbehorende circuits&#34; in hoofdstuk 10B.
</ptxt>
<ptxt>
Model met contactslot: 
<intxreftitleoff1 refid = "ADUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model met drukknopstartsysteem: 
<intxreftitleoff1 refid = "ADUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
