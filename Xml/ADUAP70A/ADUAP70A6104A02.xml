<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A6104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Te veel speling in stuurinrichting
</title>
<diag type = "condition">
<condition>
<ptxt>
Te veel speling in stuurinrichting
</ptxt>
</condition>
<ps>
<ptxt>
Versleten wiellagers
</ptxt>
</ps>
<action>
<ptxt>
Vervang het wiellager. 
<intxreftitleoff1 refid = "ADUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loszittende stuurhuisbout
</ptxt>
</ps>
<action>
<ptxt>
Draai de stuurhuisbout aan. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defect stuurhuissamenstel
</ptxt>
</ps>
<action>
<ptxt>
Vervang het stuurhuissamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Versleten koppeling van de stuurkolom
</ptxt>
</ps>
<action>
<ptxt>
Vervang het stuurkolomsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Versleten trekstanguiteinde of kogelgewricht van trekstang
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vervang het trekstanguiteinde of de trekstang.
</ptxt>
<ptxt>
Trekstanguiteinde: 
<intxreftitleoff1 refid = "ADUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Trekstang: 
<intxreftitleoff1 refid = "ADUAP70A6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Versleten wieldraagarmkoppeling
</ptxt>
</ps>
<action>
<ptxt>
Vervang de wieldraagarm. 
<intxreftitleoff1 refid = "ADUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Onjuist tandcontact tussen rondsel en tandheugel
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controleer de voorspanning van de rondsel- en tandheugelas. 
<intxreftitleoff1 refid = "ADUAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Vervang het stuurhuissamenstel als er een defect wordt vastgesteld. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
