<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A3306005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Demontage en hermontage van het tussenbaksamenstel
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A3306003">Uitbouw en inbouw van de tussenbak</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ADUAP70A3306004">Componenten van de tussenbak</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A3306005001">
<title>
Demontage
</title>
<s1>
<ptxt>
Verwijder de oliekeerring nr. 1 (1) met behulp van speciaal gereedschap van het rechtse tussenbakhuis.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C001">
<s-part>
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Verwijder de veerring (2) met een veerringtang.
</ptxt>
</s1>
<s1>
<ptxt>
Haal de tussenas (4) samen met het tussenaslager (3) uit het tussenbaksamenstel.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het tussenaslager (3) van de tussenas (4) met een lagertrekker en een hydraulische pers.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330008.swf" width = "88.000mm" height = "26.342mm" ver = "01" gw = "155" gh = "58"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de opsluitplaat van de uitgaande as van de tussenbak (1) en de afstandsring (3) door de aanslagbouten (2) te verwijderen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A330010.swf" width = "88.000mm" height = "55.632mm" ver = "01" gw = "206" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de tussenbakhuisbouten (1).
</ptxt>
</s1>
<s1>
<ptxt>
Scheid het rechtse tussenbakhuis (2) met speciaal gereedschap van het linkse tussenbakhuis (3).
</ptxt>
<servicetool>
<servicetoolitem id = "L3C002">
<s-part>
</s-part>
<s-number num = "09912-34510">
09912-34510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330011.swf" width = "88.000mm" height = "57.119mm" ver = "02" gw = "143" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het samenstel van aandrijfreductietandwielen (1) en aangedreven reductietandwielen (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330012.swf" width = "88.000mm" height = "45.732mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de buitenlagerloopringen (1) en de afstandsring (2).
</ptxt>
<attention3>
<ptxt>
Maak moeilijk te verwijderen buitenlagerloopringen met speciaal gereedschap los van het huis.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C003">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944-96011
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330013.swf" width = "88.000mm" height = "51.937mm" ver = "01" gw = "196" gh = "131"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A3306005002">
<title>
Hermontage
</title>
<s1>
<ptxt>
Kies als volgt een geschikte afstandsring.
</ptxt>
<s2>
<ptxt>
Meet afstand &#34;a&#34; tussen de buitenloopringen van het conische rollager van het samenstel van aangedreven reductietandwielen (1).
</ptxt>
</s2>
<s2>
<ptxt>
Meet diepte &#34;b&#34; van het linkse huis (2) en &#34;c&#34; van het rechtse huis (3).
</ptxt>
</s2>
<s2>
<ptxt>
Bereken de afstandsstelringdikte als volgt.
</ptxt>
<ptxt>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "9" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.748in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.157in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.451in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.157in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.451in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.157in"/>
<colspec colnum = "7" colname = "7" colwidth = "0.560in"/>
<colspec colnum = "8" colname = "8" colwidth = "0.157in"/>
<colspec colnum = "9" colname = "9" colwidth = "0.591in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "middle" align = "center">
<ptxt>
Benodigde afstandsringdikte
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
=
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Diepte &#34;b&#34;
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Diepte &#34;c&#34;
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
-
</ptxt>
</entry>
<entry colname = "7" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Afstand &#34;a&#34;
</ptxt>
</entry>
<entry colname = "8" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "9" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "middle" align = "center">
<ptxt>
0,1 mm (0,004 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<figure>
<graphic graphicname = "IAP70A330014.swf" width = "88.000mm" height = "40.526mm" ver = "02" gw = "225" gh = "98"/>
</figure>
</s2>
<c-change/>
<s2>
<ptxt>
Kies afstandsringen uit de volgende beschikbare maten zodat de totale dikte van de rechtse en linkse afstandsringen de berekende waarde bereikt.
</ptxt>
<ptxt>
<emph etype = "bold">
Bijvoorbeeld:
</emph>
</ptxt>
<ptxt>
De gemeten afstand &#34;a&#34; is 101,75 mm (4,006 in.).
</ptxt>
<ptxt>
De gemeten diepte &#34;b&#34; is 77,95 mm (3,069 in.).
</ptxt>
<ptxt>
De gemeten diepte &#34;c&#34; is 25,80 mm (1,016 in.).
</ptxt>
<ptxt>
Noodzakelijke afstandsringdikte = 77,95 mm (3,069 in.) + 25,80 mm (1,016 in.) – 101,75 mm (4,006 in.) + 0,1 mm (0,004 in.) = 2,10 mm (0,083 in.)
</ptxt>
<spec>
<title>
Beschikbare afstandsringdikte van het aangedreven reductietandwiel
</title>
<ptxt>
Rechts: 
</ptxt>
<ptxt>
0,60, 0,65, 0,70, 0,75, 0,80, 0,85, 0,90, 0,95, 1,00 en 1,05 mm (0,024, 0,026, 0,028, 0,030, 0,031, 0,033, 0,035, 0,037, 0,039 en 0,041 in.) 
</ptxt>
<ptxt>
Links: 
</ptxt>
<ptxt>
1,00, 1,05, 1,10, 1,15, 1,20, 1,25, 1,30, 1,35, 1,40 en 1,45 mm (0,039, 0,041, 0,043, 0,045, 0,047, 0,049, 0,051, 0,053, 0,055 en 0,057 in.) 
</ptxt>
</spec>
</s2>
</s1>
<s1>
<ptxt>
Reinig het pasvlak van het rechtse en linkse huis en smeer afdichtmiddel met een diameter van 1,2 mm (0,047 in.) op het rechtse huis (1) zoals op de afbeelding.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3C005" uid = "-491504098">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Afdichtmiddel
</m-desc>
<m-number>
99000-31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I5RW0A330011.swf" width = "88.000mm" height = "42.399mm" ver = "01" gw = "155" gh = "104"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de volgende onderdelen in het rechtse en linkse huis in de omgekeerde volgorde van de demontage.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Samenstel van aandrijfreductietandwielen (1)
</ptxt>
</item>
<item>
<ptxt>
Samenstel van aangedreven reductietandwielen (2)
</ptxt>
</item>
<item>
<ptxt>
Buitenlagerloopringen (3)
</ptxt>
</item>
<item>
<ptxt>
Afstandsringen van het aangedreven reductietandwiel (4)
</ptxt>
</item>
<item>
<ptxt>
Paspen (5)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A330015.jpg" width = "88.000mm" height = "60.349mm" ver = "01" gw = "213" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Haal de tussenbakhuisbouten met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T3C006">
<t-part>
Tussenbakhuisbout
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330016.swf" width = "88.000mm" height = "61.238mm" ver = "01" gw = "169" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Kies een pignonafstandsring (3) volgens stap 1) van &#34;Hermontage&#34; onder 
<intxref refid = "ADUAP70A3306009">Demontage en hermontage van de opsluitplaat van de uitgaande as van de tussenbak</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Onderzoek het tandcontact zoals beschreven in 
<intxref refid = "ADUAP70A3306011">Onderzoek van tandcontact van het conische tandwiel</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het opsluitplaatsamenstel van de uitgaande as van de tussenbak (2) op het linkse tussenbakhuis (3) samen met de pignonafstandsring (1) en haal de aanslagbouten met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T3C007">
<t-part>
Opsluitplaatbout van de uitgaande as van de tussenbak
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330017.swf" width = "88.000mm" height = "45.870mm" ver = "01" gw = "165" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de bout in het boutgat van de flens (2) en plaats het meetuiteinde van de meetklok haaks op de bout (1) zoals op de afbeelding. Hou het aangedreven reductietandwiel vast met de hand en meet de speling van de pignon en het conische tandwiel.
</ptxt>
<attention3>
<ptxt>
Als de speling de voorgeschreven waarde hieronder overschrijdt, stel ze dan bij door de dikteverhouding van de gemonteerde afstandsringen in het rechtse en linkse huis in stap 3) te wijzigen.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C004">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900-20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3C005">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900-20701
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Speling van de pignon en het conische tandwiel
</title>
<ptxt>
: 0,1 – 0,2 mm (0,0039 – 0,0078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330018.swf" width = "88.000mm" height = "39.091mm" ver = "01" gw = "157" gh = "94"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer het tussenaslager (1) met speciaal gereedschap op de tussenas (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L3C006">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913-84510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A330015.swf" width = "88.000mm" height = "48.692mm" ver = "01" gw = "71" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de tussenas (2) samen met het lager (3) in de tussenbak.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer een nieuwe veerring (1) met een veerringtang op het rechtse tussenbakhuis.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330016.swf" width = "88.000mm" height = "26.757mm" ver = "02" gw = "133" gh = "59"/>
</figure>
</s1>
<s1>
<ptxt>
Breng vet op de nieuwe oliekeerringlip nr. 1 van het rechtse huis aan.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C006" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Drijf de oliekeerring van het rechtse huis nr. 1 (1) met speciaal gereedschap en een hamer in het rechtse tussenbakhuis (2).
</ptxt>
<servicetool>
<servicetoolitem id = "L3C007">
<s-part>
(A)
</s-part>
<s-number num = "09925-16010">
09925-16010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Montagediepte van de uitgangstussenoliekeerring
</title>
<ptxt>
&#34;a&#34;: 1,0 – 2,0 mm (0,039 – 0,078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330042.swf" width = "88.000mm" height = "45.592mm" ver = "01" gw = "201" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
