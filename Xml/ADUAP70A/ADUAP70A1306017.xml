<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1306017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de CMP-sensor
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1306016">Onderzoek in het voertuig van de CMP-sensor</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1306017001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de CMP-sensor van de inlaat (1) en de CMP-sensor van de uitlaat (2) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de CMP-sensor van de inlaat (1) en de CMP-sensor van de uitlaat (2) van de cilinderkop.
</ptxt>
<figure>
<graphic graphicname = "I9P60A131006.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1306017002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1306018">Onderzoek van de CMP-sensor</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Breng motorolie op de O-ring van de sensor aan.
</ptxt>
</item>
<item>
<ptxt>
Draai de CMP-sensorbout met het voorgeschreven koppel aan.
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Gebruik nieuwe bouten die met kleefmiddel zijn voorbehandeld. Anders kunnen de bouten loskomen.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1C005">
<t-part>
CMP-sensorbout van de inlaat
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1C006">
<t-part>
CMP-sensorbout van de uitlaat
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131007.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
