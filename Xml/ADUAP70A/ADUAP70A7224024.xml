<servinfosub id = "ADUAP70A7224024004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A7224024005">
<testgroup id = "ADUAP70A7224024006">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in en controleer de DTC.
</ptxt>
</test1>
<question>
Wordt DTC B1541 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sporadische storing.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224024008">
<title>
Zekeringcontrole
</title>
<test1>
<ptxt>
Controleer de &#34;MTR&#34;-zekering.
</ptxt>
</test1>
<question>
Is ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de &#34;MTR&#34;-zekering en controleer op kortsluiting aan de massa.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224024007">
<title>
Controle van het accuvoedingscircuit
</title>
<test1>
<ptxt>
Maak de &#34;G20&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Meet de spanning tussen de &#34;WHT/RED&#34;-draadaansluiting van de &#34;G20&#34;-stekkerverbinding en de massa.
</ptxt>
</test1>
<question>
Is de spanning 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het HVAC-regelapparaat en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
