<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70AA206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de BCM
</title>
<servinfosub id = "ADUAP70AA206003001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Stel het airbagsysteem buiten werking. 
<intxreftitleoff1 refid = "ADUAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het stuurkolomopeningsdeksel. Zie hiervoor stap 4) in 
<intxref refid = "ADUAP70A6206009">Uit- en inbouw van de stuurkolom</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de zijbekleding van het dashboard. 
<intxreftitleoff1 refid = "ADUAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Koppel de stekkerverbindingen (1) en de klemmen van het J/B (2) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de moeren (3) en vervolgens het J/B.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20016.jpg" width = "88.000mm" height = "78.207mm" ver = "01" gw = "202" gh = "205"/>
</figure>
</s1>
<s1>
<ptxt>
Koppel de stekkerverbindingen (1) van de BCM (2) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de moeren van de BCM (3) en vervolgens de BCM.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20017.jpg" width = "88.000mm" height = "82.962mm" ver = "01" gw = "198" gh = "219"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA206003002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.	
</ptxt>
</servinfosub>
<list1 type = "unordered">
<item>
<ptxt>
Haal de moeren van de BCM met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T10B001">
<t-part>
Moer van de BCM
</t-part>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Activeer het airbagsysteem. 
<intxreftitleoff1 refid = "ADUAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Als de BCM vervangen moet worden, moet u 
<intxref refid = "ADUAP70AA206002">BCM-registratie (model met contactslot)</intxref>
 uitvoeren.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
