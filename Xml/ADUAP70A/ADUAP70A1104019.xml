<servinfosub id = "ADUAP70A1104019003">
<title>
DTC-controleprocedure
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Zorg dat u eerst onverwachte DTC&#39;s oplost die eerder tijdens de &#34;DTC-controleprocedure&#34; zijn waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Controleer of aan de volgende voorwaarde in deze &#34;DTC-controleprocedure&#34; is voldaan.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0107, P0108, P2119, P2135, P2138, P2228 of P2229 wordt niet waargenomen.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Laat de motor gedurende 30 sec stationair draaien.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1104019004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A1104019005">
<testgroup id = "ADUAP70A1104019006">
<question>
Is de &#34;Controle van het motor- en emissieregelsysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A1104001">Controle van het motor- en emissieregelsysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104019007">
<title>
Controle van het luchtinlaatsysteem
</title>
<test1>
<ptxt>
Controleer het luchtinlaatsysteem op verstopping of lekkage.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang het luchtinlaatsysteem.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104019008">
<title>
Controle van het MAP-sensorcircuit
</title>
<test1>
<ptxt>
Controleer de MAP-sensorcircuits in overeenstemming met stap 2 tot 4 onder 
<intxref refid = "ADUAP70A1104020">DTC P0107 / P0108</intxref>
.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104019009">
<title>
Controle van de MAP-sensor
</title>
<test1>
<ptxt>
Controleer de MAP-sensor. 
<intxreftitleoff1 refid = "ADUAP70A1306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de MAP-sensor.
</ptxt>
</action>
</testgroup>
</diag>
