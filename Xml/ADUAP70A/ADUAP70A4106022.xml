<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de rembekrachtiger
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A4106020">Componenten van de rembekrachtiger</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A4106022001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de remleidingen (1) met speciaal gereedschap los van het hydraulische regeleenheid/regelapparaatsamenstel (2) van het ESP<sup>&#174;</sup>-systeem.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410035.swf" width = "88.000mm" height = "45.139mm" ver = "02" gw = "117" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het hoofdremcilindersamenstel van de rembekrachtiger.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de vacuümslang los van de rembekrachtiger.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de klem (1) en de gaffelpen (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410036.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de rembekrachtigermoeren (1) en verwijder de rembekrachtiger van het dashboardpaneel.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410037.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A4106022004">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A4106023">Onderzoek van de rembekrachtiger</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Draai de moer (1) van de rempedaallagersteun en de bout (2) van de bovenste schutbordverstevigingsplaat los.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de rembekrachtiger op het dashboardpaneel. Verbind vervolgens de stoterstanggaffel (3) met de rempedaalarm met behulp van een gaffelpen (2) en een klem (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A410040.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het combimeter-instrumentenpaneel. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Haal de moeren van de rembekrachtiger met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T4A006">
<t-part>
Moer van de rembekrachtiger*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410041.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Haal de moer van de rempedaallagersteun met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
Moer van de rempedaallagersteun
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Haal de bovenste schutbordverstevigingsplaatbout met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
Bovenste schutbordverstevigingsplaatbout
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410042.swf" width = "88.000mm" height = "64.412mm" ver = "02" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer het meterinstrumentenpaneel.
</ptxt>
</s1>
<s1>
<ptxt>
Sluit de vacuümslang op de rembekrachtiger aan.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het hoofdremcilindersamenstel aan de rembekrachtiger.
</ptxt>
</s1>
<s1>
<ptxt>
Verbind de remleidingen (1) met speciaal gereedschap met het hydraulische regeleenheid/regelapparaatsamenstel (2) van het ESP<sup>&#174;</sup>-systeem.
</ptxt>
<torque>
<torqueitem id = "T4A009">
<t-part>
Flensmoer van de remleiding
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410043.swf" width = "88.000mm" height = "46.684mm" ver = "02" gw = "119" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Ontlucht het remsysteem na montage. 
<intxreftitleoff1 refid = "ADUAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controleer de gemonteerde onderdelen op remvloeistoflekkage.
</ptxt>
</s1>
<s1>
<ptxt>
Controleer het rempedaal op speling. 
<intxreftitleoff1 refid = "ADUAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zorg ervoor dat het remsysteem op de juiste wijze werkt zonder remvloeistoflekkage.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
