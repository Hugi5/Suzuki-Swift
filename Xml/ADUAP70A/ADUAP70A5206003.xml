<servinfo servinfosgmlid = "ADUAP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Vervanging van de oliekeerring aan de zijkant van het differentieel
</title>
<s1>
<ptxt>
Krik het voertuig omhoog en tap de transaxle-olie af.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het linker aandrijfassamenstel. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de oliekeerring (1) met speciaal gereedschap.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522004.swf" width = "88.000mm" height = "48.454mm" ver = "01" gw = "146" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de nieuwe oliekeerring (1) met speciaal gereedschap.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Monteer de oliekeerring met de veerzijde naar binnen gericht.
</ptxt>
</item>
<item>
<ptxt>
Monteer de oliekeerring evenwijdig met het oppervlak van het linkse huis (2).
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
09944-88220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Afstand tussen het oppervlak van het huis en de oliekeerring
</title>
<ptxt>
&#34;a&#34;: 0 – 1,0 mm (0 – 0,04 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Smeer vet op de oliekeerringlip en controleer de raakpunten van de aandrijfas en de oliekeerring op soepelheid.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B004" uid = "22">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A522005.swf" width = "88.000mm" height = "44.718mm" ver = "02" gw = "110" gh = "110"/>
</figure>
</s1>
<s1>
<ptxt>
Plaats het linker aandrijfassamenstel. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vul transaxle-olie bij. 
<intxreftitleoff1 refid = "ADUAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
