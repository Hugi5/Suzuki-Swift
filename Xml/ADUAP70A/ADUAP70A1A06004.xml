<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1A06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de waterpomp / dynamoaandrijfriem
</title>
<servinfosub id = "ADUAP70A1A06004001" page = "2">
<title>
Uitbouw
</title>
<s1 page = "2">
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de rechtse beschermplaat aan de onderkant van de motor.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder de compressoraandrijfriem alvorens de waterpomp-/dynamoaandrijfriem (1) te verwijderen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met handbediende A/C: 
<intxreftitleoff1 refid = "ADUAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model met automatische A/C: 
<intxreftitleoff1 refid = "ADUAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Draai de dynamobout (2) en de dynamospilbout (3) los.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Draai de dynamostelbout (4) los en verwijder dan de waterpomp-/dynamoaandrijfriem.
</ptxt>
<figure>
<graphic graphicname = "I7V20A1A1008.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "148" gh = "123"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1A06004002" page = "2">
<title>
Inbouw
</title>
<s1 page = "2">
<ptxt>
Monteer de waterpomp-/dynamoaandrijfriem (1) op de waterpomppoelie (2), de krukaspoelie (3) en de dynamopoelie (4).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Stel de riemspanning bij. 
<intxreftitleoff1 refid = "ADUAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de compressoraandrijfriem.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met handbediende A/C: 
<intxreftitleoff1 refid = "ADUAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model met automatische A/C: 
<intxreftitleoff1 refid = "ADUAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Zorg ervoor dat de aandrijfriem correct is gemonteerd in de groeven van iedere poelie.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I7V20A1A1009.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "140" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de rechtse beschermplaat aan de onderkant van de motor.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Sluit de negatieve kabel (–) op de accu aan.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
