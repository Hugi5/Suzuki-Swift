<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9F06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de audio-eenheid
</title>
<servinfosub id = "ADUAP70A9F06001001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het middenventilatierooster. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de audio-eenheid (1) uit het instrumentenpaneel door de 2 montageschroeven (2) te verwijderen.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbindingen van de audio-eenheid (3) los.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0004.jpg" width = "88.000mm" height = "63.065mm" ver = "03" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9F06001002">
<title>
Inbouw
</title>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
