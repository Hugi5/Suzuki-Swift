<servinfosub id = "ADUAP70A6304014003">
<title>
DTC-controleprocedure
</title>
<ptxt>
Laat de motor langer dan 5 seconden stationair draaien.
</ptxt>
</servinfosub>
<servinfosub id = "ADUAP70A6304014004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A6304014005">
<testgroup id = "ADUAP70A6304014006">
<question>
Is &#34;controle van het P/S-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A6304001">Controle van het P/S-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304014007">
<title>
Controle van het hoofdvoedings- en massacircuit van het P/S-regelapparaat
</title>
<test1>
<ptxt>
Controleer de circuits &#34;A1&#34; en &#34;A2&#34;. 
<intxreftitleoff1 refid = "ADUAP70A6304021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304014008">
<title>
Controle van de voedingsspanning van het P/S-regelapparaat
</title>
<test1>
<ptxt>
Meet de accuspanning terwijl de motor stationair draait.
</ptxt>
</test1>
<test1>
<ptxt>
Meet de accuspanning terwijl de motor 3.000 omw/min draait.
</ptxt>
</test1>
<question>
Ligt de spanning tussen 9 V en 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het P/S-regelapparaat en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controleer het laadsysteem. 
<intxreftitleoff1 refid = "ADUAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
