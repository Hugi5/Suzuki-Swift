<servinfosub id = "ADUAP70AA504024003">
<title>
DTC-controleprocedure
</title>
<s1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</s1>
<s1>
<ptxt>
Zet het contactslot op &#34;ACC&#34;.
</ptxt>
</s1>
<s1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</s1>
<s1>
<ptxt>
Herhaal meermaals stap 1) tot en met 3).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA504024004">
<title>
DTC-storingzoeken
</title>
<attention3>
<ptxt>
Deze DTC kan waargenomen worden als de batterij leeg of de spanning erg laag is.
</ptxt>
</attention3>
<diag type = "test" id = "ADUAP70AA504024005">
<testgroup id = "ADUAP70AA504024012">
<title>
Controle van de parameter
</title>
<test1>
<ptxt>
Sluit het SUZUKI-uitleesapparaat op de DLC aan met de ontsteking uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de weergave &#34;Onstekingsrelais 2&#34; op het SUZUKI-uitleesapparaat. 
<intxreftitleoff1 refid = "ADUAP70AA504007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Einde. (Sporadische storing.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA504024006">
<title>
Controle van het voedingscircuit van het IG2-relais (schakelaarzijde)
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Verwijder het IG2-relais.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de spanning tussen circuit &#34;A3&#34; en de massa accuspanning is.
</ptxt>
</test1>
<question>
Is het in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel en de &#34;IGN2&#34;-zekering.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA504024007">
<title>
Zekeringcontrole
</title>
<test1>
<ptxt>
Controleer de &#34;IG2 SIG&#34;-zekering.
</ptxt>
</test1>
<question>
Is ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA504024008">
<title>
Controle van signaalcircuit van het IG2-relais
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;L10&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de aansluitklemmen goed op stekkerverbinding &#34;L10&#34; zijn aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Als de aansluitingen in orde zijn, controleer dan de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand tussen circuit &#34;B3&#34; en de massa: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;B3&#34; en elke aansluitklem aan de stekkerverbinding van het IG2-relais: oneindig
</ptxt>
</item>
</list1>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de &#34;IG2 SIG&#34;-zekering en het regelapparaat van het startsysteem met afstandsbediening en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel en vervang vervolgens de &#34;IG2 SIG&#34;-zekering.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA504024009">
<title>
Controle van signaalcircuit van het IG2-relais
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;L10&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de aansluitklemmen goed op stekkerverbinding &#34;L10&#34; zijn aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Als de aansluitingen in orde zijn, controleer dan de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van circuit &#34;B3&#34;: minder dan 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;B3&#34; en elke aansluitklem aan de stekkerverbinding van het IG2-relais: oneindig
</ptxt>
</item>
<item>
<ptxt>
Spanning van circuit &#34;B3&#34;: 0 – 1 V (als de ontsteking is ingeschakeld)
</ptxt>
</item>
</list1>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA504024010">
<title>
Controle van het voedingscircuit van het IG2-relais (spoelzijde)
</title>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van circuit &#34;C3&#34;: minder dan 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuit &#34;C3&#34; en de massa: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;C3&#34; en elke aansluitklem aan de stekkerverbinding van het IG2-relais: oneindig
</ptxt>
</item>
<item>
<ptxt>
Spanning van circuit &#34;C3&#34;: 0 – 1 V (als de ontsteking is ingeschakeld)
</ptxt>
</item>
</list1>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA504024011">
<title>
Voeding van het IG2-relais
</title>
<test1>
<ptxt>
Controleer het IG2-relais. 
<intxreftitleoff1 refid = "ADUAP70AA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het IG2-relais.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA504024013">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Sluit stekkerverbinding &#34;L10&#34; aan en monteer het IG2-relais.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt de huidige DTC B1193 waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het regelapparaat van het startsysteem met afstandsbediening en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (Sporadische storing.)
</ptxt>
</action>
</testgroup>
