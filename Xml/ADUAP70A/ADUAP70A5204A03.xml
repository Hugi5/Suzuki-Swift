<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A5204A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Lawaai
</title>
<diag type = "condition">
<condition>
<ptxt>
Lawaai
</ptxt>
</condition>
<ps>
<ptxt>
Verkeerd of onvoldoende smeermiddel
</ptxt>
</ps>
<action>
<ptxt>
Vul handgeschakelde-transaxle-olie bij.
</ptxt>
</action>
<ps>
<ptxt>
Beschadigde of versleten lager(s)
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang het lager.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Linkse lager van de secundaire as: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Binnenloopring: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Buitenloopring: 
<intxreftitleoff1 refid = "ADUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Rechtse lager van de secundaire as: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Binnenloopring: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Buitenloopring: 
<intxreftitleoff1 refid = "ADUAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Linkse lager en rechtse lager van de ingaande as: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Differentieel-zijlager: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Binnenloopring: 
<intxreftitleoff1 refid = "ADUAP70A5206025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Buitenloopring aan rechterzijde: 
<intxreftitleoff1 refid = "ADUAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Buitenloopring aan linkerzijde: 
<intxreftitleoff1 refid = "ADUAP70A5206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Naaldlager: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Tandwiel van de 1ste en 2de versnelling van de secundaire as: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tandwiel van de ingaande as van de 3de en 4de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tandwiel van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
</list1>
</action>
<ps>
<ptxt>
Beschadigde of versleten tandwiel(en)
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang het tandwiel.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tandwiel van de 1ste, 2de, 3de en 4de versnelling van de secundaire as: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tandwiel van de ingaande as van de 1ste, 2de, 3de en 4de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tandwiel van de ingaande as van de 5de versnelling en tandwiel van de 5de versnelling van de secundaire as: 
<intxreftitleoff1 refid = "ADUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Beschadigde of versleten synchromesh-onderdelen
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de synchromesh-onderdelen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Synchromesh-onderdelen van de lage versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-onderdelen van de hoge versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-onderdelen van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
