<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70AA204004" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Wissen van DTC
</title>
<s1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</s1>
<s1>
<ptxt>
Sluit het SUZUKI-uitleesapparaat op de DLC (1) aan.
</ptxt>
<servicetool>
<servicetoolitem id = "L10B002">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI-diagnosecodeuitleesapparaat (SUZUKISDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A121001.jpg" width = "88.000mm" height = "67.502mm" ver = "02" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</s1>
<s1>
<ptxt>
Wis de DTC volgens de aanwijzingen op het uitleesapparaat. Zie de gebruikershandleiding van het SUZUKI-uitleesapparaat voor nadere bijzonderheden.
</ptxt>
</s1>
<s1>
<ptxt>
Schakel de ontsteking na het wissen uit en maak het SUZUKI-uitleesapparaat los van de DLC.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
