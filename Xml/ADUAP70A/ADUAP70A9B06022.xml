<servinfo servinfosgmlid = "ADUAP70A9B06022" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van het achterpaneel van de achtervloer
</title>
<attention3>
<ptxt>
De onderstaande afbeelding toont de omstandigheid waarin de volgende onderdelen zijn verwijderd.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voorwielspatbord 
<intxreftitleoff1 refid = "ADUAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Achterpaneel 
<intxreftitleoff1 refid = "ADUAP70A9B06021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0166.jpg" width = "88.000mm" height = "48.926mm" ver = "02" gw = "227" gh = "122"/>
</figure>
<servinfosub id = "ADUAP70A9B06022001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Boor de laspunten uit en verwijder het achterpaneel van de achtervloer.
</ptxt>
<attention3>
<ptxt>
Buig beide uiteinden van de flens van de middenplaat van de achtervloer open, indien nodig.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A9B0018.jpg" width = "183.000mm" height = "184.007mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9B06022002">
<title>
Inbouw
</title>
<attention3>
<ptxt>
Controleer alvorens te gaan lassen de montagepositie en de toestand van montagedelen. 
<intxreftitleoff1 refid = "ADUAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1 page = "1">
<ptxt>
Monteer de reservebandbeugel en de gereedschapskistbeugel.
</ptxt>
</s1>
<s1 page = "1">
<ptxt>
Voer weerstandspuntlassen uit.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0168.jpg" width = "183.000mm" height = "100.573mm" ver = "01" gw = "495" gh = "269"/>
</figure>
</s1>
<s1 page = "1">
<ptxt>
Monteer het achterpaneel van de achtervloer.
</ptxt>
<attention3>
<ptxt>
Buig beide uiteinden van de flens van de middenplaat van de achtervloer naar binnen, indien nodig.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Voer weerstandspuntlassen en gatlassen uit.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0019.jpg" width = "183.000mm" height = "183.872mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
