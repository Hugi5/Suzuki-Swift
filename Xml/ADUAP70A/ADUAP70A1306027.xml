<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1306027" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Onderzoek van de OCV
</title>
<list1 type = "unordered">
<item>
<ptxt>
Verwijder de OCV&#39;s (inlaatzijde en uitlaatzijde). 
<intxreftitleoff1 refid = "ADUAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Controleer de OCV&#39;s (inlaatzijde en uitlaatzijde) als volgt.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Controleer de weerstand tussen de aansluitklemmen van de OCV-stekkerverbinding (1).
</ptxt>
<ptxt>
Vervang de OCV als het controleresultaat niet bevredigend is.
</ptxt>
<spec>
<title>
Weerstand van de OCV
</title>
<ptxt>
6,7 tot 7,7 &#937; bij 20 &#176;C (68 &#176;F) 
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9T401132006.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "180" gh = "153"/>
</figure>
</item>
<item>
<ptxt>
Sluit een accu op de OCV-stekkerverbinding (1) aan zoals in de afbeelding en controleer of er een bedrijfsgeluid door het ogenblik van de plunjerklep (2) wordt veroorzaakt.
</ptxt>
<figure>
<graphic graphicname = "I9T401132007.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "193" gh = "153"/>
</figure>
</item>
</list2>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
