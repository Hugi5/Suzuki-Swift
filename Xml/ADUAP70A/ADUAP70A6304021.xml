<diag type = "test" id = "ADUAP70A6304021002">
<testgroup id = "ADUAP70A6304021003">
<title>
Controle van de circuitzekering
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak stekkerverbindingen &#34;E13&#34; en &#34;G50&#34; los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de aansluitklemmen juist op de stekkerverbindingen &#34;G50&#34; en &#34;E13&#34; zijn aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de &#34;P/S&#34;-zekering en de &#34;IG1 SIG&#34;-zekering niet gesprongen zijn als de aansluitingen in orde zijn.
</ptxt>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de zekering(en) en controleer de circuits die met deze zekering(en) verbonden zijn, op kortsluiting aan de massa.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304021004">
<title>
Controle van de hoofdvoeding voor het circuit van het P/S-regelapparaat
</title>
<test1>
<ptxt>
Controleer de spanning tussen de &#34;E13-1&#34;-aansluitklem en de massa.
</ptxt>
</test1>
<question>
Is de spanning 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
&#34;A1&#34;-circuit is onderbroken.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304021005">
<title>
Controle van de IG1-voeding voor het circuit van het P/S-regelapparaat
</title>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de spanning tussen de &#34;G50-3&#34;-aansluitklem en de massa.
</ptxt>
</test1>
<question>
Is de spanning 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
&#34;A2&#34;-circuit is onderbroken.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304021006">
<title>
Controle van de massa voor het circuit van het P/S-regelapparaat
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de weerstand tussen de &#34;E13-2&#34;-aansluitklem en de massa.
</ptxt>
</test1>
<question>
Is de weerstand 1 &#937; of minder?
</question>
<result type = "yes"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Circuit &#34;A3&#34; is onderbroken of heeft een te hoge weerstand.
</ptxt>
</action>
</testgroup>
