</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104014015">
<title>
Controle van kleptiming
</title>
<test1>
<ptxt>
Controleer de onderdelen betrokken bij de distributieketting en hun inbouwomstandigheden. 
<intxreftitleoff1 refid = "ADUAP70A1406023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Monteer opnieuw alle onderdelen betrokken bij de distributieketting correct of vervang defecte onderdelen.
</ptxt>
</action>
