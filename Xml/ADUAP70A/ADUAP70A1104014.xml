<testgroup id = "ADUAP70A1104014013">
<title>
OCV-controle
</title>
<test1>
<ptxt>
Controleer OCV. 
<intxreftitleoff1 refid = "ADUAP70A1306027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 9.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang OCV. 
<intxreftitleoff1 refid = "ADUAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104014014">
<title>
Controle van CMP-stelmotor
</title>
<test1>
<ptxt>
Controleer de CMP-stelmotor. 
<intxreftitleoff1 refid = "ADUAP70A1406014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
