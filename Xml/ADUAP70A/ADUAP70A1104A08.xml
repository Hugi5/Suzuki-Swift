<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A1104A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Brandstofverbruik te hoog
</title>
<ptxt>
Onderzoek de storingen zoals hieronder beschreven als de ECM geen DTC en geen abnormale situatie heeft waargenomen in 
<intxref refid = "ADUAP70A1104008">Visueel onderzoek</intxref>
 en 
<intxref refid = "ADUAP70A1104009">Basisonderzoek van de motor</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Brandstofverbruik te hoog
</ptxt>
</condition>
<ps>
<ptxt>
Defecte bougie (verkeerde elektrodenafstand, veel afzetting en ingebrande elektroden, enz.)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1806002">Onderzoek bougie</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Hoog stationair toerental
</ptxt>
</ps>
<action>
<ptxt>
Onjuist stationair draaien of motor draait niet stationair
</ptxt>
</action>
<ps>
<ptxt>
Slechte prestaties van ECT-sensor, MAF-sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306012">Onderzoek van de ECT-sensor</intxref>
 of 
<intxref refid = "ADUAP70A1306026">Onderzoek van de MAF- en IAT-sensor</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defect elektrische-gasklephuissamenstel
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306004">Onderzoek elektrisch-gasklephuissamenstel in het voertuig</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte APP-sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306008">Onderzoek van de APP-sensor</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte brandstofverstuiver(s)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1704003">Controle van brandstofverstuivercircuit</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1104070">Onderzoek van de ECM en de bijbehorende circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Lage compressie
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1404001">Controle van de compressie</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slechte klepzitting
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1406028">Onderzoek van klep en klepgeleiders</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slepende remmen
</ptxt>
</ps>
<action>
<ptxt>
&#34;Slepende remmen&#34; in 
<intxref refid = "ADUAP70A4104001">Diagnose van remsymptomen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slippende koppeling
</ptxt>
</ps>
<action>
<ptxt>
&#34;Slippende koppeling&#34; in 
<intxref refid = "ADUAP70A5304001">Diagnose van de koppelingssysteemsymptomen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kapotte thermostaat
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1606009">Onderzoek van het thermostaatsamenstel (geïntegreerd met ECT-sensor)</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Onjuiste bandenspanning
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A2401001">Beschrijving van banden</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defect nokkenaspositieregelsysteem (VVT)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306027">Onderzoek van de OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
