<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A1A04002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Diagnose van symptomen van dynamo
</title>
<ptxt>
Bij een storing in het laadsysteem kunnen één of meer van de volgende symptomen worden waargenomen.
</ptxt>
<servinfosub id = "ADUAP70A1A04002001" page = "1">
<title>
Werking van laadsysteemwaarschuwingslampje
</title>
<diag type = "condition" id = "ADUAP70A1A04002002">
<condition>
<ptxt>
Laadsysteemwaarschuwingslampje licht niet op terwijl het contactslot op ON staat en de motor is afgezet.
</ptxt>
</condition>
<ps>
<ptxt>
Gesprongen zekering
</ptxt>
</ps>
<action>
<ptxt>
Vervang de zekering.
</ptxt>
</action>
<ps>
<ptxt>
Defecte combimeter
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vervang de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Defecte BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controleer de BCM.
</ptxt>
<ptxt>
Model met contactslot: 
<intxreftitleoff1 refid = "ADUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model met drukknopstartsysteem: 
<intxreftitleoff1 refid = "ADUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Defecte CAN-gegevenstransmissielijn
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de CAN-gegevenstransmissielijn. 
<intxreftitleoff1 refid = "ADUAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de bedrading.
</ptxt>
</action>
<ps>
<ptxt>
Defecte IC-regelaar of veldspoel
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de dynamo. 
<intxreftitleoff1 refid = "ADUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Het laadsysteemwaarschuwingslampje gaat niet uit als de motor draait (de accu moet vaak opnieuw worden opgeladen)
</ptxt>
</condition>
<ps>
<ptxt>
Loszittende of versleten aandrijfriem
</ptxt>
</ps>
<action>
<ptxt>
Aandrijfriem bijstellen of vervangen. 
<intxreftitleoff1 refid = "ADUAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte combimeter
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vervang de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Defecte BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controleer de BCM.
</ptxt>
<ptxt>
Model met contactslot: 
<intxreftitleoff1 refid = "ADUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model met drukknopstartsysteem: 
<intxreftitleoff1 refid = "ADUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Defecte IC-regelaar of dynamo
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de dynamo. 
<intxreftitleoff1 refid = "ADUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de bedrading.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ADUAP70A1A04002003">
<title>
Storing bij het opladen van de accu
</title>
<diag type = "condition" id = "ADUAP70A1A04002004">
<condition>
<ptxt>
Accu onvoldoende opgeladen
</ptxt>
</condition>
<ps>
<ptxt>
Loszittende of versleten aandrijfriem
</ptxt>
</ps>
<action>
<ptxt>
Aandrijfriem bijstellen of vervangen. 
<intxreftitleoff1 refid = "ADUAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loszittende of gecorrodeerde accupool
</ptxt>
</ps>
<action>
<ptxt>
Maak de accupool vast of vervang de accu. 
<intxreftitleoff1 refid = "ADUAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte gelijkrichter, rotor en/of IC-regelaar
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de dynamo. 
<intxreftitleoff1 refid = "ADUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Te hoog opgeladen accu
</ptxt>
</condition>
<ps>
<ptxt>
Defecte IC-regelaar
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de dynamo. 
<intxreftitleoff1 refid = "ADUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "ADUAP70A1A04002005">
<title>
Lawaai
</title>
<diag type = "condition" id = "ADUAP70A1A04002006">
<condition>
<ptxt>
Lawaaierige dynamo
</ptxt>
</condition>
<ps>
<ptxt>
Losse montagebouten
</ptxt>
</ps>
<action>
<ptxt>
Montagebouten aandraaien. 
<intxreftitleoff1 refid = "ADUAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vuile, versleten en/of defecte lagers
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de dynamo. 
<intxreftitleoff1 refid = "ADUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte rotor, diode en/of stator
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de dynamo. 
<intxreftitleoff1 refid = "ADUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
