<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A5206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Afstelling van de versnellingskeuze-regelkabel
</title>
<s1>
<ptxt>
Maak de borgplaat (1) die de beweging van de kabeluiteindehouder (2) beperkt los.
</ptxt>
</s1>
<s1>
<ptxt>
Druk de kabeluiteindehouder (2) met geschikt gereedschap (3) uit de afsteller (4) om de kabel los te maken.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A520004.swf" width = "88.000mm" height = "100.361mm" ver = "01" gw = "193" gh = "267"/>
</figure>
</s1>
<s1>
<ptxt>
Breng vet aan op de spil (5) van de schakelhendel en monteer vervolgens de afsteller (1) stevig in de pen van de schakelhendel.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B005" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Duw de kabeluiteindehouder (2) in richting [a].
</ptxt>
<attention3>
<ptxt>
Oefen geen kracht uit op de afsteller in werkingsrichting [b] van de kabel.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Schuif de borgplaat (3) in richting [c] tot ze over de klauw (4) van de kabeluiteindehouder zit.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520039.swf" width = "88.000mm" height = "119.028mm" ver = "01" gw = "162" gh = "321"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
