<servinfosub id = "ADUAP70A7224015002">
<title>
DTC-controleprocedure
</title>
<attention3>
<ptxt>
Controleer bij deze procedure of aan de volgende voorwaarde is voldaan.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
U0073 en/of U0140 zijn niet waargenomen
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Start de motor en bedien het A/C-systeem.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7224015003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A7224015004">
<testgroup id = "ADUAP70A7224015005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer de volgende DTC van de BCM.
</ptxt>
<ptxt>
B1503: B1145 en/of B1146
</ptxt>
<ptxt>
B1562: B1141 en/of B1142
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC. 
<intxreftitleoff1 refid = "ADUAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het HVAC-regelapparaat en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
