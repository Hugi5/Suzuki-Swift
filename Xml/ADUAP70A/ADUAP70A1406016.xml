<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1406016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van het motorsamenstel
</title>
<servinfosub id = "ADUAP70A1406016001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Ontlast de brandstofdruk. 
<intxreftitleoff1 refid = "ADUAP70A1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de accu. 
<intxreftitleoff1 refid = "ADUAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de ECM-stekkerverbindingen los. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de accubeugel met de ECM. 
<intxreftitleoff1 refid = "ADUAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de rechtse en linkse beschermplaten aan de onderkant van de motor.
</ptxt>
</s1>
<s1>
<ptxt>
Tap de volgende oliën en vloeistof indien nodig af.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Motorolie: 
<intxreftitleoff1 refid = "ADUAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Handgeschakelde-transaxle-olie: 
<intxreftitleoff1 refid = "ADUAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tussenbakolie: 
<intxreftitleoff1 refid = "ADUAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Tap de koelvloeistof af. 
<intxreftitleoff1 refid = "ADUAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het luchtfiltersamenstel. 
<intxreftitleoff1 refid = "ADUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de A/C-compressor los uit zijn steun met de slang aangesloten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met handbediende A/C: 
<intxreftitleoff1 refid = "ADUAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model met automatische A/C: 
<intxreftitleoff1 refid = "ADUAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Hang de verwijderde A/C-compressor op een plaats waar geen schade kan worden veroorzaakt op wanneer het motorsamenstel wordt uitgebouwd en ingebouwd.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Maak de volgende elektrische draden/stekkerverbindingen samen met hun klemmen los.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Accumassakabel (1)
</ptxt>
</item>
<item>
<ptxt>
Stekkerverbindingen (2) in hoofdzekeringenkast
</ptxt>
</item>
<item>
<ptxt>
Stekkerverbinding van de sensor voor de elektrische belastingsstroom (3)
</ptxt>
</item>
<item>
<ptxt>
Stekkerverbinding (4) in de zekeringenkast van het afzonderlijke circuit nr. 1
</ptxt>
<figure>
<graphic graphicname = "I9P60A141043.jpg" width = "88.000mm" height = "60.102mm" ver = "01" gw = "199" gh = "154"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Maak de volgende kabels los.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Versnellingskeuze-regelkabel (1)
</ptxt>
</item>
<item>
<ptxt>
Schakelhendelkabel (2)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140002.jpg" width = "88.000mm" height = "62.413mm" ver = "01" gw = "199" gh = "160"/>
</figure>
</s1>
<s1>
<ptxt>
Maak de volgende slangen los.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Rembekrachtigerslang (1)
</ptxt>
</item>
<item>
<ptxt>
Inlaat- en uitlaatslangen (2) van de radiateur
</ptxt>
</item>
<item>
<ptxt>
In- en uitlaatslangen (3) van de verwarming
</ptxt>
</item>
<item>
<ptxt>
Brandstoftoevoerslang (4)
</ptxt>
</item>
<item>
<ptxt>
Koppelingsvloeistofslang (5) 
<intxreftitleoff1 refid = "ADUAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140003.jpg" width = "88.000mm" height = "112.325mm" ver = "02" gw = "199" gh = "302"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Maak de onderste stuuras los van de pignonas. 
<intxreftitleoff1 refid = "ADUAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de stabilisatorstangkoppelingen van de stabilisatorstang. 
<intxreftitleoff1 refid = "ADUAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak het trekstanguiteinde los van de fusee. 
<intxreftitleoff1 refid = "ADUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de linker- en rechteraandrijfaskoppelingen los van de fusee. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de pijp van uitlaat nr. 1 en de middenuitlaatpijp. 
<intxreftitleoff1 refid = "ADUAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het cardanassamenstel. 
<intxreftitleoff1 refid = "ADUAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ondersteun het voorste hulpchassis (1), het transaxlehuis (2) en het cilinderblok (3) met een krik.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bouten van het voorste hulpchassis (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A140004.jpg" width = "88.000mm" height = "55.276mm" ver = "01" gw = "199" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de bout (1) en de moeren (2) van de linkse motorophangsteun.
</ptxt>
<figure>
<graphic graphicname = "IAP70A140005.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.309in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.280in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.253in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.280in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Bovenzijde
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Onderzijde
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de bout (1) en de moeren (2) van de rechtse motorophangsteun.
</ptxt>
<figure>
<graphic graphicname = "IAP70A140006.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1>
<ptxt>
Controleer alvorens de motor te verwijderen of alle slangen, stroomdraden en kabels van de motor zijn losgemaakt.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Laat de motor met de transaxle, het voorste hulpchassis, de aandrijfassen en het P/S-stuurhuissamenstel samen zakken.
</ptxt>
<attention2>
<ptxt>
Zorg alvorens de motor te laten zakken voor wat speling tussen de A/C-compressor en de motor door de A/C-compressor op te tillen om te voorkomen dat hij wordt beschadigd.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Maak zo nodig de motorbedradingsbundel los van de motor en de transaxle.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het voorste aandrijfassamenstel, indien nodig. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder indien nodig het voorste hulpchassis.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de tussenbak indien nodig. 
<intxreftitleoff1 refid = "ADUAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak zo nodig de transaxle los van de motor. 
<intxreftitleoff1 refid = "ADUAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder indien nodig het koppelingshuisdeksel en de koppelingsschijf. 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het vliegwiel indien nodig. 
<intxreftitleoff1 refid = "ADUAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1406016002" page = "2">
<title>
Inbouw
</title>
<s1>
<ptxt>
Monteer het vliegwiel als dit verwijderd is. 
<intxreftitleoff1 refid = "ADUAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Monteer het koppelingshuisdeksel en de koppelingsschijf, indien verwijderd. 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Monteer de transaxle op de motor, indien verwijderd. 
<intxreftitleoff1 refid = "ADUAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de tussenbak als deze verwijderd is. 
<intxreftitleoff1 refid = "ADUAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Monteer het voorste hulpchassis, indien verwijderd. 
<intxreftitleoff1 refid = "ADUAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Monteer het voorste aandrijfassamenstel, indien verwijderd. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Monteer de motorbedradingsbundel op de motor en de transaxle en haal vervolgens de massabout (1) van de motorbedradingsbundel met het voorgeschreven koppel aan, indien verwijderd.
</ptxt>
<torque>
<torqueitem id = "T1D008">
<t-part>
Massabout van de motorbedradingsbundel
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140007.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Til de motor met de transaxle, het voorste hulpchassis, de aandrijfassen en het P/S-stuurhuissamenstel samen op.
</ptxt>
<attention2>
<ptxt>
Zorg alvorens de motor op te heffen voor wat speling tussen de A/C-compressor en de motor door de A/C-compressor op te tillen om te voorkomen dat hij wordt beschadigd.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Monteer de bout (1) en de moeren (2) van de rechtse motorophangsteun.
</ptxt>
<torque>
<torqueitem id = "T1D009">
<t-part>
Bout en moer van de rechtse motorophangsteun
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140008.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Haal de bouten (1) en moeren (2) van de linkse motorophangsteun met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1D010">
<t-part>
Bout en moer van de linkse motorophangsteun
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140009.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.428in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.100in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.363in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.309in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Bovenzijde
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Onderzijde
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Haal de hulpchassisbouten met het voorgeschreven koppel aan. 
<intxreftitleoff1 refid = "ADUAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het cardanassamenstel. 
<intxreftitleoff1 refid = "ADUAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Monteer uitlaatpijp nr. 1 en de middenuitlaatpijp. 
<intxreftitleoff1 refid = "ADUAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verbind de rechtse en de linkse aandrijfaskoppelingen met de fusee. 
<intxreftitleoff1 refid = "ADUAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verbind het trekstanguiteinde met de fusee. 
<intxreftitleoff1 refid = "ADUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de stabilisatorstangkoppelingen op de stabilisatorstang. 
<intxreftitleoff1 refid = "ADUAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verbind de onderste stuuras met de pignonas. 
<intxreftitleoff1 refid = "ADUAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Monteer alle andere verwijderde stroomdraden, stekkerverbindingen en slangen op hun oorspronkelijke plaats.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Haal de bout (1) van de accumassa-aansluiting aan.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141052.jpg" width = "88.000mm" height = "60.441mm" ver = "02" gw = "199" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Sluit de schakelhendelkabel aan. 
<intxreftitleoff1 refid = "ADUAP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Monteer de A/C-compressor op de beugel.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met handbediende A/C 
<intxreftitleoff1 refid = "ADUAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model met automatische A/C 
<intxreftitleoff1 refid = "ADUAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Monteer de A/C-compressoraandrijfriem.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met handbediende A/C: 
<intxreftitleoff1 refid = "ADUAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model met automatische A/C: 
<intxreftitleoff1 refid = "ADUAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Monteer het luchtfiltersamenstel. 
<intxreftitleoff1 refid = "ADUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Controleer of alle verwijderde onderdelen correct teruggeplaatst zijn. Monteer eventuele onderdelen die nog niet zijn teruggeplaatst.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Vul de volgende oliën en vloeistof indien nodig bij.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Motorolie: 
