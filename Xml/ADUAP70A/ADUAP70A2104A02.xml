<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Overmatige bandslijtage
</title>
<diag type = "condition">
<condition>
<ptxt>
Overmatige bandslijtage
</ptxt>
</condition>
<ps>
<ptxt>
Kapotte of niet goed gespannen schroefveren
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vervang de schroefveren.
</ptxt>
<ptxt>
Voor: 
<intxreftitleoff1 refid = "ADUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Achter: 
<intxreftitleoff1 refid = "ADUAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Wiel uit balans
</ptxt>
</ps>
<action>
<ptxt>
Balanceer het wiel uit of vervang de band.
</ptxt>
</action>
<ps>
<ptxt>
Wieluitlijning verstoord
</ptxt>
</ps>
<action>
<ptxt>
Controleer de wieluitlijning en stel ze bij. 
<intxreftitleoff1 refid = "ADUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defect voorste veerpootsamenstel (schokdemper)
</ptxt>
</ps>
<action>
<ptxt>
Vervang het voorste veerpootsamenstel (schokdemper). 
<intxreftitleoff1 refid = "ADUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verminderd rijcomfort
</ptxt>
</ps>
<action>
<ptxt>
Vervang de banden. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Voertuig overladen
</ptxt>
</ps>
<action>
<ptxt>
Controleer de lading.
</ptxt>
</action>
<ps>
<ptxt>
Banden niet geroteerd
</ptxt>
</ps>
<action>
<ptxt>
Vervang of roteer de banden.
</ptxt>
</action>
<ps>
<ptxt>
Wiellager versleten of los
</ptxt>
</ps>
<action>
<ptxt>
Vervang het wiellager. 
<intxreftitleoff1 refid = "ADUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Wiel of band slingert
</ptxt>
</ps>
<action>
<ptxt>
Vervang het wiel of de band.
</ptxt>
</action>
<ps>
<ptxt>
Banden niet goed opgepompt
</ptxt>
</ps>
<action>
<ptxt>
Stel de bandenspanning af.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
