<servinfosub id = "ADUAP70A1606010001">
<title>
Werking van de radiateurkoelventilator
</title>
<s1>
<ptxt>
Schakel de ontsteking uit en sluit het uitleesapparaat op de DLC (1) aan.
</ptxt>
<servicetool>
<servicetoolitem id = "L1F001">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI-diagnosecodeuitleesapparaat (SUZUKISDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
