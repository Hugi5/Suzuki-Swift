<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A5306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de hoofdkoppelingscilinder
</title>
<servinfosub id = "ADUAP70A5306011001">
<title>
Uitbouw
</title>
<s1 page = "2">
<ptxt>
Reinig rondom de dop van het hoofdremcilinderreservoir en verwijder met een spuit of iets dergelijks de vloeistof uit het hoofdremcilinderreservoir.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Maak de koppelingsvloeistofleiding van de hoofdkoppelingscilinder los. 
<intxreftitleoff1 refid = "ADUAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Maak de koppelingsvloeistofreservoirslang (1) los.
</ptxt>
<figure>
<graphic graphicname = "IAP70A530007.swf" width = "88.000mm" height = "49.059mm" ver = "01" gw = "141" gh = "123"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Verwijder de stoterstang (1) van het koppelingspedaal (2).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de moeren van de hoofdkoppelingscilinder (3) en verwijder vervolgens de hoofdkoppelingscilinder (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530008.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A5306011002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A5306012">Onderzoek van de hoofdkoppelingscilinder</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Breng vet op het uiteinde van de stoterstang aan.
</ptxt>
<materials>
<materialitem name = "SUZUKI Silicone Grease" id = "M5C001" uid = "21">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25100
</m-number>
<m-name>
SUZUKI Silicone Grease
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Haal de moeren van de hoofdkoppelingscilinder (1) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T5C004">
<t-part>
Moer van de hoofdkoppelingscilinder
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A531013.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
