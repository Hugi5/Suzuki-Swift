<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A1604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Motor raakt oververhit (radiateurventilator werkt niet)
</title>
<diag type = "condition">
<condition>
<ptxt>
Motor raakt oververhit (radiateurventilator werkt niet)
</ptxt>
</condition>
<ps>
<ptxt>
Zekering gesprongen
</ptxt>
</ps>
<action>
<ptxt>
Controleer de zekering.
</ptxt>
</action>
<ps>
<ptxt>
Radiateurkoelventilatorrelais defect.
</ptxt>
</ps>
<action>
<ptxt>
Controleer het radiateurkoelventilatorrelais. 
<intxreftitleoff1 refid = "ADUAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ECT-sensor defect
</ptxt>
</ps>
<action>
<ptxt>
Controleer de ECT-sensor. 
<intxreftitleoff1 refid = "ADUAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radiateurkoelventilatormotor defect
</ptxt>
</ps>
<action>
<ptxt>
Controleer de radiateurkoelventilatormotor. 
<intxreftitleoff1 refid = "ADUAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
<ps>
<ptxt>
Defecte ECM
</ptxt>
</ps>
<action>
<ptxt>
Controleer de ECM en het bijbehorende circuit. 
<intxreftitleoff1 refid = "ADUAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
