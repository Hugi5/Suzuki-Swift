<diag type = "test" id = "ADUAP70A7224019005">
<testgroup id = "ADUAP70A7224019006">
<title>
Controle van de uitleesapparaatparameters
</title>
<test1>
<ptxt>
Controleer de &#34;Luchtmengselpositiesensor&#34; in de &#34;Datalijst&#34;-modus van het SUZUKI-uitleesapparaat. 
<intxreftitleoff1 refid = "ADUAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is de spanning lager dan 0,1 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sporadische storing.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224019007">
<title>
Controle van het signaalcircuit van de positiesensor van de stelmotor van de temperatuurregeling
</title>
<test1>
<ptxt>
Maak de stekkerverbinding van de stelmotor van de temperatuurregeling los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC B1511-H waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de stelmotor van de temperatuurregeling. 
<intxreftitleoff1 refid = "ADUAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224019008">
<title>
Controle van het signaalcircuit van de positiesensor van de stelmotor van de temperatuurregeling
</title>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Meet de spanning tussen de &#34;WHT&#34;-draadaansluiting van de stekkerverbinding van de stelmotor van de temperatuurregeling en de massa.
</ptxt>
</test1>
<question>
Is de spanning 5 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224019009">
<title>
Controle van het signaalcircuit van de positiesensor van de stelmotor van de temperatuurregeling
</title>
<test1>
<ptxt>
Maak de &#34;G20&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van het &#34;WHT&#34;-draadcircuit: minder dan 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen het &#34;WHT&#34;-draadcircuit tussen de stelmotor van de temperatuurregeling en de massa: oneindig
</ptxt>
</item>
</list1>
</test1>
<question>
Zijn de weerstandswaarden zoals voorgeschreven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het HVAC-regelapparaat en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224019010">
<title>
Controle van het signaalcircuit van de positiesensor van de stelmotor van de temperatuurregeling
</title>
<test1>
<ptxt>
Controleer of de weerstand tussen de &#34;YEL&#34;-draadaansluiting en de massa oneindig is.
</ptxt>
</test1>
<question>
Is de weerstand zoals voorgeschreven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het HVAC-regelapparaat en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
</diag>
