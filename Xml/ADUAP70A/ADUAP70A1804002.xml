<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A1804002" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Ontstekingsvonktest
</title>
<attention1>
<ptxt>
Als de verstuiverstekkers niet worden losgemaakt, kunnen tijdens de test brandbare gassen uit de bougiegaten komen, die in de motorruimte kunnen ontploffen.
</ptxt>
</attention1>
<s1>
<ptxt>
Verwijder de bougies. 
<intxreftitleoff1 refid = "ADUAP70A1806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Onderzoek de bougies. 
<intxreftitleoff1 refid = "ADUAP70A1806002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak alle verstuiverstekkers los.
</ptxt>
</s1>
<s1>
<ptxt>
Sluit de bobinestekkerverbinding (1) op het bobinesamenstel (3) aan.
</ptxt>
</s1>
<s1>
<ptxt>
Sluit de bougie (2) op het bobinesamenstel aan en verbind de bougie met de massa.
</ptxt>
<figure>
<graphic graphicname = "I9P60A180004.swf" width = "88.000mm" height = "69.562mm" ver = "01" gw = "185" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Start de motor en controleer of alle bougies vonken.
</ptxt>
</s1>
<s1>
<ptxt>
Onderzoek de verwante onderdelen als er geen vonk is. 
<intxreftitleoff1 refid = "ADUAP70A1804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
