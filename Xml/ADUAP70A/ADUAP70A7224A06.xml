<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A7224A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Er wordt alleen bij hoge snelheden koele lucht uitgeblazen
</title>
<diag type = "condition">
<condition>
<ptxt>
Er wordt alleen bij hoge snelheden koele lucht uitgeblazen
</ptxt>
</condition>
<ps>
<ptxt>
Verstopte condensor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de condensor. 
<intxreftitleoff1 refid = "ADUAP70A7226005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Te weinig koelmiddel
</ptxt>
</ps>
<action>
<ptxt>
Controleer de hoeveelheid koelmiddel en controleer het systeem op lekken.
</ptxt>
</action>
<ps>
<ptxt>
Lucht in het A/C-systeem
</ptxt>
</ps>
<action>
<ptxt>
Vervang de condensor, zuig het A/C-systeem vacuüm en vul dan bij. 
<intxreftitleoff1 refid = "ADUAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Losse of kapotte compressoraandrijfriem
</ptxt>
</ps>
<action>
<ptxt>
Controleer de compressoraandrijfriem. 
<intxreftitleoff1 refid = "ADUAP70A7226043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte compressor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de compressor.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
