<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A7224A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Er wordt geen koele lucht uitgeblazen (radiateurkoelventilatormotor werkt niet)
</title>
<diag type = "condition">
<condition>
<ptxt>
Er wordt geen koele lucht uitgeblazen (radiateurkoelventilatormotor werkt niet)
</ptxt>
</condition>
<ps>
<ptxt>
Gesprongen zekering
</ptxt>
</ps>
<action>
<ptxt>
Controleer de betrokken zekeringen en controleer op kortsluitingen aan de massa.
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
<ps>
<ptxt>
Defect radiateurkoelventilatormotorrelais
</ptxt>
</ps>
<action>
<ptxt>
Controleer het radiateurkoelventilatormotorrelais. 
<intxreftitleoff1 refid = "ADUAP70A7226042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radiateurkoelventilatormotor defect
</ptxt>
</ps>
<action>
<ptxt>
Controleer de radiateurkoelventilatormotor. 
<intxreftitleoff1 refid = "ADUAP70A7226004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte ECM
</ptxt>
</ps>
<action>
<ptxt>
Controleer de ECM. 
<intxreftitleoff1 refid = "ADUAP70A7224040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defect HVAC-regelapparaat
</ptxt>
</ps>
<action>
<ptxt>
Controleer het HVAC-regelapparaat. 
<intxreftitleoff1 refid = "ADUAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
