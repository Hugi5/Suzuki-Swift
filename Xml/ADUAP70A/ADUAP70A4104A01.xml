<ptxt>
Onvoldoende remkracht
</ptxt>
</condition>
<ps>
<ptxt>
Remvloeistoflekken aan de remleidingen
</ptxt>
</ps>
<action>
<ptxt>
Zoek en repareer het lek.
</ptxt>
</action>
<ps>
<ptxt>
Remschijf of -blokken bevlekt met vloeistof, vet of andere olie
</ptxt>
</ps>
<action>
<ptxt>
Reinig of vervang.
</ptxt>
</action>
<ps>
<ptxt>
Oververhitte remmen
</ptxt>
</ps>
<action>
<ptxt>
Spoor de oorzaak op en repareer.
</ptxt>
</action>
<ps>
<ptxt>
Sterk versleten remblok
</ptxt>
</ps>
<action>
<ptxt>
Vervangen.
</ptxt>
</action>
<ps>
<ptxt>
Storing in remzadelsamenstel
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang.
</ptxt>
</action>
<ps>
<ptxt>
Lucht in het systeem
</ptxt>
</ps>
<action>
<ptxt>
Ontlucht het remsysteem.
</ptxt>
</action>
<ps>
<ptxt>
Interne storing van rembekrachtiger
</ptxt>
</ps>
<action>
<ptxt>
Vervang de rembekrachtiger.
</ptxt>
</action>
<ps>
<ptxt>
Negatieve druk voor rembekrachtiger is inadequaat
</ptxt>
</ps>
<action>
<ptxt>
Controleer de motortoestand en de vacuümslang.
</ptxt>
</action>
<ps>
<ptxt>
Slechtwerkende ESP<sup>&#174;</sup>
</ptxt>
</ps>
<action>
<ptxt>
Controleer het systeem en vervang het indien nodig.
</ptxt>
</action>
