<servinfosub id = "ADUAP70A8204014003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A8204014004">
<testgroup id = "ADUAP70A8204014005">
<question>
Werd de &#34;Controle van het airbagdiagnosesysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204014006">
<title>
Controle van het circuit van de passagiersairbagdeactiveringsindicator
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer op een juiste aansluiting op stekkerverbinding &#34;G153&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;G153&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Meet de spanning tussen aansluiting &#34;G153-9&#34; en de massa.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B004">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820109.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</test1>
<question>
Bedraagt de gemeten spanning 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204014007">
<title>
Controle van het circuit van de passagiersairbagdeactiveringsindicator
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer op een juiste aansluiting op stekkerverbinding &#34;G11&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;G11&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Meet de weerstand tussen aansluitklem &#34;G153-10&#34; en aansluitklem &#34;G11-15&#34;.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B005">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820110.swf" width = "90.000mm" height = "48.716mm" ver = "01" gw = "188" gh = "122"/>
</testfigure>
</test1>
<question>
Bedraagt de gemeten weerstand 1 &#937; of minder?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204014008">
<title>
Controle van het circuit van de passagiersairbagdeactiveringsindicator
</title>
<test1>
<ptxt>
Controleer het volgende punt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand tussen aansluitklem &#34;G153-10&#34; en de massa.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B006">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820111.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</item>
</list1>
</test1>
<question>
Is de gemeten weerstand oneindig?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204014009">
<title>
Controle van de passagiersairbagdeactiveringsindicator
</title>
<test1>
<ptxt>
Controleer de passagiersairbagdeactiveringsindicator. 
<intxreftitleoff1 refid = "ADUAP70A8206029"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is hij in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de SDM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de alarmknipperlichtschakelaar. 
<intxreftitleoff1 refid = "ADUAP70A9206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Voer na het onderzoek en de reparaties de volgende stappen uit.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sluit alle componenten van het airbagsysteem weer aan en controleer of ze juist zijn gemonteerd.
</ptxt>
</item>
<item>
<ptxt>
Wis eventuele DTC&#39;s volgens 
<intxref refid = "ADUAP70A8204006">Wissen van DTC</intxref>
, als een DTC wordt waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Herhaal 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
 om te controleren of de storing is opgelost.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
