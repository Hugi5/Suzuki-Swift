<servinfosub id = "ADUAP70A1104022003">
<title>
DTC-controleprocedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Voer een proefrit uit op een plaats zonder verkeer om ongevallen te voorkomen.
</ptxt>
</item>
<item>
<ptxt>
De proefrit moet door 2 personen worden uitgevoerd, een bestuurder en iemand die de test uitvoert, op een vlakke weg.
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Bevestig dat de ECT lager is dan 40 &#176;C (104 &#176;F).
</ptxt>
</s1>
<s1>
<ptxt>
Start de motor en rijd met een constante snelheid van 60 tot 80 km/h (37 tot 50 mile/h) gedurende 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1104022004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A1104022005">
<testgroup id = "ADUAP70A1104022006">
<question>
Is de &#34;Controle van het motor- en emissieregelsysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A1104001">Controle van het motor- en emissieregelsysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104022007">
<title>
Controle van het koelvloeistofpeil
</title>
<test1>
<ptxt>
Controleer het koelvloeistofpeil. 
<intxreftitleoff1 refid = "ADUAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vul koelvloeistof bij en controleer de DTC opnieuw.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104022008">
<title>
Controle van het ECT-sensorcircuit
</title>
<test1>
<ptxt>
Controleer de ECT-sensorcircuits volgens stap 2 van 
<intxref refid = "ADUAP70A1104023">DTC P0117 / P0118</intxref>
.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104022009">
<title>
Controle van de ECT-sensor
</title>
<test1>
<ptxt>
Controleer de ECT-sensor. 
<intxreftitleoff1 refid = "ADUAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de ECT-sensor.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104022010">
<title>
Controle van thermostaat
</title>
<test1>
<ptxt>
Controleer het thermostaatsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de thermostaat.
</ptxt>
</action>
</testgroup>
</diag>
