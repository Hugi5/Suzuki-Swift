<servinfosub id = "ADUAP70AA204012003">
<title>
DTC-controleprocedure
</title>
<s1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA204012004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70AA204012005">
<testgroup id = "ADUAP70AA204012008">
<title>
Controle van de parameter
</title>
<test1>
<ptxt>
Sluit het SUZUKI-uitleesapparaat op de DLC aan met de ontsteking uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de weergave &#34;Automat. lichtsensor&#34; op het SUZUKI-uitleesapparaat. 
<intxreftitleoff1 refid = "ADUAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is hij in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Einde. (Sporadische storing.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA204012006">
<title>
Controle van het voedingscircuit van de automatische-koplampsensor
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de automatische-koplampsensor en de &#34;G05&#34;-stekkerverbindingen los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de aansluitklemmen juist op de stekkerverbinding van de automatische-koplampsensor en de &#34;G05&#34;-stekkerverbindingen zijn aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Als de aansluitingen in orde zijn, controleer dan de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand tussen circuit &#34;A1&#34; en de massa: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklemmen &#34;A1&#34; en &#34;A3&#34; op de stekkerverbinding van de automatische-koplampsensor: oneindig
</ptxt>
</item>
</list1>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA204012007">
<title>
Controle van de automatische-koplampsensor
</title>
<test1>
<ptxt>
Controleer de automatische-koplampsensor. 
<intxreftitleoff1 refid = "ADUAP70A9206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is hij in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de automatische-koplampsensor. 
<intxreftitleoff1 refid = "ADUAP70A9206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA204012009">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Verbind de automatische-koplampsensor en de &#34;G05&#34;-stekkerverbindingen.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt de huidige DTC B1132 waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de BCM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (Sporadische storing.)
</ptxt>
</action>
</testgroup>
</diag>
