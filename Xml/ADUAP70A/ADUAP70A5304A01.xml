<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Slippen
</title>
<diag type = "condition">
<condition>
<ptxt>
Slippen
</ptxt>
</condition>
<ps>
<ptxt>
Onjuiste vrije slag van het koppelingspedaal
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de koppelingspedaalarm en/of de hoofdkoppelingscilinder.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Koppelingspedaalarm: 
<intxreftitleoff1 refid = "ADUAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hoofdkoppelingscilinder: 
<intxreftitleoff1 refid = "ADUAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Voering van de koppelingsschijf versleten of vettig door olie
</ptxt>
</ps>
<action>
<ptxt>
Vervang de koppelingsschijf. 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kromgetrokken plaat, drukplaat of vliegwieloppervlak
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de koppelingsschijf, het deksel of het vliegwiel.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Koppelingsschijf en deksel: 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vliegwiel: 
<intxreftitleoff1 refid = "ADUAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Verzwakte schotelveer
</ptxt>
</ps>
<action>
<ptxt>
Vervang het koppelingshuisdeksel. 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zuiger of afdichthoes van de hoofdcilinder keert niet terug
</ptxt>
</ps>
<action>
<ptxt>
Vervang de hoofdkoppelingscilinder. 
<intxreftitleoff1 refid = "ADUAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
