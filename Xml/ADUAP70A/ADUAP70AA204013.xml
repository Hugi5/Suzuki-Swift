<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70AA204013" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1133
</title>
<servinfosub id = "ADUAP70AA204013001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.385in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.833in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1133: Accuspanning te hoog 
</emph>
</ptxt>
<ptxt>
De spanning in het reservevoedingcircuit van de &#34;DOME&#34;-zekering is gedurende een voorgeschreven tijd zonder onderbreking hoger dan 16,0 V.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Laadsysteem
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70AA204013002">
<title>
DTC-controleprocedure
</title>
<s1>
<ptxt>
Start de motor, indien mogelijk.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA204013003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70AA204013004">
<testgroup id = "ADUAP70AA204013006">
<title>
Controle van de parameter
</title>
<test1>
<ptxt>
Sluit het SUZUKI-uitleesapparaat op de DLC aan met de ontsteking uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de weergave &#34;Accuspanning&#34; op het SUZUKI-uitleesapparaat. 
<intxreftitleoff1 refid = "ADUAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Einde. (Sporadische storing.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA204013005">
<title>
Controle van het laadsysteem	
</title>
<test1>
<ptxt>
Controleer het laadsysteem. 
<intxreftitleoff1 refid = "ADUAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de BCM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer het laadsysteem.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
