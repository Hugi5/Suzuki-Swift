<servinfosub id = "ADUAP70A4604011002">
<title>
Circuitbeschrijving
</title>
<ptxt>
Zie &#34;Circuitbeschrijving&#34; in 
<intxref refid = "ADUAP70A4604010">Het ESP&#174;-waarschuwingslampje gaat niet branden nadat de ontsteking is ingeschakeld</intxref>
.
</ptxt>
</servinfosub>
<servinfosub id = "ADUAP70A4604011003">
<title>
Storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604011004">
<testgroup id = "ADUAP70A4604011005">
<title>
Controle van de ESP&#174; regelapparaat-stekkerverbinding
</title>
<test1>
<ptxt>
Controleer op een goede verbinding met de ESP<sup>&#174;</sup>-regelapparaat-stekkerverbinding.
</ptxt>
</test1>
<question>
Is de aansluiting in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sluit de stekkerverbinding stevig aan.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604011006">
<title>
DTC-controle van ESP&#174;
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A4604005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604011007">
<title>
Controle van het voedings- en massacircuit van het ESP&#174;-regelapparaat
</title>
<test1>
<ptxt>
Controleer het voedings- en massacircuit van het ESP<sup>&#174;</sup>-regelapparaat. 
<intxreftitleoff1 refid = "ADUAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn de circuits in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604011008">
<title>
Controle van de combimeter
</title>
<test1>
<ptxt>
Vervang de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<question>
Blijft het waarschuwingslampje branden?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de werking van het waarschuwingslampje opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
