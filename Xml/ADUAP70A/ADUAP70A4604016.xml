<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A4604016" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1015 / C1017 / C1023
</title>
<servinfosub id = "ADUAP70A4604016001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.257in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.924in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1015: Storing in de sensor voor versnelling in lengterichting van het gierratio-/G-sensorsamenstel 
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Het signaal van de sensor voor versnelling in lengterichting valt buiten het voorgeschreven bereik.
</ptxt>
</item>
<item>
<ptxt>
Signaal van de sensor voor versnelling in lengterichting wijzigt niet, hoewel het voertuig versnelt of vertraagt.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ESP<sup>&#174;</sup>-regelapparaat
</ptxt>
</item>
<item>
<ptxt>
Beugel van de stelmotor
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1017: Prestaties van het circuit van de sensor voor versnelling in dwarsrichting
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Het signaal van de sensor voor versnelling in dwarsrichting valt buiten het voorgeschreven bereik.
</ptxt>
</item>
<item>
<ptxt>
Signaal van de sensor voor versnelling in dwarsrichting wijzigt niet, hoewel het voertuig naar rechts of links draait.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1023: Prestaties van het gierratiosensorcircuit
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Gierratiosensorsignaal valt buiten het voorgeschreven bereik.
</ptxt>
</item>
<item>
<ptxt>
Hoewel het voertuig stilstaat, is het signaal van de gierratiosensor hoger dan de voorgeschreven waarde.
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A4604016002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604016003">
<testgroup id = "ADUAP70A4604016004">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604016006">
<title>
Controle van het ESP&#174;-regelapparaat en de stelmotorbeugel
</title>
<test1>
<ptxt>
Controleer het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en de stelmotorbeugel. 
<intxreftitleoff1 refid = "ADUAP70A4606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang defecte onderdelen.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604016005">
<title>
DTC-controle van ESP&#174;
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A4604005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Worden behalve C1015, C1017 en C1023 nog andere DTC&#39;s aangegeven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
