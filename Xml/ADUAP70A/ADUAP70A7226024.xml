<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A7226024" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de stelmotor van de temperatuurregeling
</title>
<servinfosub id = "ADUAP70A7226024001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Stel het airbagsysteem buiten werking. 
<intxreftitleoff1 refid = "ADUAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het stuurkolomopeningsdeksel. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de knie-airbag (opblaaseenheid)-module. 
<intxreftitleoff1 refid = "ADUAP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de schroeven (1) en verwijder daarna de stelmotor van de temperatuurregeling (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A722007.jpg" width = "88.000mm" height = "63.150mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7226024002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A7226025">Onderzoek stelmotor van de temperatuurregeling:Automatisch type</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zorg ervoor dat de armpen (1) van de stelmotor van de temperatuurregeling in de groef (2) van het stangenstelsel gestoken wordt.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722008.swf" width = "88.000mm" height = "63.358mm" ver = "01" gw = "141" gh = "163"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
