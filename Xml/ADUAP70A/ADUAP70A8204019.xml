<servinfosub id = "ADUAP70A8204019003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A8204019004">
<testgroup id = "ADUAP70A8204019005">
<question>
Werd de &#34;Controle van het airbagdiagnosesysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204019006">
<title>
Controle van de bestuurdersairbag (opblaaseenheid)-module
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;G347&#34;- of &#34;G374&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Sluit &#34;STEERING WHEEL&#34; (1) met speciaal gereedschap (A) en (B) op stekkerverbinding &#34;G347&#34; of &#34;G374&#34; aan.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B011">
<s-part>
(A)
</s-part>
<s-number num = "09932-77320">
09932-77320
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B012">
<s-part>
(B)
</s-part>
<s-number num = "09932-75010">
09932-75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820006.swf" width = "90.000mm" height = "63.681mm" ver = "03" gw = "208" gh = "164"/>
</testfigure>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC B1032 vastgesteld?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204019007">
<title>
Circuitcontrole van de instrumentenpaneelbedradingsbundel
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;G11&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de kortsluitbeugel in de SDM-stekkerverbinding los met het vrijzetgereedschap dat behoort tot het speciaal gereedschap (A).
</ptxt>
</test1>
<test1>
<ptxt>
Controleer het volgende punt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand tussen aansluitingen &#34;G11-5&#34; en &#34;G11-6&#34;: oneindig
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B013">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820057.swf" width = "90.000mm" height = "55.937mm" ver = "01" gw = "200" gh = "142"/>
</testfigure>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de SDM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204019008">
<title>
Controle van het contactspoelcircuit
</title>
<test1>
<ptxt>
Controleer het contactspoelcircuit. 
<intxreftitleoff1 refid = "ADUAP70A8204053"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het circuit van de contactspoel in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de bestuurdersairbag (opblaaseenheid)-module. 
<intxreftitleoff1 refid = "ADUAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het contactspoelsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
<attention3>
<ptxt>
Voer na het onderzoek en de reparaties de volgende stappen uit.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sluit alle componenten van het airbagsysteem weer aan en controleer of ze juist zijn gemonteerd.
</ptxt>
</item>
<item>
<ptxt>
Wis eventuele DTC&#39;s volgens 
<intxref refid = "ADUAP70A8204006">Wissen van DTC</intxref>
, als een DTC wordt waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Herhaal 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
 om te controleren of de storing is opgelost.
</ptxt>
</item>
</list1>
</attention3>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
