<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1306009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de MAP-sensor
</title>
<servinfosub id = "ADUAP70A1306009001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de MAP-sensor los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de MAP-sensor (1) van het inlaatspruitstuk (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A131003.jpg" width = "88.000mm" height = "51.551mm" ver = "01" gw = "185" gh = "130"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1306009002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1306010">Onderzoek van de MAP-sensor</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Controleer of de O-ring niet beschadigd is.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
