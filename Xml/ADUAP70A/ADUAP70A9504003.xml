<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A9504003" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnose van de symptomen van het achterruitverwarmings- en spiegelverwarmingssysteem
</title>
<diag type = "condition" id = "ADUAP70A9504003001">
<condition>
<ptxt>
De achterruitverwarming werkt niet
</ptxt>
</condition>
<ps>
<ptxt>
Defecte systeemcircuits (inclusief relais en zekeringen)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9501002">Beschrijving van de achterklepruitverwarming en buitenspiegelverwarming</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte achterruitverwarmingsschakelaar
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9506008">Onderzoek van de achterruitverwarmingsschakelaar</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte achterruitverwarming
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9506007">Onderzoek van de achterruitverwarming</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
&#34;Onderzoek van de BCM en de bijbehorende circuits&#34;: in hoofdstuk 10B.
</ptxt>
<ptxt>
Model met contactslot: 
<intxreftitleoff1 refid = "ADUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model met drukknopstartsysteem: 
<intxreftitleoff1 refid = "ADUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<condition>
<ptxt>
Er werkt geen enkele spiegelverwarming
</ptxt>
</condition>
<ps>
<ptxt>
Gesprongen zekering
</ptxt>
</ps>
<action>
<ptxt>
Vervang de zekering en controleer op kortsluiting.
</ptxt>
</action>
<ps>
<ptxt>
Defecte spiegelverwarmingsschakelaar
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9506008">Onderzoek van de achterruitverwarmingsschakelaar</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
<ps>
<ptxt>
Defecte BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
&#34;Onderzoek van de BCM en de bijbehorende circuits&#34;: in hoofdstuk 10B.
</ptxt>
<ptxt>
Model met contactslot: 
<intxreftitleoff1 refid = "ADUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Model met drukknopstartsysteem: 
<intxreftitleoff1 refid = "ADUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<condition>
<ptxt>
Slechts één buitenspiegelverwarming werkt niet
</ptxt>
</condition>
<ps>
<ptxt>
Defecte spiegelverwarming
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9506021">Onderzoek in het voertuig van de elektrisch bediende buitenspiegel en spiegelverwarming</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
