<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1406009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van het inlaatspruitstuk
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1406005">Componenten van gasklephuis en inlaatspruitstuk</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1406009001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het luchtfiltersamenstel. 
<intxreftitleoff1 refid = "ADUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het elektrische-gasklephuissamenstel van het inlaatspruitstuk met de motorkoelvloeistofslangen aangesloten.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de MAP-sensor (1) los.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de volgende slangen los: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Rembekrachtigerslang (2) van de rembekrachtiger
</ptxt>
</item>
<item>
<ptxt>
PCV-slang (3) van de PCV-klep
</ptxt>
<figure>
<graphic graphicname = "I7V20A141039.swf" width = "88.000mm" height = "53.078mm" ver = "01" gw = "221" gh = "134"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Verwijder bout (1) van de inlaatleiding van de verwarming.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141022.jpg" width = "88.000mm" height = "51.297mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het inlaatspruitstuk (1) en de bijbehorende pakking.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141040.swf" width = "88.000mm" height = "57.944mm" ver = "01" gw = "183" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de koelwaterleiding (1). 
<intxreftitleoff1 refid = "ADUAP70A1606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de tussenring (2) en de pakking van de cilinderkop.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141023.jpg" width = "88.000mm" height = "57.901mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1406009002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Gebruik een nieuwe pakking.
</ptxt>
</item>
<item>
<ptxt>
Controleer of alle verwijderde onderdelen correct teruggeplaatst zijn.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
