<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A7214A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
De compressor maakt een ratelend geluid wanneer hij in werking is
</title>
<servinfosub id = "ADUAP70A7214004003">
<title>
Abnormaal geluid uit de magneetkoppeling
</title>
<diag type = "condition">
<condition>
<ptxt>
De compressor maakt een ratelend geluid wanneer hij in werking is
</ptxt>
</condition>
<ps>
<ptxt>
Verkeerde speling van de magneetkoppeling (te veel speling)
</ptxt>
</ps>
<action>
<ptxt>
Stel de speling van de magneetkoppeling bij. 
<intxreftitleoff1 refid = "ADUAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Wrijvingsoppervlak van de magneetkoppeling versleten
</ptxt>
</ps>
<action>
<ptxt>
Vervang het magneetkoppelingssamenstel. 
<intxreftitleoff1 refid = "ADUAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compressorolie gelekt uit de askeerring, waarbij het wrijvingsoppervlak verontreinigd is geraakt
</ptxt>
</ps>
<action>
<ptxt>
Vervang het compressorhuissamenstel. 
<intxreftitleoff1 refid = "ADUAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
