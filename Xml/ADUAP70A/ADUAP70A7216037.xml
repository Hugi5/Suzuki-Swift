<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A7216037" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de compressoraandrijfriem
</title>
<servinfosub id = "ADUAP70A7216037004">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Draai de spanpoeliebout (1) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verlaag de riemspanning door de stelbout van de spanpoelie (2) los te draaien.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de compressoraandrijfriem (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A722023.swf" width = "88.000mm" height = "57.807mm" ver = "08" gw = "182" gh = "147"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7216037001">
<title>
Inbouw
</title>
<s1>
<ptxt>
Monteer de compressoraandrijfriem.
</ptxt>
</s1>
<s1>
<ptxt>
Stel de riemspanning af. 
<intxreftitleoff1 refid = "ADUAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
