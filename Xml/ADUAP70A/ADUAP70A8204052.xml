<servinfosub id = "ADUAP70A8204052002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A8204052003">
<testgroup id = "ADUAP70A8204052004">
<title>
Controle van de accuspanning
</title>
<test1>
<ptxt>
Controleer de accuspanning.
</ptxt>
</test1>
<question>
Bedraagt de spanning 9 – 16 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controleer het laadsysteem en repareer het. 
<intxreftitleoff1 refid = "ADUAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204052005">
<title>
Controle van de SDM-aansluiting
</title>
<test1>
<ptxt>
Controleer of de aansluiting met de SDM-stekkerverbinding goed is verbonden.
</ptxt>
</test1>
<question>
Is de verbinding in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Sporadische storing. Controleer op sporadische storingen. 
<intxreftitleoff1 refid = "ADUAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Indien OK, sluit dan een goed bevonden SDM aan en controleer de aansluiting opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204052006">
<title>
Zekeringcontrole
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de &#34;A/B&#34;-zekering.
</ptxt>
</test1>
<question>
Is de &#34;A/B&#34;-zekering in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de vloerbedradingsbundel en vervang vervolgens de &#34;A/B&#34;-zekering.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204052007">
<title>
Controle van het voedingscircuit
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;L04&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Meet de spanning tussen aansluiting &#34;L04-18&#34; en de massa.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B095">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820157.swf" width = "90.000mm" height = "34.401mm" ver = "01" gw = "194" gh = "81"/>
</testfigure>
</test1>
<question>
Bedraagt de spanning 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de vloerbedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204052008">
<title>
Controle van het massacircuit
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Meet de weerstand tussen aansluitklem &#34;L04-23&#34; en de massa.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B096">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820158.swf" width = "90.000mm" height = "34.895mm" ver = "01" gw = "193" gh = "82"/>
</testfigure>
</test1>
<question>
Is de weerstand 1 &#937; of minder?
</question>
<result type = "yes"/>
<action>
<ptxt>
SDM-voeding en het massacircuit verkeren in goede staat.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de vloerbedradingsbundel.
</ptxt>
</action>
</testgroup>
</diag>
