<servinfosub id = "ADUAP70A6304010002">
<title>
Storingzoeken
</title>
<diag type = "test" id = "ADUAP70A6304010003">
<testgroup id = "ADUAP70A6304010004">
<title>
Controle van het &#34;P/S&#34;-waarschuwingslampje
</title>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<question>
Gaan er andere waarschuwingslampjes branden?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304010005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A6304003">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Wordt DTC U0073 of DTC U0155 weergegeven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70AA804002">CAN DTC (Verbroken communicatie en Communicatiebus Uit)-tabel</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304010006">
<title>
Controle van de combimeter
</title>
<test1>
<ptxt>
Vervang de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<question>
Blijft het &#34;P/S&#34;-waarschuwingslampje uit?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het P/S-regelapparaat. 
<intxreftitleoff1 refid = "ADUAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304010007">
<title>
Zekeringcontrole
</title>
<question>
Is de circuitzekering van de combimeter in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Vervang de zekering en controleer op kortsluiting aan de massa.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304010008">
<title>
Controle van het CAN-communicatiecircuit
</title>
<test1>
<ptxt>
Controleer het CAN-communicatiecircuit tussen de combimeter en het P/S-regelapparaat. 
<intxreftitleoff1 refid = "ADUAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het CAN-communicatiecircuit in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Repareer of vervang.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304010009">
<title>
Controle van het voedingscircuit van de combimeter
</title>
<test1>
<ptxt>
Verwijder de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer op een goede verbinding met de combimeterstekker.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in als het controleresultaat in orde is.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de spanning tussen aansluitklem &#34;G240-3&#34; en aansluitklem &#34;G240-5&#34; accuspanning is.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de combimeter en controleer opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 7.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304010010">
<title>
Controle van het massacircuit van de combimeter
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de weerstand tussen aansluitklem &#34;G240-5&#34; en de massa 1 &#937; of minder is.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Repareer of vervang circuit &#34;A1&#34;.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang circuit &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
</diag>
