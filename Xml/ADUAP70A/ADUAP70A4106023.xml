<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A4106023" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Onderzoek van de rembekrachtiger
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A4106022">Uitbouw en inbouw van de rembekrachtiger</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Controleer de rembekrachtiger op schade.
</ptxt>
</item>
<item>
<ptxt>
Controleer de werking van de rembekrachtiger volgens &#34;Controle van de werking&#34; onder 
<intxref refid = "ADUAP70A4106021">Werkingscontrole van rembekrachtiger</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Controleer de hoes op schade en veroudering.
</ptxt>
</item>
<item>
<ptxt>
Controleer de stoterstanglengte.
</ptxt>
<ptxt>
Vervang de rembekrachtiger als het controleresultaat niet zoals voorgeschreven is.
</ptxt>
</item>
</list1>
<spec>
<title>
Stoterstanglengte
</title>
<ptxt>
&#34;a&#34;: 114,5 – 115,5 mm (4,507 – 4,547 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I3RM0A410056.swf" width = "88.000mm" height = "44.057mm" ver = "01" gw = "139" gh = "108"/>
</figure>
</servinfo>
</servinfotype>
</configtype>
