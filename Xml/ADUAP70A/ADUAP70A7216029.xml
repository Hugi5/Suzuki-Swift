<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A7216029" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van het middenventilatierooster
</title>
<servinfosub id = "ADUAP70A7216029001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het middenventilatierooster van het instrumentenpaneel. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de alarmknipperlichtschakelaar los.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de slangen (2) los en verwijder vervolgens het middenventilatierooster (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A721028.swf" width = "88.000mm" height = "58.762mm" ver = "02" gw = "215" gh = "150"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7216029002">
<title>
Inbouw
</title>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
