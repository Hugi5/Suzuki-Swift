<servinfo servinfosgmlid = "ADUAP70A4604026" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1040
</title>
<servinfosub id = "ADUAP70A4604026001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1040: ESP<sup>&#174;</sup> voortdurend in werking
</emph>
</ptxt>
<ptxt>
De stabiliteitsregeling is langer dan de voorgeschreven tijd geactiveerd.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ESP<sup>&#174;</sup>-regelapparaat
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A4604026002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604026003">
<testgroup id = "ADUAP70A4604026004">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604026005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A4604005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Worden er behalve C1040 nog andere DTC&#39;s weergegeven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
