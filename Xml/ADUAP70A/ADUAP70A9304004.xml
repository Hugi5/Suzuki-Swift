<servinfosub id = "ADUAP70A9304004003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A9304004004">
<testgroup id = "ADUAP70A9304004005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Wis de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC B1802 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controleer op sporadische storingen. 
<intxreftitleoff1 refid = "ADUAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A9304004006">
<title>
Controle van de voedings- en massacircuits van de combimeter
</title>
<test1>
<ptxt>
Controleer het voedings- en massacircuit van de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A9304004007">
<title>
Controle van de combimetervoedingsspanning
</title>
<test1>
<ptxt>
Controleer voedingsspanning bij toerental 3.000 omw/min.
</ptxt>
</test1>
<question>
Is de spanning 10 – 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de combimeter en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controleer het laadsysteem. 
<intxreftitleoff1 refid = "ADUAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
