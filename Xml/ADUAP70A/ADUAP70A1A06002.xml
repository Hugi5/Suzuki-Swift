<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1A06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de accu
</title>
<servinfosub id = "ADUAP70A1A06002001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel (1) van de accu (4) los.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de positieve (+) kabel (2) van de accu (4) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de houder (3).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de accu (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0001.swf" width = "88.000mm" height = "71.286mm" ver = "01" gw = "171" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de accudrager (1).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de ECM (2). 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder indien nodig de accubeugel (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0002.jpg" width = "88.000mm" height = "55.738mm" ver = "02" gw = "199" gh = "141"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1A06002002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Maak de accukabels stevig vast.
</ptxt>
</item>
<item>
<ptxt>
Initialiseer indien nodig elektrische apparaten.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
