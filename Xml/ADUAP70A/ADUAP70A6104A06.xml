<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A6104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Onregelmatig sturen bij het remmen
</title>
<diag type = "condition">
<condition>
<ptxt>
Onregelmatig sturen bij het remmen
</ptxt>
</condition>
<ps>
<ptxt>
Versleten wiellager(s)
</ptxt>
</ps>
<action>
<ptxt>
Vervang het (de) wiellager(s). 
<intxreftitleoff1 refid = "ADUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kapotte of niet goed gespannen schroefveer
</ptxt>
</ps>
<action>
<ptxt>
Vervang de schroefveer. 
<intxreftitleoff1 refid = "ADUAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defect voorste veerpootsamenstel (schokdemper)
</ptxt>
</ps>
<action>
<ptxt>
Vervang het voorste veerpootsamenstel (schokdemper). 
<intxreftitleoff1 refid = "ADUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ongelijke bandenspanning
</ptxt>
</ps>
<action>
<ptxt>
Stel de bandenspanning af.
</ptxt>
</action>
<ps>
<ptxt>
Verstoorde voorwieluitlijning
</ptxt>
</ps>
<action>
<ptxt>
Controleer de voorwieluitlijning en stel ze bij. 
<intxreftitleoff1 refid = "ADUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Remmen functioneren niet samen
</ptxt>
</ps>
<action>
<ptxt>
Controleer en repareer het remsysteem. 
<intxreftitleoff1 refid = "ADUAP70A4101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Voorwielremschijf met remvloeistof bevlekt
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de voorwielremschijf. 
<intxreftitleoff1 refid = "ADUAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verbogen remschijf
</ptxt>
</ps>
<action>
<ptxt>
Vervang de voorwielremschijf. 
<intxreftitleoff1 refid = "ADUAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sterk versleten remblok
</ptxt>
</ps>
<action>
<ptxt>
Vervang het voorwielremblok. 
<intxreftitleoff1 refid = "ADUAP70A4206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
