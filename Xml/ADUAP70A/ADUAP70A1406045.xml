<servinfo servinfosgmlid = "ADUAP70A1406045" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Onderzoek van het vliegwiel
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1406021">Uit- en inbouw van het vliegwiel</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1406045001">
<title>
Visueel onderzoek
</title>
<list1 type = "unordered">
<item>
<ptxt>
Vervang het vliegwiel als het kroonwiel beschadigd, gebarsten of versleten is.
</ptxt>
</item>
<item>
<ptxt>
Vervang het vliegwiel als het oppervlak dat contact maakt met de koppelingsschijf beschadigd of overmatig versleten is.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "ADUAP70A1406045002">
<title>
Slingering van vliegwielvlak
</title>
<ptxt>
Controleer de slingering van het vliegwielvlak met een meetklok.
</ptxt>
<ptxt>
Vervang het vliegwiel als de slingering de grenswaarde overschrijdt.
</ptxt>
<spec>
<title>
Slingering vliegwiel/aandrijfplaat
</title>
<ptxt>
Grenswaarde: 0,2 mm (0,0079 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I2RH01140198.swf" width = "88.000mm" height = "42.110mm" ver = "01" gw = "183" gh = "102"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
