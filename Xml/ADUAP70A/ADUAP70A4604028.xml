<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A4604028" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1047 / C1048
</title>
<servinfosub id = "ADUAP70A4604028001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.814in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.366in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1047: Signaalprestaties van beide voorwieltoerentalsensoren of de codeerinrichting 
</emph>
</ptxt>
<ptxt>
Gierratio geschat door beide voorwieltoerentalsensoren komt niet overeen met het gierratiosensorsignaal.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Stuurhoeksensor
</ptxt>
</item>
<item>
<ptxt>
Wieltoerentalsensor
</ptxt>
</item>
<item>
<ptxt>
Circuit van de wieltoerentalsensor
</ptxt>
</item>
<item>
<ptxt>
Wieltoerentalsensorcodeerinrichting
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup>-regelapparaat
</ptxt>
</item>
</list1>
<ptxt>
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1048: Signaalprestaties van beide achterwieltoerentalsensoren of de codeerinrichting 
</emph>
</ptxt>
<ptxt>
Gierratio geschat door beide achterwieltoerentalsensoren komt niet overeen met het gierratiosensorsignaal.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A4604028002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604028003">
<testgroup id = "ADUAP70A4604028004">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604028005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A4604005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Worden er behalve C1047 of C1048 nog andere DTC&#39;s weergegeven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604028006">
<title>
Onderzoek in het voertuig van de stuurhoeksensor
</title>
<test1>
<ptxt>
Controleer de stuurhoeksensor. 
<intxreftitleoff1 refid = "ADUAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is hij in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Vervang de stuurhoeksensor en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604028007">
<title>
Controle van de wieltoerentalsensor
</title>
<test1>
<ptxt>
Controleer de betrokken wieltoerentalsensor, codeerinrichting van de wieltoerentalsensor en/of het wieltoerentalsensorcircuit volgens 
<intxref refid = "ADUAP70A4604018">DTC C1021 / C1022 / C1025 / C1026 / C1031 / C1032 / C1033/ C1035 / C1036</intxref>
.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang het defecte onderdeel.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
