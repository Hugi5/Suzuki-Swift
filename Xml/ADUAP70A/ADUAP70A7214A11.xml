<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A7214A11" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Onvoldoende stroom van gekoelde lucht
</title>
<diag type = "condition">
<condition>
<ptxt>
Onvoldoende stroom van gekoelde lucht
</ptxt>
</condition>
<ps>
<ptxt>
De A/C-verdamper is verstopt of bevroren
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controleer de A/C-verdamper en de verdampertemperatuursensor.
</ptxt>
<ptxt>
- A/C-verdamper: 
<intxreftitleoff1 refid = "ADUAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
- Verdampertemperatuursensor: 
<intxreftitleoff1 refid = "ADUAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Er lekt lucht uit de HVAC-eenheid of het luchtkanaal
</ptxt>
</ps>
<action>
<ptxt>
Repareer de HVAC-eenheid of het luchtkanaal.
</ptxt>
</action>
<ps>
<ptxt>
Defecte aanjagermotor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aanjagermotor. 
<intxreftitleoff1 refid = "ADUAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
