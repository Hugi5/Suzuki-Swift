<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9F06008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de USB-stekkerdoos
</title>
<servinfosub id = "ADUAP70A9F06008001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het middenconsolevak. 
<intxreftitleoff1 refid = "ADUAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de middenzijdebedekking. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding (1) van de USB-stekkerdoos los en verwijder vervolgens de USB-stekkerdoos (2) van het instrumentenpaneel (3) terwijl de vergrendelingen (4) worden losgemaakt.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0014.jpg" width = "88.000mm" height = "55.000mm" ver = "02" gw = "206" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9F06008002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9F06009">Onderzoek van de USB-stekkerdoos</intxrefpoff>
</ptxt>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
