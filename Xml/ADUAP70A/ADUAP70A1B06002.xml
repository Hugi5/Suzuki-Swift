<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1K">
<servcat sctnbr = "01" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1B06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van het uitlaatspruitstuk
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1B06001">Componenten van het uitlaatsysteem</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1B06002001" page = "2">
<title>
Uitbouw
</title>
<attention2>
<ptxt>
Laat het uitlaatspruitstuk niet vallen. Als deze valt, kan de katalysator binnenin beschadigd raken.
</ptxt>
</attention2>
<s1 page = "2">
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Maak de A/F-sensorstekker (1) (kleur van de stekkerverbinding: zwart) en de HO2S-stekker (2) (kleur van de stekkerverbinding: grijs) los en maak ze los van hun steun.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0002.swf" width = "88.000mm" height = "53.833mm" ver = "01" gw = "171" gh = "136"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Maak uitlaatpijp nr. 1 (1) los van het uitlaatspruitstuk.
</ptxt>
<figure page = "2">
<graphic graphicname = "I7V20A1B1003.swf" width = "88.000mm" height = "51.237mm" ver = "01" gw = "163" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Verwijder de uitlaatspruitstukverstevigingsplaten (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder de bedekking (3) van het uitlaatspruitstuk.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder de A/F-sensor (4) en HO2S (5) van het uitlaatspruitstuk, indien nodig. 
<intxreftitleoff1 refid = "ADUAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder het uitlaatspruitstuk (1) en de bijbehorende pakking van de cilinderkop.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0003.swf" width = "88.000mm" height = "70.972mm" ver = "01" gw = "193" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1B06002002" page = "2">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Gebruik een nieuwe pakking.
</ptxt>
</item>
<item>
<ptxt>
Haal de bouten en moeren van het uitlaatspruitstuk met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1K001">
<t-part>
Bout van het uitlaatspruitstuk
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6,1
</t-value2>
<t-value3>
44,5
</t-value3>
</torqueitem>
<torqueitem id = "T1K002">
<t-part>
Moer van het uitlaatspruitstuk
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6,1
</t-value2>
<t-value3>
44,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1002.jpg" width = "88.000mm" height = "57.647mm" ver = "02" gw = "199" gh = "147"/>
</figure>
</item>
<item>
<ptxt>
Monteer de A/F-sensor en de HO2S indien verwijderd. 
<intxreftitleoff1 refid = "ADUAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Monteer de uitlaatspruitstukverstevigingsplaten als volgt.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Monteer de uitlaatspruitstukverstevigingsplaten (1) en haal vervolgens de moeren (2) van de uitlaatspruitstukverstevigingsplaten met de hand aan.
</ptxt>
</item>
<item>
<ptxt>
Haal de bouten van de uitlaatspruitstukverstevigingsplaten (3) aan en haal vervolgens de moeren (2) van de uitlaatspruitstukverstevigingsplaten aan.
</ptxt>
<figure>
<graphic graphicname = "IAP70P1B0004.swf" width = "88.000mm" height = "64.959mm" ver = "01" gw = "172" gh = "168"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Haal de bouten van uitlaatpijp nr. 1 met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1K003">
<t-part>
Bout van uitlaatpijp nr. 1
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
43
</t-value1>
<t-value2>
4,4
</t-value2>
<t-value3>
32,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1004.swf" width = "88.000mm" height = "54.949mm" ver = "01" gw = "153" gh = "139"/>
</figure>
</item>
<item>
<ptxt>
Laat de motor draaien en controleer op uitlaatgaslekkage.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
