<title>
Uit- en inbouw van de luidspreker vooraan en de luidspreker achteraan
</title>
<servinfosub id = "ADUAP70A9F06002001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de portierbekleding.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voor: 
<intxreftitleoff1 refid = "ADUAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Achter: 
<intxreftitleoff1 refid = "ADUAP70A9506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Verwijder de 3 schroeven en verwijder de luidspreker vooraan of achteraan (1).
</ptxt>
</s1>
<s1>
<ptxt>
Maak de luidsprekerstekkerverbinding los.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A9F0005.jpg" width = "88.000mm" height = "65.800mm" ver = "01" gw = "168" gh = "170"/>
</figure>
</servinfosub>
<servinfosub id = "ADUAP70A9F06002002">
<title>
Inbouw
</title>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
