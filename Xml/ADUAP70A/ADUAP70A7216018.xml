<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A7216018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de expansieklep
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A7216007">Componenten van de HVAC-eenheid:Handmatig type</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A7216018001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Win koelmiddel uit het A/C-systeem met terugwinnings- en recycleerapparatuur terug volgens &#34;Terugwinnen&#34; in 
<intxref refid = "ADUAP70A7216007">Componenten van de HVAC-eenheid:Handmatig type</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Draai de bout (1) los en verwijder vervolgens de vloeistofleiding en aanzuigslang van de expansieklep (2).
</ptxt>
</s1>
<s1>
<ptxt>
Draai de bouten (3) los en verwijder de expansieklep.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A720028.swf" width = "88.000mm" height = "43.902mm" ver = "01" gw = "173" gh = "109"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7216018002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A7216019">Onderzoek van de expansieklep:Handmatig type</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Breng compressorolie op de O-ring van de expansieklep en de leidingen aan.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B104" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Compressorolie
</m-desc>
<m-number>
99000-99095-00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Haal de expansieklepbouten met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T7B102">
<t-part>
Expansieklepbout
</t-part>
<t-value1>
7,0
</t-value1>
<t-value2>
0,7
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Zuig het A/C-systeem vacuüm en vul het volgens &#34;Vacuüm zuigen&#34; en &#34;Vullen&#34; in 
<intxref refid = "ADUAP70A7216001">Bedieningsprocedure voor koelmiddelvulling:Handmatig type</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
