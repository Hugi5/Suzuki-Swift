<servinfosub id = "ADUAP70A4604030003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604030004">
<testgroup id = "ADUAP70A4604030005">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604030006">
<title>
Controle van het voedingscircuit van het ESP&#174;-regelapparaat
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak stekkerverbinding &#34;E24&#34; los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of aansluitklem &#34;E24-26&#34; juist is aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Als de aansluiting in orde is, controleer dan de spanning tussen aansluitklem &#34;E24-26&#34; en de massa.
</ptxt>
</test1>
<question>
Bedraagt de spanning 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang circuit &#34;A1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604030007">
<title>
Controle van het massacircuit van het ESP&#174;-regelapparaat
</title>
<test1>
<ptxt>
Meet de weerstand tussen elk van de aansluitklemmen &#34;E24-14&#34; en &#34;E24-27&#34; en de massa.
</ptxt>
</test1>
<question>
Bedraagt de weerstand minder dan 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang circuit &#34;B1&#34; en/of circuit &#34;B2&#34;.
</ptxt>
</action>
</testgroup>
</diag>
