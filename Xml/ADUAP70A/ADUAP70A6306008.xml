<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A6306008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de trekstang / tandheugelhoes
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A6306003">Uit- en inbouw van het trekstanguiteinde</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ADUAP70A6306001">Componenten van het stuurhuissamenstel</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ADUAP70A6306007">Onderzoek van de tandheugelhoes</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A6306008001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het stuurhuissamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het trekstanguiteinde. 
<intxreftitleoff1 refid = "ADUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de klemband (2) en de tandheugelhoesklem (1).
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Verwijder de tandheugelhoes (3) van de trekstang.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630026.swf" width = "88.000mm" height = "53.031mm" ver = "02" gw = "158" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Buig de verbogen delen van de trekstangborgring (1) recht.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de trekstang (3) van de heugel (2) zoals afgebeeld.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630027.swf" width = "88.000mm" height = "46.459mm" ver = "01" gw = "197" gh = "115"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A6306008002">
<title>
Inbouw
</title>
<s1>
<ptxt>
Lijn de groef (5) van de heugel (2) met het uitsteeksel (4) van de nieuwe trekstangborgring (3) uit.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de trekstang (1) op de heugel (2) en haal daarna de trekstang met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T6C003">
<t-part>
Trekstang
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A630015.swf" width = "88.000mm" height = "55.132mm" ver = "01" gw = "145" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Buig de borgring (1) op 2 plaatsen, zoals op de afbeelding.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630029.swf" width = "88.000mm" height = "51.419mm" ver = "02" gw = "144" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Breng vet op deel &#34;A&#34; van de trekstang aan, zoals op de afbeelding. Plaats de tandheugelhoes op de juiste wijze in de groeven van het stuurhuissamenstel (of de bevestiging aan de zijkant van de heugel) en de trekstang.
</ptxt>
<ptxt>
Controleer vervolgens of de tandheugelhoes niet verdraaid of gedeukt is.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease E" id = "M6C001" uid = "24">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25050
</m-number>
<m-name>
SUZUKI Super Grease E
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A630030.swf" width = "88.000mm" height = "33.098mm" ver = "01" gw = "196" gh = "77"/>
</figure>
</s1>
<s1>
<ptxt>
Bevestig de nieuwe klemband (1) met behulp van speciaal gereedschap en monteer de tandheugelhoesklem (2)
</ptxt>
<servicetool>
<servicetoolitem id = "L6C008">
<s-part>
(A)
</s-part>
<s-number num = "09943-55010">
09943-55010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630031.swf" width = "88.000mm" height = "40.262mm" ver = "01" gw = "161" gh = "98"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer het trekstanguiteinde. 
<intxreftitleoff1 refid = "ADUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Monteer het stuurhuissamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
