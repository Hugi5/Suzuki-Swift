<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van het open-daksamenstel
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9906001">Componenten van het open dak</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A9906002001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de dakvoering. 
<intxreftitleoff1 refid = "ADUAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de ruit van het open dak. 
<intxreftitleoff1 refid = "ADUAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de aftapslangen (1) los, die op 4 plaatsen met het open-daksamenstel verbonden zijn.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990005.jpg" width = "88.000mm" height = "75.169mm" ver = "01" gw = "227" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de open-dakmotor (1) los.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990006.jpg" width = "88.000mm" height = "69.556mm" ver = "01" gw = "225" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Maak de klemmen (1) en de open-dakbedradingsbundel (2) los.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990007.jpg" width = "88.000mm" height = "61.392mm" ver = "01" gw = "227" gh = "158"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de moeren van het open-dakhuis (1) en vervolgens het open-daksamenstel (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A990008.jpg" width = "88.000mm" height = "83.554mm" ver = "01" gw = "227" gh = "220"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ADUAP70A9906002002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal alle onderdelen met het voorgeschreven koppel aan volgens 
<intxref refid = "ADUAP70A9906001">Componenten van het open dak</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Haal de moeren van het open-dakhuis (1) in de juiste volgorde (&#34;1&#34; tot &#34;4&#34;) aan, zoals in de afbeelding.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990009.jpg" width = "88.000mm" height = "82.828mm" ver = "01" gw = "227" gh = "218"/>
</figure>
</item>
<item>
<ptxt>
Sluit de aftapslangen (1) op 4 plaatsen op het open-daksamenstel aan. Klem de aftapslangen met klemmen (2) stevig vast.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990010.jpg" width = "88.000mm" height = "75.168mm" ver = "01" gw = "227" gh = "197"/>
</figure>
<figure>
<title>
Voorstijl
</title>
<graphic graphicname = "I9P60A990011.swf" width = "88.000mm" height = "95.842mm" ver = "02" gw = "210" gh = "255"/>
</figure>
<figure>
<title>
Zijpaneel
</title>
<graphic graphicname = "I9P60A990013.swf" width = "88.000mm" height = "94.869mm" ver = "03" gw = "225" gh = "252"/>
</figure>
</item>
<item>
<ptxt>
Initialiseer de open-dakmotor. 
<intxreftitleoff1 refid = "ADUAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Stel de ruit af nadat het open-daksamenstel opnieuw is gemonteerd. 
<intxreftitleoff1 refid = "ADUAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
