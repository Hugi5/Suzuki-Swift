<testgroup id = "ADUAP70AA324014004">
<title>
DTC-controle
</title>
<question>
Worden behalve B1169 nog andere DTC&#39;s waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
