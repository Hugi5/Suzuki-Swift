<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A9904001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Diagnose van de symptomen van het elektrisch bediende open-daksysteem
</title>
<diag type = "condition" id = "ADUAP70A9904001001">
<condition>
<ptxt>
Het open dak werkt niet (de open-dakmotor werkt wel)
</ptxt>
</condition>
<ps>
<ptxt>
Er zit een voorwerp vast in de open-dakrail
</ptxt>
</ps>
<action>
<ptxt>
Verwijder het geblokkeerde voorwerp of maak het los.
</ptxt>
</action>
<ps>
<ptxt>
Onjuiste montage van de open-dakrail
</ptxt>
</ps>
<action>
<ptxt>
Goed monteren.
</ptxt>
</action>
<ps>
<ptxt>
Interferentie van onderdelen van het open dak
</ptxt>
</ps>
<action>
<ptxt>
Los de interferentie op.
</ptxt>
</action>
<ps>
<ptxt>
Onjuiste montage van de open-dakaandrijfkabel
</ptxt>
</ps>
<action>
<ptxt>
Goed monteren.
</ptxt>
</action>
<condition>
<ptxt>
Automatisch schuiven en automatisch kantelen werkt niet (werkt alleen handmatig)
</ptxt>
</condition>
<ps>
<ptxt>
Initialisatie is defect
</ptxt>
</ps>
<action>
<ptxt>
Initialiseer de open-dakmotor. 
<intxreftitleoff1 refid = "ADUAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Onjuiste montagepositie van de ruit van het open dak
</ptxt>
</ps>
<action>
<ptxt>
Stel de montagepositie van de ruit van het open dak bij. 
<intxreftitleoff1 refid = "ADUAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte schuifbeweging van de open-dakeenheid
</ptxt>
</ps>
<action>
<ptxt>
Vervang de open-dakeenheid. 
<intxreftitleoff1 refid = "ADUAP70A9906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte open-dakmotor
</ptxt>
</ps>
<action>
<ptxt>
Vervang de open-dakmotor. 
<intxreftitleoff1 refid = "ADUAP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Het open dak werkt niet (de open-dakmotor werkt niet)
</ptxt>
</condition>
<ps>
<ptxt>
Gesprongen zekering
</ptxt>
</ps>
<action>
<ptxt>
Vervang de zekering.
</ptxt>
</action>
<ps>
<ptxt>
Defecte open-dakschakelaar
</ptxt>
</ps>
<action>
<ptxt>
Controleer de open-dakschakelaar. 
<intxreftitleoff1 refid = "ADUAP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Controleer het circuit. 
<intxreftitleoff1 refid = "ADUAP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "ADUAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte open-dakmotor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de open-dakmotor. 
<intxreftitleoff1 refid = "ADUAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Lekkage van regen
</ptxt>
</condition>
<ps>
<ptxt>
Onjuiste montagepositie van de ruit van het open dak
</ptxt>
</ps>
<action>
<ptxt>
Stel de montagepositie van de ruit van het open dak bij. 
<intxreftitleoff1 refid = "ADUAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte ruit van het open dak
</ptxt>
</ps>
<action>
<ptxt>
Vervang de ruit van het open dak. 
<intxreftitleoff1 refid = "ADUAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ontkoppelde of verstopte aftapslang (voor/achter)
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aftapslang (voor/achter).
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
