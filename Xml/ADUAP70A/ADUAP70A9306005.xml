<section sectnbr = "9C">
<servcat sctnbr = "09" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9306005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de parkeersensor (indien uitgerust)
</title>
<servinfosub id = "ADUAP70A9306005001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de achterbumper. 
<intxreftitleoff1 refid = "ADUAP70A9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de parkeersensorstekker los.
</ptxt>
</s1>
<s1>
<ptxt>
Trek de parkeersensordeksel (1) los zoals op de afbeelding.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930025.jpg" width = "88.000mm" height = "106.836mm" ver = "01" gw = "208" gh = "286"/>
</figure>
</s1>
<s1>
<ptxt>
Open de klauwen (1) en verwijder de parkeersensor (2) zoals op de afbeelding.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930026.jpg" width = "88.000mm" height = "63.752mm" ver = "01" gw = "196" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder indien nodig de sensorbeugel.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9306005002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9306006">Onderzoek van de parkeersensor (indien uitgerust)</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reinig en ontvet de plaats waar de sensorbeugel (1) gemonteerd moet worden.
</ptxt>
</item>
<item>
<ptxt>
Breng grondverf (een equivalent van SUMITOMO 3M K-520 of 4298UV) op de plaats waar de sensorbeugel gemonteerd moet worden aan.
</ptxt>
</item>
<item>
<ptxt>
Monteer de sensorbeugel in de richting zoals op de afbeelding.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A930039.jpg" width = "88.000mm" height = "98.016mm" ver = "01" gw = "199" gh = "261"/>
<callout>
