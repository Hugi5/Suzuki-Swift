<servinfo servinfosgmlid = "ADUAP70A7224012" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Uitvalbeveiligingstabel
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.906in"/>
<colspec colnum = "2" colname = "2" colwidth = "6.299in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Werking van de uitvalbeveiliging
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1502-H&#183;L
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Het HVAC-regelapparaat regelt de stelmotoren in de veronderstelling dat de binnenluchttemperatuur 25 &#176;C (77 &#176;F) is.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1503
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Het HVAC-regelapparaat regelt de stelmotoren in de veronderstelling dat de verdampertemperatuur 0 &#176;C (32 &#176;F) is.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1504-L
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Het HVAC-regelapparaat regelt de stelmotoren in de veronderstelling dat de hoeveelheid zonlicht 0 W/m<sup>2</sup> is.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1511-H&#183;L
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
De werking van de stelmotor van de temperatuurregeling wordt stopgezet.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1513
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1512-H&#183;L
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
De werking van de stelmotor van de luchtstroomregeling wordt stopgezet.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1514
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1550-H&#183;L
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Het HVAC-regelapparaat bestuurt de stelmotoren, uitgaande van de volgende punten: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
De temperatuurkeuzeschakelaar staat in de stand 25 &#176;C (77 &#176;F).
</ptxt>
</item>
<item>
<ptxt>
De luchtstroomkeuzeschakelaar staat in de &#34;DEF&#34;-modus.
</ptxt>
</item>
<item>
<ptxt>
De luchtinlaat-keuzeschakelaar staat in de &#34;FRE&#34;-modus.
</ptxt>
</item>
<item>
<ptxt>
De aanjager stuurt naar &#34;Auto&#34;.
</ptxt>
</item>
<item>
<ptxt>
A/C-systeem: ON.
</ptxt>
</item>
<item>
<ptxt>
Achterruitverwarming: OFF.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1544
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1557
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Het HVAC-regelapparaat regelt de stelmotoren in de veronderstelling dat de rijsnelheid 40 km/h (25 mph) is.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1561
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Het HVAC-regelapparaat regelt de stelmotoren in de veronderstelling dat de motorkoelvloeistoftemperatuur 80 &#176;C (176 &#176;F) is.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1562
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Het HVAC-regelapparaat regelt de stelmotoren in de veronderstelling dat de buitenluchttemperatuur 20 &#176;C (68 &#176;F) is.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1563
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Het HVAC-regelapparaat regelt de stelmotoren in de veronderstelling dat de koelmiddeldruk 0 Mpa (0 kg/cm<sup>2</sup>, 0 psi) is. 
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1570
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Het HVAC-regelapparaat stuurt de stelmotoren aan gebaseerd op de gegevens voor het waarnemen van een DTC.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
B1571
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfo>
