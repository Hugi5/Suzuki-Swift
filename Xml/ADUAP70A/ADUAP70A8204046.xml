<servinfosub id = "ADUAP70A8204046003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A8204046004">
<testgroup id = "ADUAP70A8204046005">
<question>
Werd de &#34;Controle van het airbagdiagnosesysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204046006">
<title>
Controle van de gordijnairbag (opblaaseenheid)-module
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;L290&#34;- of &#34;L291&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Sluit &#34;STEERING WHEEL&#34; (1) met speciaal gereedschap (A), (B) en (C) op de &#34;L290&#34;- of &#34;L291&#34;-stekkerverbinding aan.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B085">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B086">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932-78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B087">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932-75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820034.swf" width = "90.000mm" height = "73.606mm" ver = "02" gw = "199" gh = "192"/>
</testfigure>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC B1362 of B1366 aangeduid?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de gordijnairbag (opblaaseenheid)-module. 
<intxreftitleoff1 refid = "ADUAP70A8206018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204046007">
<title>
Controle van het vloerbedradingsbundelcircuit
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;L05&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de kortsluitbeugel in de SDM-stekkerverbinding los met het vrijzetgereedschap dat behoort tot het speciaal gereedschap (A).
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand tussen aansluitingen &#34;L05-7&#34; en &#34;L05-8&#34; (DTC B1362): oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen aansluitingen &#34;L05-5&#34; en &#34;L05-6&#34; (DTC B1366): oneindig
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B088">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820113.swf" width = "90.000mm" height = "67.845mm" ver = "01" gw = "219" gh = "176"/>
</testfigure>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de SDM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de vloerbedradingsbundel.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Voer na het onderzoek en de reparaties de volgende stappen uit.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sluit alle componenten van het airbagsysteem weer aan en controleer of ze juist zijn gemonteerd.
</ptxt>
</item>
<item>
<ptxt>
Wis eventuele DTC&#39;s volgens 
<intxref refid = "ADUAP70A8204006">Wissen van DTC</intxref>
, als een DTC wordt waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Herhaal 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
 om te controleren of de storing is opgelost.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
