<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A8106009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van het achterbank-veiligheidsgordelsamenstel
</title>
<servinfosub id = "ADUAP70A8106009001">
<title>
Uitbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A8106008">Componenten van de achterbank-veiligheidsgordel</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Verwijder de rugleuning van de achterbank. 
<intxreftitleoff1 refid = "ADUAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bovenste zijpaneelbinnenbekleding. 
<intxreftitleoff1 refid = "ADUAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bouten en verwijder vervolgens het achterbank-veiligheidsgordelsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A8106009002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A8106008">Componenten van de achterbank-veiligheidsgordel</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Controleer of de pennen (3) op de carrosserie in de langgaten (2) in het oprolmechanisme (1) zijn gestoken.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810014.swf" width = "88.000mm" height = "66.076mm" ver = "01" gw = "206" gh = "171"/>
</figure>
</item>
<item>
<ptxt>
Haal de bouten van de achterbank-veiligheidsgordel in numerieke volgorde met het voorgeschreven koppel aan. 
<intxreftitleoff1 refid = "ADUAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Monteer iedere ankerplaat (1) zonder in elkaar grijpen met de omgebogen rand (2) op het vloerplaatwerk.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810015.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
