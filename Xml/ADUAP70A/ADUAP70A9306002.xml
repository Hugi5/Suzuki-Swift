<servinfo servinfosgmlid = "ADUAP70A9306002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de claxon
</title>
<servinfosub id = "ADUAP70A9306002001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de voorbumper. 
<intxreftitleoff1 refid = "ADUAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de claxonstekker (1) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de claxonbout (3) en verwijder de claxon zelf (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A930022.jpg" width = "88.000mm" height = "63.673mm" ver = "02" gw = "195" gh = "164"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9306002002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9306003">Onderzoek van de claxon</intxrefpoff>
</ptxt>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
