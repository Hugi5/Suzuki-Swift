<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1A06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de dynamosteun
</title>
<servinfosub id = "ADUAP70A1A06006001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de rechtse beschermplaat aan de onderkant van de motor.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de waterpomp / dynamoaandrijfriem. 
<intxreftitleoff1 refid = "ADUAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de waterpomppoelie (1). 
<intxreftitleoff1 refid = "ADUAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de dynamobout (2).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de dynamosteun (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1007.jpg" width = "88.000mm" height = "70.982mm" ver = "01" gw = "192" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1A06006002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Monteer de dynamosteun volgens de volgende procedure.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Richt de dynamosteun (1).
</ptxt>
</item>
<item>
<ptxt>
Haal de dynamobout (2) lichtjes aan.
</ptxt>
</item>
<item>
<ptxt>
Haal de dynamosteunmoeren (3) met het voorgeschreven koppel aan. 
<intxreftitleoff1 refid = "ADUAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
<figure>
<graphic graphicname = "I9P60A1A1016.swf" width = "88.000mm" height = "68.664mm" ver = "01" gw = "188" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
