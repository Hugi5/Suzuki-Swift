<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1306013" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Onderzoek in het voertuig van de A/F-sensor
</title>
<c-change/>
<servinfosub id = "ADUAP70A1306013002">
<title>
A/F-sensorverwarming
</title>
<s1>
<ptxt>
Maak de A/F-sensorstekker los met de ontsteking uitgeschakeld.
</ptxt>
</s1>
<s1>
<ptxt>
Meet met een ohmmeter de weerstand van de A/F-sensorstekker (sensorzijde) tussen aansluiting &#34;2&#34; en &#34;5&#34; op de A/F-sensorstekker. Vervang de A/F-sensor als een defect wordt vastgesteld. 
<intxreftitleoff1 refid = "ADUAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention3>
<ptxt>
De temperatuur van de sensor beïnvloedt de weerstandswaarde in sterke mate. Zorg dat de sensorverwarming de juiste temperatuur heeft.
</ptxt>
</attention3>
<spec>
<title>
Weerstand A/F-sensorverwarming
</title>
<ptxt>
2,4 tot 4,0 &#937; bij 20&#176;C (68&#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7N301132038.swf" width = "88.000mm" height = "30.676mm" ver = "01" gw = "67" gh = "70"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.314in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.150in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Stekker van de A/F-sensor (gezien van de aansluitingszijde)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1306013003" page = "2">
<title>
Regelweerstand van de A/F-sensor
</title>
<ptxt>
Meet met een ohmmeter de weerstand tussen aansluiting &#34;1&#34; en &#34;3&#34; op de A/F-sensorstekker. Vervang de A/F-sensor als een defect wordt vastgesteld. 
<intxreftitleoff1 refid = "ADUAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<spec>
<title>
Regelweerstand A/F-sensor
</title>
<ptxt>
30 tot 300 &#937; bij 20&#176;C (68&#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7N301132038.swf" width = "88.000mm" height = "30.676mm" ver = "01" gw = "67" gh = "70"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
