</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Stekker van de A/F-sensor (gezien van de aansluitingszijde)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
