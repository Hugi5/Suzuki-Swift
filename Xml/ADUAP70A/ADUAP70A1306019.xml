<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1306019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de CKP-sensor
</title>
<servinfosub id = "ADUAP70A1306019001" page = "2">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de dynamo. 
<intxreftitleoff1 refid = "ADUAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de CKP-sensor los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de CKP-sensor (1) van het cilinderblok.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A131017.jpg" width = "88.000mm" height = "57.392mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</servinfosub>
<servinfosub id = "ADUAP70A1306019002" page = "2">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1306020">Onderzoek van de CKP-sensor</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Breng motorolie op de O-ring van de sensor aan.
</ptxt>
</item>
<item>
<ptxt>
Draai de CKP-sensorbout met het voorgeschreven koppel aan.
</ptxt>
<attention2>
<ptxt>
Gebruik nieuwe bouten die met kleefmiddel zijn voorbehandeld. Anders kunnen de bouten loskomen.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T1C007">
<t-part>
CKP-sensorbout
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131008.jpg" width = "88.000mm" height = "57.393mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</item>
<item>
<ptxt>
Sluit de stekkerverbinding aan en ze de bedradingsbundel met een klem goed vast.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
