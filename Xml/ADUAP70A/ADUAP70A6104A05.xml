<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A6104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Zoekende voorwielen of slechte stuurstabiliteit
</title>
<diag type = "condition">
<condition>
<ptxt>
Zoekende voorwielen of slechte stuurstabiliteit
</ptxt>
</condition>
<ps>
<ptxt>
Niet-passende band of ongelijke bandenspanning
</ptxt>
</ps>
<action>
<ptxt>
Vervang of stel de bandenspanning bij. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loszittende wieldraagarmkoppeling en trekstanguiteinde
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vervang de wieldraagarm of het trekstanguiteinde.
</ptxt>
<ptxt>
Wieldraagarm: 
<intxreftitleoff1 refid = "ADUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Trekstanguiteinde: 
<intxreftitleoff1 refid = "ADUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Defect voorste veerpootsamenstel of ophanging
</ptxt>
</ps>
<action>
<ptxt>
Vervang het voorste veerpootsamenstel of repareer de ophanging. 
<intxreftitleoff1 refid = "ADUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loszittende stabilisatorstang
</ptxt>
</ps>
<action>
<ptxt>
Haal de stabilisatorstang of bus aan of vervang ze. 
<intxreftitleoff1 refid = "ADUAP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kapotte of niet goed gespannen schroefveer
</ptxt>
</ps>
<action>
<ptxt>
Vervang de schroefveer. 
<intxreftitleoff1 refid = "ADUAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defect voorste veerpootsamenstel (schokdemper)
</ptxt>
</ps>
<action>
<ptxt>
Vervang het voorste veerpootsamenstel (schokdemper). 
<intxreftitleoff1 refid = "ADUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Onjuist tandcontact tussen rondsel en tandheugel
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controleer de voorspanning van de rondsel- en tandheugelas. 
<intxreftitleoff1 refid = "ADUAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Vervang het stuurhuissamenstel als er een defect wordt vastgesteld. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Verstoorde voorwieluitlijning
</ptxt>
</ps>
<action>
<ptxt>
Controleer de voorwieluitlijning en stel ze bij. 
<intxreftitleoff1 refid = "ADUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defect stuurhuissamenstel
</ptxt>
</ps>
<action>
<ptxt>
Vervang het stuurhuissamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
