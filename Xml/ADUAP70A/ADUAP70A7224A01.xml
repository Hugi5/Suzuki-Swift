<servinfo servinfosgmlid = "ADUAP70A7224A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
De aanjagermotor werkt niet
</title>
<diag type = "condition">
<condition>
<ptxt>
De aanjagermotor werkt niet
</ptxt>
</condition>
<ps>
<ptxt>
Gesprongen zekering
</ptxt>
</ps>
<action>
<ptxt>
Controleer de betrokken zekeringen en controleer op kortsluitingen aan de massa.
</ptxt>
</action>
<ps>
<ptxt>
Defecte aanjagermotorstuureenheid
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aanjagermotorstuureenheid. 
<intxreftitleoff1 refid = "ADUAP70A7226014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defect HVAC-regelapparaat
</ptxt>
</ps>
<action>
<ptxt>
Controleer het HVAC-regelapparaat. 
<intxreftitleoff1 refid = "ADUAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
<ps>
<ptxt>
Defecte aanjagermotor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aanjagermotor. 
<intxreftitleoff1 refid = "ADUAP70A7226014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defect aanjagermotorrelais
</ptxt>
</ps>
<action>
<ptxt>
Controleer het aanjagermotorrelais. 
<intxreftitleoff1 refid = "ADUAP70A7226042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defect paneel van de automatische A/C
</ptxt>
</ps>
<action>
<ptxt>
Controleer de automatische A/C. 
<intxreftitleoff1 refid = "ADUAP70A7224037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
