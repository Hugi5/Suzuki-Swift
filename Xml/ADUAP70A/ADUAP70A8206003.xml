<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A8206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de SDM
</title>
<attention1>
<ptxt>
Hanteer een SDM tijdens de onderhoudsprocedures voorzichtig.
</ptxt>
<ptxt>
Lees 
<intxref refid = "ADUAP70A8200002">Voorzorgsmaatregelen bij het behandelen en opslaan van airbagsysteemcomponenten</intxref>
 alvorens met het werk te beginnen en neem tijdens het werk elke voorzorgsmaatregel in acht. Het niet-naleven van de voorzorgsmaatregelen kan leiden tot persoonlijk letsel, overlijden of het niet in werking treden van de airbagsysteem als dat nodig is.
</ptxt>
</attention1>
<servinfosub id = "ADUAP70A8206003001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Stel het airbagsysteem buiten werking. 
<intxreftitleoff1 refid = "ADUAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het achterste vloerconsolevak. 
<intxreftitleoff1 refid = "ADUAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Trek de vloerbedekking omhoog. 
<intxreftitleoff1 refid = "ADUAP70A9806010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bouten (1) en verwijder daarna de steun (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820048.swf" width = "88.000mm" height = "76.877mm" ver = "01" gw = "234" gh = "201"/>
</figure>
</s1>
<s1>
<ptxt>
Maak de SDM-stekkerverbindingen (1) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de SDM-bouten (2) en verwijder vervolgens de SDM (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820046.swf" width = "88.000mm" height = "68.795mm" ver = "01" gw = "236" gh = "178"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A8206003002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A8206004">Onderzoek van de SDM</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Controleer of geen van de volgende defecten aanwezig is.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Verbuiging, krassen, vervorming op het pasvlak of de carrosserie waar de SDM is gemonteerd.
</ptxt>
</item>
<item>
<ptxt>
Vreemd materiaal of roest op het pasvlak van de carrosserie waar de SDM gemonteerd is.
</ptxt>
</item>
</list2>
<item>
<ptxt>
Zorg ervoor dat de pijl (1) op de SDM naar de voorzijde van het voertuig wijst.
</ptxt>
</item>
<item>
<ptxt>
Haal de SDM-bouten (2) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T8B001">
<t-part>
SDM-bout
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,0
</t-value1>
<t-value2>
0,92
</t-value2>
<t-value3>
7,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A820047.swf" width = "88.000mm" height = "70.496mm" ver = "01" gw = "236" gh = "183"/>
</figure>
</item>
<item>
<ptxt>
Monteer de steun (2) en haal vervolgens de bouten (1) aan.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820049.swf" width = "88.000mm" height = "76.877mm" ver = "01" gw = "234" gh = "201"/>
</figure>
</item>
<item>
<ptxt>
Activeer het airbagsysteem. 
<intxreftitleoff1 refid = "ADUAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
