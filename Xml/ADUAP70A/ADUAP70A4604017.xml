<servinfosub id = "ADUAP70A4604017003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604017004">
<testgroup id = "ADUAP70A4604017005">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604017006">
<title>
DTC-controle van ESP&#174;
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A4604005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Worden DTC U0073 en/of U0100 weergegeven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604017007">
<title>
Controle van de remlichtschakelaar en het remlichtcircuit
</title>
<test1>
<ptxt>
Controleer de remlichtschakelaar en de bijbehorende circuits volgens stap 2 tot en met 4 onder 
<intxref refid = "ADUAP70A1104040">DTC P0504</intxref>
.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang.
</ptxt>
</action>
</testgroup>
</diag>
