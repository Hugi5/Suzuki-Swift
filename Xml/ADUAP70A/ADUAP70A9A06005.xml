<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van het voorwielspatbord
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9A06004">Componenten van het voorwielspatbord</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A9A06005001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de voorbumper en de voorbumperhouder. 
<intxreftitleoff1 refid = "ADUAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bekleding aan de bovenkant van het schutbord en de bekleding opzij aan de bovenkant van het schutbord. 
<intxreftitleoff1 refid = "ADUAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de koplampeenheid. 
<intxreftitleoff1 refid = "ADUAP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de richtingaanwijzer aan de zijkant. 
<intxreftitleoff1 refid = "ADUAP70A9206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de zijdrempelbescherming. 
<intxreftitleoff1 refid = "ADUAP70A9806007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de voorwielspatbordvoering.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het voorwielspatbord en het voorwielspatborddeksel.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9A06005002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Stel de speling van het voorwielspatbordpaneel bij. 
<intxreftitleoff1 refid = "ADUAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Als de verfmarkering op de bouten van het voorwielspatbord afgeschilferd is, moet ze opnieuw aangebracht worden om roestvorming te voorkomen.
</ptxt>
</item>
<item>
<ptxt>
Richt de koplampen na montage. 
<intxreftitleoff1 refid = "ADUAP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
