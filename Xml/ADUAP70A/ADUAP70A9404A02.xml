<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A9404A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ruitensproeierstoringen
</title>
<servinfosub id = "ADUAP70A9404002001">
<title>
Voorruitwisser en -sproeier
</title>
<diag type = "condition">
<condition>
<ptxt>
Ruitensproeierstoringen
</ptxt>
</condition>
<ps>
<ptxt>
Defecte sproeierslang (inclusief terugslagklep en koppelstuk) of sproeierkop
</ptxt>
</ps>
<action>
<ptxt>
Controleer de sproeierslang of sproeierkop op verstopping en verbuiging. 
<intxreftitleoff1 refid = "ADUAP70A9403001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte ruitensproeierpomp
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9406002">Onderzoek van de ruitensproeierpomp</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte ruitenwisser- en -sproeierschakelaar (sproeierschakelaar)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A9406008">Onderzoek van de ruitenwisser- en sproeierschakelaar</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
