<servinfosub id = "ADUAP70A1104057003">
<title>
DTC-controleprocedure
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Zorg dat u eerst onverwachte DTC&#39;s oplost die eerder tijdens de &#34;DTC-controleprocedure&#34; zijn waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Controleer of aan de volgende voorwaarden in deze &#34;DTC-controleprocedure&#34; is voldaan.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Systeemspanning &#62; 8 V
</ptxt>
</item>
<item>
<ptxt>
DTC P2122, P2123, P2127 of P2128 wordt niet waargenomen.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</s1>
<s1>
<ptxt>
Houd het gaspedaal gedurende 2 sec. volledig ingedrukt
</ptxt>
</s1>
<s1>
<ptxt>
Laat het gaspedaal gedurende 2 sec. los
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1104057004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A1104057005">
<testgroup id = "ADUAP70A1104057006">
<question>
Is de &#34;Controle van het motor- en emissieregelsysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A1104001">Controle van het motor- en emissieregelsysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104057007">
<title>
Controle van de bedradingsbundel
</title>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Circuits &#34;A1&#34;, &#34;A2&#34; en &#34;A3&#34;: Zie stap 3 tot en met 5 onder 
<intxref refid = "ADUAP70A1104054">DTC P2122 / P2123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Circuits &#34;B1&#34;, &#34;B2&#34; en &#34;B3&#34;: Zie stap 3 tot en met 5 onder 
<intxref refid = "ADUAP70A1104055">DTC P2127 / P2128</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104057008">
<title>
Controle APP-sensor
</title>
<test1>
<ptxt>
Controleer de prestaties van de APP-sensor. 
<intxreftitleoff1 refid = "ADUAP70A1306006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de APP-sensor: 
</ptxt>
</action>
</testgroup>
</diag>
