<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1406007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van het elektrische-gasklephuissamenstel
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1406005">Componenten van gasklephuis en inlaatspruitstuk</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ADUAP70A1406006">Onderzoek in het voertuig van het gasklephuis</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Demonteer het elektrische gasklephuis nooit. Vervang door een nieuw exemplaar als er een defect wordt vastgesteld.
</ptxt>
</attention2>
<servinfosub id = "ADUAP70A1406007001" page = "2">
<title>
Uitbouw
</title>
<s1 page = "2">
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Tap de koelvloeistof af. 
<intxreftitleoff1 refid = "ADUAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder het luchtfiltersamenstel. 
<intxreftitleoff1 refid = "ADUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Maak de motorkoelvloeistofslangen (1) en de stekkerverbinding (2) los van het gasklephuissamenstel (3).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder het elektrische-gasklephuissamenstel en de luchtfilterbeugel (4) van het inlaatspruitstuk.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1406007002" page = "2">
<title>
Inbouw
</title>
<s1 page = "2">
<ptxt>
Reinig de pasvlakken en monteer de nieuwe gasklephuispakking (1) op het inlaatspruitstuk.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141038.swf" width = "88.000mm" height = "58.059mm" ver = "01" gw = "212" gh = "148"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Monteer het elektrische-gasklephuissamenstel (3) en de luchtfilterbeugel (4) op het inlaatspruitstuk.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Sluit de stekkerverbinding (2) en de koelvloeistofslangen (1) op het elektrische-gasklephuissamenstel (3) aan.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Monteer het luchtfiltersamenstel. 
<intxreftitleoff1 refid = "ADUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Sluit de negatieve kabel (–) op de accu aan.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Vul koelvloeistof bij. 
<intxreftitleoff1 refid = "ADUAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controleer op koelvloeistoflekkage. 
<intxreftitleoff1 refid = "ADUAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
