<testgroup id = "ADUAP70A8204037010">
<title>
Controle van de sensor vooraan voor botsingen van opzij
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Vervang de sensor voor botsingen van opzij aan de voorzijde. 
<intxreftitleoff1 refid = "ADUAP70A8206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de SDM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
