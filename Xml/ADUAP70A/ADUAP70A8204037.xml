<diag type = "test" id = "ADUAP70A8204037004">
<testgroup id = "ADUAP70A8204037005">
<question>
Werd de &#34;Controle van het airbagdiagnosesysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204037006">
<title>
Controle van het vloerbedradingsbundelcircuit
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;L04&#34; en &#34;L47&#34;-stekkerverbindingen of de &#34;L05&#34;- en &#34;L48&#34;-stekkerverbindingen los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van circuits &#34;A1&#34; en &#34;A2&#34; (DTC B1083 / B1084): 1 &#937; of minder
</ptxt>
</item>
<item>
<ptxt>
Weerstand van circuits &#34;A3&#34; en &#34;A4&#34; (DTC B1093 / B1074): 1 &#937; of minder
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B064">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820029.swf" width = "90.000mm" height = "52.428mm" ver = "03" gw = "207" gh = "132"/>
</testfigure>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
