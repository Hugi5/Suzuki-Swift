<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70AA324006" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1610
</title>
<servinfosub id = "ADUAP70AA324006001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.281in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.924in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1610: Startblokkerings-ID niet geregistreerd 
</emph>
</ptxt>
<ptxt>
De ID-code van de startblokkering is niet geregistreerd
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
De ID-code van de ECM is niet geregistreerd in het regelapparaat van het startsysteem met afstandsbediening
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
CAN-communicatiecircuit / -stekkerverbinding
</ptxt>
</item>
<item>
<ptxt>
Regelapparaat verbonden met CAN-gegevenstransmissielijn
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70AA324006002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70AA324006003">
<testgroup id = "ADUAP70AA324006005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer het regelapparaat van het startsysteem met afstandsbediening op DTC&#39;s. 
<intxreftitleoff1 refid = "ADUAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1173, B1175 of B1176 waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA324006004">
<title>
ECM-registratie
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70AA326003">ECM-registratie:Model met drukknopstartsysteem</intxref>
 uit.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC P1610 nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (De ECM was niet geregistreerd)
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA324006006">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer DTC met betrekking tot CAN-communicatie.
</ptxt>
</test1>
<question>
Zijn er CAN-DTC&#39;s waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
