<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van dynamo
</title>
<servinfosub id = "ADUAP70A1A06005001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de rechtse beschermplaat aan de onderkant van de motor.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder uitlaatpijp nr. 1. 
<intxreftitleoff1 refid = "ADUAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de waterpomp / dynamoaandrijfriem. 
<intxreftitleoff1 refid = "ADUAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak aansluitdraad &#34;B&#34; (1) en de stekkerverbinding (2) los van de dynamo (3).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de dynamo (3) en neem de dynamo uit de motorruimte tussen de voorste ophangingsdraagbalk en het voorste aandrijfassamenstel.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1005.jpg" width = "88.000mm" height = "66.800mm" ver = "01" gw = "237" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1A06005002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de dynamobout en de spilbout van de dynamo met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1J003">
<t-part>
Dynamobout
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1J004">
<t-part>
Dynamospilbout
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Verbind de aansluitdraad (1) met de dynamo zoals op de afbeelding en haal dan aansluitklemmoer &#34;B&#34; met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1J005">
<t-part>
&#34;B&#34;-aansluitklemmoer
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1A1006.jpg" width = "88.000mm" height = "61.151mm" ver = "02" gw = "237" gh = "157"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
