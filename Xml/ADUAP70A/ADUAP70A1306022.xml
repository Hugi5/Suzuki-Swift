<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1306022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van detonatiesensor
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1306021">Onderzoek in het voertuig van de detonatiesensor</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1306022001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het inlaatspruitstuk. 
<intxreftitleoff1 refid = "ADUAP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekker van de detonatiesensor los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de detonatiesensor (1) van het cilinderblok.
</ptxt>
<figure>
<graphic graphicname = "I9P60A131018.jpg" width = "88.000mm" height = "51.381mm" ver = "02" gw = "185" gh = "129"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1306022002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Draai de bout van de detonatiesensor (1) met het voorgeschreven koppel aan.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1C008">
<t-part>
Bout detonatiesensor
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A130002.jpg" width = "88.000mm" height = "41.140mm" ver = "02" gw = "222" gh = "100"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
0 – 45&#176;
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
