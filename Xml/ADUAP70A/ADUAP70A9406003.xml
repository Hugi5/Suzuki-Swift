<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9406003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de voorruitwissermotor
</title>
<servinfosub id = "ADUAP70A9406003001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de wisserspilkappen (1) en de wisserarmmoeren (2) en verwijder de voorruitwisserarmen (3).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bekleding aan de bovenkant van het schutbord (4). 
<intxreftitleoff1 refid = "ADUAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I9P60A940005.jpg" width = "88.000mm" height = "62.898mm" ver = "01" gw = "198" gh = "162"/>
</figure>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de voorruitwissermotor (3) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de wissermotorbouten (1) en verwijder de voorruitwissermotor (2) in de richting van de pijl zoals op de afbeelding.
</ptxt>
<figure>
<graphic graphicname = "I9P60A940006.jpg" width = "88.000mm" height = "41.842mm" ver = "01" gw = "217" gh = "102"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9406003002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9406004">Onderzoek van de werking van de voorruitwissermotor</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de wissermotorbouten in numerieke volgorde (van &#34;1&#34; tot &#34;2&#34;) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9D002">
<t-part>
Wissermotorbout
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A940007.jpg" width = "88.000mm" height = "41.842mm" ver = "02" gw = "217" gh = "102"/>
</figure>
<list1 type = "unordered">
<item>
<ptxt>
Monteer de voorruitwisserarmen (1) in de posities zoals op de afbeelding.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Rechterzijde [A]
</ptxt>
<ptxt>
Lijn het uiteinde van het voorruitwisserblad (5) met het merkteken (4) uit.
</ptxt>
</item>
<item>
<ptxt>
Linkerzijde [B]
</ptxt>
<ptxt>
Lijn het blad met de keramische leiding (3) uit.
</ptxt>
</item>
</list2>
<item>
<ptxt>
Haal de wisserarmmoeren met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9D003">
<t-part>
Wisserarmmoer
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1,6
</t-value2>
<t-value3>
12,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940009.swf" width = "88.000mm" height = "77.752mm" ver = "02" gw = "189" gh = "204"/>
