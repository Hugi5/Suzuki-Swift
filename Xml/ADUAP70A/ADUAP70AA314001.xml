<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70AA314001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Regelsysteemcontrole van de startblokkering
</title>
<attention3>
<ptxt>
Lees zeker 
<intxref refid = "ADUAP70AA310002">Voorzorgsmaatregelen voor het startblokkeersysteem:Model met contactslot</intxref>
 alvorens een controle uit te voeren.
</ptxt>
</attention3>
<diag type = "test" id = "ADUAP70AA314001001">
<testgroup id = "ADUAP70AA314001002">
<question>
Draait de motor rond?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A1904001">Diagnose van symptomen van startsysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA314001003">
<title>
Controle van het starten van de motor
</title>
<question>
Start de motor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA314001004">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Het regelsysteem van de startblokkering is in orde.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA314001005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA314001006">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer DTC met betrekking tot CAN-communicatie.
</ptxt>
</test1>
<question>
Zijn er CAN-DTC&#39;s waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A1104009">Basisonderzoek van de motor</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
