<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70AA324010" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1644
</title>
<servinfosub id = "ADUAP70AA324010001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.166in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.039in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1644: Startblokkerings-ID niet passend
</emph>
</ptxt>
<ptxt>
Controlefout tussen de ECM en het regelapparaat van het startsysteem met afstandsbediening.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Afstandsbediening
</ptxt>
</item>
<item>
<ptxt>
De ID-code van de ECM is niet geregistreerd in het regelapparaat van het startsysteem met afstandsbediening
</ptxt>
</item>
<item>
<ptxt>
De afstandsbediening is niet geregistreerd
</ptxt>
</item>
<item>
<ptxt>
Circuit/stekkerverbinding van de motorschakelaar
</ptxt>
</item>
<item>
<ptxt>
Motorschakelaar
</ptxt>
</item>
<item>
<ptxt>
Voedings- / massacircuit van het regelapparaat van het startsysteem met afstandsbediening
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Regelapparaat van het startsysteem met afstandsbediening
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70AA324010002">
<title>
DTC-storingzoeken
</title>
<attention3>
<ptxt>
Als het regelapparaat van het startsysteem met afstandsbediening bij een ander voertuig (gebruikt artikel) geregistreerd is, kunnen geen afstandsbedieningen geregistreerd worden. Monteer altijd een nieuw regelapparaat van het startsysteem met afstandsbediening als vervanging nodig is.
</ptxt>
</attention3>
<diag type = "test" id = "ADUAP70AA324010003">
<testgroup id = "ADUAP70AA324010004">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer het regelapparaat van het startsysteem met afstandsbediening op DTC&#39;s. 
<intxreftitleoff1 refid = "ADUAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC B1189 ook waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70AA324018">DTC B1189:Model met drukknopstartsysteem</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA324010005">
<title>
DTC opnieuw controleren
</title>
<test1>
<ptxt>
Controleer of de afstandsbediening zich in het werkingsgebied van motorstartfunctie met afstandsbediening bevindt.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC P1644 nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (Mogelijkheid om de afstandsbediening uit het werkingsgebied te halen.)
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA324010006">
<title>
Controle voedings- en massacircuit van het regelapparaat van het startsysteem met afstandsbediening
</title>
<test1>
<ptxt>
Controleer het voedings- en massacircuit van het regelapparaat van het startsysteem met afstandsbediening. 
<intxreftitleoff1 refid = "ADUAP70AA504031"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA324010007">
<title>
ECM-registratie
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70AA326003">ECM-registratie:Model met drukknopstartsysteem</intxref>
 uit.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC P1644 nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (De ECM was niet geregistreerd)
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA324010008">
<title>
Registratie van de afstandsbediening
</title>
<test1>
<ptxt>
Voer &#34;Sleutelregistratie startblokkering&#34; uit. 
<intxreftitleoff1 refid = "ADUAP70AA326002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC P1644 nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. Als DTC P1644 nog steeds wordt waargenomen, vervang dan het regelapparaat van het startsysteem met afstandsbediening en controleer de DTC opnieuw.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Regelapparaat van het startsysteem met afstandsbediening: 
<intxreftitleoff1 refid = "ADUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (De afstandsbediening was niet geregistreerd)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
