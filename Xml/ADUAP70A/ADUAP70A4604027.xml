<servinfosub id = "ADUAP70A4604027003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604027004">
<testgroup id = "ADUAP70A4604027005">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604027006">
<title>
Controle van het voedingscircuit van de solenoïdeklep en het massacircuit van het ESP&#174;-regelapparaat
</title>
<test1>
<ptxt>
Controleer het voedings- en massacircuit van de solenoïdeklep onder 
<intxref refid = "ADUAP70A4604042">Controle van het voedings- en massacircuit van het ESP&#174;-regelapparaat</intxref>
.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
</diag>
