<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10A">
<servcat sctnbr = "10" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70AA104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Cruise-control kan niet worden uitgeschakeld
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Voor de diagnose van de cruise-controlsysteemsymptomen moet u eerst het cruise-controlsysteem controleren volgens 
<intxref refid = "ADUAP70AA104001">Controle van het cruise-controlsysteem</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Controleer elk onderdeel in de volgorde van de volgende lijst.
</ptxt>
</item>
</list1>
</attention3>
<diag type = "condition">
<condition>
<ptxt>
Cruise-control kan niet worden uitgeschakeld
</ptxt>
</condition>
<ps>
<ptxt>
Defecte CANCEL-schakelaar
</ptxt>
</ps>
<action>
<ptxt>
Controleer of de CANCEL-schakelaar werkt volgens 
<intxref refid = "ADUAP70AA106002">Onderzoek van de cruise-controlschakelaar</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Defecte remlichtschakelaar
</ptxt>
</ps>
<action>
<ptxt>
Controleer of de remlichtschakelaar werkt volgens 
<intxref refid = "ADUAP70AA106006">Onderzoek van de remlichtschakelaar</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Defecte CPP-schakelaar nr. 2
</ptxt>
</ps>
<action>
<ptxt>
Controleer of CPP-schakelaar nr. 2 werkt volgens 
<intxref refid = "ADUAP70AA106004">Onderzoek van CPP-schakelaar nr. 2</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Defecte bedrading of massaverbinding
</ptxt>
</ps>
<action>
<ptxt>
Repareren.
</ptxt>
</action>
<ps>
<ptxt>
Defecte ECM
</ptxt>
</ps>
<action>
<ptxt>
Vervang na vastgesteld te hebben dat geen van bovenstaande onderdelen defect is.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
