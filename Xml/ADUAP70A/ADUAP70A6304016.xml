<servinfosub id = "ADUAP70A6304016005">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A6304016006">
<testgroup id = "ADUAP70A6304016007">
<question>
Is &#34;controle van het P/S-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A6304001">Controle van het P/S-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304016008">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer de DTC&#39;s van de ECM. 
<intxreftitleoff1 refid = "ADUAP70A6304003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC. (ECM-betrokken defect) 
<intxreftitleoff1 refid = "ADUAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het P/S-regelapparaat en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
