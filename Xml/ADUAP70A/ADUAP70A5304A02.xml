<title>
Slepende koppeling
</title>
<diag type = "condition">
<condition>
<ptxt>
Slepende koppeling
</ptxt>
</condition>
<ps>
<ptxt>
Onjuiste vrije slag van het koppelingspedaal
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de koppelingspedaalarm en/of de hoofdkoppelingscilinder.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Koppelingspedaalarm: 
<intxreftitleoff1 refid = "ADUAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hoofdkoppelingscilinder: 
<intxreftitleoff1 refid = "ADUAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Verzwakte schotelveer of versleten veeruiteinde
</ptxt>
</ps>
<action>
<ptxt>
Vervang het koppelingshuisdeksel. 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verroeste spie van de ingaande as
</ptxt>
</ps>
<action>
<ptxt>
Smeer de spie van de ingaande as.
</ptxt>
</action>
<ps>
<ptxt>
Beschadigde of versleten spie van de ingaande transaxle-as
</ptxt>
</ps>
<action>
<ptxt>
Vervang de ingaande as. 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Overmatig slingerende koppelingsschijf
</ptxt>
</ps>
<action>
<ptxt>
Vervang de koppelingsschijf. 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Koppelingsvoeringen kapot of bevuild met olie
</ptxt>
</ps>
<action>
<ptxt>
Vervang de koppelingsschijf. 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vloeistoflekkage
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang het koppelingssysteem.
</ptxt>
</action>
