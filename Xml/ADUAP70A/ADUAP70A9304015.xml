<item>
<ptxt>
Het scherm bevat de volgende gegevenstypen: 
</ptxt>
<figure>
<graphic graphicname = "IAW101970026.swf" width = "88.000mm" height = "59.594mm" ver = "01" gw = "189" gh = "152"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
