<servinfosub id = "ADUAP70A9206001002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Monteer de klem van de koplampeenheid.
</ptxt>
</item>
<item>
<ptxt>
Monteer de schroeven (1, &#34;1&#34; – 1, &#34;4&#34;) in numerieke volgorde zoals afgebeeld.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920008.jpg" width = "88.000mm" height = "69.820mm" ver = "02" gw = "206" gh = "181"/>
