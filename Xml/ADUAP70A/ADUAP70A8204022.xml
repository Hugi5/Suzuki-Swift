<servinfosub id = "ADUAP70A8204022003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A8204022004">
<testgroup id = "ADUAP70A8204022005">
<question>
Werd de &#34;Controle van het airbagdiagnosesysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204022006">
<title>
Controle van de passagiersairbag (opblaaseenheid)-module
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de aansluiting met de &#34;G259&#34;-stekkerverbinding goed is verbonden.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;G259&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Sluit &#34;STEERING WHEEL&#34; (1) met speciaal gereedschap (A), (B) en (C) op de &#34;G259&#34;-stekkerverbinding aan.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B018">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B019">
<s-part>
(B)
</s-part>
<s-number num = "09932-78310">
09932-78310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L8B020">
<s-part>
(C)
</s-part>
<s-number num = "09932-75010">
09932-75010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820021.swf" width = "90.000mm" height = "75.690mm" ver = "03" gw = "211" gh = "198"/>
</testfigure>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC B1041 vastgesteld?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de passagiersairbag (opblaaseenheid)-module 
<intxreftitleoff1 refid = "ADUAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204022007">
<title>
Controle van het circuit van de passagiersairbag (opblaaseenheid)-module
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de aansluiting met de &#34;G11&#34;-stekkerverbinding goed is verbonden.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;G11&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de kortsluitbeugel in de SDM-stekkerverbinding los met het vrijzetgereedschap dat behoort tot het speciaal gereedschap (A).
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand tussen aansluitingen &#34;G11-19&#34; en &#34;G259-1&#34;: 1 &#937; of minder
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen aansluitingen &#34;G11-18&#34; en &#34;G259-2&#34;: 1 &#937; of minder
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B021">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820009.swf" width = "90.000mm" height = "95.480mm" ver = "01" gw = "227" gh = "254"/>
</testfigure>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de SDM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204022008">
<title>
Circuitcontrole van de instrumentenpaneelbedradingsbundel
</title>
<test1>
<ptxt>
Controleer of de aansluiting met de &#34;G372&#34;-stekkerverbinding goed is verbonden.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;G372&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de kortsluitbeugel in de SDM-stekkerverbinding los met het vrijzetgereedschap dat behoort tot het speciaal gereedschap (A).
</ptxt>
</test1>
<test1>
<ptxt>
Controleer het volgende punt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van circuit &#34;A3&#34; en &#34;A4&#34;: 1 &#937; of minder
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B022">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820023.swf" width = "90.000mm" height = "53.433mm" ver = "03" gw = "201" gh = "135"/>
</testfigure>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de bedradingsbundel van de passagiersairbag (opblaaseenheid)-module.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Voer na het onderzoek en de reparaties de volgende stappen uit.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sluit alle componenten van het airbagsysteem weer aan en controleer of ze juist zijn gemonteerd.
</ptxt>
</item>
<item>
<ptxt>
Wis eventuele DTC&#39;s volgens 
<intxref refid = "ADUAP70A8204006">Wissen van DTC</intxref>
, als een DTC wordt waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Herhaal 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
 om te controleren of de storing is opgelost.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
