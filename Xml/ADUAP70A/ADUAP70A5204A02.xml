<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ruw schakelen
</title>
<diag type = "condition">
<condition>
<ptxt>
Ruw schakelen
</ptxt>
</condition>
<ps>
<ptxt>
Verkeerd smeermiddel
</ptxt>
</ps>
<action>
<ptxt>
Vul handgeschakelde-transaxle-olie bij.
</ptxt>
</action>
<ps>
<ptxt>
Onjuiste vrije slag van het koppelingspedaal
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de koppelingspedaalarm of de hoofdkoppelingscilinder.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Koppelingspedaalarm: 
<intxreftitleoff1 refid = "ADUAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Hoofdkoppelingscilinder: 
<intxreftitleoff1 refid = "ADUAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Vervormde of kapotte koppelingsschijf
</ptxt>
</ps>
<action>
<ptxt>
Vervang de koppelingsschijf. 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Beschadigde koppelingsdrukplaat
</ptxt>
</ps>
<action>
<ptxt>
Vervang het koppelingshuisdeksel. 
<intxreftitleoff1 refid = "ADUAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Versleten symchromesh-ring
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de synchromesh-ring.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Synchromesh-ring van de lage versnellingen en synchromesh-ring van de 2de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-ring van de hoge versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-ring van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Versleten afgeschuinde tand op mof of tandwiel
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de synchromesh-mof en -naaf en het tandwiel.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tandwiel van de 1ste en 2de versnelling van de secundaire as: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tandwiel van de ingaande as van de 3de en 4de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tandwiel van de ingaande as van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-mof en -naaf van de lage versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-mof en-naaf van de hoge versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-mof en -naaf van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Versleten koppelingsbus van de schakelhendelas
</ptxt>
</ps>
<action>
<ptxt>
Vervang de koppelingsbus van de schakelhendelas. 
<intxreftitleoff1 refid = "ADUAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vervormde schakelas
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de schakelvork of schakelas.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Schakelas van de lage versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schakelas van de hoge versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schakelvork van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Schakel- en keuzekabels gebroken
</ptxt>
</ps>
<action>
<ptxt>
Vervang de schakel- en keuzekabel. 
<intxreftitleoff1 refid = "ADUAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
