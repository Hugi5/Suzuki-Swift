<servinfosub id = "ADUAP70A1104058003">
<title>
DTC-controleprocedure
</title>
<attention3>
<ptxt>
Controleer of aan de volgende voorwaarden in deze &#34;DTC-controleprocedure&#34; is voldaan.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Accuspanning &#62; 10 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
IAT &#62; 5 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Zet het contactslot in de &#34;ON&#34;-stand gedurende 1 min. met losgelaten gaspedaal.
</ptxt>
</s1>
<s1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1104058004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A1104058005">
<testgroup id = "ADUAP70A1104058006">
<question>
Is de &#34;Controle van het motor- en emissieregelsysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A1104001">Controle van het motor- en emissieregelsysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104058007">
<title>
IJking van het elektrische-gasklepregelsysteem
</title>
<test1>
<ptxt>
IJken van het elektrische-gasklepregelsysteem. 
<intxreftitleoff1 refid = "ADUAP70A1306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC opnieuw.
</ptxt>
</test1>
<question>
Wordt DTC P2176 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104058008">
<title>
Controle van de bedradingsbundel
</title>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
TP-sensorcircuit (hoofd): Zie stap 2 tot en met 4 onder 
<intxref refid = "ADUAP70A1104024">DTC P0122 / P0123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
TP-sensorcircuit (hulp): Zie stap 2 tot en met 4 onder 
<intxref refid = "ADUAP70A1104030">DTC P0222 / P0223</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104058009">
<title>
Controle van de TP-sensor
</title>
<test1>
<ptxt>
Controleer de TP-sensor volgens &#34;Controle van de prestaties van de gaskleppositiesensor (TP-sensor)&#34; onder 
<intxref refid = "ADUAP70A1306004">Onderzoek elektrisch-gasklephuissamenstel in het voertuig</intxref>
.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het elektrische-gasklephuissamenstel.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
