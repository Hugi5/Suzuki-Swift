<servinfo servinfosgmlid = "ADUAP70A5204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Tandwielen slippen uit aangrijppunt
</title>
<diag type = "condition">
<condition>
<ptxt>
Tandwielen slippen uit aangrijppunt
</ptxt>
</condition>
<ps>
<ptxt>
Versleten schakelvorkas
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de schakelvork of schakelas.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Schakelas van de lage versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schakelas van de hoge versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schakelvork van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Versleten schakelvork of synchromesh-mof
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de schakelvork, de schakelas of de synchromesh-mof en -naaf.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Schakelas van de lage versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schakelas van de hoge versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schakelvork van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-mof en -naaf van de lage versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-mof en-naaf van de hoge versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-mof en -naaf van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Zwakke of beschadigde pasveren
</ptxt>
</ps>
<action>
<ptxt>
Vervang de pasveer. 
<intxreftitleoff1 refid = "ADUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Versleten lagers op ingaande of secundaire as
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang het lager van de ingaande as of het lager van de uitgaande as.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Linkse lager van de secundaire as: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Binnenloopring: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Buitenloopring: 
<intxreftitleoff1 refid = "ADUAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Rechtse lager van de secundaire as: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Binnenloopring: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Buitenloopring: 
<intxreftitleoff1 refid = "ADUAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Linkse lager en rechtse lager van de ingaande as: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Versleten afgeschuinde tand op mof en tandwiel
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de synchromesh-mof en -naaf en het tandwiel.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tandwiel van de 1ste en 2de versnelling van de secundaire as: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tandwiel van de ingaande as van de 3de en 4de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tandwiel van de ingaande as van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-mof en -naaf van de lage versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-mof en-naaf van de hoge versnellingen: 
<intxreftitleoff1 refid = "ADUAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchromesh-mof en -naaf van de 5de versnelling: 
<intxreftitleoff1 refid = "ADUAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
