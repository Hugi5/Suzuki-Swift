<servinfo servinfosgmlid = "ADUAP70A9604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Alle portieren kunnen niet worden vergrendeld / ontgrendeld
</title>
<diag type = "condition">
<condition>
<ptxt>
Alle portieren kunnen niet worden vergrendeld / ontgrendeld
</ptxt>
</condition>
<ps>
<ptxt>
Defecte BCM
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Zie &#34;Onderzoek van de BCM en de bijbehorende circuits&#34; in hoofdstuk 10B.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Model met contactslot: 
<intxreftitleoff1 refid = "ADUAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model met drukknopstartsysteem: 
<intxreftitleoff1 refid = "ADUAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Defect regelapparaat van het startsysteem met afstandsbediening (model met drukknopstartsysteem)
</ptxt>
</ps>
<action>
<ptxt>
Zie 
<intxref refid = "ADUAP70AA504031">Onderzoek van het regelapparaat van het startsysteem met afstandsbediening en de bijbehorende circuits</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Defect systeemcircuit (inclusief relais en zekeringen)
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Defecte schakelaar van de centrale portiervergrendeling
</ptxt>
</ps>
<action>
<ptxt>
Zie 
<intxref refid = "ADUAP70A9606009">Onderzoek van de schakelaar van de centrale portiervergrendeling</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Defecte slotcilinder
</ptxt>
</ps>
<action>
<ptxt>
Controleer de slotcilinder. 
<intxreftitleoff1 refid = "ADUAP70A9606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
