<title>
Er wordt sporadisch geen koele lucht uitgeblazen
</title>
<diag type = "condition">
<condition>
<ptxt>
Er wordt sporadisch geen koele lucht uitgeblazen
</ptxt>
</condition>
<ps>
<ptxt>
Defecte bedradingsaansluiting
</ptxt>
</ps>
<action>
<ptxt>
Repareer de bedrading.
</ptxt>
</action>
<ps>
<ptxt>
Defecte verdampertemperatuursensor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de verdampertemperatuursensor. 
<intxreftitleoff1 refid = "ADUAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte expansieklep
</ptxt>
</ps>
<action>
<ptxt>
Controleer de expansieklep. 
<intxreftitleoff1 refid = "ADUAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Te veel vocht in het A/C-systeem
</ptxt>
</ps>
<action>
<ptxt>
Vervang de condensor, zuig vacuüm en vul bij. 
<intxreftitleoff1 refid = "ADUAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte magneetkoppeling
</ptxt>
</ps>
<action>
<ptxt>
Controleer de magneetkoppeling. 
<intxreftitleoff1 refid = "ADUAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Te veel koelmiddel
</ptxt>
</ps>
<action>
<ptxt>
Controleer de hoeveelheid koelmiddel.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
