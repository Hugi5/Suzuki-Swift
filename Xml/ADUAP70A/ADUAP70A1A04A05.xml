<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A1A04A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Lawaaierige dynamo
</title>
<ptxt>
Bij een storing in het laadsysteem kunnen één of meer van de volgende symptomen worden waargenomen.
</ptxt>
<servinfosub id = "ADUAP70A1A04002005">
<title>
Lawaai
</title>
<diag type = "condition">
<condition>
<ptxt>
Lawaaierige dynamo
</ptxt>
</condition>
<ps>
<ptxt>
Losse montagebouten
</ptxt>
</ps>
<action>
<ptxt>
Montagebouten aandraaien. 
<intxreftitleoff1 refid = "ADUAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vuile, versleten en/of defecte lagers
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de dynamo. 
<intxreftitleoff1 refid = "ADUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte rotor, diode en/of stator
</ptxt>
</ps>
<action>
<ptxt>
Repareer of vervang de dynamo. 
<intxreftitleoff1 refid = "ADUAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
