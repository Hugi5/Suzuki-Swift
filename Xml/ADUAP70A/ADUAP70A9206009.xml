<servinfosub id = "ADUAP70A9206009002">
<title>
Inbouw
</title>
<ptxt>
Keer de uitbouwprocedure om en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de moeren van het hooggemonteerd remlicht met het voorgeschreven koppel aan.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9B002">
<t-part>
Moer van het hooggemonteerd remlicht
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
2,0
</t-value1>
<t-value2>
0,20
</t-value2>
<t-value3>
1,5
</t-value3>
</torqueitem>
</torque>
