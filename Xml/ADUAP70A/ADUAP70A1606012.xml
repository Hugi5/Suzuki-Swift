<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van het radiateurkoelventilatorsamenstel
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1606010">Onderzoek in het voertuig van het radiateurkoelventilatorsamenstel</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1606012001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Tap de koelvloeistof af. 
<intxreftitleoff1 refid = "ADUAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding (1) van de radiateurkoelventilatormotor los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het reservoir (2).
</ptxt>
</s1>
<s1>
<ptxt>
Maak de inlaatslang van de radiateur (3) van de radiateur los.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160005.swf" width = "88.000mm" height = "70.920mm" ver = "01" gw = "221" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het radiateurkoelventilatorsamenstel van de radiateur.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ADUAP70A1606012002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Vul het koelsysteem met koelvloeistof bij. 
<intxreftitleoff1 refid = "ADUAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Controleer het koelsysteem op lekkage. 
<intxreftitleoff1 refid = "ADUAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
