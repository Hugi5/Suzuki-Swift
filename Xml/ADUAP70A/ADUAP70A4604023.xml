<servinfosub id = "ADUAP70A4604023003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604023004">
<testgroup id = "ADUAP70A4604023005">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604023006">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A4604005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Worden behalve C1037, C1038 en C1057 nog andere DTC&#39;s aangegeven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604023007">
<title>
DTC-controle van de BCM
</title>
<test1>
<ptxt>
Controleer de DTC van de BCM. 
<intxreftitleoff1 refid = "ADUAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt een van de DTC&#39;s U0073, U0121 en/of U0126 waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604023008">
<title>
Zekeringcontrole
</title>
<test1>
<ptxt>
Controleer de &#34;ABS&#34;-zekering.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de zekering en controleer op kortsluiting aan de massa.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604023009">
<title>
Controle van het voedingscircuit van de stuurhoeksensor
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de stekkerverbinding van de stuurhoeksensor los.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;G33&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer op een goede verbinding met de stuurhoeksensor.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in als de aansluiting in orde is.
</ptxt>
</test1>
<test1>
<ptxt>
Meet de spanning tussen circuit &#34;A1&#34; en de massa.
</ptxt>
</test1>
<question>
Bedraagt de spanning 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang circuit &#34;A1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604023010">
<title>
Controle van het massacircuit van de stuurhoeksensor
</title>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Meet de weerstand tussen circuit &#34;A2&#34; en de massa.
</ptxt>
</test1>
<question>
Is die lager dan 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang circuit &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604023011">
<title>
Controle van de stuurhoeksensor
</title>
<test1>
<ptxt>
Sluit de stekkerverbinding van de stuurhoeksensor aan.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de stuurhoeksensor. 
<intxreftitleoff1 refid = "ADUAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de stuurhoeksensor en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
