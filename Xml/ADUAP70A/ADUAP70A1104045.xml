<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A1104045" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0606
</title>
<servinfosub id = "ADUAP70A1104045001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.602in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.602in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0606: Regelapparaatprocessor
</emph>
</ptxt>
<ptxt>
Interne ECM-processor heeft gefaald.
</ptxt>
<ptxt>
(Opsporingslogica van 3 rijcycli)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Voedingscircuit en/of massacircuit van de ECM
</ptxt>
</item>
<item>
<ptxt>
A/F-sensor
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A1104045002">
<title>
Beschrijving van het systeem
</title>
<ptxt>
Het interne regelapparaat is in de ECM gemonteerd.
</ptxt>
</servinfosub>
<servinfosub id = "ADUAP70A1104045003">
<title>
DTC-controleprocedure
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Zorg dat u eerst onverwachte DTC&#39;s oplost die eerder tijdens de &#34;DTC-controleprocedure&#34; zijn waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Controleer of aan de volgende voorwaarden in deze &#34;DTC-controleprocedure&#34; is voldaan.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Accuspanning &#62; 10,7 V
</ptxt>
</item>
<item>
<ptxt>
DTC P0030, P0031, P0032, P0131 of P0132 wordt niet waargenomen.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Laat de motor gedurende 1 min. stationair draaien.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1104045004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A1104045005">
<testgroup id = "ADUAP70A1104045006">
<title>
DTC opnieuw controleren
</title>
<test1>
<ptxt>
Wis de DTC. 
<intxreftitleoff1 refid = "ADUAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Voer de DTC-bevestigingsprocedure uit en controleer de DTC.
</ptxt>
</test1>
<question>
Wordt DTC P0606 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controleer op sporadische storingen. 
<intxreftitleoff1 refid = "ADUAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104045007">
<title>
Controle van het voedings- en -massacircuit van de ECM
</title>
<test1>
<ptxt>
Controleer het voedings- en massacircuit van de ECM. 
<intxreftitleoff1 refid = "ADUAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104045008">
<title>
DTC opnieuw controleren
</title>
<test1>
<ptxt>
Vervang de A/F-sensor. 
<intxreftitleoff1 refid = "ADUAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Voer de DTC-bevestigingsprocedure uit en controleer de DTC.
</ptxt>
</test1>
<question>
Wordt DTC P0606 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
