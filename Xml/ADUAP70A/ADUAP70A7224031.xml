</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1580: EEPROM-fout 
</emph>
</ptxt>
<ptxt>
Er is een EEPROM-fout in het HVAC-regelapparaat opgetreden.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
HVAC-regelapparaat
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1902: Programmeerfout in regelapparaat
</emph>
</ptxt>
<ptxt>
Er is een fout in het programma van het HVAC-regelapparaat opgetreden.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
