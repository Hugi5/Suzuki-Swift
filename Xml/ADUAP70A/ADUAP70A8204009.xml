<servinfosub id = "ADUAP70A8204009002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A8204009003">
<testgroup id = "ADUAP70A8204009004">
<title>
Controle van de SDM-stekkerverbinding
</title>
<test1>
<ptxt>
Controleer of de aansluiting met de SDM-stekkerverbinding goed is verbonden.
</ptxt>
</test1>
<question>
Is de aansluiting in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sluit de stekkerverbinding stevig aan.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204009005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A8204005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204009006">
<title>
Controle van het voedings- en massacircuit van de SDM
</title>
<test1>
<ptxt>
Controleer het voedings- en massacircuit van de SDM. 
<intxreftitleoff1 refid = "ADUAP70A8204052"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn de circuits in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer het voedings- en massacircuit van de SDM.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204009007">
<title>
Controle van het CAN-communicatiecircuit
</title>
<test1>
<ptxt>
Controleer het CAN-communicatiecircuit tussen de SDM en de combimeter.
</ptxt>
</test1>
<question>
Is het circuit in goede toestand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204009008">
<title>
Controle van de combimeter
</title>
<test1>
<ptxt>
Vervang de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<question>
Blijft het &#34;AIR BAG&#34;-waarschuwingslampje branden?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de SDM en controleer de werking van het &#34;AIR BAG&#34;-waarschuwingslampje opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Voer na het onderzoek en de reparaties de volgende stappen uit.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sluit alle componenten van het airbagsysteem weer aan en controleer of ze juist zijn gemonteerd.
</ptxt>
</item>
<item>
<ptxt>
Herhaal 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
 om te controleren of de storing is opgelost.
</ptxt>
</item>
</list1>
</attention3>
