<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A7226035" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de binnenluchttemperatuursensor
</title>
<servinfosub id = "ADUAP70A7226035001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het stuurkolomopeningsdeksel van het instrumentenpaneel. 
<intxreftitleoff1 refid = "ADUAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder stekkerverbinding (1) en zuigslang (2) van de binnenluchttemperatuursensor (3).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de lipjes (4) en verwijder vervolgens de binnenluchttemperatuursensor (3) van het instrumentenpaneel.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723023.swf" width = "88.000mm" height = "65.896mm" ver = "01" gw = "232" gh = "170"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7226035002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A7226036">Onderzoek van de binnenluchttemperatuursensor:Automatisch type</intxrefpoff>
</ptxt>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
