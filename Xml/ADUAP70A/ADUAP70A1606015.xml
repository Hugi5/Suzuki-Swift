<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1606015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de radiateur
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1606014">Onderzoek en reiniging van de radiateur op het voertuig</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1606015001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het koelventilatorsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A1606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder het A/C-condensorsamenstel.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met handbediende A/C: 
<intxreftitleoff1 refid = "ADUAP70A7216006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model met automatische A/C: 
<intxreftitleoff1 refid = "ADUAP70A7226006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Verwijder de radiateuruitlaatslang van de radiateur.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bovenste radiateurbeugels (1).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de radiateur (2) uit het voertuig.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160007.jpg" width = "88.000mm" height = "62.569mm" ver = "01" gw = "193" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1606015002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Vul het koelsysteem met koelvloeistof bij. 
<intxreftitleoff1 refid = "ADUAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Controleer het koelsysteem op lekkage. 
<intxreftitleoff1 refid = "ADUAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
