<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9606014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de achterklepopenerschakelaar
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9606013">Onderzoek in het voertuig van de achterklepopenerschakelaar</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A9606014001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de achterklepbekleding. 
<intxreftitleoff1 refid = "ADUAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding (1) van de achterklepopenerschakelaar los.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de onderste bekleding van de achterklep. 
<intxreftitleoff1 refid = "ADUAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de schroeven (1) en verwijder vervolgens de achterklepopenerschakelaar (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A960020.jpg" width = "88.000mm" height = "57.494mm" ver = "01" gw = "194" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9606014002">
<title>
Inbouw
</title>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
