<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A1104A15" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Motor draait onjuist of niet stationair
</title>
<ptxt>
Onderzoek de storingen zoals hieronder beschreven als de ECM geen DTC en geen abnormale situatie heeft waargenomen in 
<intxref refid = "ADUAP70A1104008">Visueel onderzoek</intxref>
 en 
<intxref refid = "ADUAP70A1104009">Basisonderzoek van de motor</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Motor draait onjuist of niet stationair
</ptxt>
</condition>
<ps>
<ptxt>
Defecte bougie
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1806002">Onderzoek bougie</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Bobine met ontsteker defect
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1806004">Onderzoek van het bobinesamenstel</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Brandstofdruk buiten voorgeschreven bereik
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1704005">Controle van de brandstofdruk</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Pakking van spruitstuk, gasklephuis of cilinderkop lekt
</ptxt>
</ps>
<action>
<ptxt>
Controleer het luchtinlaatsysteem.
</ptxt>
</action>
<ps>
<ptxt>
Benzinedampafzuigsysteem defect
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1206002">Onderzoek van de afzuigklep van het EVAP-reservoir</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte brandstofverstuiver(s)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1704003">Controle van brandstofverstuivercircuit</intxref>
 of 
<intxref refid = "ADUAP70A1706009">Onderzoek van de brandstofverstuiver</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Slechte prestaties van ECT- of MAF-sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306012">Onderzoek van de ECT-sensor</intxref>
 of 
<intxref refid = "ADUAP70A1306026">Onderzoek van de MAF- en IAT-sensor</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defect elektrische-gasklephuissamenstel
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306004">Onderzoek elektrisch-gasklephuissamenstel in het voertuig</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte APP-sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306008">Onderzoek van de APP-sensor</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1104070">Onderzoek van de ECM en de bijbehorende circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Loszittende of losgekoppelde vacuümslangen
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aansluiting van de vacuümslangen.
</ptxt>
</action>
<ps>
<ptxt>
Slecht werkende PCV-klep
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1206006">Onderzoeken van de PCV-klep</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Motor oververhit
</ptxt>
</ps>
<action>
<ptxt>
Motor oververhit
</ptxt>
</action>
<ps>
<ptxt>
Lage compressie
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1404001">Controle van de compressie</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Generator en/of bijbehorend circuit defect
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1A04003">Dynamotest</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defect nokkenaspositieregelsysteem (VVT)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306027">Onderzoek van de OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
