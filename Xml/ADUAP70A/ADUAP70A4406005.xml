<section sectnbr = "4D">
<servcat sctnbr = "04" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A4406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de parkeerremhendel
</title>
<attention1>
<ptxt>
Zorg voor het volgende alvorens de parkeerremhendel te verwijderen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Werk op een vlakke plaats.
</ptxt>
</item>
<item>
<ptxt>
Schakel naar de 1ste versnelling.
</ptxt>
</item>
<item>
<ptxt>
Gebruik wielblokken.
</ptxt>
</item>
</list1>
</attention1>
<servinfosub id = "ADUAP70A4406005001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het achterste vloerconsolevak. 
<intxreftitleoff1 refid = "ADUAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de parkeerremschakelaar los van de parkeerremhendel.
</ptxt>
</s1>
<s1>
<ptxt>
Draai de stelmoer (1) los.
</ptxt>
<figure>
<graphic graphicname = "I9P60A440004.swf" width = "88.000mm" height = "66.682mm" ver = "01" gw = "189" gh = "173"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de parkeerremhendelbouten (1) en vervolgens de parkeerremhendel (2) samen met de equalizer (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A440005.swf" width = "88.000mm" height = "80.810mm" ver = "01" gw = "168" gh = "213"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A4406005002">
<title>
Inbouw
</title>
<s1>
<ptxt>
Haal de bouten (1) van de parkeerremhendel met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T4D001">
<t-part>
Parkeerremhendelbout
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
26
</t-value1>
<t-value2>
2,7
</t-value2>
<t-value3>
19,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A440006.swf" width = "88.000mm" height = "77.351mm" ver = "01" gw = "174" gh = "203"/>
</figure>
</s1>
<s1>
<ptxt>
Sluit de parkeerremkabel op de equalizer aan en stel de parkeerremkabel vervolgens af. 
<intxreftitleoff1 refid = "ADUAP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controleer of het remsysteem op de juiste wijze werkt.
</ptxt>
</s1>
<s1>
<ptxt>
Verbind de stekkerverbinding van de parkeerremschakelaar met de parkeerremhendel.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het achterste vloerconsolevak. 
<intxreftitleoff1 refid = "ADUAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
