<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A4106006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van het rempedaalsamenstel
</title>
<attention2>
<ptxt>
Demonteer nooit een rempedaalsamenstel dat met een rempedaalvoetbeschermingsmechanisme is uitgerust.
</ptxt>
<ptxt>
Door demontage wordt de oorspronkelijke werking verstoord. Vervang het hele onderdeel door een nieuw exemplaar als een defect wordt vastgesteld.
</ptxt>
</attention2>
<servinfosub id = "ADUAP70A4106006001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het combimeter-instrumentenpaneel. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het stuurkolomopeningsdeksel. 
<intxreftitleoff1 refid = "ADUAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de remlichtschakelaar. 
<intxreftitleoff1 refid = "ADUAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de onderste stuuras. 
<intxreftitleoff1 refid = "ADUAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder klem, gaffelpen en moeren van de rembekrachtiger. 
<intxreftitleoff1 refid = "ADUAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de moer (1) van de rempedaallagersteun en de bout (2) van de bovenste schutbordverstevigingsplaat.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder het rempedaalsamenstel.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A4106006002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A4106022">Uitbouw en inbouw van de rembekrachtiger</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Monteer het rempedaalsamenstel en monteer de rembekrachtiger.
</ptxt>
</s1>
<s1>
<ptxt>
Haal de moeren van de rembekrachtiger met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T4A001">
<t-part>
Moer van de rembekrachtiger*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410009.swf" width = "88.000mm" height = "63.332mm" ver = "01" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Haal de moer van de rempedaallagersteun met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T4A002">
<t-part>
Moer van rempedaallagersteun*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Haal de bovenste schutbordverstevigingsplaatbout met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T4A003">
<t-part>
Bovenste schutbordverstevigingsplaatbout
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410010.swf" width = "88.000mm" height = "64.412mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de klem en de gaffel. 
<intxreftitleoff1 refid = "ADUAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de onderste stuuras. 
<intxreftitleoff1 refid = "ADUAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ontlucht het remsysteem. 
<intxreftitleoff1 refid = "ADUAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controleer de vrije rempedaalhoogte en -speling.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Vrije rempedaalhoogte: 
<intxreftitleoff1 refid = "ADUAP70A4106007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rempedaalspeling: 
<intxreftitleoff1 refid = "ADUAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Monteer de remlichtschakelaar. 
<intxreftitleoff1 refid = "ADUAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controleer alle aansluitingen op vloeistoflekkage en ga na of het remsysteem op de juiste wijze werkt.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het stuurkolomopeningsdeksel. 
<intxreftitleoff1 refid = "ADUAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het combimeter-instrumentenpaneel. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
