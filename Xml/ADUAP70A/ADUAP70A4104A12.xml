<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A4104A12" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
ESP&#174;-waarschuwingslampje gaat niet branden nadat de ontsteking is ingeschakeld
</title>
<diag type = "condition">
<condition>
<ptxt>
ESP<sup>&#174;</sup>-waarschuwingslampje gaat niet branden nadat de ontsteking is ingeschakeld
</ptxt>
</condition>
<ps>
<ptxt>
Defect voedings- en massacircuit van de combimeter
</ptxt>
</ps>
<action>
<ptxt>
Controleer de combimeter en het bijbehorende circuit. 
<intxreftitleoff1 refid = "ADUAP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte combimeter
</ptxt>
</ps>
<action>
<ptxt>
Vervang de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slecht werkend CAN-communicatiesysteem
</ptxt>
</ps>
<action>
<ptxt>
Controleer het CAN-communicatiesysteem. 
<intxreftitleoff1 refid = "ADUAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gesprongen zekering
</ptxt>
</ps>
<action>
<ptxt>
Controleer de &#34;MTR&#34;-zekering en het circuit naar de &#34;MTR&#34;-zekering en vervang indien nodig.
</ptxt>
</action>
<ps>
<ptxt>
Defecte hydraulische regeleenheid / regelapparaat van het ESP<sup>&#174;</sup>
</ptxt>
</ps>
<action>
<ptxt>
Vervang de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup>. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
