<servinfo servinfosgmlid = "ADUAP70AA506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de waarschuwingszoemer buiten
</title>
<servinfosub id = "ADUAP70AA506017001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de voorwielspatbordvoering aan de bestuurderszijde. 
<intxreftitleoff1 refid = "ADUAP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding (1) los en verwijder vervolgens de waarschuwingszoemer buiten (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50032.jpg" width = "88.000mm" height = "68.823mm" ver = "01" gw = "213" gh = "179"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA506017002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70AA506018">Onderzoek van de waarschuwingszoemer buiten</intxrefpoff>
</ptxt>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
