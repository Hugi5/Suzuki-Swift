<title>
Demontage en hermontage van de radiateurkoelventilator
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1606012">Uitbouw en inbouw van het radiateurkoelventilatorsamenstel</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A1606013001">
<title>
Demontage
</title>
<s1 page = "2">
<ptxt>
Verwijder de ventilator (1) van de koelventilatormotor (2).
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Verwijder de koelventilatormotor (2) van de koelventilatortunnel (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70P160006.jpg" width = "88.000mm" height = "55.324mm" ver = "01" gw = "207" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1606013002" page = "2">
<title>
Hermontage
</title>
<ptxt>
Keer de demontageprocedure om.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de ventilatormoer en de bouten van de radiateurkoelventilatormotor met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1F001">
<t-part>
Ventilatormoer
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
<torqueitem id = "T1F002">
<t-part>
Bout van radiateurkoelventilatormotor
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
4,0
</t-value1>
<t-value2>
0,41
</t-value2>
<t-value3>
3,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70P160010.jpg" width = "88.000mm" height = "51.127mm" ver = "03" gw = "223" gh = "128"/>
</figure>
</item>
</list1>
