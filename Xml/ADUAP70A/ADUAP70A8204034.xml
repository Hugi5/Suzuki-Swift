<servinfosub id = "ADUAP70A8204034003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A8204034004">
<testgroup id = "ADUAP70A8204034005">
<question>
Werd de &#34;Controle van het airbagdiagnosesysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204034006">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer of een van de volgende DTC&#39;s wordt uitgestuurd. 
<intxreftitleoff1 refid = "ADUAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
B1073 of B1074 (DTC B1071 of DTC B1072)
</ptxt>
</item>
<item>
<ptxt>
B1077 of B1078 (DTC B1075 of DTC B1076)
</ptxt>
</item>
</list1>
</test1>
<question>
Is de DTC-uitvoer relevant?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204034007">
<title>
Controle van de sensor voor frontale botsingen
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Vervang de sensor voor frontale botsingen. 
<intxreftitleoff1 refid = "ADUAP70A8206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de SDM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
<attention3>
<ptxt>
Voer na het onderzoek en de reparaties de volgende stappen uit.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sluit alle componenten van het airbagsysteem weer aan en controleer of ze juist zijn gemonteerd.
</ptxt>
</item>
<item>
<ptxt>
Wis eventuele DTC&#39;s volgens 
<intxref refid = "ADUAP70A8204006">Wissen van DTC</intxref>
, als een DTC wordt waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Herhaal 
<intxref refid = "ADUAP70A8204003">Controle van &#34;AIR BAG&#34;-waarschuwingslampje</intxref>
 om te controleren of de storing is opgelost.
</ptxt>
</item>
</list1>
</attention3>
