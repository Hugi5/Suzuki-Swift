<servinfo servinfosgmlid = "ADUAP70AA504018" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1161 / B1163
</title>
<servinfosub id = "ADUAP70AA504018001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.816in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.388in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1161: De informatie van de stuursloteenheid stemt niet overeen 
</emph>
</ptxt>
<ptxt>
Controlefout tussen het regelapparaat van het startsysteem met afstandsbediening en de stuursloteenheid.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Circuit/stekkerverbinding van de stuursloteenheid
</ptxt>
</item>
<item>
<ptxt>
Stuursloteenheid
</ptxt>
</item>
<item>
<ptxt>
Regelapparaat van het startsysteem met afstandsbediening
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1163: Niet-geregistreerde stuursloteenheid 
</emph>
</ptxt>
<ptxt>
Geen registratie van de stuursloteenheid.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70AA504018002">
<title>
DTC-controleprocedure
</title>
<s1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</s1>
<s1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</s1>
<s1>
<ptxt>
Herhaal meermaals stap 1) en 2).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA504018003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70AA504018004">
<testgroup id = "ADUAP70AA504018005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Wis de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70AA504018002">DTC-controleprocedure</intxref>
 uit en controleer daarna opnieuw op DTC&#39;s.
</ptxt>
</test1>
<question>
Wordt DTC B1161 of B1163 nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (Sporadische storing.)
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA504018006">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Vervang de stuursloteenheid. 
<intxreftitleoff1 refid = "ADUAP70A6206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70AA504018002">DTC-controleprocedure</intxref>
 uit en controleer daarna opnieuw op DTC&#39;s.
</ptxt>
</test1>
<question>
Wordt DTC B1161 of B1163 nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het regelapparaat van het startsysteem met afstandsbediening en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (De stuursloteenheid was defect.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
