<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A7216026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de stelmotor van de luchtinlaatregeling
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A7216020">Componenten van de HVAC-regeleenheid:Handmatig type</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A7216026001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het handschoenenkastje. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het vloerkanaal aan de passagierszijde. 
<intxreftitleoff1 refid = "ADUAP70A7216011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de stelmotor van de luchtinlaatregeling los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de schroeven (1).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de stelmotor van de luchtinlaatregeling (2) van de HVAC-eenheid.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721028.jpg" width = "88.000mm" height = "68.236mm" ver = "01" gw = "142" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7216026002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A7216027">Onderzoek van de stelmotor van de luchtinlaatregeling:Handmatig type</intxrefpoff>
</ptxt>
<ptxt>
Keer de uitbouwprocedure om en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zorg ervoor dat de verbindingspen (1) in de groef (2) van de stelmotor van de luchtinlaatregeling gestoken wordt.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721029.swf" width = "88.000mm" height = "49.668mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
