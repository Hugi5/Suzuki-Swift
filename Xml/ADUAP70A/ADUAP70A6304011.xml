<testgroup id = "ADUAP70A6304011004">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Start de motor en controleer de DTC van het P/S-regelapparaat opnieuw.
</ptxt>
</test1>
<question>
Zijn er DTC&#39;s?
</question>
<result type = "yes"/>
<action>
<ptxt>
Voer 
<intxref refid = "ADUAP70A6304003">DTC-controle</intxref>
 uit.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A6304011005">
<title>
Controle van de combimeter
</title>
<test1>
<ptxt>
Vervang de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<question>
Blijft het &#34;P/S&#34;-waarschuwingslampje aan?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het P/S-regelapparaat en controleer opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
