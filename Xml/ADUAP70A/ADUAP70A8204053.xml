<diag type = "test" id = "ADUAP70A8204053003">
<testgroup id = "ADUAP70A8204053004">
<title>
Controle van het circuit van de bestuurdersairbag (opblaaseenheid)-module
</title>
<test1>
<ptxt>
Verwijder de bestuurdersairbag (opblaaseenheid)–module uit de stuurkolom. 
<intxreftitleoff1 refid = "ADUAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;G11&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de kortsluitbeugel in de SDM-stekkerverbinding los met het vrijzetgereedschap dat behoort tot het speciaal gereedschap (A).
</ptxt>
</test1>
<test1>
<ptxt>
Controleer het volgende punt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand tussen aansluitingen &#34;G11-5&#34; en &#34;G11-6&#34;: oneindig
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B097">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820030.swf" width = "90.000mm" height = "60.504mm" ver = "01" gw = "212" gh = "155"/>
</testfigure>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controleer op defecte bedradingsbundel. Vervang het contactspoelsamenstel als het controleresultaat in orde is. 
<intxreftitleoff1 refid = "ADUAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204053005">
<title>
Controle van het contactspoelcircuit (circuit van de bestuurdersairbag (opblaaseenheid)-module)
</title>
<test1>
<ptxt>
Verwijder het contactspoelsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer het volgende punt.
</ptxt>
<ptxt>
Model met contactslot: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Meet de weerstand tussen aansluitklemmen &#34;S121-1&#34; en &#34;S172-2&#34; en tussen &#34;S121-2&#34; en &#34;S172-1&#34;.
</ptxt>
</item>
</list1>
<ptxt>
Model met drukknopstartsysteem: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Meet de weerstand tussen aansluitklemmen &#34;S121-1&#34; en &#34;S174-2&#34; en tussen &#34;S121-2&#34; en &#34;S174-1&#34;.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B098">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820018.swf" width = "90.000mm" height = "70.672mm" ver = "02" gw = "196" gh = "184"/>
</testfigure>
</test1>
<question>
Is de weerstand 1 &#937; of minder?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het contactspoelsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204053006">
<title>
Controle van het contactspoelcircuit (claxoncircuit)
</title>
<test1>
<ptxt>
Controleer het volgende punt.
</ptxt>
<ptxt>
Model met contactslot: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Meet de weerstand tussen aansluitklemmen &#34;S61-1&#34; en &#34;S171-1&#34;.
</ptxt>
</item>
</list1>
<ptxt>
Model met drukknopstartsysteem: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
