<intxreftitleoff1 refid = "ADUAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204053007">
<title>
Controle van het contactspoelcircuit
</title>
<test1>
<ptxt>
Meet de weerstand tussen elke aansluiting van de contactspoel en een andere aansluitingen.
</ptxt>
</test1>
<question>
Is elke gemeten weerstand oneindig?
</question>
<result type = "yes"/>
<action>
<ptxt>
De contactspoel en het bijbehorend circuit zijn in goede staat.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het contactspoelsamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
