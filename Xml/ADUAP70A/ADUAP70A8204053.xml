</testfigure>
</test1>
<question>
Is de weerstand 1 &#937; of minder?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
