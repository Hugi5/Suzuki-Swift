<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A7214A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Er wordt geen koele lucht uitgeblazen of de koeling is onvoldoende (magneetkoppeling werkt normaal)
</title>
<diag type = "condition">
<condition>
<ptxt>
Er wordt geen koele lucht uitgeblazen of de koeling is onvoldoende (magneetkoppeling werkt normaal)
</ptxt>
</condition>
<ps>
<ptxt>
Te veel of te weinig koelmiddel
</ptxt>
</ps>
<action>
<ptxt>
Controleer de hoeveelheid koelmiddel en controleer het systeem op lekken.
</ptxt>
</action>
<ps>
<ptxt>
Verstopte condensor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de condensor. 
<intxreftitleoff1 refid = "ADUAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
De A/C-verdamper is verstopt of bevroren
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Controleer de A/C-verdamper en de verdampertemperatuursensor.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
A/C-verdamper: 
<intxreftitleoff1 refid = "ADUAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verdampertemperatuursensor: 
<intxreftitleoff1 refid = "ADUAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Defecte verdampertemperatuursensor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de verdampertemperatuursensor. 
<intxreftitleoff1 refid = "ADUAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte expansieklep
</ptxt>
</ps>
<action>
<ptxt>
Controleer de expansieklep. 
<intxreftitleoff1 refid = "ADUAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Losse of kapotte compressoraandrijfriem
</ptxt>
</ps>
<action>
<ptxt>
Controleer de compressoraandrijfriem. 
<intxreftitleoff1 refid = "ADUAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slippende magneetkoppeling
</ptxt>
</ps>
<action>
<ptxt>
Controleer de magneetkoppeling. 
<intxreftitleoff1 refid = "ADUAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte compressor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de compressor.
</ptxt>
</action>
<ps>
<ptxt>
Lucht in het A/C-systeem
</ptxt>
</ps>
<action>
<ptxt>
Vervang de condensor, zuig vacuüm en vul bij met koelmiddel. 
<intxreftitleoff1 refid = "ADUAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Er lekt lucht uit de HVAC-eenheid of het luchtkanaal
</ptxt>
</ps>
<action>
<ptxt>
Repareer de HVAC-eenheid of het luchtkanaal.
</ptxt>
</action>
<ps>
<ptxt>
Defect verwarmingssysteem en ventilatiesysteem
</ptxt>
</ps>
<action>
<ptxt>
Controleer de HVAC-eenheid.
</ptxt>
</action>
<ps>
<ptxt>
Defecte aanjagermotor
</ptxt>
</ps>
<action>
<ptxt>
Controleer de aanjagermotor. 
<intxreftitleoff1 refid = "ADUAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Te veel compressorolie in het A/C-systeem
</ptxt>
</ps>
<action>
<ptxt>
Tap overtollige compressorolie uit het A/C-systeemcircuit en de compressor af.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
