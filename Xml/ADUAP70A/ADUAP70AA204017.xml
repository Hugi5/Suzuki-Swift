<diag type = "test" id = "ADUAP70AA204017004">
<testgroup id = "ADUAP70AA204017005">
<title>
DTC opnieuw controleren
</title>
<test1>
<ptxt>
Wis de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70AA204017002">DTC-controleprocedure</intxref>
 uit en controleer daarna opnieuw op DTC&#39;s.
</ptxt>
</test1>
<question>
Wordt DTC B1157 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (De airbag is ooit al geactiveerd. (De DTC is niet gewist.))
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA204017006">
<title>
DTC opnieuw controleren
</title>
<test1>
<ptxt>
Vervang de SDM. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70AA204017002">DTC-controleprocedure</intxref>
 uit en controleer daarna opnieuw op DTC&#39;s.
</ptxt>
</test1>
<question>
Wordt DTC B1157 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de BCM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (SDM was defect.)
</ptxt>
</action>
