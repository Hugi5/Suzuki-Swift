<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A7216043" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de ontlastklep
</title>
<servinfosub id = "ADUAP70A7216043001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Win het koelmiddel uit het A/C-systeem terug met terugwinnings- en recycleerapparatuur volgens Terugwinnen&#34; in 
<intxref refid = "ADUAP70A7216001">Bedieningsprocedure voor koelmiddelvulling:Handmatig type</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de rechtse beschermplaat aan de onderkant van de motor.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de ontlastklep (1) van de compressor.
</ptxt>
<figure>
<graphic graphicname = "I9P60A722038.swf" width = "88.000mm" height = "48.588mm" ver = "03" gw = "120" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7216043002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Gebruik een nieuwe O-ring.
</ptxt>
</item>
<item>
<ptxt>
Smeer compressorolie op de O-ring.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B107" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Compressorolie
</m-desc>
<m-number>
99000-99095-00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Draai de ontlastklep met het voorgeschreven koppel vast.
</ptxt>
<torque>
<torqueitem id = "T7B107">
<t-part>
Ontlastklep
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,8
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A722039.swf" width = "88.000mm" height = "48.612mm" ver = "05" gw = "120" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Zuig het A/C-systeem vacuüm en vul het volgens &#34;Vacuüm zuigen&#34; en &#34;Vullen&#34; in 
<intxref refid = "ADUAP70A7216001">Bedieningsprocedure voor koelmiddelvulling:Handmatig type</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
