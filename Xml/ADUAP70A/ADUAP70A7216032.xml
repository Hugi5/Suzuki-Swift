<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A7216032" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van het HVAC-luchtfilter
</title>
<servinfosub id = "ADUAP70A7216032001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het handschoenenkastje. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het HVAC-luchtfilterdeksel (2) van de HVAC-eenheid.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de luchtfilter (1) van de HVAC-eenheid.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721033.swf" width = "88.000mm" height = "53.307mm" ver = "01" gw = "219" gh = "135"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7216032002">
<title>
Inbouw
</title>
<ptxt>
Keer de uitbouwprocedure om en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Plaats de luchtfilter met het pijlmerkteken (1) naar boven.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721034.swf" width = "88.000mm" height = "48.728mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
