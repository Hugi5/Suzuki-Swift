<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9506012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van het samenstel van het voorruitopeningsmechanisme
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9506010">Componenten van het voorportier</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A9506012001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de voorportierruit. 
<intxreftitleoff1 refid = "ADUAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de motor van de elektrisch bediende ruit los (3).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de moeren van het voorruitopeningsmechanisme (1) en verwijder het samenstel van het voorruitopeningsmechanisme (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950032.jpg" width = "88.000mm" height = "64.165mm" ver = "03" gw = "225" gh = "165"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9506012002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9506013">Onderzoek van het samenstel van het voorruitopeningsmechanisme</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Breng vet op de glijdende gedeelten van het samenstel van het voorruitopeningsmechanisme aan.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E001" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Haal de moeren van het voorruitopeningsmechanisme in volgorde (&#34;1&#34; tot &#34;6&#34;) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9E003">
<t-part>
Moer van het voorruitopeningsmechanisme*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950033.jpg" width = "88.000mm" height = "70.187mm" ver = "02" gw = "225" gh = "182"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
