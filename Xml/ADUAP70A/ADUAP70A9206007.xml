<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de kentekenplaatverlichting
</title>
<servinfosub id = "ADUAP70A9206007001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de schroeven van de onderste bekleding van de achterklep (1) en verwijder vervolgens de onderste bekleding van de achterklep (2).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de kentekenplaatverlichting (3).
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de kentekenplaatverlichting los.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920001.jpg" width = "88.000mm" height = "80.485mm" ver = "01" gw = "211" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de gloeilamp.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9206007002">
<title>
Inbouw
</title>
<ptxt>
Keer de uitbouwprocedure om en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de schroeven van de onderste bekleding van de achterklep met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9B001">
<t-part>
Schroef van de onderste bekleding van de achterklep
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A920002.jpg" width = "88.000mm" height = "80.884mm" ver = "01" gw = "211" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
