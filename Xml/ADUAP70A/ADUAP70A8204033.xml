<servinfosub id = "ADUAP70A8204033003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A8204033004">
<testgroup id = "ADUAP70A8204033005">
<question>
Werd de &#34;Controle van het airbagdiagnosesysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204033006">
<title>
Controle van het circuit van de zij-airbag (opblaaseenheid)-module
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;Q104&#34;- of &#34;Q105&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;L04&#34;- of &#34;L05&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de kortsluitbeugel in de SDM-stekkerverbinding los met het vrijzetgereedschap dat behoort tot het speciaal gereedschap (A).
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Spanning tussen elk van de circuits &#34;A1&#34; en &#34;A2&#34; en de massa (DTC B1064): ongeveer 0 V
</ptxt>
</item>
<item>
<ptxt>
Spanning tussen elk van de circuits &#34;A3&#34; en &#34;A4&#34; en de massa (DTC B1068): ongeveer 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B054">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820129.swf" width = "90.000mm" height = "106.396mm" ver = "02" gw = "228" gh = "285"/>
</testfigure>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de SDM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204033007">
<title>
Controle van het vloerbedradingsbundelcircuit
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de &#34;L384&#34;- of &#34;L385&#34;-stekkerverbinding los.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de kortsluitbeugel in de SDM-stekkerverbinding los met het vrijzetgereedschap dat behoort tot het speciaal gereedschap (A).
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Spanning tussen elk van de circuits &#34;A1&#34; en &#34;A2&#34; en de massa (DTC B1064): ongeveer 0 V
</ptxt>
</item>
<item>
<ptxt>
Spanning tussen elk van de circuits &#34;A3&#34; en &#34;A4&#34; en de massa (DTC B1068): ongeveer 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B055">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820129.swf" width = "90.000mm" height = "106.396mm" ver = "02" gw = "228" gh = "285"/>
</testfigure>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de stoelbedradingsbundel.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de vloerbedradingsbundel.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Voer na het onderzoek en de reparaties de volgende stappen uit.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sluit alle componenten van het airbagsysteem weer aan en controleer of ze juist zijn gemonteerd.
</ptxt>
</item>
<item>
<ptxt>
Wis eventuele DTC&#39;s volgens 
<intxref refid = "ADUAP70A8204006">Wissen van DTC</intxref>
, als een DTC wordt waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Herhaal 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
 om te controleren of de storing is opgelost.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
