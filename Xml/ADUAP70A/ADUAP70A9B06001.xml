<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9B06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de motorkapvergrendelingsdraagbalk, lampsteunbalk en lampsteunbeugel
</title>
<attention3>
<ptxt>
De onderstaande afbeelding toont de omstandigheid waarin de volgende onderdelen zijn verwijderd.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voorwielspatbord 
<intxreftitleoff1 refid = "ADUAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "IAP70P9B0057.jpg" width = "88.000mm" height = "55.699mm" ver = "01" gw = "227" gh = "141"/>
</figure>
<servinfosub id = "ADUAP70A9B06001001">
<title>
Algemene opmerkingen
</title>
<ptxt>
De lasmethode en het aantal laspunten zijn aan beide zijden hetzelfde. Deze reparatie-aanwijzing toont de procedure voor de linkerzijde.
</ptxt>
</servinfosub>
<servinfosub id = "ADUAP70A9B06001002">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Draai 12 bouten los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de motorkapvergrendelingsdraagbalk en de lampsteunbalk.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0003.jpg" width = "183.000mm" height = "157.046mm" ver = "02" gw = "347" gh = "429"/>
</figure>
</s1>
<s1>
<ptxt>
Boor de laspunten uit en verwijder de lampsteunbeugel.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0022.jpg" width = "183.000mm" height = "123.642mm" ver = "02" gw = "497" gh = "334"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9B06001003">
<title>
Inbouw
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Controleer alvorens te gaan lassen de montagepositie en de toestand van montagedelen. 
<intxreftitleoff1 refid = "ADUAP70A9B04004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ga verder met de reparatie en houd rekening met de montage van onderdelen die het uiterlijk beïnvloeden. 
<intxreftitleoff1 refid = "ADUAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention2>
<s1>
<ptxt>
Monteer de lampsteunbeugel.
</ptxt>
</s1>
<s1>
<ptxt>
Voer weerstandspuntlassen of gatlassen uit.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0023.jpg" width = "183.000mm" height = "123.642mm" ver = "02" gw = "497" gh = "334"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de motorkapvergrendelingsdraagbalk.
</ptxt>
</s1>
<s1>
<ptxt>
Haal de 4 bouten met het voorgeschreven koppel aan.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0006.jpg" width = "183.000mm" height = "154.844mm" ver = "04" gw = "364" gh = "422"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.465in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
23 Nm (2,3 kgk-m, 17,0 lbf-ft) 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Breng lak en coating op de gerepareerde of vervangen onderdelen aan.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de gelakte lampsteunbalk.
</ptxt>
</s1>
<s1>
<ptxt>
Haal de 6 bouten met het voorgeschreven koppel aan.
</ptxt>
<figure>
<graphic graphicname = "IAP70P9B0024.jpg" width = "183.000mm" height = "81.918mm" ver = "02" gw = "511" gh = "216"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.465in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MATORQUE-A" width = "8.011mm" height = "3.048mm"/>
: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
8,8 Nm (0,90 kgk-m, 6,5 lbf-ft) 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
