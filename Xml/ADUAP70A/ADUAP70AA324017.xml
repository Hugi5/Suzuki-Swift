<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70AA324017" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1176
</title>
<servinfosub id = "ADUAP70AA324017001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1176: Gegevensinformatie niet geregistreerd 
</emph>
</ptxt>
<ptxt>
De voertuiggegevens zijn niet geregistreerd in het regelapparaat van het startsysteem met afstandsbediening.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
De afstandsbediening is niet geregistreerd
</ptxt>
</item>
<item>
<ptxt>
Regelapparaat van het startsysteem met afstandsbediening
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70AA324017002">
<title>
DTC-storingzoeken
</title>
<attention3>
<ptxt>
Controleer of de gegevensinformatie onjuist werd geladen als de registratie van de startblokkering niet normaal werd voltooid.
</ptxt>
</attention3>
<diag type = "test" id = "ADUAP70AA324017003">
<testgroup id = "ADUAP70AA324017006">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer het regelapparaat van het startsysteem met afstandsbediening op DTC&#39;s. 
<intxreftitleoff1 refid = "ADUAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn er CAN-DTC&#39;s waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA324017005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Controleer DTC met betrekking tot CAN-communicatie.
</ptxt>
</test1>
<question>
Zijn er CAN-DTC&#39;s waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA324017004">
<title>
Registratie van de afstandsbediening
</title>
<test1>
<ptxt>
Voer &#34;Sleutelregistratie startblokkering&#34; uit. 
<intxreftitleoff1 refid = "ADUAP70AA326002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC B1176 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het regelapparaat van het startsysteem met afstandsbediening en controleer de DTC opnieuw.	 
<intxreftitleoff1 refid = "ADUAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (De afstandsbediening was niet geregistreerd)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
