<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A6306006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de stuurhuisbus
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A6306001">Componenten van het stuurhuissamenstel</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Vervang bij het vervangen van een stuurhuisbus ook de bussen aan de andere zijde als een set.
</ptxt>
</attention2>
<servinfosub id = "ADUAP70A6306006001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het stuurhuissamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Snijd het (rubberen) flensgedeelte (1) van iedere stuurhuisbus met een mes af.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630023.swf" width = "88.000mm" height = "51.406mm" ver = "01" gw = "234" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Druk de stuurhuisbus (1) eruit met behulp van een hydraulische pers (2) en speciaal gereedschap.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C004">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C005">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630024.swf" width = "88.000mm" height = "49.527mm" ver = "01" gw = "104" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A6306006002">
<title>
Inbouw
</title>
<s1>
<ptxt>
Druk een nieuwe stuurhuisbus (1) vast met speciaal gereedschap en een hydraulische pers (2).
</ptxt>
<attention2>
<ptxt>
Gebruik de stuurhuisbus niet opnieuw.
</ptxt>
</attention2>
<servicetool>
<servicetoolitem id = "L6C006">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C007">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<attention3>
<ptxt>
Breng vóór het monteren van de stuurhuisbus zeepwater op de omtrek aan om montage te vergemakkelijken.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A630025.swf" width = "88.000mm" height = "51.452mm" ver = "01" gw = "104" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Druk de stuurhuisbus (1) vast zodat de afmetingen &#34;a&#34; en &#34;b&#34; op de afbeelding gelijk worden.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer het stuurhuissamenstel. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
