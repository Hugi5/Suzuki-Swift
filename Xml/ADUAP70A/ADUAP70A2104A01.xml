<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A2104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Voertuig trekt naar een zijde (trekken)
</title>
<diag type = "condition">
<condition>
<ptxt>
Voertuig trekt naar een zijde (trekken)
</ptxt>
</condition>
<ps>
<ptxt>
Niet passende of ongelijkmatig versleten banden
</ptxt>
</ps>
<action>
<ptxt>
Vervang de banden. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Banden niet goed opgepompt
</ptxt>
</ps>
<action>
<ptxt>
Stel de bandenspanning af.
</ptxt>
</action>
<ps>
<ptxt>
Kapotte of niet goed gespannen schroefveren
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vervang de schroefveren.
</ptxt>
<ptxt>
Voor: 
<intxreftitleoff1 refid = "ADUAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Achter: 
<intxreftitleoff1 refid = "ADUAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Abnormale dwarskracht gemaakt door radiaalband
</ptxt>
</ps>
<action>
<ptxt>
Vervang de band. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Wieluitlijning verstoord
</ptxt>
</ps>
<action>
<ptxt>
Controleer de wieluitlijning en stel ze bij. 
<intxreftitleoff1 refid = "ADUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Wiel met remweerstand
</ptxt>
</ps>
<action>
<ptxt>
Stel de rem af of repareer ze.
</ptxt>
</action>
<ps>
<ptxt>
Loszittende, verbogen of kapotte onderdelen van voor- of achterwielophanging
</ptxt>
</ps>
<action>
<ptxt>
Zet de betrokken onderdelen van de wielophanging vast of vervang ze. 
<intxreftitleoff1 refid = "ADUAP70A2106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
