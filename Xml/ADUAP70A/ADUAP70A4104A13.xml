<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A4104A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Remwaarschuwingslampje blijft branden (gedurende langer dan 2 sec) na het starten van de motor
</title>
<diag type = "condition">
<condition>
<ptxt>
Remwaarschuwingslampje blijft branden (gedurende langer dan 2 sec) na het starten van de motor
</ptxt>
</condition>
<ps>
<ptxt>
De ESP<sup>&#174;</sup>-regelapparaat-stekkerverbinding is niet correct aangesloten
</ptxt>
</ps>
<action>
<ptxt>
Sluit de ESP<sup>&#174;</sup>-regelapparaat-stekkerverbinding opnieuw aan.
</ptxt>
</action>
<ps>
<ptxt>
De parkeerrem is aangetrokken
</ptxt>
</ps>
<action>
<ptxt>
Schakel de parkeerrem uit en controleer of het waarschuwingslampje uitgaat.
</ptxt>
</action>
<ps>
<ptxt>
Onvoldoende remvloeistof
</ptxt>
</ps>
<action>
<ptxt>
Controleer het remvloeistofpeil. 
<intxreftitleoff1 refid = "ADUAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Het ABS-waarschuwingslampje knippert
</ptxt>
</ps>
<action>
<ptxt>
Spoor de storing op en repareer deze. 
<intxreftitleoff1 refid = "ADUAP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte parkeerremschakelaar en/of remvloeistofpeilschakelaar
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Controleer de parkeerremschakelaar en/of remvloeistofpeilschakelaar.
</ptxt>
<ptxt>
Parkeerremschakelaar: 
<intxreftitleoff1 refid = "ADUAP70A4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Remvloeistofpeilschakelaar: 
<intxreftitleoff1 refid = "ADUAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Slecht werkend CAN-communicatiesysteem
</ptxt>
</ps>
<action>
<ptxt>
Controleer het CAN-communicatiesysteem. 
<intxreftitleoff1 refid = "ADUAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte combimeter
</ptxt>
</ps>
<action>
<ptxt>
Vervang de combimeter. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defecte hydraulische regeleenheid / regelapparaat van het ESP<sup>&#174;</sup>
</ptxt>
</ps>
<action>
<ptxt>
Vervang de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup>. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
