<servinfosub id = "ADUAP70A1104053003">
<title>
DTC-controleprocedure
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Zorg dat u eerst onverwachte DTC&#39;s oplost die eerder tijdens de &#34;DTC-controleprocedure&#34; zijn waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Controleer of aan de volgende voorwaarden in deze &#34;DTC-controleprocedure&#34; is voldaan.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Accuspanning &#62; 8 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
IAT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
DTC P0122, P0123, P0222, P0223, P2135 of P2176 wordt niet waargenomen.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</s1>
<s1>
<ptxt>
Houd het gaspedaal gedurende 2 sec. volledig ingedrukt
</ptxt>
</s1>
<s1>
<ptxt>
Laat het gaspedaal gedurende 2 sec. los
</ptxt>
</s1>
<s1>
<ptxt>
Zet het contactslot in de &#34;OFF&#34;-stand gedurende 1 min. en dan weer in de &#34;ON&#34;-stand.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1104053004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A1104053005">
<testgroup id = "ADUAP70A1104053006">
<question>
Is de &#34;Controle van het motor- en emissieregelsysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A1104001">Controle van het motor- en emissieregelsysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104053007">
<title>
DTC opnieuw controleren
</title>
<test1>
<ptxt>
Wis de DTC.
</ptxt>
</test1>
<test1>
<ptxt>
IJken van het elektrische-gasklepregelsysteem. 
<intxreftitleoff1 refid = "ADUAP70A1306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC opnieuw.
</ptxt>
</test1>
<question>
Wordt DTC P2101 / DTC P2119 nog waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104053008">
<title>
Controle van de gasklepstelmotorstuurkring
</title>
<test1>
<ptxt>
Controleer de gasklepstelmotorstuurkringen zoals beschreven in stap 2 onder 
<intxref refid = "ADUAP70A1104052">DTC P2100</intxref>
.
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer de gasklepstelmotorstuurkring.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1104053009">
<title>
Controle van het elektrische-gasklephuissamenstel
</title>
<test1>
<ptxt>
Controleer de prestaties van het elektrische gasklephuis. 
<intxreftitleoff1 refid = "ADUAP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang het elektrische-gasklephuissamenstel.
</ptxt>
</action>
</testgroup>
</diag>
