<servinfo servinfosgmlid = "ADUAP70A8204013" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1013
</title>
<servinfosub id = "ADUAP70A8204013001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.040in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.147in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1013: Interne SDM-storing 
</emph>
</ptxt>
<ptxt>
Slecht werkend(e) intern SDM-circuit, G-sensor, geheugen of CPU.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
SDM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A8204013002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A8204013003">
<testgroup id = "ADUAP70A8204013004">
<question>
Werd de &#34;Controle van het airbagdiagnosesysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A8204013005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Wis de DTC. 
<intxreftitleoff1 refid = "ADUAP70A8204006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt DTC B1013 nog steeds aangegeven?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de SDM en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Controleer op sporadische storingen. 
<intxreftitleoff1 refid = "ADUAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Voer na het onderzoek en de reparaties de volgende stappen uit.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sluit alle componenten van het airbagsysteem weer aan en controleer of ze juist zijn gemonteerd.
</ptxt>
</item>
<item>
<ptxt>
Wis eventuele DTC&#39;s volgens 
<intxref refid = "ADUAP70A8204006">Wissen van DTC</intxref>
, als een DTC wordt waargenomen.
</ptxt>
</item>
<item>
<ptxt>
Herhaal 
<intxref refid = "ADUAP70A8204001">Controle van het airbagdiagnosesysteem</intxref>
 om te controleren of de storing is opgelost.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
