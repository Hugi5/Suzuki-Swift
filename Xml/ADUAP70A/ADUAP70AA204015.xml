<servinfosub id = "ADUAP70AA204015003">
<title>
DTC-controleprocedure
</title>
<s1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70AA204015004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70AA204015005">
<testgroup id = "ADUAP70AA204015006">
<title>
DTC-controle
</title>
<question>
Is DTC B1132 ook waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar storingzoeken voor de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA204015009">
<title>
Controle van de parameter
</title>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de weergave &#34;A/C-verdampertemperatuur&#34; op het SUZUKI-uitleesapparaat. 
<intxreftitleoff1 refid = "ADUAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Einde. (Sporadische storing.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA204015007">
<title>
Controle van het circuit van de verdampertemperatuursensor
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Maak de verdampertemperatuursensor en de volgende stekkerverbindingen los.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met contactslot: Stekkerverbinding &#34;G04&#34;
</ptxt>
</item>
<item>
<ptxt>
Model met drukknopstartsysteem: Stekkerverbinding &#34;G05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Controleer of de aansluitklemmen juist op de stekkerverbinding van de verdampertemperatuursensor en de volgende stekkerverbindingen zijn aangesloten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met contactslot: Stekkerverbinding &#34;G04&#34;
</ptxt>
</item>
<item>
<ptxt>
Model met drukknopstartsysteem: Stekkerverbinding &#34;G05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Als de aansluitingen in orde zijn, controleer dan de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van circuit &#34;A1&#34; en &#34;A2&#34;: minder dan 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuit &#34;A1&#34; en de massa: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen de circuitaansluitklemmen &#34;A1&#34; en &#34;A2&#34; op de stekkerverbinding van de buitenluchttemperatuursensor: oneindig
</ptxt>
</item>
<item>
<ptxt>
Spanning van elk van de circuits &#34;A1&#34; en &#34;A2&#34;: 0 – 1 V (als de ontsteking is ingeschakeld)
</ptxt>
</item>
</list1>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70AA204015008">
<title>
Controle van de verdampertemperatuursensor
</title>
<test1>
<ptxt>
Controleer de verdampertemperatuursensor.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met handbediende A/C: 
<intxreftitleoff1 refid = "ADUAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model met automatische A/C: 
<intxreftitleoff1 refid = "ADUAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Is hij in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Vervang de verdampertemperatuursensor.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Model met handbediende A/C: 
<intxreftitleoff1 refid = "ADUAP70A7216016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Model met automatische A/C: 
<intxreftitleoff1 refid = "ADUAP70A7226018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
<testgroup id = "ADUAP70AA204015010">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Verbind de verdampertemperatuursensor en de volgende stekkerverbindingen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Model met contactslot: Stekkerverbinding &#34;E04&#34;
</ptxt>
</item>
<item>
<ptxt>
Model met drukknopstartsysteem: Stekkerverbinding &#34;E05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Controleer de DTC. 
<intxreftitleoff1 refid = "ADUAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wordt huidige DTC B1145 of B1146 waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de BCM en controleer de DTC opnieuw.	 
<intxreftitleoff1 refid = "ADUAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde. (Sporadische storing.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
