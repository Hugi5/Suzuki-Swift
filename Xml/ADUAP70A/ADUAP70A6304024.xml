<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A6304024" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Controle van de stuurkracht
</title>
<s1>
<ptxt>
Plaats het voertuig op een vlakke weg en zet het stuurwiel rechtuit.
</ptxt>
</s1>
<s1>
<ptxt>
Controleer of de bandenspanning voldoet aan de voorschriften op de bandeninformatiesticker.
</ptxt>
</s1>
<s1>
<ptxt>
Start de motor.
</ptxt>
</s1>
<s1>
<ptxt>
Meet de stuurkracht met behulp van een veerbalanceerapparaat (1) terwijl de motor stationair draait.
</ptxt>
<spec-sdm>
<sdm-title>
Stuurkracht
</sdm-title>
<sdm1>
<sdm-condition>
</sdm-condition>
<sdm-value>
34 N (3,5 kgk, 7,6 lbf)
</sdm-value>
</sdm1>
</spec-sdm>
<figure>
<graphic graphicname = "I8C50A630016.swf" width = "88.000mm" height = "42.846mm" ver = "01" gw = "0" gh = "0"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
