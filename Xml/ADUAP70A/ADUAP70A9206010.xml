<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de leeslamp (indien uitgerust)
</title>
<servinfosub id = "ADUAP70A9206010001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de leeslamp (1) terwijl de vergrendelingen (2) losgemaakt worden.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de leeslamp los.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920027.jpg" width = "88.000mm" height = "68.223mm" ver = "02" gw = "199" gh = "177"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de gloeilampfitting (1) van de leeslamp (2) en verwijder de gloeilampen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920015.jpg" width = "88.000mm" height = "57.222mm" ver = "01" gw = "204" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9206010002">
<title>
Inbouw
</title>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
