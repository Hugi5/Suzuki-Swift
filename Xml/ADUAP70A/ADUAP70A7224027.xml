<servinfosub id = "ADUAP70A7224027003">
<title>
DTC-controleprocedure
</title>
<s1>
<ptxt>
Start de motor en bedien het A/C-systeem.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A7224027004">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A7224027005">
<testgroup id = "ADUAP70A7224027006">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking uit.
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in en controleer de DTC.
</ptxt>
</test1>
<question>
Worden DTC B1550-H of B1550-L nog steeds waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sporadische storing.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A7224027007">
<title>
Controle van het communicatiecircuit
</title>
<test1>
<ptxt>
Maak de &#34;G20&#34;- en &#34;G227&#34;-stekkerverbindingen los.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van het &#34;PNK/BLU&#34;-draadcircuit: minder dan 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand van het &#34;PNK/BLU&#34;-draadcircuit tussen het paneel van de automatische A/C en de massa: oneindig
</ptxt>
</item>
</list1>
</test1>
<question>
Zijn de weerstandswaarden zoals voorgeschreven?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Monteer een goed bevonden HVAC-regelapparaat en/of paneel van de automatische A/C en controleer de DTC opnieuw.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
HVAC-regelapparaat: 
<intxreftitleoff1 refid = "ADUAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Paneel van de automatische A/C: 
<intxreftitleoff1 refid = "ADUAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de instrumentenpaneelbedradingsbundel
</ptxt>
</action>
</testgroup>
</diag>
