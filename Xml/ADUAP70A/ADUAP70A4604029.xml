<servinfosub id = "ADUAP70A4604029003">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604029004">
<testgroup id = "ADUAP70A4604029005">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604029006">
<title>
Controle van de voedings- en massacircuits van het ESP&#174;-regelapparaat
</title>
<test1>
<ptxt>
Controleer het voedings- en massacircuit van het ESP<sup>&#174;</sup>-regelapparaat. 
<intxreftitleoff1 refid = "ADUAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Zijn ze in goede staat?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang de defecte bedradingsbundel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604029007">
<title>
Controle van de voedingsspanning van het ESP&#174;-regelapparaat
</title>
<test1>
<ptxt>
Meet de accuspanning terwijl de motor 3.000 omw/min draait.
</ptxt>
</test1>
<question>
Ligt de spanning tussen 9,3 V en 16,8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Controleer het laadsysteem. 
<intxreftitleoff1 refid = "ADUAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
