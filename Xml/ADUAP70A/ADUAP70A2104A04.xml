<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Wielslingering, schudden of trillen
</title>
<diag type = "condition">
<condition>
<ptxt>
Wielslingering, schudden of trillen
</ptxt>
</condition>
<ps>
<ptxt>
Wiel uit balans
</ptxt>
</ps>
<action>
<ptxt>
Balanceer de wiel(en) uit of vervang de band(en) en/of wiel(en).
</ptxt>
</action>
<ps>
<ptxt>
Losse wiellagers
</ptxt>
</ps>
<action>
<ptxt>
Vervang de wiellagers. 
<intxreftitleoff1 refid = "ADUAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Versleten trekstanguiteinden.
</ptxt>
</ps>
<action>
<ptxt>
Vervang de trekstanguiteinden. 
<intxreftitleoff1 refid = "ADUAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Versleten wieldraagarmkoppelingen
</ptxt>
</ps>
<action>
<ptxt>
Vervang de wieldraagarm. 
<intxreftitleoff1 refid = "ADUAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Overmatige band- of wielslingering
</ptxt>
</ps>
<action>
<ptxt>
Wiel en/of band repareren of vervangen.
</ptxt>
</action>
<ps>
<ptxt>
Blaas of bult op band
</ptxt>
</ps>
<action>
<ptxt>
Vervang de band. 
<intxreftitleoff1 refid = "ADUAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Overmatige radiale slingering van band / wielsamenstel
</ptxt>
</ps>
<action>
<ptxt>
Vervang het wiel of de band.
</ptxt>
</action>
<ps>
<ptxt>
Wieluitlijning verstoord
</ptxt>
</ps>
<action>
<ptxt>
Controleer de wieluitlijning en stel ze bij. 
<intxreftitleoff1 refid = "ADUAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Los of versleten stuurstangenstelsel
</ptxt>
</ps>
<action>
<ptxt>
Onderzoek het stuursysteem. 
<intxreftitleoff1 refid = "ADUAP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loszittende stuurhuisbouten
</ptxt>
</ps>
<action>
<ptxt>
Draai de stuurhuisbouten aan. 
<intxreftitleoff1 refid = "ADUAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
