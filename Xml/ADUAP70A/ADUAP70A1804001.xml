<servinfosub id = "ADUAP70A1804001002">
<title>
Storingzoeken
</title>
<diag type = "test" id = "ADUAP70A1804001003">
<testgroup id = "ADUAP70A1804001004">
<question>
Is de &#34;Controle van het motor- en emissieregelsysteem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A1104001">Controle van het motor- en emissieregelsysteem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1804001005">
<title>
Ontstekingsvonktest 1
</title>
<test1>
<ptxt>
Voer de ontstekingsvonktest uit. 
<intxreftitleoff1 refid = "ADUAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het testresultaat in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1804001006">
<title>
Controle van het ontstekingstijdstip
</title>
<test1>
<ptxt>
Controleer de ontstekingsafstelling. 
<intxreftitleoff1 refid = "ADUAP70A1806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Het ontstekingssysteem is in orde.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang het defecte onderdeel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1804001007">
<title>
Controle van een slecht werkende cilinder
</title>
<test1>
<ptxt>
Controleer de cilinder(s) waar tijdens de ontstekingsvonktest een storing werd vastgesteld.
</ptxt>
</test1>
<question>
Zijn alle cilinders in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1804001008">
<title>
Ontstekingsvonktest 2
</title>
<test1>
<ptxt>
Vervang de bougie van elke slecht werkende cilinder door een exemplaar van een normale cilinder.
</ptxt>
</test1>
<test1>
<ptxt>
Voer de ontstekingsvonktest uit. 
<intxreftitleoff1 refid = "ADUAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het testresultaat in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de bougie. 
<intxreftitleoff1 refid = "ADUAP70A1806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 6.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1804001009">
<title>
Ontstekingsvonktest 3
</title>
<test1>
<ptxt>
Vervang de bobine van elke slecht werkende cilinder door een exemplaar van een normale cilinder.
</ptxt>
</test1>
<test1>
<ptxt>
Voer de ontstekingsvonktest uit. 
<intxreftitleoff1 refid = "ADUAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is het testresultaat in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de bobine. 
<intxreftitleoff1 refid = "ADUAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Ga naar stap 7.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "ADUAP70A1804001010">
<title>
Controle van de voedings- en massacircuits van het bobinesamenstel
</title>
<test1>
<ptxt>
Maak &#34;C01&#34; en &#34;E01&#34; los van de ECM en de bobinestekkerverbindingen als de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer of de aansluitklemmen juist op de bobinestekkerverbindingen zijn aangesloten.
</ptxt>
</test1>
<test1>
<ptxt>
Als de aansluitingen in orde zijn, controleer dan de volgende punten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van circuits &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;, &#34;A4&#34;, &#34;C1&#34;, &#34;C2&#34;, &#34;C3&#34; en &#34;C4&#34;: minder dan 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen elk van de circuits &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;, &#34;A4&#34;, &#34;C1&#34;, &#34;C2&#34;, &#34;C3&#34; en &#34;C4&#34; en de massa: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;A1&#34; en andere aansluitklem aan de bobinestekkerverbinding: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;A2&#34; en andere aansluitklem aan de bobinestekkerverbinding: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;A3&#34; en andere aansluitklem aan de bobinestekkerverbinding: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;A4&#34; en andere aansluitklem aan de bobinestekkerverbinding: oneindig
</ptxt>
</item>
<item>
<ptxt>
Spanning van circuits &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;, &#34;A4&#34;, &#34;C1&#34;, &#34;C2&#34;, &#34;C3&#34; en &#34;C4&#34;: 0 tot 1 V (als de ontsteking is ingeschakeld)
</ptxt>
</item>
</list1>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang het defecte onderdeel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1804001011">
<title>
Controle van de stuurkringen van het bobinesamenstel
</title>
<test1>
<ptxt>
Controleer de volgende punten bij uitgeschakelde ontsteking: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Weerstand van circuits &#34;B1&#34;, &#34;B2&#34;, &#34;B3&#34; en &#34;B4&#34;: minder dan 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen elk van de circuits &#34;B1&#34;, &#34;B2&#34;, &#34;B3&#34; en &#34;B4&#34; en de massa: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;B1&#34; en andere aansluitklem aan de bobinestekkerverbinding: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;B2&#34; en andere aansluitklem aan de bobinestekkerverbinding: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;B3&#34; en andere aansluitklem aan de bobinestekkerverbinding: oneindig
</ptxt>
</item>
<item>
<ptxt>
Weerstand tussen circuitaansluitklem &#34;B4&#34; en andere aansluitklem aan de bobinestekkerverbinding: oneindig
</ptxt>
</item>
<item>
<ptxt>
Spanning van circuits &#34;B1&#34;, &#34;B2&#34;, &#34;B3&#34; en &#34;B4&#34;: 0 tot 1 V (als de ontsteking is ingeschakeld)
</ptxt>
</item>
</list1>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 9.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repareer of vervang het defecte onderdeel.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A1804001012">
<title>
Controle CKP- en CMP-sensor
</title>
<test1>
<ptxt>
Controleer de CKP- en CMP-sensor.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
CKP-sensor: 
<intxreftitleoff1 refid = "ADUAP70A1306020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
CMP-sensor: 
<intxreftitleoff1 refid = "ADUAP70A1306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Is het resultaat van de controle in orde?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang de ECM en controleer de ontstekingsvonk opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vervang de CKP- of CMP-sensor.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
