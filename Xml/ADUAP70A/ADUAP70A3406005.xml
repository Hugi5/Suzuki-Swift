<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A3406005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Demontage en hermontage van de koppeling
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A3406004">Demontage en hermontage van het cardanassamenstel</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A3406005001">
<title>
Demontage
</title>
<s1>
<ptxt>
Verwijder de borgveer van de koppelingsas met een veerringtang.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de visco-koppeling (1) van de koppelingsas (2) met een hydraulische pers (3) en trekker (4).
</ptxt>
<figure>
<graphic graphicname = "I5RS0D340007.swf" width = "88.000mm" height = "49.401mm" ver = "01" gw = "114" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A3406005002">
<title>
Hermontage
</title>
<s1>
<ptxt>
Monteer de visco-koppeling (1) op de koppelingsas (2) met speciaal gereedschap en een hydraulische pers.
</ptxt>
<servicetool>
<servicetoolitem id = "L3D001">
<s-part>
(A)
</s-part>
<s-number num = "09922-55131">
09922-55131
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A340010.swf" width = "88.000mm" height = "50.636mm" ver = "01" gw = "94" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer een nieuwe borgveer op de tussenas met een veerringtang.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
