<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van het achterklepslot
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9606010">Componenten van het achterklepslot</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "ADUAP70A9606011">Onderzoek in het voertuig van het achterklepslot</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A9606012001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de achterklepbekleding (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70P960027.jpg" width = "88.000mm" height = "80.582mm" ver = "01" gw = "198" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van het achterklepslot (1) van het achterklepslotsamenstel (2) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de achterklepslotbouten (3) en verwijder het achterklepslotsamenstel (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A960004.jpg" width = "88.000mm" height = "53.858mm" ver = "01" gw = "142" gh = "136"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9606012002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de achterklepslotbouten met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9F002">
<t-part>
Achterklepslotbout
</t-part>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Stel indien nodig de achterklepslotplaat als volgt bij.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Maak indien nodig de schroeven van de achterklepslotplaat (1) los.
</ptxt>
</item>
<item>
<ptxt>
Stel de positie van de achterklepslotplaat (2) bij zodat de achterklep soepel geopend en gesloten kan worden.
</ptxt>
</item>
<item>
<ptxt>
Haal de schroeven van de achterklepslotplaat met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9F003">
<t-part>
Achterklepslotplaatschroef
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A960018.jpg" width = "88.000mm" height = "61.730mm" ver = "02" gw = "198" gh = "158"/>
</figure>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
