<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A4604024" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1038
</title>
<servinfosub id = "ADUAP70A4604024001">
<title>
DTC-waarnemingsvoorwaarde en plaats van de storing
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.259in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.896in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC-waarnemingsvoorwaarde
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Plaats van de storing
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1038: De stuurhoeksensor neemt een storing in de rolteller waar
</emph>
</ptxt>
<ptxt>
De stuurhoeksensor neemt ongeldige CAN-gegevens van het ESP<sup>&#174;</sup>-regelapparaat waar.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
CAN-communicatiecircuit
</ptxt>
</item>
<item>
<ptxt>
Stuurhoeksensor
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup>-regelapparaat
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ADUAP70A4604024002">
<title>
DTC-storingzoeken
</title>
<diag type = "test" id = "ADUAP70A4604024003">
<testgroup id = "ADUAP70A4604024004">
<question>
Werd &#34;Controle van ESP<sup>&#174;</sup>-systeem&#34; uitgevoerd?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar stap 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar 
<intxref refid = "ADUAP70A4604001">Controle van ESP&#174;-systeem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604024005">
<title>
DTC-controle
</title>
<test1>
<ptxt>
Voer 
<intxref refid = "ADUAP70A4604005">DTC-controle</intxref>
 uit.
</ptxt>
</test1>
<question>
Wordt er een andere DTC dan C1038 waargenomen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ga naar DTC-storingzoeken van de betrokken DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ga naar stap 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ADUAP70A4604024006">
<title>
Controle van de stuurhoeksensor
</title>
<test1>
<ptxt>
Controleer of de ontsteking is uitgeschakeld.
</ptxt>
</test1>
<test1>
<ptxt>
Vervang de stuurhoeksensor. 
<intxreftitleoff1 refid = "ADUAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Schakel de ontsteking in.
</ptxt>
</test1>
<test1>
<ptxt>
Controleer de DTC.
</ptxt>
</test1>
<question>
Wordt DTC C1038 vastgesteld?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vervang het samenstel van de hydraulische regeleenheid / het regelapparaat van het ESP<sup>&#174;</sup> en controleer de DTC opnieuw. 
<intxreftitleoff1 refid = "ADUAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einde.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
