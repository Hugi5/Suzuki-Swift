<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A5206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de achteruitrijlichtschakelaar
</title>
<servinfosub id = "ADUAP70A5206007001">
<title>
Uitbouw
</title>
<s1 page = "2">
<ptxt>
Verwijder de ECM van de accudrager. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de accu en de accudrager. 
<intxreftitleoff1 refid = "ADUAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de achteruitrijlichtschakelaar (1) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de achteruitrijlichtschakelaar (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A520006.jpg" width = "88.000mm" height = "56.038mm" ver = "01" gw = "199" gh = "142"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A5206007002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A5206008">Onderzoek van de achteruitrijlichtschakelaar</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Smeer olie op de nieuwe O-ring (1) en draai de achteruitrijlichtschakelaar (2) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T5B004">
<t-part>
Achteruitrijlichtschakelaar
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I3RH0A520006.swf" width = "88.000mm" height = "31.317mm" ver = "01" gw = "148" gh = "73"/>
</figure>
</s1>
<s1>
<ptxt>
Sluit de stekkerverbinding van de achteruitrijlichtschakelaar aan.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de accudrager en de accu. 
<intxreftitleoff1 refid = "ADUAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Monteer de ECM op de accudrager. 
<intxreftitleoff1 refid = "ADUAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
