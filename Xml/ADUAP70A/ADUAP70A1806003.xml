<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1806003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van het bobinesamenstel
</title>
<servinfosub id = "ADUAP70A1806003001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder het luchtfiltersamenstel. 
<intxreftitleoff1 refid = "ADUAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbindingen van de bobine los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bobinebouten (1) en trek vervolgens de bobinesamenstellen (2) naar buiten.
</ptxt>
<figure>
<graphic graphicname = "I7V20A180004.swf" width = "88.000mm" height = "54.310mm" ver = "01" gw = "212" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A1806003002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1806004">Onderzoek van het bobinesamenstel</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de bobinebout met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1H002">
<t-part>
Bout van de bobine
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
