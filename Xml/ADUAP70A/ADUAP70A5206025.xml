<servinfosub id = "ADUAP70A5206025001">
<title>
Demontage
</title>
<s1>
<ptxt>
Verwijder het linkse lager (1) met het speciale gereedschap.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B036">
<s-part>
(A)
</s-part>
<s-number num = "09913-65135">
09913-65135
</s-number>
