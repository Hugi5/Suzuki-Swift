<servinfo servinfosgmlid = "ADUAP70A9206012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de bagageruimteverlichting
</title>
<servinfosub id = "ADUAP70A9206012001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de bagageruimteverlichting (1) door ze in de richting van de pijl te trekken terwijl de vergrendeling (2) losgemaakt wordt.
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding los van de bagageruimteverlichting.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de gloeilamp (3) indien nodig.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920016.jpg" width = "88.000mm" height = "62.981mm" ver = "04" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9206012002">
<title>
Inbouw
</title>
<ptxt>
De inbouw gebeurt in de omgekeerde volgorde van de uitbouw.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
