<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van het samenstel van het achterruitopeningsmechanisme
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9506014">Componenten van het achterportier</intxrefpoff>
</ptxt>
<servinfosub id = "ADUAP70A9506017001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder de achterportierruit. 
<intxreftitleoff1 refid = "ADUAP70A9506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding van de motor van de elektrisch bediende ruit (1) los.
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de bouten van het ruitopeningsmechanisme (2) en verwijder het samenstel van het achterruitopeningsmechanisme (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950048.jpg" width = "88.000mm" height = "61.700mm" ver = "02" gw = "217" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A9506017002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A9506018">Onderzoek van het samenstel van het achterruitopeningsmechanisme</intxrefpoff>
</ptxt>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij de volgende punten in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Breng vet op de glijdende gedeelten van het samenstel van het achterruitopeningsmechanisme aan.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E002" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Vet
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Haal de bouten van het achterportierruitopeningsmechanisme in de volgorde (&#34;1&#34; tot &#34;4&#34;) met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T9E006">
<t-part>
Bout van het achterruitopeningsmechanisme*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,86
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950049.jpg" width = "88.000mm" height = "63.881mm" ver = "01" gw = "225" gh = "165"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
