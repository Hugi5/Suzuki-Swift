<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ADUAP70A1104A17" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Overmatige uitstoot van stikstofoxiden (NOx)
</title>
<ptxt>
Onderzoek de storingen zoals hieronder beschreven als de ECM geen DTC en geen abnormale situatie heeft waargenomen in 
<intxref refid = "ADUAP70A1104008">Visueel onderzoek</intxref>
 en 
<intxref refid = "ADUAP70A1104009">Basisonderzoek van de motor</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Overmatige uitstoot van stikstofoxiden (NOx)
</ptxt>
</condition>
<ps>
<ptxt>
Verkeerd ontstekingstijdstip
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1806005">Onderzoek van het ontstekingstijdstip</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Loodverontreiniging van katalysator
</ptxt>
</ps>
<action>
<ptxt>
Controleer op ontbrekende vulhalsversmalling.
</ptxt>
</action>
<ps>
<ptxt>
Brandstofdruk buiten voorgeschreven bereik
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1704005">Controle van de brandstofdruk</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Gesloten regelcircuitsysteem (A/F-terugkoppelingscompensatie) defect (slechte prestatie van de ECT-sensor of MAF-sensor)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306012">Onderzoek van de ECT-sensor</intxref>
 of 
<intxref refid = "ADUAP70A1306026">Onderzoek van de MAF- en IAT-sensor</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defect elektrische-gasklephuissamenstel
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306004">Onderzoek elektrisch-gasklephuissamenstel in het voertuig</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte APP-sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306008">Onderzoek van de APP-sensor</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte verstuiver(s)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1704003">Controle van brandstofverstuivercircuit</intxref>
 of 
<intxref refid = "ADUAP70A1706009">Onderzoek van de brandstofverstuiver</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defecte ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1104070">Onderzoek van de ECM en de bijbehorende circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defect nokkenaspositieregelsysteem (VVT)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "ADUAP70A1306027">Onderzoek van de OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
