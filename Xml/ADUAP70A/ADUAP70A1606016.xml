<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A1606016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uitbouw en inbouw van de waterpomp
</title>
<servinfosub id = "ADUAP70A1606016001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Maak de negatieve (–) kabel bij de accu los.
</ptxt>
</s1>
<s1>
<ptxt>
Tap de koelvloeistof af. 
<intxreftitleoff1 refid = "ADUAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de waterpomp / dynamoaandrijfriem. 
<intxreftitleoff1 refid = "ADUAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de waterpomppoelie (2).
</ptxt>
</s1>
<s1>
<ptxt>
Verwijder de waterpomp (1) met de dynamobeugel (3).
</ptxt>
<figure>
<graphic graphicname = "I7V20A161014.swf" width = "88.000mm" height = "66.198mm" ver = "01" gw = "211" gh = "171"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ADUAP70A1606016002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A1606017">Onderzoek van de waterpomp</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Breng afdichtmiddel op het pasvlak van de waterpomp aan zoals op de afbeelding.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1F001" uid = "41">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Afdichtmiddel
</m-desc>
<m-number>
99000-31250
</m-number>
<m-name>
SUZUKI Bond No.1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I7V20A161015.swf" width = "88.000mm" height = "43.075mm" ver = "01" gw = "184" gh = "106"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.309in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.250in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.387in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
3 mm (0,12 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;b&#34;: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
2 mm (0,08 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Monteer het waterpompsamenstel (1) met de dynamosteun (3) op het cilinderblok en haal de bouten en de moeren met het voorgeschreven koppel aan.
</ptxt>
<attention3>
<ptxt>
Zie 
<intxref refid = "ADUAP70A1A06006">Uit- en inbouw van de dynamosteun</intxref>
 voor de montageprocedure van de dynamosteun (3).
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1F003">
<t-part>
Waterpompbout en -moer
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Monteer de waterpomppoelie (2) en haal de bouten met het voorgeschreven koppel aan.
</ptxt>
<torque>
<torqueitem id = "T1F004">
<t-part>
Bout van waterpomppoelie
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A161016.swf" width = "88.000mm" height = "66.198mm" ver = "02" gw = "211" gh = "171"/>
</figure>
</s1>
<s1>
<ptxt>
Monteer de waterpomp / dynamoaandrijfriem. 
<intxreftitleoff1 refid = "ADUAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sluit de negatieve kabel (–) op de accu aan.
</ptxt>
</s1>
<s1>
<ptxt>
Vul het koelsysteem met koelvloeistof bij. 
<intxreftitleoff1 refid = "ADUAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Controleer het koelsysteem op lekkage. 
<intxreftitleoff1 refid = "ADUAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
