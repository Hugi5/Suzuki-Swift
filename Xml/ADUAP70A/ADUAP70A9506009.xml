<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A9506009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de achteruitkijkspiegel
</title>
<servinfosub id = "ADUAP70A9506009001">
<title>
Uitbouw
</title>
<ptxt>
Verwijder de bout van de achteruitkijkspiegel (TORX<sup>&#174;</sup> T20) (1) en verschuif de spiegel (2) in de richting van de pijl.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950021.swf" width = "88.000mm" height = "49.005mm" ver = "01" gw = "227" gh = "122"/>
</figure>
</servinfosub>
<servinfosub id = "ADUAP70A9506009002">
<title>
Inbouw
</title>
<ptxt>
Voer de uitbouwprocedure in omgekeerde volgorde uit en neem daarbij het volgende punt in acht.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Haal de bout van de achteruitkijkspiegel met het voorgeschreven koppel aan.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9E001">
<t-part>
Bout van de achteruitkijkspiegel
</t-part>
<t-value1>
3,5
</t-value1>
<t-value2>
0,36
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
