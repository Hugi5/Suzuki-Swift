<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ADUAP70A8206026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Uit- en inbouw van de passagiersairbagdeactiveringsschakelaar
</title>
<servinfosub id = "ADUAP70A8206026001">
<title>
Uitbouw
</title>
<s1>
<ptxt>
Verwijder het handschoenenkastje. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Maak de stekkerverbinding (1) van de passagiersairbagdeactiveringsschakelaar los.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820078.swf" width = "88.000mm" height = "87.000mm" ver = "01" gw = "231" gh = "230"/>
</figure>
</s1>
<s1>
<ptxt>
Verwijder de passagiersairbagdeactiveringsschakelaar (1) terwijl de vergrendelingen (2) losgemaakt worden.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820079.swf" width = "88.000mm" height = "59.573mm" ver = "02" gw = "207" gh = "152"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ADUAP70A8206026002">
<title>
Inbouw
</title>
<ptxt>
<intxrefpoff refid = "ADUAP70A8206027">Onderzoek van de passagiersairbagdeactiveringsschakelaar</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Monteer de passagiersairbagdeactiveringsschakelaar (1) door zijn projectie (2) met de opening (3) van het instrumentenpaneel uit te lijnen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820080.swf" width = "88.000mm" height = "64.695mm" ver = "01" gw = "207" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Sluit de stekkerverbinding aan op de passagiersairbagdeactiveringsschakelaar.
</ptxt>
</s1>
<s1>
<ptxt>
Monteer het handschoenenkastje. 
<intxreftitleoff1 refid = "ADUAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
