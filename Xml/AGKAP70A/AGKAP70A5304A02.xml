<servinfo servinfosgmlid = "AGKAP70A5304A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ο συμπλέκτης κολλάει.
</title>
<diag type = "condition">
<condition>
<ptxt>
Ο συμπλέκτης κολλάει.
</ptxt>
</condition>
<ps>
<ptxt>
Αντικανονική ελεύθερη διαδρομή πεντάλ συμπλέκτη
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε το βραχίονα του πεντάλ του συμπλέκτη ή και την αντλία του συμπλέκτη.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Βραχίονας πεντάλ συμπλέκτη: 
<intxreftitleoff1 refid = "AGKAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Αντλία συμπλέκτη: 
<intxreftitleoff1 refid = "AGKAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Εξασθενισμένο ελατήριο δια&#248;ράγματος ή &#248;θαρμένο άκρο ελατηρίου
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το πλατό του συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Σκουριασμένο πολύσ&#248;ηνο άξονα εισόδου
</ptxt>
</ps>
<action>
<ptxt>
Λιπάνετε το πολύσ&#248;ηνο του άξονα εισόδου.
</ptxt>
</action>
<ps>
<ptxt>
Κατεστραμμένο ή &#248;θαρμένο πολύσ&#248;ηνο του άξονα εισόδου του κιβωτίου ταχυτήτων.
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τον άξονα εισόδου. 
<intxreftitleoff1 refid = "AGKAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Υπερβολικό τρεμούλιασμα του δίσκου του συμπλέκτη
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το δίσκο του συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Σπασμένα υλικά τριβής του συμπλέκτη ή  λαδωμένα
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το δίσκο του συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Διαρροή υγρών
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε το σύστημα του συμπλέκτη.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
