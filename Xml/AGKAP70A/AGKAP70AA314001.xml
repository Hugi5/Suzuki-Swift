<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70AA314001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Έλεγχος Συστήματος Ελέγχου Ακινητοποίησης Κινητήρα (Immobilizer)
</title>
<attention3>
<ptxt>
Πριν την εκτέλεση του ελέγχου, βεβαιωθείτε ότι έχετε διαβάσει το 
<intxref refid = "AGKAP70AA310002">Μέτρα Προ&#248;ύλαξης για το Σύστημα Immobilizer:λεξης</intxref>
.
</ptxt>
</attention3>
<diag type = "test" id = "AGKAP70AA314001001">
<testgroup id = "AGKAP70AA314001002">
<question>
Περιστρέ&#248;εται ο κινητήρας με την μίζα;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70A1904001">Διάγνωση Συμπτωμάτων Του Συστήματος Εκκίνησης</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA314001003">
<title>
Έλεγχος εκκίνησης του κινητήρα
</title>
<question>
Ξεκινά ο κινητήρας;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA314001004">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε για κωδικό βλάβης. 
<intxreftitleoff1 refid = "AGKAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ανιχνεύεται κάποιος κωδικός DTC;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Το σύστημα ελέγχου του immobilizer είναι σε καλή κατάσταση.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA314001005">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε για κωδικό βλάβης. 
<intxreftitleoff1 refid = "AGKAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ανιχνεύεται κάποιος κωδικός DTC;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA314001006">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε για DTC σχετιζόμενο με την επικοινωνία CAN.
</ptxt>
</test1>
<question>
Έχει ανιχνευτεί κάποιος DTC;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70A1104009">Βασική Επιθεώρηση του Κινητήρα</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
