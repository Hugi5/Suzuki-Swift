<servinfo servinfosgmlid = "AGKAP70A1704001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Έλεγχος συστήματος τρο&#248;οδοσίας καυσίμου
</title>
<diag type = "test" id = "AGKAP70A1704001001">
<testgroup id = "AGKAP70A1704001002">
<title>
Επιθεώρηση της αντλίας καυσίμου
</title>
<test1>
<ptxt>
Α&#248;αιρέστε την τάπα πλήρωσης καυσίμου και θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Επιβεβαιώστε ότι ο ήχος λειτουργίας της αντλίας καυσίμου ακούγεται από την τάπα πλήρωσης καυσίμου για περίπου 2 δευτερόλεπτα πριν σταματήσει.
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ελέγξτε το κύκλωμα της αντλίας καυσίμου. 
<intxreftitleoff1 refid = "AGKAP70A1704004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A1704001003">
<title>
Έλεγχος της πίεσης καυσίμου
</title>
<test1>
<ptxt>
Ελέγξτε την πίεση καυσίμου. 
<intxreftitleoff1 refid = "AGKAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Επισκευάστε το ελαττωματικό εξάρτημα.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A1704001004">
<title>
Δοκιμή ισορροπίας ισχύος
</title>
<test1>
<ptxt>
Ελέγξτε την ισορροπία ισχύος. 
<intxreftitleoff1 refid = "AGKAP70A1704002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Το σύστημα τρο&#248;οδοσίας καυσίμου βρίσκεται σε καλή κατάσταση.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A1704001005">
<title>
Έλεγχος του κυκλώματος του μπεκ ψεκασμού
</title>
<test1>
<ptxt>
Ελέγξτε το κύκλωμα του μπεκ ψεκασμού καυσίμου. 
<intxreftitleoff1 refid = "AGKAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Επισκευάστε το ελαττωματικό εξάρτημα.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A1704001006">
<title>
Έλεγχος του μπεκ ψεκασμού
</title>
<test1>
<ptxt>
Ελέγξτε το μπεκ ψεκασμού του καυσίμου. 
<intxreftitleoff1 refid = "AGKAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Αντικαταστήστε τον εγκέ&#248;αλο ECM και ελέγξτε ξανά τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Αντικαταστήστε το μπεκ ψεκασμού καυσίμου. 
<intxreftitleoff1 refid = "AGKAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
