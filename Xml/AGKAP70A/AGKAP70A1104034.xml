<item>
<ptxt>
Αισθητήρας CMP εισαγωγής ή/και το κύκλωμά του
</ptxt>
</item>
<item>
<ptxt>
Ρότορας σήματος
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
