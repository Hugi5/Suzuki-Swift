<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70AA314012" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1167
</title>
<servinfosub id = "AGKAP70AA314012001">
<title>
Κατάσταση Ανίχνευσης Κωδικού Βλάβης και  Περιοχή Προβλήματος
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.260in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.945in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Συνθήκη ανίχνευσης κωδικού
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Περιοχή Προβλήματος
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1167: Δεν ταιριάζουν οι Πληρο&#248;ορίες του Immobilizer
</emph>
</ptxt>
<ptxt>
Σ&#248;άλμα επαλήθευσης μεταξύ των εγκε&#248;άλων BCM και ECM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Ο κωδικός ID του εγκε&#248;άλου ECM δεν έχει καταχωρηθεί στον εγκέ&#248;αλο BCM.
</ptxt>
</item>
<item>
<ptxt>
Το κλειδί ανά&#248;λεξης δεν έχει καταχωρηθεί
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGKAP70AA314012002">
<title>
Διάγνωση Κωδικού DTC
</title>
<attention3>
<ptxt>
Εάν ο εγκέ&#248;αλος BCM είχε καταχωρηθεί σε κάποιο άλλο όχημα (μεταχειρισμένο εξάρτημα), δεν είναι δυνατή η καταχώρηση των κλειδιών ανά&#248;λεξης. Πάντα να τοποθετείτε νέο εγκέ&#248;αλο BCM όταν απαιτείται αντικατάσταση.
</ptxt>
</attention3>
<diag type = "test" id = "AGKAP70AA314012003">
<testgroup id = "AGKAP70AA314012004">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε για κωδικούς βλαβών στο ECM. 
<intxreftitleoff1 refid = "AGKAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ανιχνεύεται κάποιος κωδικός DTC;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.	
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA314012005">
<title>
Επανέλεγχος κωδικών DTC
</title>
<test1>
<ptxt>
Εκτελέστε 
<intxref refid = "AGKAP70AA316003">Καταχώρηση Εγκε&#248;άλου ECM:λεξης</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Επιβεβαιώστε ότι ο διακόπτης ανά&#248;λεξης βρίσκεται στη θέση &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ελέγξτε πάλι για Κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Εξακολουθεί να ανιχνεύεται ο Κωδικός DTC B1167;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Τέλος. (Ο εγκέ&#248;αλος ECM δεν καταχωρήθηκε)
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA314012006">
<title>
Ignition key registration - Καταχώρηση του κλειδιού ανά&#248;λεξης
</title>
<test1>
<ptxt>
Εκτελέστε την &#34;Καταχώρηση Κλειδιού Immobilizer&#34;. 
<intxreftitleoff1 refid = "AGKAP70AA316002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Επιβεβαιώστε ότι ο διακόπτης ανά&#248;λεξης βρίσκεται στη θέση &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ελέγξτε πάλι για Κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Εξακολουθεί να ανιχνεύεται ο Κωδικός DTC B1167;
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε τον εγκέ&#248;αλο ΒCM και ελέγξτε ξανά τον κωδικό DTC. Εάν εξακολουθεί να ανιχνεύεται ο κωδικός DTC B1167, αντικαταστήστε τον εγκέ&#248;αλο ECM και ελέγξτε ξανά τον κωδικό DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Εγκέ&#248;αλος BCM: 
<intxreftitleoff1 refid = "AGKAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AGKAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Τέλος. (Το κλειδί ανά&#248;λεξης δεν καταχωρήθηκε)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
