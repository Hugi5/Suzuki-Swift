<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70AA314006" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1610
</title>
<servinfosub id = "AGKAP70AA314006001">
<title>
Κατάσταση Ανίχνευσης Κωδικού Βλάβης και  Περιοχή Προβλήματος
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.281in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.924in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Συνθήκη ανίχνευσης κωδικού
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Περιοχή Προβλήματος
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1610: Μη καταχωρημένο ID Immobilizer 
</emph>
</ptxt>
<ptxt>
Ο κωδικός ID του Immobilizer δεν έχει καταχωρηθεί.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Ο κωδικός ID του εγκε&#248;άλου ECM δεν έχει καταχωρηθεί στον εγκέ&#248;αλο BCM.
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Κύκλωμα / &#248;ις επικοινωνίας CAN
</ptxt>
</item>
<item>
<ptxt>
Μονάδα ελέγχου συνδεδεμένη με τη γραμμή επικοινωνίας CAN
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGKAP70AA314006002">
<title>
Διάγνωση Κωδικού DTC
</title>
<diag type = "test" id = "AGKAP70AA314006003">
<testgroup id = "AGKAP70AA314006005">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε για κωδικούς βλαβών στο BCM. 
<intxreftitleoff1 refid = "AGKAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ανιχνεύεται ο κωδικός DTC B1173, B1175 ή B1176;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA314006004">
<title>
Καταχώρηση εγκε&#248;άλου ECM
</title>
<test1>
<ptxt>
Εκτελέστε 
<intxref refid = "AGKAP70AA316003">Καταχώρηση Εγκε&#248;άλου ECM:λεξης</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Ελέγξτε πάλι για Κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ο κωδικός DTC P1610 εξακολουθεί να ανιχνεύεται;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Τέλος. (Ο εγκέ&#248;αλος ECM δεν καταχωρήθηκε)
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA314006006">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε για DTC σχετιζόμενο με την επικοινωνία CAN.
</ptxt>
</test1>
<question>
Έχει ανιχνευτεί κάποιος DTC;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Αντικαταστήστε τον εγκέ&#248;αλο ECM και ελέγξτε ξανά τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
