<servinfosub id = "AGKAP70A4604023003">
<title>
Διάγνωση Κωδικού DTC
</title>
<diag type = "test" id = "AGKAP70A4604023004">
<testgroup id = "AGKAP70A4604023005">
<question>
Πραγματοποιήθηκε ο &#34;Έλεγχος του Συστήματος ESP<sup>&#174;</sup>&#34;;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70A4604001">Έλεγχος Συστήματος ESP&#174;</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604023006">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Εκτελέστε 
<intxref refid = "AGKAP70A4604005">Έλεγχος Κωδικού DTC</intxref>
.
</ptxt>
</test1>
<question>
Υπάρχουν άλλοι κωδικοί DTC εκτός των C1037, C1038 και C1057;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην ισχύουσα διάγνωση κωδικού βλάβης.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604023007">
<title>
Έλεγχος Κωδικού DTC στον BCM
</title>
<test1>
<ptxt>
Ελέγξτε τον Κωδικό DTC στον BCM. 
<intxreftitleoff1 refid = "AGKAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Έχει ανιχνευθεί κάποιος από τους κωδικούς DTC U0073, U0121 ή/και U0126;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην ισχύουσα διάγνωση κωδικού βλάβης.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604023008">
<title>
Έλεγχος ασ&#248;άλειας
</title>
<test1>
<ptxt>
Ελέγξτε την ασ&#248;άλεια &#34;ABS&#34;.
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Αντικαταστήστε την ασ&#248;άλεια και ελέγξτε για βραχυκύκλωμα με τη γείωση.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604023009">
<title>
Έλεγχος κυκλώματος τρο&#248;οδοσίας ρεύματος του αισθητήρα γωνίας στρο&#248;ής
</title>
<test1>
<ptxt>
Επιβεβαιώστε ότι ο διακόπτης ανά&#248;λεξης βρίσκεται στη θέση &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Αποσυνδέστε το &#248;ις του αισθητήρα γωνίας στρο&#248;ής.
</ptxt>
</test1>
<test1>
<ptxt>
Αποσυνδέστε το &#248;ις &#34;G33&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ελέγξτε για σωστή σύνδεση του αισθητήρα γωνίας στρο&#248;ής.
</ptxt>
</test1>
<test1>
<ptxt>
Εάν η σύνδεση είναι εντάξει, θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Μετρήστε την τάση μεταξύ του κυκλώματος &#34;A1&#34; και της γείωσης.
</ptxt>
</test1>
<question>
Είναι η τάση 10 – 14 V;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε το κύκλωμα &#34;Α1&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604023010">
<title>
Έλεγχος του κυκλώματος γείωσης του αισθητήρα γωνίας στρο&#248;ής
</title>
<test1>
<ptxt>
Θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Μετρήστε την αντίσταση μεταξύ του κυκλώματος &#34;A2&#34; και της γείωσης.
</ptxt>
</test1>
<question>
Είναι μικρότερη από 2 Ω;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε το κύκλωμα &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604023011">
<title>
Έλεγχος αισθητήρα γωνίας στρο&#248;ής
</title>
<test1>
<ptxt>
Συνδέστε το &#248;ις του αισθητήρα γωνίας στρο&#248;ής.
</ptxt>
</test1>
<test1>
<ptxt>
Ελέγξτε τον αισθητήρα γωνίας στρο&#248;ής. 
<intxreftitleoff1 refid = "AGKAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα υδραυλικής μονάδας / μονάδας ελέγχου ESP<sup>&#174;</sup> και ελέγξτε ξανά τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Αντικαταστήστε τον αισθητήρα γωνίας στρο&#248;ής και ελέγξτε τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
