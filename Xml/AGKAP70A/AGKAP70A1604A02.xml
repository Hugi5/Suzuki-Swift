<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A1604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ο κινητήρας υπερθερμαίνεται (Ο ανεμιστήρας ψύξης δεν λειτουργεί)
</title>
<diag type = "condition">
<condition>
<ptxt>
Ο κινητήρας υπερθερμαίνεται (Ο ανεμιστήρας ψύξης δεν λειτουργεί)
</ptxt>
</condition>
<ps>
<ptxt>
Καμένη ασ&#248;άλεια
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε την ασ&#248;άλεια.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό ρελέ ανεμιστήρα ψύξης του ψυγείου.
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το ρελέ του ανεμιστήρα του ψυγείου του κινητήρα. 
<intxreftitleoff1 refid = "AGKAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός αισθητήρας ECT
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον αισθητήρα ECT. 
<intxreftitleoff1 refid = "AGKAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό μοτέρ ανεμιστήρα ψύξης ψυγείου
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το μοτέρ του ανεμιστήρα ψύξης του ψυγείου. 
<intxreftitleoff1 refid = "AGKAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική καλωδίωση ή γείωση
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε την καλωδίωση.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός ECM
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το ECM και το κύκλωμά του. 
<intxreftitleoff1 refid = "AGKAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
