<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A1604A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ο κινητήρας υπερθερμαίνεται (Ο ανεμιστήρας ψύξης λειτουργεί)
</title>
<diag type = "condition">
<condition>
<ptxt>
Ο κινητήρας υπερθερμαίνεται (Ο ανεμιστήρας ψύξης λειτουργεί)
</ptxt>
</condition>
<ps>
<ptxt>
Χαλαρός ή κομμένος ιμάντας της αντλίας νερού
</ptxt>
</ps>
<action>
<ptxt>
Ρυθμίστε ή αντικαταστήστε τον ιμάντα της αντλίας νερού. 
<intxreftitleoff1 refid = "AGKAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Δεν υπάρχει αρκετή ποσότητα ψυκτικού υγρού
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε την στάθμη του ψυκτικού υγρού και συμπληρώστε εάν είναι αναγκαίο. 
<intxreftitleoff1 refid = "AGKAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός θερμοστάτης
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα του θερμοστάτη. 
<intxreftitleoff1 refid = "AGKAP70A1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική αντλία νερού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε την αντλία νερού. 
<intxreftitleoff1 refid = "AGKAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ακάθαρτες ή στραβωμένες ψήκτρες του ψυγείου
</ptxt>
</ps>
<action>
<ptxt>
Καθαρίστε ή επισκευάστε. 
<intxreftitleoff1 refid = "AGKAP70A1606014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Διαρροή ψυκτικού υγρού στο σύστημα ψύξης
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το σύστημα ψύξης για τυχόν διαρροή. 
<intxreftitleoff1 refid = "AGKAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Βουλωμένο ψυγείο
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το ψυγείο. 
<intxreftitleoff1 refid = "AGKAP70A1606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική τάπα του ψυγείου
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε την τάπα του ψυγείου. 
<intxreftitleoff1 refid = "AGKAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φρένα που κολλούν
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τα &#248;ρένα. 
<intxreftitleoff1 refid = "AGKAP70A4104001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ο συμπλέκτης πατινάρει
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A5304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ανεπαρκώς &#248;ορτισμένη μπαταρία
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε την μπαταρία 
<intxreftitleoff1 refid = "AGKAP70A1A04001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαμηλή παραγωγή ρεύματος από τη γεννήτρια
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε την γεννήτρια. 
<intxreftitleoff1 refid = "AGKAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός αισθητήρας ECT
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον αισθητήρα ECT. 
<intxreftitleoff1 refid = "AGKAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό μοτέρ ανεμιστήρα ψύξης ψυγείου
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το μοτέρ του ανεμιστήρα ψύξης του ψυγείου. 
<intxreftitleoff1 refid = "AGKAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός ECM
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το ECM και το κύκλωμά του. 
<intxreftitleoff1 refid = "AGKAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό ρελέ ανεμιστήρα ψύξης του ψυγείου.
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το ρελέ του ανεμιστήρα του ψυγείου του κινητήρα. 
<intxreftitleoff1 refid = "AGKAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική καλωδίωση ή γείωση
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε την καλωδίωση.
</ptxt>
</action>
<ps>
<ptxt>
Πάρα πολλές προαιρετικές ηλεκτρικές συσκευές
</ptxt>
</ps>
<action>
<ptxt>
Α&#248;αιρέστε τις ηλεκτρικές συσκευές.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
