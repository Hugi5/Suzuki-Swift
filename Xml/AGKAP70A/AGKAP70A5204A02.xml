<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Δύσκολη αλλαγή σχέσεων
</title>
<diag type = "condition">
<condition>
<ptxt>
Δύσκολη αλλαγή σχέσεων
</ptxt>
</condition>
<ps>
<ptxt>
Ανεπαρκής λίπανση
</ptxt>
</ps>
<action>
<ptxt>
Συμπληρώστε βαλβολίνη μηχανικού κιβωτίου ταχυτήτων.
</ptxt>
</action>
<ps>
<ptxt>
Αντικανονική ελεύθερη διαδρομή πεντάλ συμπλέκτη
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε το βραχίονα του πεντάλ του συμπλέκτη ή την αντλία του συμπλέκτη.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Βραχίονας πεντάλ συμπλέκτη: 
<intxreftitleoff1 refid = "AGKAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Αντλία συμπλέκτη: 
<intxreftitleoff1 refid = "AGKAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Παραμορ&#248;ωμένος ή σπασμένος δίσκος συμπλέκτη
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το δίσκο του συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Κατεστραμμένη πλάκα πίεσης συμπλέκτη
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το πλατό του συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένο δακτυλίδι συγχρονιζέ
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε το δακτυλίδι συγχρονιζέ.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Δακτυλίδι συγχρονιζέ χαμηλής ταχύτητας και δακτυλίδι συγχρονιζέ 2ας ταχύτητας: 
<intxreftitleoff1 refid = "AGKAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Δακτυλίδι συγχρονιζέ υψηλής ταχύτητας: 
<intxreftitleoff1 refid = "AGKAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Δακτυλίδι συγχρονιζέ 5ης ταχύτητας: 
<intxreftitleoff1 refid = "AGKAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Φθαρμένα λοξά δόντια στο δακτυλίδι κόμπλερ ή το γρανάζι
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε την πλήμνη του εξωτερικού δακτυλιδιού κόμπλερ &#38; και το γρανάζι.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Γρανάζι 1ης και γρανάζι 2ας ενδιάμεσου άξονα: 
<intxreftitleoff1 refid = "AGKAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Γρανάζι 3ης και γρανάζι 4ης άξονα εισόδου: 
<intxreftitleoff1 refid = "AGKAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Γρανάζι 5ης άξονα εισόδου: 
<intxreftitleoff1 refid = "AGKAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Πλήμνη εξωτερικού δακτυλιδιού κόμπλερ χαμηλής ταχύτητας &#38;: 
<intxreftitleoff1 refid = "AGKAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Πλήμνη εξωτερικού δακτυλιδιού κόμπλερ υψηλής ταχύτητας &#38;: 
<intxreftitleoff1 refid = "AGKAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Πλήμνη εξωτερικού δακτυλιδιού κόμπλερ 5ης ταχύτητας &#38;: 
<intxreftitleoff1 refid = "AGKAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Φθαρμένο δαχτυλίδι συνδέσμου άξονα ελέγχου αλλαγής ταχυτήτων
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το δαχτυλίδι του συνδέσμου του άξονα ελέγχου αλλαγής ταχυτήτων. 
<intxreftitleoff1 refid = "AGKAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Παραμορ&#248;ωμένος άξονας αλλαγής σχέσεων
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε τη &#248;ουρκέτα αλλαγής του άξονα αλλαγής.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Άξονας αλλαγής σχέσεων χαμηλής ταχύτητας: 
<intxreftitleoff1 refid = "AGKAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Άξονας αλλαγής σχέσεων υψηλής ταχύτητας: 
<intxreftitleoff1 refid = "AGKAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Φουρκέτα 5ης ταχύτητας: 
<intxreftitleoff1 refid = "AGKAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Σπασμένες ντίζες αλλαγής σχέσεων / ελέγχου επιλογής
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τη ντίζα αλλαγής σχέσεων και επιλογής. 
<intxreftitleoff1 refid = "AGKAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
