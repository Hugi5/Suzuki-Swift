<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Πατινάρισμα
</title>
<diag type = "condition">
<condition>
<ptxt>
Πατινάρισμα
</ptxt>
</condition>
<ps>
<ptxt>
Αντικανονική ελεύθερη διαδρομή πεντάλ συμπλέκτη
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε το βραχίονα του πεντάλ του συμπλέκτη ή και την αντλία του συμπλέκτη.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Βραχίονας πεντάλ συμπλέκτη: 
<intxreftitleoff1 refid = "AGKAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Αντλία συμπλέκτη: 
<intxreftitleoff1 refid = "AGKAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Φθαρμένο ή λαδωμένο υλικό τριβής του δίσκου του συμπλέκτη
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το δίσκο του συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Στρεβλωμένος δίσκος, πλάκα πίεσης ή επι&#248;άνεια του σ&#248;ονδύλου
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε το δίσκο του συμπλέκτη, το πλατό συμπλέκτη ή το σ&#248;όνδυλο.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Δίσκος και πλατό συμπλέκτη: 
<intxreftitleoff1 refid = "AGKAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Βολάν: 
<intxreftitleoff1 refid = "AGKAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Εξασθενισμένο διά&#248;ραγμα
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το πλατό του συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Το έμβολο της αντλίας ή το λαστιχάκι στεγανοποίησης δεν επιστρέ&#248;ει
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε την αντλία του συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
