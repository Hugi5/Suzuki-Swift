<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A7214A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Δεν βγαίνει κρύος αέρας ή ανεπαρκής ψύξη (Κανονική λειτουργία μαγνητικού συμπλέκτη)
</title>
<diag type = "condition">
<condition>
<ptxt>
Δεν βγαίνει κρύος αέρας ή ανεπαρκής ψύξη (Κανονική λειτουργία μαγνητικού συμπλέκτη)
</ptxt>
</condition>
<ps>
<ptxt>
Ανεπαρκής ή υπερβολική πλήρωση ψυκτικού
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε την ποσότητα ψυκτικού και το σύστημα για διαρροές.
</ptxt>
</action>
<ps>
<ptxt>
Φραγμένος συμπυκνωτής
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον συμπυκνωτή. 
<intxreftitleoff1 refid = "AGKAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φραγμένος ή παγωμένος εξατμιστής κλιματισμού
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Ελέγξτε τον εξατμιστή A/C και τον αισθητήρα θερμοκρασίας εξατμιστή.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Εξατμιστής A/C: 
<intxreftitleoff1 refid = "AGKAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Αισθητήρας θερμοκρασίας εξατμιστή: 
<intxreftitleoff1 refid = "AGKAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Ελαττωματικός αισθητήρας θερμοκρασίας εξατμιστή
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον αισθητήρα θερμοκρασίας εξατμιστή. 
<intxreftitleoff1 refid = "AGKAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική βαλβίδα εκτόνωσης
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε την εκτονωτική βαλβίδα. 
<intxreftitleoff1 refid = "AGKAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρός ή σπασμένος ιμάντας κίνησης του συμπιεστή
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον ιμάντα κίνησης του συμπιεστή. 
<intxreftitleoff1 refid = "AGKAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ολισθαίνων μαγνητικός συμπλέκτης
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το μαγνητικό συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός συμπιεστής
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το συμπιεστή.
</ptxt>
</action>
<ps>
<ptxt>
Αέρας στο σύστημα A/C
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τον συμπυκνωτή και στη συνέχεια εκτελέστε εκκένωση και πλήρωση ψυκτικού. 
<intxreftitleoff1 refid = "AGKAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Διαρροή αέρα από τη μονάδα HVAC ή τον αεραγωγό
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε τη μονάδα HVAC ή τον αεραγωγό.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός θερμαντήρας και σύστημα εξαερισμού
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τη μονάδα HVAC.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό μοτέρ ανεμιστήρα
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το μοτέρ του ανεμιστήρα. 
<intxreftitleoff1 refid = "AGKAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Υπερβολικό λάδι συμπιεστή στο σύστημα A/C
</ptxt>
</ps>
<action>
<ptxt>
Α&#248;αιρέστε την υπερβολική ποσότητα λαδιού συμπιεστή από το κύκλωμα του συστήματος A/C και το συμπιεστή.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
