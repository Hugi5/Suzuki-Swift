<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A6104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ασά&#248;εια ή κακή ευστάθεια του τιμονιού
</title>
<diag type = "condition">
<condition>
<ptxt>
Ασά&#248;εια ή κακή ευστάθεια του τιμονιού
</ptxt>
</condition>
<ps>
<ptxt>
Ανόμοια ή άνιση πίεση ελαστικών
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε ή ρυθμίστε την πίεση ελαστικού. 
<intxreftitleoff1 refid = "AGKAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρώστε τον σύνδεσμο βραχίονα ανάρτησης και το ακρόμπαρο
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Αντικαταστήστε το μπροστινό κάτω ψαλίδι της ανάρτησης ή το ακρόμπαρο.
</ptxt>
<ptxt>
Βραχίονας ανάρτησης: 
<intxreftitleoff1 refid = "AGKAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ακρόμπαρο: 
<intxreftitleoff1 refid = "AGKAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Ελαττωματικό συγκρότημα ή μπροστινή βάση γονάτου
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα μπροστινού γονάτου ή επισκευάστε την βάση. 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρή αντιστρεπτική ράβδος
</ptxt>
</ps>
<action>
<ptxt>
Συσ&#248;ίξτε ή αντικαταστήστε την αντιστρεπτική ράβδο ή το σινεμπλόκ. 
<intxreftitleoff1 refid = "AGKAP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Σπασμένο ή πεσμένο ελικοειδές ελατήριο
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το ελικοειδές ελατήριο. 
<intxreftitleoff1 refid = "AGKAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό συγκρότημα μπροστινού γονάτου (αμορτισέρ)
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα μπροστινού γονάτου (αμορτισέρ) 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ακατάλληλη επα&#248;ή δοντιού μεταξύ της κρεμαγιέρας
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ελέγξτε τη ροπή περιστρο&#248;ής του άξονα της κρεμαγιέρας. 
<intxreftitleoff1 refid = "AGKAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Εάν είναι ελαττωματική, αντικαταστήστε το συγκρότημα της θήκης του γραναζιού διεύθυνσης. 
<intxreftitleoff1 refid = "AGKAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Λανθασμένη ευθυγράμμιση μπροστινών τροχών
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και ρυθμίστε την ευθυγράμμιση των μπροστινών τροχών. 
<intxreftitleoff1 refid = "AGKAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό το συγκρότημα του κελύ&#248;ους της κρεμαγιέρας
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα του κελύ&#248;ους της κρεμαγιέρας. 
<intxreftitleoff1 refid = "AGKAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
