<servinfosub id = "AGKAP70A4604017003">
<title>
Διάγνωση Κωδικού DTC
</title>
<diag type = "test" id = "AGKAP70A4604017004">
<testgroup id = "AGKAP70A4604017005">
<question>
Πραγματοποιήθηκε ο &#34;Έλεγχος του Συστήματος ESP<sup>&#174;</sup>&#34;;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70A4604001">Έλεγχος Συστήματος ESP&#174;</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604017006">
<title>
Έλεγχος κωδικού DTC για ESP&#174;
</title>
<test1>
<ptxt>
Εκτελέστε 
<intxref refid = "AGKAP70A4604005">Έλεγχος Κωδικού DTC</intxref>
.
</ptxt>
</test1>
<question>
Έχει ανιχνευτεί ο Κωδικός DTC U0073 ή και U0100;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην ισχύουσα διάγνωση κωδικού βλάβης.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604017007">
<title>
Έλεγχος διακόπτη &#248;ώτων στοπ και κυκλώματος
</title>
<test1>
<ptxt>
Ελέγξτε το διακόπτη &#248;ώτων στοπ και τα κυκλώματά του σύμ&#248;ωνα με το Βήμα 2 έως 4 στο 
<intxref refid = "AGKAP70A1104040">DTC P0504</intxref>
.
</ptxt>
</test1>
<question>
Είναι τα αποτελέσματα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα υδραυλικής μονάδας / μονάδας ελέγχου ESP<sup>&#174;</sup> και ελέγξτε ξανά τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε.
</ptxt>
</action>
</testgroup>
</diag>
