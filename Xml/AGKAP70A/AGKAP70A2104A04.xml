<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Κοσκίνισμα, τράνταγμα ή κραδασμός
</title>
<diag type = "condition">
<condition>
<ptxt>
Κοσκίνισμα, τράνταγμα ή κραδασμός
</ptxt>
</condition>
<ps>
<ptxt>
Κακή ζυγοστάθμιση τροχού
</ptxt>
</ps>
<action>
<ptxt>
Ζυγοσταθμίστε τις ζάντες ή αντικαταστήστε τα ελαστικά ή/και τις ζάντες.
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρά ρουλεμάν τροχού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ρουλεμάν του τροχού. 
<intxreftitleoff1 refid = "AGKAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένα ακρόμπαρα
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ακρόμπαρα. 
<intxreftitleoff1 refid = "AGKAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένοι σύνδεσμοι (μπαλάκια) του κάτω βραχίονα (ψαλιδιού) της ανάρτησης
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το βραχίονα της ανάρτησης. 
<intxreftitleoff1 refid = "AGKAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Υπερβολική παραμόρ&#248;ωση της ζάντας ή του ελαστικού
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε την ζάντα ή και το ελαστικό.
</ptxt>
</action>
<ps>
<ptxt>
Υπάρχει &#248;ουσκάλα ή εξόγκωμα στο ελαστικό
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ελαστικά. 
<intxreftitleoff1 refid = "AGKAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Υπερβολική ακτινική παραμόρ&#248;ωση του ελαστικού / συγκροτήματος του τροχού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το ελαστικό ή την ζάντα.
</ptxt>
</action>
<ps>
<ptxt>
Λανθασμένη ευθυγράμμιση τροχών
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και ρυθμίστε την ευθυγράμμιση των τροχών. 
<intxreftitleoff1 refid = "AGKAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρά ή &#248;θαρμένα εξαρτήματα σύνδεσης του συστήματος διεύθυνσης
</ptxt>
</ps>
<action>
<ptxt>
Επιθεωρήστε το σύστημα διεύθυνσης. 
<intxreftitleoff1 refid = "AGKAP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ξεβιδωμένες βίδες του κελύ&#248;ους της κρεμαγιέρας
</ptxt>
</ps>
<action>
<ptxt>
Σ&#248;ίξτε τις βίδες του κελύ&#248;ους της κρεμαγιέρας 
<intxreftitleoff1 refid = "AGKAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
