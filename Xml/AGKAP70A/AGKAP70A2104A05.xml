<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A2104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Αντικανονικός θόρυβος, από το μπροστινό μέρος
</title>
<diag type = "condition">
<condition>
<ptxt>
Αντικανονικός θόρυβος, από το μπροστινό μέρος
</ptxt>
</condition>
<ps>
<ptxt>
Ζημιά στο συγκρότημα μπροστινού γονάτου (αμορτισέρ) ή στις βάσεις
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε το συγκρότημα μπροστινού γονάτου (αμορτισέρ) ή τις βάσεις. 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένα, κολλημένα ή χαλαρά ακρόμπαρα
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ακρόμπαρα. 
<intxreftitleoff1 refid = "AGKAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένοι ή κατεστραμμένοι σύνδεσμοι βραχίονα ανάρτησης
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το βραχίονα της ανάρτησης. 
<intxreftitleoff1 refid = "AGKAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένοι, κολλημένοι ή χαλαροί σ&#248;αιρικοί σύνδεσμοι ακρόμπαρου
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα του κελύ&#248;ους της κρεμαγιέρας. 
<intxreftitleoff1 refid = "AGKAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένοι, κολλημένοι ή χαλαροί σύνδεσμοι ημιαξονίου
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τους συνδέσμους ημιαξονίου. 
<intxreftitleoff1 refid = "AGKAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένα μπροστινά σινεμπλόκ ψαλιδιού ανάρτησης
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα μπροστινά σινεμπλόκ του ψαλιδιού ανάρτησης. 
<intxreftitleoff1 refid = "AGKAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένα πίσω σινεμπλόκ ψαλιδιού ανάρτησης
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το βραχίονα της ανάρτησης. 
<intxreftitleoff1 refid = "AGKAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρή αντιστρεπτική ράβδος
</ptxt>
</ps>
<action>
<ptxt>
Σ&#248;ίξτε τις βίδες ή τα παξιμάδια ή/και αντικαταστήστε τα σινεμπλόκ. 
<intxreftitleoff1 refid = "AGKAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρώστε τα παξιμάδια των τροχών
</ptxt>
</ps>
<action>
<ptxt>
Σ&#248;ίξτε τα παξιμάδια των τροχών. 
<intxreftitleoff1 refid = "AGKAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρές βίδες ή παξιμάδια της ανάρτησης
</ptxt>
</ps>
<action>
<ptxt>
Σ&#248;ίξτε τις βίδες ή τα παξιμάδια της ανάρτησης. 
<intxreftitleoff1 refid = "AGKAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Σπασμένα ή κατεστραμμένα ρουλεμάν τροχού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ρουλεμάν του τροχού. 
<intxreftitleoff1 refid = "AGKAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Σπασμένα ελικοειδή ελατήρια
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Αντικαταστήστε τα ελικοειδή ελατήρια.
</ptxt>
<ptxt>
Εμπρός: 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Πίσω: 
<intxreftitleoff1 refid = "AGKAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Με κακή λίπανση ή &#248;θαρμένα ρουλεμάν του γονάτου
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ρουλεμάν του γονάτου. 
<intxreftitleoff1 refid = "AGKAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Δυσλειτουργία υποβοηθούμενου συστήματος διεύθυνσης
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και διορθώστε την δυσλειτουργία. 
<intxreftitleoff1 refid = "AGKAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
