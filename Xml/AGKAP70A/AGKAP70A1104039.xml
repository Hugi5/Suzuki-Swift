</item>
<item>
<ptxt>
Αισθητήρας ταχύτητας τροχού
</ptxt>
</item>
<item>
<ptxt>
Μονάδα ελέγχου ESP<sup>&#174;</sup>
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
