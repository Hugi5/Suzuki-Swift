<title>
DTC B1580 / B1902
</title>
<servinfosub id = "AGKAP70A7224031001">
<title>
Κατάσταση Ανίχνευσης Κωδικού Βλάβης και  Περιοχή Προβλήματος
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.922in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.288in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Συνθήκη ανίχνευσης κωδικού
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Περιοχή Προβλήματος
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1580: Σ&#248;άλμα EEPROM 
</emph>
</ptxt>
<ptxt>
Παρουσιάστηκε σ&#248;άλμα EEPROM στη μονάδα ελέγχου HVAC.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Εγκέ&#248;αλος HVAC
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1902: Σ&#248;άλμα Προγραμματισμού του Εγκε&#248;άλου
</emph>
</ptxt>
<ptxt>
Παρουσιάστηκε σ&#248;άλμα EEPROM στο πρόγραμμα στη μονάδα ελέγχου HVAC.
</ptxt>
</entry>
</row>
