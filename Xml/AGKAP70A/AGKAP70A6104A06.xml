<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A6104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Κραδασμοί στο τιμόνι κατά την πέδηση
</title>
<diag type = "condition">
<condition>
<ptxt>
Κραδασμοί στο τιμόνι κατά την πέδηση
</ptxt>
</condition>
<ps>
<ptxt>
Φθαρμένο (-α) ρουλεμάν του (των) τροχού (-ων).
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το (τα) ρουλεμάν του (των) τροχού (-ων). 
<intxreftitleoff1 refid = "AGKAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Σπασμένο ή πεσμένο ελικοειδές ελατήριο
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το ελικοειδές ελατήριο. 
<intxreftitleoff1 refid = "AGKAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό συγκρότημα μπροστινού γονάτου (αμορτισέρ)
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα μπροστινού γονάτου (αμορτισέρ) 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Άνιση πίεση ελαστικών
</ptxt>
</ps>
<action>
<ptxt>
Ρυθμίστε την πίεση των ελαστικών
</ptxt>
</action>
<ps>
<ptxt>
Λανθασμένη ευθυγράμμιση μπροστινών τροχών
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και ρυθμίστε την ευθυγράμμιση των μπροστινών τροχών. 
<intxreftitleoff1 refid = "AGKAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Τα &#248;ρένα δεν λειτουργούν ισοδύναμα
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και επισκευάστε το σύστημα πέδησης. 
<intxreftitleoff1 refid = "AGKAP70A4101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Το μπροστινό δισκό&#248;ρενο έχει λερωθεί με υγρό &#248;ρένων
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε τον μπροστινό δίσκο &#248;ρένου. 
<intxreftitleoff1 refid = "AGKAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Στρεβλωμένος δίσκος &#248;ρένου
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το μπροστινό δισκό&#248;ρενο. 
<intxreftitleoff1 refid = "AGKAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Άσχημα &#248;θαρμένα τακάκια
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα τακάκια μπροστινών &#248;ρένων. 
<intxreftitleoff1 refid = "AGKAP70A4206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
