<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A5204A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Θόρυβος
</title>
<diag type = "condition">
<condition>
<ptxt>
Θόρυβος
</ptxt>
</condition>
<ps>
<ptxt>
Ακατάλληλο ή ανεπαρκές λιπαντικό
</ptxt>
</ps>
<action>
<ptxt>
Συμπληρώστε βαλβολίνη μηχανικού κιβωτίου ταχυτήτων.
</ptxt>
</action>
<ps>
<ptxt>
Κατεστραμμένο (-α) ή &#248;θαρμένο (-α) ρουλεμάν
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε το ρουλεμάν.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Αριστερό ρουλεμάν ενδιάμεσου άξονα: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Εσωτερικός δακτύλιος: 
<intxreftitleoff1 refid = "AGKAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Εξωτερικός δακτύλιος: 
<intxreftitleoff1 refid = "AGKAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Δεξιό ρουλεμάν ενδιάμεσου άξονα: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Εσωτερικός δακτύλιος: 
<intxreftitleoff1 refid = "AGKAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Εξωτερικός δακτύλιος: 
<intxreftitleoff1 refid = "AGKAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Αριστερό και δεξιό ρουλεμάν άξονα εισόδου: 
<intxreftitleoff1 refid = "AGKAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Πλευρικό ρουλεμάν δια&#248;ορικού: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Εσωτερικός δακτύλιος: 
<intxreftitleoff1 refid = "AGKAP70A5206025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Εξωτερικό δακτυλίδι δεξιάς πλευράς: 
<intxreftitleoff1 refid = "AGKAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Εξωτερικό δακτυλίδι αριστερής πλευράς: 
<intxreftitleoff1 refid = "AGKAP70A5206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Βελονοειδές ρουλεμάν: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Γρανάζι 1ης και γρανάζι 2ας ενδιάμεσου άξονα: 
<intxreftitleoff1 refid = "AGKAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Γρανάζι 3ης και γρανάζι 4ης άξονα εισόδου: 
<intxreftitleoff1 refid = "AGKAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Γρανάζι 5ης: 
<intxreftitleoff1 refid = "AGKAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
</list1>
</action>
<ps>
<ptxt>
Κατεστραμμένα ή &#248;θαρμένα γρανάζι (α)
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε το γρανάζι.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Γρανάζι 1ης, γρανάζι 2ας, γρανάζι 3ης και γρανάζι 4ης ενδιάμεσου άξονα: 
<intxreftitleoff1 refid = "AGKAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Γρανάζι 1ης, γρανάζι 2ας, γρανάζι 3ης και γρανάζι 4ης άξονα εισαγωγής: 
<intxreftitleoff1 refid = "AGKAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Γρανάζι 5ης του άξονα εισόδου και γρανάζι 5ης ενδιάμεσου άξονα: 
<intxreftitleoff1 refid = "AGKAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Κατεστραμμένα ή &#248;θαρμένα εξαρτήματα συγχρονισμού
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Αντικαταστήστε τα εξαρτήματα του συγχρονιζέ.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Εξαρτήματα συγχρονιζέ χαμηλής ταχύτητας: 
<intxreftitleoff1 refid = "AGKAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Εξαρτήματα συγχρονιζέ υψηλής ταχύτητας: 
<intxreftitleoff1 refid = "AGKAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Εξαρτήματα συγχρονιζέ 5ης ταχύτητας: 
<intxreftitleoff1 refid = "AGKAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
