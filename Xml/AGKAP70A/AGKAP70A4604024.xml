<servinfo servinfosgmlid = "AGKAP70A4604024" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1038
</title>
<servinfosub id = "AGKAP70A4604024001">
<title>
Κατάσταση Ανίχνευσης Κωδικού Βλάβης και  Περιοχή Προβλήματος
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.259in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.896in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Συνθήκη ανίχνευσης κωδικού
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Περιοχή Προβλήματος
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1038: Ο Αισθητήρας Γωνίας Στρο&#248;ής Ανιχνεύει Βλάβη Μετρητή Κύλισης
</emph>
</ptxt>
<ptxt>
Ο αισθητήρας γωνίας στρο&#248;ής ανιχνεύει αντικανονικά δεδομένα CAN από τη μονάδα ελέγχου ESP<sup>&#174;</sup>.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Κύκλωμα επικοινωνίας CAN
</ptxt>
</item>
<item>
<ptxt>
Αισθητήρας γωνίας στρο&#248;ής
</ptxt>
</item>
<item>
<ptxt>
Μονάδα ελέγχου ESP<sup>&#174;</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGKAP70A4604024002">
<title>
Διάγνωση Κωδικού DTC
</title>
<diag type = "test" id = "AGKAP70A4604024003">
<testgroup id = "AGKAP70A4604024004">
<question>
Πραγματοποιήθηκε ο &#34;Έλεγχος του Συστήματος ESP<sup>&#174;</sup>&#34;;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70A4604001">Έλεγχος Συστήματος ESP&#174;</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604024005">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Εκτελέστε 
<intxref refid = "AGKAP70A4604005">Έλεγχος Κωδικού DTC</intxref>
.
</ptxt>
</test1>
<question>
Ανιχνεύθηκαν άλλοι κωδικοί DTC εκτός από τον C1038;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην ισχύουσα διάγνωση κωδικού βλάβης.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604024006">
<title>
Έλεγχος αισθητήρα γωνίας στρο&#248;ής
</title>
<test1>
<ptxt>
Επιβεβαιώστε ότι ο διακόπτης ανά&#248;λεξης βρίσκεται στη θέση &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Αντικαταστήστε τον αισθητήρα γωνίας στρο&#248;ής. 
<intxreftitleoff1 refid = "AGKAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ελέγξτε για κωδικό βλάβης.
</ptxt>
</test1>
<question>
Ανιχνεύεται ο Κωδικός DTC C1038;
</question>
<result type = "yes"/>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα υδραυλικής μονάδας / μονάδας ελέγχου ESP<sup>&#174;</sup> και ελέγξτε ξανά τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Τέλος.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
