</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός διακόπτης ηλιορο&#248;ής
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το διακόπτη της ηλιορο&#248;ής 
<intxreftitleoff1 refid = "AGKAP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική καλωδίωση ή γείωση
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το κύκλωμα. 
<intxreftitleoff1 refid = "AGKAP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AGKAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
