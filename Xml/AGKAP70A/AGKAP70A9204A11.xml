<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A9204A11" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Τα &#248;λας / αλάρμ δεν αναβοσβήνουν
</title>
<diag type = "condition">
<condition>
<ptxt>
Τα &#248;λας / αλάρμ δεν αναβοσβήνουν
</ptxt>
</condition>
<ps>
<ptxt>
Ελαττωματικός εγκέ&#248;αλος BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ανατρέξτε στο &#34;Επιθεώρηση του εγκε&#248;άλου BCM και των Κυκλωμάτων του&#34; στην ενότητα 10B.
</ptxt>
<ptxt>
Μοντέλο με διακόπτη ανά&#248;λεξης: 
<intxreftitleoff1 refid = "AGKAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Μοντέλο με σύστημα εκκίνησης χωρίς κλειδί: 
<intxreftitleoff1 refid = "AGKAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Ελαττωματικό κύκλωμα συστήματος (συμπεριλαμβανομένων των ρελέ και των ασ&#248;αλειών)
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε το κύκλωμα.
</ptxt>
</action>
<ps>
<ptxt>
Καμένοι λαμπτήρες
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τους λαμπτήρες.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός διακόπτης &#248;ωτισμού και &#248;λας
</ptxt>
</ps>
<action>
<ptxt>
Ανατρέξτε στο 
<intxref refid = "AGKAP70A9206015">Επιθεώρηση &#248;ωτισμού και διακόπτη &#248;λας</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός διακόπτης αλάρμ
</ptxt>
</ps>
<action>
<ptxt>
Ανατρέξτε στο 
<intxref refid = "AGKAP70A9206017">Επιθεώρηση Διακόπτη Αλάρμ</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
