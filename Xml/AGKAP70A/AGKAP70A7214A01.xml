</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το ρελέ του μοτέρ του ανεμιστήρα. 
<intxreftitleoff1 refid = "AGKAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
