<intxreftitleoff1 refid = "AGKAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική καλωδίωση ή γείωση
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε την καλωδίωση.
</ptxt>
</action>
<ps>
<ptxt>
