<servinfo servinfosgmlid = "AGKAP70A2104A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Το αμάξωμα γέρνει ή ταλαντεύεται στις στρο&#248;ές
</title>
<diag type = "condition">
<condition>
<ptxt>
Το αμάξωμα γέρνει ή ταλαντεύεται στις στρο&#248;ές
</ptxt>
</condition>
<ps>
<ptxt>
Χαλαρή αντιστρεπτική ράβδος
</ptxt>
</ps>
<action>
<ptxt>
Σ&#248;ίξτε τις βίδες ή τα παξιμάδια της αντιστρεπτικής ράβδου, ή αντικαταστήστε τα σινεμπλόκ. 
<intxreftitleoff1 refid = "AGKAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό συγκρότημα μπροστινού γονάτου (αμορτισέρ) ή βάσης
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα μπροστινού γονάτου (αμορτισέρ) ή σ&#248;ίξτε την βάση του. 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Σπασμένα ή πεσμένα ελικοειδή ελατήρια
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Αντικαταστήστε τα ελικοειδή ελατήρια.
</ptxt>
<ptxt>
Εμπρός: 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Πίσω: 
<intxreftitleoff1 refid = "AGKAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Υπερ&#248;ορτωμένο αυτοκίνητο
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε την &#248;όρτωση.
</ptxt>
</action>
</diag>
