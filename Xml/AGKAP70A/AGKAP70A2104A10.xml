<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A2104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Τα λάστιχα παραμορ&#248;ώνονται (σαν βεντούζες)
</title>
<diag type = "condition">
<condition>
<ptxt>
Τα λάστιχα παραμορ&#248;ώνονται (σαν βεντούζες)
</ptxt>
</condition>
<ps>
<ptxt>
Λανθασμένη ευθυγράμμιση τροχών
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και ρυθμίστε την ευθυγράμμιση των τροχών. 
<intxreftitleoff1 refid = "AGKAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό συγκρότημα μπροστινού γονάτου
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα του εμπρός γονάτου. 
<intxreftitleoff1 refid = "AGKAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένα ρουλεμάν του τροχού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ρουλεμάν του τροχού. 
<intxreftitleoff1 refid = "AGKAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Υπερβολική παραμόρ&#248;ωση της ζάντας ή του ελαστικού
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε το ελαστικό και/ή τη ζάντα.
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένοι σύνδεσμοι (μπαλάκια) του κάτω βραχίονα (ψαλιδιού) της ανάρτησης
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το βραχίονα της ανάρτησης. 
<intxreftitleoff1 refid = "AGKAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Κακή ζυγοστάθμιση τροχού
</ptxt>
</ps>
<action>
<ptxt>
Κάνετε ζυγοστάθμιση ή αντικαταστήστε το ελαστικό.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
