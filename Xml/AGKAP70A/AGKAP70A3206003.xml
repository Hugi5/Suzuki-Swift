<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGKAP70A3206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Α&#248;αίρεση και επανατοποθέτηση πίσω δια&#248;ορικού
</title>
<servinfosub id = "AGKAP70A3206003001">
<title>
Α&#248;αίρεση
</title>
<s1>
<ptxt>
Ανυψώστε το αυτοκίνητο και α&#248;αιρέστε τους τροχούς.
</ptxt>
</s1>
<s1>
<ptxt>
Αποστραγγίστε το λάδι από το πίσω δια&#248;ορικό, εάν είναι αναγκαίο. 
<intxreftitleoff1 refid = "AGKAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Α&#248;αιρέστε τα πίσω ημιαξόνια. 
<intxreftitleoff1 refid = "AGKAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Α&#248;αιρέστε τον κεντρικό άξονα από το πίσω δια&#248;ορικό. 
<intxreftitleoff1 refid = "AGKAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Α&#248;αιρέστε τον ελαστικό σωλήνα αναπνοής (1) από το πίσω δια&#248;ορικό.
</ptxt>
</s1>
<s1>
<ptxt>
Τοποθετήστε το γρύλο έτσι ώστε το συγκρότημα του δια&#248;ορικού να μη γέρνει.
</ptxt>
</s1>
<s1>
<ptxt>
Α&#248;αιρέστε τις βίδες (2) του εμπρός βραχίονα του δια&#248;ορικού.
</ptxt>
</s1>
<s1>
<ptxt>
Α&#248;αιρέστε την πίσω βίδα στήριξης του δια&#248;ορικού (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A320007.swf" width = "88.000mm" height = "57.146mm" ver = "02" gw = "186" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Χαμηλώστε το γρύλο με το συγκρότημα του πίσω δια&#248;ορικού.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGKAP70A3206003002">
<title>
Επανατοποθέτηση
</title>
<ptxt>
Αντιστρέψτε τη διαδικασία αποσυναρμολόγησης λαμβάνοντας υπόψη τα ακόλουθα σημεία.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Σ&#248;ίξτε κάθε βίδα με την καθορισμένη ροπή.
</ptxt>
<torque>
<torqueitem id = "T3B004">
<t-part>
Βίδα εμπρός βραχίονα δια&#248;ορικού
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
<torqueitem id = "T3B005">
<t-part>
Πίσω βίδα στήριξης δια&#248;ορικού
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
80
</t-value1>
<t-value2>
8,2
</t-value2>
<t-value3>
59,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320008.swf" width = "88.000mm" height = "52.572mm" ver = "02" gw = "186" gh = "133"/>
</figure>
</item>
<item>
<ptxt>
Γεμίστε με λιπαντικό πίσω δια&#248;ορικού, εάν έχει αποστραγγιστεί, 
<intxreftitleoff1 refid = "AGKAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
