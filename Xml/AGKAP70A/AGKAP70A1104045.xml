<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A1104045" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0606
</title>
<servinfosub id = "AGKAP70A1104045001">
<title>
Κατάσταση Ανίχνευσης Κωδικού Βλάβης και  Περιοχή Προβλήματος
</title>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.087in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.117in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Συνθήκη ανίχνευσης κωδικού
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Περιοχή Προβλήματος
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0606: Επεξεργαστής Μονάδας Ελέγχου 
</emph>
</ptxt>
<ptxt>
Βλάβη εσωτερικού επεξεργαστή εγκε&#248;άλου ECM.
</ptxt>
<ptxt>
(λογική ανίχνευσης 3 D/C)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Κύκλωμα τρο&#248;οδοσίας ρεύματος εγκε&#248;άλου ECM ή και κύκλωμα γείωσης
</ptxt>
</item>
<item>
<ptxt>
Αισθητήρας A/F
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGKAP70A1104045002">
<title>
Περιγρα&#248;ή Συστήματος
</title>
<ptxt>
Η εσωτερική μονάδα ελέγχου βρίσκεται τοποθετημένη μέσα στον ECM.
</ptxt>
</servinfosub>
<servinfosub id = "AGKAP70A1104045003">
<title>
Διαδικασία Επιβεβαίωσης Κωδικού Βλάβης DTC
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Διερευνήστε πρώτα τους μη αναμενόμενους κωδικούς DTCs που ανιχνεύθηκαν προηγουμένως στην &#34;Διαδικασία επιβεβαίωσης κωδικού DTC&#34;.
</ptxt>
</item>
<item>
<ptxt>
Επιβεβαιώστε ότι ικανοποιούνται οι παρακάτω συνθήκες σε αυτή τη &#34;Διαδικασία Επιβεβαίωσης Κωδικού DTC&#34;.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Τάση μπαταρίας &#62; 10,7 V
</ptxt>
</item>
<item>
<ptxt>
Δεν ανιχνεύεται κωδικός DTC P0030, P0031, P0032, P0131 ή P0132.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Λειτουργήστε τον κινητήρα για 1 min. στο ρελαντί.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGKAP70A1104045004">
<title>
Διάγνωση Κωδικού DTC
</title>
<diag type = "test" id = "AGKAP70A1104045005">
<testgroup id = "AGKAP70A1104045006">
<title>
Επανέλεγχος κωδικών DTC
</title>
<test1>
<ptxt>
Διαγράψτε τον Κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Πραγματοποιήστε την διαδικασία επιβεβαίωσης του Κωδικού DTC και ελέγξτε τον Κωδικό DTC.
</ptxt>
</test1>
<question>
Εξακολουθεί να ανιχνεύεται ο Κωδικός DTC P0606;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ελέγξτε για διακοπτόμενο πρόβλημα. 
<intxreftitleoff1 refid = "AGKAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A1104045007">
<title>
Έλεγχος κυκλώματος τρο&#248;οδοσίας και γείωσης του εγκε&#248;άλου ECM
</title>
<test1>
<ptxt>
Ελέγξτε το κύκλωμα τρο&#248;οδοσίας και το κύκλωμα γείωσης του ECM. 
<intxreftitleoff1 refid = "AGKAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε την ελαττωματική ηλεκτρική καλωδίωση.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A1104045008">
<title>
Επανέλεγχος κωδικών DTC
</title>
<test1>
<ptxt>
Αντικαταστήστε τον αισθητήρα A/F. 
<intxreftitleoff1 refid = "AGKAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Πραγματοποιήστε την διαδικασία επιβεβαίωσης του Κωδικού DTC και ελέγξτε τον Κωδικό DTC.
</ptxt>
</test1>
<question>
Εξακολουθεί να ανιχνεύεται ο Κωδικός DTC P0606;
</question>
<result type = "yes"/>
<action>
<ptxt>
Αντικαταστήστε τον εγκέ&#248;αλο ECM και ελέγξτε ξανά τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Τέλος.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
