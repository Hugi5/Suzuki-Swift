</ptxt>
</item>
<item>
<ptxt>
Μονάδα πλευρικού αερόσακου οδηγού / συνοδηγού (πυροκροτητής)
</ptxt>
</item>
<item>
<ptxt>
SDM
</ptxt>
</item>
</list1>
