<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A6104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Θόρυβος κατά την αλλαγή διεύθυνσης (Κροτάλισμα ή καγχασμός)
</title>
<diag type = "condition">
<condition>
<ptxt>
Θόρυβος κατά την αλλαγή διεύθυνσης (Κροτάλισμα ή καγχασμός)
</ptxt>
</condition>
<ps>
<ptxt>
Ξεβιδωμένη βίδα του κελύ&#248;ους της κρεμαγέρας
</ptxt>
</ps>
<action>
<ptxt>
Σ&#248;ίξτε τη βίδα του κελύ&#248;ους της κρεμαγέρας. 
<intxreftitleoff1 refid = "AGKAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ακατάλληλη επα&#248;ή δοντιού μεταξύ της κρεμαγιέρας
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ελέγξτε τη ροπή περιστρο&#248;ής του άξονα της κρεμαγιέρας. 
<intxreftitleoff1 refid = "AGKAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Εάν είναι ελαττωματική, αντικαταστήστε το συγκρότημα της θήκης του γραναζιού διεύθυνσης. 
<intxreftitleoff1 refid = "AGKAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Ελαττωματικό το συγκρότημα του κελύ&#248;ους της κρεμαγιέρας
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα του κελύ&#248;ους της κρεμαγιέρας. 
<intxreftitleoff1 refid = "AGKAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Σπασμένα ή κατεστραμμένα ρουλεμάν τροχού(-ων)
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το (τα) ρουλεμάν του (των) τροχού (-ων). 
<intxreftitleoff1 refid = "AGKAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένο ακρόμπαρο ή εσωτερικός σ&#248;αιρικός σύνδεσμος ημίμπαρου
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Αντικαταστήστε το ακρόμπαρο ή το ημίμπαρο.
</ptxt>
<ptxt>
Ακρόμπαρο: 
<intxreftitleoff1 refid = "AGKAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Ημίμπαρο: 
<intxreftitleoff1 refid = "AGKAP70A6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
