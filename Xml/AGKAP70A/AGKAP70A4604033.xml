<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A4604033" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1074 / C1075
</title>
<servinfosub id = "AGKAP70A4604033001">
<title>
Κατάσταση Ανίχνευσης Κωδικού Βλάβης και  Περιοχή Προβλήματος
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Συνθήκη ανίχνευσης κωδικού
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Περιοχή Προβλήματος
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1074: Καλιμπράρισμα αισθητήρα G 
</emph>
</ptxt>
<ptxt>
Το καλιμπράρισμα του αισθητήρα βαθμού εκτροπής / αισθητήρα G δεν έχει ολοκληρωθεί.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Το καλιμπράρισμα του αισθητήρα βαθμού εκτροπής / αισθητήρα G είναι ημιτελές
</ptxt>
</item>
<item>
<ptxt>
Μονάδα ελέγχου ESP<sup>&#174;</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1075: Καλιμπράρισμα Αισθητήρα Γωνίας Στρο&#248;ής
</emph>
</ptxt>
<ptxt>
Το καλιμπράρισμα του αισθητήρα γωνίας στρο&#248;ής δεν έχει ολοκληρωθεί.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Αισθητήρας γωνίας στρο&#248;ής
</ptxt>
</item>
<item>
<ptxt>
Το καλιμπράρισμα του αισθητήρα γωνίας τιμονιού είναι ημιτελές
</ptxt>
</item>
<item>
<ptxt>
Μονάδα ελέγχου ESP<sup>&#174;</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGKAP70A4604033002">
<title>
Διάγνωση Κωδικού DTC
</title>
<diag type = "test" id = "AGKAP70A4604033003">
<testgroup id = "AGKAP70A4604033004">
<question>
Πραγματοποιήθηκε ο &#34;Έλεγχος του Συστήματος ESP<sup>&#174;</sup>&#34;;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70A4604001">Έλεγχος Συστήματος ESP&#174;</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604033005">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Εκτελέστε 
<intxref refid = "AGKAP70A4604005">Έλεγχος Κωδικού DTC</intxref>
.
</ptxt>
</test1>
<question>
Υπάρχουν άλλοι κωδικοί DTC εκτός από τους C1074 και C1075;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην ισχύουσα διάγνωση κωδικού βλάβης.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604033006">
<title>
Καλιμπράρισμα αισθητήρα
</title>
<test1>
<ptxt>
Καλιμπράρετε όλους τους αισθητήρες. 
<intxreftitleoff1 refid = "AGKAP70A4606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Έχει ολοκληρωθεί το καλιμπράρισμα του αισθητήρα;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Αντικαταστήστε τον αισθητήρα γωνίας στρο&#248;ής. 
<intxreftitleoff1 refid = "AGKAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A4604033007">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Διαγράψτε όλους τους κωδικούς DTC και ελέγξτε ξανά για κωδικό DTC.
</ptxt>
</test1>
<question>
Εξακολουθούν να ανιχνεύονται οι κωδικοί DTC C1074 ή/και C1075;
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
DTC C1074: Αντικαταστήστε το συγκρότημα υδραυλικής μονάδας / μονάδας ελέγχου ESP<sup>&#174;</sup> και ελέγξτε ξανά τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
DTC C1075: Αντικαταστήστε τον αισθητήρα γωνίας στρο&#248;ής και ελέγξτε τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Τέλος.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
