</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>
Περιστρέψτε τον ενδιάμεσο άξονα (3) 10 &#248;ορές ή περισσότερο.
</ptxt>
<figure page = "2">
<graphic graphicname = "I9P60A522032.swf" width = "88.000mm" height = "67.012mm" ver = "01" gw = "217" gh = "173"/>
<callout>
