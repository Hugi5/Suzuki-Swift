<servinfo servinfosgmlid = "AGKAP70A7214A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Δεν βγαίνει θερμός αέρας ή υπάρχει ανεπαρκής θέρμανση (Ελαττωματικός έλεγχος θερμοκρασίας)
</title>
<diag type = "condition">
<condition>
<ptxt>
Δεν βγαίνει θερμός αέρας ή υπάρχει ανεπαρκής θέρμανση (Ελαττωματικός έλεγχος θερμοκρασίας)
</ptxt>
</condition>
<ps>
<ptxt>
Σπασμένη ή τσακισμένη ντίζα ελέγχου θερμοκρασίας
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τη ντίζα ελέγχου θερμοκρασίας.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός επιλογέας θερμοκρασίας
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον επιλογέα θερμοκρασίας.
</ptxt>
</action>
<ps>
<ptxt>
Λανθασμένη τοποθέτηση της ντίζας ελέγχου θερμοκρασίας
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τη θέση της ντίζας και προσαρμόστε την εάν είναι απαραίτητο.
</ptxt>
</action>
<ps>
<ptxt>
Σπασμένο συγκρότημα κλαπέτου ελέγχου θερμοκρασίας
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε το συγκρότημα του κλαπέτου ελέγχου θερμοκρασίας.
</ptxt>
</action>
<ps>
<ptxt>
Φραγμένοι αεραγωγοί
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε τους αεραγωγούς.
</ptxt>
</action>
<ps>
<ptxt>
Διαρροή ή &#248;ράξιμο ψυγείου καλορι&#248;έρ
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το ψυγείο του καλορι&#248;έρ.
</ptxt>
</action>
<ps>
<ptxt>
Διαρροή ή &#248;ράξιμο ελαστικών σωλήνων καλορι&#248;έρ
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τους ελαστικούς σωλήνες του καλορι&#248;έρ.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός θερμοστάτης
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον θερμοστάτη. 
<intxreftitleoff1 refid = "AGKAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός αισθητήρας ECT
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον αισθητήρα ECT. 
<intxreftitleoff1 refid = "AGKAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
