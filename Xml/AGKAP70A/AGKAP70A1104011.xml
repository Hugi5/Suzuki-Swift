<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A1104011" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
Η λυχνία MIL δεν ανάβει με το κλειδί ανά&#248;λεξης σε Θέση &#34;ON&#34; και τον κινητήρα σταματημένο (αλλά ο κινητήρας μπορεί να πάρει μπροστά)
</title>
<servinfosub id = "AGKAP70A1104011001">
<title>
Διάγνωση βλαβών
</title>
<diag type = "test" id = "AGKAP70A1104011002">
<testgroup id = "AGKAP70A1104011003">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε για DTC σχετιζόμενο με την επικοινωνία CAN.
</ptxt>
</test1>
<question>
Έχει ανιχνευτεί κάποιος DTC;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A1104011004">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε τον κωδικό DTC για πίνακα οργάνων.
</ptxt>
</test1>
<question>
Έχει ανιχνευτεί κάποιος(οι) Κωδικός (οί) DTC;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Αντικαταστήστε τον εγκέ&#248;αλο ECM και ελέγξτε ξανά τη λειτουργία της λυχνίας MIL. 
<intxreftitleoff1 refid = "AGKAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
