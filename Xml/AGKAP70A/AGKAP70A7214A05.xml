<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A7214A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Δεν βγαίνει κρύος αέρας (ο μαγνητικός συμπλέκτης του ανεμιστήρα δεν λειτουργεί)
</title>
<diag type = "condition">
<condition>
<ptxt>
Δεν βγαίνει κρύος αέρας (ο μαγνητικός συμπλέκτης του ανεμιστήρα δεν λειτουργεί)
</ptxt>
</condition>
<ps>
<ptxt>
Δεν υπάρχει ψυκτικό
</ptxt>
</ps>
<action>
<ptxt>
Εκτελέστε ανάκτηση ψυκτικού, εκκένωση και πλήρωση. 
<intxreftitleoff1 refid = "AGKAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Καμένη ασ&#248;άλεια
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τις σχετικές ασ&#248;άλειες, και στη συνέχεια ελέγξτε για βραχυκύκλωμα με τη γείωση.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός διακόπτης A/C
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το διακόπτη A/C. 
<intxreftitleoff1 refid = "AGKAP70A7216034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός επιλογέας στρο&#248;ών ανεμιστήρα
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον επιλογέα στρο&#248;ών ανεμιστήρα. 
<intxreftitleoff1 refid = "AGKAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός αισθητήρας θερμοκρασίας εξατμιστή
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον αισθητήρα θερμοκρασίας εξατμιστή. 
<intxreftitleoff1 refid = "AGKAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός αισθητήρας πίεσης ψυκτικού υγρού του κλιματισμού
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον αισθητήρα πίεσης ψυκτικού υγρού του κλιματισμού A/C. 
<intxreftitleoff1 refid = "AGKAP70A7216023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική καλωδίωση ή γείωση
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε την καλωδίωση.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός ΕCM και το κύκλωμά του
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ελέγξτε τον ECM. 
<intxreftitleoff1 refid = "AGKAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Ελαττωματικός μαγνητικός συμπλέκτης
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το μαγνητικό συμπλέκτη. 
<intxreftitleoff1 refid = "AGKAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρός ή σπασμένος ιμάντας κίνησης του συμπιεστή
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον ιμάντα κίνησης του συμπιεστή. 
<intxreftitleoff1 refid = "AGKAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός συμπιεστής
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το συμπιεστή.
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό ρελέ συμπιεστή
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το ρελέ του συμπιεστή. 
<intxreftitleoff1 refid = "AGKAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός εγκέ&#248;αλος BCM
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον εγκέ&#248;αλο BCM. 
<intxreftitleoff1 refid = "AGKAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
