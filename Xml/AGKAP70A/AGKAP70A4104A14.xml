<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A4104A14" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Η προειδοποιητική λυχνία &#248;ρένων δεν ανάβει μετά από το γύρισμα του κλειδιού ανά&#248;λεξης στη θέση &#34;ON&#34;
</title>
<diag type = "condition">
<condition>
<ptxt>
Η προειδοποιητική λυχνία &#248;ρένων δεν ανάβει μετά από το γύρισμα του κλειδιού ανά&#248;λεξης στη θέση &#34;ON&#34;
</ptxt>
</condition>
<ps>
<ptxt>
Ελαττωματικό κύκλωμα τρο&#248;οδοσίας ρεύματος και γείωσης του πίνακα οργάνων
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τον πίνακα οργάνων και το κύκλωμα. 
<intxreftitleoff1 refid = "AGKAP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός πίνακας οργάνων
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τον πίνακα οργάνων. 
<intxreftitleoff1 refid = "AGKAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Η προειδοποιητική λυχνία ABS αναβοσβήνει
</ptxt>
</ps>
<action>
<ptxt>
Εντοπίστε τη δυσλειτουργία και επιδιορθώστε την. 
<intxreftitleoff1 refid = "AGKAP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική υδραυλική μονάδα / μονάδα ελέγχου ESP<sup>&#174;</sup>
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε την υδραυλική μονάδας / μονάδα ελέγχου ESP<sup>&#174;</sup>. 
<intxreftitleoff1 refid = "AGKAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
