<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70AA324001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Έλεγχος Συστήματος Ελέγχου Ακινητοποίησης Κινητήρα (Immobilizer)
</title>
<diag type = "test" id = "AGKAP70AA324001001">
<testgroup id = "AGKAP70AA324001003">
<title>
Έλεγχος ανά&#248;λεξης σε θέση &#34;ON&#34;
</title>
<test1>
<ptxt>
Γυρίστε το διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;
</ptxt>
</test1>
<test1>
<ptxt>
Πατήστε το πεντάλ του συμπλέκτη.
</ptxt>
</test1>
<question>
ΑΝΑΒΟΥΝ οι ενδεικτικές λυχνίες ON και PUSH;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70AA504001">Έλεγχος Συστήματος Εκκίνησης Χωρίς Κλειδί</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA324001004">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε για κωδικό βλάβης. 
<intxreftitleoff1 refid = "AGKAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ανιχνεύεται κάποιος κωδικός DTC;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA324001006">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Ελέγξτε για DTC σχετιζόμενο με την επικοινωνία CAN.
</ptxt>
</test1>
<question>
Έχει ανιχνευτεί κάποιος DTC;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στην διάγνωση του αντίστοιχου Κωδικού DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA324001005">
<question>
Περιστρέ&#248;εται ο κινητήρας με την μίζα;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70A1904001">Διάγνωση Συμπτωμάτων Του Συστήματος Εκκίνησης</intxref>
 &#34;.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70AA324001002">
<title>
Έλεγχος εκκίνησης του κινητήρα
</title>
<question>
Ξεκινά ο κινητήρας;
</question>
<result type = "yes"/>
<action>
<ptxt>
Το σύστημα ελέγχου του immobilizer είναι σε καλή κατάσταση.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70A1104009">Βασική Επιθεώρηση του Κινητήρα</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
