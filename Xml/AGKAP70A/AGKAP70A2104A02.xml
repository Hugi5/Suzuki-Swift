<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Υπερβολική &#248;θορά ελαστικού
</title>
<diag type = "condition">
<condition>
<ptxt>
Υπερβολική &#248;θορά ελαστικού
</ptxt>
</condition>
<ps>
<ptxt>
Σπασμένα ή πεσμένα ελικοειδή ελατήρια
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Αντικαταστήστε τα ελικοειδή ελατήρια.
</ptxt>
<ptxt>
Εμπρός: 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Πίσω: 
<intxreftitleoff1 refid = "AGKAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Κακή ζυγοστάθμιση τροχού
</ptxt>
</ps>
<action>
<ptxt>
Κάνετε ζυγοστάθμιση ή αντικαταστήστε το ελαστικό.
</ptxt>
</action>
<ps>
<ptxt>
Λανθασμένη ευθυγράμμιση τροχών
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και ρυθμίστε την ευθυγράμμιση των τροχών. 
<intxreftitleoff1 refid = "AGKAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικό συγκρότημα μπροστινού γονάτου (αμορτισέρ)
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το συγκρότημα μπροστινού γονάτου (αμορτισέρ) 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Τραχιά οδήγηση
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ελαστικά. 
<intxreftitleoff1 refid = "AGKAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Υπερ&#248;ορτωμένο αυτοκίνητο
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε την &#248;όρτωση.
</ptxt>
</action>
<ps>
<ptxt>
Τα ελαστικά δεν έχουν εναλλαχθεί (σταυρωθεί)
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε ή σταυρώστε τα ελαστικά.
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένο ή χαλαρό ρουλεμάν τροχού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το ρουλεμάν του τροχού. 
<intxreftitleoff1 refid = "AGKAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ο τροχός ή το ελαστικό παίζει
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε την ζάντα ή το ελαστικό.
</ptxt>
</action>
<ps>
<ptxt>
Τα ελαστικά δεν είναι &#248;ουσκωμένα επαρκώς
</ptxt>
</ps>
<action>
<ptxt>
Ρυθμίστε την πίεση των ελαστικών
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
