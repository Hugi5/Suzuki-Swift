<servinfosub id = "AGKAP70A7224024004">
<title>
Διάγνωση Κωδικού DTC
</title>
<diag type = "test" id = "AGKAP70A7224024005">
<testgroup id = "AGKAP70A7224024006">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Γυρίστε το διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Γυρίστε το διακόπτη ανά&#248;λεξης στη θέση &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Γυρίστε το διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34; και ελέγξτε τον κωδικό DTC.
</ptxt>
</test1>
<question>
Εξακολουθεί να ανιχνεύεται ο Κωδικός DTC B1541;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Διακοπτόμενο πρόβλημα.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A7224024008">
<title>
Έλεγχος ασ&#248;άλειας
</title>
<test1>
<ptxt>
Ελέγξτε την ασ&#248;άλεια &#34;MTR&#34;.
</ptxt>
</test1>
<question>
Είναι σε καλή κατάσταση;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Αντικαταστήστε την ασ&#248;άλεια &#34;MTR&#34; και ελέγξτε για βραχυκύκλωμα με τη γείωση.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A7224024007">
<title>
Έλεγχος του κυκλώματος τρο&#248;οδοσίας ρεύματος της μπαταρίας
</title>
<test1>
<ptxt>
Αποσυνδέστε το &#248;ις &#34;G20&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Μετρήστε την τάση μεταξύ του ακροδέκτη του καλωδίου &#34;WHT/RED&#34; του &#248;ις &#34;G20&#34; και της γείωσης.
</ptxt>
</test1>
<question>
Η τάση είναι 10 – 14 V;
</question>
<result type = "yes"/>
<action>
<ptxt>
Αντικαταστήστε τη μονάδα ελέγχου HVAC και επανελέγξτε τον κωδικό DTC. 
<intxreftitleoff1 refid = "AGKAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Αντικαταστήστε την καλωδίωση του ταμπλό οργάνων.
</ptxt>
</action>
</testgroup>
