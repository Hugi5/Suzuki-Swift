<servinfosub id = "AGKAP70A6304010002">
<title>
Διάγνωση βλαβών
</title>
<diag type = "test" id = "AGKAP70A6304010003">
<testgroup id = "AGKAP70A6304010004">
<title>
Έλεγχος προειδοποιητικής λυχνίας &#34;P/S&#34;
</title>
<test1>
<ptxt>
Θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<question>
Οι άλλες προειδοποιητικές λυχνίες ανάβουν;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A6304010005">
<title>
Έλεγχος Κωδικού Βλάβης DTC
</title>
<test1>
<ptxt>
Εκτελέστε 
<intxref refid = "AGKAP70A6304003">Έλεγχος Κωδικού DTC</intxref>
.
</ptxt>
</test1>
<question>
Υπάρχει κωδικός DTC U0073 ή DTC U0155;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο 
<intxref refid = "AGKAP70AA804002">Πίνακας CAN DTC (Απώλεια Επικοινωνίας και Δίαυλος Επικοινωνίας Εκτός Λειτουργίας)</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A6304010006">
<title>
Έλεγχος πίνακα οργάνων
</title>
<test1>
<ptxt>
Αντικαταστήστε τον πίνακα οργάνων. 
<intxreftitleoff1 refid = "AGKAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<question>
Παραμένει σβηστή η προειδοποιητική λυχνία P/S;
</question>
<result type = "yes"/>
<action>
<ptxt>
Αντικαταστήστε τον εγκέ&#248;αλο P/S. 
<intxreftitleoff1 refid = "AGKAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Τέλος.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A6304010007">
<title>
Έλεγχος ασ&#248;άλειας
</title>
<question>
Είναι σε καλή κατάσταση το κύκλωμα της ασ&#248;άλειας του πίκανα οργάνων;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Αντικαταστήστε την ασ&#248;άλεια και ελέγξτε για βραχυκύκλωμα με τη γείωση.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AGKAP70A6304010008">
<title>
Ελέγξτε το κύκλωμα επικοινωνίας CAN
</title>
<test1>
<ptxt>
Ελέγξτε το κύκλωμα επικοινωνίας CAN μεταξύ του πίνακα οργάνων και της μονάδας ελέγχου P/S. 
<intxreftitleoff1 refid = "AGKAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Το κύκλωμα επικοινωνίας CAN είναι σε καλή κατάσταση;
</question>
<result type = "yes"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Επισκευάστε ή αντικαταστήστε.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AGKAP70A6304010009">
<title>
Έλεγχος κυκλώματος τρο&#248;οδοσίας ρεύματος πίνακα οργάνων
</title>
<test1>
<ptxt>
Α&#248;αιρέστε τον πίνακα οργάνων. 
<intxreftitleoff1 refid = "AGKAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Ελέγξτε για σωστή σύνδεση στο &#248;ις του πίνακα οργάνων.
</ptxt>
</test1>
<test1>
<ptxt>
Εάν το αποτέλεσμα του ελέγχου είναι εντάξει, θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;ON&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ελέγξτε ότι η τάση μεταξύ του ακροδέκτη &#34;G240-3&#34; και του ακροδέκτη &#34;G240-5&#34; είναι τάση μπαταρίας.
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Αντικαταστήστε τον πίνακα οργάνων και ελέγξτε ξανά. 
<intxreftitleoff1 refid = "AGKAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Πηγαίνετε στο Βήμα 7.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGKAP70A6304010010">
<title>
Έλεγχος κυκλώματος γείωσης πίνακα οργάνων
</title>
<test1>
<ptxt>
Θέστε τον διακόπτη ανά&#248;λεξης στη θέση &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Ελέγξτε ότι η αντίσταση μεταξύ του ακροδέκτη &#34;G240-5&#34; και της γείωσης είναι 1 Ω ή μικρότερη.
</ptxt>
</test1>
<question>
Είναι το αποτέλεσμα του ελέγχου ΟΚ;
</question>
<result type = "yes"/>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε το κύκλωμα &#34;Α1&#34;.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Επισκευάστε ή αντικαταστήστε το κύκλωμα &#34;A2&#34;.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
