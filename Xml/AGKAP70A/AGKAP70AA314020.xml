<servinfosub id = "AGKAP70AA314020001">
<title>
Κατάσταση Ανίχνευσης και Περιοχή Προβλήματος
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.602in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.602in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Κατάσταση Ανίχνευσης
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Περιοχή Προβλήματος
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1190: Δυσλειτουργία Διακόπτη Κινητήρα 
</emph>
</ptxt>
<ptxt>
Η μονάδα ελέγχου immobilizer είναι ελαττωματική.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Εγκέ&#248;αλος Immobilizer
</ptxt>
</entry>
