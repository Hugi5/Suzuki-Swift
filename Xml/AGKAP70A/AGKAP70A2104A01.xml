<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A2104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Το όχημα ωθείται προς τη μία πλευρά (τραβάει)
</title>
<diag type = "condition">
<condition>
<ptxt>
Το όχημα ωθείται προς τη μία πλευρά (τραβάει)
</ptxt>
</condition>
<ps>
<ptxt>
Αναντιστοιχία ή ανομοιόμορ&#248;η &#248;θορά ελαστικών
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ελαστικά. 
<intxreftitleoff1 refid = "AGKAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Τα ελαστικά δεν είναι &#248;ουσκωμένα επαρκώς
</ptxt>
</ps>
<action>
<ptxt>
Ρυθμίστε την πίεση των ελαστικών
</ptxt>
</action>
<ps>
<ptxt>
Σπασμένα ή πεσμένα ελικοειδή ελατήρια
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Αντικαταστήστε τα ελικοειδή ελατήρια.
</ptxt>
<ptxt>
Εμπρός: 
<intxreftitleoff1 refid = "AGKAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Πίσω: 
<intxreftitleoff1 refid = "AGKAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Αντικανονική πλευρική ισχύς που δημιουργήθηκε από ελαστικό ράντιαλ
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τα ελαστικά. 
<intxreftitleoff1 refid = "AGKAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Λανθασμένη ευθυγράμμιση τροχών
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και ρυθμίστε την ευθυγράμμιση των τροχών. 
<intxreftitleoff1 refid = "AGKAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Τα &#248;ρένα κολλάνε σε έναν τροχό
</ptxt>
</ps>
<action>
<ptxt>
Ρυθμίστε ή επισκευάστε τα &#248;ρένα.
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρά, στραβωμένα ή σπασμένα εξαρτήματα της μπροστινής ή της πίσω ανάρτησης
</ptxt>
</ps>
<action>
<ptxt>
Σ&#248;ίξτε ή αντικαταστήστε τα αντίστοιχα εξαρτήματα της ανάρτησης. 
<intxreftitleoff1 refid = "AGKAP70A2106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
