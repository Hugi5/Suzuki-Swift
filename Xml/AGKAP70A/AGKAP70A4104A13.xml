<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A4104A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Η προειδοποιητική λυχνία &#248;ρένων παραμένει αναμμένη (για παραπάνω από 2 sec) μετά από την εκκίνηση του κινητήρα
</title>
<diag type = "condition">
<condition>
<ptxt>
Η προειδοποιητική λυχνία &#248;ρένων παραμένει αναμμένη (για παραπάνω από 2 sec) μετά από την εκκίνηση του κινητήρα
</ptxt>
</condition>
<ps>
<ptxt>
Το &#248;ις της μονάδας ελέγχου ESP<sup>&#174;</sup> δεν είναι συνδεδεμένο σωστά
</ptxt>
</ps>
<action>
<ptxt>
Συνδέστε ξανά το &#248;ις της μονάδας ελέγχου ESP<sup>&#174;</sup>.
</ptxt>
</action>
<ps>
<ptxt>
Το χειρό&#248;ρενο είναι ενεργοποιημένο
</ptxt>
</ps>
<action>
<ptxt>
Απελευθερώστε το χειρό&#248;ρενο και ελέγξτε ότι η προειδοποιητική λυχνία σβήνει.
</ptxt>
</action>
<ps>
<ptxt>
Ανεπαρκής ποσότητα υγρών &#248;ρένων
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε τη στάθμη του υγρού των &#248;ρένων. 
<intxreftitleoff1 refid = "AGKAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Η προειδοποιητική λυχνία ABS αναβοσβήνει
</ptxt>
</ps>
<action>
<ptxt>
Εντοπίστε τη δυσλειτουργία και επιδιορθώστε την. 
<intxreftitleoff1 refid = "AGKAP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Προβληματικός διακόπτης χειρό&#248;ρενου ή/και διακόπτης στάθμης υγρού &#248;ρένων
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ελέγξτε το διακόπτη χειρό&#248;ρενου ή/και το διακόπτη στάθμης υγρού &#248;ρένων.
</ptxt>
<ptxt>
Διακόπτης χειρό&#248;ρενου: 
<intxreftitleoff1 refid = "AGKAP70A4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Διακόπτης στάθμης υγρού &#248;ρένων: 
<intxreftitleoff1 refid = "AGKAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Δυσλειτουργία του συστήματος επικοινωνίας CAN
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε το σύστημα επικοινωνίας CAN. 
<intxreftitleoff1 refid = "AGKAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματικός πίνακας οργάνων
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε τον πίνακα οργάνων. 
<intxreftitleoff1 refid = "AGKAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ελαττωματική υδραυλική μονάδα / μονάδα ελέγχου ESP<sup>&#174;</sup>
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε την υδραυλική μονάδας / μονάδα ελέγχου ESP<sup>&#174;</sup>. 
<intxreftitleoff1 refid = "AGKAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
