<servinfo servinfosgmlid = "AGKAP70A3204001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Διάγνωση συμπτωμάτων πίσω δια&#248;ορικού
</title>
<diag type = "condition" id = "AGKAP70A3204001001">
<condition>
<ptxt>
Θόρυβος γραναζιού
</ptxt>
</condition>
<ps>
<ptxt>
Λιπαντικό αλλοιωμένο ή νοθευμένο με νερό
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε και συμπληρώστε. 
<intxreftitleoff1 refid = "AGKAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ακατάλληλο ή ανεπαρκές λιπαντικό
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε και συμπληρώστε. 
<intxreftitleoff1 refid = "AGKAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Λανθασμένα ρυθμισμένος τζόγος μεταξύ του κωνικού πινιόν και του γραναζιού
</ptxt>
</ps>
<action>
<ptxt>
Ρυθμίστε την ευθυγράμμιση σύμ&#248;ωνα με τις προδιαγρα&#248;ές. 
<intxreftitleoff1 refid = "AGKAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Λανθασμένη επα&#248;ή δοντιού στη σύμπλεξη μεταξύ του κωνικού πινιόν και του γραναζιού
</ptxt>
</ps>
<action>
<ptxt>
Ρυθμίστε ή αντικαταστήστε. 
<intxreftitleoff1 refid = "AGKAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Χαλαρώστε τις βίδες ασ&#248;άλισης του κωνικού πινιόν
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε ή σ&#248;ίξτε τις πάλι. 
<intxreftitleoff1 refid = "AGKAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένος πλανήτης(-ες) ή πινιόν δια&#248;ορικού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε. 
<intxreftitleoff1 refid = "AGKAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Σταθερός θόρυβος ρουλεμάν
</ptxt>
</condition>
<ps>
<ptxt>
Λιπαντικό αλλοιωμένο ή νοθευμένο με νερό
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε και συμπληρώστε. 
<intxreftitleoff1 refid = "AGKAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ακατάλληλο ή ανεπαρκές λιπαντικό
</ptxt>
</ps>
<action>
<ptxt>
Επισκευάστε και συμπληρώστε. 
<intxreftitleoff1 refid = "AGKAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Θόρυβος κατά τη διαδρομή του ρουλεμάν
</ptxt>
</condition>
<ps>
<ptxt>
Χαλασμένο(-α) ρουλεμάν του κωνικού πινιόν
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε. 
<intxreftitleoff1 refid = "AGKAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Θόρυβος κατά την περιστρο&#248;ή του ρουλεμάν
</ptxt>
</condition>
<ps>
<ptxt>
Κατεστραμμένο (-α) πλευρικό (ά) ρουλεμάν δια&#248;ορικού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε. 
<intxreftitleoff1 refid = "AGKAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Διαρροή λαδιού
</ptxt>
</condition>
<ps>
<ptxt>
Φραγμένη τάπα αναπνοής
</ptxt>
</ps>
<action>
<ptxt>
Καθαρίστε.
</ptxt>
</action>
<ps>
<ptxt>
Φθαρμένη ή με κατεστραμμένη τσιμούχα λαδιού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε. 
<intxreftitleoff1 refid = "AGKAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Υπερβολικό λάδι
</ptxt>
</ps>
<action>
<ptxt>
Ρυθμίστε τη στάθμη του λαδιού. 
<intxreftitleoff1 refid = "AGKAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
