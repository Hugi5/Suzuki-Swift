<servicetoolitem id = "L1D015">
<s-part>
(A)
</s-part>
<s-number num = "09924-17811">
09924-17811
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I8C50A140045.swf" width = "88.000mm" height = "50.407mm" ver = "01" gw = "141" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Α&#248;αιρέστε το βολάν από τον στρο&#248;αλο&#248;όρο.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGKAP70A1406021002">
