<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGKAP70A6104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Βαρύ τιμόνι
</title>
<diag type = "condition">
<condition>
<ptxt>
Βαρύ τιμόνι
</ptxt>
</condition>
<ps>
<ptxt>
Μη επαρκής πίεση ελαστικών
</ptxt>
</ps>
<action>
<ptxt>
Ρυθμίστε την πίεση των ελαστικών
</ptxt>
</action>
<ps>
<ptxt>
Δυσλειτουργία του συστήματος διεύθυνσης με υποβοήθηση
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και διορθώστε. 
<intxreftitleoff1 refid = "AGKAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Κολλημένος σ&#248;αιρικός σύνδεσμος ακρόμπαρου
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το ακρόμπαρο. 
<intxreftitleoff1 refid = "AGKAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Κολλημένος σ&#248;αιρικός σύνδεσμος βραχίονα ανάρτησης
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε το βραχίονα της ανάρτησης. 
<intxreftitleoff1 refid = "AGKAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Λανθασμένη ευθυγράμμιση μπροστινών τροχών
</ptxt>
</ps>
<action>
<ptxt>
Ελέγξτε και ρυθμίστε την ευθυγράμμιση των μπροστινών τροχών. 
<intxreftitleoff1 refid = "AGKAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Κολλημένη κολώνα τιμονιού
</ptxt>
</ps>
<action>
<ptxt>
Αντικαταστήστε την κολώνα του τιμονιού. 
<intxreftitleoff1 refid = "AGKAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ακατάλληλη επα&#248;ή δοντιού μεταξύ της κρεμαγιέρας
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Ελέγξτε τη ροπή περιστρο&#248;ής του άξονα της κρεμαγιέρας. 
<intxreftitleoff1 refid = "AGKAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Εάν είναι ελαττωματική, αντικαταστήστε το συγκρότημα της θήκης του γραναζιού διεύθυνσης. 
<intxreftitleoff1 refid = "AGKAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
