<item>
<ptxt>
Sensor de estacionamiento 
</ptxt>
</item>
<item>
<ptxt>
Módulo de control del sistema del sensor de estacionamiento 
</ptxt>
</item>
<item>
<ptxt>
Circuito de comunicación 
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
