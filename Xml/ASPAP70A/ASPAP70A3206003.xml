<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A3206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Montaje y desmontaje del conjunto de diferencial trasero 
</title>
<servinfosub id = "ASPAP70A3206003001">
<title>
Desmontaje 
</title>
<s1>
<ptxt>
Levante el vehículo y saque las ruedas. 
</ptxt>
</s1>
<s1>
<ptxt>
Drene el aceite del diferencial trasero si fuera necesario. 
<intxreftitleoff1 refid = "ASPAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los ejes impulsores traseros. 
<intxreftitleoff1 refid = "ASPAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 . 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el eje de transmisión del diferencial trasero. 
<intxreftitleoff1 refid = "ASPAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 . 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el tubo de ventilación (1) del diferencial trasero. 
</ptxt>
</s1>
<s1>
<ptxt>
Coloque el gato de manera que el conjunto del diferencial no se incline. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los pernos del brazo delantero del diferencial (2). 
</ptxt>
</s1>
<s1>
<ptxt>
Retire el perno de montaje trasero del diferencial (3). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A320007.swf" width = "88.000mm" height = "57.146mm" ver = "02" gw = "186" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Baje el gato, con el conjunto del diferencial trasero. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A3206003002">
<title>
Montaje 
</title>
<ptxt>
Invierta el procedimiento de desmontaje, teniendo en cuenta los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete los pernos al par de apriete especificado. 
</ptxt>
<torque>
<torqueitem id = "T3B004">
<t-part>
 Perno del brazo delantero del diferencial 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 50 
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
<torqueitem id = "T3B005">
<t-part>
 Perno de la montura trasera del diferencial 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
 80 
</t-value1>
<t-value2>
8,2
</t-value2>
<t-value3>
59,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320008.swf" width = "88.000mm" height = "52.572mm" ver = "02" gw = "186" gh = "133"/>
</figure>
</item>
<item>
<ptxt>
Vierta aceite en el diferencial trasero si se ha drenado, 
<intxreftitleoff1 refid = "ASPAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
