<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Patinaje 
</title>
<diag type = "condition">
<condition>
<ptxt>
Patinaje 
</ptxt>
</condition>
<ps>
<ptxt>
Recorrido libre del pedal de embrague incorrecto 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Reemplace el brazo del pedal de embrague y/o el cilindro maestro del embrague. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Brazo del pedal de embrague: 
<intxreftitleoff1 refid = "ASPAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Cilindro maestro del embrague: 
<intxreftitleoff1 refid = "ASPAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Forro del disco de embrague desgastado o manchado de aceite. 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Superficie deformada del disco, el plato de presión o el volante 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Reemplace el disco, la cubierta del embrague o el volante. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Cubierta y disco del embrague: 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Volante: 
<intxreftitleoff1 refid = "ASPAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Muelle del diafragma debilitado 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace la tapa del embrague. 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
El pistón de cilindro maestro o la copa del sello no retornan. 
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el cilindro maestro del embrague. 
<intxreftitleoff1 refid = "ASPAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
