<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "1">
<servinfo servinfosgmlid = "ASPAP70A4601006" svcinfotypenbr = "03" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Descripción del estado de calibración del sensor 
</title>
<ptxt>
Cuando se da la siguiente condición, deberá realizarse la calibración del sensor, puesto que se borran los datos de calibración originales.<sup></sup>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1" page = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.646in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.558in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Sensor que debe calibrarse 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición que requiere calibración 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Sensor del ángulo de dirección 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Se reemplaza el sensor del ángulo de dirección. 
</ptxt>
</item>
<item>
<ptxt>
El conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> se ha reemplazado. 
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Sensor de presión del cilindro maestro del freno 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
El conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> se ha reemplazado. 
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Conjunto del sensor G/sensor giroscopio 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
El conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> se ha reemplazado. 
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
<ptxt>
Realice la calibración del sensor de acuerdo con 
<intxref refid = "ASPAP70A4606002">Calibración del sensor</intxref>
. 
</ptxt>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
