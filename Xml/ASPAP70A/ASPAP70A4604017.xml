<servinfosub id = "ASPAP70A4604017003">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70A4604017004">
<testgroup id = "ASPAP70A4604017005">
<question>
¿Se ha llevado a cabo el procedimiento de &#34;Inspección del sistema ESP<sup>&#174;</sup>&#34;? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70A4604001">Comprobación del sistema del ESP&#174;</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A4604017006">
<title>
Comprobación de DTC para el ESP&#174;
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70A4604005">Comprobación del DTC</intxref>
. 
</ptxt>
</test1>
<question>
¿Se ha detectado el DTC U0073 y/o U0100? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización de averías del DTC correspondiente. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A4604017007">
<title>
Comprobación del circuito y del interruptor de la luz de freno 
</title>
<test1>
<ptxt>
Inspeccione el interruptor de la luz de freno y su circuito; para ello, consulte los pasos del 2 al 4 de 
<intxref refid = "ASPAP70A1104040">DTC P0504</intxref>
. 
</ptxt>
</test1>
<question>
¿Son correctos los resultados de la comprobación? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o reemplace. 
</ptxt>
</action>
</testgroup>
