<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A1604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
El motor se recalienta (el ventilador del radiador no funciona) 
</title>
<diag type = "condition">
<condition>
<ptxt>
El motor se recalienta (el ventilador del radiador no funciona) 
</ptxt>
</condition>
<ps>
<ptxt>
Fusible fundido 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el fusible. 
</ptxt>
</action>
<ps>
<ptxt>
Relé del ventilador de refrigeración del radiador defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Revise el relé del ventilador de refrigeración del radiador. 
<intxreftitleoff1 refid = "ASPAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensor ECT defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el sensor ECT. 
<intxreftitleoff1 refid = "ASPAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motor del ventilador de refrigeración del radiador defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Revise el motor del ventilador de refrigeración del radiador. 
<intxreftitleoff1 refid = "ASPAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos 
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado. 
</ptxt>
</action>
<ps>
<ptxt>
ECM defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Verifique el ECM y su circuito. 
<intxreftitleoff1 refid = "ASPAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
