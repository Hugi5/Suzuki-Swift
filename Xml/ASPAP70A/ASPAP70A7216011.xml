<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A7216011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del resistor del motor del soplador 
</title>
<servinfosub id = "ASPAP70A7216011001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la guantera del panel de instrumentos. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conducto de aire para los pies del lado del pasajero (2) de la unidad HVAC; para ello, retire el tornillo (1). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A721036.jpg" width = "88.000mm" height = "94.268mm" ver = "01" gw = "199" gh = "251"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del resistor del motor del soplador (2) y después retire el resistor de la unidad HVAC, extrayendo los tornillos (3). 
</ptxt>
<figure>
<graphic graphicname = "I4RS0A710010.swf" width = "88.000mm" height = "53.049mm" ver = "01" gw = "183" gh = "134"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A7216011002">
<title>
Instalación 
</title>
<ptxt>
Invierta el procedimiento de extracción. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
