<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A7216029" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la persiana de ventilación central 
</title>
<servinfosub id = "ASPAP70A7216029001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la rejilla de ventilación central del panel de instrumentos. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del interruptor de luz de intermitente de emergencia. 
</ptxt>
</s1>
<s1>
<ptxt>
Retire los tubos (2) y, a continuación, extraiga la rejilla de ventilación central (1). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A721028.swf" width = "88.000mm" height = "58.762mm" ver = "02" gw = "215" gh = "150"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A7216029002">
<title>
Instalación 
</title>
<ptxt>
Invierta el procedimiento de extracción. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
