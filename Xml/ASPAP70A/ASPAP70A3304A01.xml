<title>
Ruido 
</title>
<diag type = "condition">
<condition>
<ptxt>
Ruido 
</ptxt>
</condition>
<ps>
<ptxt>
Lubricante inadecuado o insuficiente 
</ptxt>
</ps>
<action>
<ptxt>
Rellene. 
<intxreftitleoff1 refid = "ASPAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cojinetes dañados o desgastados 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace. 
<intxreftitleoff1 refid = "ASPAP70A3306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
