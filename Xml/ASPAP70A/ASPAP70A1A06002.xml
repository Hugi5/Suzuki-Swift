<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A1A06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la batería 
</title>
<servinfosub id = "ASPAP70A1A06002001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) (1) de la batería (4). 
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el cable positivo (+) (2) de la batería (4). 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el retén (3). 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la batería (4). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0001.swf" width = "88.000mm" height = "71.286mm" ver = "01" gw = "171" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga la bandeja de la batería (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el ECM (2). 
<intxreftitleoff1 refid = "ASPAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el soporte de la batería (3) si fuera necesario. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0002.jpg" width = "88.000mm" height = "55.738mm" ver = "02" gw = "199" gh = "141"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A1A06002002">
<title>
Instalación 
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete firmemente los cables de la batería. 
</ptxt>
</item>
<item>
<ptxt>
Inicialice los dispositivos eléctricos si es necesario. 
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
