<s1>
<ptxt>
Instale firmemente el nuevo anillo elástico (1) en la ranura. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Coloque el cojinete de agujas (2), aplíquele aceite y, a continuación, coloque el anillo sincronizador (3) y el engranaje de 4ª. 
</ptxt>
<figure>
<graphic graphicname = "I2RH01520052.swf" width = "88.000mm" height = "45.751mm" ver = "01" gw = "170" gh = "113"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
