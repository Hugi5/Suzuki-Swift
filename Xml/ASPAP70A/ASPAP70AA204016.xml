<servinfosub id = "ASPAP70AA204016003">
<title>
Procedimiento de confirmación del DTC 
</title>
<s1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</s1>
<s1>
<ptxt>
Coloque el interruptor de luz en la posición &#34;AUTO&#34;. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70AA204016004">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70AA204016005">
<testgroup id = "ASPAP70AA204016006">
<title>
Verificación de DTC 
</title>
<question>
¿Se ha detectado además el DTC B1132? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA204016009">
<title>
Comprobación de parámetros 
</title>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe el elemento &#34;Sensor Luz Auto&#34; que se muestra en la herramienta de escaneado SUZUKI. 
<intxreftitleoff1 refid = "ASPAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está en buenas condiciones? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Fin de la inspección. (Avería intermitente.) 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA204016007">
<title>
Comprobación del circuito del sensor de encendido automático de faros 
</title>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el conector &#34;G05&#34; y el del sensor de encendido automático de faros. 
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe que la conexión de los terminales al conector &#34;G05&#34; y al del sensor de encendido automático de faros es correcta. 
</ptxt>
</test1>
<test1>
<ptxt>
Si las conexiones son correctas, compruebe los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistencia de los circuitos &#34;A1&#34; y &#34;A2&#34;: menos de 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Resistencia entre el circuito &#34;A1&#34; y la masa: infinito 
</ptxt>
</item>
<item>
<ptxt>
Resistencia entre el circuito &#34;A2&#34; y la masa: infinito 
</ptxt>
</item>
<item>
<ptxt>
Resistencia entre los terminales del circuito &#34;A2&#34; y &#34;A3&#34; en el conector del sensor de encendido automático de faros: infinito 
</ptxt>
</item>
<item>
<ptxt>
Tensión de los circuitos &#34;A2&#34; y &#34;A3&#34;: 0 – 1 V (cuando el encendido está conectado (posición &#34;ON&#34;)) 
</ptxt>
</item>
</list1>
</test1>
<question>
¿Están en buenas condiciones? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA204016008">
<title>
Comprobación de sensor de encendido automático de faros 
</title>
<test1>
<ptxt>
Compruebe el sensor de encendido automático de faros. 
<intxreftitleoff1 refid = "ASPAP70A9206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está en buenas condiciones? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el sensor de encendido automático de faros. 
<intxreftitleoff1 refid = "ASPAP70A9206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA204016010">
<title>
Verificación de DTC 
</title>
<test1>
<ptxt>
Desconecte el encendido (posición “OFF”). 
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el conector del sensor de encendido automático de faros y &#34;G05&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se detecta el DTC B1148? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el BCM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (Avería intermitente.) 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
