<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A7224A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
No sale aire frío de forma intermitente 
</title>
<diag type = "condition">
<condition>
<ptxt>
No sale aire frío de forma intermitente 
</ptxt>
</condition>
<ps>
<ptxt>
Conexión del cableado defectuosa 
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado si es necesario. 
</ptxt>
</action>
<ps>
<ptxt>
Válvula de expansión, defectuosa 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione la válvula de expansión. 
<intxreftitleoff1 refid = "ASPAP70A7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Humedad excesiva en el sistema de A/C 
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el condensador y realice la evacuación y la carga. 
<intxreftitleoff1 refid = "ASPAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Embrague magnético defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el embrague magnético. 
<intxreftitleoff1 refid = "ASPAP70A7226047"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cantidad excesiva de refrigerante 
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la cantidad de refrigerante. 
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
