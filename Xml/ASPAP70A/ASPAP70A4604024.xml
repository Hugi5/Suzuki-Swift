<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A4604024" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1038
</title>
<servinfosub id = "ASPAP70A4604024001">
<title>
Condición de detección del DTC y área afectada 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.259in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.896in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1038: El sensor del ángulo de dirección detecta un fallo en el contador de rodillo
</emph>
</ptxt>
<ptxt>
El sensor del ángulo de dirección detecta datos CAN no válidos procedentes del módulo de control del ESP<sup>&#174;</sup>. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Circuito de comunicación CAN 
</ptxt>
</item>
<item>
<ptxt>
Sensor del ángulo de dirección 
</ptxt>
</item>
<item>
<ptxt>
Módulo de control ESP<sup>&#174;</sup>
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70A4604024002">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70A4604024003">
<testgroup id = "ASPAP70A4604024004">
<question>
¿Se ha llevado a cabo el procedimiento de &#34;Inspección del sistema ESP<sup>&#174;</sup>&#34;? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70A4604001">Comprobación del sistema del ESP&#174;</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A4604024005">
<title>
Verificación de DTC 
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70A4604005">Comprobación del DTC</intxref>
. 
</ptxt>
</test1>
<question>
¿Se detecta algún DTC distinto a C1038? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización de averías del DTC correspondiente. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A4604024006">
<title>
Comprobación del sensor del ángulo de dirección 
</title>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Reemplace el sensor del ángulo de la dirección. 
<intxreftitleoff1 refid = "ASPAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe el DTC. 
</ptxt>
</test1>
<question>
¿Se detecta el DTC C1038? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
