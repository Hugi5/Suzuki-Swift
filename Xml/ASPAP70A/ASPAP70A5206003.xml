<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Sustitución del sello de aceite lateral del diferencial 
</title>
<s1>
<ptxt>
Levante el vehículo y drene el aceite del transeje. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del eje impulsor izquierdo. 
<intxreftitleoff1 refid = "ASPAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el sello (1) de aceite con la herramienta especial. 
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
 09913-50121 
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522004.swf" width = "88.000mm" height = "48.454mm" ver = "01" gw = "146" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Instale el sello (1) de aceite nuevo utilizando la herramienta especial. 
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Asegúrese de instalar el lado del muelle del sello de aceite hacia el interior. 
</ptxt>
</item>
<item>
<ptxt>
Asegúrese de instalar el sello de aceite en la superficie de la caja izquierda (2) en paralelo. 
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
 09944-88220 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
 09924-74510 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Distancia entre la superficie de la caja y el sello de aceite 
</title>
<ptxt>
&#34;a&#34;: 0 – 1,0 mm (0 – 0,04 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Aplique grasa al borde del sello de aceite y compruebe la suavidad del eje impulsor en el lugar donde está en contacto con el sello de aceite. 
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B004" uid = "22">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasa
</m-desc>
<m-number>
 99000-25011 
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A522005.swf" width = "88.000mm" height = "44.718mm" ver = "02" gw = "110" gh = "110"/>
</figure>
</s1>
<s1>
<ptxt>
Inserte el conjunto del eje impulsor izquierdo. 
<intxreftitleoff1 refid = "ASPAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Añada aceite del transeje. 
<intxreftitleoff1 refid = "ASPAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
