<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A1104045" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0606
</title>
<servinfosub id = "ASPAP70A1104045001">
<title>
Condición de detección del DTC y área afectada 
</title>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.337in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.860in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Condición de detección del DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Área afectada 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0606: Procesador del módulo de control 
</emph>
</ptxt>
<ptxt>
Ha habido un fallo en el procesador interno del ECM. 
</ptxt>
<ptxt>
(Lógica de detección de 3 ciclos de conducción) 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Circuito de la alimentación eléctrica del ECM y/o circuito a masa 
</ptxt>
</item>
<item>
<ptxt>
Sensor A/F 
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70A1104045002">
<title>
Descripción del sistema 
</title>
<ptxt>
El módulo de control interno se instala en el ECM. 
</ptxt>
</servinfosub>
<servinfosub id = "ASPAP70A1104045003">
<title>
Procedimiento de confirmación del DTC 
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
En primer lugar, asegúrese de realizar la localización de averías de los DTC inesperados detectados previamente en el &#34;Procedimiento de confirmación del DTC&#34;. 
</ptxt>
</item>
<item>
<ptxt>
Compruebe que se cumplen las siguientes condiciones en este &#34;Procedimiento de confirmación del DTC&#34;. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tensión de la batería &#62; 10,7 V
</ptxt>
</item>
<item>
<ptxt>
No se detecta el DTC P0030, P0031, P0032, P0131 o P0132. 
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Haga funcionar el motor en régimen de ralentí durante 1 min.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A1104045004">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70A1104045005">
<testgroup id = "ASPAP70A1104045006">
<title>
Nueva comprobación del DTC. 
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el encendido (posición “OFF”). 
</ptxt>
</test1>
<test1>
<ptxt>
Realice el procedimiento de confirmación del DTC y verifíquelo. 
</ptxt>
</test1>
<question>
¿Se detecta todavía el DTC P0606? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Verifique los problemas intermitentes. 
<intxreftitleoff1 refid = "ASPAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A1104045007">
<title>
Verificación del circuito de masa y de la alimentación del ECM 
</title>
<test1>
<ptxt>
Compruebe el circuito de alimentación eléctrica y el circuito de masa del ECM. 
<intxreftitleoff1 refid = "ASPAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A1104045008">
<title>
Nueva comprobación del DTC. 
</title>
<test1>
<ptxt>
Reemplace el sensor A/F. 
<intxreftitleoff1 refid = "ASPAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Realice el procedimiento de confirmación del DTC y verifíquelo. 
</ptxt>
</test1>
<question>
¿Se detecta todavía el DTC P0606? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el ECM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
