<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70AA506008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la antena interior trasera 
</title>
<servinfosub id = "ASPAP70AA506008001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el embellecedor del extremo trasero. 
<intxreftitleoff1 refid = "ASPAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector de la antena interior trasera (1) y, a continuación, extraiga dicha antena (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50027.swf" width = "88.000mm" height = "59.203mm" ver = "01" gw = "175" gh = "151"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70AA506008002">
<title>
Instalación 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70AA506010">Inspección de la antena</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
