<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A7216032" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del filtro de aire de HVAC 
</title>
<servinfosub id = "ASPAP70A7216032001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Saque la guantera. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Retire la tapa del filtro de aire de HVAC (2) de la unidad de HVAC. 
</ptxt>
</s1>
<s1>
<ptxt>
Retire el filtro del aire (1) de la unidad de HVAC. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A721033.swf" width = "88.000mm" height = "53.307mm" ver = "01" gw = "219" gh = "135"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A7216032002">
<title>
Instalación 
</title>
<ptxt>
Para la instalación, invierta el procedimiento anterior de extracción, teniendo en cuenta los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Coloque el filtro de aire con la marca de la flecha (1) apuntando hacia arriba. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A721034.swf" width = "88.000mm" height = "48.728mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
