<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70AA324014" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1169
</title>
<servinfosub id = "ASPAP70AA324014001">
<title>
Condición de detección del DTC y área afectada 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1169: Fallo de registro 
</emph>
</ptxt>
<ptxt>
Fallo del registro del ECM o del mando a distancia. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Conector/circuito de la fuente de alimentación 
</ptxt>
</item>
<item>
<ptxt>
Conector/circuito de comunicación CAN 
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Módulo de control de arranque sin llave 
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70AA324014002">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70AA324014003">
<testgroup id = "ASPAP70AA324014004">
<title>
Verificación de DTC 
</title>
<question>
¿Se ha detectado algún DTC distinto del B1169? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA324014005">
<title>
Registro del ECM 
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70AA326003">Registro del ECM:Modelo con sistema de arranque por pulsación sin llave</intxref>
. 
</ptxt>
</test1>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1169? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el ECM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
