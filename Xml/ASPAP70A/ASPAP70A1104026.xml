<item>
<ptxt>
Sistema de admisión de aire 
</ptxt>
</item>
<item>
<ptxt>
Sistema de escape 
</ptxt>
</item>
<item>
<ptxt>
Sistema de combustible 
</ptxt>
</item>
<item>
