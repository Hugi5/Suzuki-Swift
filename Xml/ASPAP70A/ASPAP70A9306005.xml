<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A9306005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del sensor de estacionamiento (si el vehículo dispone de ello) 
</title>
<servinfosub id = "ASPAP70A9306005001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Extraiga el parachoques trasero. 
<intxreftitleoff1 refid = "ASPAP70A9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del sensor de estacionamiento. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta del sensor de estacionamiento (1) como se indica en la imagen. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A930025.jpg" width = "88.000mm" height = "106.836mm" ver = "01" gw = "208" gh = "286"/>
</figure>
</s1>
<s1>
<ptxt>
Abra las garras (1) y extraiga el sensor de estacionamiento (2), como se muestra en la imagen. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A930026.jpg" width = "88.000mm" height = "63.752mm" ver = "01" gw = "196" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Si es necesario, extraiga el soporte del sensor. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A9306005002">
<title>
Instalación 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A9306006">Inspección del sensor de estacionamiento (si el vehículo dispone de ello)</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Limpie y desengrase el área donde se instalará el soporte del sensor (1). 
</ptxt>
</item>
<item>
<ptxt>
Aplique imprimación (un equivalente de SUMITOMO 3M K-520 o 4298UV) en el área donde se instalará el soporte del sensor. 
</ptxt>
</item>
<item>
<ptxt>
Instale el soporte del sensor en la dirección que se muestra en la ilustración. 
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A930039.jpg" width = "88.000mm" height = "98.016mm" ver = "01" gw = "199" gh = "261"/>
<callout>
