<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A7224A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Flujo de aire frío insuficiente 
</title>
<diag type = "condition">
<condition>
<ptxt>
Flujo de aire frío insuficiente 
</ptxt>
</condition>
<ps>
<ptxt>
Evaporador del A/C atascado o congelado 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el sensor de temperatura del evaporador así como el evaporador del A/C en sí. 
<intxreftitleoff1 refid = "ASPAP70A7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 y 
<intxreftitleoff1 refid = "ASPAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fuga de aire en la unidad de HVAC o en el conducto de aire 
</ptxt>
</ps>
<action>
<ptxt>
Repare el conducto de aire o la unidad de HVAC. 
</ptxt>
</action>
<ps>
<ptxt>
Motor del soplador defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el motor del soplador. 
<intxreftitleoff1 refid = "ASPAP70A7226012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos 
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado si es necesario. 
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
