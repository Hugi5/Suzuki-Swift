<title>
DTC C1141 / C1142 / C1143 / C1145 
</title>
<servinfosub id = "ASPAP70A6304013001">
<title>
Condición de detección del DTC y área afectada 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
