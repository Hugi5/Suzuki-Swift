<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A1406016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del conjunto del motor 
</title>
<servinfosub id = "ASPAP70A1406016001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Libere la presión del combustible. 
<intxreftitleoff1 refid = "ASPAP70A1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la batería. 
<intxreftitleoff1 refid = "ASPAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte los conectores del ECM. 
<intxreftitleoff1 refid = "ASPAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el soporte de la batería con el ECM. 
<intxreftitleoff1 refid = "ASPAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las cubiertas inferiores derecha e izquierda del motor. 
</ptxt>
</s1>
<s1>
<ptxt>
Drene los siguientes aceites y líquidos, si es necesario. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Aceite de motor: 
<intxreftitleoff1 refid = "ASPAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Aceite de transeje manual: 
<intxreftitleoff1 refid = "ASPAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Aceite de la transferencia: 
<intxreftitleoff1 refid = "ASPAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Drene el refrigerante. 
<intxreftitleoff1 refid = "ASPAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del depurador de aire. 
<intxreftitleoff1 refid = "ASPAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Con la manguera conectada, saque de su soporte el compresor del A/C. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modelos con A/C manual: 
<intxreftitleoff1 refid = "ASPAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modelos con A/C automático: 
<intxreftitleoff1 refid = "ASPAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Cuelgue el compresor del A/C desmontado en un lugar donde no pueda estropearse durante los procesos de extracción y montaje del conjunto del motor. 
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Desconecte los siguientes cables eléctricos o conectores y sus abrazaderas: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Cable de masa de la batería (1) 
</ptxt>
</item>
<item>
<ptxt>
Conector es (2) en la caja de fusibles principal 
</ptxt>
</item>
<item>
<ptxt>
Conector del sensor de corriente de carga eléctrica (3) 
</ptxt>
</item>
<item>
<ptxt>
Conector (4) en la caja de fusibles del circuito individual n&#176; 1 
</ptxt>
<figure>
<graphic graphicname = "I9P60A141043.jpg" width = "88.000mm" height = "60.102mm" ver = "01" gw = "199" gh = "154"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Desconecte los cables siguientes: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Cable de control de selección de engranaje (1) 
</ptxt>
</item>
<item>
<ptxt>
Cable de control del cambio de engranaje (2) 
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140002.jpg" width = "88.000mm" height = "62.413mm" ver = "01" gw = "199" gh = "160"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte las siguientes mangueras: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manguera del servofreno (1) 
</ptxt>
</item>
<item>
<ptxt>
Mangueras de entrada y de salida (2) del radiador 
</ptxt>
</item>
<item>
<ptxt>
Tubos de entrada y salida del calentador (3) 
</ptxt>
</item>
<item>
<ptxt>
Manguera de alimentación de combustible (4) 
</ptxt>
</item>
<item>
<ptxt>
Manguera del líquido de embrague (5) 
<intxreftitleoff1 refid = "ASPAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140003.jpg" width = "88.000mm" height = "112.325mm" ver = "02" gw = "199" gh = "302"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Desconecte el eje inferior de dirección del eje del piñón. 
<intxreftitleoff1 refid = "ASPAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Retire las juntas de la barra estabilizadora de dicha barra. 
<intxreftitleoff1 refid = "ASPAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el extremo de la barra de acoplamiento del pivote de la dirección. 
<intxreftitleoff1 refid = "ASPAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte las juntas derecha e izquierda del eje propulsor del pivote de dirección. 
<intxreftitleoff1 refid = "ASPAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el tubo de escape n&#176; 1 y el tubo central de escape. 
<intxreftitleoff1 refid = "ASPAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del eje de transmisión. 
<intxreftitleoff1 refid = "ASPAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sujete el bastidor de la suspensión delantera (1), la caja del transeje (2) y el bloque de cilindros (3) mediante un gato. 
</ptxt>
</s1>
<s1>
<ptxt>
Quite los pernos del bastidor de la suspensión delantera (4). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A140004.jpg" width = "88.000mm" height = "55.276mm" ver = "01" gw = "199" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el perno (1) y las tuercas (2) del soporte de montaje izquierdo del motor. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A140005.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.309in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.280in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.253in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.280in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lado superior 
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lado inferior 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el perno (1) y las tuercas (2) del soporte de montaje derecho del motor. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A140006.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1>
<ptxt>
Antes de extraer el motor, asegúrese de que todas las mangueras, los cables eléctricos y los cables se hayan desconectado del motor. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Baje el motor con el transeje, el bastidor de la suspensión delantera, los ejes impulsores y el conjunto de la caja de engranajes de P/S a la vez. 
</ptxt>
<attention2>
<ptxt>
Antes de bajar el motor, y para evitar daños en el compresor del A/C, suspenda el compresor del A/C para dejar espacio libre entre él y el motor. 
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Desconecte el mazo de cables del motor y del transeje, si fuera necesario. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del eje impulsor delantero si es necesario. 
<intxreftitleoff1 refid = "ASPAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el bastidor de la suspensión delantera si fuera necesario. 
</ptxt>
</s1>
<s1>
<ptxt>
Si fuera necesario, extraiga la transferencia. 
<intxreftitleoff1 refid = "ASPAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el transeje del motor, si fuera necesario. 
<intxreftitleoff1 refid = "ASPAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la tapa y el disco del embrague, si fuera necesario. 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el volante, si es necesario. 
<intxreftitleoff1 refid = "ASPAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A1406016002" page = "2">
<title>
Instalación 
</title>
<s1>
<ptxt>
Si extrajo el volante, instálelo. 
<intxreftitleoff1 refid = "ASPAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Instale la tapa y el disco del embrague, en caso de que se haya extraído. 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Instale el transeje en el motor, en el caso de que haya sido extraído. 
<intxreftitleoff1 refid = "ASPAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Si extrajo la transferencia, instálela. 
<intxreftitleoff1 refid = "ASPAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Coloque el bastidor de la suspensión delantera en caso de que haya sido extraído. 
<intxreftitleoff1 refid = "ASPAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Instale el conjunto del eje impulsor delantero si se ha extraído. 
<intxreftitleoff1 refid = "ASPAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Coloque el mazo de cables del motor en el motor y el transeje y, a continuación, apriete el perno de masa del mazo de cables (1) al par especificado, si se ha extraído. 
</ptxt>
<torque>
<torqueitem id = "T1D008">
<t-part>
 Perno de masa del mazo de cables del motor 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 11 
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140007.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Suba el motor con el transeje, el bastidor de la suspensión delantera, los ejes impulsores y el conjunto de la caja de engranajes de P/S a la vez. 
</ptxt>
<attention2>
<ptxt>
Antes de elevar el motor, y para evitar daños en el compresor del A/C, suspenda el compresor del A/C para dejar espacio libre entre él y el motor. 
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Coloque el perno (1) y las tuercas (2) del soporte de montaje derecho del motor. 
</ptxt>
<torque>
<torqueitem id = "T1D009">
<t-part>
 Perno y tuerca del soporte de montaje de la derecha del motor 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 55 
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140008.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Apriete al par de apriete especificado los pernos (1) y las tuercas (2) del soporte de montaje izquierdo del motor. 
</ptxt>
<torque>
<torqueitem id = "T1D010">
<t-part>
 Perno y tuerca del soporte de montura izquierda del motor 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 55 
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140009.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.428in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.100in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.363in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.309in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lado superior 
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lado inferior 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Apriete los pernos del bastidor de la suspensión al par de apriete especificado. 
<intxreftitleoff1 refid = "ASPAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Instale el conjunto del eje de transmisión. 
<intxreftitleoff1 refid = "ASPAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Instale el tubo de escape n&#176;1 y el tubo central de escape. 
<intxreftitleoff1 refid = "ASPAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Conecte las juntas derecha e izquierda del eje propulsor al pivote de dirección. 
<intxreftitleoff1 refid = "ASPAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Conecte el extremo de la barra de acoplamiento del pivote de la dirección. 
<intxreftitleoff1 refid = "ASPAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Instale las juntas de la barra estabilizadora en dicha barra. 
<intxreftitleoff1 refid = "ASPAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Conecte el eje inferior de dirección del eje del piñón. 
<intxreftitleoff1 refid = "ASPAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Instale todos los demás cables eléctricos, conectores y mangueras que se desconectaron en sus ubicaciones originales. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Apriete el perno del terminal de la batería (1). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A141052.jpg" width = "88.000mm" height = "60.441mm" ver = "02" gw = "199" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Conecte el cable de control del cambio de marchas. 
<intxreftitleoff1 refid = "ASPAP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Instale el compresor del A/C en su soporte. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modelo de A/C manual 
<intxreftitleoff1 refid = "ASPAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modelo de A/C automático 
<intxreftitleoff1 refid = "ASPAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Instale la correa de transmisión del compresor del A/C. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modelos con A/C manual: 
<intxreftitleoff1 refid = "ASPAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modelos con A/C automático: 
<intxreftitleoff1 refid = "ASPAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Instale el conjunto del depurador de aire. 
<intxreftitleoff1 refid = "ASPAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Asegúrese de que todas las piezas extraídas se han vuelto a colocar en su lugar correspondiente. Vuelva a instalar las piezas necesarias que no han sido reinstaladas. 
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Rellene los siguientes aceites y líquidos, si es necesario. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Aceite de motor: 
