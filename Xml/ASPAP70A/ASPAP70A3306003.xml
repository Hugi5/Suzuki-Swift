<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A3306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Montaje y desmontaje de la transferencia 
</title>
<servinfosub id = "ASPAP70A3306003001">
<title>
Desmontaje 
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería. 
</ptxt>
</s1>
<s1>
<ptxt>
Drene los aceites siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Aceite de transeje manual: 
<intxreftitleoff1 refid = "ASPAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Aceite de la transferencia: 
<intxreftitleoff1 refid = "ASPAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del eje impulsor del lado derecho. 
<intxreftitleoff1 refid = "ASPAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el eje de transmisión. 
<intxreftitleoff1 refid = "ASPAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el bastidor de la suspensión delantera. 
<intxreftitleoff1 refid = "ASPAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el montaje trasero del motor y el soporte de montaje trasero del motor. 
<intxreftitleoff1 refid = "ASPAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el reforzador de la transferencia (2) y los pernos de la transferencia. 
</ptxt>
</s1>
<s1>
<ptxt>
Separe la transferencia (1) del transeje. 
</ptxt>
<attention1>
<ptxt>
Cuando desmonte la transferencia, tenga cuidado para que no se caiga. De lo contrario, puede dañarse la transferencia y causar daños personales. 
</ptxt>
</attention1>
<figure>
<graphic graphicname = "IAP70A330004.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "213" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el anillo en O (1) y el pasador de posicionamiento (2). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A330005.jpg" width = "88.000mm" height = "52.680mm" ver = "01" gw = "213" gh = "133"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASPAP70A3306003002">
<title>
Montaje 
</title>
<ptxt>
Invierta el procedimiento de desmontaje, teniendo en cuenta los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Utilice un anillo en O y una tuerca del eje impulsor nuevos. 
</ptxt>
</item>
<item>
<ptxt>
Aplique grasa al anillo en O (1). 
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C004" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Grasa
</m-desc>
<m-number>
 99000-25011 
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A330006.jpg" width = "88.000mm" height = "50.958mm" ver = "02" gw = "213" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Apriete los pernos de la transferencia al par de apriete especificado. 
</ptxt>
<torque>
<torqueitem id = "T3C004">
<t-part>
 Perno de la transferencia 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 88 
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Apriete los pernos del reforzador de la transferencia como se indica a continuación. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Apriete los pernos del reforzador de la transferencia &#34;2&#34; y &#34;3&#34; con la mano. 
</ptxt>
</item>
<item>
<ptxt>
Empuje el reforzador de la transferencia contra la transferencia y apriete los pernos del reforzador de la transferencia al par de apriete especificado de un modo uniforme y gradual, y siguiendo un orden numérico (&#34;1&#34; – &#34;5&#34;). 
</ptxt>
<torque>
<torqueitem id = "T3C005">
<t-part>
 Perno del reforzador de la transferencia* 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
 55 
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330007.jpg" width = "88.000mm" height = "56.283mm" ver = "01" gw = "213" gh = "143"/>
</figure>
<figure>
<graphic graphicname = "IAP70A330008.jpg" width = "88.000mm" height = "55.083mm" ver = "01" gw = "202" gh = "140"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Apriete los pernos y las tuercas siguientes al par de apriete especificado. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Perno del montaje trasero del motor y perno del soporte: 
<intxreftitleoff1 refid = "ASPAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Perno de montaje del bastidor de la suspensión delantera: 
<intxreftitleoff1 refid = "ASPAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Asegúrese de utilizar un perno de montaje del bastidor de la suspensión nuevo. 
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Tuerca de junta del estabilizador: 
<intxreftitleoff1 refid = "ASPAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Perno de la junta esférica del brazo de suspensión: 
<intxreftitleoff1 refid = "ASPAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tuerca del extremo de la barra de acoplamiento: 
<intxreftitleoff1 refid = "ASPAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Perno del sensor de velocidad de la rueda delantera: 
<intxreftitleoff1 refid = "ASPAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Perno del eje de transmisión: 
<intxreftitleoff1 refid = "ASPAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tuerca del soporte central: 
<intxreftitleoff1 refid = "ASPAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Perno del tubo de escape: 
<intxreftitleoff1 refid = "ASPAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Perno de refuerzo del tubo de escape n&#176; 1: 
<intxreftitleoff1 refid = "ASPAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tuerca del eje impulsor: 
<intxreftitleoff1 refid = "ASPAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Asegúrese de utilizar una tuerca nueva para el eje impulsor. 
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Tuerca de rueda: 
<intxreftitleoff1 refid = "ASPAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Calafatee la tuerca del eje impulsor. 
<intxreftitleoff1 refid = "ASPAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Añada los aceites siguientes. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Aceite de transeje manual: 
<intxreftitleoff1 refid = "ASPAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
	Aceite de la transferencia: 
<intxreftitleoff1 refid = "ASPAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Verifique que en las conexiones no hay fugas de aceite ni de gases del escape. 
</ptxt>
</item>
<item>
<ptxt>
Compruebe la alineación de las ruedas delanteras. 
<intxreftitleoff1 refid = "ASPAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
