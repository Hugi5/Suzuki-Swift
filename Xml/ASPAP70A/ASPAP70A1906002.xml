<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A1906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del motor de arranque 
</title>
<servinfosub id = "ASPAP70A1906002001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el colector de admisión. 
<intxreftitleoff1 refid = "ASPAP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el soporte del sensor de detonación (1) del bloque de cilindros. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A190003.swf" width = "88.000mm" height = "58.388mm" ver = "01" gw = "172" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte el cable conductor del interruptor magnético (1) y el cable del motor de arranque (2) desde el motor de arranque. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los pernos de montaje del motor de arranque (3). 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el motor de arranque (4). 
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A190005.swf" width = "183.000mm" height = "82.031mm" ver = "02" gw = "405" gh = "216"/>
</figure>
</servinfosub>
<servinfosub id = "ASPAP70A1906002002">
<title>
Instalación 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A1906009">Inspección del motor de arranque</intxrefpoff>
</ptxt>
<ptxt>
Invierta los procedimientos de desmontaje teniendo en cuenta los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete los pernos de montaje del motor de arranque y la tuerca del cable del motor de arranque al par de apriete especificado. 
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1I001">
<t-part>
 Tuerca del cable del motor de arranque 
</t-part>
<t-value1>
 11 
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1I002">
<t-part>
 Perno de montaje del motor de arranque 
</t-part>
<t-value1>
 45 
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
