<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Bamboleo, sacudida o vibración 
</title>
<diag type = "condition">
<condition>
<ptxt>
Bamboleo, sacudida o vibración 
</ptxt>
</condition>
<ps>
<ptxt>
Rueda desequilibrada 
</ptxt>
</ps>
<action>
<ptxt>
Equilibre las ruedas o sustituya los neumáticos y/o las ruedas. 
</ptxt>
</action>
<ps>
<ptxt>
Cojinetes de la rueda flojos 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace los cojinetes de rueda. 
<intxreftitleoff1 refid = "ASPAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Extremos de la barra de acoplamiento desgastados 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace los extremos de la barra de acoplamiento. 
<intxreftitleoff1 refid = "ASPAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Juntas del brazo de suspensión desgastadas 
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el brazo de la suspensión. 
<intxreftitleoff1 refid = "ASPAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Descentramiento excesivo en el neumático o la rueda 
</ptxt>
</ps>
<action>
<ptxt>
Repare o reemplace la rueda y/o el neumático. 
</ptxt>
</action>
<ps>
<ptxt>
Abolladura o deformación en el neumático 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el neumático. 
<intxreftitleoff1 refid = "ASPAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Desviación radial excesiva del conjunto de las ruedas o los neumáticos 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el neumático o la rueda. 
</ptxt>
</action>
<ps>
<ptxt>
Alineación de las ruedas desajustada 
</ptxt>
</ps>
<action>
<ptxt>
Compruebe y ajuste la alineación de las ruedas. 
<intxreftitleoff1 refid = "ASPAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Varillaje de la dirección flojo o desgastado 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el sistema de dirección. 
<intxreftitleoff1 refid = "ASPAP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pernos flojos de la caja de engranajes de dirección 
</ptxt>
</ps>
<action>
<ptxt>
Apriete los pernos de la caja de engranajes de dirección. 
<intxreftitleoff1 refid = "ASPAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
