<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A7226026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del actuador de control del flujo de aire 
</title>
<servinfosub id = "ASPAP70A7226026001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desactive el sistema de airbag. 
<intxreftitleoff1 refid = "ASPAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la cubierta del orificio de la columna de dirección. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el módulo del airbag (inflador) de rodillas. 
<intxreftitleoff1 refid = "ASPAP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la columna de la dirección. 
<intxreftitleoff1 refid = "ASPAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del pedal del freno. 
<intxreftitleoff1 refid = "ASPAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los tornillos (1) y, a continuación, extraiga el actuador de control de flujo de aire (2). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A722011.jpg" width = "88.000mm" height = "63.150mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A7226026002">
<title>
Instalación 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A7226027">Inspección del actuador de control del flujo de aire:Tipo automático</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento anterior teniendo en cuenta los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Introduzca el pasador de la articulación (2) en el orificio (1) del brazo del actuador de control de flujo de aire. 
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722012.swf" width = "88.000mm" height = "68.493mm" ver = "02" gw = "234" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
