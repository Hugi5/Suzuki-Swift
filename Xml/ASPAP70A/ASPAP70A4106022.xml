<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del servofreno 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A4106020">Componentes del servofreno</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70A4106022001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desconecte los tubos de freno (1) del conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> (2) con la herramienta especial. 
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
 09950-78220 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410035.swf" width = "88.000mm" height = "45.139mm" ver = "02" gw = "117" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el conjunto del cilindro maestro de freno del servofreno. 
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte la manguera de vacío del servofreno. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el clip (1) y el pasador de horquilla (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A410036.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Quite las tuercas del servofreno (1) y, a continuación, extraiga el servofreno del panel del salpicadero. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A410037.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A4106022004">
<title>
Instalación 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A4106023">Inspección del servofreno</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Afloje la tuerca del soporte del pedal del freno (1) y el perno de refuerzo superior del cubretableros (2). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Coloque el servofreno en el panel del salpicadero. A continuación, conecte la horquilla de la varilla de empuje (3) al brazo del pedal del freno con el pasador de horquilla (2) y el clip (1). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A410040.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Retire el tablero de instrumentos. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Apriete las tuercas del servofreno al par de apriete especificado. 
</ptxt>
<torque>
<torqueitem id = "T4A006">
<t-part>
 Tuerca del servofreno* 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410041.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Apriete las tuercas del soporte del pedal del freno al par de apriete especificado. 
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
 Tuerca del soporte del pedal del freno 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Apriete el perno de refuerzo superior del capó al par de apriete especificado. 
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
 Perno de refuerzo superior del capó 
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
 13 
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410042.swf" width = "88.000mm" height = "64.412mm" ver = "02" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Instale el tablero de instrumentos. 
</ptxt>
</s1>
<s1>
<ptxt>
Conecte la manguera de vacío en el servofreno. 
</ptxt>
</s1>
<s1>
<ptxt>
Instale el conjunto del cilindro maestro de freno en el servofreno. 
</ptxt>
</s1>
<s1>
<ptxt>
Conecte los tubos de freno (1) al conjunto de la unidad hidráulica/módulo de control del ESP<sup>&#174;</sup> (2) con la herramienta especial. 
</ptxt>
<torque>
<torqueitem id = "T4A009">
<t-part>
 Tuerca abocinada de tubo de freno 
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
 19 
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
 09950-78220 
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410043.swf" width = "88.000mm" height = "46.684mm" ver = "02" gw = "119" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Después de la instalación, purgue el sistema de frenos. 
<intxreftitleoff1 refid = "ASPAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Compruebe si las piezas instaladas presentan fugas de líquido de frenos. 
</ptxt>
</s1>
<s1>
<ptxt>
Compruebe el juego del pedal del freno. 
<intxreftitleoff1 refid = "ASPAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Asegúrese de que el sistema de frenos funcione correctamente y compruebe si hay fugas de líquido de frenos. 
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
