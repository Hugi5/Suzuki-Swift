<servinfo servinfosgmlid = "ASPAP70A9806011" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Extracción y montaje del forro interior del techo 
</title>
<servinfosub id = "ASPAP70A9806011001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desactive el sistema de airbag. 
<intxreftitleoff1 refid = "ASPAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga las viseras (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la luz personal (si el vehículo dispone de ella) (3) y la luz del techo (2). 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Luz personal (si el vehículo dispone de ella): 
<intxreftitleoff1 refid = "ASPAP70A9206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Luz del techo: 
<intxreftitleoff1 refid = "ASPAP70A9206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga los siguientes embellecedores. 
<intxreftitleoff1 refid = "ASPAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Embellecedores del pilar delantero 
</ptxt>
</item>
<item>
<ptxt>
Embellecedores superiores del pilar central 
</ptxt>
</item>
<item>
<ptxt>
Embellecedores superiores e inferiores laterales traseros 
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Extraiga las asas auxiliares (4). 
</ptxt>
</s1>
<s1>
<ptxt>
Para los modelos con techo solar, extraiga el embellecedor del techo solar (5). 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga los clips y extraiga el forro interior del techo (6). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A980008.jpg" width = "183.000mm" height = "158.326mm" ver = "01" gw = "488" gh = "432"/>
