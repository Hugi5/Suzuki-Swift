<ptxt>
Detecte la avería y repare. 
<intxreftitleoff1 refid = "ASPAP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
