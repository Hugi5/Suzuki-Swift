<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A1104073" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P0602
</title>
<servinfosub id = "ASPAP70A1104073001">
<title>
Condición de detección del DTC y área afectada 
</title>
<attention3>
<ptxt>
Si, después de ejecutar la reprogramación del ECM, se emite el DTC P0602, es posible que la reprogramación del ECM no se haya completado correctamente.
</ptxt>
</attention3>
<table frame = "all" colsep = "1" rowsep = "1" pgwide = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.602in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.602in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Condición de detección del DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Área afectada 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0602: Error de programación del módulo de control
</emph>
</ptxt>
<ptxt>
Fallo interno del ECM o error de programación del ECM
</ptxt>
<ptxt>
(Lógica de detección de 1 ciclos de conducción) 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Fallo de reprogramación del ECM
</ptxt>
</item>
<item>
<ptxt>
Circuito de alimentación eléctrica y/o circuito de masa del ECM
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70A1104073002">
<title>
Procedimiento de confirmación del DTC 
</title>
<s1>
<ptxt>
Coloque el interruptor de encendido en la posición ON durante 10 segundos.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A1104073003">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70A1104073005">
<testgroup id = "ASPAP70A1104073006">
<title>
Nueva comprobación del DTC. 
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Coloque el interruptor de encendido en la posición OFF.
</ptxt>
</test1>
<test1>
<ptxt>
Realice el procedimiento de confirmación del DTC y verifíquelo. 
</ptxt>
</test1>
<question>
¿Se detecta todavía el DTC P0602? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Verifique los problemas intermitentes. 
<intxreftitleoff1 refid = "ASPAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A1104073007">
<title>
Verificación de la reprogramación del ECM
</title>
<question>
¿Se ha ejecutado la reprogramación del ECM?
</question>
<result type = "yes"/>
<action>
<ptxt>
Vuelva a ejecutar correctamente la reprogramación del ECM.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A1104073008">
<title>
Comprobación del circuito de alimentación y del circuito de masa del ECM
</title>
<test1>
<ptxt>
Compruebe los circuitos de masa y de alimentación del ECM. 
<intxreftitleoff1 refid = "ASPAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el ECM por uno que se encuentre en buen estado y vuelva a realizar la inspección. 
<intxreftitleoff1 refid = "ASPAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
