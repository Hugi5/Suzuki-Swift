<servinfosub id = "ASPAP70A9304004003">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70A9304004004">
<testgroup id = "ASPAP70A9304004005">
<title>
Verificación de DTC 
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1802? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Verifique los problemas intermitentes. 
<intxreftitleoff1 refid = "ASPAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A9304004006">
<title>
Inspección de los circuitos de la alimentación eléctrica y a masa del juego de instrumentos 
</title>
<test1>
<ptxt>
Inspeccione los circuitos de alimentación y a masa del juego de instrumentos. 
<intxreftitleoff1 refid = "ASPAP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Están en buenas condiciones? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare el mazo de cables defectuoso. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A9304004007">
<title>
Verificación de la tensión de la alimentación eléctrica del juego de instrumentos 
</title>
<test1>
<ptxt>
Compruebe la tensión de la alimentación eléctrica a un régimen del motor de 3.000 rpm. 
</ptxt>
</test1>
<question>
¿La tensión es de 10 – 15 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el juego de instrumentos y vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Inspeccione el sistema de carga. 
<intxreftitleoff1 refid = "ASPAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
