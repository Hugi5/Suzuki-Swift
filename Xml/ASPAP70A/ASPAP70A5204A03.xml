<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A5204A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ruido 
</title>
<diag type = "condition">
<condition>
<ptxt>
Ruido 
</ptxt>
</condition>
<ps>
<ptxt>
Lubricante inadecuado o insuficiente 
</ptxt>
</ps>
<action>
<ptxt>
Añada aceite del transeje manual. 
</ptxt>
</action>
<ps>
<ptxt>
Cojinetes dañados o desgastados 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sustituya el cojinete. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Cojinete izquierdo del contraeje: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Anillo-guía interior: 
<intxreftitleoff1 refid = "ASPAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Anillo-guía exterior: 
<intxreftitleoff1 refid = "ASPAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Cojinete derecho del contraeje: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Anillo-guía interior: 
<intxreftitleoff1 refid = "ASPAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Anillo-guía exterior: 
<intxreftitleoff1 refid = "ASPAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Cojinete derecho y cojinete izquierdo del eje de entrada: 
<intxreftitleoff1 refid = "ASPAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Cojinete lateral del diferencial: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Anillo-guía interior: 
<intxreftitleoff1 refid = "ASPAP70A5206025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Anillo-guía exterior del lado derecho: 
<intxreftitleoff1 refid = "ASPAP70A5206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Anillo-guía exterior del lado izquierdo: 
<intxreftitleoff1 refid = "ASPAP70A5206017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
<item>
<ptxt>
Cojinete de agujas: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Engranaje de 1ª y engranaje de 2ª del contraeje: 
<intxreftitleoff1 refid = "ASPAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Engranaje de 3ª y engranaje de 4ª del eje de entrada: 
<intxreftitleoff1 refid = "ASPAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Engranaje de 5ª: 
<intxreftitleoff1 refid = "ASPAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
</list1>
</action>
<ps>
<ptxt>
Engranajes dañados o desgastados 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sustituya el engranaje. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Engranaje de 1ª, engranaje de 2ª, engranaje de 3ª y engranaje de 4ª del contraeje: 
<intxreftitleoff1 refid = "ASPAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Engranaje de 1ª, engranaje de 2ª, engranaje de 3ª y engranaje de 4ª del eje de entrada: 
<intxreftitleoff1 refid = "ASPAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Engranaje de 5ª del eje de entrada y engranaje de 5ª del contraeje: 
<intxreftitleoff1 refid = "ASPAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Piezas del sincronizador dañadas o desgastadas 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sustituya las piezas del sincronizador. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Piezas del sincronizador de baja velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Piezas del sincronizador de alta velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Piezas del sincronizador de 5ª velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
