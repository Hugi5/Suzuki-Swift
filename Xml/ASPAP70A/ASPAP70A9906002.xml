<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A9906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del conjunto del techo solar 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A9906001">Componentes del techo solar</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70A9906002001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Extraiga el forro del techo. 
<intxreftitleoff1 refid = "ASPAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el cristal del techo solar. 
<intxreftitleoff1 refid = "ASPAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte las mangueras de drenaje (1) conectadas al conjunto del techo solar en 4 lugares. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990005.jpg" width = "88.000mm" height = "75.169mm" ver = "01" gw = "227" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Desconecte el conector del motor del techo solar (1). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990006.jpg" width = "88.000mm" height = "69.556mm" ver = "01" gw = "225" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Desprende las abrazaderas (1) y el mazo de cables del techo solar (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990007.jpg" width = "88.000mm" height = "61.392mm" ver = "01" gw = "227" gh = "158"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga las tuercas (1) del alojamiento del techo solar, y a continuación, extraiga el conjunto del techo solar (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990008.jpg" width = "88.000mm" height = "83.554mm" ver = "01" gw = "227" gh = "220"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "ASPAP70A9906002002">
<title>
Instalación 
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apriete cada pieza al par de apriete especificado; para ello, consulte 
<intxref refid = "ASPAP70A9906001">Componentes del techo solar</intxref>
. 
</ptxt>
</item>
<item>
<ptxt>
Apriete las tuercas (1) del alojamiento del techo solar en el orden (de &#34;1&#34; a &#34;4&#34;) que se muestra en la imagen. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990009.jpg" width = "88.000mm" height = "82.828mm" ver = "01" gw = "227" gh = "218"/>
</figure>
</item>
<item>
<ptxt>
Conecte las mangueras de drenaje (1) al conjunto del techo solar en 4 lugares. Conecte firmemente las mangueras de drenaje con las abrazaderas (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A990010.jpg" width = "88.000mm" height = "75.168mm" ver = "01" gw = "227" gh = "197"/>
</figure>
<figure>
<title>
Columna delantera 
</title>
<graphic graphicname = "I9P60A990011.swf" width = "88.000mm" height = "95.842mm" ver = "02" gw = "210" gh = "255"/>
</figure>
<figure>
<title>
Panel lateral trasero 
</title>
<graphic graphicname = "I9P60A990013.swf" width = "88.000mm" height = "94.869mm" ver = "03" gw = "225" gh = "252"/>
</figure>
</item>
<item>
<ptxt>
Inicialice el motor del techo solar. 
<intxreftitleoff1 refid = "ASPAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Después de haber reinstalado el conjunto del techo solar, cerciórese de ajustar el cristal. 
<intxreftitleoff1 refid = "ASPAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
