<servinfosub id = "ASPAP70AA204017002">
<title>
Procedimiento de confirmación del DTC 
</title>
<s1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el encendido (posición “OFF”). 
</ptxt>
</s1>
<s1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70AA204017003">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70AA204017004">
<testgroup id = "ASPAP70AA204017005">
<title>
Nueva comprobación del DTC. 
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70AA204017002">Procedimiento de confirmación del DTC </intxref>
 y vuelva a comprobar el DTC. 
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1157? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (El airbag se ha desplegado en el pasado. [No se borró el DTC]) 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA204017006">
<title>
Nueva comprobación del DTC. 
</title>
<test1>
<ptxt>
Reemplace el SDM. 
<intxreftitleoff1 refid = "ASPAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70AA204017002">Procedimiento de confirmación del DTC </intxref>
 y vuelva a comprobar el DTC. 
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1157? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el BCM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (El SDM estaba defectuoso) 
</ptxt>
</action>
</testgroup>
