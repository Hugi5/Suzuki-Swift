<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A9706002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del asiento delantero 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A9706001">Componentes de los asientos delanteros</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70A9706002001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desactive el sistema de airbag. 
<intxreftitleoff1 refid = "ASPAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte los conectores del asiento delantero. 
</ptxt>
</s1>
<s1>
<ptxt>
Quite los 4 pernos de montaje y extraiga el conjunto del asiento. 
</ptxt>
</s1>
<s1>
<ptxt>
Desmonte y repare las piezas, si es necesario. 
<intxreftitleoff1 refid = "ASPAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A9706002002">
<title>
Instalación 
</title>
<ptxt>
Invierta el procedimiento anterior de desmontaje, teniendo en cuenta los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Consulte el par de apriete en 
<intxref refid = "ASPAP70A9706001">Componentes de los asientos delanteros</intxref>
. 
</ptxt>
</item>
<item>
<ptxt>
Active el sistema de airbag. 
<intxreftitleoff1 refid = "ASPAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
