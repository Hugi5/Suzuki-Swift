<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A3204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ruido en el engranaje 
</title>
<diag type = "condition">
<condition>
<ptxt>
Ruido en el engranaje 
</ptxt>
</condition>
<ps>
<ptxt>
Lubricante deteriorado o agua mezclada con lubricante 
</ptxt>
</ps>
<action>
<ptxt>
Repare y rellene. 
<intxreftitleoff1 refid = "ASPAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lubricante inadecuado o insuficiente 
</ptxt>
</ps>
<action>
<ptxt>
Repare y rellene. 
<intxreftitleoff1 refid = "ASPAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Holgura entre el engranaje y el piñón biselado desajustada 
</ptxt>
</ps>
<action>
<ptxt>
Ajuste según se indica. 
<intxreftitleoff1 refid = "ASPAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Contacto inadecuado de dientes en el engranaje entre el piñón cónico y el engranaje 
</ptxt>
</ps>
<action>
<ptxt>
Ajuste o sustituya. 
<intxreftitleoff1 refid = "ASPAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pernos de sujeción del engranaje cónico flojos 
</ptxt>
</ps>
<action>
<ptxt>
Cámbielos o ajústelos. 
<intxreftitleoff1 refid = "ASPAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Engranajes laterales o piñones del diferencial dañados 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace. 
<intxreftitleoff1 refid = "ASPAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
