<graphic graphicname = "IAP70A330026.swf" width = "88.000mm" height = "52.535mm" ver = "01" gw = "146" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el cojinete de rodillos cónicos trasero (1) junto con el espaciador (2). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A330027.jpg" width = "88.000mm" height = "47.505mm" ver = "01" gw = "200" gh = "118"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el anillo-guía exterior delantero (1) y el anillo-guía exterior trasero (2) con una barra de latón (3). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A330028.swf" width = "88.000mm" height = "40.911mm" ver = "01" gw = "167" gh = "99"/>
</figure>
</s1>
