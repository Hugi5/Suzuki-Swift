<graphic graphicname = "IAP70A330023.swf" width = "88.000mm" height = "50.374mm" ver = "01" gw = "139" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga la brida de salida de la transferencia (1) con la herramienta especial. 
</ptxt>
<servicetool>
<servicetoolitem id = "L3C024">
<s-part>
