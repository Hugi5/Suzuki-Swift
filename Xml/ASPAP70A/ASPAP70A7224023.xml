<servinfosub id = "ASPAP70A7224023003">
<title>
Procedimiento de confirmación del DTC 
</title>
<s1>
<ptxt>
Arranque el motor y después ponga en marcha el sistema de A/C. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A7224023004">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70A7224023005">
<testgroup id = "ASPAP70A7224023006">
<title>
Verificación de DTC 
</title>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el encendido (posición &#34;OFF&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;) y compruebe el DTC. 
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1540? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Problema intermitente. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A7224023008">
<title>
Inspección del fusible 
</title>
<test1>
<ptxt>
Inspeccione el fusible &#34;MTR&#34;. 
</ptxt>
</test1>
<question>
¿Está en buenas condiciones? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el fusible &#34;MTR&#34; y verifique si se ha producido un cortocircuito a masa. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A7224023007">
<title>
Inspección del circuito de suministro de tensión de la batería 
</title>
<test1>
<ptxt>
Desconecte el conector del panel del A/C automático. 
</ptxt>
</test1>
<test1>
<ptxt>
Mida la tensión entre el terminal del cable &#34;WHT/RED&#34; del conector del panel del A/C automático y la masa. 
</ptxt>
</test1>
<question>
¿La tensión es de 10 – 14 V? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el panel del A/C automático. 
<intxreftitleoff1 refid = "ASPAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el mazo de cables del panel de instrumentos. 
</ptxt>
</action>
</testgroup>
