<servinfosub id = "ASPAP70AA314013002">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70AA314013003">
<testgroup id = "ASPAP70AA314013004">
<title>
Entrada de la contraseña del inmovilizador 
</title>
<test1>
<ptxt>
Vuelva a introducir la contraseña del inmovilizador. 
</ptxt>
</test1>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1168? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vuelva a comprobar la contraseña del inmovilizador. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (Se ha introducido una contraseña incorrecta) 
</ptxt>
</action>
</testgroup>
