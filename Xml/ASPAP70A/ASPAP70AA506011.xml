<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70AA506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del receptor de entrada sin llave 
</title>
<servinfosub id = "ASPAP70AA506011001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la caja de la consola central. 
<intxreftitleoff1 refid = "ASPAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector del receptor de entrada sin llave (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el tornillo (3) y, a continuación, el receptor de entrada sin llave (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50030.swf" width = "88.000mm" height = "77.203mm" ver = "01" gw = "202" gh = "202"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70AA506011002">
<title>
Instalación 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70AA506012">Inspección del receptor de entrada sin llave</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
