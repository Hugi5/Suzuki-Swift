<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A1A04A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Batería descargada 
</title>
<ptxt>
Los problemas en el sistema de carga se manifestarán a través de una o varias de las situaciones siguientes: 
</ptxt>
<servinfosub id = "ASPAP70A1A04002003">
<title>
Fallo de la carga de la batería 
</title>
<diag type = "condition">
<condition>
<ptxt>
Batería descargada 
</ptxt>
</condition>
<ps>
<ptxt>
Correa de transmisión suelta o desgastada 
</ptxt>
</ps>
<action>
<ptxt>
Ajuste o sustituya la correa de transmisión. 
<intxreftitleoff1 refid = "ASPAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Terminal de batería flojo o corroído 
</ptxt>
</ps>
<action>
<ptxt>
Apriete el terminal de la batería o sustituya la batería. 
<intxreftitleoff1 refid = "ASPAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rectificador, rotor y/o regulador de IC defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el generador. 
<intxreftitleoff1 refid = "ASPAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
