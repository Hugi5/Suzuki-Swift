<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A5304A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Arrastre del embrague 
</title>
<diag type = "condition">
<condition>
<ptxt>
Arrastre del embrague 
</ptxt>
</condition>
<ps>
<ptxt>
Recorrido libre del pedal de embrague incorrecto 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Reemplace el brazo del pedal de embrague y/o el cilindro maestro del embrague. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Brazo del pedal de embrague: 
<intxreftitleoff1 refid = "ASPAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Cilindro maestro del embrague: 
<intxreftitleoff1 refid = "ASPAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Muelle del diafragma debilitado o punta del muelle desgastada. 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace la tapa del embrague. 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Estría del eje de entrada oxidada 
</ptxt>
</ps>
<action>
<ptxt>
Lubrique la estría del eje de entrada. 
</ptxt>
</action>
<ps>
<ptxt>
Estría del eje de entrada del transeje desgastada o dañada. 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el eje de entrada. 
<intxreftitleoff1 refid = "ASPAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disco de embrague excesivamente suelto 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Forros del disco de embrague aceitosos o rotos. 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pérdida de líquido 
</ptxt>
</ps>
<action>
<ptxt>
Repare o reemplace el sistema del embrague. 
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
