<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A6104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Funcionamiento irregular de la dirección al frenar 
</title>
<diag type = "condition">
<condition>
<ptxt>
Funcionamiento irregular de la dirección al frenar 
</ptxt>
</condition>
<ps>
<ptxt>
Cojinetes de rueda desgastados 
</ptxt>
</ps>
<action>
<ptxt>
Sustituya los cojinetes de rueda. 
<intxreftitleoff1 refid = "ASPAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Muelle helicoidal roto o hundido 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el muelle helicoidal. 
<intxreftitleoff1 refid = "ASPAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Conjunto del puntal delantero defectuoso (amortiguador) 
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el conjunto del puntal delantero (amortiguador). 
<intxreftitleoff1 refid = "ASPAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Presión desigual de los neumáticos 
</ptxt>
</ps>
<action>
<ptxt>
Ajuste la presión de inflado de los neumáticos. 
</ptxt>
</action>
<ps>
<ptxt>
Desajuste de la alineación de las ruedas delanteras 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione y ajuste la alineación de las ruedas delanteras. 
<intxreftitleoff1 refid = "ASPAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Los frenos no se accionan simultáneamente 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione y repare el sistema de frenos. 
<intxreftitleoff1 refid = "ASPAP70A4101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disco de freno delantero manchado con líquido de frenos 
</ptxt>
</ps>
<action>
<ptxt>
Repare o sustituya el disco del freno delantero. 
<intxreftitleoff1 refid = "ASPAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disco de freno deformado 
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el disco de freno delantero. 
<intxreftitleoff1 refid = "ASPAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Pastilla de freno considerablemente desgastada 
</ptxt>
</ps>
<action>
<ptxt>
Sustituya la pastilla del freno delantero. 
<intxreftitleoff1 refid = "ASPAP70A4206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
