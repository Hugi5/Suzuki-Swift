<diag type = "test" id = "ASPAP70A7224020007">
<testgroup id = "ASPAP70A7224020008">
<title>
Comprobación de los parámetros de la herramienta de escaneado 
</title>
<test1>
<ptxt>
Compruebe &#34;Sen pos mez aire&#34; con el modo &#34;Lista de Datos&#34; de la herramienta de escaneado SUZUKI. 
<intxreftitleoff1 refid = "ASPAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está en buenas condiciones? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Problema intermitente. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A7224020009">
<title>
Comprobación del circuito del actuador de control de temperatura 
</title>
<test1>
<ptxt>
Desconecte el conector &#34;G20&#34; y el conector del actuador de control de temperatura. 
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe los puntos siguientes. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistencia de los circuitos de los cables &#34;GRY&#34; y &#34;LT BLU&#34;: menos de 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Resistencia de los circuitos de los cables &#34;GRY&#34; y &#34;LT BLU&#34; entre el actuador de control de temperatura y la conexión a masa: infinito 
</ptxt>
</item>
</list1>
</test1>
<question>
¿Está la resistencia dentro de los valores especificados? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el mazo de cables del panel de instrumentos. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A7224020010">
<title>
Inspección del actuador de control de temperatura 
</title>
<test1>
<ptxt>
Compruebe el actuador del control de temperatura. 
<intxreftitleoff1 refid = "ASPAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está el actuador en buen estado? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control HVAC y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el actuador de control de temperatura. 
<intxreftitleoff1 refid = "ASPAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
