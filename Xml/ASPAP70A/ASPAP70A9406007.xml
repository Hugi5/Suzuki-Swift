<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A9406007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del interruptor del lavaparabrisas y limpiaparabrisas 
</title>
<servinfosub id = "ASPAP70A9406007001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Extraiga la cubierta de la columna de la dirección. 
<intxreftitleoff1 refid = "ASPAP70A6206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desenchufe el conector del interruptor (3) del limpia/lava parabrisas. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el interruptor de limpiaparabrisas y lavaparabrisas (1) de la columna de dirección mientras presiona la garra (2) en la dirección de la flecha. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A940006.jpg" width = "88.000mm" height = "85.417mm" ver = "01" gw = "201" gh = "226"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A9406007002">
<title>
Instalación 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A9406008">Inspección del interruptor del lavaparabrisas y limpiaparabrisas</intxrefpoff>
</ptxt>
<ptxt>
Invierta el procedimiento de extracción. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
