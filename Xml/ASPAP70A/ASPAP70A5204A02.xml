<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Dureza del cambio 
</title>
<diag type = "condition">
<condition>
<ptxt>
Dureza del cambio 
</ptxt>
</condition>
<ps>
<ptxt>
Lubricante inadecuado 
</ptxt>
</ps>
<action>
<ptxt>
Añada aceite del transeje manual. 
</ptxt>
</action>
<ps>
<ptxt>
Recorrido libre del pedal de embrague incorrecto 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Reemplace el brazo del pedal de embrague o el cilindro maestro del embrague. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Brazo del pedal de embrague: 
<intxreftitleoff1 refid = "ASPAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Cilindro maestro del embrague: 
<intxreftitleoff1 refid = "ASPAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Disco del embrague deformado o roto 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el disco del embrague. 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Plato de presión del embrague dañado 
</ptxt>
</ps>
<action>
<ptxt>
Reemplace la tapa del embrague. 
<intxreftitleoff1 refid = "ASPAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Anillo del sincronizador desgastado 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sustituya el anillo del sincronizador. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Anillo sincronizador de baja velocidad y anillo sincronizador del engranaje de 2ª: 
<intxreftitleoff1 refid = "ASPAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Anillo del sincronizador de alta velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Anillo sincronizador de 5ª velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Diente biselado del manguito o del engranaje desgastado 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sustituya el cubo y el manguito del sincronizador, y el engranaje. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Engranaje de 1ª y engranaje de 2ª del contraeje: 
<intxreftitleoff1 refid = "ASPAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Engranaje de 3ª y engranaje de 4ª del eje de entrada: 
<intxreftitleoff1 refid = "ASPAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Engranaje de 5ª del eje de entrada: 
<intxreftitleoff1 refid = "ASPAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Cubo y manguito del sincronizador de baja velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Cubo y manguito del sincronizador de alta velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Cubo y manguito sincronizador de 5ª velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Casquillo de la junta del eje de control del cambio de marchas desgastado 
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el casquillo de la junta del eje de control del cambio de engranaje. 
<intxreftitleoff1 refid = "ASPAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Eje de cambio deformado 
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Sustituya la horquilla de cambio o el eje de cambio. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Eje de cambio de engranaje de baja velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Eje de cambio de engranaje de alta velocidad: 
<intxreftitleoff1 refid = "ASPAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Horquilla de cambio del engranaje de 5ª: 
<intxreftitleoff1 refid = "ASPAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Cables de control de cambio y selección de marchas rotos 
</ptxt>
</ps>
<action>
<ptxt>
Sustituya el cambio de engranaje y el cable de selección. 
<intxreftitleoff1 refid = "ASPAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
