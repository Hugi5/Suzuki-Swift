<servinfosub id = "ASPAP70A1104046003">
<title>
Procedimiento de confirmación del DTC 
</title>
<s1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;) durante 1 min. como mínimo. 
</ptxt>
</s1>
<s1>
<ptxt>
Arranque el motor si es posible. 
</ptxt>
</s1>
</servinfosub>
