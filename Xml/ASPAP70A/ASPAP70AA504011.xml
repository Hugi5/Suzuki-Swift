<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70AA504011" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1122
</title>
<servinfosub id = "ASPAP70AA504011001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.161in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.043in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1122: Avería en la alimentación eléctrica de reserva 
</emph>
</ptxt>
<ptxt>
La tensión del circuito de alimentación eléctrica de reserva procedente del fusible &#34;BCM&#34; es inferior a lo especificado.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Fusible &#34;BCM&#34;
</ptxt>
</item>
<item>
<ptxt>
Módulo de control de arranque sin llave
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70AA504011002">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70AA504011003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70AA504011004">
<testgroup id = "ASPAP70AA504010005">
<title>
Inspección del fusible
</title>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;.
</ptxt>
</test1>
<test1>
<ptxt>
Inspeccione el fusible &#34;BCM&#34;.
</ptxt>
</test1>
<question>
¿Está en buenas condiciones?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control de arranque sin llave y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el fusible &#34;BCM&#34; y vaya al Paso 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA504010006">
<title>
Verificación de DTC
</title>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1122?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el fusible &#34;BCM&#34; y el módulo de control de arranque sin llave, y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
