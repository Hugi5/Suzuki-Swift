<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70AA314018" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1188
</title>
<servinfosub id = "ASPAP70AA314018001">
<title>
Condición de detección del DTC y área afectada 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1188: Error de comunicación del transpondedor 
</emph>
</ptxt>
<ptxt>
Error de verificación entre el BCM y la llave de encendido. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
La llave de encendido no está registrada 
</ptxt>
</item>
<item>
<ptxt>
Llave de contacto 
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70AA314018002">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Antes de realizar el procedimiento de localización y reparación de averías, asegúrese de leer 
<intxref refid = "ASPAP70AA310002">Medidas de precaución para el sistema del inmovilizador:Modelos con interruptor de encendido</intxref>
. 
</ptxt>
</item>
<item>
<ptxt>
Si el BCM ha sido registrado en otro vehículo (artículo utilizado), no podrá registrar las llaves de contacto. Instale siempre un BCM nuevo cuando la sustitución sea necesaria. 
</ptxt>
</item>
</list1>
</attention3>
<diag type = "test" id = "ASPAP70AA314018003">
<testgroup id = "ASPAP70AA314018004">
<title>
Verificación del arranque del motor 
</title>
<test1>
<ptxt>
Ponga en marcha el motor con la llave de contacto de repuesto. 
</ptxt>
</test1>
<question>
¿Arranca el motor? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Fin de la inspección. (No se ha registrado la llave de encendido.) 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA314018005">
<title>
Registro de la llave de encendido 
</title>
<test1>
<ptxt>
Realice el &#34;Registro de la llave del inmovilizador&#34;. 
<intxreftitleoff1 refid = "ASPAP70AA316002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1188? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el BCM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (La llave de encendido no estaba registrada) 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
