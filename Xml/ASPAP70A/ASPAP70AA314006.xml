<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70AA314006" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1610
</title>
<servinfosub id = "ASPAP70AA314006001">
<title>
Condición de detección del DTC y área afectada 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.281in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.924in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1610: ID del inmovilizador sin registrar 
</emph>
</ptxt>
<ptxt>
El código ID del inmovilizador no está registrado. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
El código ID del ECM no está registrado en el BCM. 
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Conector/circuito de comunicación CAN 
</ptxt>
</item>
<item>
<ptxt>
Módulo de control conectado con la línea de comunicación CAN 
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70AA314006002">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70AA314006003">
<testgroup id = "ASPAP70AA314006005">
<title>
Verificación de DTC 
</title>
<test1>
<ptxt>
Compruebe el DTC del BCM. 
<intxreftitleoff1 refid = "ASPAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se detectan los DTC B1173, B1175 o B1176? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA314006004">
<title>
Registro del ECM 
</title>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70AA316003">Registro del ECM:Modelos con interruptor de encendido</intxref>
. 
</ptxt>
</test1>
<test1>
<ptxt>
Vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC P1610? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección. (No se ha registrado el ECM) 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA314006006">
<title>
Verificación de DTC 
</title>
<test1>
<ptxt>
Verifique los DTC relacionados con la comunicación CAN. 
</ptxt>
</test1>
<question>
¿Se detecta algún DTC relacionado con la CAN? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el ECM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
