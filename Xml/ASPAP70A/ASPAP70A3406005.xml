<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A3406005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Desmontaje y montaje del acoplamiento 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A3406004">Montaje y desmontaje del conjunto del árbol de transmisión</intxrefpoff>
</ptxt>
<servinfosub id = "ASPAP70A3406005001">
<title>
Desmontaje 
</title>
<s1>
<ptxt>
Extraiga el anillo elástico del eje de acoplamiento con ayuda de unos alicates para anillos de retención. 
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga el acoplamiento viscoso (1) del eje de acoplamiento (2) con la prensa hidráulica (3) y el extractor (4). 
</ptxt>
<figure>
<graphic graphicname = "I5RS0D340007.swf" width = "88.000mm" height = "49.401mm" ver = "01" gw = "114" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A3406005002">
<title>
Montaje 
</title>
<s1>
<ptxt>
Instale el acoplamiento viscoso (1) en el eje de acoplamiento (2) con la herramienta especial y la prensa hidráulica. 
</ptxt>
<servicetool>
<servicetoolitem id = "L3D001">
<s-part>
(A)
</s-part>
<s-number num = "09922-55131">
 09922-55131 
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A340010.swf" width = "88.000mm" height = "50.636mm" ver = "01" gw = "94" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Instale un anillo elástico nuevo en el eje central con los alicates para anillos de retención. 
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
