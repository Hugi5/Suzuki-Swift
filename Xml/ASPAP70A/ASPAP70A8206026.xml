<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A8206026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del interruptor de desactivación del airbag del pasajero 
</title>
<servinfosub id = "ASPAP70A8206026001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Saque la guantera. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Desconecte el conector (1) del interruptor de desactivación del airbag del pasajero. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A820078.swf" width = "88.000mm" height = "87.000mm" ver = "01" gw = "231" gh = "230"/>
</figure>
</s1>
<s1>
<ptxt>
Extraiga el interruptor de desactivación del airbag del pasajero (1) mientras libera los bloqueos (2). 
</ptxt>
<figure>
<graphic graphicname = "I9P60A820079.swf" width = "88.000mm" height = "59.573mm" ver = "02" gw = "207" gh = "152"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A8206026002">
<title>
Instalación 
</title>
<ptxt>
<intxrefpoff refid = "ASPAP70A8206027">Inspección del interruptor de desactivación del airbag del pasajero</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Coloque el interruptor de desactivación del airbag del pasajero (1) alineando su saliente (2) con el encaje (3) del panel de instrumentos. 
</ptxt>
<figure>
<graphic graphicname = "I9P60A820080.swf" width = "88.000mm" height = "64.695mm" ver = "01" gw = "207" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Conecte el conector del interruptor de desactivación del airbag del pasajero. 
</ptxt>
</s1>
<s1>
<ptxt>
Instale la guantera. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
