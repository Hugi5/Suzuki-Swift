<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A7214A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
No sale aire frío (el embrague magnético no funciona) 
</title>
<diag type = "condition">
<condition>
<ptxt>
No sale aire frío (el embrague magnético no funciona) 
</ptxt>
</condition>
<ps>
<ptxt>
No hay refrigerante 
</ptxt>
</ps>
<action>
<ptxt>
Efectúe la recuperación, vaciado y carga del refrigerante. 
<intxreftitleoff1 refid = "ASPAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fusible fundido 
</ptxt>
</ps>
<action>
<ptxt>
Verifique si hay cortocircuito a masa en los fusibles relacionados. 
</ptxt>
</action>
<ps>
<ptxt>
Interruptor de A/C defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el interruptor de A/C. 
<intxreftitleoff1 refid = "ASPAP70A7216034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Selector de velocidad del soplador defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el selector de velocidad del soplador. 
<intxreftitleoff1 refid = "ASPAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensor de temperatura del evaporador defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Revise el sensor de temperatura del evaporador. 
<intxreftitleoff1 refid = "ASPAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Sensor de presión del refrigerante del A/C defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Examine el sensor de presión del refrigerante del A/C. 
<intxreftitleoff1 refid = "ASPAP70A7216023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos 
</ptxt>
</ps>
<action>
<ptxt>
Repare el cableado. 
</ptxt>
</action>
<ps>
<ptxt>
ECM y su circuito defectuosos 
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Compruebe el ECM. 
<intxreftitleoff1 refid = "ASPAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Embrague magnético defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el embrague magnético. 
<intxreftitleoff1 refid = "ASPAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Correa de transmisión del compresor floja o rota 
</ptxt>
</ps>
<action>
<ptxt>
Compruebe la correa de transmisión del compresor. 
<intxreftitleoff1 refid = "ASPAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Compresor defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el compresor. 
</ptxt>
</action>
<ps>
<ptxt>
Relé del compresor defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Inspeccione el relé del compresor. 
<intxreftitleoff1 refid = "ASPAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
BCM defectuoso 
</ptxt>
</ps>
<action>
<ptxt>
Revise el BCM. 
<intxreftitleoff1 refid = "ASPAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
