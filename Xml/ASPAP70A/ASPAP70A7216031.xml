<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A7216031" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación del conducto trasero (si está instalado) 
</title>
<servinfosub id = "ASPAP70A7216031001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desactive el sistema de airbag. 
<intxreftitleoff1 refid = "ASPAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Retire los asientos delanteros. 
<intxreftitleoff1 refid = "ASPAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la caja delantera de la consola del suelo. 
<intxreftitleoff1 refid = "ASPAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Retire la alfombrilla hasta que los conductos posteriores queden totalmente expuestos. 
</ptxt>
</s1>
<s1>
<ptxt>
Retire los conductos traseros derecho e izquierdo (1). 
</ptxt>
</s1>
<s1>
<ptxt>
Retire el conducto trasero central (2) si es necesario. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A721040.swf" width = "88.000mm" height = "71.569mm" ver = "01" gw = "238" gh = "186"/>
