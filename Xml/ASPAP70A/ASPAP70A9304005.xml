<section sectnbr = "9C">
<servcat sctnbr = "09" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A9304005" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1803
</title>
<servinfosub id = "ASPAP70A9304005001">
<title>
Condición de detección del DTC y área afectada 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.597in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.597in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1803: Fallo de funcionamiento en el circuito del indicador SET/CRUISE 
</emph>
</ptxt>
<ptxt>
El LED está roto. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Juego de instrumentos 
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70A9304005002">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70A9304005003">
<testgroup id = "ASPAP70A9304005004">
<title>
Verificación de DTC 
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Asegúrese de que el interruptor de encendido está en la posición &#34;OFF&#34;. 
</ptxt>
</test1>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1803? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el juego de instrumentos y vuelva a comprobar el DTC. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Verifique los problemas intermitentes. 
<intxreftitleoff1 refid = "ASPAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
