<servinfosub id = "ASPAP70A1104022003">
<title>
Procedimiento de confirmación del DTC 
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Efectúe una prueba en carretera en un lugar donde no haya tráfico para evitar accidentes. 
</ptxt>
</item>
<item>
<ptxt>
La prueba en carretera deben realizarla dos personas, un conductor y un probador, en una carretera nivelada. 
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Compruebe que la ECT es inferior a 40 &#176;C (104 &#176;F). 
</ptxt>
</s1>
<s1>
<ptxt>
Arranque el motor y conduzca el vehículo a una velocidad constante de 60 a 80 km/h (37 a 50 mile/h), durante 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A1104022004">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70A1104022005">
<testgroup id = "ASPAP70A1104022006">
<question>
¿Se ha realizado la &#34;Inspección del sistema de control del motor y de las emisiones&#34;? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70A1104001">Inspección del sistema de control del motor y de las emisiones</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A1104022007">
<title>
Comprobación del nivel de refrigerante 
</title>
<test1>
<ptxt>
Compruebe el nivel de refrigerante. 
<intxreftitleoff1 refid = "ASPAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Añada refrigerante y vuelva a realizar la comprobación del DTC. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A1104022008">
<title>
Inspección del circuito del sensor ECT 
</title>
<test1>
<ptxt>
Inspeccione los circuitos del sensor ECT conforme al paso 2 de 
<intxref refid = "ASPAP70A1104023">DTC P0117 / P0118</intxref>
. 
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repare o sustituya el mazo de cables defectuoso. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A1104022009">
<title>
Verificación del sensor ECT 
</title>
<test1>
<ptxt>
Inspeccione el sensor ECT. 
<intxreftitleoff1 refid = "ASPAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Reemplace el sensor ECT. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A1104022010">
<title>
Inspección del termostato 
</title>
<test1>
<ptxt>
Inspeccione el conjunto del termostato. 
<intxreftitleoff1 refid = "ASPAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es correcto el resultado de la inspección? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el ECM y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el termostato. 
</ptxt>
</action>
</testgroup>
</diag>
