<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A9904A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
El techo solar no funciona (el motor del techo solar no funciona)
</title>
<diag type = "condition">
<condition>
<ptxt>
El techo solar no funciona (el motor del techo solar no funciona)
</ptxt>
</condition>
<ps>
<ptxt>
Fusible fundido
</ptxt>
</ps>
<action>
<ptxt>
Reemplace el fusible.
</ptxt>
</action>
<ps>
<ptxt>
Interruptor del techo solar defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el interruptor del techo solar. 
<intxreftitleoff1 refid = "ASPAP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Cableado o conexión a masa defectuosos
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el circuito. 
<intxreftitleoff1 refid = "ASPAP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "ASPAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Motor del techo solar defectuoso
</ptxt>
</ps>
<action>
<ptxt>
Compruebe el motor del techo solar. 
<intxreftitleoff1 refid = "ASPAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
