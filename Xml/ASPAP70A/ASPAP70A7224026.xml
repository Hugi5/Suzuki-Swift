<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70A7224026" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1546
</title>
<servinfosub id = "ASPAP70A7224026001">
<title>
Condición de detección del DTC y área afectada 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.937in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.274in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada 
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1546: Presión anómala del refrigerante del A/C 
</emph>
</ptxt>
<ptxt>
La presión del refrigerante del A/C es inferior al valor especificado, aunque la temperatura exterior es superior al valor especificado. 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Sensor de presión del refrigerante del A/C 
</ptxt>
</item>
<item>
<ptxt>
Sensor de temperatura del aire exterior 
</ptxt>
</item>
<item>
<ptxt>
Refrigerante insuficiente 
</ptxt>
</item>
<item>
<ptxt>
Módulo de control HVAC 
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70A7224026002">
<title>
Procedimiento de confirmación del DTC 
</title>
<s1>
<ptxt>
Arranque el motor y después ponga en marcha el sistema de A/C. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A7224026003">
<title>
Localización y reparación de la avería correspondiente al DTC 
</title>
<diag type = "test" id = "ASPAP70A7224026004">
<testgroup id = "ASPAP70A7224026005">
<title>
Comprobación de la presión del refrigerante del A/C 
</title>
<test1>
<ptxt>
Encienda el interruptor A/C y accione el compresor del A/C. 
</ptxt>
</test1>
<test1>
<ptxt>
Compruebe &#34;Presión del refrig.&#34; con el modo &#34;Lista de Datos&#34; en la herramienta de escaneado SUZUKI. 
<intxreftitleoff1 refid = "ASPAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Es la presión superior a 0,34 MPa? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Añada refrigerante y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A7224026006">
<title>
Inspección del sensor de presión del refrigerante del A/C 
</title>
<test1>
<ptxt>
Examine el sensor de presión del refrigerante del A/C. 
<intxreftitleoff1 refid = "ASPAP70A7226022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está el sensor en buen estado? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sustituya el sensor de presión de refrigerante del A/C. 
<intxreftitleoff1 refid = "ASPAP70A7226023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A7224026007">
<title>
Inspección del sensor de temperatura del aire exterior 
</title>
<test1>
<ptxt>
Inspeccione el sensor de temperatura del aire exterior. 
<intxreftitleoff1 refid = "ASPAP70AA206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está el sensor en buen estado? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 4. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Reemplace el sensor de temperatura del aire exterior. 
<intxreftitleoff1 refid = "ASPAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70A7224026008">
<title>
Inspección del sistema de A/C 
</title>
<test1>
<ptxt>
Inspeccione el sistema A /C. 
<intxreftitleoff1 refid = "ASPAP70A7224001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Está el sistema en buenas condiciones? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control HVAC y vuelva a comprobar los DTC. 
<intxreftitleoff1 refid = "ASPAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Lleve a cabo el procedimiento de 
<intxref refid = "ASPAP70A7224002">Diagnóstico de problemas relacionados con una presión anómala:Tipo automático</intxref>
 y vuelva a comprobar el DTC. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
