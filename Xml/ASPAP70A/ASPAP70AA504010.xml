<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70AA504010" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1120 / B1170
</title>
<servinfosub id = "ASPAP70AA504010001">
<title>
Condición de detección del DTC y área afectada
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.118in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.087in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condición de detección del DTC
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Área afectada
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1120: Defecto interno en el módulo de control de arranque sin llave 
</emph>
</ptxt>
<ptxt>
Fallo interno en el módulo de control de arranque sin llave.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Módulo de control de arranque sin llave
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1170: Error de acceso de la EEPROM
</emph>
</ptxt>
<ptxt>
Fallo interno en el módulo de control de arranque sin llave. (Error de la EEPROM)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "ASPAP70AA504010002">
<title>
Procedimiento de confirmación del DTC
</title>
<s1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;).
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70AA504010003">
<title>
Localización y reparación de la avería correspondiente al DTC
</title>
<diag type = "test" id = "ASPAP70AA504010004">
<testgroup id = "ASPAP70AA504009005">
<title>
Nueva comprobación del DTC
</title>
<test1>
<ptxt>
Borre el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Desconecte el encendido (posición “OFF”).
</ptxt>
</test1>
<test1>
<ptxt>
Efectúe 
<intxref refid = "ASPAP70AA504010002">Procedimiento de confirmación del DTC</intxref>
 y vuelva a comprobar el DTC.
</ptxt>
</test1>
<question>
¿Se sigue detectando el DTC B1120 o B1170?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sustituya el módulo de control de arranque sin llave y vuelva a realizar la comprobación de DTC. 
<intxreftitleoff1 refid = "ASPAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Fin de la inspección.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
