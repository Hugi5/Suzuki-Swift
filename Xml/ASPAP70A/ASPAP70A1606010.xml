<servinfosub id = "ASPAP70A1606010002">
<title>
Motor del ventilador de refrigeración del radiador 
</title>
<s1>
<ptxt>
Desconecte el conector del motor del ventilador de refrigeración del radiador (1). 
</ptxt>
<figure>
<graphic graphicname = "IAP70P160004.swf" width = "88.000mm" height = "65.899mm" ver = "01" gw = "201" gh = "170"/>
</figure>
</s1>
<s1>
<ptxt>
Conecte el conector del motor del ventilador de refrigeración del radiador y la batería mediante un cable de servicio tal como aparece en la ilustración. 
</ptxt>
<figure>
<graphic graphicname = "IAP70A160002.swf" width = "88.000mm" height = "48.839mm" ver = "01" gw = "222" gh = "122"/>
