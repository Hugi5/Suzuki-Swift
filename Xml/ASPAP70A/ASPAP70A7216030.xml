<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "ASPAP70A7216030" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Extracción e instalación de la rejilla de ventilación lateral 
</title>
<servinfosub id = "ASPAP70A7216030001">
<title>
Extracción 
</title>
<s1>
<ptxt>
Desconecte el cable negativo (–) de la batería. 
</ptxt>
</s1>
<s1>
<ptxt>
Lado del conductor: Retire el tablero de instrumentos del panel de instrumentos. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Lado del pasajero: Extraiga la puerta del airbag del pasajero. 
<intxreftitleoff1 refid = "ASPAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Extraiga la rejilla de ventilación lateral. 
<intxreftitleoff1 refid = "ASPAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Retire los tubos (1) y, a continuación, separe la rejilla de ventilación lateral (2) del embellecedor lateral del panel de instrumentos (3). 
</ptxt>
<figure>
<graphic graphicname = "IAP70A721039.swf" width = "88.000mm" height = "68.687mm" ver = "01" gw = "177" gh = "178"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "ASPAP70A7216030002">
<title>
Instalación 
</title>
<ptxt>
Invierta el procedimiento de extracción. 
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
