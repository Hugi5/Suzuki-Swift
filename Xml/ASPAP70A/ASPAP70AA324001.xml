<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "ASPAP70AA324001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Comprobación del sistema de control del inmovilizador 
</title>
<diag type = "test" id = "ASPAP70AA324001001">
<testgroup id = "ASPAP70AA324001003">
<title>
Comprobación del encendido en posición &#34;ON&#34; 
</title>
<test1>
<ptxt>
Conecte el encendido (posición &#34;ON&#34;). 
</ptxt>
</test1>
<test1>
<ptxt>
Pise el pedal del embrague. 
</ptxt>
</test1>
<question>
¿Se encienden la luz indicadora ON y la luz indicadora PUSH? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 2. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70AA504001">Inspección del sistema de arranque sin llave</intxref>
. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA324001004">
<title>
Verificación de DTC 
</title>
<test1>
<ptxt>
Compruebe el DTC. 
<intxreftitleoff1 refid = "ASPAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
¿Se ha detectado algún DTC? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 3. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA324001006">
<title>
Verificación de DTC 
</title>
<test1>
<ptxt>
Verifique los DTC relacionados con la comunicación CAN. 
</ptxt>
</test1>
<question>
¿Se detecta algún DTC relacionado con la CAN? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya a la localización y reparación de averías de DTC correspondiente. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya al paso 4. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA324001005">
<question>
¿Gira el motor para arrancar? 
</question>
<result type = "yes"/>
<action>
<ptxt>
Vaya al paso 5. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70A1904001">Diagnóstico de síntomas del sistema de arranque</intxref>
&#34;. 
</ptxt>
</action>
</testgroup>
<testgroup id = "ASPAP70AA324001002">
<title>
Verificación del arranque del motor 
</title>
<question>
¿Arranca el motor? 
</question>
<result type = "yes"/>
<action>
<ptxt>
El sistema de control del inmovilizador está en buen estado. 
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Vaya a 
<intxref refid = "ASPAP70A1104009">Inspección básica del motor</intxref>
. 
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
