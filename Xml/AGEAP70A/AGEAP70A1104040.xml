<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0504: Bremsschalter, &#34;A&#34;/&#34;B&#34;-Korrelation
</emph>
</ptxt>
<ptxt>
Eine der folgenden Bedingungen ist erfüllt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Signalspannungen von Bremslichtschalter und Bremsschalter sind über einen bestimmten Zeitraum niedrig.
</ptxt>
</item>
<item>
<ptxt>
Signalspannungen von Bremslichtschalter und Bremsschalter sind über einen bestimmten Zeitraum hoch.
</ptxt>
</item>
</list1>
<ptxt>
(3-Fahrten-Testlogik, die MIL leuchtet jedoch nicht auf)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Bremslichtschalter und/oder zugehöriger Schaltkreis
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
