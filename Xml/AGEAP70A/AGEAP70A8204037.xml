<servinfosub id = "AGEAP70A8204037001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.927in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.276in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1083: Masseschluss im Schaltkreis des Seitenaufprallsensors (Fahrerseite) 
</emph>
</ptxt>
<ptxt>
Der Schaltkreis des vorderen Seitenaufprallsensors auf der Fahrerseite hat einen Masseschluss.
</ptxt>
</entry>
<entry colname = "2" morerows = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Schaltkreis des vorderen Seitenaufprallsensors auf Fahrer-/Beifahrerseite
</ptxt>
</item>
<item>
<ptxt>
Vorderer Seitenaufprallsensor auf Fahrer-/Beifahrerseite
</ptxt>
</item>
<item>
<ptxt>
SDM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1084: Unterbrechung im Schaltkreis des Seitenaufprallsensors (Fahrerseite) 
</emph>
</ptxt>
<ptxt>
Der Schaltkreis des vorderen Seitenaufprallsensors auf der Fahrerseite hat einen Kurzschluss gegen Stromversorgung oder eine Unterbrechung.
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1093: Masseschluss im Schaltkreis des Seitenaufprallsensors (Beifahrerseite) 
</emph>
</ptxt>
<ptxt>
Der Schaltkreis des vorderen Seitenaufprallsensors auf der Beifahrerseite hat einen Masseschluss.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1094: Unterbrechung im Schaltkreis des Seitenaufprallsensors (Beifahrerseite) 
</emph>
</ptxt>
<ptxt>
Der Schaltkreis des vorderen Seitenaufprallsensors auf der Beifahrerseite hat einen Kurzschluss gegen Stromversorgung oder eine Unterbrechung.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
