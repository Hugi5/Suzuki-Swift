<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A9204A11" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Blinker/Warnblinkanlage blinkt nicht
</title>
<diag type = "condition">
<condition>
<ptxt>
Blinker/Warnblinkanlage blinkt nicht
</ptxt>
</condition>
<ps>
<ptxt>
BCM defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Siehe &#34;Überprüfung des BCM und seiner Schaltkreise&#34; in Abschnitt 10B.
</ptxt>
<ptxt>
Modell mit Zündschalter: 
<intxreftitleoff1 refid = "AGEAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modell mit schlüssellosem Startsystem: 
<intxreftitleoff1 refid = "AGEAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Fehler im System-Schaltkreis (einschließlich Relais und Sicherungen)
</ptxt>
</ps>
<action>
<ptxt>
Den Schaltkreis reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Glühlampen durchgebrannt
</ptxt>
</ps>
<action>
<ptxt>
Glühlampen austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Defekter Beleuchtungs- und Blinkerschalter
</ptxt>
</ps>
<action>
<ptxt>
Siehe 
<intxref refid = "AGEAP70A9206015">Überprüfung des Beleuchtungs- und Blinkerschalters</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Defekter Warnblinkschalter
</ptxt>
</ps>
<action>
<ptxt>
Siehe 
<intxref refid = "AGEAP70A9206017">Überprüfung des Warnblinkschalters</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
