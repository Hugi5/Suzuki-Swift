<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A9404A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Störungen der Waschanlage
</title>
<servinfosub id = "AGEAP70A9404002001">
<title>
Scheibenwischer- und Waschanlage
</title>
<diag type = "condition">
<condition>
<ptxt>
Störungen der Waschanlage
</ptxt>
</condition>
<ps>
<ptxt>
Defekter Waschanlagenschlauch (einschließlich Rückschlagventil und Steckverbinder) oder Waschanlagendüse
</ptxt>
</ps>
<action>
<ptxt>
Waschanlagenschlauch oder -düse auf Verstopfung und Verbiegung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9403001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defekte Waschwasserpumpe
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A9406002">Überprüfung der Waschwasserpumpe</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defekter Wischer- und Waschanlagenschalter (Waschanlagenschalter)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A9406008">Überprüfung des Scheibenwischer- und Waschanlagenschalters</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defekte Verkabelung bzw. Masseanschluss
</ptxt>
</ps>
<action>
<ptxt>
Die Verkabelung reparieren.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
