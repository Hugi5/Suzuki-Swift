<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Anlassermotors
</title>
<servinfosub id = "AGEAP70A1906002001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Ansaugkrümmer entfernen. 
<intxreftitleoff1 refid = "AGEAP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Klopfsensorhalterung (1) vom Zylinderblock abmontieren.
</ptxt>
<figure>
<graphic graphicname = "IAP70A190003.swf" width = "88.000mm" height = "58.388mm" ver = "01" gw = "172" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Das Anschlusskabel des Magnetschalters (1) und das Anlassermotorkabel (2) vom Anlassermotor abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Befestigungsschrauben des Anlassermotors (3) ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Anlassermotor (4) ausbauen.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A190005.swf" width = "183.000mm" height = "82.031mm" ver = "02" gw = "405" gh = "216"/>
</figure>
</servinfosub>
<servinfosub id = "AGEAP70A1906002002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1906009">Überprüfung des Anlassermotors</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und dabei folgenden Punkt beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Befestigungsschrauben des Anlassermotors und die Kabelmutter des Anlassermotors mit dem angegebenen Drehmoment festziehen.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1I001">
<t-part>
Mutter des Anlassermotorkabels
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1I002">
<t-part>
Befestigungsschraube des Anlassermotors
</t-part>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
