<servinfo servinfosgmlid = "AGEAP70A9B06022" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des hinteren Heckbodenblechs
</title>
<attention3>
<ptxt>
Die nachstehende Abbildung zeigt den Zustand, bei dem die folgenden Teile entfernt sind.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kotflügel vorn
<intxreftitleoff1 refid = "AGEAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rückwand 
<intxreftitleoff1 refid = "AGEAP70A9B06021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0166.jpg" width = "88.000mm" height = "48.926mm" ver = "02" gw = "227" gh = "122"/>
</figure>
<servinfosub id = "AGEAP70A9B06022001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Schweißpunkte ausbohren, und das hintere Heckbodenblech abnehmen.
</ptxt>
<attention3>
<ptxt>
Nötigenfalls beide Enden des Heckboden-Mittelblechflansches aufbiegen.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A9B0018.jpg" width = "183.000mm" height = "184.007mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9B06022002">
<title>
Einbau
</title>
<attention3>
<ptxt>
Vor der Durchführung von Schweißarbeiten die Einbauposition und den Zustand der Einbauteile überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1 page = "1">
<ptxt>
Ersatzradhalterung und Werkzeugkastenhalterung einbauen.
</ptxt>
</s1>
<s1 page = "1">
<ptxt>
Widerstands-Punktschweißung durchführen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0168.jpg" width = "183.000mm" height = "100.573mm" ver = "01" gw = "495" gh = "269"/>
</figure>
</s1>
<s1 page = "1">
<ptxt>
Das hintere Heckbodenblech einbauen.
</ptxt>
<attention3>
<ptxt>
Nötigenfalls beide Enden des Heckboden-Mittelblechflansches einbiegen.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Widerstands-Punktschweißung und Lochschweißung durchführen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0019.jpg" width = "183.000mm" height = "183.872mm" ver = "01" gw = "487" gh = "505"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
