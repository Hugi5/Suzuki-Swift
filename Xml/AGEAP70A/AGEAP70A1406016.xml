<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1406016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Motorbaugruppe
</title>
<servinfosub id = "AGEAP70A1406016001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Kraftstoffdruck ablassen. 
<intxreftitleoff1 refid = "AGEAP70A1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Batterie ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die ECM-Steckverbinder abziehen. 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Batteriehalterung mit ECM entfernen. 
<intxreftitleoff1 refid = "AGEAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den rechten und linken Motorunterboden abmontieren.
</ptxt>
</s1>
<s1>
<ptxt>
Bei Bedarf die folgenden Öle und Flüssigkeiten ablassen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Motoröl: 
<intxreftitleoff1 refid = "AGEAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schaltgetriebeöl: 
<intxreftitleoff1 refid = "AGEAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verteilergetriebeöl: 
<intxreftitleoff1 refid = "AGEAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Kühlmittel ablassen. 
<intxreftitleoff1 refid = "AGEAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Luftfilter-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den A/C-Kompressor mit angeschlossenem Schlauch von seiner Halterung lösen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit manueller Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modell mit automatischer Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Den A/C-Kompressor an einer sicheren Stelle aufhängen, wo er beim Aus- und Einbau der Motorbaugruppe nicht beschädigt werden kann.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Folgende elektrische Drähte/Steckverbinder und Klemmen lösen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Batteriemassekabel (1)
</ptxt>
</item>
<item>
<ptxt>
Steckverbinder (2) im Hauptsicherungskasten
</ptxt>
</item>
<item>
<ptxt>
Steckverbinder des Sensors für elektrische Last (3)
</ptxt>
</item>
<item>
<ptxt>
Steckverbinder (4) in Einzelsicherungskasten Nr. 1
</ptxt>
<figure>
<graphic graphicname = "I9P60A141043.jpg" width = "88.000mm" height = "60.102mm" ver = "01" gw = "199" gh = "154"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Folgende Seilzüge lösen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Wählzug (1)
</ptxt>
</item>
<item>
<ptxt>
Schaltzug (2)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140002.jpg" width = "88.000mm" height = "62.413mm" ver = "01" gw = "199" gh = "160"/>
</figure>
</s1>
<s1>
<ptxt>
Folgende Schläuche lösen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Bremskraftverstärkerschlauch (1)
</ptxt>
</item>
<item>
<ptxt>
Kühlereinlass- und -auslassschläuche (2)
</ptxt>
</item>
<item>
<ptxt>
Ein- und Auslassschläuche der Heizung (3)
</ptxt>
</item>
<item>
<ptxt>
Kraftstoffförderschlauch (4)
</ptxt>
</item>
<item>
<ptxt>
Kupplungsflüssigkeitsleitung (5) 
<intxreftitleoff1 refid = "AGEAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140003.jpg" width = "88.000mm" height = "112.325mm" ver = "02" gw = "199" gh = "302"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Untere Lenkwelle von Ritzelwelle trennen. 
<intxreftitleoff1 refid = "AGEAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Stabilisatorgelenke vom Stabilisator abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Spurstangenkopf vom Achsschenkel trennen. 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das rechte und linke Antriebswellengelenk vom Achsschenkel abbauen. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Abgasrohr Nr. 1 und das mittlere Abgasrohr abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Kardanwellen-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Rahmen für die Radaufhängung vorn (1), das Getriebegehäuse (2) und den Zylinderblock (3) mit einem Wagenheber abstützen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (4) des vorderen Rahmens für Radaufhängung herausdrehen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A140004.jpg" width = "88.000mm" height = "55.276mm" ver = "01" gw = "199" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Die Schraube (1) und die Muttern (2) der linken Strebe für Motoraufhängung abmontieren.
</ptxt>
<figure>
<graphic graphicname = "IAP70A140005.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.309in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.280in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.253in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.280in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Oben
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Unten
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Die Schraube (1) und die Muttern (2) der rechten Strebe für Motoraufhängung abmontieren.
</ptxt>
<figure>
<graphic graphicname = "IAP70A140006.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1>
<ptxt>
Vor dem Ausbau des Motors sicherstellen, dass alle Schläuche, elektrischen Drähte und Seilzüge vom Motor gelöst sind.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Motorbaugruppe zusammen mit dem Getriebe, dem Rahmen für die Radaufhängung vorn, den Antriebswellen und dem P/S-Lenkgetriebegehäuse absenken.
</ptxt>
<attention2>
<ptxt>
Vor dem Absenken des Motors den A/C-Kompressor auf einen gewissen Abstand zum Motor anheben, damit er nicht beschädigt wird.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Falls erforderlich, den Motorkabelbaum von Motor und Getriebe trennen.
</ptxt>
</s1>
<s1>
<ptxt>
Falls erforderlich die vordere Antriebswellen-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Falls erforderlich den Rahmen für die Radaufhängung vorn abbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Ggf. das Verteilergetriebe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Falls erforderlich Getriebe vom Motor trennen. 
<intxreftitleoff1 refid = "AGEAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Falls erforderlich Kupplungsdeckel und Kupplungsscheibe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ggf. die Schwungscheibe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1406016002" page = "2">
<title>
Einbau
</title>
<s1>
<ptxt>
Die Schwungscheibe einbauen, falls sie ausgebaut wurde. 
<intxreftitleoff1 refid = "AGEAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Falls sie ausgebaut wurden, den Kupplungsdeckel und die Kupplungsscheibe einbauen. 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Getriebe am Motor montieren, falls es ausgebaut wurde. 
<intxreftitleoff1 refid = "AGEAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Verteilergetriebe einbauen, falls es ausgebaut wurde. 
<intxreftitleoff1 refid = "AGEAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den Rahmen für die Radaufhängung vorn einbauen, falls er ausgebaut wurde. 
<intxreftitleoff1 refid = "AGEAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die vordere Antriebswellen-Baugruppe einbauen, falls sie ausgebaut wurde. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den Motorkabelbaum am Motor und Getriebe anbringen und dann die Masseschraube (1) am Motorkabelbaum mit dem vorgeschriebenen Drehmoment anziehen, falls er ausgebaut wurde.
</ptxt>
<torque>
<torqueitem id = "T1D008">
<t-part>
Motorkabelbaum-Masseschraube
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140007.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Die Motorbaugruppe zusammen mit dem Getriebe, dem Rahmen für die Radaufhängung vorn, den Antriebswellen und dem P/S-Lenkgetriebegehäuse anheben.
</ptxt>
<attention2>
<ptxt>
Vor dem Anheben des Motors den A/C-Kompressor auf einen gewissen Abstand zum Motor anheben, damit er nicht beschädigt wird.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Die Schraube (1) und die Muttern (2) der rechten Strebe für Motoraufhängung anbringen.
</ptxt>
<torque>
<torqueitem id = "T1D009">
<t-part>
Mutter und Schraube der rechten Strebe für Motoraufhängung
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140008.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Die Schrauben (1) und Muttern (2) der linken Strebe für die Motoraufhängung mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1D010">
<t-part>
Schraube und Mutter der linken Strebe für die Motoraufhängung
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140009.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.428in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.100in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.363in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.309in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Oben
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Unten
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Die Schrauben des Fahrschemels auf das vorgeschriebene Drehmoment anziehen. 
<intxreftitleoff1 refid = "AGEAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Kardanwellen-Baugruppe einbauen. 
<intxreftitleoff1 refid = "AGEAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Abgasrohr Nr. 1 und das mittlere Abgasrohr einbauen. 
<intxreftitleoff1 refid = "AGEAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das rechte und linke Antriebswellengelenk mit dem Achsschenkel verbinden. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Spurstangenkopf mit dem Achsschenkel verbinden. 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Stabilisatorgelenke am Stabilisator anbringen. 
<intxreftitleoff1 refid = "AGEAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Untere Lenkwelle und Ritzelwelle verbinden. 
<intxreftitleoff1 refid = "AGEAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Alle übrigen entfernten elektrischen Drähte, Steckverbinder und Schläuche an den ursprünglichen Stellen anbringen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Schraube (1) der Batterie-Masseklemme festziehen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141052.jpg" width = "88.000mm" height = "60.441mm" ver = "02" gw = "199" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Den Schaltzug anschließen. 
<intxreftitleoff1 refid = "AGEAP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den A /C-Kompressor in die Halterung einsetzen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit manueller Klimaanlage 
<intxreftitleoff1 refid = "AGEAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modell mit automatischer Klimaanlage 
<intxreftitleoff1 refid = "AGEAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Den A/C-Kompressor-Antriebsriemen einbauen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit manueller Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modell mit automatischer Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Luftfilter-Baugruppe anbringen. 
<intxreftitleoff1 refid = "AGEAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Sicherstellen, dass alle entfernten Teile sich wieder an der ursprünglichen Position befinden. Noch fehlende Teile anbringen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Bei Bedarf die folgenden Öle und Flüssigkeiten nachfüllen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Motoröl: 
