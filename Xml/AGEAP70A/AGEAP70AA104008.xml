<servinfosub id = "AGEAP70AA104008003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA104008004">
<testgroup id = "AGEAP70AA104008005">
<title>
Überprüfung der Parameter
</title>
<test1>
<ptxt>
Bei ausgeschalteter Zündung das SUZUKI-Diagnosegerät an den DLC anschließen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Anzeigen von &#34;Tempomat CANCEL Sch&#34;, &#34;Tempomat RES/ACCSchl&#34;, &#34;TempomatSET/COASTSch&#34; und &#34;Tempomat ON/OFF Sch&#34; am SUZUKI-Diagnosegerät prüfen. 
<intxreftitleoff1 refid = "AGEAP70AA104006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ende. (Zeitweilige Störung)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA104008006">
<title>
Schaltkreisprüfung des Geschwindigkeitsregelungsschalters
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder &#34;C01&#34;, &#34;E01&#34; und &#34;G371&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreien Klemmenanschluss zu den Steckverbindern &#34;C01&#34;, &#34;E01&#34; und &#34;G371&#34; überprüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn die Anschlüsse in Ordnung sind, folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand der Schaltkreise &#34;A1&#34; und &#34;A2&#34;: weniger als 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen Schaltkreis &#34;A1&#34; und Masse: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen Stromkreisklemme &#34;A1&#34; und anderen Anschlussklemmen am Steckverbinder &#34;G371&#34;: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen Stromkreisklemme &#34;A2&#34; und anderen Anschlussklemmen am Steckverbinder &#34;G371&#34;: unendlich
</ptxt>
</item>
<item>
<ptxt>
Spannung der Schaltkreise &#34;A1&#34; und &#34;A2&#34;: 0 – 1 V (bei Zündung auf &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekten Kabelbaum reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA104008007">
<title>
Überprüfung des Tempomatschalters
</title>
<test1>
<ptxt>
Den Tempomatschalter überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
ECM austauschen und DTC erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Tempomatschalter austauschen. 
<intxreftitleoff1 refid = "AGEAP70AA106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
