<servinfo servinfosgmlid = "AGEAP70A5304A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kupplungsgeräusche
</title>
<diag type = "condition">
<condition>
<ptxt>
Kupplungsgeräusche
</ptxt>
</condition>
<ps>
<ptxt>
Ausrücklager verschlissen oder beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsnehmerzylinder-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rechtes Antriebswellenlager verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Rechtes Antriebswellenlager austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Übermäßiges Rattern der Kupplungsscheibennabe
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kupplungsscheibe rissig
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rattern der Druckplatte und der Membranfeder
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsdeckel austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
