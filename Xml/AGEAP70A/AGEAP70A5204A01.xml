<title>
Gänge springen heraus
</title>
<diag type = "condition">
<condition>
<ptxt>
Gänge springen heraus
</ptxt>
</condition>
<ps>
<ptxt>
Schaltschiene verschlissen
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Die Schaltgabel und Schaltwelle austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Langsamgang-Schaltwelle: 
<intxreftitleoff1 refid = "AGEAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schnellgang-Schaltwelle: 
<intxreftitleoff1 refid = "AGEAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schaltgabel des 5. Gangs: 
<intxreftitleoff1 refid = "AGEAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Schaltgabel oder Synchronschaltmuffe verschlissen
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Die Schaltgabel, Schaltwelle oder Synchronschaltmuffe u. Synchronkörper.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Langsamgang-Schaltwelle: 
<intxreftitleoff1 refid = "AGEAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schnellgang-Schaltwelle: 
<intxreftitleoff1 refid = "AGEAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schaltgabel des 5. Gangs: 
<intxreftitleoff1 refid = "AGEAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Langsamgang-Schaltmuffe u. -Synchronkörper: 
<intxreftitleoff1 refid = "AGEAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schnellgang-Schaltmuffe u. -Synchronkörper: 
<intxreftitleoff1 refid = "AGEAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchronschaltmuffe u. -Synchronkörper des 5. Gangs: 
<intxreftitleoff1 refid = "AGEAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Stellfedern ermüdet oder beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Stellfeder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lager der Antriebs- oder Vorgelegewelle verschlissen
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Antriebs- oder Abtriebswellenlager austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Linkes Vorgelegewellenlager: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
Lagerinnenring: 
<intxreftitleoff1 refid = "AGEAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Lageraußenring: 
<intxreftitleoff1 refid = "AGEAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list3>
</list2>
<list2 type = "unordered">
<item>
<ptxt>
Rechtes Vorgelegewellenlager: 
</ptxt>
</item>
<list3 type = "unordered">
<item>
<ptxt>
