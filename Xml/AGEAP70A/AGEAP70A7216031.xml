<servinfo servinfosgmlid = "AGEAP70A7216031" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Fondkanals (sofern vorhanden)
</title>
<servinfosub id = "AGEAP70A7216031001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Airbagsystem deaktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vordersitze ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das vordere Bodenkonsolenfach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Teppich herausnehmen, bis Fondkanäle vollständig freiliegen.
</ptxt>
</s1>
<s1>
<ptxt>
Rechten und linken Fondkanal (1) ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Falls erforderlich, mittleren Fondkanal (2) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721040.swf" width = "88.000mm" height = "71.569mm" ver = "01" gw = "238" gh = "186"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
