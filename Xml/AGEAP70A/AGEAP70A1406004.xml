<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1406004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Luftfilter-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1406001">Komponenten des Luftfilters</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1406004001" page = "2">
<title>
Ausbau
</title>
<s1 page = "2">
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den Steckverbinder (1) des MAF- und IAT-Sensors lösen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Spülventil des EVAP-Aktivkohlebehälters (2) ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Motorkabelbaumklemmen lösen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Klemmschraube des Luftfilter-Auslassschlauchs lösen und die Luftfilterbaugruppe (3) mit Luftansaugleitung (4) ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Falls erforderlich, den Luftfilter-Auslassschlauch (6) folgendermaßen ausbauen.
</ptxt>
<s2>
<ptxt>
Die Entlüftungsleitung (5) vom Luftfilter-Auslassschlauch lösen.
</ptxt>
</s2>
<s2>
<ptxt>
Den Luftfilter-Auslassschlauch entfernen.
</ptxt>
</s2>
<figure>
<graphic graphicname = "I9P60A141019.jpg" width = "88.000mm" height = "98.987mm" ver = "01" gw = "199" gh = "264"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1406004002" page = "2">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
