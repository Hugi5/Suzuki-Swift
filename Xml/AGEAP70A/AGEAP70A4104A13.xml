<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A4104A13" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Bremswarnleuchte bleibt eingeschaltet (länger als 2 Sek.), nachdem der Motor gestartet wurde
</title>
<diag type = "condition">
<condition>
<ptxt>
Bremswarnleuchte bleibt eingeschaltet (länger als 2 Sek.), nachdem der Motor gestartet wurde
</ptxt>
</condition>
<ps>
<ptxt>
ESP<sup>&#174;</sup>-Steuermodul-Steckverbinder nicht richtig angeschlossen
</ptxt>
</ps>
<action>
<ptxt>
Den Steckverbinder des ESP<sup>&#174;</sup>-Steuermoduls erneut anschließen.
</ptxt>
</action>
<ps>
<ptxt>
Feststellbremse ist angezogen
</ptxt>
</ps>
<action>
<ptxt>
Die Feststellbremse lösen und sicherstellen, dass die Warnleuchte erlischt.
</ptxt>
</action>
<ps>
<ptxt>
Bremsflüssigkeitsstand zu niedrig
</ptxt>
</ps>
<action>
<ptxt>
Den Bremsflüssigkeitsstand prüfen. 
<intxreftitleoff1 refid = "AGEAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ABS-Warnleuchte blinkt
</ptxt>
</ps>
<action>
<ptxt>
Störung lokalisieren und beheben. 
<intxreftitleoff1 refid = "AGEAP70A4604013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Feststellbremsschalter und/oder Warnschalter für Bremsflüssigkeitsstand defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Feststellbremsschalter und/oder Warnschalter für den Bremsflüssigkeitsstand prüfen.
</ptxt>
<ptxt>
Feststellbremsschalter: 
<intxreftitleoff1 refid = "AGEAP70A4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Warnschalter für Bremsflüssigkeitsstand: 
<intxreftitleoff1 refid = "AGEAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Funktionsstörung im CAN-Kommunikationssystem
</ptxt>
</ps>
<action>
<ptxt>
CAN-Kommunikationssystem prüfen. 
<intxreftitleoff1 refid = "AGEAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kombiinstrument defekt
</ptxt>
</ps>
<action>
<ptxt>
Das Kombiinstrument austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ESP<sup>&#174;</sup> ABS-Hydraulikeinheit/Steuermodul defekt
</ptxt>
</ps>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit-/Steuermodul austauschen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
