<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A3204001" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Symptomdiagnose für Hinterachsdifferenzial
</title>
<diag type = "condition" id = "AGEAP70A3204001001">
<condition>
<ptxt>
Zahnradgeräusch
</ptxt>
</condition>
<ps>
<ptxt>
Verschlissenes oder mit Wasser vermischtes Schmiermittel
</ptxt>
</ps>
<action>
<ptxt>
Wechseln bzw. auffüllen. 
<intxreftitleoff1 refid = "AGEAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Schmiermittel ungeeignet oder unzureichend
</ptxt>
</ps>
<action>
<ptxt>
Wechseln bzw. auffüllen. 
<intxreftitleoff1 refid = "AGEAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Falsch eingestelltes Zahnflankenspiel zwischen Kegelritzel und Kegelrad
</ptxt>
</ps>
<action>
<ptxt>
Wie vorgeschrieben einstellen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Mangelhaftes Tragbild im Eingriff zwischen Kegelradritzel und Gangrad
</ptxt>
</ps>
<action>
<ptxt>
Einstellen oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Tellerrad-Sicherungsschrauben locker
</ptxt>
</ps>
<action>
<ptxt>
Austauschen oder nachziehen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Beschädigte Achswellenräder oder Ausgleichsräder
</ptxt>
</ps>
<action>
<ptxt>
Austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Ständige Geräusche des Lagers
</ptxt>
</condition>
<ps>
<ptxt>
Verschlissenes oder mit Wasser vermischtes Schmiermittel
</ptxt>
</ps>
<action>
<ptxt>
Wechseln bzw. auffüllen. 
<intxreftitleoff1 refid = "AGEAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Schmiermittel ungeeignet oder unzureichend
</ptxt>
</ps>
<action>
<ptxt>
Wechseln bzw. auffüllen. 
<intxreftitleoff1 refid = "AGEAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Geräusche beim Ausrollen des Lagers
</ptxt>
</condition>
<ps>
<ptxt>
Kegelritzellager beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Geräusche bei Drehung des Lagers
</ptxt>
</condition>
<ps>
<ptxt>
Beschädigte Differenziallager
</ptxt>
</ps>
<action>
<ptxt>
Austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Ölaustritt
</ptxt>
</condition>
<ps>
<ptxt>
Verstopfter Entlüftungsstopfen
</ptxt>
</ps>
<action>
<ptxt>
Reinigen.
</ptxt>
</action>
<ps>
<ptxt>
Radialdichtring verschlissen oder beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zu hoher Ölstand
</ptxt>
</ps>
<action>
<ptxt>
Ölstand korrigieren. 
<intxreftitleoff1 refid = "AGEAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
