<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A6306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des P/S-Steuermoduls
</title>
<servinfosub id = "AGEAP70A6306011001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Instrumentenblock im Armaturenbrett ausbauen 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Bremspedal-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Steckverbinder (1) vom P/S-Steuermodul (2) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die P/S-Steuermodulschrauben (3) von der Stützstrebe für das Lenkgetriebe entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630037.swf" width = "88.000mm" height = "94.023mm" ver = "01" gw = "148" gh = "250"/>
</figure>
</s1>
<s1>
<ptxt>
P/S-Steuermodul ausbauen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A6306011002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und dabei die folgenden Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Schrauben des P/S-Steuermoduls mit dem angegebenen Anzugsmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T6C006">
<t-part>
Befestigungsschraube des P/S-Steuermoduls
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,0
</t-value1>
<t-value2>
0,51
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A630034.swf" width = "88.000mm" height = "98.099mm" ver = "02" gw = "148" gh = "262"/>
</figure>
</item>
<item>
<ptxt>
Bremspedal-Baugruppe einbauen. 
<intxreftitleoff1 refid = "AGEAP70A4106006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
