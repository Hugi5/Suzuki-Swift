<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Türscheibe hinten
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9506014">Bauteile der Fondtür</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9506015001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Fondtürscheibe vollständig herunterfahren.
</ptxt>
</s1>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Innenverkleidung für Tür hinten (1) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Innengriffkappe (2) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (3) und die Klammer (B) entfernen und anschließend die Türverkleidung (4) durch Ziehen in Pfeilrichtung entfernen, dann die Steckverbinder des Türkabelbaums abklemmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950037.jpg" width = "88.000mm" height = "109.011mm" ver = "01" gw = "227" gh = "292"/>
</figure>
</s1>
<s1>
<ptxt>
Äußere Türdichtleiste für Tür hinten (1) durch Bewegen in Pfeilrichtung in der vorgegebenen Reihenfolge (&#34;1&#34; bis &#34;2&#34;) wie in der Abbildung gezeigt entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950038.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.176in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.176in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Klaue
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Fondtür-Außenblech
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Innere Türdichtleiste für Tür hinten (1) durch Ziehen in Pfeilrichtung in der vorgegebenen Reihenfolge (&#34;1&#34; bis &#34;2&#34;) wie in der Abbildung gezeigt entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950039.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.905in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Fondtür-Innenblech
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Die Türverkleidungshalterung (1) und die Türschachtleiste (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950040.jpg" width = "88.000mm" height = "91.844mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Die Scheibenführung (1) umklappen und dann die Schraube (2) der Fondtür-Führungsschiene herausdrehen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (3) der Fondtür-Führungsschiene herausdrehen, und dann Fondtür-Führungsschiene (4) sowie Scheibenführung entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950041.jpg" width = "88.000mm" height = "80.089mm" ver = "02" gw = "211" gh = "211"/>
</figure>
</s1>
<s1>
<ptxt>
Die Türscheibe hinten (1) in Richtung des Pfeils &#34;1&#34; drehen, um die untere Fensterführung (3) von der hinteren Fensterheberbaugruppe (2) zu entfernen, und dann die Türscheibe hinten in Richtung des Pfeils &#34;2&#34; entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950042.jpg" width = "88.000mm" height = "97.155mm" ver = "01" gw = "227" gh = "259"/>
</figure>
</s1>
<s1>
<ptxt>
Bei Bedarf die untere Fensterführung von der Fondtürscheibe entfernen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9506015002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die untere Fensterführung (1) an der angegebenen Position der Fondtürscheibe (2) anbringen, wenn sie von der Fondtürscheibe entfernt wurde.
</ptxt>
<spec>
<title>
Einbauposition der Fondtürscheibe
</title>
<ptxt>
&#34;a&#34;: 17 – 19 mm (0,67 – 0,74 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9P60A950043.jpg" width = "88.000mm" height = "69.916mm" ver = "01" gw = "227" gh = "182"/>
</figure>
</item>
<item>
<ptxt>
Die Fondtürscheibe (3) in Richtung des Pfeils &#34;1&#34; einsetzen und in Richtung des Pfeils &#34;2&#34; drehen, um die untere Fensterführung (1) in Richtung des Pfeils &#34;3&#34; zu bewegen und an die hintere Fensterheberbaugruppe (2) zu setzen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950044.jpg" width = "88.000mm" height = "97.155mm" ver = "01" gw = "227" gh = "259"/>
</figure>
</item>
<item>
<ptxt>
Die Schraube der Fondtür-Führungsschiene anziehen und die Sechskantschrauben der Fondtür-Führungsschiene in der Reihenfolge &#34;1&#34; bis &#34;3&#34; auf die angegebenen Drehmomente anziehen.
</ptxt>
<torque>
<torqueitem id = "T9E004">
<t-part>
Schraube der Fondtür-Führungsschiene*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3,0
</t-value1>
<t-value2>
0,31
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
<torqueitem id = "T9E005">
<t-part>
Sechskantschraube der Fondtür-Führungsschiene*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950045.jpg" width = "88.000mm" height = "80.089mm" ver = "04" gw = "227" gh = "211"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.176in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.176in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Führungsschiene der Fondtür
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Scheibenführung
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Wenn die Scheibenführung verzogen ist, diese reparieren oder durch ein Neuteil ersetzen.
</ptxt>
</item>
<item>
<ptxt>
Die Türschachtleiste (1) mit Butylband (2) anbringen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950046.jpg" width = "88.000mm" height = "80.908mm" ver = "01" gw = "185" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
