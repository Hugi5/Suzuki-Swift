<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Kühlerlüfter-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1606010">Überprüfung der Kühlerlüfter-Baugruppe am Fahrzeug</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1606012001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Kühlmittel ablassen. 
<intxreftitleoff1 refid = "AGEAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder (1) des Kühlerlüftermotors abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Ausgleichsbehälter (2) ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Kühlereinlassschlauch (3) vom Kühler lösen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160005.swf" width = "88.000mm" height = "70.920mm" ver = "01" gw = "221" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Die Kühlerlüfter-Baugruppe vom Kühler abbauen.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AGEAP70A1606012002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kühlsystem mit Kühlmittel befüllen. 
<intxreftitleoff1 refid = "AGEAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kühlsystem auf Undichtigkeiten prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
