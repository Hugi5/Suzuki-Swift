<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1A04A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Die Ladekontrollleuchte leuchtet nicht, wenn die Zündung auf ON steht und der Motor ausgeschaltet ist.
</title>
<ptxt>
Fehler im Ladesystem werden durch eines oder mehrere der folgenden Symptome angezeigt: 
</ptxt>
<servinfosub id = "AGEAP70A1A04002001" page = "1">
<title>
Funktion der Ladekontrollleuchte
</title>
<diag type = "condition">
<condition>
<ptxt>
Die Ladekontrollleuchte leuchtet nicht, wenn die Zündung auf ON steht und der Motor ausgeschaltet ist.
</ptxt>
</condition>
<ps>
<ptxt>
Durchgebrannte Sicherung
</ptxt>
</ps>
<action>
<ptxt>
Sicherung austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Kombiinstrument defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Das Kombiinstrument austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
BCM überprüfen.
</ptxt>
<ptxt>
Modell mit Zündschalter: 
<intxreftitleoff1 refid = "AGEAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modell mit schlüssellosem Startsystem: 
<intxreftitleoff1 refid = "AGEAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
CAN-Kommunikationsleitung defekt
</ptxt>
</ps>
<action>
<ptxt>
Die CAN-Kommunikationsleitung reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung defekt
</ptxt>
</ps>
<action>
<ptxt>
Verkabelung reparieren oder austauschen.
</ptxt>
</action>
<ps>
<ptxt>
IC-Regler oder Feldspule defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
