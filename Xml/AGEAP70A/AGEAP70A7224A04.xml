<servinfo servinfosgmlid = "AGEAP70A7224A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kein bzw. unzureichendes Ausströmen kalter Luft (bei normaler Funktion der Magnetkupplung)
</title>
<diag type = "condition">
<condition>
<ptxt>
Kein bzw. unzureichendes Ausströmen kalter Luft (bei normaler Funktion der Magnetkupplung)
</ptxt>
</condition>
<ps>
<ptxt>
Nicht genügend oder zuviel Kältemittel
</ptxt>
</ps>
<action>
<ptxt>
Kältemittelmenge und System auf Undichtigkeiten überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Kondensator verstopft
</ptxt>
</ps>
<action>
<ptxt>
Kondensator überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A/C-Verdampfer verstopft oder eingefroren
</ptxt>
</ps>
<action>
<ptxt>
A/C-Verdampfer und Verdampfer-Temperatursensor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 und 
<intxreftitleoff1 refid = "AGEAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verdampfer-Temperatursensor defekt
</ptxt>
</ps>
<action>
<ptxt>
Verdampfer-Temperatursensor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defektes Expansionsventil
</ptxt>
</ps>
<action>
<ptxt>
Expansionsventil überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Trockenmittelverstopfung
</ptxt>
</ps>
<action>
<ptxt>
Trockenmittel und Kappe mit Filter überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Kompressor-Antriebsriemen locker oder gerissen
</ptxt>
</ps>
<action>
<ptxt>
Den Kompressor-Antriebsriemen überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rutschende Magnetkupplung
</ptxt>
</ps>
<action>
<ptxt>
Magnetkupplung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226047"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kompressor defekt
</ptxt>
</ps>
<action>
<ptxt>
Kompressor überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Luft im A/C-System
</ptxt>
</ps>
<action>
<ptxt>
Den Kondensator austauschen, anschließend entleeren und befüllen. 
<intxreftitleoff1 refid = "AGEAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Luftaustritt aus HVAC-Einheit oder Luftkanal
</ptxt>
</ps>
<action>
<ptxt>
HVAC-Einheit oder Luftkanal reparieren.
</ptxt>
</action>
<ps>
<ptxt>
