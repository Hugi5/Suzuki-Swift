<ptxt>
Gebläsemotor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zu viel Kompressoröl im A/C-System
</ptxt>
</ps>
<action>
<ptxt>
Überschüssiges Kompressoröl aus A/C-Systemkreislauf und Kompressor ablassen.
</ptxt>
</action>
</diag>
