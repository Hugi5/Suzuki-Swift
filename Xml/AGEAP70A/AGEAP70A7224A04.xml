</ptxt>
</ps>
<action>
<ptxt>
HVAC-Einheit überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
HVAC-Steuermodul defekt
</ptxt>
</ps>
<action>
<ptxt>
HVAC-Steuermodul überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Stellglied für Temperaturregelung defekt
</ptxt>
</ps>
<action>
<ptxt>
Stellglied für Temperaturregelung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
