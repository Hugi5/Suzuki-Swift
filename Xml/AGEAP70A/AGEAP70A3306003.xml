<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Verteilergetriebes
</title>
<servinfosub id = "AGEAP70A3306003001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die folgenden Öle ablassen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Schaltgetriebeöl: 
<intxreftitleoff1 refid = "AGEAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verteilergetriebeöl: 
<intxreftitleoff1 refid = "AGEAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Rechte Antriebswellen-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Kardanwelle ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den vorderen Radaufhängungsrahmen ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Hintere Motoraufhängung und hintere Motor-Befestigungsklammer ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Verteilergetriebe-Versteifungsstrebe (2) und die Verteilergetriebe-Schrauben festziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Verteilergetriebe (1) vom Getriebe lösen.
</ptxt>
<attention1>
<ptxt>
Beim Ausbauen des Verteilergetriebes vorsichtig vorgehen und dieses nicht fallen lassen. Andernfalls kann es zur Beschädigung des Verteilergetriebes und zu Verletzungen kommen.
</ptxt>
</attention1>
<figure>
<graphic graphicname = "IAP70A330004.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "213" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Den O-Ring (1) und den Passstift (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A330005.jpg" width = "88.000mm" height = "52.680mm" ver = "01" gw = "213" gh = "133"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AGEAP70A3306003002">
<title>
Einbau
</title>
<ptxt>
Zum Einbau den Ausbauvorgang unter Beachtung der folgenden Punkte umkehren.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Neuen O-Ring und neue Antriebswellenmutter verwenden.
</ptxt>
</item>
<item>
<ptxt>
Fett auf den O-Ring (1) auftragen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C004" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A330006.jpg" width = "88.000mm" height = "50.958mm" ver = "02" gw = "213" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Alle Verteilergetriebe-Schrauben mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T3C004">
<t-part>
Schraube des Verteilergetriebes
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Die Schrauben der Versteifungsstrebe für Verteilergetriebe wie folgt festziehen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Die Schrauben der Versteifungsstrebe für Verteilergetriebe &#34;2&#34; und &#34;3&#34; von Hand festziehen.
</ptxt>
</item>
<item>
<ptxt>
Die Versteifungsstrebe für Verteilergetriebe andrücken und die Schrauben der Versteifungsstrebe für Verteilergetriebe mit dem vorgeschriebenen Drehmoment in numerischer Reihenfolge (&#34;1&#34; – &#34;5&#34;) gleichmäßig und schrittweise anziehen.
</ptxt>
<torque>
<torqueitem id = "T3C005">
<t-part>
Schraube der Versteifungsstrebe für Verteilergetriebe*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330007.jpg" width = "88.000mm" height = "56.283mm" ver = "01" gw = "213" gh = "143"/>
</figure>
<figure>
<graphic graphicname = "IAP70A330008.jpg" width = "88.000mm" height = "55.083mm" ver = "01" gw = "202" gh = "140"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Die folgenden Schrauben und Muttern mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Schrauben des hinteren Motortraglagers und Halterungsschraube: 
<intxreftitleoff1 refid = "AGEAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Befestigungsschraube des Rahmens für Radaufhängung vorn: 
<intxreftitleoff1 refid = "AGEAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Unbedingt neue Befestigungsschrauben für die Radaufhängung vorn verwenden.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Mutter des Stabilisatorgelenks: 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schraube des Querlenker-Kugelgelenks: 
<intxreftitleoff1 refid = "AGEAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Mutter des Spurstangenkopfes: 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schraube des Vorderrad-Drehzahlsensors: 
<intxreftitleoff1 refid = "AGEAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kardanwellenschraube: 
<intxreftitleoff1 refid = "AGEAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Mutter des mittleren Traglagers: 
<intxreftitleoff1 refid = "AGEAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Abgasanlagen-Schraube: 
<intxreftitleoff1 refid = "AGEAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schraube der Versteifungsstrebe der Abgasanlage Nr. 1: 
<intxreftitleoff1 refid = "AGEAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Antriebswellenmutter: 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Unbedingt eine neue Antriebswellenmutter verwenden.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Radmutter: 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Die Antriebswellenmutter verstemmen. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Die folgenden Öle auffüllen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Schaltgetriebeöl: 
<intxreftitleoff1 refid = "AGEAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
	Verteilergetriebeöl: 
<intxreftitleoff1 refid = "AGEAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Sicherstellen, dass an den Anschlüssen kein Öl bzw. Abgas austritt.
</ptxt>
</item>
<item>
<ptxt>
Vorderradspur bestätigen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
