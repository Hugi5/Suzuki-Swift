<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1506004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau von Ölwanne und Ölpumpensieb
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1506003">Bauteile von Ölwanne und Ölpumpensieb</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1506004001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Den Ölmessstab herausziehen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den rechten Motorunterboden ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Ablassschraube herausdrehen und das Motoröl ablassen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Abgasrohr Nr. 1 ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Verteilergetriebe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Ölfilter ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Getriebeschrauben (1) und Schrauben (2) der Ölwanne herausdrehen.
</ptxt>
<figure>
<graphic graphicname = "I7V20A151012.swf" width = "88.000mm" height = "49.208mm" ver = "01" gw = "227" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Mit Spezialwerkzeug und Hammer die Ölwanne (1) vom Zylinderblock abmontieren.
</ptxt>
<servicetool>
<servicetoolitem id = "L1E005">
<s-part>
(A)
</s-part>
<s-number num = "09921-96510">
09921-96510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A151013.swf" width = "88.000mm" height = "49.206mm" ver = "02" gw = "230" gh = "123"/>
</figure>
</s1>
<c-change/>
<s1 page = "2">
<ptxt>
Falls erforderlich, das Ölpumpensieb ausbauen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Falls erforderlich, das Schwallblech in der Ölwanne und die Stehbolzen des Schwallblechs in der Ölwanne ausbauen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1506004002">
<title>
Einbau
</title>
<s1>
<ptxt>
Falls zuvor entfernt, den Stehbolzen (1) für das Ölwannen-Schwallblech wieder einsetzen und mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1E004">
<t-part>
Stehbolzen für Schwallblech in der Ölwanne
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Das Schwallblech (2) in die Ölwanne einsetzen und die Schwallblech-Schrauben (3) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1E005">
<t-part>
Schraube des Schwallblechs in der Ölwanne
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure page = "2">
<graphic graphicname = "I9P60A151002.swf" width = "88.000mm" height = "50.955mm" ver = "01" gw = "177" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Neuen O-Ring (1) mit Motoröl bestreichen und die O-Ringe am Ölpumpensieb (2) anbringen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Ölpumpensieb mit dem O-Ring an der Ölpumpe anbringen und dann zunächst die Schraube (3) und anschließend die Mutter (4) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1E006">
<t-part>
Schraube des Ölpumpensiebs*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1E007">
<t-part>
Halterungsmutter für Ölpumpensieb*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151003.jpg" width = "88.000mm" height = "61.290mm" ver = "01" gw = "199" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Die Passstifte (1) in die Ölwanne und den Zylinderblock einsetzen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A151004.jpg" width = "88.000mm" height = "67.299mm" ver = "01" gw = "207" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Einen neuen O-Ring (1) mit Motoröl bestreichen und wie abgebildet anbringen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Anlagefläche der Ölwanne entsprechend der Abbildung mit Dichtmittel bestreichen.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Vor dem Auftragen des Dichtmittels sicherstellen, dass die Anlagefläche sauber und trocken ist.
</ptxt>
</item>
<item>
<ptxt>
Überschüssiges Dichtmittel abwischen.
</ptxt>
</item>
<item>
<ptxt>
Die Ölwanne innerhalb von 2 Minuten nach dem Auftragen des Dichtmittels montieren.
</ptxt>
</item>
</list1>
</attention3>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M1E002" uid = "-491504098">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Dichtmittel
</m-desc>
<m-number>
99000-31260
</m-number>
<m-name>
SUZUKI Bond Nr.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<spec>
<title>
Dichtmittelmenge für Ölwanne
</title>
<ptxt>
Breite &#34;a&#34;: 3 mm (0,12 in.)
</ptxt>
<ptxt>
Höhe &#34;b&#34;: 2 mm (0,08 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7V20A151017.swf" width = "88.000mm" height = "59.875mm" ver = "01" gw = "146" gh = "153"/>
</figure>
</s1>
<s1>
<ptxt>
Die Ölwanne am Zylinderblock anbringen und die Ölwannenschrauben in der Reihenfolge &#34;1&#34; – &#34;17&#34; gleichmäßig und schrittweise mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1E008">
<t-part>
Ölwannenschraube*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151005.swf" width = "88.000mm" height = "63.567mm" ver = "01" gw = "227" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Die Getriebeschrauben (1) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1E009">
<t-part>
Getriebeschraube
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A151006.swf" width = "88.000mm" height = "46.039mm" ver = "01" gw = "227" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Ölfilter einbauen. 
<intxreftitleoff1 refid = "AGEAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Verteilergetriebe einbauen. 
<intxreftitleoff1 refid = "AGEAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Abgasrohr Nr. 1 anbringen. 
<intxreftitleoff1 refid = "AGEAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den rechten Motorunterboden montieren.
</ptxt>
</s1>
<s1>
<ptxt>
Ablassschraube einbauen und den Motor mit Motoröl auffüllen. 
<intxreftitleoff1 refid = "AGEAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Ölmessstab einführen.
</ptxt>
</s1>
<s1>
<ptxt>
Sicherstellen, dass an keinem Anschluss Motoröl bzw. Abgas austritt.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
