<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7214A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kein Kühlluftaustritt (Kühlerlüftermotor funktioniert nicht)
</title>
<diag type = "condition">
<condition>
<ptxt>
Kein Kühlluftaustritt (Kühlerlüftermotor funktioniert nicht)
</ptxt>
</condition>
<ps>
<ptxt>
Durchgebrannte Sicherung
</ptxt>
</ps>
<action>
<ptxt>
Die betreffenden Sicherungen überprüfen und dann auf einen Kurzschluss an Masse überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung oder Masseanschluss ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Die Verkabelung reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Kühlerlüftermotorrelais defekt
</ptxt>
</ps>
<action>
<ptxt>
Kühlerlüfterrelais überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kühlerlüftermotor ist defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Kühlerlüftermotor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
ECM defekt
</ptxt>
</ps>
<action>
<ptxt>
ECM überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7214017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
