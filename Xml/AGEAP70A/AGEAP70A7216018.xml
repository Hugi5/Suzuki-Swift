<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7216018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Expansionsventils
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7216007">Bauteile der HVAC-Einheit:Manuelle Ausführung</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A7216018001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Kältemittel mittels der Ausrüstung für Rückgewinnung und Wiederaufbereitung aus der Klimaanlage auffangen. Siehe dazu &#34;Rückgewinnung&#34; unter 
<intxref refid = "AGEAP70A7216007">Bauteile der HVAC-Einheit:Manuelle Ausführung</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Schraube (1) lösen, dann Flüssigkeitsleitung und Ansaugschlauch vom Expansionsventil (2) lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Schrauben (3) lockern und Expansionsventil entfernen.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A720028.swf" width = "88.000mm" height = "43.902mm" ver = "01" gw = "173" gh = "109"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7216018002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7216019">Überprüfung des Expansionsventils:Manuelle Ausführung</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und dabei die folgenden Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
O-Ring des Expansionsventils und Leitungen mit Kompressoröl bestreichen.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B104" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Kompressoröl
</m-desc>
<m-number>
99000-99095-00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Die Schrauben des Expansionsventils mit dem vorgegebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T7B102">
<t-part>
Schraube des Expansionsventils
</t-part>
<t-value1>
7,0
</t-value1>
<t-value2>
0,7
</t-value2>
<t-value3>
5,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Das A/C-System gemäß &#34;Entlüften&#34; und &#34;Befüllen&#34; in 
<intxref refid = "AGEAP70A7216001">Vorgehensweise für das Befüllen mit Kältemittel:Manuelle Ausführung</intxref>
 entlüften und befüllen.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
