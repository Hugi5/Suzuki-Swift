<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1604A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Überhitzung des Motors (Kühlerlüfter funktioniert nicht)
</title>
<diag type = "condition">
<condition>
<ptxt>
Überhitzung des Motors (Kühlerlüfter funktioniert nicht)
</ptxt>
</condition>
<ps>
<ptxt>
Sicherung durchgebrannt
</ptxt>
</ps>
<action>
<ptxt>
Die Sicherung überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Kühlerlüfterrelais ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Kühlerlüfterrelais überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ECT-Sensor ist defekt
</ptxt>
</ps>
<action>
<ptxt>
ECT-Sensor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kühlerlüftermotor ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Kühlerlüftermotor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung oder Masseanschluss ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Die Verkabelung reparieren.
</ptxt>
</action>
<ps>
<ptxt>
ECM defekt
</ptxt>
</ps>
<action>
<ptxt>
ECM und zugehörigen Schaltkreis prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
