<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1906007" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Zerlegung und Zusammenbau des Anlassermotors
</title>
<servinfosub id = "AGEAP70A1906007001">
<title>
Zerlegung
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1906002">Aus- und Einbau des Anlassermotors</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A1906004">Bauteile des Anlassermotors</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Vor dem Zerlegen wie gezeigt Einstellmarkierungen (1) und (2) anbringen, um eine korrekte Ausrichtung beim Zusammenbau sicherzustellen.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190005.swf" width = "88.000mm" height = "55.476mm" ver = "01" gw = "121" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Die Mutter (1) abschrauben und das Anschlusskabel (2) vom Magnetschalter (3) abklemmen.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190006.swf" width = "88.000mm" height = "55.476mm" ver = "01" gw = "145" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Die Schrauben (4) herausdrehen und den Magnetschalter (1) aus der Anlassermotor-Baugruppe herausnehmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Feder (2) und den Stößel (3) aus dem Magnetschaltergehäuse entfernen.
</ptxt>
<attention2>
<ptxt>
Das Magnetschaltergehäuse nicht zerlegen.
</ptxt>
<ptxt>
Das Magnetschaltergehäuse als Baugruppe austauschen, falls erforderlich.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I8C50B190007.swf" width = "88.000mm" height = "72.205mm" ver = "01" gw = "137" gh = "188"/>
</figure>
</s1>
<s1>
<ptxt>
Die Schrauben (1) herausdrehen und den Mitnehmer vom Ankergehäuse (2) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190008.swf" width = "88.000mm" height = "61.193mm" ver = "01" gw = "192" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Die Tülle (2) und die Planetenzahnräder (1) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190009.swf" width = "88.000mm" height = "39.697mm" ver = "01" gw = "134" gh = "96"/>
</figure>
</s1>
<s1>
<ptxt>
Die Gummidichtung (1) und die Platte (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190010.swf" width = "88.000mm" height = "55.234mm" ver = "01" gw = "170" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Die Wellenbaugruppe (1) samt Antriebshebel (2) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190011.swf" width = "88.000mm" height = "47.402mm" ver = "01" gw = "164" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Den Anschlagring (3) für das Ritzel in Richtung der Freilaufkupplung (4) (in Pfeilrichtung) ziehen und dann den Sprengring (2) mit einer Sprengringzange (5) abziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Dann den Anschlagring (3) für das Ritzel, die Freilaufkupplung (4) und das Hohlrad (1) von der Gangschaltschiene ziehen.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190012.swf" width = "88.000mm" height = "39.316mm" ver = "01" gw = "163" gh = "94"/>
</figure>
</s1>
<s1>
<ptxt>
Das Endgehäuse (1) entfernen und dann die Bürstenbaugruppe (2) vom Mitnehmer (3) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190013.swf" width = "88.000mm" height = "55.771mm" ver = "01" gw = "226" gh = "142"/>
</figure>
</s1>
<s1>
<ptxt>
Den Anker (1) vom Mitnehmer (2) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190014.swf" width = "88.000mm" height = "47.593mm" ver = "02" gw = "181" gh = "118"/>
</figure>
</s1>
<s1>
<ptxt>
Die Bürsten (1) und die Bürstenfedern (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I6JB01190014.swf" width = "88.000mm" height = "66.987mm" ver = "01" gw = "140" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1906007002">
<title>
Zusammenbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1906009">Überprüfung des Anlassermotors</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Die Bürstenfedern (2) und die Bürsten (1) am Bürstenhalter (3) anbringen.
</ptxt>
<figure>
<graphic graphicname = "I6JB01190015.swf" width = "88.000mm" height = "66.987mm" ver = "01" gw = "140" gh = "173"/>
</figure>
</s1>
<s1>
<ptxt>
Den Anker (2) am Mitnehmer anbringen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Bürstenbaugruppe (1) an den Anker (2) montieren und gleichzeitig die 4 Bürsten (3) nach außen drücken.
</ptxt>
<figure>
<graphic graphicname = "I8C50B190015.swf" width = "88.000mm" height = "90.437mm" ver = "01" gw = "193" gh = "240"/>
</figure>
</s1>
<s1>
<ptxt>
Das Endgehäuse (1) am Bürstenhalter anbringen und die Bürstenhalter-Schrauben (2) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1I003">
<t-part>
Bürstenhalter-Schraube
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
3,5
</t-value1>
<t-value2>
0,36
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190016.swf" width = "88.000mm" height = "49.914mm" ver = "01" gw = "183" gh = "125"/>
</figure>
</s1>
<s1>
<ptxt>
Fett auf den Zahnkranz der Ritzelwelle (1) und die Zähne des Hohlrads (2) auftragen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I001" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A191019.swf" width = "88.000mm" height = "31.442mm" ver = "01" gw = "205" gh = "72"/>
</figure>
</s1>
<s1>
<ptxt>
Das Hohlrad und die Freilaufkupplung (1) mit einem neuen Sprengring (3) und einem Anschlagring (2) für das Ritzel auf die Ritzelwelle (4) setzen.
</ptxt>
<attention3>
<ptxt>
Den Anschlagring für das Ritzel bezüglich Position und Ausrichtung so anbringen, wie in der Abbildung gezeigt.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IYSQ01190024.swf" width = "88.000mm" height = "42.999mm" ver = "01" gw = "159" gh = "105"/>
</figure>
</s1>
<s1>
<ptxt>
Fett auf den Antriebshebel (2) auftragen und die Wellenbaugruppe (1) so in das Ankergehäuse einsetzen, dass der Antriebshebel so ausgerichtet ist wie in der Abbildung dargestellt.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I002" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAY301190005.swf" width = "88.000mm" height = "47.402mm" ver = "02" gw = "164" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Die Bohrungen für die Ankergehäuseschrauben (3) und die Aussparungen in den Tüllen aufeinander ausrichten und die Tülle (1) in das Ankergehäuse einsetzen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Platte (5) und die Gummidichtung (4) am Ankergehäuse anbringen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Planetenräder (2) einfetten und an der Gangschaltschiene anbringen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I003" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I8C50B190019.swf" width = "88.000mm" height = "58.155mm" ver = "01" gw = "176" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Den Anlassermotor-Mitnehmer, den Anker, die Bürstenbaugruppe und das Endgehäuse (4) am Ankergehäuse (2) anbringen und dabei die vor der Zerlegung angebrachten Einstellmarkierungen (3) fluchten.
</ptxt>
</s1>
<s1>
<ptxt>
Die Endgehäuseschrauben (1) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1I004">
<t-part>
Endgehäuseschraube
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190020.swf" width = "88.000mm" height = "62.840mm" ver = "01" gw = "192" gh = "162"/>
</figure>
</s1>
<s1>
<ptxt>
Fett auf den Stößel auftragen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M1I004" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I8C50B190021.swf" width = "88.000mm" height = "54.810mm" ver = "01" gw = "142" gh = "138"/>
</figure>
</s1>
<s1>
<ptxt>
Den Magnetschalter (1), die Feder (2) und den Stößel (3) am Ankergehäuse (5) anbringen. Dabei die vor dem Ausbau angebrachten Einstellmarkierungen fluchten.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (4) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1I005">
<t-part>
Magnetschalterschraube
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190022.swf" width = "88.000mm" height = "72.616mm" ver = "01" gw = "137" gh = "189"/>
</figure>
</s1>
<s1>
<ptxt>
Das Anschlusskabel (1) an Anschlussklemme &#34;M&#34; (2) anklemmen und die Mutter des Anschlusskabels mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1I006">
<t-part>
Mutter des Anschlusskabels
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50B190023.swf" width = "88.000mm" height = "55.487mm" ver = "01" gw = "145" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Die Funktion des Magnetschalters überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1906009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
