</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 7.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA804004016">
<title>
Überprüfung der Kommunikation des ESP&#174;-Steuermoduls
