</s1>
<s1>
<ptxt>
Neuen Sicherungsring (1) fest einsetzen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Nadellager (2) einsetzen, mit Öl bestreichen und anschließend den Synchronring (3) und das 4. Gangrad montieren.
</ptxt>
<figure>
<graphic graphicname = "I2RH01520052.swf" width = "88.000mm" height = "45.751mm" ver = "01" gw = "170" gh = "113"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
