<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Übermäßiger Motorölverbrauch – Öl gelangt in den Verbrennungsraum
</title>
<ptxt>
Fehlersuche gemäß folgenden Anweisungen durchführen, wenn das ECM keine DTCs erfasst und bei 
<intxref refid = "AGEAP70A1104008">Sichtprüfung</intxref>
 und 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
 keine Mängel festgestellt werden.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Übermäßiger Motorölverbrauch – Öl gelangt in den Verbrennungsraum
</ptxt>
</condition>
<ps>
<ptxt>
Kolbenring schwergängig
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406035">Überprüfung von Zylinder, Kolben und Kolbenring</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kolben und Zylinder verschlissen
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406035">Überprüfung von Zylinder, Kolben und Kolbenring</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kolbenringnut und Ring verschlissen
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406035">Überprüfung von Zylinder, Kolben und Kolbenring</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kolbenringstoß falsch positioniert
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406034">Zerlegung und Zusammenbau von Kolben, Kolbenring, Pleuelstange und Zylinder</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Verschlissene oder beschädigte Ventilschaftdichtung
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406028">Überprüfung von Ventil und Ventilführung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Verschlissener Ventilschaft
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406028">Überprüfung von Ventil und Ventilführung</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
