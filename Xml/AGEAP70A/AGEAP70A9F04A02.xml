<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9O">
<servcat sctnbr = "09" scnbr = "15">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A9F04A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Schlechter Radioempfang
</title>
<ptxt>
Vor Durchführen der Fehlersuche anhand der Bedienungsanleitung überprüfen, ob das Symptom nicht auf eine unsachgemäße Bedienung zurückzuführen ist.
</ptxt>
<ptxt>
Kann der Fehler durch nachfolgende Fehlersuche nicht ermittelt werden, Audioanlage durch eine intakte ersetzen. Falls das Symptom verschwindet, ist die Audioanlage die Störungsursache.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Schlechter Radioempfang
</ptxt>
</condition>
<ps>
<ptxt>
Fehler im Radioantennensteckverbinder
</ptxt>
</ps>
<action>
<ptxt>
Radioantennensteckverbinder auf richtigen Anschluss überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Fehler der Radioantenne
</ptxt>
</ps>
<action>
<ptxt>
Durch eine intakte Radioantenne ersetzen und Empfang erneut überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Fehler im Radioantennenkabel
</ptxt>
</ps>
<action>
<ptxt>
Siehe 
<intxref refid = "AGEAP70A9F06005">Überprüfung des Radioantennenkabels</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Fehler im Stromversorgungskreis der Radioantenne
</ptxt>
</ps>
<action>
<ptxt>
Siehe 
<intxref refid = "AGEAP70A9F02001">Schaltplan der Audioanlage</intxref>
 und 
<intxref refid = "AGEAP70A9F04001">Überprüfung des Audiosystems</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
