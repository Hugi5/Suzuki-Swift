<servinfosub id = "AGEAP70A9304007002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A9304007003">
<testgroup id = "AGEAP70A9304007004">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTC löschen. 
<intxreftitleoff1 refid = "AGEAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1820 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das Kombiinstrument austauschen und erneut DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Auf zeitweilige Störung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
