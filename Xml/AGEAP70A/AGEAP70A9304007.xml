<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1820: Fehler des internen Steuermodul-EEPROM 
</emph>
</ptxt>
<ptxt>
Speicher im Kombiinstrument ist defekt.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Kombiinstrument
</ptxt>
</item>
<item>
<ptxt>
Parksensorsystem-Steuermodul
</ptxt>
</item>
<item>
<ptxt>
Schaltkreis LIN-Kommunikation
</ptxt>
</item>
</list1>
