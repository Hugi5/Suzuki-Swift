<title>
Aus- und Einbau der mittleren Innenantenne
</title>
<servinfosub id = "AGEAP70AA506007001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Mittelkonsolenfach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder (1) lösen, und anschließend mittlere Innenantenne (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50026.swf" width = "88.000mm" height = "59.622mm" ver = "01" gw = "196" gh = "153"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA506007002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70AA506010">Überprüfung der Antenne</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
