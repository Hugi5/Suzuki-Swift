<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1806004" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung der Zündspulen-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1806003">Aus- und Einbau der Zündspulen-Baugruppe</intxrefpoff>
</ptxt>
<ptxt>
Die Zündspulen-Baugruppe auf folgende Punkte überprüfen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Beschädigung
</ptxt>
</item>
<item>
<ptxt>
Verschleiß
</ptxt>
</item>
<item>
<ptxt>
Korrosion an Anschlussklemmen
</ptxt>
</item>
</list1>
<ptxt>
Falls das Prüfergebnis nicht den Vorgaben entspricht, die Zündspulen-Baugruppe austauschen.
</ptxt>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
