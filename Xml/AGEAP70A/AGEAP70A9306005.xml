<servinfo servinfosgmlid = "AGEAP70A9306005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Parksensors (falls vorhanden)
</title>
<servinfosub id = "AGEAP70A9306005001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Hinteren Stoßfänger entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder des Parksensors lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Abdeckung (1) des Parksensors wie in der Abbildung gezeigt abziehen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930025.jpg" width = "88.000mm" height = "106.836mm" ver = "01" gw = "208" gh = "286"/>
</figure>
</s1>
<s1>
<ptxt>
Die Klauen (1) öffnen und Parksensor (2) wie in der Abbildung gezeigt entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930026.jpg" width = "88.000mm" height = "63.752mm" ver = "01" gw = "196" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
Ggf. Sensorhalterung entfernen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9306005002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9306006">Überprüfung der Parksensoren (falls vorhanden)</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den Einbaubereich der Sensorhalterung (1) säubern und entfetten.
</ptxt>
</item>
<item>
<ptxt>
Ein Primer (SUMITOMO 3M K-520 bzw. 4298UV oder gleichwertig) auf den Einbaubereich der Sensorhalterung auftragen.
</ptxt>
</item>
<item>
<ptxt>
Sensorhalterung in der vorgeschriebenen Richtung wie in der Abbildung dargestellt installieren.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A930039.jpg" width = "88.000mm" height = "98.016mm" ver = "01" gw = "199" gh = "261"/>
