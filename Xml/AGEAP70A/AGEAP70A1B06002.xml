<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1K">
<servcat sctnbr = "01" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1B06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Abgaskrümmers
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1B06001">Bauteile des Abgassystems</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1B06002001" page = "2">
<title>
Ausbau
</title>
<attention2>
<ptxt>
Den Abgaskrümmer nicht fallen lassen. Der integrierte Katalysator kann durch den Aufprall beschädigt werden.
</ptxt>
</attention2>
<s1 page = "2">
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
A/F-Sensorstecker (1) abklemmen (Steckverbinderfarbe: schwarz) und HO2S-Steckverbinder (2) (Steckverbinderfarbe: grau) abklemmen und aus der Aufnahme lösen.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0002.swf" width = "88.000mm" height = "53.833mm" ver = "01" gw = "171" gh = "136"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Abgasrohr Nr. 1 (1) vom Abgaskrümmer abnehmen.
</ptxt>
<figure page = "2">
<graphic graphicname = "I7V20A1B1003.swf" width = "88.000mm" height = "51.237mm" ver = "01" gw = "163" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Versteifungsstrebe für Abgaskrümmer (2) entfernen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Abgaskrümmerabdeckung (3) vom Abgaskrümmer abmontieren.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Falls erforderlich A/F-Sensor (4) und HO2S (5) vom Abgaskrümmer entfernen. 
<intxreftitleoff1 refid = "AGEAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den Abgaskrümmer (1) und dessen Dichtung vom Zylinderkopf abnehmen.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P1B0003.swf" width = "88.000mm" height = "70.972mm" ver = "01" gw = "193" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1B06002002" page = "2">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Eine neue Dichtung verwenden.
</ptxt>
</item>
<item>
<ptxt>
Die Schrauben und Muttern des Abgaskrümmers mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1K001">
<t-part>
Abgaskrümmerschraube
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6,1
</t-value2>
<t-value3>
44,5
</t-value3>
</torqueitem>
<torqueitem id = "T1K002">
<t-part>
Abgaskrümmermutter
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6,1
</t-value2>
<t-value3>
44,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1002.jpg" width = "88.000mm" height = "57.647mm" ver = "02" gw = "199" gh = "147"/>
</figure>
</item>
<item>
<ptxt>
A/F-Sensor und beheizte Lambdasonde einbauen. 
<intxreftitleoff1 refid = "AGEAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Die Abgaskrümmer-Versteifungsstreben wie folgt einbauen.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Die Abgaskrümmer-Versteifungsstreben (1) anbringen, und dann die Muttern (2) der Abgaskrümmer-Versteifungsstrebe von Hand festziehen.
</ptxt>
</item>
<item>
<ptxt>
Die Schrauben (3) der Abgaskrümmer-Versteifungsstrebe, und dann die Muttern (2) der Abgaskrümmer-Versteifungsstrebe von Hand festziehen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P1B0004.swf" width = "88.000mm" height = "64.959mm" ver = "01" gw = "172" gh = "168"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Die Schrauben des Auspuffrohrs Nr. 1 mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1K003">
<t-part>
Schraube von Abgasrohr Nr. 1
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
43
</t-value1>
<t-value2>
4,4
</t-value2>
<t-value3>
32,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1B1004.swf" width = "88.000mm" height = "54.949mm" ver = "01" gw = "153" gh = "139"/>
</figure>
</item>
<item>
<ptxt>
Den Motor laufen lassen und auf Abgasaustritt prüfen.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
