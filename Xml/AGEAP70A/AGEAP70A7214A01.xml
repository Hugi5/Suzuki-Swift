<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7214A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Gebläsemotor funktioniert nicht
</title>
<diag type = "condition">
<condition>
<ptxt>
Gebläsemotor funktioniert nicht
</ptxt>
</condition>
<ps>
<ptxt>
Durchgebrannte Sicherung
</ptxt>
</ps>
<action>
<ptxt>
Die betreffenden Sicherungen überprüfen und dann auf einen Kurzschluss an Masse überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Gebläsemotorrelais defekt
</ptxt>
</ps>
<action>
<ptxt>
Gebläsemotorrelais überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gebläsemotorwiderstand defekt
</ptxt>
</ps>
<action>
<ptxt>
Gebläsemotorwiderstand überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vorwahl für Gebläsedrehzahl defekt
</ptxt>
</ps>
<action>
<ptxt>
Vorwahl für Gebläsedrehzahl überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung oder Masseanschluss ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Die Verkabelung reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Gebläsemotor defekt
</ptxt>
</ps>
<action>
<ptxt>
Gebläsemotor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fremdkörper eingedrungen
</ptxt>
</ps>
<action>
<ptxt>
Fremdkörper entfernen.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
