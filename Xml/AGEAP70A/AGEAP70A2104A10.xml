<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A2104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Ausgebeulte Reifen
</title>
<diag type = "condition">
<condition>
<ptxt>
Ausgebeulte Reifen
</ptxt>
</condition>
<ps>
<ptxt>
Radspur falsch eingestellt
</ptxt>
</ps>
<action>
<ptxt>
Radspur überprüfen und einstellen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vordere Federbein-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
Die vordere Federbein-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radlager verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Radlager austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Übermäßige Unwucht eines Rads oder Reifens
</ptxt>
</ps>
<action>
<ptxt>
Rad und/oder Reifen reparieren oder austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Querlenkeranschlüsse verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Querlenker austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radunwucht
</ptxt>
</ps>
<action>
<ptxt>
Reifen auswuchten oder ersetzen.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
