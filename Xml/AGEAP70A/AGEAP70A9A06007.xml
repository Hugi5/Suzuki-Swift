<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9A06007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Vordertür-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9A06006">Bauteile der Vordertür</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9A06007001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Vordertürverkleidung ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Steckverbinder des Türkabelbaums von der Tür abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Türfangschraube (1) herausdrehen.
</ptxt>
<figure>
<graphic graphicname = "I9W10P9A0009.swf" width = "88.000mm" height = "70.937mm" ver = "02" gw = "193" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Das Türblech (1) mit einem Wagenheber (2) abstützen. Hierzu Lappen (3) und ein Holzbrett (4) zwischen Wagenheber und Türblech platzieren, wie in der Abbildung gezeigt.
</ptxt>
<figure>
<graphic graphicname = "I2RH019A0003.swf" width = "88.000mm" height = "48.545mm" ver = "01" gw = "144" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Die Schrauben (2) herausdrehen, und die Vordertür (1) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I9W10P9A0023.swf" width = "88.000mm" height = "64.886mm" ver = "02" gw = "161" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Das Türscharnier bei Bedarf nach Ausbau des Frontkotflügels entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9A06007002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Beim Austausch der Tür die Ersatztür innen mit Korrosionsschutzwachs für korrekte Korrosionsschutzbehandlung beschichten. 
<intxreftitleoff1 refid = "AGEAP70A9C06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Dichtmittel auf die Montagefläche &#34;A&#34; des Türscharniers (1), und Fett auf den Drehbereich &#34;B&#34; des Türscharniers (1) auftragen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1215" id = "M9J002" uid = "27">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Dichtmittel
</m-desc>
<m-number>
99000-31110
</m-number>
<m-name>
SUZUKI Bond Nr.1215
</m-name>
<ptxt>
</ptxt>
</materialitem>
<materialitem name = "SUZUKI Super Grease A" id = "M9J003" uid = "1126491901">
<m-part>
&#34;B&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9W10P9A0010.jpg" width = "88.000mm" height = "70.516mm" ver = "01" gw = "228" gh = "183"/>
</figure>
</item>
<item>
<ptxt>
Die Schrauben des Vordertürscharniers und die Türfangschraube mit dem vorgeschriebenen Drehmoment festziehen. 
<intxreftitleoff1 refid = "AGEAP70A9A06006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Wenn ein Türfang (1) eingebaut ist, sicherstellen, dass die Ausrichtmarkierung (2) nach oben weist.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Rechte Tür: Markierung &#34;R&#34; weist nach oben
</ptxt>
</item>
<item>
<ptxt>
Linke Tür: Markierung &#34;L&#34; weist nach oben
</ptxt>
<figure>
<graphic graphicname = "I9W10P9A0011.swf" width = "88.000mm" height = "71.083mm" ver = "02" gw = "193" gh = "185"/>
</figure>
</item>
</list2>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Die Position des Tür-Schließbügels einstellen. 
<intxreftitleoff1 refid = "AGEAP70A9606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nach dem Einbau die Tür öffnen und schließen, um zu prüfen, ob sie leicht und einwandfrei geschlossen werden kann.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
