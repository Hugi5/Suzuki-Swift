<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104012" svcinfotypenbr = "06" svcinfoqualnbr = "03" supplyoff = "1" modify = "0">
<title>
MIL bleibt nach Starten des Motors an
</title>
<servinfosub id = "AGEAP70A1104012001">
<title>
Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A1104012002">
<testgroup id = "AGEAP70A1104012003">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Den Motor anlassen und dann bei laufendem Motor erneut die DTCs des ECMs abrufen.
</ptxt>
</test1>
<question>
Liegen DTCs vor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Fehlersuche für einschlägiges MIL-Symptom
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Durch ein intaktes Kombiinstrument ersetzen und erneut DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Falls MIL weiterhin leuchtet, ECM austauschen und MIL-Funktion erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
