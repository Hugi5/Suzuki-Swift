<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1806005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung des Zündzeitpunkts
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Der Zündzeitpunkt kann nicht eingestellt werden. Wenn der Zündzeitpunkt nicht den Vorgaben entspricht, die Komponenten des Zündsystems überprüfen.
</ptxt>
</item>
<item>
<ptxt>
Zur Identifizierung der Zylinder siehe 
<intxref refid = "AGEAP70A1101001">Hinweise zu Sauberkeit und Sorgfalt</intxref>
.
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Bei Zündung auf &#34;OFF&#34; das Diagnosegerät an den DLC (1) anschließen.
</ptxt>
<servicetool>
<servicetoolitem id = "L1H001">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI-Testgerät (SUZUKI-SDT)
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A180005.jpg" width = "88.000mm" height = "67.502mm" ver = "01" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Den Motor starten und auf normale Betriebstemperatur bringen.
</ptxt>
</s1>
<s1>
<ptxt>
Sicherstellen, dass alle elektrischen Verbraucher außer der Zündung ausgeschaltet sind.
</ptxt>
</s1>
<s1>
<ptxt>
Sicherstellen, dass die Leerlaufdrehzahl den Vorgaben entspricht. Siehe 
<intxref refid = "AGEAP70A1106001">Überprüfung der Leerlaufdrehzahl und der IAC-Drosselklappenöffnung</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Den Zündzeitpunkt wie im folgenden Schritt beschrieben prüfen.
</ptxt>
<ptxt>
Falls ein Ergebnis von der Vorgabe abweicht, folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kurbelwinkelsensor
</ptxt>
</item>
<item>
<ptxt>
Kurbelwinkel-Sensorplatte
</ptxt>
</item>
<item>
<ptxt>
ECM und zugehöriger Schaltkreis
</ptxt>
</item>
<item>
<ptxt>
Nockenwellensensor
</ptxt>
</item>
<item>
<ptxt>
Zahn am Geberrad der Nockenwelle
</ptxt>
</item>
<item>
<ptxt>
Kurbelwelle
</ptxt>
</item>
<item>
<ptxt>
Kurbelwellenriemenscheibe
</ptxt>
</item>
<item>
<ptxt>
Keil der Kurbelwellenriemenscheibe
</ptxt>
</item>
</list1>
<s2>
<ptxt>
Mit dem SUZUKI-Diagnosegerät sicherstellen, dass der Zündzeitpunkt innerhalb der Vorgaben liegt.
</ptxt>
</s2>
<s2>
<ptxt>
Die Zündlichtpistole (1) an den Zündspulen-Kabelbaum für Zylinder Nr. 1 anschließen und prüfen, ob der Zündzeitpunkt innerhalb der Vorgabe liegt.
</ptxt>
</s2>
<spec-sdm>
<sdm-title>
Zündzeitpunkt
</sdm-title>
<sdm1>
<sdm-condition>
</sdm-condition>
<sdm-value>
1&#176; bis 15&#176; v.OT (bei vorgegebener Leerlaufdrehzahl)
</sdm-value>
</sdm1>
</spec-sdm>
<spec>
<title>
Zündfolge
</title>
<ptxt>
1 – 3 – 4 – 2
</ptxt>
</spec>
<servicetool>
<servicetoolitem id = "L1H002">
<s-part>
(A)
</s-part>
<s-number num = "09930-76420">
09930-76420
</s-number>
</servicetoolitem>
<servicetoolitem id = "L1H003">
<s-part>
(A)
</s-part>
<s-number num = "09930-76310">
09930-76310
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A180007.swf" width = "88.000mm" height = "52.060mm" ver = "01" gw = "178" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Bei Motor im Leerlauf sicherstellen, dass bei Erhöhung der Motordrehzahl der Zündzeitpunkt vorverstellt wird.
</ptxt>
<ptxt>
Ist das Prüfergebnis nicht in Ordnung, die folgenden Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
ECM und zugehöriger Schaltkreis: 
<intxreftitleoff1 refid = "AGEAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
TP-Sensor: 
<intxreftitleoff1 refid = "AGEAP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
APP-Sensor: 
<intxreftitleoff1 refid = "AGEAP70A1306006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
