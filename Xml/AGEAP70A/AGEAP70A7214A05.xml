<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7214A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kein Kaltluftaustritt (Magnetkupplung funktioniert nicht)
</title>
<diag type = "condition">
<condition>
<ptxt>
Kein Kaltluftaustritt (Magnetkupplung funktioniert nicht)
</ptxt>
</condition>
<ps>
<ptxt>
Kein Kältemittel
</ptxt>
</ps>
<action>
<ptxt>
Rückgewinnung des Kältemittels, Entlüftung und Befüllung durchführen. 
<intxreftitleoff1 refid = "AGEAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Durchgebrannte Sicherung
</ptxt>
</ps>
<action>
<ptxt>
Die betreffenden Sicherungen überprüfen und dann auf einen Kurzschluss an Masse überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
A/C-Schalter defekt
</ptxt>
</ps>
<action>
<ptxt>
A/C-Schalter überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216034"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vorwahl für Gebläsedrehzahl defekt
</ptxt>
</ps>
<action>
<ptxt>
Vorwahl für Gebläsedrehzahl überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verdampfer-Temperatursensor defekt
</ptxt>
</ps>
<action>
<ptxt>
Verdampfer-Temperatursensor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Drucksensor für A/C-Kältemittel defekt
</ptxt>
</ps>
<action>
<ptxt>
Den Drucksensor für A/C-Kältemittel überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung oder Masseanschluss ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Die Verkabelung reparieren.
</ptxt>
</action>
<ps>
<ptxt>
ECM und zugehöriger Schaltkreis defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
ECM überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1104070"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Magnetkupplung defekt
</ptxt>
</ps>
<action>
<ptxt>
Magnetkupplung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kompressor-Antriebsriemen locker oder gerissen
</ptxt>
</ps>
<action>
<ptxt>
Den Kompressor-Antriebsriemen überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kompressor defekt
</ptxt>
</ps>
<action>
<ptxt>
Kompressor überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Kompressorrelais defekt
</ptxt>
</ps>
<action>
<ptxt>
Kompressorrelais überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
BCM defekt
</ptxt>
</ps>
<action>
<ptxt>
BCM überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
