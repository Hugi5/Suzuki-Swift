<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A4106017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Hauptbremszylinder-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4106015">Bauteile des Hauptbremszylinders</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A4106016">Überprüfung der Hauptbremszylinder-Baugruppe am Fahrzeug</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Keinesfalls den Hauptbremszylinder zerlegen. Dadurch würde die ursprüngliche Funktion beeinträchtigt werden.
</ptxt>
<ptxt>
Bei Mängeln den Hauptbremszylinder als Baugruppe erneuern.
</ptxt>
</item>
<item>
<ptxt>
Lackierte Flächen vor Bremsflüssigkeit schützen. Die Lackierung wird von der Bremsflüssigkeit angegriffen. Wird Flüssigkeit verschüttet, diese sofort mit Wasser abspülen.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AGEAP70A4106017001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Batterie und Batteriefach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Außenfläche des Hauptbremszylinders reinigen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder (1) des Warnschalters für Bremsflüssigkeitsstand vom Ausgleichsbehälter abziehen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410002.swf" width = "88.000mm" height = "65.516mm" ver = "01" gw = "199" gh = "169"/>
</figure>
</s1>
<s1>
<ptxt>
Die Bremsflüssigkeit aus dem Behälter ablassen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Schlauch für den Kupplungsausgleichbehälter vom Ausgleichsbehälter abziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Mit dem Spezialwerkzeug die Überwurfmuttern lösen und die Bremsleitungen (1) vom Hauptbremszylinder abziehen.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A002">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Die Haltemuttern (2) des Hauptbremszylinders abschrauben.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410010.swf" width = "88.000mm" height = "60.983mm" ver = "01" gw = "159" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Den Hauptbremszylinder (1) und den O-Ring (2) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410011.swf" width = "88.000mm" height = "46.988mm" ver = "02" gw = "159" gh = "117"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A4106017004">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4106019">Überprüfung der Hauptbremszylinder-Baugruppe</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Einen neuen O-Ring (2) in die Hauptbremszylinder-Baugruppe (1) einsetzen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410011.swf" width = "88.000mm" height = "46.988mm" ver = "02" gw = "159" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Den Hauptbremszylinder am Bremskraftverstärker anbringen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Befestigungsmuttern des Hauptbremszylinders mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T4A004">
<t-part>
Befestigungsmutter des Hauptbremszylinders
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
18
</t-value1>
<t-value2>
1,8
</t-value2>
<t-value3>
13,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Die Bremsleitung (1) an den Hauptbremszylinder anschließen und die Überwurfmuttern mit dem Spezialwerkzeug und dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A003">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<torque>
<torqueitem id = "T4A005">
<t-part>
Überwurfmutter der Bremsleitung
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A410012.swf" width = "88.000mm" height = "60.983mm" ver = "01" gw = "159" gh = "156"/>
</figure>
</s1>
<s1>
<ptxt>
Den Schlauch für den Kupplungsausgleichbehälter an den Ausgleichsbehälter anschließen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder des Warnschalters für Bremsflüssigkeitsstand anklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Batteriefach und Batterie einbauen. 
<intxreftitleoff1 refid = "AGEAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nach dem Einbau das Bremssystem entlüften. 
<intxreftitleoff1 refid = "AGEAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Alle eingebauten Teile auf Bremsflüssigkeitsleckage prüfen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Bremspedal auf Spiel prüfen. 
<intxreftitleoff1 refid = "AGEAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sicherstellen, dass das Bremssystem einwandfrei funktioniert und keine Flüssigkeitsleckagen bestehen.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
