<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9906004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Schiebedachscheibe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9906001">Komponenten des Schiebedachs</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9906004001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Sonnenblende (1) vollständig öffnen, und das Schiebedach hochkippen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990022.swf" width = "88.000mm" height = "43.115mm" ver = "01" gw = "138" gh = "106"/>
</figure>
</s1>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schiebedachscheibe durch Entfernen der Scheiben-Befestigungsschrauben (TORX<sup>&#174;</sup> T25) (1) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I5JB0A990003.swf" width = "88.000mm" height = "45.253mm" ver = "01" gw = "185" gh = "112"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9906004002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Schiebedachscheiben-Befestigungsschrauben mit dem vorgeschriebenen Drehmoment festziehen. 
<intxreftitleoff1 refid = "AGEAP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Einbauposition der Schiebedachscheibe anpassen. 
<intxreftitleoff1 refid = "AGEAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Den Schiebedachmotor initialisieren. 
<intxreftitleoff1 refid = "AGEAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
