<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70AA506005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau von Heckklappenöffner und Steuerschalter
</title>
<servinfosub id = "AGEAP70AA506005001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Heckklappenverkleidung ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9606010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder (1) von Heckklappenöffner und Steuerschalter sowie Klammer lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Untere Heckklappenverkleidung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Die Schrauben herausdrehen und dann den Heckklappenöffner und Steuerschalter (1) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50023.swf" width = "88.000mm" height = "54.154mm" ver = "01" gw = "198" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA506005002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70AA506009">Überprüfung des Steuerschalters</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
