<servinfosub id = "AGEAP70A1804001002">
<title>
Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A1804001003">
<testgroup id = "AGEAP70A1804001004">
<question>
Wurde die &#34;Überprüfung des Motor- und Abgassteuerungssystems&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A1104001">Überprüfung des Motor- und Abgassteuerungssystems</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1804001005">
<title>
Zündfunkentest 1
</title>
<test1>
<ptxt>
Zündfunkentest durchführen. 
<intxreftitleoff1 refid = "AGEAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Prüfergebnis in Ordnung?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1804001006">
<title>
Überprüfung des Zündzeitpunkts
</title>
<test1>
<ptxt>
Zündzeitpunkt überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das Zündsystem ist in Ordnung.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekte Teile reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1804001007">
<title>
Feststellen des defekten Zylinders
</title>
<test1>
<ptxt>
Den/die Zylinder mit Mängeln beim Zündfunkentest feststellen.
</ptxt>
</test1>
<question>
Alle Zylinder?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1804001008">
<title>
Zündfunkentest 2
</title>
<test1>
<ptxt>
Die Zündkerze jedes Zylinders mit Störung durch eine Zündkerze eines normal zündenden Zylinders ersetzen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündfunkentest durchführen. 
<intxreftitleoff1 refid = "AGEAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Prüfergebnis in Ordnung?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zündkerze austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 6.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1804001009">
<title>
Zündfunkentest 3
</title>
<test1>
<ptxt>
Die Zündspule jedes Zylinders mit Störung durch eine Zündspule eines normal zündenden Zylinders ersetzen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündfunkentest durchführen. 
<intxreftitleoff1 refid = "AGEAP70A1804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Prüfergebnis in Ordnung?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zündspule austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Weiter mit Schritt 7.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AGEAP70A1804001010">
<title>
Überprüfung von Stromversorgungs- und Massekreisen der Zündspulen-Baugruppe
</title>
<test1>
<ptxt>
Bei Zündung auf &#34;OFF&#34; die Steckverbinder &#34;C01&#34; und &#34;E01&#34; vom ECM und die Zündspulen-Steckverbinder abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf ordnungsgemäßen Klemmenanschluss an den Zündspulen-Steckverbindern prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn die Anschlüsse in Ordnung sind, folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand in den Schaltkreisen &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;, &#34;A4&#34;, &#34;C1&#34;, &#34;C2&#34;, &#34;C3&#34; und &#34;C4&#34;: weniger als 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen den Schaltkreisen &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;, &#34;A4&#34;, &#34;C1&#34;, &#34;C2&#34;, &#34;C3&#34; und &#34;C4&#34; und Masse: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen der Anschlussklemme des Schaltkreises &#34;A1&#34; und der anderen Anschlussklemme am Steckverbinder der Zündspule: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen der Anschlussklemme des Schaltkreises &#34;A2&#34; und der anderen Anschlussklemme am Steckverbinder der Zündspule: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen der Anschlussklemme des Schaltkreises &#34;A3&#34; und der anderen Anschlussklemme am Steckverbinder der Zündspule: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen der Anschlussklemme des Schaltkreises &#34;A4&#34; und der anderen Anschlussklemme am Steckverbinder der Zündspule: unendlich
</ptxt>
</item>
<item>
<ptxt>
Spannung in den Schaltkreisen &#34;A1&#34;, &#34;A2&#34;, &#34;A3&#34;, &#34;A4&#34;, &#34;C1&#34;, &#34;C2&#34;, &#34;C3&#34; und &#34;C4&#34;: 0 bis 1 V (bei Zündung auf &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
Werden die Vorgaben erfüllt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekte Teile reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1804001011">
<title>
Überprüfung der Treiberschaltkreise der Zündspulen-Baugruppe
</title>
<test1>
<ptxt>
Bei Zündung auf &#34;OFF&#34; die folgenden Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand der Schaltkreise &#34;B1&#34;, &#34;B2&#34;, &#34;B3&#34; und &#34;B4&#34;: weniger als 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen jedem der Schaltkreise &#34;B1&#34;, &#34;B2&#34;, &#34;B3&#34; und &#34;B4&#34; und Masse: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen der Anschlussklemme des Schaltkreises &#34;B1&#34; und der anderen Anschlussklemme am Steckverbinder der Zündspule: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen der Anschlussklemme des Schaltkreises &#34;B2&#34; und der anderen Anschlussklemme am Steckverbinder der Zündspule: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen der Anschlussklemme des Schaltkreises &#34;B3&#34; und der anderen Anschlussklemme am Steckverbinder der Zündspule: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen der Anschlussklemme des Schaltkreises &#34;B4&#34; und der anderen Anschlussklemme am Steckverbinder der Zündspule: unendlich
</ptxt>
</item>
<item>
<ptxt>
Spannung der Schaltkreise &#34;B1&#34;, &#34;B2&#34;, &#34;B3&#34; und &#34;B4&#34;: 0 bis 1 V (bei Zündung auf &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
Werden die Vorgaben erfüllt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 9.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekte Teile reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1804001012">
<title>
Überprüfung von Kurbelwinkelsensor und Nockenwellensensor
</title>
<test1>
<ptxt>
Kurbelwinkelsensor und den Nockenwellensensor überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kurbelwinkelsensor: 
<intxreftitleoff1 refid = "AGEAP70A1306020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nockenwellensensor: 
<intxreftitleoff1 refid = "AGEAP70A1306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
ECM austauschen und Zündfunken erneut prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kurbelwinkelsensor oder Nockenwellensensor erneuern.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
