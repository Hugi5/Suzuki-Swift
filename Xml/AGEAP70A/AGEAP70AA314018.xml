<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA314018" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1188
</title>
<servinfosub id = "AGEAP70AA314018001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1188: Kommunikationsfehler des Transponders
</emph>
</ptxt>
<ptxt>
Verifizierungsfehler zwischen Zündschlüssel und BCM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Zündschlüssel ist nicht registriert
</ptxt>
</item>
<item>
<ptxt>
Zündschlüssel
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70AA314018002">
<title>
DTC-Fehlersuche
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Vor der Fehlersuche unbedingt 
<intxref refid = "AGEAP70AA310002">Vorsichtsmaßnahmen für Wegfahrsperrensystem:Modell mit Zündschalter</intxref>
 lesen.
</ptxt>
</item>
<item>
<ptxt>
Falls das BCM mit einem anderen Fahrzeug registriert wurde (gebrauchtes Teil), können die Zündschlüssel nicht registriert werden. Immer ein neues BCM einbauen, wenn ein Austausch notwendig ist.
</ptxt>
</item>
</list1>
</attention3>
<diag type = "test" id = "AGEAP70AA314018003">
<testgroup id = "AGEAP70AA314018004">
<title>
Überprüfung des Motorstarts
</title>
<test1>
<ptxt>
Den Motor mit dem Reserve-Zündschlüssel starten.
</ptxt>
</test1>
<question>
Springt der Motor an?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ende. (Zündschlüssel wurde nicht registriert)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA314018005">
<title>
Registrierung des Zündschlüssels
</title>
<test1>
<ptxt>
&#34;Wgfhrspr-Schlsslreg.&#34; durchführen. 
<intxreftitleoff1 refid = "AGEAP70AA316002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1188 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
BCM austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (Zündschlüssel wurde nicht registriert)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
