<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7216008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der HVAC-Einheit
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7216007">Bauteile der HVAC-Einheit:Manuelle Ausführung</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A7216017">Überprüfung des Verdampfer-Temperatursensors:Manuelle Ausführung</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A7216008001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Airbagsystem deaktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Kältemittel mit der Auffang- und Recyclingausrüstung aus der Klimaanlage ablassen. Siehe dazu &#34;Rückgewinnung&#34; unter 
<intxref refid = "AGEAP70A7216001">Vorgehensweise für das Befüllen mit Kältemittel:Manuelle Ausführung</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Motorkühlmittel ablassen. 
<intxreftitleoff1 refid = "AGEAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Anschließend die Heizungsschläuche von der HVAC-Einheit abziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Die obere Wasserkastenzierblende entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Schraube (1) lösen, dann Flüssigkeitsleitung und Ansaugschlauch vom Expansionsventil (2) lösen.
</ptxt>
<figure>
<graphic graphicname = "I7V20A720023.swf" width = "88.000mm" height = "41.377mm" ver = "01" gw = "98" gh = "101"/>
</figure>
</s1>
<s1>
<ptxt>
Das Armaturenbrett von der Karosserie abbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Muttern (2) abschrauben und die HVAC-Einheit (1) von der Karosserie abbauen.
</ptxt>
<attention3>
<ptxt>
Beim Ausbau der HVAC-Einheit darauf achten, dass kein Motorkühlmittel und Kompressoröl auf dem Fahrzeugboden verschüttet wird.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A721018.jpg" width = "88.000mm" height = "77.963mm" ver = "01" gw = "231" gh = "204"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7216008002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7216015">Überprüfung des Verdampfers:Manuelle Ausführung</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A7216016">Aus- und Einbau des Verdampfer-Temperatursensor:Manuelle Ausführung</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und dabei die folgenden Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die vorgegebene Menge Kompressoröl über die Kompressoransaugseite einfüllen. Siehe dazu &#34;Kompressoröl nachfüllen&#34; in 
<intxref refid = "AGEAP70A7216001">Vorgehensweise für das Befüllen mit Kältemittel:Manuelle Ausführung</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Die Manschette (1) gleichmäßig in die Einbauöffnung einsetzen.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A721025.swf" width = "88.000mm" height = "51.129mm" ver = "02" gw = "154" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Das A/C-System gemäß &#34;Entlüften&#34; und &#34;Befüllen&#34; in 
<intxref refid = "AGEAP70A7216001">Vorgehensweise für das Befüllen mit Kältemittel:Manuelle Ausführung</intxref>
 entlüften und befüllen.
</ptxt>
</item>
<item>
<ptxt>
Kühlsystem mit Kühlmittel befüllen. 
<intxreftitleoff1 refid = "AGEAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Reglerzüge einstellen. 
<intxreftitleoff1 refid = "AGEAP70A7216021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
