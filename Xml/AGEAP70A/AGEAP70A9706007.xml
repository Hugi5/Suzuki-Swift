<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9706007" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Rücksitzes
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9706006">Bauteile des Rücksitzes</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9706007001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Rücksitzkissen ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Rücksitzscharnierschrauben entfernen und Rücksitzlehnen-Baugruppen ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Falls erforderlich, den Rücksitz zerlegen und reparieren. 
<intxreftitleoff1 refid = "AGEAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9706007002">
<title>
Einbau
</title>
<ptxt>
Zum Einbau den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Informationen zum Drehmoment siehe 
<intxref refid = "AGEAP70A9706006">Bauteile des Rücksitzes</intxref>
.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
