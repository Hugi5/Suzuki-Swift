<servinfosub id = "AGEAP70A8204014003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A8204014004">
<testgroup id = "AGEAP70A8204014005">
<question>
Wurde die &#34;Überprüfung des Airbag-Diagnosesystems&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A8204001">Überprüfung des Airbag-Diagnosesystems</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204014006">
<title>
Überprüfung des Schaltkreises der Beifahrerairbag-Deaktivierungsanzeige
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung auf &#34;OFF&#34; steht.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreie Verbindung zum Steckverbinder &#34;G153&#34; prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder &#34;G153&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Spannung zwischen Anschlussklemme &#34;G153-9&#34; und Masse messen.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B004">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820109.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</test1>
<question>
Beträgt die gemessene Spannung 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204014007">
<title>
Überprüfung des Schaltkreises der Beifahrerairbag-Deaktivierungsanzeige
</title>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreie Verbindung zum Steckverbinder &#34;G11&#34; prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder &#34;G11&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Widerstand zwischen der Klemme &#34;G153-10&#34; und der Klemme &#34;G11-15&#34; messen.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B005">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820110.swf" width = "90.000mm" height = "48.716mm" ver = "01" gw = "188" gh = "122"/>
</testfigure>
</test1>
<question>
Beträgt der Widerstand 1 &#937; oder weniger?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204014008">
<title>
Überprüfung des Schaltkreises der Beifahrerairbag-Deaktivierungsanzeige
</title>
<test1>
<ptxt>
Folgenden Punkt überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand zwischen der Klemme &#34;G153-10&#34; und Masse.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B006">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820111.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</item>
</list1>
</test1>
<question>
Ist der gemessene Widerstand unendlich?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204014009">
<title>
Überprüfung der Beifahrerairbag-Deaktivierungsanzeige
</title>
<test1>
<ptxt>
Beifahrerairbag-Deaktivierungsanzeige überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A8206029"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
SDM austauschen und DTC erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Warnblinkschalter austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Nach Abschluss der Überprüfung und der Reparaturarbeiten die folgenden Arbeiten durchführen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Alle Bauteile des Airbagsystems wieder anschließen und sicherstellen, dass sie einwandfrei montiert sind.
</ptxt>
</item>
<item>
<ptxt>
Eventuelle DTCs löschen, wenn DTCs festgestellt wurden. Siehe dazu 
<intxref refid = "AGEAP70A8204006">Löschen von DTCs</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
<intxref refid = "AGEAP70A8204001">Überprüfung des Airbag-Diagnosesystems</intxref>
 wiederholen, um sicherzustellen, dass die Störung behoben wurde.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
