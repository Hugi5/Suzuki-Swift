<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1606008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Thermostatbaugruppe (mit integriertem ECT-Sensor)
</title>
<servinfosub id = "AGEAP70A1606008001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Kühlmittel ablassen. 
<intxreftitleoff1 refid = "AGEAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Auslassnockenwellensensor ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1306017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder des ECT-Sensors lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Einlassschläuche für Kühler (2) und Heizung (3) von der Thermostatbaugruppe (1) lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Thermostatbaugruppe (1) vom Zylinderkopf abnehmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160003.swf" width = "88.000mm" height = "50.065mm" ver = "01" gw = "181" gh = "125"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1606008002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Eine neue Dichtung verwenden.
</ptxt>
</item>
<item>
<ptxt>
Kühlsystem mit Kühlmittel befüllen. 
<intxreftitleoff1 refid = "AGEAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kühlsystem auf Undichtigkeiten prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auslassnockenwellensensor auf Öllecks prüfen.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
