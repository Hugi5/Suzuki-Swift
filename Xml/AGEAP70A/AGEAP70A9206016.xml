<title>
Aus- und Einbau des Warnblinkschalters
</title>
<servinfosub id = "AGEAP70A9206016001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Mittlere Belüftungsdüse (1) ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder abklemmen und dann den Warnblinkschalter (2) bei ausgerückten Verriegelungen (3) aus dem mittleren oberen Fach ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920023.jpg" width = "88.000mm" height = "65.260mm" ver = "01" gw = "181" gh = "168"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9206016002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9206017">Überprüfung des Warnblinkschalters</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
