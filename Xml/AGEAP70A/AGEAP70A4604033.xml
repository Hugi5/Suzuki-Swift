<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A4604033" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1074/C1075
</title>
<servinfosub id = "AGEAP70A4604033001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1074: G-Sensor-Kalibrierung 
</emph>
</ptxt>
<ptxt>
Gierraten- / G-Sensor-Kalibrierung nicht abgeschlossen.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Kalibrierung des Gierraten-/G-Sensors nicht abgeschlossen
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup>-Steuermodul
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1075: Kalibrierung des Lenkwinkelsensors
</emph>
</ptxt>
<ptxt>
Die Kalibrierung des Lenkwinkelsensors wurde nicht abgeschlossen.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Lenkwinkelsensor
</ptxt>
</item>
<item>
<ptxt>
Lenkwinkelsensor-Kalibrierung nicht abgeschlossen
</ptxt>
</item>
<item>
<ptxt>
ESP<sup>&#174;</sup>-Steuermodul
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70A4604033002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604033003">
<testgroup id = "AGEAP70A4604033004">
<question>
Wurde die &#34;ESP<sup>&#174;</sup>-Systemprüfung&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A4604001">ESP&#174;-Systemprüfung</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604033005">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
<intxref refid = "AGEAP70A4604005">DTC-Überprüfung</intxref>
 durchführen.
</ptxt>
</test1>
<question>
Liegen andere DTCs als C1074 oder C1075 vor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604033006">
<title>
Sensorkalibrierung
</title>
<test1>
<ptxt>
Alle Sensoren kalibrieren. 
<intxreftitleoff1 refid = "AGEAP70A4606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wurde die Sensorkalibrierung abgeschlossen?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Lenkwinkelsensor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604033007">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Alle DTCs löschen und dann erneut abrufen.
</ptxt>
</test1>
<question>
Werden DTC C1074 und/oder DTC C1075 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
DTC C1074: ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul-Baugruppe austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
DTC C1075: Den Lenkwinkelsensor austauschen und erneut DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
