<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1806001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Zündkerzen
</title>
<servinfosub id = "AGEAP70A1806001001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Zündspulen-Baugruppen ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Zündkerzen entfernen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1806001002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1806002">Überprüfung der Zündkerzen</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Die Zündkerzen einsetzen und auf das vorgeschriebene Anzugsmoment anziehen.
</ptxt>
<torque>
<torqueitem id = "T1H001">
<t-part>
Zündkerze
</t-part>
<t-value1>
18
</t-value1>
<t-value2>
1,8
</t-value2>
<t-value3>
13,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Die Zündspulen-Baugruppen einbauen. 
<intxreftitleoff1 refid = "AGEAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
