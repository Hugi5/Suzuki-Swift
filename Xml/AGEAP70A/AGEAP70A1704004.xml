<servinfosub id = "AGEAP70A1704004002">
<title>
Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A1704004003">
<testgroup id = "AGEAP70A1704004004">
<title>
Funktionsprüfung der Kraftstoffpumpensteuerung
</title>
<test1>
<ptxt>
Den Tankdeckel entfernen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Prüfen, ob das Betriebsgeräusch der Kraftstoffpumpe am Tankeinfüllstutzen etwa 2 Sekunden lang zu hören ist und dann aufhört.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Der Schaltkreis der Kraftstoffpumpe ist in einwandfreiem Zustand. Den Tankdeckel wieder aufsetzen.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704004005">
<title>
Überprüfung des Stromversorgungskreises des Kraftstoffpumpenrelais
</title>
<test1>
<ptxt>
Den Tankdeckel wieder aufsetzen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Das Kraftstoffpumpenrelais aus dem Einzelsicherungskasten Nr. 1 ausbauen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf ordnungsgemäßen Klemmenanschluss am Steckverbinder des Kraftstoffpumpenrelais prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn in Ordnung, die Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Spannung zwischen &#34;A1&#34; und &#34;A2&#34; und Masse der Batteriespannung entspricht.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Stromversorgungskreis des Kraftstoffpumpenrelais reparieren.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704004006">
<title>
Überprüfung des Kraftstoffpumpenrelais
</title>
<test1>
<ptxt>
Kraftstoffpumpenrelais überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kraftstoffpumpenrelais austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704004007">
<title>
Überprüfung des Treiberschaltkreises des Kraftstoffpumpenrelais
</title>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Steckverbinder &#34;C01&#34; und &#34;E01&#34; vom ECM abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf korrekten Klemmenanschluss der Steckverbinder &#34;C01&#34; und &#34;E01&#34; prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn die Anschlüsse in Ordnung sind, folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand im Schaltkreis &#34;B1&#34;: weniger als 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen Schaltkreis &#34;B1&#34; und Masse: unendlich
</ptxt>
</item>
<item>
<ptxt>
Spannung im Schaltkreis &#34;B1&#34;: 0 – 1 V (bei Zündung auf &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Treiberschaltkreis des Kraftstoffpumpenrelais reparieren.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704004008">
<title>
Überprüfung des Treiberschaltkreissignals des Kraftstoffpumpenrelais
</title>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Steckverbinder &#34;C01&#34; und &#34;E01&#34; am ECM anschließen.
</ptxt>
</test1>
<test1>
<ptxt>
Mit einem Prüfkabel das Kraftstoffpumpenrelais anschließen.
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Spannung zwischen &#34;B1&#34; und Masse 0 – 1 V beträgt für 2 Sek., nachdem die Zündung auf &#34;ON&#34; gestellt wurde.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
ECM austauschen und Betrieb der Kraftstoffpumpe erneut prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704004009">
<title>
Überprüfung des Stromversorgungskreises der Kraftstoffpumpe
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Den Kraftstofftank ausbauen.
</ptxt>
</test1>
<test1>
<ptxt>
Den Steckverbinder der Kraftstoffpumpe abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass der Widerstand zwischen Schaltkreis &#34;B2&#34; und Masse unendlich ist.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Stromversorgungskreis der Kraftstoffpumpe reparieren.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704004010">
<title>
Überprüfung des Stromversorgungskreises der Kraftstoffpumpe
</title>
<test1>
<ptxt>
Das Prüfkabel zwischen &#34;B1&#34; und Masse anschließen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Spannung zwischen &#34;B2&#34; und Masse der Batteriespannung entspricht.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Stromversorgungskreis der Kraftstoffpumpe reparieren.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704004011">
<title>
Überprüfung des Masseschaltkreises der Kraftstoffpumpe
</title>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass der Widerstand zwischen &#34;B3&#34; und Masse unter 1 &#937; beträgt.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Kraftstoffpumpe ersetzen. 
<intxreftitleoff1 refid = "AGEAP70A1706015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Masseschaltkreis der Kraftstoffpumpe reparieren.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
