<title>
Aus- und Einbau der hinteren Außenantenne
</title>
<servinfosub id = "AGEAP70AA506006001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Hinteren Stoßfänger entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder (1) lösen, und anschließend hintere Außenantenne (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50025.swf" width = "88.000mm" height = "54.582mm" ver = "01" gw = "176" gh = "138"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA506006002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70AA506010">Überprüfung der Antenne</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
