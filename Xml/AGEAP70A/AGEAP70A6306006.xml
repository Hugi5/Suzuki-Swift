<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A6306006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Lenkgetriebegehäuse-Buchse
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A6306001">Bauteile der Lenkgetriebegehäuse-Baugruppe</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Beim Austausch der Lenkgetriebe-Buchse die Buchsen auf beiden Seiten als Satz erneuern.
</ptxt>
</attention2>
<servinfosub id = "AGEAP70A6306006001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Lenkgetriebegehäuse-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Trennflansch (Gummi) (1) jeder Lenkgetriebegehäuse-Buchse mit einem Messer abschneiden.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630023.swf" width = "88.000mm" height = "51.406mm" ver = "01" gw = "234" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Die Lenkgetriebegehäuse-Buchse (1) mit einer Hydraulikpresse (2) und Spezialwerkzeug herausdrücken.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C004">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C005">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630024.swf" width = "88.000mm" height = "49.527mm" ver = "01" gw = "104" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A6306006002">
<title>
Einbau
</title>
<s1>
<ptxt>
Die Lenkgetriebegehäuse-Buchse (1) mit einem Spezialwerkzeug und einer Hydraulikpresse (2) hineintreiben.
</ptxt>
<attention2>
<ptxt>
Die Lenkgetriebegehäuse-Buchse nicht wiederverwenden.
</ptxt>
</attention2>
<servicetool>
<servicetoolitem id = "L6C006">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L6C007">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<attention3>
<ptxt>
Vor dem Einbau der Lenkgetriebegehäuse-Buchse Seifenwasser auf dessen Umfang verteilen, um den Einbau zu vereinfachen.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I9P60A630025.swf" width = "88.000mm" height = "51.452mm" ver = "01" gw = "104" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Die Lenkgetriebegehäuse-Buchse (1) so hineintreiben, dass die Abmessungen &#34;a&#34; und &#34;b&#34; in der Abbildung gleich sind.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Die Lenkgetriebegehäuse-Baugruppe einbauen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
