<servinfo servinfosgmlid = "AGEAP70A1406021" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Schwungscheibe
</title>
<servinfosub id = "AGEAP70A1406021001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Kupplungsdeckel und Kupplungsscheibe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Spezialwerkzeug in die Zahnkranz-Verzahnung einsetzen, um die Schwungscheibe wie abgebildet zu blockieren.
</ptxt>
<servicetool>
<servicetoolitem id = "L1D015">
<s-part>
(A)
</s-part>
<s-number num = "09924-17811">
09924-17811
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I8C50A140045.swf" width = "88.000mm" height = "50.407mm" ver = "01" gw = "141" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Schwungscheibe aus Kurbelwelle entfernen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1406021002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Neue Schwungscheibenschrauben einbauen.
</ptxt>
</item>
<item>
<ptxt>
Das Spezialwerkzeug in die Zahnkranz-Verzahnung einsetzen, um die Schwungscheibe wie abgebildet zu blockieren.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L1D016">
<s-part>
(A)
</s-part>
<s-number num = "09924-17811">
09924-17811
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<list1 type = "unordered">
<item>
<ptxt>
Die Schwungscheibenschrauben mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1D014">
<t-part>
Schwungscheibenschraube
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
70
</t-value1>
<t-value2>
7,1
</t-value2>
<t-value3>
52,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I8C50A140046.swf" width = "88.000mm" height = "50.407mm" ver = "01" gw = "141" gh = "126"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
