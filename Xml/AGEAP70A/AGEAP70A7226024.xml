<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7226024" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Stellglieds für Temperaturregelung
</title>
<servinfosub id = "AGEAP70A7226024001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Airbagsystem deaktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Abdeckung für die Lenksäulenöffnung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Knie-Airbagmodul (Gasgenerator) ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A8206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zuerst die Schrauben (1) und dann den Temperaturregler (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A722007.jpg" width = "88.000mm" height = "63.150mm" ver = "01" gw = "199" gh = "162"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7226024002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7226025">Prüfung des Stellglieds für Temperaturregelung:Automatiktyp</intxrefpoff>
</ptxt>
<ptxt>
Zum Einbau den Ausbauvorgang unter Beachtung der folgenden Hinweise umkehren.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sicherstellen, dass der Stift des Stellglieds für die Temperaturregelung (1) in die Nut (2) des Gestänge eingesetzt wird.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A722008.swf" width = "88.000mm" height = "63.358mm" ver = "01" gw = "141" gh = "163"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
