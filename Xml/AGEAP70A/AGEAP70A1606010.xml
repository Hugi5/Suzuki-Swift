<servinfosub id = "AGEAP70A1606010002">
<title>
Kühlerlüftermotor
</title>
<s1>
<ptxt>
Den Steckverbinder (1) des Kühlerlüftermotors abklemmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160004.swf" width = "88.000mm" height = "65.899mm" ver = "01" gw = "201" gh = "170"/>
</figure>
</s1>
<s1>
<ptxt>
Steckverbinder des Kühlerlüftermotors und Batterie wie dargestellt mit einem Prüfkabel verbinden.
</ptxt>
<figure>
<graphic graphicname = "IAP70A160002.swf" width = "88.000mm" height = "48.839mm" ver = "01" gw = "222" gh = "122"/>
