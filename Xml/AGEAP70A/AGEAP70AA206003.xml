<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70AA206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Ausbau und Einbau des BCM
</title>
<servinfosub id = "AGEAP70AA206003001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Airbagsystem deaktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Lenksäulen-Lochabdeckung gemäß Schritt 4) von 
<intxref refid = "AGEAP70A6206009">Aus- und Einbau der Lenksäule</intxref>
 entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Fußraumseitenverkleidung abnehmen. 
<intxreftitleoff1 refid = "AGEAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Steckverbinder (1) und Klemmen vom J/B (2) lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Muttern (3) abschrauben, und dann den J/B entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20016.jpg" width = "88.000mm" height = "78.207mm" ver = "01" gw = "202" gh = "205"/>
</figure>
</s1>
<s1>
<ptxt>
Die Steckverbinder (1) vom BCM (2) lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die BCM-Muttern (3) abschrauben und anschließend das BCM abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA20017.jpg" width = "88.000mm" height = "82.962mm" ver = "01" gw = "198" gh = "219"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA206003002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.	
</ptxt>
</servinfosub>
<list1 type = "unordered">
<item>
<ptxt>
Die BCM-Muttern mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T10B001">
<t-part>
BCM-Mutter
</t-part>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Das Airbagsystem aktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Falls das BCM ausgetauscht wird, 
<intxref refid = "AGEAP70AA206002">BCM-Registrierung (Modell mit Zündschalter)</intxref>
 durchführen.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
