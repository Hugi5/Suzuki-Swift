<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Zu hoher Kraftstoffverbrauch
</title>
<ptxt>
Fehlersuche gemäß folgenden Anweisungen durchführen, wenn das ECM keine DTCs erfasst und bei 
<intxref refid = "AGEAP70A1104008">Sichtprüfung</intxref>
 und 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
 keine Mängel festgestellt werden.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Zu hoher Kraftstoffverbrauch
</ptxt>
</condition>
<ps>
<ptxt>
Zündkerze defekt (falscher Elektrodenabstand, übermäßige Kohleablagerung, verbrannte Elektroden usw.)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1806002">Überprüfung der Zündkerzen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Erhöhte Leerlaufdrehzahl
</ptxt>
</ps>
<action>
<ptxt>
Symptom &#34;Leerlauf verstellt oder Motor dreht nicht in Leerlauf&#34;
</ptxt>
</action>
<ps>
<ptxt>
Schwache Leistung von ECT-Sensor, MAF-Sensor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306012">Überprüfung des ECT-Sensors</intxref>
 oder 
<intxref refid = "AGEAP70A1306026">Überprüfung des MAF- und IAT-Sensors</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Elektrische Drosselklappengehäuse-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306004">Überprüfung der elektrischen Drosselklappengehäuse-Baugruppe am Fahrzeug</intxref>
</ptxt>
</action>
<ps>
<ptxt>
APP-Sensorbaugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306008">Überprüfung des APP-Sensors</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Einspritzventil(e) defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1704003">Überprüfung des Einspritzventil-Schaltkreises</intxref>
</ptxt>
</action>
<ps>
<ptxt>
ECM defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1104070">Überprüfung von ECM und dessen Schaltkreisen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kompression zu niedrig
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1404001">Kompressionsprüfung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Schlechter Ventilsitz
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406028">Überprüfung von Ventil und Ventilführung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Bremsen schleifen
</ptxt>
</ps>
<action>
<ptxt>
Symptom &#34;Bremsen schleifen&#34; in 
<intxref refid = "AGEAP70A4104001">Symptomdiagnose für Bremsanlage</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kupplung rutscht
</ptxt>
</ps>
<action>
<ptxt>
Symptom &#34;Kupplungsschlupf&#34; in 
<intxref refid = "AGEAP70A5304001">Symptomdiagnose für Kupplungssystem</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Thermostat defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1606009">Überprüfung der Thermostatbaugruppe (mit integriertem ECT-Sensor)</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Falscher Reifenluftdruck
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A2401001">Beschreibung der Reifen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nockenwellensteuerung (VVT-System) außer Betrieb
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306027">Überprüfung des OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
