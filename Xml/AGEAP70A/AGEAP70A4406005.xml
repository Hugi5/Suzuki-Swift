<servinfo servinfosgmlid = "AGEAP70A4406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Feststellbremshebels
</title>
<attention1>
<ptxt>
Vor dem Ausbau des Feststellbremshebels sicherstellen, dass folgende Bedingungen erfüllt sind.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Arbeiten Sie auf ebenem Grund.
</ptxt>
</item>
<item>
<ptxt>
Getriebe in den &#34;1.&#34; Gang schalten.
</ptxt>
</item>
<item>
<ptxt>
Die Räder blockieren.
</ptxt>
</item>
</list1>
</attention1>
<servinfosub id = "AGEAP70A4406005001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Den hinteren Bodenkonsolenkasten ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder des Feststellbremsschalters vom Feststellbremshebel abziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Einstellmutter (1) lösen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A440004.swf" width = "88.000mm" height = "66.682mm" ver = "01" gw = "189" gh = "173"/>
</figure>
</s1>
<s1>
<ptxt>
Die Schrauben (1) des Feststellbremshebels herausdrehen und den Feststellbremshebel (2) zusammen mit dem Ausgleichshebel (3) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A440005.swf" width = "88.000mm" height = "80.810mm" ver = "01" gw = "168" gh = "213"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A4406005002">
<title>
Einbau
</title>
<s1>
<ptxt>
Die Schrauben (1) des Feststellbremshebels mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T4D001">
<t-part>
Feststellbremshebelschraube
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
26
</t-value1>
<t-value2>
2,7
</t-value2>
<t-value3>
19,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A440006.swf" width = "88.000mm" height = "77.351mm" ver = "01" gw = "174" gh = "203"/>
</figure>
</s1>
<s1>
<ptxt>
Den Feststellbremszug mit dem Ausgleicher verbinden und dann den Feststellbremszug einstellen. 
<intxreftitleoff1 refid = "AGEAP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sicherstellen, dass das Bremssystem ordnungsgemäß funktioniert.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder des Feststellbremsschalters am Feststellbremshebel anschließen.
</ptxt>
</s1>
<s1>
<ptxt>
Das hintere Bodenkonsolenfach anbringen. 
<intxreftitleoff1 refid = "AGEAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
