<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A5206005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau von Gangschalthebel und Schaltzug
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A5206004">Bauteile des Gangschalthebels und Schaltzugs</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A5206005001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das ECM aus dem Batteriefach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Batterie und Batteriefach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das vordere Bodenkonsolenfach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Schalt- und Wählzugenden (5) vom Drehzapfen (6) der Gangschalthebel-Baugruppe lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Schalt- und Wählzug (1) an der Gangschalthebel-Baugruppe (2) aushängen und dabei den Schnellverbinder (4) in die gezeigte Pfeilrichtung ziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Muttern (3) entfernen und die Gangschalthebel-Baugruppe vom Bodenblech abnehmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520038.swf" width = "88.000mm" height = "74.693mm" ver = "01" gw = "187" gh = "195"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.662in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
7.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Stift
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Den Schalt- und Wählzug vom Getriebe lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schraube der Seilzugtülle lösen und anschließend den Schalt- und Wählzug vom Bodenblech abnehmen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A5206005002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und dabei die folgenden Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Alle Schrauben und Muttern mit dem vorgeschriebenen Drehmoment festziehen. 
<intxreftitleoff1 refid = "AGEAP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Wählzug einstellen. 
<intxreftitleoff1 refid = "AGEAP70A5206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
