<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1604A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Überhitzung des Motors (Kühlerlüfter in Betrieb)
</title>
<diag type = "condition">
<condition>
<ptxt>
Überhitzung des Motors (Kühlerlüfter in Betrieb)
</ptxt>
</condition>
<ps>
<ptxt>
Antriebsriemen der Kühlmittelpumpe lose oder gerissen
</ptxt>
</ps>
<action>
<ptxt>
Antriebsriemen für Kühlmittelpumpe einstellen oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nicht genügend Kühlmittel
</ptxt>
</ps>
<action>
<ptxt>
Kühlmittelstand überprüfen und bei Bedarf nachfüllen. 
<intxreftitleoff1 refid = "AGEAP70A1606002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Thermostat ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Thermostat-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kühlmittelpumpe ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Kühlmittelpumpe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verschmutzte oder verbogene Kühlerrippen
</ptxt>
</ps>
<action>
<ptxt>
Reinigen oder reparieren. 
<intxreftitleoff1 refid = "AGEAP70A1606014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kühlmittelaustritt am Kühlsystem
</ptxt>
</ps>
<action>
<ptxt>
Kühlsystem auf Undichtigkeiten prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verstopfter Kühler
</ptxt>
</ps>
<action>
<ptxt>
Kühler austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kühlerdeckel ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Kühlerdeckel prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Bremsen schleifen
</ptxt>
</ps>
<action>
<ptxt>
Bremsen überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4104001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kupplung rutscht
</ptxt>
</ps>
<action>
<ptxt>
Kupplung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A5304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
