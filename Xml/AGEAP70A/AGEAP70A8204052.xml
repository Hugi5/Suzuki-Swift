<servinfosub id = "AGEAP70A8204052002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A8204052003">
<testgroup id = "AGEAP70A8204052004">
<title>
Überprüfung der Batteriespannung
</title>
<test1>
<ptxt>
Die Batteriespannung prüfen.
</ptxt>
</test1>
<question>
Beträgt die Spannung 9 – 16 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ladesystem überprüfen und reparieren. 
<intxreftitleoff1 refid = "AGEAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204052005">
<title>
Anschlussüberprüfung des SDM
</title>
<test1>
<ptxt>
Auf korrekten Anschluss an SDM-Steckverbinder prüfen.
</ptxt>
</test1>
<question>
Ist der Anschluss einwandfrei?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Zeitweilige Störung. Auf zeitweilige Störung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Wenn in Ordnung, ein intaktes SDM anschließen und die Verbindung erneut prüfen. 
<intxreftitleoff1 refid = "AGEAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204052006">
<title>
Überprüfung der Sicherung
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung auf &#34;OFF&#34; steht.
</ptxt>
</test1>
<test1>
<ptxt>
Die Sicherung &#34;A/B&#34; entfernen.
</ptxt>
</test1>
<question>
Ist die &#34;A/B&#34;-Sicherung in Ordnung?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Bodenkabelbaum austauschen, dann Sicherung &#34;A/B&#34; austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204052007">
<title>
Überprüfung des Hauptstromkreises
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung auf &#34;OFF&#34; steht.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder &#34;L04&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Spannung zwischen Anschlussklemme &#34;L04-18&#34;und Masse messen.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B095">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820157.swf" width = "90.000mm" height = "34.401mm" ver = "01" gw = "194" gh = "81"/>
</testfigure>
</test1>
<question>
Beträgt die Spannung 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Bodenkabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204052008">
<title>
Überprüfung des Masseschaltkreises
</title>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Widerstand zwischen Anschlussklemme &#34;L04-23&#34;und Masse messen.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B096">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820158.swf" width = "90.000mm" height = "34.895mm" ver = "01" gw = "193" gh = "82"/>
</testfigure>
</test1>
<question>
Beträgt der Widerstand 1 &#937; oder weniger?
</question>
<result type = "yes"/>
<action>
<ptxt>
SDM-Hauptstromkreis und -Massekreis in Ordnung.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Bodenkabelbaum austauschen.
</ptxt>
</action>
</testgroup>
</diag>
