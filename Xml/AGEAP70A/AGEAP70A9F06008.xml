<title>
Aus- und Einbau des USB-Anschlusses
</title>
<servinfosub id = "AGEAP70A9F06008001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Mittelkonsolenfach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den mittleren Seitendeckel ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder für den USB-Anschluss (1) abklemmen, dann USB-Anschluss (2) bei gelösten Verriegelungen (4) aus Armaturenbrett (3) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9F0014.jpg" width = "88.000mm" height = "55.000mm" ver = "02" gw = "206" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9F06008002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9F06009">Überprüfung des USB-Anschlusses</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
