<section sectnbr = "9K">
<servcat sctnbr = "09" scnbr = "11">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9B06023" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau von hinterem Heckboden-Seitenträger, hinterer Heckboden-Seitenträgerverstärkung und hinterem Heckbodenblech (teilweise)
</title>
<attention3>
<ptxt>
Die nachstehende Abbildung zeigt den Zustand, bei dem die folgenden Teile entfernt sind.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kotflügel vorn
<intxreftitleoff1 refid = "AGEAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rückwand 
<intxreftitleoff1 refid = "AGEAP70A9B06021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</attention3>
<figure>
<graphic graphicname = "I9P60A9B0170.jpg" width = "88.000mm" height = "48.926mm" ver = "02" gw = "227" gh = "122"/>
</figure>
<servinfosub id = "AGEAP70A9B06023001">
<title>
Allgemeine Hinweise
</title>
<list1 type = "unordered">
<item>
<ptxt>
Die Schweißmethode und die Anzahl der Schweißpunkte sind auf beiden Seiten gleich. Diese Reparaturanleitung beschreibt das Verfahren für die linke Seite.
</ptxt>
</item>
<item>
<ptxt>
Das hintere Heckbodenblech ist wieder zu verwenden.
</ptxt>
</item>
</list1>
</servinfosub>
<servinfosub id = "AGEAP70A9B06023002">
<title>
Ausbau
</title>
<s1>
<ptxt>
Eine Markierung an der gezeigten Position anbringen und das hintere Heckbodenblech abschneiden.
</ptxt>
<attention2>
<ptxt>
Beim Schneiden nicht die Teile unter dem hinteren Heckbodenblech beschädigen.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Die Schweißpunkte ausbohren, und das hintere Heckbodenblech abnehmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0020G.jpg" width = "183.000mm" height = "128.243mm" ver = "01" gw = "463" gh = "347"/>
</figure>
</s1>
<s1>
<ptxt>
Die Schweißpunkte ausbohren, dann hinteren Heckboden-Seitenträger und hintere Heckboden-Seitenträgerverstärkung abnehmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0021.jpg" width = "183.000mm" height = "220.754mm" ver = "01" gw = "460" gh = "609"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.411in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Nötigenfalls die Schweißpunkte mit einem Bandschleifer abschleifen.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9B06023003">
<title>
Einbau
</title>
<attention3>
<ptxt>
Vor der Durchführung von Schweißarbeiten die Einbauposition und den Zustand der Einbauteile überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9B04009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1>
<ptxt>
Hinteren Heckboden-Seitenträger und hintere Heckboden-Seitenträgerverstärkung einbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Widerstands-Punktschweißung oder Lochschweißung durchführen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0022.jpg" width = "183.000mm" height = "220.754mm" ver = "01" gw = "460" gh = "609"/>
</figure>
</s1>
<s1>
<ptxt>
Das hintere Heckbodenblech einbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Widerstands-Punktschweißung oder Lochschweißung durchführen.
</ptxt>
</s1>
<s1>
<ptxt>
Durchgehende Schweißung durchführen.
</ptxt>
</s1>
<s1>
<ptxt>
Rostschutzwachs auf die Rückseite der durchgehenden Schweißnaht auftragen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A9B0023G.jpg" width = "183.000mm" height = "128.243mm" ver = "01" gw = "463" gh = "347"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
