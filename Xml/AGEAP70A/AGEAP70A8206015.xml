<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A8206015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Seitenairbagmoduls (Gasgenerator)
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A8206014">Bauteile des Seitenairbagmoduls (Gasgenerator)</intxrefpoff>
</ptxt>
<attention1>
<ptxt>
Bei der Handhabung des Airbagmodul (Gasgenerator) unbedingt 
<intxref refid = "AGEAP70A8200002">Vorsichtsmaßnahmen bei der Handhabung und Lagerung von Airbagsystem-Bauteilen</intxref>
 lesen und alle Anweisungen befolgen.
</ptxt>
<ptxt>
Eine Missachtung dieser Anweisungen kann zu Schäden am Airbagmodul (Gasgenerator) oder zu Verletzungen führen.
</ptxt>
</attention1>
<attention3>
<ptxt>
Vor dem Austausch eines ausgelösten Airbags 
<intxref refid = "AGEAP70A8204054">Erforderliche Reparatur und Überprüfung nach einem Unfall</intxref>
 lesen.
</ptxt>
</attention3>
<servinfosub id = "AGEAP70A8206015001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Airbagsystem deaktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sitzlehnenkissen ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder (1) des Seitenairbagmoduls (Gasgenerator) wie in der Abbildung dargestellt abklemmen.
</ptxt>
<s2>
<ptxt>
Die Verriegelung öffnen (2).
</ptxt>
</s2>
<s2>
<ptxt>
Steckverbinder bei gelöster Verriegelung abklemmen.
</ptxt>
</s2>
</s1>
<s1>
<ptxt>
Muttern (4) des Seitenairbagmoduls (Gasgenerator) herausdrehen und das Seitenairbagmodul (Gasgenerator) (3) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820065.swf" width = "88.000mm" height = "90.427mm" ver = "03" gw = "222" gh = "240"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A8206015002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A8206016">Prüfung des Seitenairbagmoduls (Gasgenerator)</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den Steckverbinder des Seitenairbagmoduls (Gasgenerator) sicher verriegeln.
</ptxt>
</item>
<item>
<ptxt>
Die Muttern (1) des Seitenairbagmoduls (Gasgenerator) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T8B005">
<t-part>
Mutter des Seitenairbagmoduls (Gasgenerator)
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A820066.swf" width = "88.000mm" height = "58.771mm" ver = "01" gw = "166" gh = "150"/>
</figure>
</item>
<item>
<ptxt>
Das Airbagsystem aktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
