<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7216005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung des Kondensators am Fahrzeug
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7216006">Aus- und Einbau der Kondensator-Baugruppe:Manuelle Ausführung</intxrefpoff>
</ptxt>
<ptxt>
Folgendes überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kondensatorlamellen
</ptxt>
<ptxt>
Falls die Kondensatorlamellen verstopft sind, diese mit Wasser reinigen und mit Druckluft trocknen.
</ptxt>
</item>
<item>
<ptxt>
Kondensatorlamellen auf Undichtigkeit und Risse prüfen
</ptxt>
<ptxt>
Falls Defekte gefunden werden, den Kondensator reparieren oder austauschen.
</ptxt>
</item>
<item>
<ptxt>
Kondensatoranschlüsse auf Undichtigkeiten prüfen
</ptxt>
<ptxt>
Falls Defekte gefunden werden, den Kondensator reparieren oder austauschen.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
