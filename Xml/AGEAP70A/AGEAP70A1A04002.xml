<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1A04002" svcinfotypenbr = "06" svcinfoqualnbr = "04" page = "1" supplyoff = "1" modify = "0">
<title>
Symptomdiagnose für Generator
</title>
<ptxt>
Fehler im Ladesystem werden durch eines oder mehrere der folgenden Symptome angezeigt: 
</ptxt>
<servinfosub id = "AGEAP70A1A04002001" page = "1">
<title>
Funktion der Ladekontrollleuchte
</title>
<diag type = "condition" id = "AGEAP70A1A04002002">
<condition>
<ptxt>
Die Ladekontrollleuchte leuchtet nicht, wenn die Zündung auf ON steht und der Motor ausgeschaltet ist.
</ptxt>
</condition>
<ps>
<ptxt>
Durchgebrannte Sicherung
</ptxt>
</ps>
<action>
<ptxt>
Sicherung austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Kombiinstrument defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Das Kombiinstrument austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
BCM überprüfen.
</ptxt>
<ptxt>
Modell mit Zündschalter: 
<intxreftitleoff1 refid = "AGEAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modell mit schlüssellosem Startsystem: 
<intxreftitleoff1 refid = "AGEAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
CAN-Kommunikationsleitung defekt
</ptxt>
</ps>
<action>
<ptxt>
Die CAN-Kommunikationsleitung reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung defekt
</ptxt>
</ps>
<action>
<ptxt>
Verkabelung reparieren oder austauschen.
</ptxt>
</action>
<ps>
<ptxt>
IC-Regler oder Feldspule defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Die Ladekontrollleuchte erlischt nicht, wenn der Motor läuft (häufiges Aufladen der Batterie erforderlich).
</ptxt>
</condition>
<ps>
<ptxt>
Lockerer oder abgenutzter Antriebsriemen
</ptxt>
</ps>
<action>
<ptxt>
Den Antriebsriemen einstellen oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kombiinstrument defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Das Kombiinstrument austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
BCM defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
BCM überprüfen.
</ptxt>
<ptxt>
Modell mit Zündschalter: 
<intxreftitleoff1 refid = "AGEAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modell mit schlüssellosem Startsystem: 
<intxreftitleoff1 refid = "AGEAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
IC-Regler oder Generator defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung defekt
</ptxt>
</ps>
<action>
<ptxt>
Verkabelung reparieren oder austauschen.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AGEAP70A1A04002003">
<title>
Batterieladefehler
</title>
<diag type = "condition" id = "AGEAP70A1A04002004">
<condition>
<ptxt>
Batterie nicht ausreichend geladen
</ptxt>
</condition>
<ps>
<ptxt>
Lockerer oder abgenutzter Antriebsriemen
</ptxt>
</ps>
<action>
<ptxt>
Den Antriebsriemen einstellen oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Batteriepolklemme locker oder korrodiert
</ptxt>
</ps>
<action>
<ptxt>
Batteriepolklemme anziehen oder Batterie austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gleichrichter, Rotor und/oder IC-Regler defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Batterie überladen
</ptxt>
</condition>
<ps>
<ptxt>
IC-Regler defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AGEAP70A1A04002005">
<title>
Geräusche
</title>
<diag type = "condition" id = "AGEAP70A1A04002006">
<condition>
<ptxt>
Generator macht Lärm
</ptxt>
</condition>
<ps>
<ptxt>
Die Befestigungsschrauben lockern
</ptxt>
</ps>
<action>
<ptxt>
Befestigungsschrauben festziehen. 
<intxreftitleoff1 refid = "AGEAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lager verschmutzt, verschlissen und/oder defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rotor, Diode und/oder Stator defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
