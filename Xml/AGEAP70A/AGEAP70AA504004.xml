<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA504004" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Löschen von DTCs
</title>
<s1>
<ptxt>
Sicherstellen, dass die Zündung &#34;OFF&#34; ist.
</ptxt>
</s1>
<s1>
<ptxt>
Das SUZUKI-Diagnosegerät an den DLC (1) anschließen.
</ptxt>
<servicetool>
<servicetoolitem id = "L10E002">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI-Testgerät (SUZUKI-SDT)
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A121001.jpg" width = "88.000mm" height = "67.502mm" ver = "02" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Die DTCs gemäß den Anweisungen des Diagnosegeräts löschen. Weitere Einzelheiten sind der Bedienungsanleitung des SUZUKI-Diagnosegeräts zu entnehmen.
</ptxt>
</s1>
<s1>
<ptxt>
Nach Abschluss der Löschung die Zündung auf &#34;OFF&#34; stellen und das SUZUKI-Diagnosegerät vom DLC trennen.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
