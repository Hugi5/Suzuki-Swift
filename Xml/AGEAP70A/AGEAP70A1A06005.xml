<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Generators
</title>
<servinfosub id = "AGEAP70A1A06005001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Den rechten Motorunterboden ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Abgasanlage Nr. 1 ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Antriebsriemen für Kühlmittelpumpe/Generator austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Anschlusskabel &#34;B&#34; (1) und den Steckverbinder (2) vom Generator (3) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Generator (3) aus dem Motorraum zwischen den Rahmen für die Radaufhängung vorn und der vorderen Antriebswellen-Baugruppe ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1005.jpg" width = "88.000mm" height = "66.800mm" ver = "01" gw = "237" gh = "173"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1A06005002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Generatorschraube und die Generator-Bundschraube mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1J003">
<t-part>
Generatorschraube
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
<torqueitem id = "T1J004">
<t-part>
Generator-Bundschraube
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Das Kabel (1) an den Generator anschließen, wie in der Abbildung gezeigt, und die Mutter der Anschlussklemme &#34;B&#34; mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1J005">
<t-part>
Klemmenmutter &#34;B&#34;
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A1A1006.jpg" width = "88.000mm" height = "61.151mm" ver = "02" gw = "237" gh = "157"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
