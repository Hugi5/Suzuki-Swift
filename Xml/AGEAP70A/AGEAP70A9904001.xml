<title>
Symptomdiagnose des elektrischen Schiebedachsystems
</title>
<diag type = "condition" id = "AGEAP70A9904001001">
<condition>
<ptxt>
Schiebedach funktioniert nicht (Schiebedachmotor funktioniert)
</ptxt>
</condition>
<ps>
<ptxt>
Gegenstand steckt in der Schiebedachschiene
</ptxt>
</ps>
<action>
<ptxt>
Gegenstand entfernen oder säubern.
</ptxt>
</action>
<ps>
<ptxt>
Falsche Installation der Schiebedachschiene
</ptxt>
</ps>
<action>
<ptxt>
Richtig einbauen.
</ptxt>
</action>
<ps>
<ptxt>
Störung der Schiebedachkomponenten
</ptxt>
</ps>
<action>
<ptxt>
Störung beheben.
</ptxt>
</action>
<ps>
<ptxt>
Falsche Installation des Schiebedach-Antriebskabels
</ptxt>
</ps>
<action>
<ptxt>
Richtig einbauen.
</ptxt>
</action>
<condition>
<ptxt>
Automatische Schiebe- und Kippfunktionen funktionieren nicht (nur manueller Betrieb möglich)
</ptxt>
</condition>
<ps>
<ptxt>
Fehlerhafte Initialisierung
</ptxt>
</ps>
<action>
<ptxt>
Den Schiebedachmotor initialisieren. 
<intxreftitleoff1 refid = "AGEAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Falsche Einbauposition der Schiebedachscheibe
</ptxt>
</ps>
<action>
<ptxt>
Einbauposition der Schiebedachscheibe anpassen. 
<intxreftitleoff1 refid = "AGEAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Falsche Schiebebewegung der Schiebedacheinheit
</ptxt>
</ps>
<action>
<ptxt>
Schiebedacheinheit austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9906002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defekt des Schiebedachmotors
</ptxt>
</ps>
<action>
<ptxt>
Schiebedachmotor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9906001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Schiebedach funktioniert nicht (Schiebedachmotor funktioniert nicht)
</ptxt>
</condition>
<ps>
<ptxt>
Durchgebrannte Sicherung
</ptxt>
</ps>
<action>
<ptxt>
Sicherung austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Defekt des Schiebedachschalters
</ptxt>
</ps>
<action>
<ptxt>
Schiebedachschalter überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9906007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung oder Masseanschluss ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Schaltkreis überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9902001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 / 
<intxreftitleoff1 refid = "AGEAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defekt des Schiebedachmotors
</ptxt>
</ps>
<action>
<ptxt>
Schiebedachmotor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9904002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Wasserundichtheit
</ptxt>
</condition>
<ps>
<ptxt>
Falsche Einbauposition der Schiebedachscheibe
</ptxt>
</ps>
<action>
<ptxt>
Einbauposition der Schiebedachscheibe anpassen. 
<intxreftitleoff1 refid = "AGEAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defekt der Schiebedachscheibe
</ptxt>
</ps>
<action>
<ptxt>
Schiebedachscheibe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ablassschlauch (vorn/hinten) gelöst oder verstopft
</ptxt>
</ps>
<action>
<ptxt>
Ablassschlauch (vorn/hinten) überprüfen.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
