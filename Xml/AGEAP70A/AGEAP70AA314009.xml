<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA314009" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1642/P1646
</title>
<servinfosub id = "AGEAP70AA314009001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.406in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.789in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1642: Fehler in der Kommunikationsleitung der Wegfahrsperre
</emph>
</ptxt>
<ptxt>
Kommunikationsfehler mit BCM.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Schaltkreis/Steckverbinder der CAN-Kommunikation
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Mit CAN-Kommunikationslinie verbundenes Steuermodul
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1646: Falscher ID-Code
</emph>
</ptxt>
<ptxt>
CAN-Kommunikationsfehler.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70AA314009002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA314009003">
<testgroup id = "AGEAP70AA314009004">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTC bezüglich CAN-Kommunikation überprüfen.
</ptxt>
</test1>
<question>
Werden CAN-DTC(s) erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA314009005">
<title>
Überprüfung des CAN-Kommunikationsschaltkreises
</title>
<test1>
<ptxt>
Den CAN-Kommunikationsschaltkreis gemäß &#34;Diagnoseverfahren&#34; in 
<intxref refid = "AGEAP70AA804004">Fehlersuche bei &#34;Kommunikationsbus Aus&#34;</intxref>
 überprüfen.
</ptxt>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
ECM austauschen und DTC erneut abrufen. Falls DTC P1642 weiterhin erfasst wird, das BCM austauschen und erneut auf DTCs prüfen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekten Kabelbaum reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
