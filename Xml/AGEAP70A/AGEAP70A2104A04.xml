<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A2104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Schwammiges bzw. ruckartiges Fahrverhalten oder Vibrationen
</title>
<diag type = "condition">
<condition>
<ptxt>
Schwammiges bzw. ruckartiges Fahrverhalten oder Vibrationen
</ptxt>
</condition>
<ps>
<ptxt>
Radunwucht
</ptxt>
</ps>
<action>
<ptxt>
Rad (Räder) auswuchten oder Reifen und/oder Rad (Räder) austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Radlager locker
</ptxt>
</ps>
<action>
<ptxt>
Radlager austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Spurstangenköpfe verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Spurstangenköpfe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Querlenkeranschlüsse verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Querlenker austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Übermäßige Unwucht eines Rads oder Reifens
</ptxt>
</ps>
<action>
<ptxt>
Rad und/oder Reifen reparieren oder austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Reifen weist Blasen oder Beulen auf
</ptxt>
</ps>
<action>
<ptxt>
Reifen austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Übermäßige radiale Rundlaufabweichung des Rads / Reifens
</ptxt>
</ps>
<action>
<ptxt>
Reifen bzw. Rad austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Radspur falsch eingestellt
</ptxt>
</ps>
<action>
<ptxt>
Radspur überprüfen und einstellen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lenkgestänge locker oder verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Lenkung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A6104002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Schrauben des Lenkgetriebegehäuses locker
</ptxt>
</ps>
<action>
<ptxt>
Schrauben des Lenkgetriebegehäuses festziehen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
