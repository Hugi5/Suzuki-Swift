<title>
Aus- und Einbau des Bodenteppichs
</title>
<servinfosub id = "AGEAP70A9806010001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Sitze ausbauen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Vordersitz: 
<intxreftitleoff1 refid = "AGEAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Rücksitz: 
<intxreftitleoff1 refid = "AGEAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Die folgenden Verkleidungen und Schwellerleisten entfernen: 
<intxreftitleoff1 refid = "AGEAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Vordere Türschweller-Innenleisten
</ptxt>
</item>
<item>
<ptxt>
Hinteres Türschweller-Innenblech
</ptxt>
</item>
<item>
<ptxt>
Fußraumseitenverkleidungen
</ptxt>
</item>
<item>
<ptxt>
Untere B-Säulenverkleidungen
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Das vordere/hintere Mittelkonsolenfach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Abdeckung für das Lenkgelenk entfernen. 
<intxreftitleoff1 refid = "AGEAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
5 Klammern (1), Gaspedalanschlag (2) und dann Bodenteppich (3) entfernen.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A980007.jpg" width = "88.000mm" height = "60.725mm" ver = "02" gw = "238" gh = "156"/>
