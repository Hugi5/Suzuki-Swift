<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A2104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Fahrzeug zieht auf eine Seite
</title>
<diag type = "condition">
<condition>
<ptxt>
Fahrzeug zieht auf eine Seite
</ptxt>
</condition>
<ps>
<ptxt>
Nicht zueinander passende oder ungleichmäßig verschlissene Reifen
</ptxt>
</ps>
<action>
<ptxt>
Reifen ersetzen. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Reifendruck nicht korrekt
</ptxt>
</ps>
<action>
<ptxt>
Den Reifendruck entsprechend korrigieren.
</ptxt>
</action>
<ps>
<ptxt>
Gebrochene oder ermüdete Schraubenfedern
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Schraubenfedern austauschen.
</ptxt>
<ptxt>
Vorne: 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hinten: 
<intxreftitleoff1 refid = "AGEAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Abnormale, vom Radialreifen erzeugte Seitenkraft
</ptxt>
</ps>
<action>
<ptxt>
Reifen austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radspur falsch eingestellt
</ptxt>
</ps>
<action>
<ptxt>
Radspur überprüfen und einstellen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Einseitiges Schleifen einer Bremse
</ptxt>
</ps>
<action>
<ptxt>
Bremse einstellen oder reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Lockere, verbogene oder gebrochene Teile der Vorder- oder Hinterradaufhängung
</ptxt>
</ps>
<action>
<ptxt>
Teile der Radaufhängung festziehen bzw. austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
