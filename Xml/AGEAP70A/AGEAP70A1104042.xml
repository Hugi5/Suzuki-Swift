<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0530: Schaltkreis des Drucksensors für A/C-Kältemittel &#34;A&#34;
</emph>
</ptxt>
<ptxt>
Eine der folgenden Bedingungen ist erfüllt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ausgangsspannung des Kältemittel-Drucksensors (A/C) unterschreitet 0,15 V.
</ptxt>
</item>
<item>
<ptxt>
Ausgangsspannung des Kältemittel-Drucksensors (A/C) überschreitet 4,93 V.
</ptxt>
</item>
</list1>
<ptxt>
(3-Fahrten-Testlogik, die MIL leuchtet jedoch nicht auf)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Drucksensor für A/C-Kältemittel und/oder zugehöriger Schaltkreis
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
