<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3126008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Hinterradnabe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A3126005">Bauteile der Hinterradnabe und des Achsschenkels:Hinten</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A3126008001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Fahrzeug aufbocken und das Hinterrad abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Verstemmung der Antriebswellenmutter lösen und dann die Antriebswellenmutter bei gedrücktem Bremspedal entfernen. 
<intxreftitleoff1 refid = "AGEAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Hinterrad-Bremsscheibe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A4306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Stecker vom Hinterrad-Drehzahlsensor lösen. 
<intxreftitleoff1 refid = "AGEAP70A4606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (1) der Hinterradnaben-Baugruppe entfernen und dann die Hinterradnaben-Baugruppe mit der Staubabdeckung der Hinterrad-Bremsscheibe von der Hinterachse abnehmen.
</ptxt>
<attention3>
<ptxt>
Leicht auf das Wellenende an der Radnabenseite schlagen, wenn sich die Baugruppe der hinteren Antriebswelle nicht leicht ausbauen lässt.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A312008.swf" width = "88.000mm" height = "47.897mm" ver = "01" gw = "178" gh = "119"/>
</figure>
</s1>
<s1>
<ptxt>
Die Radbolzen (1) ggf. mit einer Hydraulikpresse heraustreiben.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312010.jpg" width = "88.000mm" height = "54.842mm" ver = "01" gw = "173" gh = "139"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A3126008002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Radbolzen (1) in die Radnabenbohrungen einsetzen. Die Radbolzen langsam drehen, um die Zahnungen an die von den ursprünglichen Bolzen in der Bohrung hinterlassenen Zahnungen einzupassen.
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Stets neue Radbolzen verwenden.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A312009.jpg" width = "88.000mm" height = "50.374mm" ver = "02" gw = "171" gh = "126"/>
</figure>
<list1 type = "unordered">
<item>
<ptxt>
Fett auf die Anlagefläche der Hinterradnaben-Baugruppe und der hinteren Antriebswelle auftragen. 
<intxreftitleoff1 refid = "AGEAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Die neuen Schrauben der Hinterradnabe mit dem vorgeschriebenen Anzugsmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T3A204">
<t-part>
Schraube der Hinterradnaben-Baugruppe
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
82
</t-value1>
<t-value2>
8,4
</t-value2>
<t-value3>
60,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A312011.swf" width = "88.000mm" height = "47.897mm" ver = "01" gw = "178" gh = "119"/>
</figure>
</item>
<item>
<ptxt>
Die Antriebswellenmutter mit dem vorgeschriebenen Drehmoment festziehen und die Mutter der Antriebswelle verstemmen. 
<intxreftitleoff1 refid = "AGEAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Unbedingt eine neue Antriebswellenmutter verwenden.
</ptxt>
</attention2>
<list1 type = "unordered">
<item>
<ptxt>
Die Radmuttern mit dem vorgeschriebenen Drehmoment festziehen. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
