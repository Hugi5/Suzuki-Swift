<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1606013" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Zerlegung und Zusammenbau des Kühlerlüfters
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1606012">Aus- und Einbau der Kühlerlüfter-Baugruppe</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1606013001">
<title>
Zerlegung
</title>
<s1 page = "2">
<ptxt>
Lüfter (1) vom Kühlerlüftermotor (2) abbauen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den Kühlerlüftermotor (2) aus der Kühlerlüfterhutze (3) entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160006.jpg" width = "88.000mm" height = "55.324mm" ver = "01" gw = "207" gh = "140"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1606013002" page = "2">
<title>
Zusammenbau
</title>
<ptxt>
Den Zerlegungsvorgang umkehren.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Lüftermuttern und die Schrauben des Kühlerlüftermotors mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1F001">
<t-part>
Lüftermutter
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
<torqueitem id = "T1F002">
<t-part>
Schraube des Kühlerlüftermotors
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
4,0
</t-value1>
<t-value2>
0,41
</t-value2>
<t-value3>
3,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70P160010.jpg" width = "88.000mm" height = "51.127mm" ver = "03" gw = "223" gh = "128"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
