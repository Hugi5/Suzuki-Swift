<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7216011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Gebläsemotorwiderstands
</title>
<servinfosub id = "AGEAP70A7216011001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Handschuhfach aus dem Armaturenbrett ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Fußraum-Luftkanal auf der Beifahrerseite (1) durch Entfernen der Schraube (2) aus der HVAC-Einheit ausbauen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721036.jpg" width = "88.000mm" height = "94.268mm" ver = "01" gw = "199" gh = "251"/>
</figure>
</s1>
<s1>
<ptxt>
Den Steckverbinder (1) vom Gebläsemotorwiderstand (2) abklemmen und dann durch Entfernen der Schrauben (3) den Gebläsemotorwiderstand aus der HVAC-Einheit ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A710010.swf" width = "88.000mm" height = "53.049mm" ver = "01" gw = "183" gh = "134"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7216011002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
