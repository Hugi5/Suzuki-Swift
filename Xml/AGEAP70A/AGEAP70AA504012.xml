<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA504012" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1123
</title>
<servinfosub id = "AGEAP70AA504012001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.461in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.744in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1123: Störung der Ersatzstromversorgung
</emph>
</ptxt>
<ptxt>
Spannung des Ersatz-Stromversorgungskreises von der Sicherung &#34;DOME&#34; liegt unter dem Sollwert.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Sicherung &#34;DOME&#34;
</ptxt>
</item>
<item>
<ptxt>
Jedes System über Sicherung &#34;DOME&#34; angeschlossen
</ptxt>
</item>
<item>
<ptxt>
Steuermodul für schlüsselloses Starten
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70AA504012002">
<title>
DTC-Überprüfungsverfahren
</title>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA504012003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA504012004">
<testgroup id = "AGEAP70AA504011005">
<title>
Überprüfung der Sicherung
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung &#34;OFF&#34; ist.
</ptxt>
</test1>
<test1>
<ptxt>
Sicherung &#34;DOME&#34; prüfen.
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Steuermodul für schlüsselloses Starten austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Sicherung &#34;DOME&#34; ersetzen, dann weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA504011006">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1123 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA504011007">
<title>
Überprüfung, dass jedes System über Sicherung &#34;DOME&#34; angeschlossen ist
</title>
<test1>
<ptxt>
Jedes über Sicherung &#34;DOME&#34; angeschlossene System, außer Steuermodul für schlüsselloses Starten, überprüfen.
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Sicherung &#34;DOME&#34; und Steuermodul für schlüsselloses Starten ersetzen und erneut auf DTCs prüfen. 
<intxreftitleoff1 refid = "AGEAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defektes Bauteil bzw. Kabelbaum reparieren oder austauschen, dann Sicherung &#34;DOME&#34; ersetzen und DTC erneut überprüfen.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
