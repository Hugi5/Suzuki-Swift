</servinfosub>
<servinfosub id = "AGEAP70AA204017002">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA204017003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA204017004">
<testgroup id = "AGEAP70AA204017005">
<title>
DTCs erneut abrufen
</title>
<test1>
<ptxt>
DTC löschen. 
<intxreftitleoff1 refid = "AGEAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
<intxref refid = "AGEAP70AA204017002">Überprüfung von Diagnosecodes</intxref>
 durchführen, und dann DTCs erneut überprüfen.
</ptxt>
</test1>
<question>
Wird DTC B1157 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (Der Airbag wurde in der Vergangenheit ausgelöst. (DTC wurde nicht gelöscht))
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204017006">
<title>
DTCs erneut abrufen
</title>
<test1>
<ptxt>
SDM austauschen. 
<intxreftitleoff1 refid = "AGEAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
<intxref refid = "AGEAP70AA204017002">Überprüfung von Diagnosecodes</intxref>
 durchführen, und dann DTCs erneut überprüfen.
</ptxt>
</test1>
<question>
Wird DTC B1157 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
BCM austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (SDM war defekt)
</ptxt>
</action>
</testgroup>
</diag>
