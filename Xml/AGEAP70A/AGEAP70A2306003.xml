<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2C">
<servcat sctnbr = "02" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A2306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Hinterrad-Stoßdämpfers
</title>
<servinfosub id = "AGEAP70A2306003001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Fahrzeug aufbocken und die Hinterräder abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Abdeckung der Zugangsöffnung (1) von Seitenteil-Innenverkleidung (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A230002.swf" width = "88.000mm" height = "52.091mm" ver = "01" gw = "165" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Die Hinterachse mit einem Wagenheber abstützen, damit sie sich nicht senken kann.
</ptxt>
</s1>
<s1>
<ptxt>
Die untere Mutter (1) des hinteren Stoßdämpfers und die untere Beilegscheibe (5) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die obere Mutter (2) des hinteren Stoßdämpfers, den hinteren Stoßdämpfer (3) und die oberen Beilegscheiben (4) des Stoßdämpfers entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A230002.swf" width = "88.000mm" height = "119.930mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Obere Buchsen (1) des Stoßdämpfers entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A230004.swf" width = "88.000mm" height = "81.823mm" ver = "01" gw = "147" gh = "215"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A2306003002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A2306004">Überprüfung des Hinterrad-Stoßdämpfers</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Die obere Mutter des hinteren Stoßdämpfers ist eine selbstsichernde Mutter. Mutter nicht wiederverwenden. Anderenfalls können sich die Muttern lockern.
</ptxt>
</attention2>
<s1>
<ptxt>
Obere Stoßdämpferbuchsen (6), hinteren Stoßdämpfer (1) und obere Stoßdämpfer-Beilegscheibe (2) wie abgebildet einbauen.
</ptxt>
<ptxt>
Die neue obere (4) und untere Mutter (5) des Stoßdämpfers in diesem Schritt provisorisch festziehen.
</ptxt>
<attention3>
<ptxt>
Für die korrekte Einbaurichtung der oberen Stoßdämpfer-Beilegscheibe (2) siehe die nachfolgende Abbildung.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A230003.swf" width = "88.000mm" height = "52.815mm" ver = "01" gw = "236" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.956in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Karosserieverkleidung
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Den Wagenheber unter der Hinterachse entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Hinterräder anbringen. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die obere und die untere Mutter des hinteren Stoßdämpfers mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<attention3>
<ptxt>
Beim Festziehen dieser Muttern muss das Fahrzeug abgesenkt und unbeladen sein.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T2C001">
<t-part>
Obere Mutter des hinteren Stoßdämpfers
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
28
</t-value1>
<t-value2>
2,9
</t-value2>
<t-value3>
21,0
</t-value3>
</torqueitem>
<torqueitem id = "T2C002">
<t-part>
Untere Mutter des Hinterrad-Stoßdämpfers
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
90
</t-value1>
<t-value2>
9,2
</t-value2>
<t-value3>
66,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A230004.swf" width = "88.000mm" height = "119.931mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Abdeckung für Zugangsöffnung in die Seitenteil-Innenverkleidung anbringen.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
