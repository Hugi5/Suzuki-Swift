<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9606012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Heckklappenverriegelung
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9606010">Bauteile der Heckklappenverriegelung</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A9606011">Überprüfung des Heckklappenschlosses am Fahrzeug</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9606012001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Heckklappenverkleidung (1) entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P960027.jpg" width = "88.000mm" height = "80.582mm" ver = "01" gw = "198" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Den Steckverbinder der Heckklappenverriegelung (1) von der Heckklappenverriegelungs-Baugruppe (2) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (3) der Heckklappenverriegelung und die Heckklappenverriegelungs-Baugruppe (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A960004.jpg" width = "88.000mm" height = "53.858mm" ver = "01" gw = "142" gh = "136"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9606012002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Schrauben der Heckklappenverriegelung mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T9F002">
<t-part>
Schraube der Heckklappenverriegelung
</t-part>
<t-value1>
10
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Falls erforderlich, die Position des Heckklappen-Schließbügels wie folgt korrigieren: 
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Schrauben (1) des Heckklappen-Schließbügels lösen.
</ptxt>
</item>
<item>
<ptxt>
Position des Heckklappen-Schließbügels (2) so anpassen, dass die Heckklappe leichtgängig geöffnet und geschlossen werden kann.
</ptxt>
</item>
<item>
<ptxt>
Die Schrauben des Heckklappen-Schließbügels mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T9F003">
<t-part>
Schraube für Heckklappen-Schließbügel
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A960018.jpg" width = "88.000mm" height = "61.730mm" ver = "02" gw = "198" gh = "158"/>
</figure>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
