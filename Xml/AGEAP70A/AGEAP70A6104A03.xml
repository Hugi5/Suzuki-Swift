<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A6104A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Lenkrad kehrt unzureichend in Ausgangsstellung zurück
</title>
<diag type = "condition">
<condition>
<ptxt>
Lenkrad kehrt unzureichend in Ausgangsstellung zurück
</ptxt>
</condition>
<ps>
<ptxt>
Spurstangenkopf-Kugelgelenk verklemmt
</ptxt>
</ps>
<action>
<ptxt>
Spurstangenkopf austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Querlenkergelenk verklemmt
</ptxt>
</ps>
<action>
<ptxt>
Querlenker austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lenksäule verklemmt
</ptxt>
</ps>
<action>
<ptxt>
Lenksäule wieder einbauen. 
<intxreftitleoff1 refid = "AGEAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vorderradspur falsch eingestellt
</ptxt>
</ps>
<action>
<ptxt>
Vorderradspur überprüfen und einstellen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lenkgetriebegehäuse-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
Lenkgetriebegehäuse-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Unzureichender Reifenluftdruck
</ptxt>
</ps>
<action>
<ptxt>
Den Reifendruck entsprechend korrigieren.
</ptxt>
</action>
<ps>
<ptxt>
Fehlerhaftes Tragbild zwischen Zahnstange und Ritzel
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Das Drehmoment von Zahnstange und Ritzelwelle überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Bei Defekten die Lenkgetriebegehäuse-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
