<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0515: Schaltkreis des Batterietemperatursensors
</emph>
</ptxt>
<ptxt>
Eine der folgenden Bedingungen ist erfüllt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ausgangsspannung des Batterietemperatursensors liegt für 5 Sek. unter 0,1 V.
</ptxt>
</item>
<item>
<ptxt>
Ausgangsspannung des Batterietemperatursensors liegt für 5 Sek. über 4,8 V.
</ptxt>
</item>
</list1>
<ptxt>
(3-Fahrten-Testlogik, die MIL leuchtet jedoch nicht auf)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Sensor für elektrische Last und/oder zugehöriger Schaltkreis
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
