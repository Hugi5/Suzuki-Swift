<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1706017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Kraftstoffstandsensors
</title>
<attention2>
<ptxt>
Die Widerstandsplatte (1) keinesfalls berühren und den Sensorhebel (2) nicht verformen. Dies könnte zu Störungen des Kraftstoffstandsensors führen.
</ptxt>
<figure>
<graphic graphicname = "IAW101170039.swf" width = "88.000mm" height = "56.718mm" ver = "01" gw = "193" gh = "144"/>
</figure>
</attention2>
<servinfosub id = "AGEAP70A1706017001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Kraftstoffpumpen-Baugruppe vom Kraftstofftank abbauen. 
<intxreftitleoff1 refid = "AGEAP70A1706015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder (1) des Kraftstoffstandsensors lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Verriegelung (2) lösen und den Kraftstoffstandsensor (3) durch Schieben in die abgebildete Pfeilrichtung von der Kraftstoffpumpe (4) entfernen.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A170008.swf" width = "88.000mm" height = "55.018mm" ver = "01" gw = "169" gh = "139"/>
</figure>
</servinfosub>
<servinfosub id = "AGEAP70A1706017002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1706018">Überprüfung des Kraftstoffstandsensors</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
