<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A6306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Spurstangenkopfs
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A6306002">Überprüfung der Spurstangenkopfmanschetten am Fahrzeug</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A6306001">Bauteile der Lenkgetriebegehäuse-Baugruppe</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A6306003001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Fahrzeug aufbocken und das Vorderrad abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Klammer und (2) und die Spurstangenkopf-Mutter (1) von dem Spurstangenkopf entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A630011.jpg" width = "88.000mm" height = "57.647mm" ver = "01" gw = "171" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Den Spurstangenkopf (1) mit dem Spezialwerkzeug vom Achsschenkel (2) lösen.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C003">
<s-part>
(A)
</s-part>
<s-number num = "09913-65210">
09913-65210
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630016.swf" width = "88.000mm" height = "52.953mm" ver = "01" gw = "118" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Für eine leichtere Einstellung nach dem Einbau die Einbauposition der Spurstangenkopf-Sicherungsmutter (2) am Gewinde des Spurstangenkopfes markieren (1). Dann die Sicherungsmutter lösen und den Spurstangenkopf (3) von der Spurstange (4) trennen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630017.swf" width = "88.000mm" height = "51.911mm" ver = "02" gw = "108" gh = "131"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AGEAP70A6306003002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A6306004">Überprüfung des Spurstangenkopfes</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Die Spurstangenkopf-Sicherungsmutter (2) und den Spurstangenkopf (3) auf die Spurstange (4) aufsetzen. Die Sicherungsmutter an der Markierung (1) am Spurstangengewinde ausrichten.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630017.swf" width = "88.000mm" height = "51.911mm" ver = "02" gw = "108" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Den Spurstangenkopf am Achsschenkel montieren. Die Mutter des Spurstangenkopfs (1) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T6C001">
<t-part>
Mutter des Spurstangenkopfes
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
45
</t-value1>
<t-value2>
4,6
</t-value2>
<t-value3>
33,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Klammer (2) anbringen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A630012.jpg" width = "88.000mm" height = "57.647mm" ver = "01" gw = "171" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Vorderrad montieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Spur prüfen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Wenn die Spur der Vorgabe entspricht, die Sicherungsmutter am Spurstangenkopf mit dem vorgeschriebenen Drehmoment festziehen. 
<intxreftitleoff1 refid = "AGEAP70A6306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
