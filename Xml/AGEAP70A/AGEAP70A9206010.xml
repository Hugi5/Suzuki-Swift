<title>
Aus- und Einbau der Leseleuchte (falls vorhanden)
</title>
<servinfosub id = "AGEAP70A9206010001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Verriegelungen (2) lösen und Leseleuchte (1) ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder von der Leseleuchte abziehen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920027.jpg" width = "88.000mm" height = "68.223mm" ver = "02" gw = "199" gh = "177"/>
</figure>
</s1>
<s1>
<ptxt>
Die Glühlampenfassung (1) von der Leseleuchte (2) entfernen und die Glühlampen ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920015.jpg" width = "88.000mm" height = "57.222mm" ver = "01" gw = "204" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9206010002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
