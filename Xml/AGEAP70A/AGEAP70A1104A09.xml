<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Übermäßiger Motorölverbrauch – Ölaustritt
</title>
<ptxt>
Fehlersuche gemäß folgenden Anweisungen durchführen, wenn das ECM keine DTCs erfasst und bei 
<intxref refid = "AGEAP70A1104008">Sichtprüfung</intxref>
 und 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
 keine Mängel festgestellt werden.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Übermäßiger Motorölverbrauch – Ölaustritt
</ptxt>
</condition>
<ps>
<ptxt>
Zylinderkopfdichtung defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406029">Überprüfung des Zylinderkopfs</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Dichtring der Kurbelwellen-Riemenscheibe undicht
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406014">Prüfung von Nockenwelle und Stößel</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Hinterer Kurbelwellendichtring undicht
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406043">Überprüfung des hinteren Dichtrings</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Zylinderkopfdeckeldichtung undicht
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406010">Komponenten des Ventildeckels</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
