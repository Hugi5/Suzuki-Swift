<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7224A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kein Kühlluftaustritt (Kühlerlüftermotor funktioniert nicht)
</title>
<diag type = "condition">
<condition>
<ptxt>
Kein Kühlluftaustritt (Kühlerlüftermotor funktioniert nicht)
</ptxt>
</condition>
<ps>
<ptxt>
Durchgebrannte Sicherung
</ptxt>
</ps>
<action>
<ptxt>
Die betreffenden Sicherungen überprüfen und dann auf einen Kurzschluss an Masse überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung oder Masseanschluss ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Die Verkabelung reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Kühlerlüftermotorrelais defekt
</ptxt>
</ps>
<action>
<ptxt>
Kühlerlüftermotorrelais überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kühlerlüftermotor ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Kühlerlüftermotor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ECM defekt
</ptxt>
</ps>
<action>
<ptxt>
ECM überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
HVAC-Steuermodul defekt
</ptxt>
</ps>
<action>
<ptxt>
HVAC-Steuermodul überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
