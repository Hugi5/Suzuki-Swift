<servinfosub id = "AGEAP70A7224027003">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Den Motor anlassen und die Klimaanlage einschalten.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7224027004">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A7224027005">
<testgroup id = "AGEAP70A7224027006">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen und DTC abrufen.
</ptxt>
</test1>
<question>
Liegt DTC B1550-H oder B1550-L immer noch vor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zeitweilige Störung.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224027007">
<title>
Überprüfung des Kommunikationsschaltkreises
</title>
<test1>
<ptxt>
Steckverbinder &#34;G20&#34; und &#34;G227&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Folgende Punkte überprüfen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand im Schaltkreis des Kabels &#34;PNK/BLU&#34;: weniger als 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Widerstand im Schaltkreis des Kabels &#34;PNK/BLU&#34; zwischen dem Auto-A/C-Bedienfeld und Masse: unendlich
</ptxt>
</item>
</list1>
</test1>
<question>
Entsprechen die Werte des Widerstands den Vorgaben?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Ein intaktes HVAC-Steuermodul und/oder Auto-A/C-Bedienfeld austauschen und DTC erneut abrufen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
HVAC-Steuermodul: 
<intxreftitleoff1 refid = "AGEAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bedienfeld des automatischen A/C-Systems: 
<intxreftitleoff1 refid = "AGEAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
</diag>
