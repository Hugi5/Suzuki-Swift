<servinfo servinfosgmlid = "AGEAP70A9306006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung der Parksensoren (falls vorhanden)
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9306005">Aus- und Einbau des Parksensors (falls vorhanden)</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den Parksensor auf Schäden untersuchen.
</ptxt>
</item>
<item>
<ptxt>
Den Steckverbinder des Parksensors auf Schäden untersuchen.
</ptxt>
</item>
<item>
<ptxt>
Die Steckerklemme des Parksensors auf Verbiegung, Rost oder Korrosion überprüfen.
</ptxt>
<ptxt>
Bei Mängeln den Parksensor austauschen.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
