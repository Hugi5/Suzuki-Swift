<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A6306008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Spurstange/Manschette für Zahnstangenlenkgetriebe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A6306003">Aus- und Einbau des Spurstangenkopfs</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A6306001">Bauteile der Lenkgetriebegehäuse-Baugruppe</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A6306007">Überprüfung der Manschette für das Zahnstangenlenkgetriebe</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A6306008001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Lenkgetriebegehäuse-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Spurstangenkopf abbauen. 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Schelle (2) und die Klammer (1) der Manschette für Zahnstangenlenkgetriebe abnehmen.
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Die Manschette für Zahnstangenlenkgetriebe (3) von der Spurstange entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630026.swf" width = "88.000mm" height = "53.031mm" ver = "02" gw = "158" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Die gebogenen Teile der Spurstangen-Sicherungsscheibe (1) gerade biegen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Spurstange (3) von der Zahnstange (2) abbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630027.swf" width = "88.000mm" height = "46.459mm" ver = "01" gw = "197" gh = "115"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A6306008002">
<title>
Einbau
</title>
<s1>
<ptxt>
Die Nut (5) der Zahnstange (2) mit dem Überstand (4) der neuen Spurstangen-Sicherungsscheibe (3) fluchten.
</ptxt>
</s1>
<s1>
<ptxt>
Die Spurstange (1) an der Zahnstange (2) anbringen und mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T6C003">
<t-part>
Spurstange
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9,0
</t-value2>
<t-value3>
65,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A630015.swf" width = "88.000mm" height = "55.132mm" ver = "01" gw = "145" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Die Sicherungsscheibe (1) wie abgebildet an 2 Stellen umbiegen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630029.swf" width = "88.000mm" height = "51.419mm" ver = "02" gw = "144" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Auf Abschnitt &#34;A&#34; der Spurstange wie abgebildet Fett auftragen. Die Manschette für Zahnstangenlenkgetriebe korrekt in die Nuten des Lenkgetriebegehäuses (oder Gummilager des Zahnstangengehäuses) einpassen und Spurstange einlegen.
</ptxt>
<ptxt>
Danach sicherstellen, dass die Manschette für Zahnstangenlenkgetriebe weder verdreht noch eingedellt ist.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease E" id = "M6C001" uid = "24">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25050
</m-number>
<m-name>
SUZUKI Super Grease E
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A630030.swf" width = "88.000mm" height = "33.098mm" ver = "01" gw = "196" gh = "77"/>
</figure>
</s1>
<s1>
<ptxt>
Die neue Schelle (1) mit dem Spezialwerkzeug festziehen und dann die Klammer (2) der Zahnstangenmanschette anbringen.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C008">
<s-part>
(A)
</s-part>
<s-number num = "09943-55010">
09943-55010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630031.swf" width = "88.000mm" height = "40.262mm" ver = "01" gw = "161" gh = "98"/>
</figure>
</s1>
<s1>
<ptxt>
Den Spurstangenkopf montieren. 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Die Lenkgetriebegehäuse-Baugruppe einbauen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
