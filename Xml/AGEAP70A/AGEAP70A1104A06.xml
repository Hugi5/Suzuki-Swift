<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Motorgeräusche – Kurbelwellengeräusche
</title>
<ptxt>
Fehlersuche gemäß folgenden Anweisungen durchführen, wenn das ECM keine DTCs erfasst und bei 
<intxref refid = "AGEAP70A1104008">Sichtprüfung</intxref>
 und 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
 keine Mängel festgestellt werden.
</ptxt>
<diag type = "condition">
<condition>
<paragroup>
<ptxt>
Motorgeräusche – Kurbelwellengeräusche
</ptxt>
<attention3>
<ptxt>
Vor Überprüfung auf mechanische Geräusche Folgendes sicherstellen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zündkerzentyp ist korrekt.
</ptxt>
</item>
<item>
<ptxt>
Kraftstofftyp ist korrekt.
</ptxt>
</item>
</list1>
</attention3>
</paragroup>
</condition>
<ps>
<ptxt>
Zu geringer Öldruck
</ptxt>
</ps>
<action>
<ptxt>
Symptom &#34;Zu geringer Öldruck&#34;
</ptxt>
</action>
<ps>
<ptxt>
Hauptlager verschlissen
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406041">Überprüfung der Hauptlager</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kurbelwellenlagerzapfen verschlissen
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406040">Überprüfung der Kurbelwelle</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Lose Lagerdeckelschrauben
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406041">Überprüfung der Hauptlager</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Übermäßiges Kurbelwellen-Druckspiel
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406040">Überprüfung der Kurbelwelle</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
