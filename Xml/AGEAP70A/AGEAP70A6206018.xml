<servinfo servinfosgmlid = "AGEAP70A6206018" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Zündschalters (Modell mit Zündschalter)
</title>
<servinfosub id = "AGEAP70A6206018001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die untere und obere Lenksäulenabdeckung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sicherstellen, dass der Zündschlüssel abgezogen ist.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder (1) vom Zündschalter (2) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (4) herausdrehen und dann den Zündschalter (2) vom Lenkschloss (3) abmontieren.
</ptxt>
<figure>
<graphic graphicname = "I9P60A620036.jpg" width = "88.000mm" height = "54.155mm" ver = "05" gw = "237" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A6206018002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A6206019">Überprüfung des Zündschalters (Modell mit Zündschalter)</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
