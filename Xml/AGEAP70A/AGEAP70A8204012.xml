<colspec colnum = "2" colname = "2" colwidth = "3.597in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1012: Vorübergehende Störungen des SDM-Steckverbinders 
</emph>
</ptxt>
<ptxt>
Fehlerhafte Verbindung des SDM-Steckverbinders
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
SDM-Steckverbinder
</ptxt>
</item>
<item>
<ptxt>
SDM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70A8204012002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A8204012003">
<testgroup id = "AGEAP70A8204012004">
<question>
Wurde die &#34;Überprüfung des Airbag-Diagnosesystems&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A8204001">Überprüfung des Airbag-Diagnosesystems</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204012005">
<title>
Überprüfung des SDM-Steckverbinders
</title>
<test1>
<ptxt>
Korrekte Verbindung von SDM-Steckverbinder und &#34;Verbindungserkennungsstift&#34; des SDM-Steckverbinders überprüfen.
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
SDM durch ein Neuteil ersetzen. 
<intxreftitleoff1 refid = "AGEAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Auf zeitweilige Störung prüfen. 
<intxreftitleoff1 refid = "AGEAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Nach Abschluss der Überprüfung und der Reparaturarbeiten die folgenden Arbeiten durchführen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Alle Bauteile des Airbagsystems wieder anschließen und sicherstellen, dass sie einwandfrei montiert sind.
</ptxt>
</item>
<item>
<ptxt>
Eventuelle DTCs löschen, wenn DTCs festgestellt wurden. Siehe dazu 
<intxref refid = "AGEAP70A8204006">Löschen von DTCs</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
<intxref refid = "AGEAP70A8204001">Überprüfung des Airbag-Diagnosesystems</intxref>
 wiederholen, um sicherzustellen, dass die Störung behoben wurde.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
