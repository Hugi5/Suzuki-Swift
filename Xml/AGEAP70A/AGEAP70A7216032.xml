<servinfo servinfosgmlid = "AGEAP70A7216032" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des HVAC-Luftfilters
</title>
<servinfosub id = "AGEAP70A7216032001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Handschuhfach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
HVAC-Luftfilterabdeckung (2) von der HVAC-Einheit abnehmen.
</ptxt>
</s1>
<s1>
<ptxt>
Luftfilter (1) von der HVAC-Einheit abbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721033.swf" width = "88.000mm" height = "53.307mm" ver = "01" gw = "219" gh = "135"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7216032002">
<title>
Einbau
</title>
<ptxt>
Zum Einbau den Ausbauvorgang umkehren und folgende Punkte beachten: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Luftfilter mit Pfeilmarkierung (1) nach oben fixieren.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721034.swf" width = "88.000mm" height = "48.728mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
