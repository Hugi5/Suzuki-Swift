<servinfo servinfosgmlid = "AGEAP70A5306001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des CPP-Schalters Nr. 1 (Falls vorhanden)
</title>
<servinfosub id = "AGEAP70A5306001001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Den Steckverbinder des CPP-Schalters Nr. 1 (1) bei ausgeschalteter Zündung abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Den CPP-Schalter Nr. 1 (1) aus der Pedalhalterung nehmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A531003.swf" width = "88.000mm" height = "79.324mm" ver = "01" gw = "104" gh = "208"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A5306001002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A5306002">Prüfung und Einstellung des CPP-Schalters Nr. 1 (Falls vorhanden)</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Den CPP-Schalter Nr. 1 an der Pedalhalterung montieren.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schalterposition einstellen. 
<intxreftitleoff1 refid = "AGEAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder fest am CPP-Schalter Nr. 1 anklemmen.
</ptxt>
</s1>
</servinfosub>
</servinfo>
