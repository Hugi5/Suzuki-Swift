<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A5304A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kupplung schleift
</title>
<diag type = "condition">
<condition>
<ptxt>
Kupplung schleift
</ptxt>
</condition>
<ps>
<ptxt>
Kupplungspedalspiel falsch eingestellt
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Kupplungspedalarm und/oder Kupplungsgeberzylinder austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Kupplungspedalarm: 
<intxreftitleoff1 refid = "AGEAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kupplungsgeberzylinder: 
<intxreftitleoff1 refid = "AGEAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Membranfeder ermüdet oder Federspitzen verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsdeckel austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Antriebswellenverzahnung rostig
</ptxt>
</ps>
<action>
<ptxt>
Antriebswellenverzahnung schmieren.
</ptxt>
</action>
<ps>
<ptxt>
Zahnkranz der Getriebeeingangswelle beschädigt oder verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Antriebswelle austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Übermäßiger Schlag der Kupplungsscheibe
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kupplungsscheibenbeläge riefig oder verölt
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Flüssigkeitsaustritt
</ptxt>
</ps>
<action>
<ptxt>
Kupplungssystem reparieren oder austauschen.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
