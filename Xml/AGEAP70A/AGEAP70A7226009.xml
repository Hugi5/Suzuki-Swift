<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7226009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Auto-A/C-Bedienfelds
</title>
<servinfosub id = "AGEAP70A7226009001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Das vordere Bodenkonsolenfach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Blende für das Kombiinstrument und die mittlere Belüftungsdüse ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Audioanlage ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9F06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Beifahrer-Airbagmodul (Gasgenerator) entfernen. 
<intxreftitleoff1 refid = "AGEAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Mittlere seitliche Abdeckungen entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Auto-A/C-Bedienfeld (1) aus Armaturenbrett ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder des Auto-A/C-Bedienfelds abklemmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723013.swf" width = "88.000mm" height = "64.865mm" ver = "03" gw = "233" gh = "167"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7226009002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
