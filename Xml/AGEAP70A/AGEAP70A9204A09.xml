<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A9204A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Rückfahrleuchten leuchten nicht
</title>
<diag type = "condition">
<condition>
<ptxt>
Rückfahrleuchten leuchten nicht
</ptxt>
</condition>
<ps>
<ptxt>
Fehler im System-Schaltkreis (einschließlich Relais und Sicherungen)
</ptxt>
</ps>
<action>
<ptxt>
Den Schaltkreis reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Glühlampen durchgebrannt
</ptxt>
</ps>
<action>
<ptxt>
Glühlampen austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Rückfahrlichtschalter defekt
</ptxt>
</ps>
<action>
<ptxt>
Siehe 
<intxref refid = "AGEAP70A5206008">Überprüfung des Rückfahrlichtschalters</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
