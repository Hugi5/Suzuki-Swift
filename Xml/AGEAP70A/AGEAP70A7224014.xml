<servinfosub id = "AGEAP70A7224014003">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Den Motor anlassen und die Klimaanlage einschalten.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7224014004">
<title>
DTC-Fehlersuche
</title>
<p-change/>
<diag type = "test" id = "AGEAP70A7224014005">
<testgroup id = "AGEAP70A7224014006">
<title>
Überprüfung der Diagnosegerät-Parameter
</title>
<test1>
<ptxt>
Die &#34;Kabinentemperatur&#34; über den Modus &#34;Datenliste&#34; mit dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Liegt die Temperatur über 87,5 &#176;C (189,5 &#176;F) (Innentemperatursensor-Signalspannung liegt unter 0,1 V)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zeitweilige Störung.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224014007">
<title>
Überprüfung des Innentemperatursensors
</title>
<test1>
<ptxt>
Den Steckverbinder des Innentemperatursensors abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1502-H erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Innentemperatursensor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7226035"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224014008">
<title>
Überprüfung des Innentemperatursensor-Signalkreises
</title>
<test1>
<ptxt>
Steckverbinder &#34;G20&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Überprüfen, ob der Widerstand zwischen der Kabelklemme &#34;PNK/BLK&#34; und Masse unendlich ist.
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das HVAC-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
</diag>
