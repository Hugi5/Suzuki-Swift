<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A4106014" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung der Bremsschläuche und -leitungen
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4106013">Aus- und Einbau der Bremsschläuche/-leitungen</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A4106014001">
<title>
Bremsschlauch
</title>
<ptxt>
Folgende Punkte überprüfen: Falls das Prüfergebnis nicht OK ist, den Bremsschlauch ersetzen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Anschluss auf Leckage und sonstige Schäden.
</ptxt>
</item>
<item>
<ptxt>
Blasen, Risse und sonstige Schäden.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A410017.swf" width = "88.000mm" height = "54.263mm" ver = "01" gw = "188" gh = "137"/>
</figure>
</servinfosub>
<servinfosub id = "AGEAP70A4106014002">
<title>
Leitung
</title>
<ptxt>
Bremsleitung auf Beschädigung, Risse, Dellen und Korrosion überprüfen. Falls das Prüfergebnis nicht OK ist, die Leitung ersetzen.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
