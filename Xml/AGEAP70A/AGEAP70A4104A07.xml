<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A4104A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Pedal pulsiert (Pedal pulsiert bei Bremsenbetätigung)
</title>
<diag type = "condition">
<condition>
<ptxt>
Pedal pulsiert (Pedal pulsiert bei Bremsenbetätigung)
</ptxt>
</condition>
<ps>
<ptxt>
Lockeres oder beschädigtes vorderes und/oder hinteres Radlager
</ptxt>
</ps>
<action>
<ptxt>
Radlager austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Verzogener Achsschenkel
</ptxt>
</ps>
<action>
<ptxt>
Achsschenkel austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Übermäßige laterale Rundlaufabweichung der Bremsscheibe
</ptxt>
</ps>
<action>
<ptxt>
Gemäß Anweisung überprüfen. Bei Überschreitung des Grenzwerts die Bremsscheibe abdrehen oder austauschen.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
