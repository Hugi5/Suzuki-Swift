<servinfosub id = "AGEAP70A4604029003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604029004">
<testgroup id = "AGEAP70A4604029005">
<question>
Wurde die &#34;ESP<sup>&#174;</sup>-Systemprüfung&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A4604001">ESP&#174;-Systemprüfung</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604029006">
<title>
Überprüfung von Stromversorgungs- und Masseschaltkreis des ESP&#174;-Steuermoduls
</title>
<test1>
<ptxt>
Den Stromversorgungs- und den Masseschaltkreis des ESP<sup>&#174;</sup>-Steuermoduls überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekten Kabelbaum reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604029007">
<title>
Überprüfung der Versorgungsspannung des ESP&#174;-Steuermoduls
</title>
<test1>
<ptxt>
Die Batteriespannung messen, während der Motor mit 3000 min<sup>-1</sup> läuft.
</ptxt>
</test1>
<question>
Beträgt die Spannung 9,3 V und 16,8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul-Baugruppe austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Das Ladesystem überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
</diag>
