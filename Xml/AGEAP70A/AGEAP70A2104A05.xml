<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A2104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Abnormales Geräusch, Vorderradaufhängung
</title>
<diag type = "condition">
<condition>
<ptxt>
Abnormales Geräusch, Vorderradaufhängung
</ptxt>
</condition>
<ps>
<ptxt>
Vordere Federbein-Baugruppe (Stoßdämpfer) oder Federbeinlager beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Vordere Federbein-Baugruppe (Stoßdämpfer) bzw. Federbeinlager reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verschlissene, schwergängige oder lockere Spurstangenköpfe
</ptxt>
</ps>
<action>
<ptxt>
Spurstangenköpfe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verschlissene oder beschädigte Querlenkeranschlüsse
</ptxt>
</ps>
<action>
<ptxt>
Querlenker austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verschlissene, schwergängige oder lockere Spurstangen-Kugelgelenke
</ptxt>
</ps>
<action>
<ptxt>
Lenkgetriebegehäuse-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Verschlissene, schwergängige oder lockere Antriebswellengelenke
</ptxt>
</ps>
<action>
<ptxt>
Antriebswellengelenke austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vordere Buchsen des Querlenkers verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Vordere Buchsen des Querlenkers austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Hintere Buchsen des Querlenkers verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Querlenker austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Stabilisator locker
</ptxt>
</ps>
<action>
<ptxt>
Schrauben oder Muttern festziehen und/oder Buchsen austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radmuttern locker
</ptxt>
</ps>
<action>
<ptxt>
Radmuttern festziehen. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Schrauben bzw. Muttern der Radaufhängung locker
</ptxt>
</ps>
<action>
<ptxt>
Schrauben bzw. Muttern der Radaufhängung festziehen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radlager gebrochen oder anderweitig beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Radlager austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Schraubenfedern gebrochen
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Schraubenfedern austauschen.
</ptxt>
<ptxt>
Vorne: 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hinten: 
<intxreftitleoff1 refid = "AGEAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Schlecht geschmierte oder verschlissene Federbeinlager
</ptxt>
</ps>
<action>
<ptxt>
Die Federbeinlager austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Störung des Servolenkungssystems
</ptxt>
</ps>
<action>
<ptxt>
Überprüfen und Störung beheben. 
<intxreftitleoff1 refid = "AGEAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
