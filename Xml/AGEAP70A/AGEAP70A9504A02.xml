<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A9504A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Einer der elektrischen Fensterheber funktioniert nicht
</title>
<diag type = "condition">
<condition>
<ptxt>
Einer der elektrischen Fensterheber funktioniert nicht
</ptxt>
</condition>
<ps>
<ptxt>
Verkabelung defekt
</ptxt>
</ps>
<action>
<ptxt>
Die Verkabelung reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Elektrischer Fensterheber und/oder Motor defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Vorne: 
<intxreftitleoff1 refid = "AGEAP70A9506013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hinten: 
<intxreftitleoff1 refid = "AGEAP70A9506018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Hauptschalter für elektrische Fensterheber defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A9506019">Überprüfung des Hauptschalters für elektrische Fensterheber</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defekter Nebenschalter für elektrische Fensterheber
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A9506020">Überprüfung des Nebenschalters für elektrische Fensterheber</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Fensterverriegelungsschalter ist gedrückt (verriegelt)
</ptxt>
</ps>
<action>
<ptxt>
Den Fensterverriegelungsschalter ausschalten.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
