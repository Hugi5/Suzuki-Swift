<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1306019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des CKP-Sensors
</title>
<servinfosub id = "AGEAP70A1306019001" page = "2">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Generator ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder vom Kurbelwinkelsensor abziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Kurbelwinkelsensor (1) vom Zylinderblock abmontieren.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A131017.jpg" width = "88.000mm" height = "57.392mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</servinfosub>
<servinfosub id = "AGEAP70A1306019002" page = "2">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1306020">Überprüfung des CKP-Sensors</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den O-Ring des Sensors mit Motoröl bestreichen.
</ptxt>
</item>
<item>
<ptxt>
Die Schraube des Kurbelwinkelsensors mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<attention2>
<ptxt>
Unbedingt neue Schrauben mit Gewindekleber-Vorbeschichtung verwenden. Anderenfalls könnten sich die Schrauben lockern.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T1C007">
<t-part>
Schraube des Kurbelwinkelsensors
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131008.jpg" width = "88.000mm" height = "57.393mm" ver = "01" gw = "199" gh = "146"/>
</figure>
</item>
<item>
<ptxt>
Steckverbinder anschließen und Kabelbaum mit einer Klemme sicher befestigen.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
