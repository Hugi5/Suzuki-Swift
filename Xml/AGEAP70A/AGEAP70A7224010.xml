<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7224010" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Löschen von DTCs
</title>
<servinfosub id = "AGEAP70A7224010001">
<title>
Mit SUZUKI-Diagnosegerät
</title>
<s1>
<ptxt>
Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Das SUZUKI-Diagnosegerät an den DLC (1) anschließen, der sich an der Unterseite des Armaturenbretts auf der Fahrerseite befindet.
</ptxt>
<servicetool>
<servicetoolitem id = "L7B209">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI-Testgerät (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A723002.jpg" width = "88.000mm" height = "67.502mm" ver = "03" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Die DTC anhand der Anweisungen des SUZUKI-Diagnosegeräts löschen.
</ptxt>
<attention3>
<ptxt>
Zur Verwendung des SUZUKI-Diagnosegeräts, siehe die Bedienungsanleitung für das SUZUKI-Diagnosegerät.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Nach Beendigung des Löschens &#34;Überprüfung der Diagnosecodes&#34; durchführen und sicherstellen, dass der normale DTC (Kein Code) angezeigt wird.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Zündung auf &#34;OFF&#34; stellen und SUZUKI-Diagnosegerät vom DLC lösen.
</ptxt>
</s1>
</servinfosub>
<c-change/>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
