<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3306005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Zerlegung und Zusammenbau der Verteilergetriebe-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A3306003">Aus- und Einbau des Verteilergetriebes</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A3306004">Bauteile der Verteilergetriebe-Baugruppe</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A3306005001">
<title>
Zerlegung
</title>
<s1>
<ptxt>
Den Dichtring Nr. 1 (1) des rechten Gehäuses mit dem Spezialwerkzeug vom rechten Verteilergetriebegehäuse abziehen.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C001">
<s-part>
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Den Sprengring (2) mit einer Sprengringzange entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Zwischenwelle (4) mit dem Zwischenwellenlager (3) aus der Verteilergetriebe-Baugruppe ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Zwischenwellenlager (3) mit dem Lagerabzieher und einer Hydraulikpresse von der Zwischenwelle (4) treiben.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330008.swf" width = "88.000mm" height = "26.342mm" ver = "01" gw = "155" gh = "58"/>
</figure>
</s1>
<s1>
<ptxt>
Die Halterungsschrauben (2) entfernen und die Verteilergetriebe-Abtriebswellenaufnahme (1) sowie die Scheibe (3) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A330010.swf" width = "88.000mm" height = "55.632mm" ver = "01" gw = "206" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Die Schrauben (1) des Verteilergetriebegehäuses entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Das rechte Verteilergetriebegehäuse (2) mit dem Spezialwerkzeug vom linken Verteilergetriebegehäuse (3) trennen.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C002">
<s-part>
</s-part>
<s-number num = "09912-34510">
09912-34510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330011.swf" width = "88.000mm" height = "57.119mm" ver = "02" gw = "143" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Die Baugruppen des Untersetzungsantriebsrads (1) und des Untersetzungsabtriebsrads (2) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A330012.swf" width = "88.000mm" height = "45.732mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Die Lageraußenringe (1) und die Scheibe (2) abnehmen.
</ptxt>
<attention3>
<ptxt>
Wenn sich die Lageraußenringe nur schwer aus dem Gehäuse ausbauen lassen, das Spezialwerkzeug verwenden.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C003">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944-96011
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330013.swf" width = "88.000mm" height = "51.937mm" ver = "01" gw = "196" gh = "131"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A3306005002">
<title>
Zusammenbau
</title>
<s1>
<ptxt>
Folgendermaßen eine geeignete Scheibe auswählen: 
</ptxt>
<s2>
<ptxt>
Den Abstand &#34;a&#34; zwischen den Kegelrollenlager-Außenringen des Untersetzungsabtriebsrades (1) messen.
</ptxt>
</s2>
<s2>
<ptxt>
Die Tiefe &#34;b&#34; des linken Gehäuses (2) und die Tiefe &#34;c&#34; des rechten Gehäuses (3) messen.
</ptxt>
</s2>
<s2>
<ptxt>
Die Stärke der Ausgleichsscheibe mit folgender Formel berechnen: 
</ptxt>
<ptxt>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "9" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.748in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.157in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.451in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.157in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.451in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.157in"/>
<colspec colnum = "7" colname = "7" colwidth = "0.560in"/>
<colspec colnum = "8" colname = "8" colwidth = "0.157in"/>
<colspec colnum = "9" colname = "9" colwidth = "0.591in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "middle" align = "center">
<ptxt>
Erforderliche Scheibenstärke
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
=
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Tiefe &#34;b&#34;
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Tiefe &#34;c&#34;
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
-
</ptxt>
</entry>
<entry colname = "7" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Abstand &#34;a&#34;
</ptxt>
</entry>
<entry colname = "8" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "9" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "middle" align = "center">
<ptxt>
0,1 mm (0,004 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<figure>
<graphic graphicname = "IAP70A330014.swf" width = "88.000mm" height = "40.526mm" ver = "02" gw = "225" gh = "98"/>
</figure>
</s2>
<c-change/>
<s2>
<ptxt>
Die Scheiben aus den folgenden verfügbaren Größen auswählen, sodass die gesamte Dicke der rechten und linken Seitenscheiben den berechneten Wert erreicht.
</ptxt>
<ptxt>
<emph etype = "bold">
Beispiel:
</emph>
</ptxt>
<ptxt>
Gemessener Abstand &#34;a&#34; beträgt 101,75 mm (4,006 in.).
</ptxt>
<ptxt>
Gemessene Tiefe &#34;b&#34; beträgt 77,95 mm (3,069 in.).
</ptxt>
<ptxt>
Gemessene Tiefe &#34;c&#34; beträgt 25,80 mm (1,016 in.).
</ptxt>
<ptxt>
Erforderliche Scheibenstärke = 77,95 mm (3,069 in.) + 25,80 mm (1,016 in.) – 101,75 mm (4,006 in.) + 0,1 mm (0,004 in.) = 2,10 mm (0,083 in.)
</ptxt>
<spec>
<title>
Verfügbare Scheibenstärken für das Untersetzungsabtriebsrad
</title>
<ptxt>
Rechte Seite: 
</ptxt>
<ptxt>
0,60, 0,65, 0,70, 0,75, 0,80, 0,85, 0,90, 0,95, 1,00 und 1,05 mm (0,024, 0,026, 0,028, 0,030, 0,031, 0,033, 0,035, 0,037, 0,039 und 0,041 in.) 
</ptxt>
<ptxt>
Linke Seite: 
</ptxt>
<ptxt>
1,00, 1,05, 1,10, 1,15, 1,20, 1,25, 1,30, 1,35, 1,40 und 1,45 mm (0,039, 0,041, 0,043, 0,045, 0,047, 0,049, 0,051, 0,053, 0,055 und 0,057 in.) 
</ptxt>
</spec>
</s2>
</s1>
<s1>
<ptxt>
Die Anlageflächen von rechtem und linkem Gehäuse säubern. Dann wie abgebildet einen Dichtmittelwulst mit einem Durchmesser von 1,2 mm (0,047 in.) auf das rechte Gehäuses (1) aufbringen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3C005" uid = "-491504098">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Dichtmittel
</m-desc>
<m-number>
99000-31260
</m-number>
<m-name>
SUZUKI Bond Nr.1217G
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I5RW0A330011.swf" width = "88.000mm" height = "42.399mm" ver = "01" gw = "155" gh = "104"/>
</figure>
</s1>
<s1>
<ptxt>
Die folgenden Teile durch Umkehrung der Zerlegungsschritte in das rechte und linke Gehäuse einbauen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Baugruppe Untersetzungsantriebsrad (1)
</ptxt>
</item>
<item>
<ptxt>
Baugruppe Untersetzungsabtriebsrad (2)
</ptxt>
</item>
<item>
<ptxt>
Lageraußenringe (3)
</ptxt>
</item>
<item>
<ptxt>
Scheiben des Untersetzungsabtriebsrades (4)
</ptxt>
</item>
<item>
<ptxt>
Passstift (5)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A330015.jpg" width = "88.000mm" height = "60.349mm" ver = "01" gw = "213" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Die Verteilergetriebegehäuseschrauben mit dem vorgeschriebenen Anzugsmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T3C006">
<t-part>
Schraube des Verteilergetriebegehäuses
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330016.swf" width = "88.000mm" height = "61.238mm" ver = "01" gw = "169" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Die Kegelritzelscheibe (1) auswählen, wie in Schritt 1) in &#34;Zusammenbau&#34; unter 
<intxref refid = "AGEAP70A3306009">Zerlegung und Zusammenbau der Abtriebswellenaufnahme des Verteilergetriebes</intxref>
 beschrieben.
</ptxt>
</s1>
<s1>
<ptxt>
Das Tragbild prüfen. Siehe hierzu 
<intxref refid = "AGEAP70A3306011">Prüfung des Kegelrad-Tragbildes</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Das Verteilergetriebe-Abtriebsgehäuse (2) zusammen mit Kegelritzelscheibe (1) in das linke Gehäuse (3) einbauen und dann die Halteschrauben mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T3C007">
<t-part>
Schraube der Verteilergetriebe-Abtriebswellenaufnahme
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5,6
</t-value2>
<t-value3>
40,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330017.swf" width = "88.000mm" height = "45.870mm" ver = "01" gw = "165" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Die Schraube in die Schraubenbohrung des Flanschs (2) einschrauben und die Messspitze der Messuhr wie abgebildet in einem rechten Winkel zur Schraube (1) ansetzen. Das Untersetzungsabtriebsrad mit der Hand festhalten und das Zahnflankenspiel von Ritzel und Kegelrad messen.
</ptxt>
<attention3>
<ptxt>
Falls das Zahnflankenspiel den unten genannten Sollwert überschreitet, zur Korrektur das Verhältnis der Stärke der in Schritt 3) in das linke und rechte Gehäuse eingebauten Scheiben ändern.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C004">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900-20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3C005">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900-20701
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Zahnflankenspiel zwischen Kegelritzel und Kegelrad
</title>
<ptxt>
: 0,1 – 0,2 mm (0,0039 – 0,0078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330018.swf" width = "88.000mm" height = "39.091mm" ver = "01" gw = "157" gh = "94"/>
</figure>
</s1>
<s1>
<ptxt>
Das Zwischenwellenlager (1) mit dem Spezialwerkzeug auf die Zwischenwelle (2) treiben.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C006">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913-84510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A330015.swf" width = "88.000mm" height = "48.692mm" ver = "01" gw = "71" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Die Zwischenwelle (2) mit dem Lager (3) in das Verteilergetriebe einbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Mit einer Sprengringzange einen neuen Sprengring (1) in das rechte Verteilergetriebegehäuse einsetzen.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330016.swf" width = "88.000mm" height = "26.757mm" ver = "02" gw = "133" gh = "59"/>
</figure>
</s1>
<s1>
<ptxt>
Die Lippe des neuen Dichtrings Nr. 1 des rechten Gehäuses einfetten.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C006" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Den Dichtring Nr. 1 (1) des rechten Gehäuses mit dem Spezialwerkzeug und einem Hammer in das rechte Verteilergetriebegehäuse (2) treiben.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C007">
<s-part>
(A)
</s-part>
<s-number num = "09925-16010">
09925-16010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Einbautiefe des Abtriebswellendichtrings
</title>
<ptxt>
&#34;a&#34;: 1,0 – 2,0 mm (0,039 – 0,078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330042.swf" width = "88.000mm" height = "45.592mm" ver = "01" gw = "201" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
