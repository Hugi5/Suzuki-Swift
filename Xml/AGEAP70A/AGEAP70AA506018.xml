<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70AA506018" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung des äußeren Warnsummers
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70AA506017">Aus- und Einbau des äußeren Warnsummers</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Bei Zündung &#34;OFF&#34; das SUZUKI-Diagnosegerät an den DLC anschließen.
</ptxt>
</s1>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Funktion &#34;Warnsummer (außen)&#34; im Modus &#34;Aktivtest&#34; wählen.
</ptxt>
</s1>
<s1>
<ptxt>
Prüfen, ob äußerer Warnsummer ertönt.
</ptxt>
<ptxt>
Werden die Vorgaben nicht erfüllt, den betreffenden Schaltkreis auf Unterbrechung oder Kurzschluss prüfen. Wenn der Schaltkreis in Ordnung ist, äußeren Warnsummer austauschen und erneut prüfen.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
