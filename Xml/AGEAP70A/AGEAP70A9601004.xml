<configtype typenbr = "0">
<servinfotype sitcode = "1">
<servinfo servinfosgmlid = "AGEAP70A9601004" svcinfotypenbr = "03" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Beschreibung der Funktion der Zentralverriegelung
</title>
<ptxt>
Das Ver-/Entriegeln der Türen erfolgt durch eine Betätigung der in der folgenden Tabelle genannten Elemente.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.883in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.763in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.602in"/>
<colspec colnum = "4" colname = "4" colwidth = "4.965in"/>
<thead>
<row rowsep = "1">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Element
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Aktivierte Türverriegelung(en)
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry namest = "1" nameend = "3" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Fernbedienung
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Die Taste LOCK einmal drücken, und alle Türen werden verriegelt
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Die Taste UNLOCK einmal drücken, und die Fahrertür wird entriegelt
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Die Taste UNLOCK zweimal drücken, und alle Türen werden entriegelt
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Türsteuerschalter
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Arbeitsweise
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Verriegelung
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Den Steuerschalter einmal drücken, und alle Türen werden verriegelt
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "3" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Entriegeln
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Den Steuerschalter einmal drücken, und die betätigte Tür wird entriegelt
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Den Steuerschalter zweimal drücken, und alle Türen werden entriegelt
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Schalter, Zentralverriegelung (Fahrerseite)
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Alle Türen
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry namest = "1" nameend = "3" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Schlosszylinder
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Den Schlosszylinder einmal in die Position LOCK drehen, und alle Türen werden verriegelt
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Den Schlosszylinder einmal in die Position UNLOCK drehen, und die Fahrertür wird entriegelt
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Den Schlosszylinder zweimal in die Position UNLOCK drehen, und alle Türen werden entriegelt
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry namest = "1" nameend = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Türverriegelungshebel
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Betätigt alle Türen
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
