<servinfosub id = "AGEAP70A7224029002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A7224029003">
<testgroup id = "AGEAP70A7224029005">
<title>
Überprüfung der Testgerät-Ausgabeparameter
</title>
<test1>
<ptxt>
Bei Zündung auf &#34;OFF&#34; das Diagnosegerät anschließen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Zündung auf &#34;ON&#34; stellen und den Modus &#34;DATENLISTE&#34; wählen.
</ptxt>
</test1>
<test1>
<ptxt>
Den auf dem Diagnosegerät angezeigten &#34;Motortyp&#34; überprüfen.
</ptxt>
</test1>
<question>
Wird der Motortyp in den &#34;Daten des Diagnosegeräts&#34; korrekt angezeigt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Durch ein intaktes HVAC-Steuermodul ersetzen und erneut überprüfen.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intaktes Ersatz-ECM einbauen und Prüfung wiederholen.
</ptxt>
</action>
</testgroup>
</diag>
