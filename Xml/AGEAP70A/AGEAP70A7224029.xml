<ptxt>
<emph>
B1570: Motortyp-Signalfehler 
</emph>
</ptxt>
<ptxt>
Das HVAC-Steuermodul empfängt ungültige Daten des Motortypsignals vom ECM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
HVAC-Steuermodul
</ptxt>
</item>
</list1>
