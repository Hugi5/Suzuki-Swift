<servinfosub id = "AGEAP70A4604027003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604027004">
<testgroup id = "AGEAP70A4604027005">
<question>
Wurde die &#34;ESP<sup>&#174;</sup>-Systemprüfung&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A4604001">ESP&#174;-Systemprüfung</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604027006">
<title>
Prüfung der Stromversorgung des Magnetventils und des Masseschaltkreises des ESP&#174;-Steuermoduls
</title>
<test1>
<ptxt>
Überprüfung der Spannungsversorgung des Magnetventils und der Masseschaltkreise unter 
<intxref refid = "AGEAP70A4604042">Überprüfung von Stromversorgung und Masseschaltkreis des ESP&#174;-Steuermoduls</intxref>
.
</ptxt>
</test1>
<question>
Werden die Vorgaben erfüllt?
</question>
<result type = "yes"/>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul-Baugruppe austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekten Kabelbaum reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
</diag>
