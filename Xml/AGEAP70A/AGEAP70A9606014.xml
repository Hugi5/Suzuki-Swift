<section sectnbr = "9F">
<servcat sctnbr = "09" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9606014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Schalters für den Heckklappenöffner
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9606013">Überprüfung des Schalters für den Heckklappenöffner am Fahrzeug</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9606014001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Heckklappenverkleidung ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder (1) des Schalters für den Heckklappenöffner abziehen.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50024.swf" width = "88.000mm" height = "52.404mm" ver = "01" gw = "210" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Untere Heckklappenverkleidung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9206007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zunächst Schrauben (1) und dann Schalter (2) für den Heckklappenöffner entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A960020.jpg" width = "88.000mm" height = "57.494mm" ver = "01" gw = "194" gh = "146"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9606014002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
