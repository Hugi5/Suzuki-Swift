</ptxt>
</test1>
<test1>
<ptxt>
Parksensor (hinten links) austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
