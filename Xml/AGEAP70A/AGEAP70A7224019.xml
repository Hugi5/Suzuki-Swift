<diag type = "test" id = "AGEAP70A7224019005">
<testgroup id = "AGEAP70A7224019006">
<title>
Überprüfung der Diagnosegerät-Parameter
</title>
<test1>
<ptxt>
Den Parameter &#34;LUFTMISCHPOSSENSOR&#34; über den Modus &#34;Datenliste&#34; mit dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Liegt die Spannung unter 0,1 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zeitweilige Störung.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224019007">
<title>
Überprüfung des Positionssensorsignalkreises des Stellglieds für Temperaturregelung
</title>
<test1>
<ptxt>
Den Steckverbinder des Stellglieds für die Temperaturregelung abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1511-H erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Stellglied für Temperaturregelung austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224019008">
<title>
Überprüfung des Positionssensorsignalkreises des Stellglieds für Temperaturregelung
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Spannung zwischen Kabelklemme &#34;WHT&#34; am Steckverbinder des Stellglieds für Temperaturregelung und Masse messen.
</ptxt>
</test1>
<question>
Beträgt die Spannung 5 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224019009">
<title>
Überprüfung des Positionssensorsignalkreises des Stellglieds für Temperaturregelung
</title>
<test1>
<ptxt>
Steckverbinder &#34;G20&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Folgende Punkte überprüfen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand des &#34;WHT&#34;-Kabelschaltkreises: weniger als 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Widerstand im Schaltkreis des Kabels &#34;WHT&#34; zwischen dem Stellglied für Temperaturregelung und Masse: unendlich
</ptxt>
</item>
</list1>
</test1>
<question>
Entsprechen die Werte des Widerstands den Vorgaben?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das HVAC-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224019010">
<title>
Überprüfung des Positionssensorsignalkreises des Stellglieds für Temperaturregelung
</title>
<test1>
<ptxt>
Überprüfen, ob der Widerstand zwischen der Kabelklemme &#34;YEL&#34; und Masse unendlich ist.
</ptxt>
</test1>
<question>
Entspricht der Widerstand den Vorgaben?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das HVAC-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
</diag>
