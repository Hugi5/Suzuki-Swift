<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A5304A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Schlupf
</title>
<diag type = "condition">
<condition>
<ptxt>
Schlupf
</ptxt>
</condition>
<ps>
<ptxt>
Kupplungspedalspiel falsch eingestellt
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Kupplungspedalarm und/oder Kupplungsgeberzylinder austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Kupplungspedalarm: 
<intxreftitleoff1 refid = "AGEAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kupplungsgeberzylinder: 
<intxreftitleoff1 refid = "AGEAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Belag der Kupplungsscheibe verölt oder verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kupplungsscheibe, Druckplatte oder Schwungscheibe verzogen
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Kupplungsscheibe, Kupplungsdeckel oder Schwungscheibe austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Kupplungsscheibe und -deckel: 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schwungscheibe: 
<intxreftitleoff1 refid = "AGEAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Membranfeder ermüdet
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsdeckel austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Geberzylinderkolben bzw. Topfdichtung kehrt nicht in Ausgangsstellung zurück
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsgeberzylinder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
