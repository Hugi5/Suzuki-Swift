<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A9504A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Heckscheibenheizung funktioniert nicht
</title>
<diag type = "condition">
<condition>
<ptxt>
Heckscheibenheizung funktioniert nicht
</ptxt>
</condition>
<ps>
<ptxt>
Defekte System-Schaltkreise (einschließlich Relais und Sicherungen)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A9501002">Heizung für Heckklappenscheibe und Außenspiegelheizung Systembeschreibung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defekter Schalter für Heckscheibenheizung
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A9506008">Überprüfung des Schalters für Heckscheibenheizung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defekte Heckscheibenheizung
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A9506007">Überprüfung der Heckscheibenheizung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
BCM defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
&#34;Überprüfung des BCM und seiner Schaltkreise&#34;: in Abschnitt 10B.
</ptxt>
<ptxt>
Modell mit Zündschalter: 
<intxreftitleoff1 refid = "AGEAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modell mit schlüssellosem Startsystem: 
<intxreftitleoff1 refid = "AGEAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
