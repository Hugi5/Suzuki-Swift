<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A3204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Zahnradgeräusch
</title>
<diag type = "condition">
<condition>
<ptxt>
Zahnradgeräusch
</ptxt>
</condition>
<ps>
<ptxt>
Verschlissenes oder mit Wasser vermischtes Schmiermittel
</ptxt>
</ps>
<action>
<ptxt>
Wechseln bzw. auffüllen. 
<intxreftitleoff1 refid = "AGEAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Schmiermittel ungeeignet oder unzureichend
</ptxt>
</ps>
<action>
<ptxt>
Wechseln bzw. auffüllen. 
<intxreftitleoff1 refid = "AGEAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Falsch eingestelltes Zahnflankenspiel zwischen Kegelritzel und Kegelrad
</ptxt>
</ps>
<action>
<ptxt>
Wie vorgeschrieben einstellen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Mangelhaftes Tragbild im Eingriff zwischen Kegelradritzel und Gangrad
</ptxt>
</ps>
<action>
<ptxt>
Einstellen oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Tellerrad-Sicherungsschrauben locker
</ptxt>
</ps>
<action>
<ptxt>
Austauschen oder nachziehen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Beschädigte Achswellenräder oder Ausgleichsräder
</ptxt>
</ps>
<action>
<ptxt>
Austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
