<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Schiebedach-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9906001">Komponenten des Schiebedachs</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9906002001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Dachhimmel ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Schiebedachscheibe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die an die Schiebedach-Baugruppe angeschlossenen Ablassschläuche (1) an 4 Stellen lösen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990005.jpg" width = "88.000mm" height = "75.169mm" ver = "01" gw = "227" gh = "197"/>
</figure>
</s1>
<s1>
<ptxt>
Den Steckverbinder (1) des Schiebedachmotors lösen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990006.jpg" width = "88.000mm" height = "69.556mm" ver = "01" gw = "225" gh = "181"/>
</figure>
</s1>
<s1>
<ptxt>
Klemmen (1) und Schiebedach-Kabelbaum (2) lösen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990007.jpg" width = "88.000mm" height = "61.392mm" ver = "01" gw = "227" gh = "158"/>
</figure>
</s1>
<s1>
<ptxt>
Schiebedachgehäusemuttern (1) und anschließend Schiebedach-Baugruppe (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990008.jpg" width = "88.000mm" height = "83.554mm" ver = "01" gw = "227" gh = "220"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AGEAP70A9906002002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Alle Teile mit dem vorgeschriebenen Drehmoment befestigen. Siehe dazu 
<intxref refid = "AGEAP70A9906001">Komponenten des Schiebedachs</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Schiebedachgehäusemuttern (1) in der abgebildeten Reihenfolge (&#34;1&#34; bis &#34;4&#34;) festziehen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990009.jpg" width = "88.000mm" height = "82.828mm" ver = "01" gw = "227" gh = "218"/>
</figure>
</item>
<item>
<ptxt>
Die Ablassschläuche (1) an 4 Stellen an die Schiebedach-Baugruppe anschließen. Die Ablassschläuche mit Klammern (2) sicher befestigen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A990010.jpg" width = "88.000mm" height = "75.168mm" ver = "01" gw = "227" gh = "197"/>
</figure>
<figure>
<title>
A-Säule
</title>
<graphic graphicname = "I9P60A990011.swf" width = "88.000mm" height = "95.842mm" ver = "02" gw = "210" gh = "255"/>
</figure>
<figure>
<title>
Seitenblech
</title>
<graphic graphicname = "I9P60A990013.swf" width = "88.000mm" height = "94.869mm" ver = "03" gw = "225" gh = "252"/>
</figure>
</item>
<item>
<ptxt>
Den Schiebedachmotor initialisieren. 
<intxreftitleoff1 refid = "AGEAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Nach dem Einbau der Schiebedach-Baugruppe die Schiebedachscheibe ausrichten. 
<intxreftitleoff1 refid = "AGEAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
