<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Motorgeräusche – Ventilgeräusche
</title>
<ptxt>
Fehlersuche gemäß folgenden Anweisungen durchführen, wenn das ECM keine DTCs erfasst und bei 
<intxref refid = "AGEAP70A1104008">Sichtprüfung</intxref>
 und 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
 keine Mängel festgestellt werden.
</ptxt>
<diag type = "condition">
<condition>
<paragroup>
<ptxt>
Motorgeräusche – Ventilgeräusche
</ptxt>
<attention3>
<ptxt>
Vor Überprüfung auf mechanische Geräusche Folgendes sicherstellen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Zündkerzentyp ist korrekt.
</ptxt>
</item>
<item>
<ptxt>
Kraftstofftyp ist korrekt.
</ptxt>
</item>
</list1>
</attention3>
</paragroup>
</condition>
<ps>
<ptxt>
Falsches Ventilspiel
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406014">Prüfung von Nockenwelle und Stößel</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Ventilschaft und Ventilführung verschlissen
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406028">Überprüfung von Ventil und Ventilführung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Schwache oder gebrochene Ventilfeder
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406031">Überprüfung der Ventilfedern</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Verzogenes oder verbogenes Ventil
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406028">Überprüfung von Ventil und Ventilführung</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
