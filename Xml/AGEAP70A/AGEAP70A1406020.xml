<servinfo servinfosgmlid = "AGEAP70A1406020" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des OCV
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1406017">Komponenten des Steuerkettendeckels</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1406020001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Einlass-OCV-Steckverbinder (schwarz) (1) und Auslass-OCV-Steckverbinder (blau) (2) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Einlass-OCV (3) und Auslass-OCV (4) vom Steuerkettendeckel abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141060.jpg" width = "88.000mm" height = "58.155mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1406020002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang unter Beachtung des folgenden Punkts umkehren: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die OCV-Schrauben auf das vorgeschriebene Drehmoment anziehen.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1D013">
<t-part>
OCV-Schraube
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
