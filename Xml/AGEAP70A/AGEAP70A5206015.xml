</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A5206014">Zerlegung und Zusammenbau des 5. Gangs</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A5206013">Bauteile der Schaltgetriebe-Baugruppe</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A5206018">Bauteile der Antriebswelle und der Vorgelegewelle</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A5206012">Aus- und Einbau der Gangschalt- und Wählhebelschienen-Baugruppe</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A5206015001">
<title>
Zerlegung
</title>
<s1>
<ptxt>
Die Gangschalthebel- und Wählhebelschienen-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A5206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Antriebswelle des 5. Gangs und Vorgelegewelle des 5. Gangs ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (3) der linken Gehäuseplatte herausdrehen.
</ptxt>
</s1>
<s1>
<ptxt>
Linke Gehäuseplatte (1) und Lager-Ausgleichscheibensatz (2) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Sprengring (6) mit einer Sprengringzange (4) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A522018.swf" width = "88.000mm" height = "63.883mm" ver = "02" gw = "196" gh = "165"/>
</figure>
<figure>
