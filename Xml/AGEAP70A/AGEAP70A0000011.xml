<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "00">
<servcat sctnbr = "00" scnbr = "00">
<configtype typenbr = "0">
<servinfotype sitcode = "0">
<servinfo servinfosgmlid = "AGEAP70A0000011" svcinfotypenbr = "01" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Vorsichtsmaßnahmen bei Fahrzeugen mit ESP&#174;-System
</title>
<list1 type = "unordered">
<item>
<ptxt>
Beim Überprüfen eines mit ESP<sup>&#174;</sup> ausgestatteten Fahrzeugs mit folgenden oder ähnlichen Geräten (Testen des Fahrzeugs im Stillstand durch Drehen der Räder (Reifen)) sicherstellen, dass das ESP<sup>&#174;</sup>-System gemäß 
<intxref refid = "AGEAP70A4606002">Sensorkalibrierung</intxref>
 ausgeschaltet wurde, damit die gewonnenen Daten nicht beeinflusst werden.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Prüfstand für 2WD- oder 4WD-Fahrzeuge
</ptxt>
</item>
<item>
<ptxt>
Tachometertester
</ptxt>
</item>
<item>
<ptxt>
Bremsenprüfstand
</ptxt>
</item>
</list2>
</list1>
<servinfosub id = "AGEAP70A0000011001">
<title>
ESP&#174;-Steuermodul
</title>
<list1 type = "unordered">
<item>
<ptxt>
Beim Ein-/Ausbau des ESP<sup>&#174;</sup>-Steuermoduls keine Schlagschrauber verwenden, um eine Beschädigung der Sensoren des ESP<sup>&#174;</sup>-Steuermoduls durch Stöße oder Schläge zu vermeiden.
</ptxt>
</item>
<item>
<ptxt>
Nach Durchführen einer der nachfolgenden Arbeiten muss der Lenkwinkelsensor gemäß 
<intxref refid = "AGEAP70A4606002">Sensorkalibrierung</intxref>
 kalibriert werden.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Austausch des Lenkwinkelsensors
</ptxt>
</item>
<item>
<ptxt>
Austausch des ESP<sup>&#174;</sup>-Steuermoduls
</ptxt>
</item>
</list2>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
