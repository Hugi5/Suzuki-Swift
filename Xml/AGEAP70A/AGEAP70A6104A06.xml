<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A6104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Unberechenbare Lenkwirkung beim Bremsen
</title>
<diag type = "condition">
<condition>
<ptxt>
Unberechenbare Lenkwirkung beim Bremsen
</ptxt>
</condition>
<ps>
<ptxt>
Radlager verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Radlager austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gebrochene oder ermüdete Schraubenfeder
</ptxt>
</ps>
<action>
<ptxt>
Schraubenfeder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vordere Federbeinbaugruppe (Stoßdämpfer) defekt
</ptxt>
</ps>
<action>
<ptxt>
Vordere Federbeinbaugruppe (Stoßdämpfer) austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ungleicher Reifenluftdruck
</ptxt>
</ps>
<action>
<ptxt>
Den Reifendruck entsprechend korrigieren.
</ptxt>
</action>
<ps>
<ptxt>
Vorderradspur falsch eingestellt
</ptxt>
</ps>
<action>
<ptxt>
Vorderradspur überprüfen und einstellen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ungleichmäßige Bremswirkung
</ptxt>
</ps>
<action>
<ptxt>
Bremssystem überprüfen und reparieren. 
<intxreftitleoff1 refid = "AGEAP70A4101001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vorderrad-Bremsscheibe mit Bremsflüssigkeit verunreinigt
</ptxt>
</ps>
<action>
<ptxt>
Bremsscheibe vorn reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Bremsscheibe verzogen
</ptxt>
</ps>
<action>
<ptxt>
Die Vorderrad-Bremsscheibe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Bremsklotz stark verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Den vorderen Bremsklotz erneuern. 
<intxreftitleoff1 refid = "AGEAP70A4206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
