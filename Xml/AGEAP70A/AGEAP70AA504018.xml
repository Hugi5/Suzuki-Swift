<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA504018" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1161/B1163
</title>
<servinfosub id = "AGEAP70AA504018001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.816in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.388in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1161: Nicht übereinstimmende Lenkschlosseinheitdaten 
</emph>
</ptxt>
<ptxt>
Verifizierungsfehler zwischen Steuermodul für schlüsselloses Starten und Lenkschlosseinheit.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Schaltkreis/Steckverbinder der Lenkschlosseinheit
</ptxt>
</item>
<item>
<ptxt>
Lenkschlosseinheit
</ptxt>
</item>
<item>
<ptxt>
Steuermodul für schlüsselloses Starten
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1163: Nicht registrierte Lenkschlosseinheit 
</emph>
</ptxt>
<ptxt>
Lenkschlosseinheit ist nicht registriert.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70AA504018002">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</s1>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schritte 1) und 2) mehrmals wiederholen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA504018003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA504018004">
<testgroup id = "AGEAP70AA504018005">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTC löschen. 
<intxreftitleoff1 refid = "AGEAP70AA504004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
<intxref refid = "AGEAP70AA504018002">Überprüfung von Diagnosecodes</intxref>
 durchführen, und dann DTCs erneut überprüfen.
</ptxt>
</test1>
<question>
Wird DTC B1161 oder B1163 noch immer erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (Zeitweilige Störung)
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA504018006">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Die Lenkschlosseinheit austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
<intxref refid = "AGEAP70AA504018002">Überprüfung von Diagnosecodes</intxref>
 durchführen, und dann DTCs erneut überprüfen.
</ptxt>
</test1>
<question>
Wird DTC B1161 oder B1163 noch immer erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Steuermodul für schlüsselloses Starten ersetzen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (Lenkschlosseinheit war defekt.)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
