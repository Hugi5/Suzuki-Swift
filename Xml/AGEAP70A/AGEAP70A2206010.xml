<section sectnbr = "2B">
<servcat sctnbr = "02" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A2206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der vorderen Querlenkerbuchse
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A2206008">Aus- und Einbau des Querlenkers</intxrefpoff>
</ptxt>
<attention3>
<ptxt>
Die hintere Querlenkerbuchse ist nicht einzeln austauschbar. Wenn die Buchse defekt ist, den Querlenker austauschen.
</ptxt>
</attention3>
<servinfosub id = "AGEAP70A2206010001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Den Flansch der vorderen Buchse (Gummi) (1) des vorderen Querlenkers mit einem Messer abschneiden.
</ptxt>
<figure>
<graphic graphicname = "I9P60A220022.jpg" width = "88.000mm" height = "56.949mm" ver = "01" gw = "238" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Die vordere Buchse des vorderen Querlenkers (1) mit einer Hydraulikpresse (2) und den Spezialwerkzeugen herausdrücken.
</ptxt>
<servicetool>
<servicetoolitem id = "L2B003">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L2B004">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A220023.swf" width = "88.000mm" height = "48.435mm" ver = "01" gw = "173" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A2206010002">
<title>
Einbau
</title>
<s1>
<ptxt>
Die vordere Buchse des vorderen Querlenkers (1) mit den Spezialwerkzeugen und einer Hydraulikpresse (2) einpressen.
</ptxt>
<attention2>
<ptxt>
Buchse nicht wiederverwenden.
</ptxt>
</attention2>
<attention3>
<ptxt>
Zur Vereinfachung des Einbaus die Buchse zuvor am gesamten Umfang mit Seifenwasser benetzen.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L2B005">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943-76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L2B006">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913-75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A220024.swf" width = "88.000mm" height = "48.773mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Die vordere Buchse (1) des vorderen Querlenkers so einpressen, dass die Abmessungen &#34;a&#34; und &#34;b&#34; in der Abbildung gleich sind.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
