<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Hinterachsdifferenzials
</title>
<servinfosub id = "AGEAP70A3206003001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Fahrzeug aufbocken und Räder abmontieren.
</ptxt>
</s1>
<s1>
<ptxt>
Das Öl ggf. aus dem Hinterachsdifferenzial ablassen. 
<intxreftitleoff1 refid = "AGEAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die hinteren Antriebswellen ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Die hintere Kardanwelle vom hinteren Differenzial trennen. 
<intxreftitleoff1 refid = "AGEAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</s1>
<s1>
<ptxt>
Den Entlüftungsschlauch (1) vom Hinterachsdifferenzial entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Wagenheber so platzieren, dass das Differenzial stabilisiert ist.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben des vorderen Querlenkers (2) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schraube der hinteren Differenziallagerung (3) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A320007.swf" width = "88.000mm" height = "57.146mm" ver = "02" gw = "186" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Das hintere Differenzial mit dem Wagenheber absenken.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A3206003002">
<title>
Einbau
</title>
<ptxt>
Zum Einbau den Ausbauvorgang unter Beachtung der folgenden Punkte umkehren.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Alle Schrauben mit den vorgeschriebenen Anzugsmomenten festziehen.
</ptxt>
<torque>
<torqueitem id = "T3B004">
<t-part>
Die Schraube des vorderen Querlenkers
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
<torqueitem id = "T3B005">
<t-part>
Schraube des hinteren Differenzial-Traglagers
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
80
</t-value1>
<t-value2>
8,2
</t-value2>
<t-value3>
59,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320008.swf" width = "88.000mm" height = "52.572mm" ver = "02" gw = "186" gh = "133"/>
</figure>
</item>
<item>
<ptxt>
Hinterachsdifferenzialöl auffüllen, wenn abgelassen, 
<intxreftitleoff1 refid = "AGEAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
