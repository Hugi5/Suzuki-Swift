</ptxt>
</condition>
<ps>
<ptxt>
Stabilisator locker
</ptxt>
</ps>
<action>
<ptxt>
Schrauben oder Muttern des Stabilisators festziehen oder Buchsen austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
