<title>
Aus- und Einbau der Laderaumleuchte
</title>
<servinfosub id = "AGEAP70A9206012001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Verriegelung (2) lösen und Laderaumleuchte (1) in Pfeilrichtung ziehen und ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder von der Laderaumleuchte abziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Glühlampe (3) bei Bedarf entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920016.jpg" width = "88.000mm" height = "62.981mm" ver = "04" gw = "199" gh = "162"/>
