<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A8106010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Ausbau des mittleren Sicherheitsgurts hinten und Installation
</title>
<servinfosub id = "AGEAP70A8106010001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Sitzkissen der hinteren Sitzlehne ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Schraube und Mutter entfernen und anschließend mittlere hintere Sicherheitsgurt-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A8106010002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A8106003">Überprüfung der Sicherheitsgurt-Baugruppe vorn</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und dabei die folgenden Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Stifte (3) am Sitzlehnenrahmen unbedingt in die länglichen Löcher (2) in der Gurtrolle (1) einpassen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810016.swf" width = "88.000mm" height = "77.820mm" ver = "02" gw = "236" gh = "204"/>
</figure>
</item>
<item>
<ptxt>
Die Schrauben des mittleren hinteren Sicherheitsgurts mit dem vorgeschriebenen Drehmoment festziehen. 
<intxreftitleoff1 refid = "AGEAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Beim Anbringen der Ankerplatte (1) nicht auf die Wulste (2) treten.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810017.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
