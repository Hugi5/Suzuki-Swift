<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A8206026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Beifahrerairbag-Deaktivierungsschalters
</title>
<servinfosub id = "AGEAP70A8206026001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Handschuhfach ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder (1) des Beifahrerairbag-Deaktivierungsschalters abziehen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820078.swf" width = "88.000mm" height = "87.000mm" ver = "01" gw = "231" gh = "230"/>
</figure>
</s1>
<s1>
<ptxt>
Die Verriegelungen (2) lösen und den Beifahrerairbag-Deaktivierungsschalter (1) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820079.swf" width = "88.000mm" height = "59.573mm" ver = "02" gw = "207" gh = "152"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A8206026002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A8206027">Überprüfung des Beifahrerairbag-Deaktivierungsschalters</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Den Beifahrerairbag-Deaktivierungsschalter (1) einbauen und dabei seinen Vorsprung (2) auf die Aussparung (3) am Armaturenbrett ausrichten.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820080.swf" width = "88.000mm" height = "64.695mm" ver = "01" gw = "207" gh = "167"/>
</figure>
</s1>
<s1>
<ptxt>
Den Steckverbinder des Beifahrerairbag-Deaktivierungsschalters anschließen.
</ptxt>
</s1>
<s1>
<ptxt>
Handschuhfach einbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
