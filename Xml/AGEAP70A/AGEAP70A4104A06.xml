<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A4104A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Bremsen schleifen (Alle Bremsen schleifen geringfügig unmittelbar nach Pedalfreigabe)
</title>
<diag type = "condition">
<condition>
<ptxt>
Bremsen schleifen (Alle Bremsen schleifen geringfügig unmittelbar nach Pedalfreigabe)
</ptxt>
</condition>
<ps>
<ptxt>
Kolben im Hauptbremszylinder werden nicht ordnungsgemäß rückgeführt
</ptxt>
</ps>
<action>
<ptxt>
Hauptbremszylinder austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Bremsleitungen oder -schläuche verstopft
</ptxt>
</ps>
<action>
<ptxt>
Auf aufgeweichte Schläuche und beschädigte Bremsleitungen prüfen. Bei Bedarf Bremsschläuche und/oder Bremsleitungen erneuern.
</ptxt>
</action>
<ps>
<ptxt>
Feststellbremsmechanismus an Bremsen hinten falsch eingestellt
</ptxt>
</ps>
<action>
<ptxt>
Prüfen und gemäß Vorgabe einstellen.
</ptxt>
</action>
<ps>
<ptxt>
Feststellbremszug oder -gestänge reagiert träge
</ptxt>
</ps>
<action>
<ptxt>
Reparieren oder austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Bremssattelkolben klemmt
</ptxt>
</ps>
<action>
<ptxt>
Bei Bedarf reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Bremssattel-Kolbendichtring stark verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Kolbendichtring austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Bremspedalhöhe falsch eingestellt
</ptxt>
</ps>
<action>
<ptxt>
Die Bremspedalhöhe überprüfen.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
