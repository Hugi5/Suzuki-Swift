<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A4106022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Bremskraftverstärkers
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4106020">Bauteile des Bremskraftverstärkers</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A4106022001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Bremsleitungen (1) mit dem Spezialwerkzeug von ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul (2) lösen.
</ptxt>
<servicetool>
<servicetoolitem id = "L4A012">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410035.swf" width = "88.000mm" height = "45.139mm" ver = "02" gw = "117" gh = "111"/>
</figure>
</s1>
<s1>
<ptxt>
Die Hauptbremszylinder-Baugruppe vom Bremskraftverstärker abmontieren.
</ptxt>
</s1>
<s1>
<ptxt>
Den Unterdruckschlauch vom Bremskraftverstärker lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Klammer (1) und Gabelkopfbolzen (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410036.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Die Muttern (1) des Bremskraftverstärkers entfernen und den Bremskraftverstärker vom Armaturenbrett abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410037.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A4106022004">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4106023">Überprüfung des Bremskraftverstärkers</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Die Mutter der Bremspedalhalterung (1) und die Schraube der oberen Armaturenbrettversteifung (2) lockern.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Den Bremskraftverstärker an das Armaturenbrett anschrauben. Danach den Gabelkopf an der Schubstange (3) mittels Gabelkopfbolzen (2) und Klammer (1) mit dem Pedalarm verbinden.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410040.jpg" width = "88.000mm" height = "74.521mm" ver = "02" gw = "190" gh = "195"/>
</figure>
</s1>
<s1>
<ptxt>
Die Blende für Kombiinstrument entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Muttern des Bremskraftverstärkers mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T4A006">
<t-part>
Mutter des Bremskraftverstärkers*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410041.swf" width = "88.000mm" height = "63.332mm" ver = "02" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Die Mutter der Bremspedalhalterung mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T4A007">
<t-part>
Mutter der Bremspedalhalterung
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Die Schraube der oberen Armaturenbrettversteifung mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T4A008">
<t-part>
Schraube der oberen Armaturenbrettversteifung
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410042.swf" width = "88.000mm" height = "64.412mm" ver = "02" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Die Instrumententafelabdeckung einbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Unterdruckschlauch am Bremskraftverstärker anschließen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Hauptbremszylinder-Baugruppe am Bremskraftverstärker anbringen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Bremsleitungen (1) mit dem Spezialwerkzeug an ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul (2) anschließen.
</ptxt>
<torque>
<torqueitem id = "T4A009">
<t-part>
Überwurfmutter der Bremsleitung
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
19
</t-value1>
<t-value2>
1,9
</t-value2>
<t-value3>
14,0
</t-value3>
</torqueitem>
</torque>
<servicetool>
<servicetoolitem id = "L4A013">
<s-part>
</s-part>
<s-number num = "09950-78220">
09950-78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A410043.swf" width = "88.000mm" height = "46.684mm" ver = "02" gw = "119" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Nach dem Einbau das Bremssystem entlüften. 
<intxreftitleoff1 refid = "AGEAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Alle eingebauten Teile auf Bremsflüssigkeitsleckage prüfen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Bremspedal auf Spiel prüfen. 
<intxreftitleoff1 refid = "AGEAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sicherstellen, dass das Bremssystem einwandfrei funktioniert und keine Bremsflüssigkeitsleckagen bestehen.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
