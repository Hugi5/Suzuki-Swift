<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1306027" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung des OCV
</title>
<list1 type = "unordered">
<item>
<ptxt>
OCVs (Einlass- und Auslassseite) entfernen. 
<intxreftitleoff1 refid = "AGEAP70A1406020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
OCVs (Einlass- und Auslassseite) wie folgt überprüfen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Den Widerstand zwischen den Anschlussklemmen des OCV-Steckverbinders (1) überprüfen.
</ptxt>
<ptxt>
Falls das Prüfergebnis nicht den Vorgaben entspricht, das OCV austauschen.
</ptxt>
<spec>
<title>
Widerstand des OCV
</title>
<ptxt>
6,7 bis 7,7 &#937; bei 20 &#176;C (68 &#176;F) 
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9T401132006.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "180" gh = "153"/>
</figure>
</item>
<item>
<ptxt>
Eine Batterie wie abgebildet an den Steckverbinder des OCV (1) anschließen und das durch die Bewegung des Kolbenventils (2) verursachte Betriebsgeräusch überprüfen.
</ptxt>
<figure>
<graphic graphicname = "I9T401132007.swf" width = "88.000mm" height = "59.819mm" ver = "02" gw = "193" gh = "153"/>
</figure>
</item>
</list2>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
