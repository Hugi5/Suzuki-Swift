<servinfosub id = "AGEAP70A7224017003">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Den Motor anlassen und die Klimaanlage einschalten.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7224017004">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A7224017005">
<testgroup id = "AGEAP70A7224017006">
<title>
Überprüfung der Diagnosegerät-Parameter
</title>
<test1>
<ptxt>
Den Parameter &#34;Sonneneinstrahlung&#34; über den Modus &#34;Datenliste&#34; mit dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Liegt Wert für die Sonneneinstrahlung über 2440 W/m<sup>2</sup> (Signalspannung des Solarsensors liegt unter dem vorgeschriebenen Wert 0,1 V)?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zeitweilige Störung.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224017007">
<title>
Überprüfung des Solarsensor-Signalkreises
</title>
<test1>
<ptxt>
Den Solarsensorstecker abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1504-H erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Solarsensor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7226031"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224017008">
<title>
Überprüfung des Solarsensor-Signalkreises
</title>
<test1>
<ptxt>
Steckverbinder &#34;G20&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Überprüfen, dass bei Zündung auf &#34;ON&#34; die Spannung zwischen der Kabelklemme &#34;PNK&#34; und Masse 0 – 1 V beträgt.
</ptxt>
</test1>
<question>
Entspricht die Spannung der Vorgabe?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das HVAC-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
