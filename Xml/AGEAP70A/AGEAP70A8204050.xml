<servinfosub id = "AGEAP70A8204050003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A8204050004">
<testgroup id = "AGEAP70A8204050005">
<question>
Wurde die &#34;Überprüfung des Airbag-Diagnosesystems&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A8204001">Überprüfung des Airbag-Diagnosesystems</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204050006">
<title>
Überprüfung des Bodenkabelbaums auf Unterbrechungen
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung auf &#34;OFF&#34; steht.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder &#34;L04&#34; und &#34;L49&#34; oder Steckverbinder &#34;L05&#34; und &#34;L50&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Folgende Punkte überprüfen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand der Schaltkreise &#34;A1&#34; und &#34;A2&#34; (DTC B1392/B1393): 1 &#937; oder weniger
</ptxt>
</item>
<item>
<ptxt>
Widerstand der Schaltkreise &#34;A3&#34; und &#34;A4&#34; (DTC B1397/B1398): 1 &#937; oder weniger
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B091">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820036.swf" width = "90.000mm" height = "67.074mm" ver = "02" gw = "214" gh = "174"/>
</testfigure>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Bodenkabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204050007">
<title>
Überprüfung des Bodenkabelbaum-Schaltkreises
</title>
<test1>
<ptxt>
Folgende Punkte überprüfen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand zwischen den Anschlussklemmen &#34;L04-11&#34; und &#34;L04-12&#34; messen (DTC B1392/B1393): unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen den Anschlussklemmen &#34;L05-11&#34; und &#34;L05-12&#34; messen (DTC B1397/B1398): unendlich
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B092">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820154.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Bodenkabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204050008">
<title>
Überprüfung des Bodenkabelbaum-Schaltkreises
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Folgende Punkte überprüfen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand zwischen den Schaltkreisen &#34;A1&#34; und &#34;A2&#34; und Masse (DTC B1392/B1393): unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen den Schaltkreisen &#34;A3&#34; und &#34;A4&#34; und Masse (DTC B1397/B1398): unendlich
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B093">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820155.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Bodenkabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204050009">
<title>
Überprüfung des Bodenkabelbaum-Schaltkreises
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Folgende Punkte überprüfen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Spannung zwischen den Schaltkreisen &#34;A1&#34; und &#34;A2&#34; und Masse (DTC B1392/B1393): ca. 0 V
</ptxt>
</item>
<item>
<ptxt>
Spannung zwischen den Schaltkreisen &#34;A3&#34; und &#34;A4&#34; und Masse (DTC B1397/B1398): ca. 0 V
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B094">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820156.swf" width = "90.000mm" height = "52.428mm" ver = "01" gw = "214" gh = "132"/>
</testfigure>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Bodenkabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204050010">
<title>
Überprüfung des hinteren Seitenaufprallsensors
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung auf &#34;OFF&#34; steht.
</ptxt>
</test1>
<test1>
<ptxt>
Hinteren Seitenaufprallsensor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A8206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird ein DTC erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
SDM austauschen und DTC erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Nach Abschluss der Überprüfung und der Reparaturarbeiten die folgenden Arbeiten durchführen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Alle Bauteile des Airbagsystems wieder anschließen und sicherstellen, dass sie einwandfrei montiert sind.
</ptxt>
</item>
<item>
<ptxt>
Eventuelle DTCs löschen, wenn DTCs festgestellt wurden. Siehe dazu 
<intxref refid = "AGEAP70A8204006">Löschen von DTCs</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
<intxref refid = "AGEAP70A8204001">Überprüfung des Airbag-Diagnosesystems</intxref>
 wiederholen, um sicherzustellen, dass die Störung behoben wurde.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
