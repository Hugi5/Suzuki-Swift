<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung des Hinterachsdifferenzials
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A3206005">Zerlegung und Zusammenbau des Hinterachsdifferenzials</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den Mitnehmerflansch auf Verschleiß und Schäden überprüfen.
</ptxt>
</item>
<item>
<ptxt>
Die Lager auf Verschleiß und Verfärbungen überprüfen.
</ptxt>
</item>
<item>
<ptxt>
Das Ausgleichsgehäuse auf Rissbildung überprüfen.
</ptxt>
</item>
<item>
<ptxt>
Das Antriebskegelradritzel und das Kegelrad auf Verschleiß und Rissbildung überprüfen.
</ptxt>
</item>
<item>
<ptxt>
Die Achswellenräder, Ritzel und die Ritzelwelle auf Verschleiß und Beschädigungen überprüfen.
</ptxt>
</item>
<item>
<ptxt>
Den Zahnkranz der Achswellenräder auf Verschleiß und Beschädigungen überprüfen.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
