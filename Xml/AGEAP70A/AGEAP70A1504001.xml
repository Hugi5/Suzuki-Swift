<section sectnbr = "1E">
<servcat sctnbr = "01" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1504001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Öldruckprüfung
</title>
<attention1>
<ptxt>
Keinesfalls Wartungsarbeiten am noch heißen Abgassystem ausführen, da Verbrennungsgefahr besteht.
</ptxt>
</attention1>
<attention3>
<ptxt>
Vor der Öldruckprüfung folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Ölstand in Ölwanne
</ptxt>
<ptxt>
Bei zu niedrigem Ölstand bis zur Füllstandmarkierung (Loch) (1) am Ölmessstab nachfüllen. 
<intxreftitleoff1 refid = "AGEAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ölzustand
</ptxt>
<ptxt>
Verfärbtes oder kontaminiertes Öl wechseln. 
<intxreftitleoff1 refid = "AGEAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Ölaustritt
</ptxt>
<ptxt>
Undichtigkeiten beseitigen.
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Den Schalthebel auf &#34;Leerlauf&#34; stellen und die Feststellbremse anziehen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den Stoßfänger vorn abbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Vordere Motorabdeckung ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Anschlusskabel (1) vom Öldruckschalter abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Öldruckschalter (2) vom Zylinderblock abmontieren.
</ptxt>
<figure>
<graphic graphicname = "I7V20A151002.swf" width = "88.000mm" height = "51.220mm" ver = "01" gw = "182" gh = "129"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Die Spezialwerkzeuge an der Gewindebohrung ansetzen, wo der Öldruckschalter entfernt wurde.
</ptxt>
<servicetool>
<servicetoolitem id = "L1E001">
<s-part>
(A)
</s-part>
<s-number num = "09915-77311">
09915-77311
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L1E002">
<s-part>
(B)
</s-part>
<s-number num = "09915-78211">
09915-78211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A151003.swf" width = "88.000mm" height = "51.906mm" ver = "01" gw = "230" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Den Motor anlassen und auf normale Betriebstemperatur bringen.
</ptxt>
</s1>
<s1>
<ptxt>
Nach dem Warmlaufen die Motordrehzahl auf 4000 min<sup>-1</sup> erhöhen und den Öldruck messen.
</ptxt>
<spec>
<title>
Öldruck-Sollwert
</title>
<ptxt>
Mehr als 300 – 500 kPa (3,1 – 5,1 kgf/cm<sup>2</sup>, 43,5 – 72,5 psi.) bei 4000 min<sup>-1</sup>. 
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Nach der Öldruckkontrolle den Motor abstellen und die Spezialwerkzeuge entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Auf das Gewinde des Öldruckschalters (1) Dichtmittel auftragen und den Öldruckschalter mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<attention2>
<ptxt>
Kein Dichtmittel auf die Bohrung für den Öldruckschalter auftragen.
</ptxt>
</attention2>
<materials>
<materialitem name = "Thread Lock Cement Super 1322" id = "M1E001" uid = "37">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Gewindekleber
</m-desc>
<m-number>
99000-32110
</m-number>
<m-name>
Thread Lock Cement Super 1322
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<torque>
<torqueitem id = "T1E001">
<t-part>
Öldruckschalter
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9R90A150004.swf" width = "88.000mm" height = "51.483mm" ver = "01" gw = "184" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Anschlusskabel (1) des Öldruckschalters anklemmen.
</ptxt>
<figure>
<graphic graphicname = "I7V20A151005.swf" width = "88.000mm" height = "51.029mm" ver = "01" gw = "186" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Motor starten und Öldruckschalter auf Ölaustritt überprüfen. Bei Ölaustritt den Einbau des Öldruckschalters korrigieren.
</ptxt>
</s1>
<s1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Wenn ein DTC angezeigt wird, diesen DTC löschen. 
<intxreftitleoff1 refid = "AGEAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
