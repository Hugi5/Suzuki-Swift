<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A5304A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kupplung vibriert
</title>
<diag type = "condition">
<condition>
<ptxt>
Kupplung vibriert
</ptxt>
</condition>
<ps>
<ptxt>
Kupplungsscheibenbeläge (glasähnlich) verhärtet
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kupplungsscheibenbeläge verölt
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Ausrücklager gleitet nicht reibungslos
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsnehmerzylinder-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kupplungsscheibenschlag oder mangelhafter Belagkontakt
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Torsionsfedern der Kupplungsscheibe ermüdet
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Nieten der Kupplungsscheibe locker
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Druckplatte oder Schwungscheibe verzogen
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Kupplungsdeckel bzw. Schwungscheibe austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Kupplungsscheibe und -deckel: 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schwungscheibe: 
<intxreftitleoff1 refid = "AGEAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Mangelhafte Motoraufhängung bzw. Schraube(n) und/oder Mutter(n) der Motoraufhängung locker
</ptxt>
</ps>
<action>
<ptxt>
Motoraufhängung austauschen oder Schrauben und/oder Muttern der Motoraufhängung nachziehen. 
<intxreftitleoff1 refid = "AGEAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
