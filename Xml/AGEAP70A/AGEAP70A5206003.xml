<servinfo servinfosgmlid = "AGEAP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Austausch des Differenzialdichtrings
</title>
<s1>
<ptxt>
Das Fahrzeug aufbocken und das Getriebeöl ablassen.
</ptxt>
</s1>
<s1>
<ptxt>
Die linke Antriebswellen-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Radialdichtring (1) mit dem Spezialwerkzeug abmontieren.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913-50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522004.swf" width = "88.000mm" height = "48.454mm" ver = "01" gw = "146" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Den neuen Radialdichtring (1) mit Spezialwerkzeug einbauen.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Sicherstellen, dass der Dichtring mit nach innen weisender Federseite eingebaut wird.
</ptxt>
</item>
<item>
<ptxt>
Sicherstellen, dass der Radialdichtring parallel zur Oberfläche des linken Gehäuses (2) eingebaut wird.
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
09944-88220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
09924-74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Abstand zwischen Gehäuseoberfläche und Radialdichtring
</title>
<ptxt>
&#34;a&#34;: 0 – 1,0 mm (0 – 0,04 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Fett auf Radialdichtringlippe auftragen und Antriebswelle an der Kontaktstelle mit dem Radialdichtring auf Leichtgängigkeit prüfen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B004" uid = "22">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A522005.swf" width = "88.000mm" height = "44.718mm" ver = "02" gw = "110" gh = "110"/>
</figure>
</s1>
<s1>
<ptxt>
Die linke Antriebswellen-Baugruppe einbauen. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Getriebeöl nachfüllen. 
<intxreftitleoff1 refid = "AGEAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
