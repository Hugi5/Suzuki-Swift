<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9506009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Innenrückspiegels
</title>
<servinfosub id = "AGEAP70A9506009001">
<title>
Ausbau
</title>
<ptxt>
Schraube (TORX<sup>&#174;</sup> T20) (1) des Innenrückspiegels entfernen und Spiegel (2) in Pfeilrichtung schieben.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950021.swf" width = "88.000mm" height = "49.005mm" ver = "01" gw = "227" gh = "122"/>
</figure>
</servinfosub>
<servinfosub id = "AGEAP70A9506009002">
<title>
Einbau
</title>
<ptxt>
Zum Einbau den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Schraube des Innenrückspiegels mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9E001">
<t-part>
Schraube des Innenrückspiegels
</t-part>
<t-value1>
3,5
</t-value1>
<t-value2>
0,36
</t-value2>
<t-value3>
2,5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
