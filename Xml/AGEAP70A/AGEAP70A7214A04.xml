<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7214A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kein Warmluftaustritt bzw. unzureichende Heizung (Temperaturregelung defekt)
</title>
<diag type = "condition">
<condition>
<ptxt>
Kein Warmluftaustritt bzw. unzureichende Heizung (Temperaturregelung defekt)
</ptxt>
</condition>
<ps>
<ptxt>
Zug für Temperaturregelung defekt oder verbogen
</ptxt>
</ps>
<action>
<ptxt>
Zug für Temperaturregelung überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Temperaturregler defekt
</ptxt>
</ps>
<action>
<ptxt>
Temperaturregler überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Falscher Einbau des Zugs für Temperaturregelung
</ptxt>
</ps>
<action>
<ptxt>
Position des Zugs überprüfen und ggf. einstellen.
</ptxt>
</action>
<ps>
<ptxt>
Temperaturregelungsklappen-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
Temperaturregelungsklappen-Baugruppe reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Luftkanäle verstopft
</ptxt>
</ps>
<action>
<ptxt>
Luftkanäle reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Wärmetauscher undicht oder verstopft
</ptxt>
</ps>
<action>
<ptxt>
Wärmetauscher austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Heizungsschläuche undicht oder verstopft
</ptxt>
</ps>
<action>
<ptxt>
Heizungsschläuche austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Thermostat ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Thermostat überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
ECT-Sensor ist defekt
</ptxt>
</ps>
<action>
<ptxt>
ECT-Sensor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
