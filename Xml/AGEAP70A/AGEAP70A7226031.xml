<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7226031" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Solarsensors
</title>
<servinfosub id = "AGEAP70A7226031001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Airbagsystem deaktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Armaturenbrett ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Klaue drücken und den Solarsensor (1) nach oben aus dem Armaturenbrett drücken.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder (2) des Solarsensors abklemmen.
</ptxt>
<figure page = "2">
<graphic graphicname = "I7RW01722028.swf" width = "88.000mm" height = "40.458mm" ver = "01" gw = "238" gh = "98"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AGEAP70A7226031002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7226032">Prüfung des Sonnenlichtsensors:Automatiktyp</intxrefpoff>
</ptxt>
<ptxt>
Zum Einbau den Ausbauvorgang umkehren und folgende Punkte beachten: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den Solarsensor (1) durch Einpassen der Laschen (2) des Sensors in die Nuten (3) des Armaturenbretts wie abgebildet einbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723025.swf" width = "88.000mm" height = "35.371mm" ver = "01" gw = "209" gh = "84"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.181in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Fahrzeugvorderseite
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
