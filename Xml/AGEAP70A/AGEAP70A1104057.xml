<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P2138: Spannungskorrelation im Schaltkreis des Pedal-/Drosselklappenstellungssensors/-schalters &#34;D&#34;/&#34;E&#34;
</emph>
</ptxt>
<ptxt>
Die Differenz zwischen halbem Ausgangssignalwert des APP-Hauptsensors und Signal des APP-Nebensensors überschreitet Toleranzwert.
</ptxt>
<ptxt>
(1-Fahrten-Testlogik)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
APP-Sensor und/oder zugehöriger Schaltkreis
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
