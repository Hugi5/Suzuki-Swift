<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1406007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der elektrischen Drosselklappengehäuse-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1406005">Bauteile von Drosselklappengehäuse und Ansaugkrümmer</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A1406006">Überprüfung des Drosselklappengehäuses am Fahrzeug</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Das elektrische Drosselklappengehäuse darf nicht zerlegt werden. Bei Defekten gegen ein Neuteil austauschen.
</ptxt>
</attention2>
<servinfosub id = "AGEAP70A1406007001" page = "2">
<title>
Ausbau
</title>
<s1 page = "2">
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Kühlmittel ablassen. 
<intxreftitleoff1 refid = "AGEAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Luftfilter-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Motorkühlmittelschläuche (1) und den Steckverbinder (2) von der elektrischen Drosselklappengehäuse-Baugruppe (3) abklemmen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die elektrische Drosselklappengehäuse-Baugruppe und die Luftfilterhalterung (4) vom Ansaugkrümmer abmontieren.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1406007002" page = "2">
<title>
Einbau
</title>
<s1 page = "2">
<ptxt>
Die Anlageflächen reinigen und die neue Dichtung des Drosselklappengehäuses (1) auf den Ansaugkrümmer setzen.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141038.swf" width = "88.000mm" height = "58.059mm" ver = "01" gw = "212" gh = "148"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Die elektrische Drosselklappengehäuse-Baugruppe (3) und die Luftfilterhalterung (4) am Ansaugkrümmer anbringen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den Steckverbinder (2) und die Kühlmittelschläuche (1) an der elektrischen Drosselklappengehäuse-Baugruppe (3) anschließen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141021.jpg" width = "88.000mm" height = "61.795mm" ver = "01" gw = "199" gh = "159"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Luftfilter-Baugruppe anbringen. 
<intxreftitleoff1 refid = "AGEAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Minuskabel (–) an die Batterie anklemmen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Kühlmittel auffüllen. 
<intxreftitleoff1 refid = "AGEAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Auf Kühlmittellecks prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
