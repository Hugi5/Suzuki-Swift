<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1190: Störung des Motorschalters 
</emph>
</ptxt>
<ptxt>
Wegfahrsperren-Steuermodul ist defekt.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Wegfahrsperren-Steuermodul
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70AA314020002">
<title>
Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA314020003">
<testgroup id = "AGEAP70AA314020004">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTC löschen. 
<intxreftitleoff1 refid = "AGEAP70AA314004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1190 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Wegfahrsperren-Steuermodul austauschen und DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA316001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (Zeitweilige Störung)
</ptxt>
</action>
</testgroup>
</diag>
