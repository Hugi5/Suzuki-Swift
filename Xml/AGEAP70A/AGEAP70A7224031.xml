<title>
DTC B1580/B1902
</title>
<servinfosub id = "AGEAP70A7224031001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.922in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.288in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1580: EEPROM-Fehler 
</emph>
</ptxt>
<ptxt>
Im HVAC-Steuermodul ist ein EEPROM-Fehler aufgetreten.
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
HVAC-Steuermodul
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1902: Steuermodul-Programmierungsfehler
</emph>
</ptxt>
<ptxt>
Im HVAC-Steuermodul ist ein Programmier-Fehler aufgetreten.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70A7224031006">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Den Motor anlassen und die Klimaanlage einschalten.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7224031002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A7224031003">
<testgroup id = "AGEAP70A7234024004">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen und DTC abrufen.
</ptxt>
</test1>
<question>
Wird DTC B1580 oder B1902 noch immer erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das HVAC-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zeitweilige Störung.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
