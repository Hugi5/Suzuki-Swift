<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9206007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Kennzeichenbeleuchtung
</title>
<servinfosub id = "AGEAP70A9206007001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Schrauben (1) der unteren Heckklappenverkleidung lösen und anschließend untere Heckklappenverkleidung (2) abnehmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Kennzeichenbeleuchtung (3) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder der Kennzeichenbeleuchtung abklemmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920001.jpg" width = "88.000mm" height = "80.485mm" ver = "01" gw = "211" gh = "212"/>
</figure>
</s1>
<s1>
<ptxt>
Die Glühlampe herausnehmen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9206007002">
<title>
Einbau
</title>
<ptxt>
Zum Einbau den Ausbauvorgang umkehren und folgende Punkte beachten: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Schrauben der unteren Heckklappenverkleidung mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T9B001">
<t-part>
Schraube der unteren Heckklappenverkleidung
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A920002.jpg" width = "88.000mm" height = "80.884mm" ver = "01" gw = "211" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
