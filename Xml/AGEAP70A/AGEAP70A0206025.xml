<section sectnbr = "0B">
<servcat sctnbr = "00" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A0206025" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung der Radaufhängung
</title>
<list1 type = "unordered">
<item>
<ptxt>
Die vorderen Federbein-Baugruppen und Hinterrad-Stoßdämpfer auf Anzeichen von Ölundichtigkeit, Dellen oder sonstige Schäden der Manschetten überprüfen. Außerdem die Ankerpunkte auf Verschleiß überprüfen.
</ptxt>
<ptxt>
Defekte Teile austauschen.
</ptxt>
</item>
<item>
<ptxt>
Die Vorder- und Hinterradaufhängung auf beschädigte, lockere oder fehlende Teile überprüfen. Außerdem prüfen, ob Teile Anzeichen von Verschleiß oder mangelnder Schmierung aufweisen.
</ptxt>
<ptxt>
Defekte Teile reparieren oder austauschen.
</ptxt>
<figure>
<title>
Vorn
</title>
<graphic graphicname = "IAP70P020011.jpg" width = "88.000mm" height = "66.835mm" ver = "01" gw = "113" gh = "173"/>
</figure>
<figure>
<title>
Hinten
</title>
<graphic graphicname = "IAP70P020012.jpg" width = "88.000mm" height = "86.351mm" ver = "01" gw = "200" gh = "228"/>
</figure>
</item>
<item>
<ptxt>
Die Staubabdeckungen der Vorderrad-Querlenker-Kugelgelenke auf Undichtigkeit, Ablösung, Risse oder sonstige Schäden überprüfen.
</ptxt>
<ptxt>
Defekte Staubabdeckungen austauschen.
</ptxt>
<figure>
<graphic graphicname = "IAW101020014.swf" width = "88.000mm" height = "44.830mm" ver = "01" gw = "176" gh = "111"/>
</figure>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
