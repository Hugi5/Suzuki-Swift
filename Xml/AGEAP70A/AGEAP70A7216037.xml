<servinfosub id = "AGEAP70A7216037001">
<title>
Einbau
</title>
<s1>
<ptxt>
Kompressor-Antriebsriemen einbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Riemenspannung einstellen. 
<intxreftitleoff1 refid = "AGEAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
