<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4B">
<servcat sctnbr = "04" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A4206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Vorderrad-Bremsklötze
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4206001">Bauteile der Bremsen vorn</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Keinesfalls die Vorderrad-Bremsschläuche beschädigen.
</ptxt>
</item>
<item>
<ptxt>
Während der unten aufgeführten Wartungsarbeiten keinesfalls das Bremspedal betätigen.
</ptxt>
</item>
</list1>
</attention2>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Beim Ausbau der Vorderrad-Bremsklötze auf Austritt von Bremsflüssigkeit prüfen und bei eventuellen Lecks den Vorderrad-Bremssattel reparieren.
</ptxt>
</item>
<item>
<ptxt>
Stets alle Vorderrad-Bremsklötze als Satz austauschen, selbst wenn nur ein Bremsklotz mangelhaft ist.
</ptxt>
</item>
</list1>
</attention3>
<servinfosub id = "AGEAP70A4206003001">
<title>
Ausbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4206002">Überprüfung der Vorderrad-Bremsklötze am Fahrzeug</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Das Fahrzeug aufbocken und das Vorderrad abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Stiftschrauben (1) des Vorderrad-Bremssattels entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A420003.swf" width = "88.000mm" height = "52.270mm" ver = "01" gw = "149" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Den Vorderrad-Bremssattel (1) vom Vorderrad-Bremssattelträger (2) abnehmen.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Den ausgebauten Vorderrad-Bremssattel (1) mit einem Drahthaken (4) aufhängen, um ein Abknicken, Verdrehen oder Überdehnen des Vorderrad-Bremsschlauchs zu verhindern.
</ptxt>
</item>
<item>
<ptxt>
Bei ausgebauten Vorderrad-Bremsklötzen keinesfalls das Bremspedal betätigen.
</ptxt>
</item>
</list1>
</attention3>
</s1>
<s1>
<ptxt>
Die Vorderrad-Bremsklötze (3) und die Spreizfedern (5) vom Vorderrad-Bremssattelträger (2) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A420004.swf" width = "88.000mm" height = "61.626mm" ver = "01" gw = "158" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A4206003002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4206006">Überprüfung der Vorderrad-Bremsscheibe</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A4206009">Überprüfung des Vorderrad-Bremssattels</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Beim Einbau des Vorderrad-Bremssattelträgers nicht den Vorderrad-Bremsschlauch verdrehen.
</ptxt>
</attention2>
<s1>
<ptxt>
Die Spreizfedern (1) am Vorderrad-Bremssattelträger (2) befestigen.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70A420005.swf" width = "88.000mm" height = "51.112mm" ver = "01" gw = "140" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Die Scheiben (1) an die inneren Vorderad-Bremsklötze (3) und Geräuschdämmscheibe (2) am äußeren Vorderrad-Bremsklotz (4) anbringen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A420006.swf" width = "88.000mm" height = "40.376mm" ver = "01" gw = "220" gh = "98"/>
</figure>
</s1>
<s1>
<ptxt>
Die Vorderrad-Bremsklötze (1) mit den Scheiben wie dargestellt in die Vorderrad-Bremssattelträgerschrauben (2) einsetzen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A420007.swf" width = "88.000mm" height = "60.961mm" ver = "01" gw = "158" gh = "156"/>
</figure>
<attention3>
<ptxt>
Den inneren Vorderrad-Bremsklotz unbedingt so in den Bremssattelträger einsetzen, dass der Verschleißanzeiger (1) nach oben weist.
</ptxt>
<figure>
<graphic graphicname = "I9P60A420024.swf" width = "88.000mm" height = "36.526mm" ver = "03" gw = "162" gh = "87"/>
</figure>
</attention3>
</s1>
<s1>
<ptxt>
Den Vorderrad-Bremssattel einbauen und die Stiftschrauben (1) des Vorderrad-Bremssattels mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T4B001">
<t-part>
Stiftschraube des Vorderrad-Bremssattels
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
26
</t-value1>
<t-value2>
2,7
</t-value2>
<t-value3>
19,5
</t-value3>
</torqueitem>
</torque>
<figure page = "2">
<graphic graphicname = "IAP70A420008.swf" width = "88.000mm" height = "52.270mm" ver = "01" gw = "149" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Vorderrad montieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Sicherstellen, dass das Bremssystem einwandfrei funktioniert.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
