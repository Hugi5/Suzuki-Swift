<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Nebelscheinwerfer (falls vorhanden)
</title>
<servinfosub id = "AGEAP70A9206003001">
<title>
Ausbau
</title>
<attention3>
<ptxt>
Nach dem Austausch von Nebelscheinwerfer bzw. Glühlampe für Nebelscheinwerfer die Ausrichtung der Nebelscheinwerfer überprüfen und ggf. anpassen. 
<intxreftitleoff1 refid = "AGEAP70A9206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1>
<ptxt>
Einfassung für Nebelscheinwerfer (1) entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben des Nebelscheinwerfers (2) herausdrehen und den Nebelscheinwerfer (3) ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder vom Nebelscheinwerfer abziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Fassung (4) gegen den Uhrzeigersinn drehen, um die Glühlampe zu entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920009.jpg" width = "88.000mm" height = "81.348mm" ver = "01" gw = "206" gh = "214"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9206003002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
