<servinfosub id = "AGEAP70A4604023003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604023004">
<testgroup id = "AGEAP70A4604023005">
<question>
Wurde die &#34;ESP<sup>&#174;</sup>-Systemprüfung&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A4604001">ESP&#174;-Systemprüfung</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604023006">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
<intxref refid = "AGEAP70A4604005">DTC-Überprüfung</intxref>
 durchführen.
</ptxt>
</test1>
<question>
Liegen andere DTCs als C1037, C1038 und C1057 vor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604023007">
<title>
DTC-Überprüfung des BCM
</title>
<test1>
<ptxt>
DTC für BCM überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC U0073, U0121 oder U0126 erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604023008">
<title>
Überprüfung der Sicherung
</title>
<test1>
<ptxt>
&#34;ABS&#34;-Sicherung überprüfen.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Die Sicherung austauschen und den Schaltkreis auf Masseschluss prüfen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604023009">
<title>
Prüfung des Stromversorgungskreises des Lenkwinkelsensors
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Den Lenkwinkelsensor-Steckverbinder abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder &#34;G33&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreien Anschluss am Lenkwinkelsensor prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn der Anschluss in Ordnung ist, die Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Spannung zwischen Schaltkreis &#34;A1&#34; und Masse messen.
</ptxt>
</test1>
<question>
Beträgt sie 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
&#34;A1&#34;-Schaltkreis reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604023010">
<title>
Prüfung des Masseschaltkreises des Lenkwinkelsensors
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Den Widerstand zwischen Schaltkreis &#34;A2&#34; und Masse messen.
</ptxt>
</test1>
<question>
Beträgt er weniger als 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Schaltkreis &#34;A2&#34; reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604023011">
<title>
Prüfung des Lenkwinkelsensors
</title>
<test1>
<ptxt>
Den Lenkwinkelsensor-Steckverbinder anschließen.
</ptxt>
</test1>
<test1>
<ptxt>
Lenkwinkelsensor prüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul-Baugruppe austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Lenkwinkelsensor austauschen und erneut DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
