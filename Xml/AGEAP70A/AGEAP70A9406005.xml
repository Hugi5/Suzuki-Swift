<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9406005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Heckscheibenwischers
</title>
<servinfosub id = "AGEAP70A9406005001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Heckscheibenwischerarmabdeckung (1), Heckscheibenwischerarmmutter (2), Heckscheibenwischerarm mit Wischerblatt-Baugruppe (3), Kappe für Heckwischerwelle (4), Mutter des Heckscheibenwischers (5) und Dichtung für Heckscheibenwischer (6) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A940013.swf" width = "88.000mm" height = "45.733mm" ver = "01" gw = "174" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Die Heckklappenverkleidung ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Heckscheibenwischermotor entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder vom Heckscheibenwischermotor (1) mit einem Schlitzschraubendreher (2) wie in der Abbildung dargestellt abklemmen.
</ptxt>
<figure>
<graphic graphicname = "I7V10A940003.swf" width = "88.000mm" height = "79.003mm" ver = "01" gw = "161" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9406005002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9406006">Überprüfung des Heckscheibenwischermotors</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Schrauben des Heckscheibenwischermotors mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T9D004">
<t-part>
Schraube des Heckscheibenwischermotors
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I5RW0A940011.swf" width = "88.000mm" height = "56.315mm" ver = "01" gw = "172" gh = "143"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.373in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Heckscheibenwischermotor
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Heckscheibenwischerdichtung (1) einsetzen und Mutter des Heckscheibenwischers mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T9D005">
<t-part>
Mutter des Heckscheibenwischers
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,3
</t-value1>
<t-value2>
0,54
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
