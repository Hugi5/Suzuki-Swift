<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3306010" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Prüfung der Verteilergetriebe-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A3306005">Zerlegung und Zusammenbau der Verteilergetriebe-Baugruppe</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A3306003">Aus- und Einbau des Verteilergetriebes</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Alle Lager auf Leichtgängigkeit, Verschleiß und Verfärbung kontrollieren.
</ptxt>
<ptxt>
Bei Fehlern das Lager austauschen.
</ptxt>
</item>
<item>
<ptxt>
Den Radialdichtring auf Undichtigkeit und die Dichtlippe auf übermäßige Härte prüfen.
</ptxt>
<ptxt>
Ggf. den Radialdichtring austauschen.
</ptxt>
</item>
<item>
<ptxt>
Das Verteilergetriebegehäuse auf Risse untersuchen.
</ptxt>
</item>
<item>
<ptxt>
Kegelritzel und Kegelräder auf Verschleiß und Risse untersuchen.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
