<servinfo servinfosgmlid = "AGEAP70A9306004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Parksensorsystem-Steuermoduls (falls vorhanden)
</title>
<servinfosub id = "AGEAP70A9306004001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die untere Innenverkleidung für das Seitenteil hinten ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder (1) des Parksensorsystem-Steuermoduls und Steckverbinder (2) des Parksensor-Warnsummers vom Parksensorsystem-Steuermodul abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (3) entfernen und das Steuermodul (4) des Parksensorsystems entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930024.jpg" width = "88.000mm" height = "56.820mm" ver = "02" gw = "205" gh = "145"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9306004002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
