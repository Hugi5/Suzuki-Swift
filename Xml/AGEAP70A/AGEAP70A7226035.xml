<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7226035" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Innentemperatursensors
</title>
<servinfosub id = "AGEAP70A7226035001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Abdeckung für die Lenksäulenöffnung vom Armaturenbrett abnehmen. 
<intxreftitleoff1 refid = "AGEAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Steckverbinder (1) und Entlüftungsschlauch (2) vom Innentemperatursensor (3) lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Laschen (4) lösen und dann den Innentemperatursensor (3) vom Armaturenbrett entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723023.swf" width = "88.000mm" height = "65.896mm" ver = "01" gw = "232" gh = "170"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7226035002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7226036">Prüfung des Innentemperatursensors:Automatiktyp</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
