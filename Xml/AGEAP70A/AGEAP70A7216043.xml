<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7216043" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Überdruckventils
</title>
<servinfosub id = "AGEAP70A7216043001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Kältemittel mit Auffang- und Recyclingausrüstung aus der Klimaanlage ablassen. Siehe dazu &#34;Rückgewinnung&#34; unter 
<intxref refid = "AGEAP70A7216001">Vorgehensweise für das Befüllen mit Kältemittel:Manuelle Ausführung</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Den rechten Motorunterboden ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Überdruckventil (1) vom Kompressor entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A722038.swf" width = "88.000mm" height = "48.588mm" ver = "03" gw = "120" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7216043002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und dabei die folgenden Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Neuen O-Ring verwenden.
</ptxt>
</item>
<item>
<ptxt>
O-Ring mit Kompressoröl bestreichen.
</ptxt>
<materials>
<materialitem name = "MITSUBISHI S10X" id = "M7B107" uid = "1078878149">
<m-part>
</m-part>
<m-desc>
Kompressoröl
</m-desc>
<m-number>
99000-99095-00A
</m-number>
<m-name>
MITSUBISHI S10X
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Das Überdruckventil mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T7B107">
<t-part>
Überdruckventil
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9,8
</t-value1>
<t-value2>
1,0
</t-value2>
<t-value3>
7,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A722039.swf" width = "88.000mm" height = "48.612mm" ver = "05" gw = "120" gh = "121"/>
</figure>
</item>
<item>
<ptxt>
Das A/C-System gemäß &#34;Entlüften&#34; und &#34;Befüllen&#34; in 
<intxref refid = "AGEAP70A7216001">Vorgehensweise für das Befüllen mit Kältemittel:Manuelle Ausführung</intxref>
 entlüften und befüllen.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
