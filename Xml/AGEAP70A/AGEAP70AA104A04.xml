<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10A">
<servcat sctnbr = "10" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Geschwindigkeitsregelung kann nicht abgebrochen werden
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Vor der Durchführung dieser Symptomdiagnose des Geschwindigkeitsregelsystems die Überprüfung des Geschwindigkeitsregelsystems durchführen. Siehe 
<intxref refid = "AGEAP70AA104001">Überprüfung des Tempomatsystems</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Alle Punkte der folgenden Liste der Reihe nach überprüfen.
</ptxt>
</item>
</list1>
</attention3>
<diag type = "condition">
<condition>
<ptxt>
Geschwindigkeitsregelung kann nicht abgebrochen werden
</ptxt>
</condition>
<ps>
<ptxt>
Fehlerhafter CANCEL-Schalter
</ptxt>
</ps>
<action>
<ptxt>
Funktion des CANCEL-Schalter überprüfen. Siehe 
<intxref refid = "AGEAP70AA106002">Überprüfung des Tempomatschalters</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Fehlerhafter Bremslichtschalter
</ptxt>
</ps>
<action>
<ptxt>
Die Funktion des Bremslichtschalters überprüfen. Siehe 
<intxref refid = "AGEAP70AA106006">Überprüfung des Bremslichtschalters</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
CPP-Schalter Nr. 2 fehlerhaft
</ptxt>
</ps>
<action>
<ptxt>
CPP-Schalter Nr. 2 gemäß 
<intxref refid = "AGEAP70AA106004">Überprüfung des CPP-Schalters Nr. 2</intxref>
 auf einwandfreie Funktion prüfen.
</ptxt>
</action>
<ps>
<ptxt>
Verkabelung oder Masseanschluss ist defekt
</ptxt>
</ps>
<action>
<ptxt>
Reparieren.
</ptxt>
</action>
<ps>
<ptxt>
ECM defekt
</ptxt>
</ps>
<action>
<ptxt>
Austauschen, nachdem sichergestellt wurde, dass keines der obigen Teile defekt ist.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
