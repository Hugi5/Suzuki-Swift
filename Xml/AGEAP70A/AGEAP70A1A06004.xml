<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1A06004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Antriebsriemens für Kühlmittelpumpe/Generator
</title>
<servinfosub id = "AGEAP70A1A06004001" page = "2">
<title>
Ausbau
</title>
<s1 page = "2">
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Den rechten Motorunterboden ausbauen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Erst den Kompressor-Antriebsriemen und dann den Antriebsriemen für Kühlmittelpumpe/Generator (1) abnehmen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit manueller Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modell mit automatischer Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Die Generatorschraube (2) und die Bundschraube (3) des Generators lösen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Generator-Einstellschraube (4) lösen und dann den Antriebsriemen für Kühlmittelpumpe/Generator abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I7V20A1A1008.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "148" gh = "123"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1A06004002" page = "2">
<title>
Einbau
</title>
<s1 page = "2">
<ptxt>
Den Antriebsriemen für Kühlmittelpumpe/Generator (1) auf die Kühlmittelpumpen-Riemenscheibe (2), die Kurbelwellenriemenscheibe (3) und die Generatorriemenscheibe (4) ziehen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Riemenspannung einstellen. 
<intxreftitleoff1 refid = "AGEAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Kompressor-Antriebsriemen aufziehen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit manueller Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modell mit automatischer Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Sicherstellen, dass der Antriebsriemen korrekt in den Nuten der jeweiligen Riemenscheibe sitzt.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "I7V20A1A1009.swf" width = "88.000mm" height = "49.275mm" ver = "01" gw = "140" gh = "123"/>
</figure>
</s1>
<s1>
<ptxt>
Den rechten Motorunterboden montieren.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Minuskabel (–) an die Batterie anklemmen.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
