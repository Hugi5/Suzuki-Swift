<title>
DTC P1611
</title>
<servinfosub id = "AGEAP70AA314007001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.667in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.527in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
P1611: Nicht übereinstimmendes Passwort 
</emph>
</ptxt>
<ptxt>
Das registrierte Passwort ist falsch.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Ein in einem anderen Fahrzeug verwendetes BCM oder ECM ist eingebaut worden
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70AA314007002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA314007003">
<testgroup id = "AGEAP70AA314007004">
<title>
ECM-Registrierung
</title>
<test1>
<ptxt>
Durchführung von 	 
<intxref refid = "AGEAP70AA316003">ECM-Registrierung:Modell mit Zündschalter</intxref>
 .
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC P1611 noch immer erfasst?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
ECM austauschen und DTC erneut abrufen. Falls DTC P1611 weiterhin erfasst wird, das BCM austauschen und erneut auf DTCs prüfen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (ECM war nicht registriert)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
