<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9506022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Außenspiegels
</title>
<servinfosub id = "AGEAP70A9506022001">
<title>
Ausbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9506021">Überprüfung des elektrisch verstellbaren Außenspiegels und Spiegelheizung an dem Fahrzeug</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Innenblende der Schienenhalterung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Beim Modell mit elektrisch verstellbaren Außenspiegeln die Vordertürverkleidung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Beim Modell mit elektrisch verstellbaren Außenspiegeln den Steckverbinder (1) für die elektrisch verstellbaren Außenspiegel abziehen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Muttern (2) des Außenspiegels entfernen und dann den Außenspiegel (3) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950056.jpg" width = "88.000mm" height = "64.314mm" ver = "01" gw = "219" gh = "166"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9506022002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Nach dem Einbau die Funktion des Außenspiegels überprüfen.
</ptxt>
</item>
<item>
<ptxt>
Die Muttern des Außenspiegels in der Reihenfolge (&#34;1&#34; bis &#34;3&#34;) auf das angegebene Drehmoment anziehen.
</ptxt>
<torque>
<torqueitem id = "T9E007">
<t-part>
Mutter für Außenspiegel*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7,9
</t-value1>
<t-value2>
0,81
</t-value2>
<t-value3>
6,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950057.jpg" width = "88.000mm" height = "63.396mm" ver = "01" gw = "225" gh = "163"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
