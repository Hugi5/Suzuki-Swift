<servinfo servinfosgmlid = "AGEAP70A7216030" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der seitlichen Belüftungsdüse
</title>
<servinfosub id = "AGEAP70A7216030001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Fahrerseite: Die Blende für das Kombiinstrument vom Armaturenbrett abbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Beifahrerseite: Beifahrerairbag-Abdeckung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A8206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Seitliche Belüftungsdüse entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Laschen (1) lösen und dann seitliche Belüftungsdüse (2) von der seitlichen Blende des Armaturenbretts (3) trennen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721039.swf" width = "88.000mm" height = "68.687mm" ver = "01" gw = "177" gh = "178"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7216030002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
