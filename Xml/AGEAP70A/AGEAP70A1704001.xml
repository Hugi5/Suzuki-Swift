<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1704001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Überprüfung des Kraftstoffsystems
</title>
<diag type = "test" id = "AGEAP70A1704001001">
<testgroup id = "AGEAP70A1704001002">
<title>
Überprüfung der Kraftstoffpumpe
</title>
<test1>
<ptxt>
Tankdeckel abnehmen und Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Prüfen, ob das Betriebsgeräusch der Kraftstoffpumpe am Tankstutzen etwa 2 Sekunden lang zu hören ist und dann aufhört.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Kraftstoffpumpen-Schaltkreis überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1704004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704001003">
<title>
Überprüfung des Kraftstoffdrucks
</title>
<test1>
<ptxt>
Den Kraftstoffdruck überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1704005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defektes Bauteil reparieren.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704001004">
<title>
Überprüfung der Leistungsbilanz
</title>
<test1>
<ptxt>
Die Leistungsbilanz prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1704002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das Kraftstoffsystem ist einwandfrei.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704001005">
<title>
Überprüfung des Einspritzventil-Schaltkreises
</title>
<test1>
<ptxt>
Schaltkreis des Einspritzventils überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1704003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defektes Bauteil reparieren.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A1704001006">
<title>
Überprüfung der Einspritzventile
</title>
<test1>
<ptxt>
Einspritzventil überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1706009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
ECM austauschen und DTC erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Einspritzventil austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1706008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
