<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA314012" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1167
</title>
<servinfosub id = "AGEAP70AA314012001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.260in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.945in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1167: Nicht übereinstimmende Wegfahrsperrendaten
</emph>
</ptxt>
<ptxt>
Verifizierungsfehler zwischen BCM und ECM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Der ECM-ID-Code ist nicht im BCM registriert.
</ptxt>
</item>
<item>
<ptxt>
Zündschlüssel ist nicht registriert
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70AA314012002">
<title>
DTC-Fehlersuche
</title>
<attention3>
<ptxt>
Falls das BCM mit einem anderen Fahrzeug registriert wurde (gebrauchtes Teil), können die Zündschlüssel nicht registriert werden. Immer ein neues BCM einbauen, wenn ein Austausch notwendig ist.
</ptxt>
</attention3>
<diag type = "test" id = "AGEAP70AA314012003">
<testgroup id = "AGEAP70AA314012004">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Die DTCs im ECM abrufen. 
<intxreftitleoff1 refid = "AGEAP70A1104003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird ein DTC erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.	
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA314012005">
<title>
DTCs erneut abrufen
</title>
<test1>
<ptxt>
<intxref refid = "AGEAP70AA316003">ECM-Registrierung:Modell mit Zündschalter</intxref>
 durchführen.
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1167 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (ECM war nicht registriert)
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA314012006">
<title>
Registrierung des Zündschlüssels
</title>
<test1>
<ptxt>
&#34;Wgfhrspr-Schlsslreg.&#34; durchführen. 
<intxreftitleoff1 refid = "AGEAP70AA316002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1167 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
BCM austauschen und die DTCs erneut abrufen. Falls DTC B1167 immer noch erfasst wird, das ECM austauschen und DTC erneut überprüfen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
BCM: 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (Zündschlüssel wurde nicht registriert)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
