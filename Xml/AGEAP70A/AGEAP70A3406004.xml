<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3406004" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Zerlegung und Zusammenbau der Gelenkwelle
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A3406002">Aus- und Einbau der Kardanwelle</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A3406004001">
<title>
Zerlegung
</title>
<s1>
<ptxt>
Vor Zerlegung der Kardanwelle die Richtmarkierungen (1) von Gelenkflansch (2), (3) Viskosekupplung und Kupplungswelle (4) wie dargestellt aneinander ausrichten.
</ptxt>
</s1>
<s1>
<ptxt>
Kardanwelle Nr. 1 (5), Nr. 2 (7) und Zwischenwelle (6) trennen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A340008.swf" width = "88.000mm" height = "38.820mm" ver = "01" gw = "197" gh = "94"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A3406004002">
<title>
Zusammenbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A3406005">Zerlegung und Zusammenbau der Kupplung</intxrefpoff>
</ptxt>
<ptxt>
Den Zerlegungsvorgang unter Beachtung der folgenden Punkte umkehren.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Beim Zusammenbau der Kardanwelle die Richtmarkierungen (1) aneinander ausrichten. Andernfalls können während der Fahrt Vibrationen auftreten.
</ptxt>
</item>
<item>
<ptxt>
Die Muttern des mittleren Traglagers und die Schrauben der Kardanwelle Nr. 2 Schrauben mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T3D003">
<t-part>
Mutter des mittleren Traglagers
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
<torqueitem id = "T3D004">
<t-part>
Schraube der Kardanwelle Nr. 2
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2,3
</t-value2>
<t-value3>
17,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A340009.swf" width = "88.000mm" height = "46.800mm" ver = "01" gw = "198" gh = "116"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
