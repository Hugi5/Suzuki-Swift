<servinfosub id = "AGEAP70A6304016005">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A6304016006">
<testgroup id = "AGEAP70A6304016007">
<question>
Wurde die &#34;Überprüfung des P/S-Systems&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A6304001">Überprüfung des P/S-Systems</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A6304016008">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTC im ECM abrufen. 
<intxreftitleoff1 refid = "AGEAP70A6304003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Liegen DTC(s) vor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche. (Zum ECM gehöriges Teil defekt) 
<intxreftitleoff1 refid = "AGEAP70A1104005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Das P/S-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
