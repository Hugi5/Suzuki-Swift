<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1706015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Kraftstoffpumpen-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1706014">Überprüfung der Kraftstoffpumpe am Fahrzeug</intxrefpoff>
</ptxt>
<attention1>
<ptxt>
Bei der Durchführung der folgenden Arbeiten unbedingt 
<intxref refid = "AGEAP70A1700001">Vorsichtsmaßnahmen bei der Kraftstoffsystemwartung</intxref>
 beachten, um das Brand- und Verletzungsrisiko zu reduzieren.
</ptxt>
</attention1>
<attention2>
<ptxt>
Die Kraftstoffpumpen-Baugruppe mit Ausnahme des Kraftstoffstandsensors keinesfalls zerlegen. Falls ein Defekt erkannt wird, durch ein Neuteil ersetzen.
</ptxt>
</attention2>
<servinfosub id = "AGEAP70A1706015001" page = "2">
<title>
Ausbau
</title>
<s1 page = "2">
<ptxt>
Den Kraftstofftank aus dem Fahrzeug ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1706011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Kraftstoffförderleitung (1) von der Kraftstoffpumpen-Baugruppe (2) lösen. 
<intxreftitleoff1 refid = "AGEAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure page = "2">
<graphic graphicname = "I9P60A171009.swf" width = "88.000mm" height = "43.559mm" ver = "01" gw = "176" gh = "107"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Die Kraftstoffpumpen-Sicherungsmutter (1) mit einem Spezialwerkzeug vom Kraftstofftank (2) lösen.
</ptxt>
<servicetool>
<servicetoolitem id = "L1G013">
<s-part>
(A)
</s-part>
<s-number num = "09941-51013">
09941-51013
</s-number>
</servicetoolitem>
</servicetool>
<figure page = "2">
<graphic graphicname = "I7V20A171016.swf" width = "88.000mm" height = "51.053mm" ver = "01" gw = "137" gh = "128"/>
</figure>
</s1>
<s1>
<ptxt>
Die Kraftstoffpumpen-Baugruppe langsam anheben und die Kraftstoff-Ansaugleitung (1) von der Kraftstoffpumpe lösen. 
<intxreftitleoff1 refid = "AGEAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "IAP70P170012.swf" width = "88.000mm" height = "78.039mm" ver = "01" gw = "190" gh = "205"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Die Kraftstoffpumpen-Baugruppe und den O-Ring vom Kraftstofftank entfernen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1706015002" page = "2">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1706018">Überprüfung des Kraftstoffstandsensors</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Die Außenflächen der Leitung, an der die Kupplung eingesetzt wird, reinigen und die Rastkupplung in die Leitung drücken. Sicherstellen, dass die Leitungen fest angeschlossen sind. Wird das versäumt, kann es zu Kraftstoffaustritt kommen.
</ptxt>
</attention2>
<s1 page = "2">
<ptxt>
Die Anlageflächen von Kraftstoffpumpen-Baugruppe und Kraftstofftank reinigen.
</ptxt>
</s1>
<s1>
<ptxt>
Einen neuen O-Ring (1) am Kraftstofftank (2) anbringen.
</ptxt>
<figure>
<graphic graphicname = "IBP60B170007.swf" width = "88.000mm" height = "56.952mm" ver = "01" gw = "199" gh = "145"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Die Kraftstoffansaugleitung (2) an die Kraftstoffpumpen-Baugruppe (1) anschließen.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70P170012.swf" width = "88.000mm" height = "78.039mm" ver = "01" gw = "190" gh = "205"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Die Kraftstoffpumpen-Baugruppe (1) folgendermaßen am Kraftstofftank (2) montieren:
</ptxt>
<s2>
<ptxt>
Die Pfeilmarkierung (3) auf der Kraftstoffpumpen-Baugruppe an der Aussparung (4) des Kraftstofftanks ausrichten.
</ptxt>
</s2>
<s2>
<ptxt>
Die Kraftstoffpumpen-Baugruppe mit der Hand nach unten drücken, bis die Kraftstoffpumpen-Baugruppe den Kraftstofftank wie abgebildet berührt.
</ptxt>
<figure>
<graphic graphicname = "IBP60B170008.swf" width = "88.000mm" height = "90.025mm" ver = "01" gw = "219" gh = "239"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.510in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
O-Ring
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
Während der Durchführung von Schritt b) die neue Kraftstoffpumpen-Sicherungsmutter (1) von Hand festziehen.
</ptxt>
<attention2>
<ptxt>
Nur neue Sicherungsmuttern für die Kraftstoffpumpe verwenden. Die Wiederverwendung der ausgebauten Sicherungsmutter der Kraftstoffpumpe kann zu Kraftstoffaustritt führen.
</ptxt>
</attention2>
<attention3>
<ptxt>
Beim Festziehen gerade auf die Sicherungsmutter drücken, damit sie sich nicht verkantet.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IBP60B170009.swf" width = "88.000mm" height = "89.491mm" ver = "01" gw = "200" gh = "237"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.462in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.503in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Kraftstoffpumpen-Baugruppe
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
O-Ring
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Kraftstofftank
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s2>
<s2>
<ptxt>
Mit dem Spezialwerkzeug die Kraftstoffpumpen-Sicherungsmutter (1) festziehen, bis die Markierungen (3) von Kraftstoffpumpen-Sicherungsmutter und Kraftstofftank fluchten.
</ptxt>
<attention3>
<ptxt>
Die Markierungen fluchten, wenn die Kraftstoffpumpen-Sicherungsmutter mit ca. 1 und 1/3 Umdrehungen angezogen wurde.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L1G014">
<s-part>
(A)
</s-part>
<s-number num = "09941-51013">
09941-51013
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I7V20A171018.swf" width = "88.000mm" height = "89.624mm" ver = "01" gw = "152" gh = "238"/>
</figure>
</s2>
</s1>
<s1 page = "2">
<ptxt>
Die Kraftstoffförderleitung (1) an die Kraftstoffpumpen-Baugruppe (2) anschließen. 
<intxreftitleoff1 refid = "AGEAP70A1706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure page = "2">
<graphic graphicname = "I9P60A171009.swf" width = "88.000mm" height = "43.559mm" ver = "01" gw = "176" gh = "107"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Den Kraftstofftank in das Fahrzeug einbauen. 
<intxreftitleoff1 refid = "AGEAP70A1706011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
