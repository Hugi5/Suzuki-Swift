<servinfosub id = "AGEAP70A4604030003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604030004">
<testgroup id = "AGEAP70A4604030005">
<question>
Wurde die &#34;ESP<sup>&#174;</sup>-Systemprüfung&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A4604001">ESP&#174;-Systemprüfung</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604030006">
<title>
Prüfung des Stromversorgungskreises des ESP&#174;-Steuermoduls
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Den Steckverbinder &#34;E24&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreien Kontakt mit Anschlussklemme &#34;E24-26&#34; prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn der Anschluss in Ordnung ist, die Spannung zwischen Anschlussklemme &#34;E24-26&#34; und Masse messen.
</ptxt>
</test1>
<question>
Beträgt sie 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
&#34;A1&#34;-Schaltkreis reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604030007">
<title>
Prüfung des Masseschaltkreises des ESP&#174;-Steuermoduls
</title>
<test1>
<ptxt>
Den Widerstand zwischen Anschlussklemme &#34;E24-14&#34; sowie &#34;E24-27&#34; und Masse messen.
</ptxt>
</test1>
<question>
Beträgt der Widerstand weniger als 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul-Baugruppe austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
&#34;B1&#34;- und/oder &#34;B2&#34;-Schaltkreis reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
</diag>
