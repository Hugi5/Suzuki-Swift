</s1>
<s1>
<ptxt>
Die vorderen (1) und die hinteren Traglagerstreben (2) des Hinterachsdifferenzials einbauen.
</ptxt>
<torque>
<torqueitem id = "T3B009">
<t-part>
Schraube des vorderen Hinterachsdifferenzial-Traglagers
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5,1
</t-value2>
<t-value3>
37,0
</t-value3>
</torqueitem>
<torqueitem id = "T3B010">
<t-part>
