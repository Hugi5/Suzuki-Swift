<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A5306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Kupplungsgeberzylinders
</title>
<servinfosub id = "AGEAP70A5306011001">
<title>
Ausbau
</title>
<s1 page = "2">
<ptxt>
Den Bereich um den Deckel des Bremsflüssigkeitsbehälters am Hauptbremszylinder reinigen und die Flüssigkeit mit einer Spritze o. Ä. aus dem Bremsflüssigkeitsbehälter am Hauptbremszylinder absaugen.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Leitung für Kupplungsflüssigkeit vom Kupplungsgeberzylinder abziehen. 
<intxreftitleoff1 refid = "AGEAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Den Kupplungsausgleichsbehälterschlauch lösen (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530007.swf" width = "88.000mm" height = "49.059mm" ver = "01" gw = "141" gh = "123"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Die Schubstange (1) vom Kupplungspedal (2) abmontieren.
</ptxt>
</s1>
<s1>
<ptxt>
Die Muttern (3) des Kupplungsgeberzylinders abschrauben und den Kupplungsgeberzylinder (4) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A530008.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A5306011002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A5306012">Überprüfung des Kupplungsgeberzylinders</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Schubstangenspitze mit Fett bestreichen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Silicone Grease" id = "M5C001" uid = "21">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25100
</m-number>
<m-name>
SUZUKI Silicone Grease
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Die Muttern (1) des Kupplungsgeberzylinders mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T5C004">
<t-part>
Mutter des Kupplungsgeberzylinders
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A531013.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
