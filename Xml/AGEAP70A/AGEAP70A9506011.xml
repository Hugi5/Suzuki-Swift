<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Türscheibe vorn
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9506010">Bauteile der Vordertür</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9506011001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die vordere Türscheibe auf etwa 150 mm (5,91 in.) von der unteren Kante des Fensters senken.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950023.jpg" width = "88.000mm" height = "45.882mm" ver = "02" gw = "225" gh = "114"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.331in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.870in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Ca. 150 mm (5,91 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Innenblende (1) der Schienenhalterung entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Innengriffkappe (2) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (3), die Klammer (B) entfernen und anschließend die Türverkleidung (4) durch Ziehen in Pfeilrichtung entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950025.jpg" width = "88.000mm" height = "101.074mm" ver = "01" gw = "227" gh = "270"/>
</figure>
</s1>
<s1>
<ptxt>
Die Steckverbinder des Türkabelbaums abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Äußere Türdichtleiste für Vordertür (1) durch Bewegen in Pfeilrichtung in der Reihenfolge (&#34;1&#34; bis &#34;2&#34;) wie in der Abbildung gezeigt entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950026.jpg" width = "88.000mm" height = "93.412mm" ver = "01" gw = "227" gh = "248"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.236in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.071in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.236in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.783in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Klaue
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Vordertür-Außenblech
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Die Türverkleidungshalterung (1) und die Türschachtleiste (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950027.jpg" width = "88.000mm" height = "91.845mm" ver = "01" gw = "227" gh = "244"/>
</figure>
</s1>
<s1>
<ptxt>
Schrauben (1) entfernen und Vordertürscheibe (2) durch Bewegen in Pfeilrichtung in der Reihenfolge (&#34;1&#34; bis &#34;2&#34;) wie in der Abbildung gezeigt entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950028.jpg" width = "88.000mm" height = "78.685mm" ver = "02" gw = "225" gh = "207"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9506011002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Türscheibenbefestigungen (1) an der angegebenen Position der Vordertürscheibe (2) anbringen, falls diese von der Vordertürscheibe entfernt wurden.
</ptxt>
<spec>
<title>
Einbauposition der Vordertürscheibenbefestigung
</title>
<ptxt>
&#34;a&#34;: 104 – 106 mm (4,10 – 4,17 in.)
</ptxt>
<ptxt>
&#34;b&#34;: 431,2 – 433,2 mm (16,98 – 17,05 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70P950015.jpg" width = "88.000mm" height = "46.523mm" ver = "01" gw = "191" gh = "115"/>
</figure>
</item>
<item>
<ptxt>
Die Schrauben der Vordertürscheibe in der ordnungsgemäßen Reihenfolge (von &#34;1&#34; bis &#34;2&#34;) wie in der Abbildung gezeigt anziehen.
</ptxt>
</item>
<item>
<ptxt>
Die Schrauben der Vordertürscheibe mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T9E002">
<t-part>
Schraube der Vordertürscheibe*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
5,5
</t-value1>
<t-value2>
0,56
</t-value2>
<t-value3>
4,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950029.jpg" width = "88.000mm" height = "81.655mm" ver = "02" gw = "225" gh = "215"/>
</figure>
</item>
<item>
<ptxt>
Wenn die Scheibenführung verzogen ist, diese reparieren oder durch ein Neuteil ersetzen.
</ptxt>
</item>
<item>
<ptxt>
Die Türschachtleiste (1) mit Butylband (2) anbringen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950031.jpg" width = "88.000mm" height = "81.028mm" ver = "01" gw = "215" gh = "213"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
