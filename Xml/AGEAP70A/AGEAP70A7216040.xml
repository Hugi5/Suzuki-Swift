<servinfo servinfosgmlid = "AGEAP70A7216040" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung der Magnetkupplung
</title>
<list1 type = "unordered">
<item>
<ptxt>
Ankerplatte und Magnetkupplungsscheibe jeweils auf Verschleiß und Ölverschmutzung überprüfen.
</ptxt>
</item>
<item>
<ptxt>
Lager der Magnetkupplungsscheibe auf Geräusche, Verschleiß und Fettrückstände überprüfen.
</ptxt>
</item>
<item>
<ptxt>
Magnetkupplungsspule bei 20 &#176;C (68 &#176;F) messen. Falls der gemessene Widerstand außerhalb der Vorgabe liegt, die Magnetkupplungs-Baugruppe austauschen.
</ptxt>
<spec>
<title>
Widerstand der Magnetkupplungsspule
</title>
<ptxt>
Ca. 4,0 &#937; (bei 20 &#176;C (68 &#176;F))
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A721034.swf" width = "88.000mm" height = "48.333mm" ver = "02" gw = "181" gh = "120"/>
</figure>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
