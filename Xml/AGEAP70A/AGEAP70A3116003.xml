<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3116003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der vorderen Antriebswellen-Baugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A3116001">Bauteile der vorderen Antriebswelle:Vorn</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A3116002">Überprüfung der vorderen Antriebswelle am Fahrzeug:Vorn</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A3116003001">
<title>
Ausbau
</title>
<s1 page = "2">
<ptxt>
Das Fahrzeug aufbocken und das Vorderrad abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die Verstemmung (1) lösen und die Antriebswellenmutter (2) bei gedrücktem Bremspedal abschrauben.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311002.swf" width = "88.000mm" height = "54.100mm" ver = "01" gw = "182" gh = "137"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Getriebe- und Verteilergetriebeöl ablassen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Getriebeöl: 
<intxreftitleoff1 refid = "AGEAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verteilergetriebeöl: 
<intxreftitleoff1 refid = "AGEAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Den Vorderrad-Drehzahlsensor vom Achsschenkel abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Querlenker-Kugelgelenk vom Achsschenkel trennen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Das Antriebswellengelenk (2) mithilfe eines Reifenhebels (1) oder eines Kunststoffhammers (3) herausziehen.
</ptxt>
<attention3>
<ptxt>
Ein Drehen der Antriebswelle während des Herausziehens der Welle kann das Lösen des Sprengrings aus der Gelenkverzahnung vereinfachen.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A311004.swf" width = "88.000mm" height = "41.941mm" ver = "01" gw = "197" gh = "102"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.298in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.298in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Linke Welle
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Rechte Antriebswelle
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Die Antriebswellen-Baugruppe ausbauen.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AGEAP70A3116003002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und dabei die folgenden Punkte beachten.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Unbedingt darauf achten, dass Radialdichtringe und Manschetten beim Antriebswelleneinbau nicht beschädigt werden.
</ptxt>
</item>
<item>
<ptxt>
Keinesfalls mit einem Hammer gegen die Gelenkmanschette schlagen. Das Gelenk darf nur mit den Händen eingesetzt werden.
</ptxt>
</item>
<item>
<ptxt>
Sicherstellen, dass das differenzialseitige Gelenk vollständig eingesetzt ist und der Sicherungsring an der dafür vorgesehenen Stelle sitzt.
</ptxt>
</item>
<item>
<ptxt>
Vor dem Einrücken der Antriebswelle (1) sicherstellen, dass der Codierer (2) am Radlager frei von Fremdkörpern ist.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311003.swf" width = "88.000mm" height = "51.493mm" ver = "01" gw = "203" gh = "129"/>
</figure>
</item>
</list1>
</attention2>
<list1 type = "unordered">
<item>
<ptxt>
Differenzialseitig neuen Sicherungsring für Gelenk verwenden.
</ptxt>
</item>
<item>
<ptxt>
Fett auf die Anlagefläche von Vorderradnabe und Antriebswelle auftragen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A101" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A311005.jpg" width = "88.000mm" height = "67.700mm" ver = "01" gw = "230" gh = "175"/>
</figure>
</item>
<item>
<ptxt>
Die Antriebswellenmutter (1) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<attention2>
<ptxt>
Unbedingt eine neue Antriebswellenmutter verwenden.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T3A101">
<t-part>
Antriebswellenmutter
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17,8
</t-value2>
<t-value3>
129,0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Die Achswellenmutter (1) wie abgebildet verstemmen.
</ptxt>
<attention2>
<ptxt>
Beim Verstemmen darauf achten, dass der zu verstemmende Teil der (2) Antriebswellenmutter nicht bricht. Bei einem Bruch durch ein Neuteil ersetzen.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A311006.swf" width = "88.000mm" height = "54.205mm" ver = "01" gw = "172" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Das Querlenker-Kugelgelenk verbinden. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Den Vorderrad-Drehzahlsensor montieren. 
<intxreftitleoff1 refid = "AGEAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vorderrad montieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Getriebeöl nachfüllen. 
<intxreftitleoff1 refid = "AGEAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verteilergetriebeöl nachfüllen. 
<intxreftitleoff1 refid = "AGEAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Vorderradspur überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
