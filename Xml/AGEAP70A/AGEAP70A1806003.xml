<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1806003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Zündspulen-Baugruppe
</title>
<servinfosub id = "AGEAP70A1806003001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Luftfilter-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Zündspulen-Steckverbinder abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (1) der Zündspulen entfernen und die Zündspulen-Baugruppen (2) herausziehen.
</ptxt>
<figure>
<graphic graphicname = "I7V20A180004.swf" width = "88.000mm" height = "54.310mm" ver = "01" gw = "212" gh = "137"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1806003002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1806004">Überprüfung der Zündspulen-Baugruppe</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgenden Punkt beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Zündspulenschraube mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1H002">
<t-part>
Zündspulenschraube
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
