<servinfosub id = "AGEAP70AA204011003">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA204011004">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA204011005">
<testgroup id = "AGEAP70AA204011009">
<title>
Überprüfung der Parameter
</title>
<test1>
<ptxt>
Bei ausgeschalteter Zündung das SUZUKI-Diagnosegerät an den DLC anschließen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
&#34;Batteriespannung&#34; &#34;Zündschalter 1&#34; und &#34;ACC-Schalter&#34; per Anzeige auf dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ende. (Zeitweilige Störung)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204011006">
<title>
Überprüfung der Schaltkreissicherung
</title>
<test1>
<ptxt>
Zündung auf &#34;OFF&#34; stellen und dann die Sicherungen &#34;DOME&#34; und &#34;HAZ&#34; aus dem J/B entfernen.
</ptxt>
</test1>
<test1>
<ptxt>
Sicherung &#34;DOME&#34; und Sicherung &#34;HAZ&#34; überprüfen.
</ptxt>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Schaltkreissicherung(en) austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204011007">
<title>
Überprüfung des BCM-Reservestromversorgungskreises
</title>
<test1>
<ptxt>
Die Steckverbinder &#34;E323&#34; und &#34;E324&#34; vom Verteilerkasten lösen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf korrekten Klemmenanschluss an den Steckverbindern &#34;E323&#34; und &#34;E324&#34; prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn die Anschlüsse in Ordnung sind, folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Spannung zwischen Schaltkreis &#34;A1&#34; und Masse: Batteriespannung
</ptxt>
</item>
<item>
<ptxt>
Spannung zwischen Schaltkreis &#34;A2&#34; und Masse: Batteriespannung
</ptxt>
</item>
</list1>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kabel &#34;WHT/BLK&#34; oder &#34;WHT&#34; auf Unterbrechung oder Kurzschluss überprüfen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204011008">
<title>
Überprüfung des BCM-Reservestromversorgungskreises
</title>
<test1>
<ptxt>
Den Steckverbinder &#34;E04&#34; vom BCM lösen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreien Klemmenanschluss an Steckverbinder &#34;E04&#34; prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn die Anschlüsse in Ordnung sind, folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Spannung zwischen Schaltkreis &#34;A3&#34; und Masse: Batteriespannung
</ptxt>
</item>
<item>
<ptxt>
Spannung zwischen Schaltkreis &#34;A4&#34; und Masse: Batteriespannung
</ptxt>
</item>
</list1>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
BCM austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kabel &#34;BRN&#34; und/oder &#34;BLK/RED&#34; auf Unterbrechung oder Masseschluss überprüfen.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
