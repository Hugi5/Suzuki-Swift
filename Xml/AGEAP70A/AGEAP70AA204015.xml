<servinfosub id = "AGEAP70AA204015003">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA204015004">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA204015005">
<testgroup id = "AGEAP70AA204015006">
<title>
DTC-Überprüfung
</title>
<question>
Wird DTC B1132 ebenfalls angezeigt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204015009">
<title>
Überprüfung der Parameter
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Anzeige &#34;A/C-Verdampfertemp&#34; auf dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ende. (Zeitweilige Störung)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204015007">
<title>
Überprüfung des Schaltkreises des Verdampfer-Temperatursensors
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder für Verdampfer-Temperatursensor und folgende Steckverbinder abklemmen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit Zündschalter: Steckverbinder &#34;G04&#34;
</ptxt>
</item>
<item>
<ptxt>
Modell mit schlüssellosem Startsystem: Steckverbinder &#34;G05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Anschlussklemmen auf einwandfreie Verbindung zum Steckverbinder des Verdampfer-Temperatursensors und zu folgenden Steckverbindern überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit Zündschalter: Steckverbinder &#34;G04&#34;
</ptxt>
</item>
<item>
<ptxt>
Modell mit schlüssellosem Startsystem: Steckverbinder &#34;G05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Wenn die Anschlüsse in Ordnung sind, folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand der Schaltkreise &#34;A1&#34; und &#34;A2&#34;: weniger als 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen Schaltkreis &#34;A1&#34; und Masse: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen Stromkreisklemmen &#34;A1&#34; und &#34;A2&#34; am Steckverbinder des Außentemperatursensors: unendlich
</ptxt>
</item>
<item>
<ptxt>
Spannung der Schaltkreise &#34;A1&#34; und &#34;A2&#34;: 0 – 1 V (bei Zündung auf &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekten Kabelbaum reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204015008">
<title>
Überprüfung des Verdampfer-Temperatursensors
</title>
<test1>
<ptxt>
Verdampfer-Temperatursensor überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit manueller Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modell mit automatischer Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Verdampfer-Temperatursensor austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Modell mit manueller Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7216016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modell mit automatischer Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7226018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204015010">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Den Verdampfer-Temperatursensor und die folgenden Steckverbinder anschließen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit Zündschalter: Steckverbinder &#34;E04&#34;
</ptxt>
</item>
<item>
<ptxt>
Modell mit schlüssellosem Startsystem: Steckverbinder &#34;E05&#34;
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird der aktuelle DTC B1145 oder B1146 erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
BCM austauschen und die DTCs erneut abrufen.	 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (Zeitweilige Störung)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
