<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9G">
<servcat sctnbr = "09" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9706002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Vordersitzes
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9706001">Bauteile des Vordersitzes</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9706002001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Airbagsystem deaktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Steckverbinder vom Vordersitz abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
4 Befestigungsschrauben herausdrehen, und die Sitz-Baugruppe ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Falls erforderlich, den Sitz zerlegen und defekte Teile reparieren. 
<intxreftitleoff1 refid = "AGEAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9706002002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Informationen zum Drehmoment siehe 
<intxref refid = "AGEAP70A9706001">Bauteile des Vordersitzes</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
Das Airbagsystem aktivieren. 
<intxreftitleoff1 refid = "AGEAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
