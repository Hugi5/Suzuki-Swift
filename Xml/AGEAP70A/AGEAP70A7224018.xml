<diag type = "test" id = "AGEAP70A7224018005">
<testgroup id = "AGEAP70A7224018006">
<title>
Überprüfung der Diagnosegerät-Parameter
</title>
<test1>
<ptxt>
Den Parameter &#34;LUFTMISCHPOSSENSOR&#34; über den Modus &#34;Datenliste&#34; mit dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Beträgt die Spannung mehr als 4,8 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zeitweilige Störung.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224018007">
<title>
Überprüfung des Positionssensorsignalkreises des Stellglieds für Temperaturregelung
</title>
<test1>
<ptxt>
Den Steckverbinder des Stellglieds für die Temperaturregelung abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Kabelklemmen &#34;YEL&#34; und &#34;YEL/RED&#34; des Steckverbinders des Stellglieds für Temperaturregelung mit einem Prüfkabel verbinden.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1511-L erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Stellglied für Temperaturregelung austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224018008">
<title>
Überprüfung des Positionssensorsignalkreises des Stellglieds für Temperaturregelung
</title>
<test1>
<ptxt>
Die Kabelklemmen &#34;YEL&#34; und &#34;YEL/RED&#34; des Steckverbinders &#34;G20&#34; mit einem Prüfkabel verbinden.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7224009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1511-L erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Das HVAC-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
