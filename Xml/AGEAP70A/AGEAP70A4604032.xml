<servinfo servinfosgmlid = "AGEAP70A4604032" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1069
</title>
<servinfosub id = "AGEAP70A4604032001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.536in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.635in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1069: Nicht registrierte Lenkwinkelsensorspezifikation 
</emph>
</ptxt>
<ptxt>
Das ESP<sup>&#174;</sup>-Steuermodul erfasst, dass ein Lenkwinkelsensor aus einem anderen Fahrzeug eingebaut ist.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ESP<sup>&#174;</sup>-Steuermodul
</ptxt>
</item>
<item>
<ptxt>
Lenkwinkelsensor
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70A4604032002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604032003">
<testgroup id = "AGEAP70A4604032004">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Den Lenkwinkelsensor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A4606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
<intxref refid = "AGEAP70A4604005">DTC-Überprüfung</intxref>
 durchführen.
</ptxt>
</test1>
<question>
Wird DTC C1069 erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul-Baugruppe austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
