<servinfosub id = "AGEAP70A4604017003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604017004">
<testgroup id = "AGEAP70A4604017005">
<question>
Wurde die &#34;ESP<sup>&#174;</sup>-Systemprüfung&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A4604001">ESP&#174;-Systemprüfung</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604017006">
<title>
Abruf von ESP&#174;-bezogenen DTC
</title>
<test1>
<ptxt>
<intxref refid = "AGEAP70A4604005">DTC-Überprüfung</intxref>
 durchführen.
</ptxt>
</test1>
<question>
Werden DTC U0073 und/oder U0100 erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604017007">
<title>
Überprüfung von Bremslichtschalter und Schaltkreis
</title>
<test1>
<ptxt>
Bremslichtschalter und zugehörigen Schaltkreis gemäß Schritt 2 bis 4 unter 
<intxref refid = "AGEAP70A1104040">DTC P0504</intxref>
 überprüfen.
</ptxt>
</test1>
<question>
Werden die Vorgaben erfüllt?
</question>
<result type = "yes"/>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul-Baugruppe austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
