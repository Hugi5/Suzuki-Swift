<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7214004" svcinfotypenbr = "06" svcinfoqualnbr = "04" supplyoff = "1" modify = "0">
<title>
Symptomdiagnose für abnormale Geräusche des HVAC-Systems
</title>
<servinfosub id = "AGEAP70A7214004001">
<title>
Abnormale Geräusche vom Kompressor
</title>
<diag type = "condition" id = "AGEAP70A7214004002">
<condition>
<ptxt>
Während der Kompressor läuft, ist ein Rumpelgeräusch zu hören, das proportional zur Motordrehzahl auftritt.
</ptxt>
</condition>
<ps>
<ptxt>
Ungeeignetes Spiel im Zahnkranzbereich
</ptxt>
</ps>
<action>
<ptxt>
Kompressor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Bei einer gewissen Drehzahl tritt – unabhängig von der jeweiligen Geschwindigkeit – ein lautes Geräusch auf.
</ptxt>
</condition>
<ps>
<ptxt>
Kompressor-Antriebsriemen locker bzw. defekt
</ptxt>
</ps>
<action>
<ptxt>
Den Kompressor-Antriebsriemen überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Befestigungsschrauben des Kompressors locker
</ptxt>
</ps>
<action>
<ptxt>
Befestigungsschrauben nachziehen. 
<intxreftitleoff1 refid = "AGEAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Bei niedriger Motordrehzahl ist ein lautes Rattern zu hören.
</ptxt>
</condition>
<ps>
<ptxt>
Mutter der Kupplungsdruckplatte des Kompressors locker
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Mutter der Kupplungsdruckplatte nachziehen. 
<intxreftitleoff1 refid = "AGEAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Kompressor austauschen, wenn er für längere Zeit unter diesen Bedingungen betrieben wurde.
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
<servinfosub id = "AGEAP70A7214004003">
<title>
Abnormale Geräusche von der Magnetkupplung
</title>
<diag type = "condition" id = "AGEAP70A7214004004">
<condition>
<ptxt>
Wenn der Kompressor nicht läuft, ist ein Rumpelgeräusch zu hören.
</ptxt>
</condition>
<ps>
<ptxt>
Lager verschlissen bzw. beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Magnetkupplungs-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Wenn der Kompressor läuft, sind Klappergeräusche zu hören.
</ptxt>
</condition>
<ps>
<ptxt>
Magnetkupplungsspiel fehlerhaft (übermäßiges Spiel)
</ptxt>
</ps>
<action>
<ptxt>
Magnetkupplungsspiel einstellen. 
<intxreftitleoff1 refid = "AGEAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Reibfläche der Magnetkupplung verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Magnetkupplungs-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kompressoröl ist an der Wellendichtung ausgetreten und hat die Reibfläche verschmutzt
</ptxt>
</ps>
<action>
<ptxt>
Kompressorgehäuse-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AGEAP70A7214004005">
<title>
Abnormale Geräusche von Leitungen
</title>
<diag type = "condition" id = "AGEAP70A7214004006">
<condition>
<ptxt>
Im Fahrzeuginneren sind Dröhngeräusche zu hören, doch im Motorraum sind sie nicht besonders auffällig.
</ptxt>
</condition>
<ps>
<ptxt>
Leitungsklemmen defekt
</ptxt>
</ps>
<action>
<ptxt>
Klemmen neu fixieren bzw. die Klemmenanzahl erhöhen.
</ptxt>
</action>
<ps>
<ptxt>
Resonanz durch Pulsieren aufgrund von Kältemittel-Druckschwankungen
</ptxt>
</ps>
<action>
<ptxt>
Ein Dämmelement an der Leitung anbringen oder Position und Länge der Leitung ändern.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AGEAP70A7214004007">
<title>
Anormale Geräusche von der Kondensator-Baugruppe
</title>
<diag type = "condition" id = "AGEAP70A7214004008">
<condition>
<ptxt>
Beträchtliche Vibration in der Kondensator-Baugruppe
</ptxt>
</condition>
<ps>
<ptxt>
Resonanz über Kondensatorhalterung und Karosserie
</ptxt>
</ps>
<action>
<ptxt>
Ein Dämmelement zwischen Kondensatorhalterung und Karosserie einspannen.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AGEAP70A7214004009">
<title>
Anormale Geräusche von der Kurbelwellenriemenscheibe
</title>
<diag type = "condition" id = "AGEAP70A7214004010">
<condition>
<ptxt>
Im Leerlauf oder bei plötzlicher Beschleunigung sind starke Rattergeräusche zu hören.
</ptxt>
</condition>
<ps>
<ptxt>
Schraube der Kurbelwellenriemenscheibe locker
</ptxt>
</ps>
<action>
<ptxt>
Schraube nachziehen. 
<intxreftitleoff1 refid = "AGEAP70A1406017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AGEAP70A7214004011">
<title>
Anormale Geräusche von der Riemenspannrolle
</title>
<diag type = "condition" id = "AGEAP70A7214004012">
<condition>
<ptxt>
Riemenscheibe verursacht ein Klappergeräusch
</ptxt>
</condition>
<ps>
<ptxt>
Lager verschlissen bzw. beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Riemenspannrolle austauschen.
</ptxt>
</action>
<condition>
<ptxt>
Bei Kontakt dreht sich die Riemenscheibe
</ptxt>
</condition>
<ps>
<ptxt>
Gebrochene oder lockere Halterung
</ptxt>
</ps>
<action>
<ptxt>
Halterung austauschen bzw. nachziehen.
</ptxt>
</action>
</diag>
</servinfosub>
<servinfosub id = "AGEAP70A7214004013">
<title>
Ungewöhnliche Geräusche vom A/C-Verdampfer
</title>
<diag type = "condition" id = "AGEAP70A7214004014">
<condition>
<ptxt>
Vom A/C-Verdampfer ist ein Pfeifgeräusch zu hören
</ptxt>
</condition>
<ps>
<ptxt>
Abhängig vom Verhältnis von Innen-/Außentemperatur, Motordrehzahl und Kältemitteldruck kann beim Kältemittelfluss aus dem Expansionsventil ein Pfeifgeräusch entstehen.
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Eine geringfügige Verminderung des Kältemittelvolumens kann dieses Geräusch u. U. stoppen.
</ptxt>
<ptxt>
Expansionsventil überprüfen und bei Mängeln austauschen.
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
<servinfosub id = "AGEAP70A7214004015">
<title>
Ungewöhnliche Geräusche vom Gebläsemotor
</title>
<diag type = "condition" id = "AGEAP70A7214004016">
<condition>
<ptxt>
Gebläsemotor gibt abhängig von der Drehzahl ein Zirpgeräusch von sich
</ptxt>
</condition>
<ps>
<ptxt>
Motorbürsten oder Kollektor verschlissen bzw. beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Gebläsemotor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7216009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<condition>
<ptxt>
Flatter- oder laute Dröhngeräusche vom Gebläsemotor
</ptxt>
</condition>
<ps>
<ptxt>
Blätter oder andere Fremdkörper sind durch den Frischlufteinlass in den Gebläsemotor gelangt
</ptxt>
</ps>
<action>
<ptxt>
Fremdkörper entfernen und sicherstellen, dass der Filter am Frischlufteinlass intakt ist.
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
