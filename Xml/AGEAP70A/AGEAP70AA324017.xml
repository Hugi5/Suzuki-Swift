<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA324017" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1176
</title>
<servinfosub id = "AGEAP70AA324017001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1176: Nicht registrierte technische Daten 
</emph>
</ptxt>
<ptxt>
Fahrzeugausführung ist nicht im Steuermodul für schlüsselloses Starten registriert.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Fernbedienung ist nicht registriert.
</ptxt>
</item>
<item>
<ptxt>
Steuermodul für schlüsselloses Starten
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70AA324017002">
<title>
DTC-Fehlersuche
</title>
<attention3>
<ptxt>
Wenn die Registrierung der Wegfahrsperre nicht ordnungsgemäß abgeschlossen wurde, überprüfen, ob die technischen Daten korrekt geladen wurden.
</ptxt>
</attention3>
<diag type = "test" id = "AGEAP70AA324017003">
<testgroup id = "AGEAP70AA324017006">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTCs im Steuermodul für schlüsselloses Starten abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Werden CAN-DTC(s) erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA324017005">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTC bezüglich CAN-Kommunikation überprüfen.
</ptxt>
</test1>
<question>
Werden CAN-DTC(s) erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA324017004">
<title>
Registrierung der Fernbedienung
</title>
<test1>
<ptxt>
&#34;Wgfhrspr-Schlsslreg.&#34; durchführen. 
<intxreftitleoff1 refid = "AGEAP70AA326002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1176 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Steuermodul für schlüsselloses Starten ersetzen und DTC erneut überprüfen.	 
<intxreftitleoff1 refid = "AGEAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (Fernbedienung war nicht registriert).
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
