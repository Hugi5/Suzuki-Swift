</s1>
<s1>
<ptxt>
Das Abgasrohr Nr. 1 anbringen. 
<intxreftitleoff1 refid = "AGEAP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Abgassystem auf Abgasundichtigkeiten überprüfen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Verteilergetriebe auf Öllecks prüfen.
</ptxt>
</s1>
