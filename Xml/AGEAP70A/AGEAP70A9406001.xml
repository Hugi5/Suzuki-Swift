<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9406001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau von Waschwasserbehälter und Waschwasserpumpe
</title>
<servinfosub id = "AGEAP70A9406001001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Den Stoßfänger vorn abbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Kabelbaumklemmen (1), Steckverbinder der Waschwasserpumpe (2) und Waschanlagenschläuche (3) lösen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P940004.jpg" width = "88.000mm" height = "67.662mm" ver = "01" gw = "209" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Schrauben (1) des Waschwasserbehälters lösen, und den Waschwasserbehälter (2) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P940005.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "180" gh = "174"/>
</figure>
</s1>
<s1>
<ptxt>
Windschutzscheiben-Waschwasserpumpe (1) und hintere Waschwasserpumpe (2) in Pfeilrichtung ziehen, um sie aus dem Waschwasserbehälter (3) zu entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P940006.jpg" width = "88.000mm" height = "62.134mm" ver = "01" gw = "161" gh = "160"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9406001002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9406002">Überprüfung der Waschwasserpumpe</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Schrauben des Waschwasserbehälters mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T9D001">
<t-part>
Schraube des Waschwasserbehälters
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
6,0
</t-value1>
<t-value2>
0,61
</t-value2>
<t-value3>
4,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A940008.jpg" width = "88.000mm" height = "67.383mm" ver = "01" gw = "201" gh = "174"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
