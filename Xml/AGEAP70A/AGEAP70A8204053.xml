<diag type = "test" id = "AGEAP70A8204053003">
<testgroup id = "AGEAP70A8204053004">
<title>
Schaltkreisüberprüfung des Fahrer-Airbagmoduls (Gasgenerator)
</title>
<test1>
<ptxt>
Das Fahrer-Airbagmodul (Gasgenerator) aus der Lenksäule ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A8206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder &#34;G11&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Den Kurzschlussbügel im SDM-Steckverbinder mit dem im Spezialwerkzeug (A) enthaltenen Lösewerkzeug lösen.
</ptxt>
</test1>
<test1>
<ptxt>
Folgenden Punkt überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand zwischen den Anschlussklemmen &#34;G11-5&#34; und &#34;G11-6&#34;: unendlich
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B097">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820030.swf" width = "90.000mm" height = "60.504mm" ver = "01" gw = "212" gh = "155"/>
</testfigure>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zustand des Kabelbaums überprüfen. Wenn Kabelbaum in Ordnung, Kontaktspulen-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204053005">
<title>
Überprüfung des Kontaktspulen-Schaltkreises (Schaltkreis des Fahrer-Airbagmoduls (Gasgenerator))
</title>
<test1>
<ptxt>
Die Kontaktspulen-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Folgenden Punkt überprüfen.
</ptxt>
<ptxt>
Modell mit Zündschalter: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand zwischen den Anschlussklemmen &#34;S121-1&#34; und &#34;S172-2&#34; und zwischen &#34;S121-2&#34; und &#34;S172-1&#34; messen.
</ptxt>
</item>
</list1>
<ptxt>
Modell mit schlüssellosem Startsystem: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand zwischen den Anschlussklemmen &#34;S121-1&#34; und &#34;S174-2&#34; und zwischen &#34;S121-2&#34; und &#34;S174-1&#34; messen.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B098">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820018.swf" width = "90.000mm" height = "70.672mm" ver = "02" gw = "196" gh = "184"/>
</testfigure>
</test1>
<question>
Beträgt der Widerstand 1 &#937; oder weniger?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Die Kontaktspulen-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204053006">
<title>
Überprüfung des Kontaktspulen-Schaltkreises (Hupenschaltkreises)
</title>
<test1>
<ptxt>
Folgenden Punkt überprüfen.
</ptxt>
<ptxt>
Modell mit Zündschalter: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den Widerstand zwischen den Anschlussklemmen &#34;S61-1&#34; und &#34;S171-1&#34; messen.
</ptxt>
</item>
</list1>
<ptxt>
Modell mit schlüssellosem Startsystem: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den Widerstand zwischen den Anschlussklemmen &#34;S62-4&#34; und &#34;S173-4&#34; messen.
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B099">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932-76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAP70A820019.swf" width = "90.000mm" height = "85.625mm" ver = "02" gw = "225" gh = "226"/>
</testfigure>
</test1>
<question>
Beträgt der Widerstand 1 &#937; oder weniger?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Die Kontaktspulen-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A8204053007">
<title>
Überprüfung des Kontaktspulen-Schaltkreises
</title>
<test1>
<ptxt>
Den Widerstand zwischen jeder Anschlussklemme der Kontaktspule und den anderen Anschlussklemmen messen.
</ptxt>
</test1>
<question>
Ist jeder gemessene Widerstand unendlich?
</question>
<result type = "yes"/>
<action>
<ptxt>
Die Kontaktspule und ihr Schaltkreis sind in einwandfreiem Zustand.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Die Kontaktspulen-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
