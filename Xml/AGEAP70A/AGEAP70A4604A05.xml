<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A4604A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
EBD-Warnleuchte (Bremswarnleuchte) bleibt nach dem Drehen der Zündung auf &#34;ON&#34; länger als 2 Sekunden eingeschaltet.
</title>
<diag type = "condition">
<condition>
<ptxt>
EBD-Warnleuchte (Bremswarnleuchte) bleibt nach dem Drehen der Zündung auf &#34;ON&#34; länger als 2 Sekunden eingeschaltet.
</ptxt>
</condition>
<ps>
<ptxt>
Feststellbremse angezogen
</ptxt>
</ps>
<action>
<ptxt>
Feststellbremse lösen und sicherstellen, dass die EBD-Warnleuchte (Bremswarnleuchte) erlischt.
</ptxt>
</action>
<ps>
<ptxt>
Bremsflüssigkeitsstand zu niedrig
</ptxt>
</ps>
<action>
<ptxt>
Den Bremsflüssigkeitsstand prüfen. 
<intxreftitleoff1 refid = "AGEAP70A4106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Störung im Schaltkreis des Feststellbremsschalters und/oder des Warnschalters für Bremsflüssigkeitsstand
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
BCM und dessen Schaltkreis prüfen.
</ptxt>
<ptxt>
Modell mit Zündschalter: 
<intxreftitleoff1 refid = "AGEAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modell mit schlüssellosem Startsystem: 
<intxreftitleoff1 refid = "AGEAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Feststellbremsschalter und/oder Warnschalter für Bremsflüssigkeitsstand defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Feststellbremsschalter und/oder Warnschalter für den Bremsflüssigkeitsstand prüfen.
</ptxt>
<ptxt>
Feststellbremsschalter: 
<intxreftitleoff1 refid = "AGEAP70A4406006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Warnschalter für Bremsflüssigkeitsstand: 
<intxreftitleoff1 refid = "AGEAP70A4106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
EBD-System defekt
</ptxt>
</ps>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Systemüberprüfung durchführen. 
<intxreftitleoff1 refid = "AGEAP70A4604001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Stromversorgung und Masseschaltkreis des ESP<sup>&#174;</sup>-Steuermoduls defekt
</ptxt>
</ps>
<action>
<ptxt>
Stromversorgung und Masseschaltkreis des ESP<sup>&#174;</sup>-Steuermoduls prüfen. 
<intxreftitleoff1 refid = "AGEAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Funktionsstörung im CAN-Kommunikationssystem
</ptxt>
</ps>
<action>
<ptxt>
CAN-Kommunikationssystem prüfen. 
<intxreftitleoff1 refid = "AGEAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
BCM defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
BCM und dessen Schaltkreis prüfen.
</ptxt>
<ptxt>
Modell mit Zündschalter: 
<intxreftitleoff1 refid = "AGEAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Modell mit schlüssellosem Startsystem: 
<intxreftitleoff1 refid = "AGEAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
ESP<sup>&#174;</sup>-Steuermodul defekt
</ptxt>
</ps>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Steuermodul austauschen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defekt im Schaltkreis der EBD-Warnleuchte
</ptxt>
</ps>
<action>
<ptxt>
Schaltkreis der EBD-Warnleuchte überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4604015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
