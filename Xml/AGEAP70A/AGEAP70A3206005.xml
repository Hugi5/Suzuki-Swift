<s1>
<ptxt>
Die Spezialwerkzeuge ansetzen und Kegelritzel-Montagelehre verwenden.
</ptxt>
<servicetool>
<servicetoolitem id = "L3B019">
<s-part>
(A)
</s-part>
<s-number num = "09922-76120">
09922-76120
</s-number>
