<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1561: Störung des Motorkühlmittel-Temperatursensors und/oder dessen Schaltkreises 
</emph>
</ptxt>
<ptxt>
HVAC-Steuermodul empfängt ungültige Daten des ECT-Signals vom ECM.
</ptxt>
</entry>
