<servinfosub id = "AGEAP70A6304013004">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A6304013005">
<testgroup id = "AGEAP70A6304013006">
<question>
Wurde die &#34;Überprüfung des EPS-Systems&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A6304001">Überprüfung des P/S-Systems</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A6304013007">
<title>
Überprüfung der Schaltkreise des P/S-Motors und des P/S-Motorausgangs
</title>
<test1>
<ptxt>
Bei Zündung in der Stellung &#34;OFF&#34; den Steckverbinder &#34;E12&#34; des P/S-Motors vom P/S-Steuermodul abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreie Klemmenanschlüsse an dem Steckverbinder &#34;E12&#34; des P/S-Motors prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn die Anschlüsse in Ordnung sind, folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand zwischen den Schaltkreisen &#34;A1&#34; und &#34;A2&#34;: ca. 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen Schaltkreis &#34;A1&#34; und Masse: unendlich
</ptxt>
</item>
<item>
<ptxt>
Spannung des Schaltkreises &#34;A1&#34;: 0 bis 1 V (bei Zündung auf &#34;ON&#34;)
</ptxt>
</item>
</list1>
</test1>
<test1>
<ptxt>
Den P/S-Motor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A6306013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das P/S-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den P/S-Motor (Lenksäulen-Baugruppe) austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
