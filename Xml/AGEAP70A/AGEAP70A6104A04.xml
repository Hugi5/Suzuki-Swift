<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A6104A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Lenkgeräusche (Rattern oder Knacken)
</title>
<diag type = "condition">
<condition>
<ptxt>
Lenkgeräusche (Rattern oder Knacken)
</ptxt>
</condition>
<ps>
<ptxt>
Schraube des Lenkgetriebegehäuses locker
</ptxt>
</ps>
<action>
<ptxt>
Schraube des Lenkgetriebegehäuses festziehen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fehlerhaftes Tragbild zwischen Zahnstange und Ritzel
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Das Drehmoment von Zahnstange und Ritzelwelle überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Bei Defekten die Lenkgetriebegehäuse-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Lenkgetriebegehäuse-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
Lenkgetriebegehäuse-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Radlager gebrochen oder beschädigt.
</ptxt>
</ps>
<action>
<ptxt>
Radlager austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Spurstangenkopf bzw. inneres Spurstangenkugelgelenk verschlissen
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Spurstangenkopf oder Spurstange austauschen.
</ptxt>
<ptxt>
Spurstangenkopf: 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Spurstange: 
<intxreftitleoff1 refid = "AGEAP70A6306008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
