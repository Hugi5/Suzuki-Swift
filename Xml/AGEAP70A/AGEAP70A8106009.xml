<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "8A">
<servcat sctnbr = "08" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A8106009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der seitlichen hinteren Sicherheitsgurt-Baugruppe
</title>
<servinfosub id = "AGEAP70A8106009001">
<title>
Ausbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A8106008">Bauteile der hinteren Sicherheitsgurte</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Hintere Sitzlehne ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die obere Seitenteil-Innenverkleidung ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Schrauben entfernen und anschließend seitliche hintere Sicherheitsgurt-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A8106009002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A8106008">Bauteile der hinteren Sicherheitsgurte</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und dabei die folgenden Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Stifte (3) an der Karosserie unbedingt in die länglichen Löcher (2) in der Gurtrolle (1) einpassen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810014.swf" width = "88.000mm" height = "66.076mm" ver = "01" gw = "206" gh = "171"/>
</figure>
</item>
<item>
<ptxt>
Die Schrauben des seitlichen hinteren Sicherheitsgurts in numerischer Reihenfolge mit dem vorgeschriebenen Drehmoment festziehen. 
<intxreftitleoff1 refid = "AGEAP70A8106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Jede Ankerplatte (1) installieren, ohne dabei mit der Wulst (2) des Bodenbleches in Beeinträchtigung zu kommen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A810015.swf" width = "88.000mm" height = "65.389mm" ver = "01" gw = "208" gh = "169"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
