<servinfosub id = "AGEAP70A9304004003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A9304004004">
<testgroup id = "AGEAP70A9304004005">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTC löschen. 
<intxreftitleoff1 refid = "AGEAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1802 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Auf zeitweilige Störung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A9304004006">
<title>
Überprüfung des Stromversorgungs- und Masseschaltkreises des Kombiinstruments
</title>
<test1>
<ptxt>
Stromversorgungs- und Masseschaltkreis des Kombiinstruments überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9304015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den defekten Kabelbaum reparieren.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A9304004007">
<title>
Überprüfung der Stromversorgungsspannung des Kombiinstruments
</title>
<test1>
<ptxt>
Die Stromversorgungsspannung bei einer Motordrehzahl von 3000 min<sup>-1</sup> überprüfen.
</ptxt>
</test1>
<question>
Beträgt die Spannung 10 – 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das Kombiinstrument austauschen und erneut DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Das Ladesystem überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
