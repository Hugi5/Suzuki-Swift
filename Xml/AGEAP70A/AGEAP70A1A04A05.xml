<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1A04A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Generator macht Lärm
</title>
<ptxt>
Fehler im Ladesystem werden durch eines oder mehrere der folgenden Symptome angezeigt: 
</ptxt>
<servinfosub id = "AGEAP70A1A04002005">
<title>
Geräusche
</title>
<diag type = "condition">
<condition>
<ptxt>
Generator macht Lärm
</ptxt>
</condition>
<ps>
<ptxt>
Die Befestigungsschrauben lockern
</ptxt>
</ps>
<action>
<ptxt>
Befestigungsschrauben festziehen. 
<intxreftitleoff1 refid = "AGEAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lager verschmutzt, verschlissen und/oder defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rotor, Diode und/oder Stator defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
