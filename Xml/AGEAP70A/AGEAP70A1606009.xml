<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1606009" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung der Thermostatbaugruppe (mit integriertem ECT-Sensor)
</title>
<list1 type = "unordered">
<item>
<ptxt>
Sicherstellen, dass das Entlüftungsventil (1) des Thermostats sauber ist.
</ptxt>
</item>
<item>
<ptxt>
Sicherstellen, dass der Ventilsitz (2) frei von Fremdkörpern ist, die den passgenauen Sitz des Ventils verhindern würden.
</ptxt>
<figure>
<graphic graphicname = "I7V20A161006.swf" width = "88.000mm" height = "51.019mm" ver = "01" gw = "123" gh = "128"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Wachsdehnelement
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
<item>
<ptxt>
Die Thermostatbaugruppe wie folgt überprüfen.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Die Thermostat-Baugruppe (1) in Wasser eintauchen und das Wasser nach und nach erhitzen.
</ptxt>
<attention2>
<ptxt>
Niemals den Steckverbinder des ECT-Sensors in Wasser eintauchen.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Prüfen, ob sich das Wachsdehnelement bei der vorgegebenen Temperatur zu öffnen beginnt.
</ptxt>
<spec>
<title>
Temperatur, bei der sich das Ventil zu öffnen beginnt (Hub 0,05 mm (0,002 in)): 
</title>
<ptxt>
86,5 – 89,5 &#176;C (187,7 – 193,1 &#176;F)
</ptxt>
</spec>
<spec>
<title>
Temperatur, bei der sich das Ventil vollständig öffnet: 
</title>
<ptxt>
100 &#176;C (212 &#176;F)
</ptxt>
</spec>
<spec>
<title>
Ventilhub: 
</title>
<ptxt>
Mehr als 8 mm (0,3 in) bei 100 &#176;C (212 &#176;F)
</ptxt>
</spec>
<figure page = "2">
<graphic graphicname = "I7V20A161007.swf" width = "88.000mm" height = "49.148mm" ver = "01" gw = "103" gh = "123"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.291in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.328in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.265in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Heizung
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Thermometer
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list2>
<item>
<ptxt>
Falls das Prüfresultat nicht zufriedenstellend ist, die Thermostatbaugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1606008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
