<servinfosub id = "AGEAP70AA204010002">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA204010003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA204010004">
<testgroup id = "AGEAP70AA204010005">
<title>
DTCs erneut abrufen
</title>
<test1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</test1>
<test1>
<ptxt>
Das Minuskabel (–) an die Batterie anklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
<intxref refid = "AGEAP70AA204010002">Überprüfung von Diagnosecodes</intxref>
 durchführen, und dann DTCs erneut überprüfen.
</ptxt>
</test1>
<question>
Wird DTC B1120 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
BCM austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende.
</ptxt>
</action>
</testgroup>
</diag>
