<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9D">
<servcat sctnbr = "09" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9406003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Windschutzscheibenwischermotors
</title>
<servinfosub id = "AGEAP70A9406003001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Wischerwellenkappen (1) abziehen, Wischerarmmuttern (2) abschrauben und Scheibenwischerarme (3) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Obere Wasserkastenzierblende (4) ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<figure>
<graphic graphicname = "I9P60A940005.jpg" width = "88.000mm" height = "62.898mm" ver = "01" gw = "198" gh = "162"/>
</figure>
</s1>
<s1>
<ptxt>
Den Steckverbinder des Windschutzscheibenwischermotors (3) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben des Wischermotors (1) lösen und den Windschutzscheibenwischermotor (2) in Pfeilrichtung entfernen wie in der Abbildung gezeigt.
</ptxt>
<figure>
<graphic graphicname = "I9P60A940006.jpg" width = "88.000mm" height = "41.842mm" ver = "01" gw = "217" gh = "102"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9406003002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9406004">Funktionsprüfung des Windschutzscheibenwischermotors</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Schrauben des Wischermotors in numerischer Reihenfolge (&#34;1&#34; bis &#34;2&#34;) mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T9D002">
<t-part>
Schraube des Wischermotors
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,3
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A940007.jpg" width = "88.000mm" height = "41.842mm" ver = "02" gw = "217" gh = "102"/>
</figure>
<list1 type = "unordered">
<item>
<ptxt>
Die Scheibenwischerarme (1) in den in der Abbildung gezeigten Positionen installieren.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Rechte Seite [A]
</ptxt>
<ptxt>
Die Spitze des Scheibenwischerblatts (5) mit der Einstellmarkierung (4) ausrichten.
</ptxt>
</item>
<item>
<ptxt>
Linke Seite [B]
</ptxt>
<ptxt>
Das Wischerblatt mit dem Keramikmantel (3) ausrichten.
</ptxt>
</item>
</list2>
<item>
<ptxt>
Die Muttern der Wischerarme mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T9D003">
<t-part>
Wischerarmmutter
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1,6
</t-value2>
<t-value3>
12,0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A940009.swf" width = "88.000mm" height = "77.752mm" ver = "02" gw = "189" gh = "204"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.277in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.708in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Wischerwellenkappe
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
