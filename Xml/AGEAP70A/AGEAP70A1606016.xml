<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1606016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Kühlmittelpumpe
</title>
<servinfosub id = "AGEAP70A1606016001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Kühlmittel ablassen. 
<intxreftitleoff1 refid = "AGEAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Antriebsriemen für Kühlmittelpumpe/Generator austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Riemenscheibe der Kühlmittelpumpe (2) ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Kühlmittelpumpenbaugruppe (1) samt Generatorhalterung (3) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I7V20A161014.swf" width = "88.000mm" height = "66.198mm" ver = "01" gw = "211" gh = "171"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AGEAP70A1606016002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1606017">Überprüfung der Kühlmittelpumpe</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Die Anlagefläche der Kühlmittelpumpe mit Dichtmittel bestreichen (siehe Abbildung).
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1F001" uid = "41">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Dichtmittel
</m-desc>
<m-number>
99000-31250
</m-number>
<m-name>
SUZUKI Bond Nr.1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I7V20A161015.swf" width = "88.000mm" height = "43.075mm" ver = "01" gw = "184" gh = "106"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.309in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.250in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.387in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
3 mm (0,12 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;b&#34;: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
2 mm (0,08 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Die Kühlmittelpumpen-Baugruppe (1) samt Generatorhalterung (3) am Zylinderblock montieren und die Schrauben und Muttern mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<attention3>
<ptxt>
Für das Einbauverfahren der Generatorhalterung (3) siehe 
<intxref refid = "AGEAP70A1A06006">Aus- und Einbau der Generatorhalterung</intxref>
.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1F003">
<t-part>
Schraube und Mutter der Kühlmittelpumpe
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2,5
</t-value2>
<t-value3>
18,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Die Riemenscheibe der Kühlmittelpumpe (2) einbauen und die Schrauben mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T1F004">
<t-part>
Schraube der Kühlmittelpumpen-Riemenscheibe
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A161016.swf" width = "88.000mm" height = "66.198mm" ver = "02" gw = "211" gh = "171"/>
</figure>
</s1>
<s1>
<ptxt>
Den Antriebsriemen für Kühlmittelpumpe/Generator einbauen. 
<intxreftitleoff1 refid = "AGEAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Minuskabel (–) an die Batterie anklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Kühlsystem mit Kühlmittel befüllen. 
<intxreftitleoff1 refid = "AGEAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Kühlsystem auf Undichtigkeiten prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
