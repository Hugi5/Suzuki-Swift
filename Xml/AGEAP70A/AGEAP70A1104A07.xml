<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Überhitzung des Motors
</title>
<ptxt>
Fehlersuche gemäß folgenden Anweisungen durchführen, wenn das ECM keine DTCs erfasst und bei 
<intxref refid = "AGEAP70A1104008">Sichtprüfung</intxref>
 und 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
 keine Mängel festgestellt werden.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Überhitzung des Motors
</ptxt>
</condition>
<ps>
<ptxt>
Thermostat defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1606009">Überprüfung der Thermostatbaugruppe (mit integriertem ECT-Sensor)</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Leistung der Kühlmittelpumpe mangelhaft
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1606017">Überprüfung der Kühlmittelpumpe</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kühler verstopft oder undicht
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1606014">Überprüfung und Reinigung des Kühlers am Fahrzeug</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Ungeeignete Motorölklasse
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A0206004">Motoröl- und Ölfilterwechsel</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Ölfilter oder Ölsieb verstopft
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1504001">Öldruckprüfung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Ölpumpenleistung mangelhaft
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1504001">Öldruckprüfung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kühlerlüftersteuerung defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1604002">Überprüfung des Kühlerlüftersystems</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Bremsen schleifen
</ptxt>
</ps>
<action>
<ptxt>
Symptom &#34;Bremsen schleifen&#34; in 
<intxref refid = "AGEAP70A4104001">Symptomdiagnose für Bremsanlage</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kupplung rutscht
</ptxt>
</ps>
<action>
<ptxt>
Symptom &#34;Kupplungsschlupf&#34; in 
<intxref refid = "AGEAP70A5304001">Symptomdiagnose für Kupplungssystem</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Zylinderkopfdichtung durchgebrannt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406029">Überprüfung des Zylinderkopfs</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Luft im Kühlsystem
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1606006">Auffüllen des Kühlsystems</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
