<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3116008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau von Vorderradnabe, Achsschenkel und Radlager
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A3116006">Bauteile der Vorderradnabe und des Achsschenkels:Vorn</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Beim Aus- und Einbau der Achsschenkel-Baugruppe keinesfalls die Staubabdeckung des Querlenker-Kugelgelenks an der Vorderradbremse beschädigen.
</ptxt>
</attention2>
<servinfosub id = "AGEAP70A3116008001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Fahrzeug aufbocken und das Vorderrad abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Antriebswellenmutter abschrauben. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Bremsscheibe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Radnabe (1) mit dem Spezialwerkzeug abziehen.
</ptxt>
<attention3>
<ptxt>
Die Außenseite des Radlager-Innenlaufrings kommt zusammen mit der Radnabe heraus.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3A103">
<s-part>
(A)
</s-part>
<s-number num = "09943-17912">
09943-17912
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A104">
<s-part>
(B)
</s-part>
<s-number num = "09942-15511">
09942-15511
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311016.swf" width = "88.000mm" height = "57.642mm" ver = "01" gw = "181" gh = "147"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Spurstangenkopf vom Achsschenkel trennen. 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Vorderrad-Drehzahlsensor vom Achsschenkel abmontieren. 
<intxreftitleoff1 refid = "AGEAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Muttern und Schrauben der Federbeinhalterung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Querlenker-Kugelgelenk vom Achsschenkel trennen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Achsschenkel von der Antriebswelle trennen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Verstemmung (1) an den 4 Stellen mit einem Meißel o. Ä. lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Staubabdeckung (2) der Vorderradbremse entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311015.swf" width = "88.000mm" height = "63.961mm" ver = "01" gw = "187" gh = "165"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Den Sicherungsring (1) vom Achsschenkel entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<s1>
<ptxt>
Das Radlager mit dem Spezialwerkzeug und einer Hydraulikpresse (1) heraustreiben.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A105">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913-75810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A106">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A311017.swf" width = "88.000mm" height = "46.725mm" ver = "01" gw = "99" gh = "116"/>
</figure>
</s1>
<s1>
<ptxt>
Den äußeren Radlager-Innenlaufring (1) mit einem Meißel o. ä. aufstemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Den äußeren Radlager-Innenlaufring (1) mit dem Spezialwerkzeug wie in der Abbildung gezeigt von der Radnabe trennen.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A107">
<s-part>
(A)
</s-part>
<s-number num = "09913-65810">
09913-65810
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A108">
<s-part>
(B)
</s-part>
<s-number num = "09926-37610-003">
09926-37610-003
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311020.swf" width = "88.000mm" height = "78.517mm" ver = "01" gw = "104" gh = "206"/>
</figure>
</s1>
<s1>
<ptxt>
Die Radbolzen (1) ggf. mit einer Hydraulikpresse oder einem Kupferhammer heraustreiben.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A220020.swf" width = "88.000mm" height = "51.000mm" ver = "01" gw = "166" gh = "128"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AGEAP70A3116008002">
<title>
Einbau
</title>
<s1>
<ptxt>
Neuen Radbolzen (1) in die Radnabenbohrung einsetzen. Den Radbolzen langsam drehen, um seine Zahnung an die von der Originalschraube in der Bohrung hinterlassene Zahnung einzupassen, wenn diese entfernt wurde.
</ptxt>
<figure>
<graphic graphicname = "I2RH01220040.swf" width = "88.000mm" height = "47.317mm" ver = "01" gw = "142" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Ein neues Radlager (1) wie abgebildet mit der braunen Gummidichtungsseite (3) nach unten auf dem Achsschenkel (2) anbringen.
</ptxt>
</s1>
<s1>
<ptxt>
Radlager gemäß Abbildung mit Spezialwerkzeugen mit dem Achsschenkel (2) verpressen.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A109">
<s-part>
(A)
</s-part>
<s-number num = "09913-75510">
09913-75510
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A110">
<s-part>
(B)
</s-part>
<s-number num = "09926-68310">
09926-68310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A111">
<s-part>
(C)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311022.swf" width = "88.000mm" height = "71.587mm" ver = "01" gw = "232" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Neuen Sicherungsring (1) einsetzen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311016.swf" width = "88.000mm" height = "59.096mm" ver = "02" gw = "119" gh = "151"/>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Neue Staubabdeckung an der vorgeschriebenen Position am Achsschenkel anbringen, wie in der Abbildung dargestellt.
</ptxt>
<attention2>
<ptxt>
Darauf achten, dass die Staubabdeckung beim Einpressen nicht verformt wird.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Die Staubabdeckung (2) der Vorderradbremse mit einer Hydraulikpresse (1) und den Spezialwerkzeugen in den Achsschenkel einpressen.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A112">
<s-part>
(A)
</s-part>
<s-number num = "09951-17010">
09951-17010
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3A113">
<s-part>
(B)
</s-part>
<s-number num = "09944-77030">
09944-77030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311018.swf" width = "88.000mm" height = "55.099mm" ver = "01" gw = "203" gh = "140"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.135in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.595in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;a&#34;: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
13&#176;
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
&#34;b&#34;: 
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
70 mm (2,8 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Mehr als 4 Stellen mit einem kleinen Kaltmeißel verstemmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A311020.swf" width = "88.000mm" height = "52.911mm" ver = "01" gw = "186" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Verstemmen
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Die Radnabe (1) mit dem Spezialwerkzeug und einer Hydraulikpresse in das Radlager (2) hineinpressen.
</ptxt>
<servicetool>
<servicetoolitem id = "L3A114">
<s-part>
(A)
</s-part>
<s-number num = "09913-75810">
09913-75810
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3A115">
<s-part>
(B)
</s-part>
<s-number num = "09951-18211">
09951-18211
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A311017.swf" width = "88.000mm" height = "57.910mm" ver = "01" gw = "203" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Die Antriebswelle mit dem Achsschenkel verbinden. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Achsschenkel an den Querlenker anbringen. 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben und Muttern der Federbeinhalterung montieren. 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Vorderrad-Drehzahlsensor montieren. 
<intxreftitleoff1 refid = "AGEAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Spurstangenkopf am Achsschenkel montieren. 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Bremsscheibe und den Bremssattel einbauen. 
<intxreftitleoff1 refid = "AGEAP70A4206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Antriebswellenmutter mit dem vorgeschriebenen Drehmoment festziehen und die Mutter der Antriebswelle verstemmen. 
<intxreftitleoff1 refid = "AGEAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Unbedingt eine neue Antriebswellenmutter verwenden.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Vorderrad montieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Vorderradspur bestätigen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
