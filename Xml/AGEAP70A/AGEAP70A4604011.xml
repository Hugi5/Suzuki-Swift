<servinfosub id = "AGEAP70A4604011002">
<title>
Schaltkreisbeschreibung
</title>
<ptxt>
Siehe &#34;Schaltkreisbeschreibung&#34; unter 
<intxref refid = "AGEAP70A4604010">ESP&#174;-Warnleuchte leuchtet nicht, nachdem Zündung auf &#34;ON&#34; gestellt ist</intxref>
.
</ptxt>
</servinfosub>
<servinfosub id = "AGEAP70A4604011003">
<title>
Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604011004">
<testgroup id = "AGEAP70A4604011005">
<title>
Überprüfung des ESP&#174;-Steuermodul-Steckverbinders
</title>
<test1>
<ptxt>
Auf einwandfreie Verbindung zum ESP<sup>&#174;</sup>-Steuermodul-Steckverbinder prüfen.
</ptxt>
</test1>
<question>
Ist die Verbindung in einem einwandfreien Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Steckverbinder fest anklemmen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604011006">
<title>
Abruf von ESP&#174;-bezogenen DTCs
</title>
<test1>
<ptxt>
<intxref refid = "AGEAP70A4604005">DTC-Überprüfung</intxref>
 durchführen.
</ptxt>
</test1>
<question>
Liegen DTCs vor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604011007">
<title>
Überprüfung von Stromversorgungs- und Masseschaltkreis des ESP&#174;-Steuermoduls
</title>
<test1>
<ptxt>
Den Stromversorgungs- und den Masseschaltkreis des ESP<sup>&#174;</sup>-Steuermoduls überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4604042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Sind die Schaltkreise in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekten Kabelbaum reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604011008">
<title>
Prüfung des Kombiinstruments
</title>
<test1>
<ptxt>
Das Kombiinstrument austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<question>
Bleibt die Warnleuchte eingeschaltet?
</question>
<result type = "yes"/>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit / Steuermodul austauschen und Aufleuchten der Warnleuchte erneut prüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende.
</ptxt>
</action>
</testgroup>
