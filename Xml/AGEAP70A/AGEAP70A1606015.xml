<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1606015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Kühlers
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1606014">Überprüfung und Reinigung des Kühlers am Fahrzeug</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1606015001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Kühlerlüfter-Baugruppe entfernen. 
<intxreftitleoff1 refid = "AGEAP70A1606012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Die A/C-Kondensatorbaugruppe ausbauen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Modell mit manueller Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7216006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Modell mit automatischer Klimaanlage: 
<intxreftitleoff1 refid = "AGEAP70A7226006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Den Kühlerauslassschlauch vom Kühler abbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Die oberen Kühlerhalterungen (1) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Kühler (2) aus dem Fahrzeug ausbauen.
</ptxt>
<figure>
<graphic graphicname = "IAP70P160007.jpg" width = "88.000mm" height = "62.569mm" ver = "01" gw = "193" gh = "161"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1606015002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kühlsystem mit Kühlmittel befüllen. 
<intxreftitleoff1 refid = "AGEAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kühlsystem auf Undichtigkeiten prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
