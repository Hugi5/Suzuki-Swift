<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1306017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des CMP-Fühlers
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1306016">Überprüfung des Nockenwellensensors am Fahrzeug</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1306017001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder vom Einlass-Nockenwellensensor (1) und Auslass-Nockenwellensensor (2) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Einlass-Nockenwellensensor (1) und Auslass-Nockenwellensensor (2) vom Zylinderkopf abbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A131006.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1306017002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1306018">Überprüfung des CMP-Fühlers</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den O-Ring des Sensors mit Motoröl bestreichen.
</ptxt>
</item>
<item>
<ptxt>
Die Schraube des Nockenwellensensors auf das vorgeschriebene Drehmoment anziehen.
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Unbedingt neue Schrauben mit Gewindekleber-Vorbeschichtung verwenden. Anderenfalls könnten sich die Schrauben lockern.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1C005">
<t-part>
Schraube des Einlass-Nockenwellensensors
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
<torqueitem id = "T1C006">
<t-part>
Schraube des Auslass-Nockenwellensensors
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1,1
</t-value2>
<t-value3>
8,5
</t-value3>
</torqueitem>
</torque>
