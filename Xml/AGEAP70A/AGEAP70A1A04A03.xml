<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1A04A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Batterie nicht ausreichend geladen
</title>
<ptxt>
Fehler im Ladesystem werden durch eines oder mehrere der folgenden Symptome angezeigt: 
</ptxt>
<servinfosub id = "AGEAP70A1A04002003">
<title>
Batterieladefehler
</title>
<diag type = "condition">
<condition>
<ptxt>
Batterie nicht ausreichend geladen
</ptxt>
</condition>
<ps>
<ptxt>
Lockerer oder abgenutzter Antriebsriemen
</ptxt>
</ps>
<action>
<ptxt>
Den Antriebsriemen einstellen oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Batteriepolklemme locker oder korrodiert
</ptxt>
</ps>
<action>
<ptxt>
Batteriepolklemme anziehen oder Batterie austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gleichrichter, Rotor und/oder IC-Regler defekt
</ptxt>
</ps>
<action>
<ptxt>
Generator reparieren oder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
