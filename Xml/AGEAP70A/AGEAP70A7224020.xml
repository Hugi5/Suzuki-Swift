<diag type = "test" id = "AGEAP70A7224020007">
<testgroup id = "AGEAP70A7224020008">
<title>
Überprüfung der Diagnosegerät-Parameter
</title>
<test1>
<ptxt>
Den Parameter &#34;LUFTMISCHPOSSENSOR&#34; über den Modus &#34;Datenliste&#34; mit dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Zeitweilige Störung.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224020009">
<title>
Überprüfung des Schaltkreises des Stellglieds für Temperaturregelung
</title>
<test1>
<ptxt>
Den Steckverbinder &#34;G20&#34; und den Steckverbinder des Stellglieds für Temperaturregelung abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Folgende Punkte überprüfen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand der Schaltkreise &#34;GRY&#34; und &#34;LT BLU&#34;: weniger als 1 &#937;
</ptxt>
</item>
<item>
<ptxt>
Widerstand in den Schaltkreisen der Kabel &#34;GRY&#34; und &#34;LT BLU&#34; zwischen dem Stellglied für Temperaturregelung und Masse: unendlich
</ptxt>
</item>
</list1>
</test1>
<question>
Entsprechen die Werte des Widerstands den Vorgaben?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224020010">
<title>
Überprüfung des Stellglieds für Temperaturregelung
</title>
<test1>
<ptxt>
Stellglied für Temperaturregelung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Stellglied in Ordnung?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das HVAC-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Stellglied für Temperaturregelung austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
