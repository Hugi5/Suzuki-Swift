<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7214A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Wenn der Kompressor läuft, sind Klappergeräusche zu hören.
</title>
<servinfosub id = "AGEAP70A7214004003">
<title>
Abnormale Geräusche von der Magnetkupplung
</title>
<diag type = "condition">
<condition>
<ptxt>
Wenn der Kompressor läuft, sind Klappergeräusche zu hören.
</ptxt>
</condition>
<ps>
<ptxt>
Magnetkupplungsspiel fehlerhaft (übermäßiges Spiel)
</ptxt>
</ps>
<action>
<ptxt>
Magnetkupplungsspiel einstellen. 
<intxreftitleoff1 refid = "AGEAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Reibfläche der Magnetkupplung verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Magnetkupplungs-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kompressoröl ist an der Wellendichtung ausgetreten und hat die Reibfläche verschmutzt
</ptxt>
</ps>
<action>
<ptxt>
Kompressorgehäuse-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
