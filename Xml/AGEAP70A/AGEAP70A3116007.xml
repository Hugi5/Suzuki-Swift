<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A3116007" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung der Vorderradlager
</title>
<s1>
<ptxt>
Radmutter auf festen Sitz überprüfen und ggf. mit dem vorgeschriebenen Drehmoment festziehen. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Fahrzeug aufbocken.
</ptxt>
</s1>
<s1>
<ptxt>
Radlager auf Verschleiß überprüfen. Zum Messen des Druckspiels einen Feinzeiger, wie in der Abbildung gezeigt, an das Vorderrad ansetzen.
</ptxt>
<ptxt>
Das Lager austauschen, falls die Vorgaben nicht erfüllt werden.
</ptxt>
<spec-sdm>
<sdm-title>
Druckspiel des Vorderradlagers
</sdm-title>
<sdm1>
<sdm-condition>
Grenzwert
</sdm-condition>
<sdm-value>
0,1 mm (0,004 in.)
</sdm-value>
</sdm1>
</spec-sdm>
<figure>
<graphic graphicname = "I3RM0A230049.swf" width = "88.000mm" height = "55.572mm" ver = "01" gw = "194" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Das Rad drehen und das Radlager auf Geräusche und Leichtgängigkeit überprüfen.
</ptxt>
<ptxt>
Bei Defekten das Radlager austauschen.
</ptxt>
<figure>
<graphic graphicname = "I3RM0A230050.swf" width = "88.000mm" height = "52.948mm" ver = "01" gw = "162" gh = "133"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
