<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A5206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Einstellung des Wählzugs
</title>
<s1>
<ptxt>
Die Sicherungsblech (1) lösen, die den Seilzugende-Halter (2) arretiert.
</ptxt>
</s1>
<s1>
<ptxt>
Mit einem geeigneten Werkzeug (3) den Seilzugende-Halter (2) aus dem Einsteller (4) herausdrücken, um den Zug zu lösen.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A520004.swf" width = "88.000mm" height = "100.361mm" ver = "01" gw = "193" gh = "267"/>
</figure>
</s1>
<s1>
<ptxt>
Den Drehzapfen (5) des Gangschalthebels mit Fett bestreichen und dann den Einsteller (1) fest in den Drehzapfen des Gangschalthebels einführen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B005" uid = "1126491901">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Den Seilzugende-Halter (2) in Richtung [a] drücken.
</ptxt>
<attention3>
<ptxt>
Keine Gewalt auf den Einsteller in Seilzugrichtung [b] ausüben.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Das Sicherungsblech (3) in Richtung [c] schieben, bis es über der Klaue (4) des Seilzugende-Halters sitzt.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520039.swf" width = "88.000mm" height = "119.028mm" ver = "01" gw = "162" gh = "321"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
