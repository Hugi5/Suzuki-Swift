<title>
Aus- und Einbau des Luftfilters
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1406001">Komponenten des Luftfilters</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1406002001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Klemmen (2) lösen und das Luftfiltergehäuse (1) öffnen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141018.jpg" width = "88.000mm" height = "57.642mm" ver = "01" gw = "199" gh = "147"/>
</figure>
</s1>
<s1>
<ptxt>
Den Luftfilter aus dem Gehäuse entfernen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1406002002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1406003">Überprüfung und Reinigung des Luftfilters</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
