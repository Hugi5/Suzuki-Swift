<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70AA316001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Wegfahrsperren-Steuermoduls
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Da das Wegfahrsperren-Steuermodul aus Präzisionsteilen besteht, darf es keinen starken Erschütterungen ausgesetzt werden.
</ptxt>
</item>
<item>
<ptxt>
Das Wegfahrsperren-Steuermodul nicht zerlegen.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AGEAP70AA316001001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Die untere und obere Lenksäulenabdeckung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A6206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Den Steckverbinder (1) vom Wegfahrsperren-Steuermodul (2) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schraube (3) am Wegfahrsperren-Steuermodul herausdrehen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Wegfahrsperren-Steuermodul aus der Lenkschloss-Baugruppe entfernen, wie in der Abbildung gezeigt.
</ptxt>
<figure>
<graphic graphicname = "I9P60AA31004.jpg" width = "88.000mm" height = "60.854mm" ver = "01" gw = "197" gh = "156"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA316001002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
