<servinfosub id = "AGEAP70A1104046004">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A1104046005">
<testgroup id = "AGEAP70A1104046006">
<title>
DTCs erneut abrufen
</title>
<test1>
<ptxt>
DTC löschen. 
<intxreftitleoff1 refid = "AGEAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Überprüfung von Diagnosecodes durchführen und DTCs überprüfen.
</ptxt>
</test1>
<question>
Wird DTC P0607 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Auf zeitweilige Störung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
