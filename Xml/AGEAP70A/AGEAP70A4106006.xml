<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A4106006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Bremspedal-Baugruppe
</title>
<attention2>
<ptxt>
Niemals eine mit Bremspedal-Fußschutzsystem ausgestattete Bremspedal-Baugruppe zerlegen.
</ptxt>
<ptxt>
Ein Zerlegen beeinträchtigt die ursprüngliche Funktion. Falls ein Defekt gefunden wird, die gesamte Baugruppe austauschen.
</ptxt>
</attention2>
<servinfosub id = "AGEAP70A4106006001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Blende für Kombiinstrument entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Abdeckung für die Lenksäulenöffnung entfernen. 
<intxreftitleoff1 refid = "AGEAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Bremslichtschalter überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die untere Lenkwelle entfernen. 
<intxreftitleoff1 refid = "AGEAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Klammer, den Gabelkopfbolzen und die Muttern des Bremskraftverstärkers entfernen. 
<intxreftitleoff1 refid = "AGEAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Mutter der Bremspedalhalterung (1) und die Schraube der oberen Armaturenbrettversteifung (2) entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A410005.swf" width = "88.000mm" height = "64.414mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Bremspedal-Baugruppe ausbauen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A4106006002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4106022">Aus- und Einbau des Bremskraftverstärkers</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Die Bremspedal-Baugruppe und den Bremskraftverstärker einbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Muttern des Bremskraftverstärkers mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T4A001">
<t-part>
Mutter des Bremskraftverstärkers*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410009.swf" width = "88.000mm" height = "63.332mm" ver = "01" gw = "190" gh = "163"/>
</figure>
</s1>
<s1>
<ptxt>
Die Mutter der Bremspedalhalterung mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T4A002">
<t-part>
Mutter der Bremspedalhalterung*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Die Schraube der oberen Armaturenbrettversteifung mit dem vorgeschriebenen Drehmoment festziehen.
</ptxt>
<torque>
<torqueitem id = "T4A003">
<t-part>
Schraube der oberen Armaturenbrettversteifung
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1,3
</t-value2>
<t-value3>
9,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A410010.swf" width = "88.000mm" height = "64.412mm" ver = "01" gw = "190" gh = "166"/>
</figure>
</s1>
<s1>
<ptxt>
Klammer und Gabelkopf anbringen. 
<intxreftitleoff1 refid = "AGEAP70A4106022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die untere Lenkwelle einbauen. 
<intxreftitleoff1 refid = "AGEAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Bremssystem entlüften. 
<intxreftitleoff1 refid = "AGEAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Höhe und Spiel des Bremspedals überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Bremspedalhöhe: 
<intxreftitleoff1 refid = "AGEAP70A4106007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bremspedalspiel: 
<intxreftitleoff1 refid = "AGEAP70A4106008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Den Bremslichtschalter einbauen. 
<intxreftitleoff1 refid = "AGEAP70A4106010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Alle Anschlüsse auf Flüssigkeitsleckage prüfen und sicherstellen, dass das Bremssystem einwandfrei funktioniert.
</ptxt>
</s1>
<s1>
<ptxt>
Die Abdeckung für die Lenksäulenöffnung einbauen. 
<intxreftitleoff1 refid = "AGEAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Blende des Kombiinstruments einbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
