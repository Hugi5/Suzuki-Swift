<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1A06002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Batterie
</title>
<servinfosub id = "AGEAP70A1A06002001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) (1) von der Batterie (4) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Pluskabel (+) (2) von der Batterie (4) abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Halter (3) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Batterie (4) entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0001.swf" width = "88.000mm" height = "71.286mm" ver = "01" gw = "171" gh = "186"/>
</figure>
</s1>
<s1>
<ptxt>
Das Batteriefach (1) ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
ECM (2) ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Nötigenfalls die Batteriehalterung (3) entfernen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A1A0002.jpg" width = "88.000mm" height = "55.738mm" ver = "02" gw = "199" gh = "141"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1A06002002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Batteriekabel fest anziehen.
</ptxt>
</item>
<item>
<ptxt>
Bei Bedarf elektrische Geräte initialisieren.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
