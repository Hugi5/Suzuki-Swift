<servinfo servinfosgmlid = "AGEAP70A1306009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des MAP-Sensors
</title>
<servinfosub id = "AGEAP70A1306009001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Steckverbinder vom MAP-Sensor abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Den MAP-Sensor (1) vom Ansaugkrümmer (2) abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A131003.jpg" width = "88.000mm" height = "51.551mm" ver = "01" gw = "185" gh = "130"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1306009002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1306010">Überprüfung des MAP-Sensors</intxrefpoff>
</ptxt>
<ptxt>
Zum Einbau den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sicherstellen, dass der O-Ring unbeschädigt ist.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
