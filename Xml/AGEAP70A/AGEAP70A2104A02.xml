<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A2104A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Übermäßiger Reifenverschleiß
</title>
<diag type = "condition">
<condition>
<ptxt>
Übermäßiger Reifenverschleiß
</ptxt>
</condition>
<ps>
<ptxt>
Gebrochene oder ermüdete Schraubenfedern
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Schraubenfedern austauschen.
</ptxt>
<ptxt>
Vorne: 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Hinten: 
<intxreftitleoff1 refid = "AGEAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Radunwucht
</ptxt>
</ps>
<action>
<ptxt>
Reifen auswuchten oder ersetzen.
</ptxt>
</action>
<ps>
<ptxt>
Radspur falsch eingestellt
</ptxt>
</ps>
<action>
<ptxt>
Radspur überprüfen und einstellen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vordere Federbeinbaugruppe (Stoßdämpfer) defekt
</ptxt>
</ps>
<action>
<ptxt>
Vordere Federbeinbaugruppe (Stoßdämpfer) austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Extreme Fahrbedingungen
</ptxt>
</ps>
<action>
<ptxt>
Reifen ersetzen. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Überladung des Fahrzeugs
</ptxt>
</ps>
<action>
<ptxt>
Zuladung überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Unterlassenes Umsetzen von Rädern
</ptxt>
</ps>
<action>
<ptxt>
Reifen ersetzen oder umsetzen.
</ptxt>
</action>
<ps>
<ptxt>
Radlager verschlissen oder locker
</ptxt>
</ps>
<action>
<ptxt>
Radlager austauschen. 
<intxreftitleoff1 refid = "AGEAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rad- oder Reifenflattern
</ptxt>
</ps>
<action>
<ptxt>
Rad bzw. Reifen ersetzen.
</ptxt>
</action>
<ps>
<ptxt>
Reifendruck nicht korrekt
</ptxt>
</ps>
<action>
<ptxt>
Den Reifendruck entsprechend korrigieren.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
