</servinfosub>
<servinfosub id = "AGEAP70AA204012004">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA204012005">
<testgroup id = "AGEAP70AA204012008">
<title>
Überprüfung der Parameter
</title>
<test1>
<ptxt>
Bei ausgeschalteter Zündung das SUZUKI-Diagnosegerät an den DLC anschließen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Anzeige &#34;Sensor für automatische Lichtsteuerung&#34; auf dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ende. (Zeitweilige Störung)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204012006">
<title>
Überprüfung des Scheinwerfersensor-Stromversorgungskreises
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder für Scheinwerfersensor und &#34;G05&#34; lösen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreien Klemmenanschluss zu den Steckverbindern des Scheinwerfersensors und &#34;G05&#34; überprüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn die Anschlüsse in Ordnung sind, folgende Punkte überprüfen.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Widerstand zwischen Schaltkreis &#34;A1&#34; und Masse: unendlich
</ptxt>
</item>
<item>
<ptxt>
Widerstand zwischen den Anschlussklemmen &#34;A1&#34; und &#34;A3&#34; am Steckverbinder des Scheinwerfersensors: unendlich
</ptxt>
</item>
</list1>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekten Kabelbaum reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204012007">
<title>
Überprüfung des Scheinwerfersensors
</title>
<test1>
<ptxt>
Scheinwerfersensor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Scheinwerfersensor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204012009">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder für Scheinwerfersensor und &#34;G05&#34; einstecken.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird der aktuelle DTC B1132 erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
BCM austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende. (Zeitweilige Störung)
</ptxt>
</action>
</testgroup>
</diag>
