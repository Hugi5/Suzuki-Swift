<servinfosub id = "AGEAP70A9304006003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A9304006004">
<testgroup id = "AGEAP70A9304006005">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTC löschen. 
<intxreftitleoff1 refid = "AGEAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird DTC B1810 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Auf zeitweilige Störung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A9304006006">
<title>
Überprüfung des Kraftstoffstandsensors
</title>
<test1>
<ptxt>
Den Kraftstoffstandsensor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1706018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Kraftstoffstandsensor austauschen und DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A1706017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AGEAP70A9304006007">
<title>
Überprüfung des Kraftstoffstandsensorschaltkreises
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Steckverbinder des Kombiinstruments und des Kraftstoffstandsensors abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreie Verbindung zu den Anschlussklemmen von Kombiinstrument und Kraftstoffstandsensor überprüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn die Verbindungen in Ordnung sind, den Schaltkreis zwischen Steckverbinder des Kombiinstruments und Kraftstoffstandsensor auf Unterbrechung, Masseschluss oder Kurzschluss gegen Stromversorgung überprüfen.
</ptxt>
</test1>
<question>
Sind sie in einwandfreiem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das Kombiinstrument austauschen und erneut DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekten Kabelbaum reparieren und DTCs erneut abrufen.
</ptxt>
</action>
</testgroup>
</diag>
