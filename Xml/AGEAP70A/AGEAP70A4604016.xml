<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A4604016" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1015/C1017/C1023
</title>
<servinfosub id = "AGEAP70A4604016001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.257in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.924in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
C1015: Störung des Längsbeschleunigungssensors in der Gierraten-/G-Sensor-Baugruppe 
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Signal des Längsbeschleunigungssensors außerhalb des Sollbereichs.
</ptxt>
</item>
<item>
<ptxt>
Signal des Längsbeschleunigungssensors ändert sich nicht, obwohl das Fahrzeug beschleunigt oder verzögert.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ESP<sup>&#174;</sup>-Steuermodul
</ptxt>
</item>
<item>
<ptxt>
Stellgliedhalterung
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1017: Schaltkreisleistung des Querbeschleunigungssensors
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Signal des Querbeschleunigungssensors ist außerhalb des Sollbereichs.
</ptxt>
</item>
<item>
<ptxt>
Signal des Querbeschleunigungssensors ändert sich nicht, obwohl Fahrzeug nach rechts oder links gelenkt wird.
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1023: Schaltkreisleistung Gierratensensor
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Das Signal des Gierratensensors liegt nicht im Sollbereich.
</ptxt>
</item>
<item>
<ptxt>
Obwohl das Fahrzeug angehalten wurde, liegt das Signal des Gierratensensors über dem Sollwert.
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70A4604016002">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604016003">
<testgroup id = "AGEAP70A4604016004">
<question>
Wurde die &#34;ESP<sup>&#174;</sup>-Systemprüfung&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A4604001">ESP&#174;-Systemprüfung</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604016006">
<title>
ESP&#174;-Steuermodul und Stellgliedhalterung überprüfen
</title>
<test1>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit-/Steuermodul und Stellgliedhalterung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Defekte Bauteile reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604016005">
<title>
Abruf von ESP&#174;-bezogenen DTC
</title>
<test1>
<ptxt>
<intxref refid = "AGEAP70A4604005">DTC-Überprüfung</intxref>
 durchführen.
</ptxt>
</test1>
<question>
Liegen andere DTCs als C1015, C1017 und C1023 vor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul-Baugruppe austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
