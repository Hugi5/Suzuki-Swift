<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104A14" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Mangelhafter Motorleistung
</title>
<ptxt>
Fehlersuche gemäß folgenden Anweisungen durchführen, wenn das ECM keine DTCs erfasst und bei 
<intxref refid = "AGEAP70A1104008">Sichtprüfung</intxref>
 und 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
 keine Mängel festgestellt werden.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Mangelhafter Motorleistung
</ptxt>
</condition>
<ps>
<ptxt>
Zündkerze defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1806002">Überprüfung der Zündkerzen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defekte Zündspule mit Zünder
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1806004">Überprüfung der Zündspulen-Baugruppe</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Klopfsensor defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306021">Überprüfung des Klopfsensors am Fahrzeug</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kraftstoffschlauch oder -leitungen verstopft
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1704005">Überprüfung des Kraftstoffdrucks</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kraftstoffpumpe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1704004">Überprüfung der Kraftstoffpumpe und ihres Schaltkreises</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Ansaugen von Nebenluft durch Ansaugkrümmerdichtung oder Dichtung des Drosselklappengehäuses
</ptxt>
</ps>
<action>
<ptxt>
Luftzufuhrsystem überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Überhitzung des Motors
</ptxt>
</ps>
<action>
<ptxt>
Symptom &#34;Überhitzung des Motors&#34;
</ptxt>
</action>
<ps>
<ptxt>
Leistung von ECT-Sensor oder MAF-Sensor mangelhaft
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306012">Überprüfung des ECT-Sensors</intxref>
 oder 
<intxref refid = "AGEAP70A1306026">Überprüfung des MAF- und IAT-Sensors</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Elektrische Drosselklappengehäuse-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306004">Überprüfung der elektrischen Drosselklappengehäuse-Baugruppe am Fahrzeug</intxref>
</ptxt>
</action>
<ps>
<ptxt>
APP-Sensorbaugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306008">Überprüfung des APP-Sensors</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Einspritzventil(e) defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1704003">Überprüfung des Einspritzventil-Schaltkreises</intxref>
 oder 
<intxref refid = "AGEAP70A1706009">Überprüfung des Einspritzventils</intxref>
</ptxt>
</action>
<ps>
<ptxt>
ECM defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1104070">Überprüfung von ECM und dessen Schaltkreisen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Bremsen schleifen
</ptxt>
</ps>
<action>
<ptxt>
Symptom &#34;Bremsen schleifen&#34; in 
<intxref refid = "AGEAP70A4104001">Symptomdiagnose für Bremsanlage</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kupplung rutscht
</ptxt>
</ps>
<action>
<ptxt>
Symptom &#34;Kupplungsschlupf&#34; in 
<intxref refid = "AGEAP70A5304001">Symptomdiagnose für Kupplungssystem</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kompression zu niedrig
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1404001">Kompressionsprüfung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nockenwellensteuerung (VVT-System) außer Betrieb
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306027">Überprüfung des OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
