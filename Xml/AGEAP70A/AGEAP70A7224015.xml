<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1503: Störung des Verdampfer-Temperatursensors und/oder dessen Schaltkreises
</emph>
</ptxt>
<ptxt>
HVAC-Steuermodul empfängt ununterbrochen ungültige Daten des Verdampfer-Temperatursensors vom BCM über die CAN-Kommunikationsleitung.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Verdampfer-Temperatursensor-Schaltkreis
</ptxt>
</item>
<item>
<ptxt>
Verdampfer-Temperatursensor
</ptxt>
</item>
<item>
<ptxt>
HVAC-Steuermodul
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1562: Störung des Außentemperatursensors und/oder dessen Schaltkreises
</emph>
</ptxt>
<ptxt>
HVAC-Steuermodul empfängt ununterbrochen ungültige Daten des Außentemperatursensors vom BCM über die CAN-Kommunikationsleitung.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
