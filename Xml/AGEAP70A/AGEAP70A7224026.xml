<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7224026" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1546
</title>
<servinfosub id = "AGEAP70A7224026001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.937in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.274in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1546: Störung beim A/C-Kältemitteldruck 
</emph>
</ptxt>
<ptxt>
A/C-Kältemitteldruck liegt unter dem Sollwert, obwohl Außentemperatur über dem Sollwert liegt.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Drucksensor für A/C-Kältemittel
</ptxt>
</item>
<item>
<ptxt>
Außentemperatursensor
</ptxt>
</item>
<item>
<ptxt>
Unzureichendes Kältemittel
</ptxt>
</item>
<item>
<ptxt>
HVAC-Steuermodul
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70A7224026002">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Den Motor anlassen und die Klimaanlage einschalten.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7224026003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A7224026004">
<testgroup id = "AGEAP70A7224026005">
<title>
Überprüfung des A/C-Kältemitteldrucks
</title>
<test1>
<ptxt>
Die Klimaanlage einschalten, damit der A/C-Kompressor anspringt.
</ptxt>
</test1>
<test1>
<ptxt>
Den Parameter &#34;Kältemitteldruck&#34; über den Modus &#34;Datenliste&#34; mit dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Liegt der Druck über 0,34 MPa?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Kältemittel einfüllen und DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224026006">
<title>
Überprüfung des Kältemitteldrucksensors der Klimaanlage (A/C)
</title>
<test1>
<ptxt>
Den Drucksensor für A/C-Kältemittel überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7226022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist der Sensor in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Drucksensor für A/C-Kältemittel austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7226023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224026007">
<title>
Überprüfung des Außentemperatursensors
</title>
<test1>
<ptxt>
Außenlufttemperatursensor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist der Sensor in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Außenlufttemperatursensor austauschen. 
<intxreftitleoff1 refid = "AGEAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224026008">
<title>
Überprüfung des A/C-Systems
</title>
<test1>
<ptxt>
A /C-System überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7224001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das System einwandfrei?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das HVAC-Steuermodul austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
<intxref refid = "AGEAP70A7224002">Störungsdiagnose bei abnormalem Druck:Automatiktyp</intxref>
 durchführen und erneut DTCs abrufen.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
