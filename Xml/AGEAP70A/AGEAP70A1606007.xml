<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1606007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Kühlwasserleitungen und -schläuche
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1606001">Bauteile des Kühlsystems</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AGEAP70A1606009">Überprüfung der Thermostatbaugruppe (mit integriertem ECT-Sensor)</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1606007001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Kühlmittel ablassen. 
<intxreftitleoff1 refid = "AGEAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Zum Entfernen der Kühlwasserleitungen oder -schläuche die jeweiligen Klemmen lösen und das Schlauchende abziehen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1606007002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Alle Klemmen in der vorgesehenen Richtung fest anziehen. 
<intxreftitleoff1 refid = "AGEAP70A1606001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kühlsystem mit Kühlmittel befüllen. 
<intxreftitleoff1 refid = "AGEAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kühlsystem auf Undichtigkeiten prüfen. 
<intxreftitleoff1 refid = "AGEAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
