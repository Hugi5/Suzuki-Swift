<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1406009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Ansaugkrümmers
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A1406005">Bauteile von Drosselklappengehäuse und Ansaugkrümmer</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A1406009001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Luftfilter-Baugruppe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Bei angeschlossenen Motorkühlmittelschläuchen die elektrische Drosselklappengehäuse-Baugruppe vom Ansaugkrümmer abnehmen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder (1) des MAP-Sensors abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Folgende Schläuche lösen: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Bremskraftverstärkerschlauch (2) vom Bremskraftverstärker
</ptxt>
</item>
<item>
<ptxt>
PCV-Schlauch (3) vom PCV-Ventil
</ptxt>
<figure>
<graphic graphicname = "I7V20A141039.swf" width = "88.000mm" height = "53.078mm" ver = "01" gw = "221" gh = "134"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Die Schraube der Einlassleitung für die Heizung (1) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141022.jpg" width = "88.000mm" height = "51.297mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Ansaugkrümmer (1) und dessen Dichtung entfernen.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141040.swf" width = "88.000mm" height = "57.944mm" ver = "01" gw = "183" gh = "148"/>
</figure>
</s1>
<s1>
<ptxt>
Die Kühlwasserleitung (1) ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Das Distanzstück (2) und die Dichtung vom Zylinderkopf abnehmen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141023.jpg" width = "88.000mm" height = "57.901mm" ver = "01" gw = "199" gh = "148"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1406009002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Eine neue Dichtung verwenden.
</ptxt>
</item>
<item>
<ptxt>
Sicherstellen, dass alle entfernten Teile sich wieder an der ursprünglichen Position befinden.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
