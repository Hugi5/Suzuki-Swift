<section sectnbr = "4B">
<servcat sctnbr = "04" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A4206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung der Vorderrad-Bremsscheibe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A4206005">Aus- und Einbau der Vorderrad-Bremsscheibe</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A4206006001" page = "2">
<title>
Vorderrad-Bremsscheibe
</title>
<list1 type = "unordered">
<item>
<ptxt>
Die Abweichung der Scheibe mithilfe eines Magnetsockels und einer Messuhr mit Fühler ca. 10 mm (0,39 in.) vom äußeren Umfang der Scheibe entfernt messen. Wenn sie den Grenzwert übersteigt, die Vorderrad-Bremsscheibe korrigieren oder austauschen.
</ptxt>
<spec-sdm>
<sdm-title>
Unrundheit der Vorderrad-Bremsscheibe
</sdm-title>
<sdm1>
<sdm-condition>
Grenzwert
</sdm-condition>
<sdm-value>
0,10 mm (0,004 in.) 
</sdm-value>
</sdm1>
</spec-sdm>
<servicetool>
<servicetoolitem id = "L4B001">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900-20607
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L4B002">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900-20701
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure page = "2">
<graphic graphicname = "IAP70A420010.swf" width = "88.000mm" height = "49.949mm" ver = "02" gw = "133" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Mit einem Mikrometer die Dicke der Vorderrad-Bremsscheibe messen. Liegt sie unter dem Grenzwert, die Vorderrad-Bremsscheibe austauschen.
</ptxt>
<spec-sdm>
<sdm-title>
Vorderrad-Bremsscheibendicke
</sdm-title>
<sdm-part>
&#34;a&#34;
</sdm-part>
<sdm1>
<sdm-condition>
Sollwert
</sdm-condition>
<sdm-value>
22,0 mm (0,87 in.)
</sdm-value>
</sdm1>
<sdm1>
<sdm-condition>
Grenzwert
</sdm-condition>
<sdm-value>
20,0 mm (0,79 in.)
</sdm-value>
</sdm1>
</spec-sdm>
<figure page = "2">
<graphic graphicname = "IAP70A420011.swf" width = "88.000mm" height = "52.057mm" ver = "01" gw = "133" gh = "131"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
