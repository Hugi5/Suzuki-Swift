<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7224025" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1544
</title>
<servinfosub id = "AGEAP70A7224025001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.118in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.087in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1544: Übertragung ungültiger Daten zwischen HVAC-Steuermodul und Auto-A/C-Bedienfeld 
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
HVAC-Steuermodul sendete ungültiges Signal an Auto-A/C-Bedienfeld.
</ptxt>
</item>
<item>
<ptxt>
HVAC-Steuermodul empfing ungültiges Signal vom Auto-A/C-Bedienfeld.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Auto-A/C-Bedienfeld
</ptxt>
</item>
<item>
<ptxt>
HVAC-Steuermodul
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70A7224025002">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Den Motor anlassen und die Klimaanlage einschalten.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7224025003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A7224025004">
<testgroup id = "AGEAP70A7224025005">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen und DTC abrufen.
</ptxt>
</test1>
<question>
Wird DTC B1544 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Ein intaktes HVAC-Steuermodul und/oder Auto-A/C-Bedienfeld austauschen und DTC erneut abrufen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
HVAC-Steuermodul: 
<intxreftitleoff1 refid = "AGEAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Bedienfeld des automatischen A/C-Systems: 
<intxreftitleoff1 refid = "AGEAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Zeitweilige Störung.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
