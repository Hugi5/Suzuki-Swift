<servinfosub id = "AGEAP70A7224023003">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Den Motor anlassen und die Klimaanlage einschalten.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7224023004">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A7224023005">
<testgroup id = "AGEAP70A7224023006">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen und DTC abrufen.
</ptxt>
</test1>
<question>
Wird DTC B1540 weiterhin erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Zeitweilige Störung.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224023008">
<title>
Überprüfung der Sicherung
</title>
<test1>
<ptxt>
Die Sicherung &#34;MTR&#34; überprüfen.
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Die Sicherung &#34;MTR&#34; austauschen und den Schaltkreis auf Masseschluss prüfen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A7224023007">
<title>
Überprüfung des Versorgungskreises der Batteriespannung
</title>
<test1>
<ptxt>
Den Steckverbinder des Auto-A/C-Bedienfelds abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Spannung zwischen der Kabelklemme &#34;WHT/RED&#34; des Steckverbinders des Auto-A/C-Bedienfelds und Masse messen.
</ptxt>
</test1>
<question>
Beträgt die Spannung 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Auto-A/C-Bedienfeld austauschen. 
<intxreftitleoff1 refid = "AGEAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den Armaturenbrett-Kabelbaum austauschen.
</ptxt>
</action>
</testgroup>
</diag>
