<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Anlassproblem (Anlasserbetätigung in Ordnung)
</title>
<ptxt>
Fehlersuche gemäß folgenden Anweisungen durchführen, wenn das ECM keine DTCs erfasst und bei 
<intxref refid = "AGEAP70A1104008">Sichtprüfung</intxref>
 und 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
 keine Mängel festgestellt werden.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Anlassproblem (Anlasserbetätigung in Ordnung)
</ptxt>
</condition>
<ps>
<ptxt>
Zündkerze defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1806002">Überprüfung der Zündkerzen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Zündspule defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1806004">Überprüfung der Zündspulen-Baugruppe</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kraftstoffschlauch oder -leitungen verschmutzt oder verstopft
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1704005">Überprüfung des Kraftstoffdrucks</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kraftstoffpumpe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1704005">Überprüfung des Kraftstoffdrucks</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Ansaugen von Nebenluft durch Ansaugkrümmerdichtung oder Dichtung des Drosselklappengehäuses
</ptxt>
</ps>
<action>
<ptxt>
Luftzufuhrsystem überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Elektrische Drosselklappengehäuse-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306004">Überprüfung der elektrischen Drosselklappengehäuse-Baugruppe am Fahrzeug</intxref>
</ptxt>
</action>
<ps>
<ptxt>
APP-Sensorbaugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306008">Überprüfung des APP-Sensors</intxref>
</ptxt>
</action>
<ps>
<ptxt>
ECT-Sensor oder MAF-Sensor defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306012">Überprüfung des ECT-Sensors</intxref>
 oder 
<intxref refid = "AGEAP70A1306026">Überprüfung des MAF- und IAT-Sensors</intxref>
</ptxt>
</action>
<ps>
<ptxt>
ECM defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1104070">Überprüfung von ECM und dessen Schaltkreisen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kompression zu niedrig
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1404001">Kompressionsprüfung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Zündkerzen nicht festgezogen oder Dichtung defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1806001">Aus- und Einbau der Zündkerzen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kompressionsverlust durch Ventilsitz
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406028">Überprüfung von Ventil und Ventilführung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Ventilschaft schwergängig
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406028">Überprüfung von Ventil und Ventilführung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Ventilfedern schwach oder beschädigt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406031">Überprüfung der Ventilfedern</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kompressionsverlust durch undichte Zylinderkopfdichtung
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406029">Überprüfung des Zylinderkopfs</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kolbenring klemmt oder ist beschädigt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406035">Überprüfung von Zylinder, Kolben und Kolbenring</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kolben, Kolbenring oder Zylinder verschlissen
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406035">Überprüfung von Zylinder, Kolben und Kolbenring</intxref>
</ptxt>
</action>
<ps>
<ptxt>
PCV-Ventil defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1206006">Überprüfung des PCV-Ventils</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nockenwellensteuerung (VVT-System) außer Betrieb
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306027">Überprüfung des OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
