<title>
Mangelhafte Bremskraft
</title>
<diag type = "condition">
<condition>
<ptxt>
Mangelhafte Bremskraft
</ptxt>
</condition>
<ps>
<ptxt>
Austritt von Bremsflüssigkeit aus Bremsleitungen
</ptxt>
</ps>
<action>
<ptxt>
Leckstelle lokalisieren und reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Bremsscheibe oder Bremsklötze mit Flüssigkeit, Fett oder Öl verunreinigt
</ptxt>
</ps>
<action>
<ptxt>
Reinigen oder austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Bremsen überhitzt
</ptxt>
</ps>
<action>
<ptxt>
Ursache ermitteln und beheben.
</ptxt>
</action>
<ps>
<ptxt>
Bremsklotz stark verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Bremssattel-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
Reparieren oder austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Luft im System
</ptxt>
</ps>
<action>
<ptxt>
Das Bremssystem entlüften.
</ptxt>
</action>
<ps>
<ptxt>
Interner Defekt des Bremskraftverstärkers
</ptxt>
</ps>
<action>
<ptxt>
Den Bremskraftverstärker austauschen.
</ptxt>
</action>
<ps>
<ptxt>
Unzureichender Unterdruck für Bremskraftverstärker
</ptxt>
</ps>
<action>
<ptxt>
Motor und Unterdruckschlauch überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
ESP<sup>&#174;</sup> defekt
</ptxt>
</ps>
<action>
<ptxt>
Das System überprüfen und bei Bedarf austauschen.
</ptxt>
</action>
</diag>
