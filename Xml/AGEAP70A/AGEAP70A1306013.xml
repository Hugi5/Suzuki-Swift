<servinfo servinfosgmlid = "AGEAP70A1306013" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Überprüfung des A/F-Sensors am Fahrzeug
</title>
<c-change/>
<servinfosub id = "AGEAP70A1306013002">
<title>
A/F-Sensorheizung
</title>
<s1>
<ptxt>
Den A/F-Sensorstecker bei Zündung auf &#34;OFF&#34; abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Mit einem Ohmmeter den sensorseitigen Widerstand zwischen den Anschlussklemmen &#34;2&#34; und &#34;5&#34; des A/F-Sensorsteckers messen. Bei vorliegenden Defekten den A/F-Sensor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention3>
<ptxt>
Die Temperatur des Sensors hat großen Einfluss auf den Widerstandswert. Sicherstellen, dass die Sensorheizung die richtige Temperatur aufweist.
</ptxt>
</attention3>
<spec>
<title>
Widerstand der A/F-Sensorheizung
</title>
<ptxt>
2,4 bis 4,0 &#937; bei 20&#176;C (68&#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7N301132038.swf" width = "88.000mm" height = "30.676mm" ver = "01" gw = "67" gh = "70"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.314in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.150in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
A/F-Sensorstecker (von der Klemmenseite aus gesehen)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1306013003" page = "2">
<title>
Regelwiderstand des A/F-Sensors
</title>
<ptxt>
Mit einem Ohmmeter den Widerstand zwischen den Anschlussklemmen &#34;1&#34; und &#34;3&#34; des A/F-Sensorsteckers messen. Bei vorliegenden Defekten den A/F-Sensor austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<spec>
<title>
Regelwiderstand für A/F-Sensor
</title>
<ptxt>
30 bis 300 &#937; bei 20&#176;C (68&#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7N301132038.swf" width = "88.000mm" height = "30.676mm" ver = "01" gw = "67" gh = "70"/>
