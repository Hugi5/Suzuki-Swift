<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1306005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Kalibrierung des elektrischen Drosselklappensteuersystems
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Falls die unter 
<intxref refid = "AGEAP70A1101007">Beschreibung der Kalibrierung des elektrischen Drosselklappensystems</intxref>
 beschriebenen Wartungsarbeiten durchgeführt werden, das elektrische Drosselklappensystem wie folgt kalibrieren.
</ptxt>
</item>
<item>
<ptxt>
Sicherstellen, dass die folgenden Bedingungen erfüllt sind, wenn dieses Verfahren angewendet wird.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Umgebungstemperatur &#62; 5 &#176;C (41 &#176;F)
</ptxt>
</item>
<item>
<ptxt>
Es wurden keine DTCs erfasst.
</ptxt>
</item>
<item>
<ptxt>
Gaspedalposition: Leerlaufstellung
</ptxt>
</item>
<item>
<ptxt>
5 &#176;C (41 &#176;F) &#60; ECT &#60; 100 &#176;C (212 &#176;F)
</ptxt>
</item>
<item>
<ptxt>
Batteriespannung &#62; 10 V
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Die Zündung 60 Sek. lang auf &#34;ON&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Nach Abschluss der Kalibrierung prüfen, ob für das ECM DTCs erfasst werden.
</ptxt>
<ptxt>
Falls ein DTC erfasst wird, die Fehlersuche für diesen DTC durchführen.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
