<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9A06005" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Kotflügels vorn
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9A06004">Bauteile des Kotflügels vorn</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9A06005001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Stoßfänger vorn und Halter für Stoßfänger vorn entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Windlaufzierblende und die seitliche Windlaufzierblende entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9806005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Scheinwerfereinheit ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die seitliche Blinkerleuchte entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9206006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Schwellerschutz entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9806007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Radlaufblende vorn abmontieren.
</ptxt>
</s1>
<s1>
<ptxt>
Frontkotflügel und Frontkotflügelabdeckung entfernen.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9A06005002">
<title>
Einbau
</title>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Den Abstand des Frontkotflügels einstellen. 
<intxreftitleoff1 refid = "AGEAP70A9B04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Falls der Lack einer Frontkotflügelschraube abgeblättert ist, diese unbedingt neu lackieren, um Rostbildung zu vermeiden.
</ptxt>
</item>
<item>
<ptxt>
Nach dem Einbau die Scheinwerfereinstellung durchführen. 
<intxreftitleoff1 refid = "AGEAP70A9206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
