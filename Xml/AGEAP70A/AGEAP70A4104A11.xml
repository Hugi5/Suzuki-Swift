<title>
ESP&#174;-Warnleuchte bleibt nach dem Einschalten der Zündung auf &#34;ON&#34; eingeschaltet (länger als 2 Sek.)
</title>
<diag type = "condition">
<condition>
<ptxt>
ESP<sup>&#174;</sup>-Warnleuchte bleibt nach dem Einschalten der Zündung auf &#34;ON&#34; eingeschaltet (länger als 2 Sek.)
</ptxt>
</condition>
<ps>
<ptxt>
ESP<sup>&#174;</sup> defekt
</ptxt>
</ps>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Systemüberprüfung durchführen. 
<intxreftitleoff1 refid = "AGEAP70A4604001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Stromversorgung und Masseschaltkreis des ESP<sup>&#174;</sup>-Steuermoduls defekt
</ptxt>
</ps>
<action>
<ptxt>
