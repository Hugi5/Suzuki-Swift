<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A1104A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Übermäßiger Ausstoß von Kohlenwasserstoff (HC) oder Kohlenmonoxid (CO)
</title>
<ptxt>
Fehlersuche gemäß folgenden Anweisungen durchführen, wenn das ECM keine DTCs erfasst und bei 
<intxref refid = "AGEAP70A1104008">Sichtprüfung</intxref>
 und 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
 keine Mängel festgestellt werden.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Übermäßiger Ausstoß von Kohlenwasserstoff (HC) oder Kohlenmonoxid (CO)
</ptxt>
</condition>
<ps>
<ptxt>
Zündkerze defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1806002">Überprüfung der Zündkerzen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defekte Zündspule mit Zünder
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1806004">Überprüfung der Zündspulen-Baugruppe</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kompression zu niedrig
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1404001">Kompressionsprüfung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Dreiwege-Katalysator mit Blei kontaminiert
</ptxt>
</ps>
<action>
<ptxt>
Auf fehlende Einfüllstutzenverengung überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Tankdunst-Rückhaltesystem defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1204001">Überprüfung des EVAP-Aktivkohlebehälter-Spülsystems</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Kraftstoffdruck entspricht nicht den Vorgaben
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1704005">Überprüfung des Kraftstoffdrucks</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Defekt im geschlossenen Lambdaregelkreis (Gemischkorrektur) (mangelhafte Funktion von ECT-Sensor oder MAF-Sensor)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306012">Überprüfung des ECT-Sensors</intxref>
 oder 
<intxref refid = "AGEAP70A1306026">Überprüfung des MAF- und IAT-Sensors</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Elektrische Drosselklappengehäuse-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306004">Überprüfung der elektrischen Drosselklappengehäuse-Baugruppe am Fahrzeug</intxref>
</ptxt>
</action>
<ps>
<ptxt>
APP-Sensorbaugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306008">Überprüfung des APP-Sensors</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Einspritzventil(e) defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1704003">Überprüfung des Einspritzventil-Schaltkreises</intxref>
</ptxt>
</action>
<ps>
<ptxt>
ECM defekt
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1104070">Überprüfung von ECM und dessen Schaltkreisen</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Motor hat nicht die normale Betriebstemperatur
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Luftfilter verstopft
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1406003">Überprüfung und Reinigung des Luftfilters</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Unterdrucklecks
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1404002">Motor-Unterdruckprüfung</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Nockenwellensteuerung (VVT-System) außer Betrieb
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AGEAP70A1306027">Überprüfung des OCV</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
