<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A9204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Beide Abblendlichter leuchten nicht auf.
</title>
<diag type = "condition">
<condition>
<ptxt>
Beide Abblendlichter leuchten nicht auf.
</ptxt>
</condition>
<ps>
<ptxt>
Defekter Beleuchtungs- und Blinkerschalter
</ptxt>
</ps>
<action>
<ptxt>
Siehe 
<intxref refid = "AGEAP70A9206015">Überprüfung des Beleuchtungs- und Blinkerschalters</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Glühlampen durchgebrannt
</ptxt>
</ps>
<action>
<ptxt>
Glühlampen austauschen, wenn alle oben genannten Punkte normal sind.
</ptxt>
</action>
<ps>
<ptxt>
Defekte Verkabelung bzw. Masseanschluss
</ptxt>
</ps>
<action>
<ptxt>
Die Verkabelung reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Defektes DRL-Steuermodul (falls vorhanden)
</ptxt>
</ps>
<action>
<ptxt>
System überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9204002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
