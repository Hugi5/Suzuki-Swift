</ptxt>
</condition>
<ps>
<ptxt>
Verschleißanzeige liegt an Bremsscheibe an
</ptxt>
</ps>
<action>
<ptxt>
Bremsklotz erneuern.
</ptxt>
</action>
<condition>
<ptxt>
Zu großer Pedalhub (Pedalweg zu groß)
</ptxt>
</condition>
<ps>
<ptxt>
