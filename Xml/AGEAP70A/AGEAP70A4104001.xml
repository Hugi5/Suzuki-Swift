</ptxt>
</condition>
<ps>
<ptxt>
ESP<sup>&#174;</sup> defekt
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
ESP<sup>&#174;</sup>-Systemüberprüfung durchführen. 
<intxreftitleoff1 refid = "AGEAP70A4604001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 .
</ptxt>
</paragroup>
</action>
<condition>
<ptxt>
