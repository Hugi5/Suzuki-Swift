<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A7216026" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau des Stellglieds für Luftzufuhrregelung
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7216020">Bauteile der HVAC-Steuereinheit:Manuelle Ausführung</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A7216026001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Glühkerzen ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Fußraum-Luftkanal auf der Beifahrerseite ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A7216011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder des Stellglieds für Luftzufuhrregelung abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Schrauben (1) lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Stellglied für die Luftzufuhrregelung (2) von der HVAC-Einheit abnehmen.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721028.jpg" width = "88.000mm" height = "68.236mm" ver = "01" gw = "142" gh = "177"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A7216026002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A7216027">Überprüfung des Stellglieds für Luftzufuhrregelung:Manuelle Ausführung</intxrefpoff>
</ptxt>
<ptxt>
Zum Einbau den Ausbauvorgang umkehren und folgende Punkte beachten: 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Sicherstellen, dass der Gestängestift (1) in die Nut (2) des Stellglieds für die Luftzufuhrregelung eingesetzt ist.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721029.swf" width = "88.000mm" height = "49.668mm" ver = "01" gw = "167" gh = "124"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
