<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A6304004" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Löschen von DTCs
</title>
<s1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</s1>
<s1>
<ptxt>
Das SUZUKI-Diagnosegerät an den DLC (1) anschließen, der sich an der Unterseite des Armaturenbretts auf der Fahrerseite befindet.
</ptxt>
<servicetool>
<servicetoolitem id = "L6C002">
<s-part>
(A)
</s-part>
<s-number num = "NNNNN-00024">
SUZUKI-Testgerät (SUZUKI-SDT)
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630006.jpg" width = "88.000mm" height = "67.502mm" ver = "03" gw = "159" gh = "175"/>
</figure>
</s1>
<s1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</s1>
<s1>
<ptxt>
Die DTC anhand der Anweisungen des SUZUKI-Diagnosegeräts löschen. Näheres hierzu ist der Bedienungsanleitung des SUZUKI-Diagnosegeräts zu entnehmen.
</ptxt>
</s1>
<s1>
<ptxt>
Nach dem Löschen der DTC die Zündung auf &#34;OFF&#34; stellen und das SUZUKI-Diagnosegerät vom DLC abklemmen.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
