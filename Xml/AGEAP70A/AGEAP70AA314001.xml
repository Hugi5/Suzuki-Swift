<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA314001" svcinfotypenbr = "06" svcinfoqualnbr = "01" page = "1" supplyoff = "1" modify = "0">
<title>
Überprüfung des Wegfahrsperren-Steuersystems
</title>
<attention3>
<ptxt>
Vor der Fehlersuche unbedingt 
<intxref refid = "AGEAP70AA310002">Vorsichtsmaßnahmen für Wegfahrsperrensystem:Modell mit Zündschalter</intxref>
 lesen.
</ptxt>
</attention3>
<diag type = "test" id = "AGEAP70AA314001001">
<testgroup id = "AGEAP70AA314001002">
<question>
Dreht der Motor?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A1904001">Symptomdiagnose für das Anlassersystem</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA314001003">
<title>
Überprüfung des Motorstarts
</title>
<question>
Springt der Motor an?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA314001004">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird ein DTC erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Das Wegfahrsperren-Steuersystem funktioniert einwandfrei.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA314001005">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
Die DTCs abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA314003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Wird ein DTC erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA314001006">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
DTC bezüglich CAN-Kommunikation überprüfen.
</ptxt>
</test1>
<question>
Werden CAN-DTC(s) erfasst?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit betreffender DTC-Fehlersuche.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A1104009">Grundlegende Motorüberprüfung</intxref>
.
</ptxt>
</action>
</testgroup>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
