<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A1A06006" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Generatorhalterung
</title>
<servinfosub id = "AGEAP70A1A06006001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Das Minuskabel (–) von der Batterie lösen.
</ptxt>
</s1>
<s1>
<ptxt>
Den rechten Motorunterboden ausbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Den Antriebsriemen für Kühlmittelpumpe/Generator austauschen. 
<intxreftitleoff1 refid = "AGEAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Riemenscheibe der Kühlmittelpumpe (1) ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Die Generatorschraube (2) entfernen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Generatorhalterung (3) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A1A1007.jpg" width = "88.000mm" height = "70.982mm" ver = "01" gw = "192" gh = "185"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A1A06006002">
<title>
Einbau
</title>
<ptxt>
Zum Einbau den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Die Generatorhalterung folgendermaßen einbauen.
</ptxt>
</item>
<list2 type = "ordered">
<item>
<ptxt>
Die Generatorhalterung (1) positionieren.
</ptxt>
</item>
<item>
<ptxt>
Die Generatorschraube (2) leicht anziehen.
</ptxt>
</item>
<item>
<ptxt>
Die Muttern (3) der Generatorhalterung mit dem vorgeschriebenen Drehmoment festziehen. 
<intxreftitleoff1 refid = "AGEAP70A1606016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
<figure>
<graphic graphicname = "I9P60A1A1016.swf" width = "88.000mm" height = "68.664mm" ver = "01" gw = "188" gh = "178"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
