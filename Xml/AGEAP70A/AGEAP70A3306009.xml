<graphic graphicname = "IAP70A330023.swf" width = "88.000mm" height = "50.374mm" ver = "01" gw = "139" gh = "126"/>
</figure>
</s1>
<s1>
<ptxt>
Den Verteilergetriebe-Abtriebsflansch (1) mit dem Spezialwerkzeug ausbauen.
</ptxt>
