<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A6104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Schwammige Lenkung bzw. mangelhafte Lenkstabilität
</title>
<diag type = "condition">
<condition>
<ptxt>
Schwammige Lenkung bzw. mangelhafte Lenkstabilität
</ptxt>
</condition>
<ps>
<ptxt>
Unterschiedliche Reifen oder ungleicher Reifenluftdruck
</ptxt>
</ps>
<action>
<ptxt>
Austauschen bzw. Reifendruck korrigieren. 
<intxreftitleoff1 refid = "AGEAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Querlenkergelenk und Spurstangenkopf locker
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Querlenker oder Spurstangenkopf austauschen.
</ptxt>
<ptxt>
Querlenker: 
<intxreftitleoff1 refid = "AGEAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Spurstangenkopf: 
<intxreftitleoff1 refid = "AGEAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Vordere Federbeinbaugruppe oder Federbeinlager defekt
</ptxt>
</ps>
<action>
<ptxt>
Vordere Federbeinbaugruppe austauschen oder Federbeinlager reparieren. 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Stabilisator locker
</ptxt>
</ps>
<action>
<ptxt>
Stabilisator bzw. Buchse festziehen bzw. ersetzen. 
<intxreftitleoff1 refid = "AGEAP70A2206013"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Gebrochene oder ermüdete Schraubenfeder
</ptxt>
</ps>
<action>
<ptxt>
Schraubenfeder austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Vordere Federbeinbaugruppe (Stoßdämpfer) defekt
</ptxt>
</ps>
<action>
<ptxt>
Vordere Federbeinbaugruppe (Stoßdämpfer) austauschen. 
<intxreftitleoff1 refid = "AGEAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fehlerhaftes Tragbild zwischen Zahnstange und Ritzel
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Das Drehmoment von Zahnstange und Ritzelwelle überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Bei Defekten die Lenkgetriebegehäuse-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Vorderradspur falsch eingestellt
</ptxt>
</ps>
<action>
<ptxt>
Vorderradspur überprüfen und einstellen. 
<intxreftitleoff1 refid = "AGEAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Lenkgetriebegehäuse-Baugruppe defekt
</ptxt>
</ps>
<action>
<ptxt>
Lenkgetriebegehäuse-Baugruppe austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
