<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10B">
<servcat sctnbr = "10" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70AA204013" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1133
</title>
<servinfosub id = "AGEAP70AA204013001">
<title>
Bedingung für DTC-Erfassung und Störungsbereich
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.385in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.833in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Bedingung für DTC-Erfassung
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Störungsbereich
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1133: Batteriespannung zu hoch 
</emph>
</ptxt>
<ptxt>
Spannung des Ersatz-Stromversorgungskreises von der Sicherung &#34;DOME&#34; liegt während des vorgegebenen Zeitraums kontinuierlich über 16,0 V.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Ladesystem
</ptxt>
</item>
<item>
<ptxt>
BCM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AGEAP70AA204013002">
<title>
Überprüfung von Diagnosecodes
</title>
<s1>
<ptxt>
Den Motor anlassen, wenn möglich.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70AA204013003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70AA204013004">
<testgroup id = "AGEAP70AA204013006">
<title>
Überprüfung der Parameter
</title>
<test1>
<ptxt>
Bei ausgeschalteter Zündung das SUZUKI-Diagnosegerät an den DLC anschließen.
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Die Anzeige &#34;Batteriespannung&#34; auf dem SUZUKI-Diagnosegerät überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
Ende. (Zeitweilige Störung)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70AA204013005">
<title>
Überprüfung des Ladesystems	
</title>
<test1>
<ptxt>
Das Ladesystem überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist das Teil in gutem Zustand?
</question>
<result type = "yes"/>
<action>
<ptxt>
BCM austauschen und die DTCs erneut abrufen. 
<intxreftitleoff1 refid = "AGEAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Das Ladesystem reparieren.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
