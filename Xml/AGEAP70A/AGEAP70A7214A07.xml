<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A7214A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Kein bzw. unzureichendes Ausströmen kalter Luft (bei normaler Funktion der Magnetkupplung)
</title>
<diag type = "condition">
<condition>
<ptxt>
Kein bzw. unzureichendes Ausströmen kalter Luft (bei normaler Funktion der Magnetkupplung)
</ptxt>
</condition>
<ps>
<ptxt>
Nicht genügend oder zuviel Kältemittel
</ptxt>
</ps>
<action>
<ptxt>
Kältemittelsystem auf ausreichenden Füllstand und Undichtigkeit prüfen.
</ptxt>
</action>
<ps>
<ptxt>
Kondensator verstopft
</ptxt>
</ps>
<action>
<ptxt>
Kondensator überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
A/C-Verdampfer verstopft oder eingefroren
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
A/C-Verdampfer und Verdampfer-Temperatursensor überprüfen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
A/C-Verdampfer: 
<intxreftitleoff1 refid = "AGEAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Verdampfer-Temperatursensor: 
<intxreftitleoff1 refid = "AGEAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Verdampfer-Temperatursensor defekt
</ptxt>
</ps>
<action>
<ptxt>
Verdampfer-Temperatursensor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Defektes Expansionsventil
</ptxt>
</ps>
<action>
<ptxt>
Expansionsventil überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kompressor-Antriebsriemen locker oder gerissen
</ptxt>
</ps>
<action>
<ptxt>
Den Kompressor-Antriebsriemen überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rutschende Magnetkupplung
</ptxt>
</ps>
<action>
<ptxt>
Magnetkupplung überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kompressor defekt
</ptxt>
</ps>
<action>
<ptxt>
Kompressor überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Luft im A/C-System
</ptxt>
</ps>
<action>
<ptxt>
Den Kondensator austauschen, anschließend entleeren und mit Kältemittel befüllen. 
<intxreftitleoff1 refid = "AGEAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Luftaustritt aus HVAC-Einheit oder Luftkanal
</ptxt>
</ps>
<action>
<ptxt>
HVAC-Einheit oder Luftkanal reparieren.
</ptxt>
</action>
<ps>
<ptxt>
Heizungs- und Belüftungssystem defekt
</ptxt>
</ps>
<action>
<ptxt>
HVAC-Einheit überprüfen.
</ptxt>
</action>
<ps>
<ptxt>
Gebläsemotor defekt
</ptxt>
</ps>
<action>
<ptxt>
Gebläsemotor überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Zu viel Kompressoröl im A/C-System
</ptxt>
</ps>
<action>
<ptxt>
Überschüssiges Kompressoröl aus A/C-Systemkreislauf und Kompressor ablassen.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
