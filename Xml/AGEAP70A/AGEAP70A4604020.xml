<servinfosub id = "AGEAP70A4604020003">
<title>
DTC-Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A4604020004">
<testgroup id = "AGEAP70A4604020005">
<question>
Wurde die &#34;ESP<sup>&#174;</sup>-Systemprüfung&#34; durchgeführt?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70A4604001">ESP&#174;-Systemprüfung</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604020006">
<title>
Überprüfung des ESP&#174;-AUS-Schalters
</title>
<test1>
<ptxt>
Sicherstellen, dass die Zündung ausgeschaltet ist.
</ptxt>
</test1>
<test1>
<ptxt>
Den ESP<sup>&#174;</sup> OFF-Schalter ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A4606017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Alle Anschlussklemmen des ESP<sup>&#174;</sup> AUS-Schalters auf einwandfreie Verbindung prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn die Anschlüsse in Ordnung sind, den ESP<sup>&#174;</sup>-OFF-Schalter überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Den ESP<sup>&#174;</sup> OFF-Schalter austauschen.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A4604020007">
<title>
Überprüfung des Schaltkreises des ESP&#174;-AUS-Schalters
</title>
<test1>
<ptxt>
Den Steckverbinder &#34;E24&#34; abklemmen.
</ptxt>
</test1>
<test1>
<ptxt>
Auf einwandfreien Kontakt mit Anschlussklemme &#34;E24-38&#34; prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn der Anschluss in Ordnung ist, den Widerstand zwischen Anschlussklemme &#34;E24-38&#34; und Masse messen.
</ptxt>
</test1>
<question>
Ist der Widerstand unendlich?
</question>
<result type = "yes"/>
<action>
<ptxt>
ESP<sup>&#174;</sup>-Hydraulikeinheit/Steuermodul-Baugruppe austauschen und DTC erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
&#34;A1&#34;-Schaltkreis bei Kurzschluss reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
</diag>
