</s1>
<s1>
<ptxt>
Die Vordertürscharnier-Verstärkung einbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Lochschweißung durchführen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0047.jpg" width = "183.000mm" height = "153.828mm" ver = "05" gw = "406" gh = "420"/>
</figure>
</s1>
<s1>
<ptxt>
Ein neues A-Säulen-Außenblech an der Karosserie anbringen und in gestapeltem Zustand abschneiden.
</ptxt>
</s1>
<s1>
<ptxt>
A-Säulen-Außenblech einbauen.
</ptxt>
</s1>
<s1>
<ptxt>
Widerstands-Punktschweißung und Lochschweißung durchführen.
</ptxt>
</s1>
<s1>
<ptxt>
Durchgehende Schweißung durchführen.
</ptxt>
</s1>
<s1>
<ptxt>
Rostschutzwachs auf die Rückseite der durchgehenden Schweißnaht auftragen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Blechlasche (Pfeil) des A-Säulen-Außenblechs umbiegen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9B0071G.jpg" width = "183.000mm" height = "231.685mm" ver = "06" gw = "497" gh = "640"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.472in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.706in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
<symbol name = "MANOTE" width = "5.132mm" height = "3.048mm"/>
: 
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Widerstands-Punktschweißung bei drei Blechstärken durchführen.
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
</servinfo>
