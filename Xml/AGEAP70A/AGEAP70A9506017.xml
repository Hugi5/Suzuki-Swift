<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Fondtür-Fensterheberbaugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9506014">Bauteile der Fondtür</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9506017001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Türscheibe hinten ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9506015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder (1) des Motors des elektrischen Fensterhebers abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Fensterheber-Sechskantschrauben (2) herausdrehen und hintere Fensterheberbaugruppe (3) entfernen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950048.jpg" width = "88.000mm" height = "61.700mm" ver = "02" gw = "217" gh = "158"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9506017002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9506018">Überprüfung der hinteren Fensterheberbaugruppe</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Fett auf die Gleitteile der hinteren Fensterheberbaugruppe auftragen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E002" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Die Schrauben des hinteren Fensterhebers in der Reihenfolge (&#34;1&#34; bis &#34;4&#34;) auf das angegebene Drehmoment anziehen.
</ptxt>
<torque>
<torqueitem id = "T9E006">
<t-part>
Schraube des hinteren Fensterhebers*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,86
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950049.jpg" width = "88.000mm" height = "63.881mm" ver = "01" gw = "225" gh = "165"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
