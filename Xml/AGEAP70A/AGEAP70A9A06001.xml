<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9J">
<servcat sctnbr = "09" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9A06001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Motorhaube
</title>
<servinfosub id = "AGEAP70A9A06001001">
<title>
Ausbau
</title>
<attention2>
<ptxt>
Die Karosserie mit Lappen abdecken, um Beschädigungen zu vermeiden.
</ptxt>
</attention2>
</servinfosub>
<s1>
<ptxt>
Die 4 Haubenscharnierschrauben (1) herausdrehen, um die Motorhaube (2) abzunehmen.
</ptxt>
</s1>
<s1>
<ptxt>
Das Haubenscharnier ggf. nach Ausbau des Frontkotflügels entfernen. 
<intxreftitleoff1 refid = "AGEAP70A9A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<servinfosub id = "AGEAP70A9A06001002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9A06002">Überprüfung und Einstellung der Motorhaube</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Kontaktfläche &#34;A&#34; des Haubenscharniers mit Dichtmittel bestreichen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1215" id = "M9J001" uid = "27">
<m-part>
&#34;A&#34;
</m-part>
<m-desc>
Dichtmittel
</m-desc>
<m-number>
99000-31110
</m-number>
<m-name>
SUZUKI Bond Nr.1215
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Falls erforderlich die Raststellungen der Motorhaube justieren. 
<intxreftitleoff1 refid = "AGEAP70A9A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Falls der Lack am Haubenscharnier abgeblättert ist, dieses unbedingt neu lackieren, um Rostbildung zu vermeiden.
</ptxt>
<figure>
<graphic graphicname = "I9P60A9A0001.swf" width = "88.000mm" height = "90.826mm" ver = "01" gw = "226" gh = "241"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
