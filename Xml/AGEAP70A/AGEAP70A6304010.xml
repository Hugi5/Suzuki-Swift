<servinfosub id = "AGEAP70A6304010002">
<title>
Fehlersuche
</title>
<diag type = "test" id = "AGEAP70A6304010003">
<testgroup id = "AGEAP70A6304010004">
<title>
Überprüfen der &#34;P/S&#34;-Warnleuchte
</title>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<question>
Leuchten andere Warnleuchten auf?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 4.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A6304010005">
<title>
DTC-Überprüfung
</title>
<test1>
<ptxt>
<intxref refid = "AGEAP70A6304003">DTC-Überprüfung</intxref>
 durchführen.
</ptxt>
</test1>
<question>
Wird DTC U0073 oder DTC U0155 ausgegeben?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit 
<intxref refid = "AGEAP70AA804002">Tabelle der CAN-DTCs (&#34;Kommunikationsabbruch&#34; und &#34;Kommunikationsbus Aus&#34;)</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A6304010006">
<title>
Prüfung des Kombiinstruments
</title>
<test1>
<ptxt>
Das Kombiinstrument austauschen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<question>
Bleibt die P/S-Warnleuchte aus?
</question>
<result type = "yes"/>
<action>
<ptxt>
P/S-Steuermodul austauschen. 
<intxreftitleoff1 refid = "AGEAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Ende.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A6304010007">
<title>
Überprüfung der Sicherung
</title>
<question>
Ist die Schaltkreissicherung des Kombiinstruments in Ordnung?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Die Sicherung austauschen und den Schaltkreis auf Masseschluss prüfen.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AGEAP70A6304010008">
<title>
Überprüfung des CAN-Kommunikationsschaltkreises
</title>
<test1>
<ptxt>
Den CAN-Kommunikationsschaltkreis zwischen Kombiinstrument und P/S-Steuermodul überprüfen. 
<intxreftitleoff1 refid = "AGEAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Ist der CAN-Kommunikationsschaltkreis in Ordnung?
</question>
<result type = "yes"/>
<action>
<ptxt>
Weiter mit Schritt 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Reparieren oder austauschen.
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AGEAP70A6304010009">
<title>
Überprüfung des Stromversorgungskreises des Kombiinstruments
</title>
<test1>
<ptxt>
Das Kombiinstrument ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Auf richtigen Anschluss an Kombiinstrument-Steckverbinder prüfen.
</ptxt>
</test1>
<test1>
<ptxt>
Wenn das Prüfergebnis in Ordnung ist, die Zündung auf &#34;ON&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Überprüfen, ob die Spannung zwischen Anschlussklemme &#34;G240-3&#34; und &#34;G240-5&#34; der Batteriespannung entspricht.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Das Kombiinstrument austauschen und erneut überprüfen. 
<intxreftitleoff1 refid = "AGEAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Weiter mit Schritt 7.
</ptxt>
</action>
</testgroup>
<testgroup id = "AGEAP70A6304010010">
<title>
Überprüfung des Masseschaltkreises des Kombiinstruments
</title>
<test1>
<ptxt>
Die Zündung auf &#34;OFF&#34; stellen.
</ptxt>
</test1>
<test1>
<ptxt>
Den Widerstand zwischen der Kabelklemme &#34;G240-5&#34; und Masse beträgt 1 &#937; oder weniger.
</ptxt>
</test1>
<question>
Ist Prüfergebnis OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
&#34;A1&#34;-Schaltkreis reparieren oder austauschen.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Schaltkreis &#34;A2&#34; reparieren oder austauschen.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
