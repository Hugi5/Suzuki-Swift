<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AGEAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Schaltung schwergängig
</title>
<diag type = "condition">
<condition>
<ptxt>
Schaltung schwergängig
</ptxt>
</condition>
<ps>
<ptxt>
Unzulängliche Schmierung
</ptxt>
</ps>
<action>
<ptxt>
Schaltgetriebeöl nachfüllen.
</ptxt>
</action>
<ps>
<ptxt>
Kupplungspedalspiel falsch eingestellt
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Kupplungspedalarm bzw. Kupplungsgeberzylinder austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Kupplungspedalarm: 
<intxreftitleoff1 refid = "AGEAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Kupplungsgeberzylinder: 
<intxreftitleoff1 refid = "AGEAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Kupplungsscheibe verzogen oder beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsscheibe austauschen.
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Kupplungsdruckplatte beschädigt
</ptxt>
</ps>
<action>
<ptxt>
Kupplungsdeckel austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Synchronring verschlissen
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Synchronring austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Langsamgang-Synchronring und Synchronring des 2. Gangs: 
<intxreftitleoff1 refid = "AGEAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schnellgang-Synchronring: 
<intxreftitleoff1 refid = "AGEAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchronring des 5. Gangs: 
<intxreftitleoff1 refid = "AGEAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Verschlissener angefaster Zahn an Schaltmuffe oder Gangrad
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Synchronschaltmuffe u. Gangrad austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Vorgelegewelle des 1. und 2. Gangs: 
<intxreftitleoff1 refid = "AGEAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Antriebswelle des 3. und 4. Gangrads: 
<intxreftitleoff1 refid = "AGEAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Antriebswelle des 5. Gangs: 
<intxreftitleoff1 refid = "AGEAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Langsamgang-Schaltmuffe u. -Synchronkörper: 
<intxreftitleoff1 refid = "AGEAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schnellgang-Schaltmuffe u. -Synchronkörper: 
<intxreftitleoff1 refid = "AGEAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Synchronschaltmuffe u. -Synchronkörper des 5. Gangs: 
<intxreftitleoff1 refid = "AGEAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Gelenkbuchse der Schaltarmschiene verschlissen
</ptxt>
</ps>
<action>
<ptxt>
Gelenkbuchse der Schaltarmschiene austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Schaltwelle verzogen
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Die Schaltgabel und Schaltwelle austauschen.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Langsamgang-Schaltwelle: 
<intxreftitleoff1 refid = "AGEAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schnellgang-Schaltwelle: 
<intxreftitleoff1 refid = "AGEAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Schaltgabel des 5. Gangs: 
<intxreftitleoff1 refid = "AGEAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Schalt-/Wählzüge gerissen.
</ptxt>
</ps>
<action>
<ptxt>
Schalt- /Wählzug austauschen. 
<intxreftitleoff1 refid = "AGEAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
