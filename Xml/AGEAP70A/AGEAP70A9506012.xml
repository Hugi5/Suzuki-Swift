<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AGEAP70A9506012" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Aus- und Einbau der Vordertür-Fensterheberbaugruppe
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9506010">Bauteile der Vordertür</intxrefpoff>
</ptxt>
<servinfosub id = "AGEAP70A9506012001">
<title>
Ausbau
</title>
<s1>
<ptxt>
Die Vordertürscheibe ausbauen. 
<intxreftitleoff1 refid = "AGEAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Den Steckverbinder (3) des Motors des elektrischen Fensterhebers abklemmen.
</ptxt>
</s1>
<s1>
<ptxt>
Die Muttern (1) des Vordertür-Fensterhebers herausdrehen und dann die Vordertür-Fensterheberbaugruppe (2) ausbauen.
</ptxt>
<figure>
<graphic graphicname = "I9P60A950032.jpg" width = "88.000mm" height = "64.165mm" ver = "03" gw = "225" gh = "165"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AGEAP70A9506012002">
<title>
Einbau
</title>
<ptxt>
<intxrefpoff refid = "AGEAP70A9506013">Überprüfung der Vordertür-Fensterheberbaugruppe</intxrefpoff>
</ptxt>
<ptxt>
Den Ausbauvorgang umkehren und folgende Punkte beachten.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Fett auf die Gleitteile der Vordertür-Fensterheberbaugruppe auftragen.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M9E001" uid = "1126491901">
<m-part>
</m-part>
<m-desc>
Fett
</m-desc>
<m-number>
99000-25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
<item>
<ptxt>
Die Muttern des vorderen Fensterhebers in der ordnungsgemäßen Reihenfolge (&#34;1&#34; bis &#34;6&#34;) auf das angegebene Drehmoment anziehen.
</ptxt>
<torque>
<torqueitem id = "T9E003">
<t-part>
Vordere Fensterhebermutter*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
8,4
</t-value1>
<t-value2>
0,85
</t-value2>
<t-value3>
6,5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950033.jpg" width = "88.000mm" height = "70.187mm" ver = "02" gw = "225" gh = "182"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
