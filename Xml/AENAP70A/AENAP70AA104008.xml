<servinfosub id = "AENAP70AA104008001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.197in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.010in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
DTC P0575: Cruise Control Input Circuit
</emph>
</ptxt>
<ptxt>
This DTC is detected if any one of the following conditions is met.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Signal voltage of cruise control switch signal circuit is higher than specified voltage for specified time continuously.
</ptxt>
</item>
<item>
<ptxt>
ON signals of any or all of following switches of cruise control system are detected for longer than specified time.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
MAIN (ON/OFF) switch
</ptxt>
</item>
<item>
<ptxt>
CANCEL switch
</ptxt>
</item>
<item>
<ptxt>
RES/ACC switch
</ptxt>
</item>
<item>
<ptxt>
SET/COAST switch
</ptxt>
</item>
</list2>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Cruise control switch circuit / connector
</ptxt>
</item>
<item>
<ptxt>
Cruise control switch
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
