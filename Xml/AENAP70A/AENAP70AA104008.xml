<servinfosub id = "AENAP70AA104008003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70AA104008004">
<testgroup id = "AENAP70AA104008005">
<title>
Parameter check
</title>
<test1>
<ptxt>
Connect SUZUKI scan tool to DLC when ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Cruise CANCEL Switch”, “Cruise RES/ACC Switch”, “Cruise SET/COAST Switch” and “Cruise ON/OFF Switch” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENAP70AA104006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA104008006">
<title>
Cruise control switch circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “C01”, “E01” and “G371” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01”, “E01” and “G371” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” and “A2” circuits: less than 3 &#937;
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit terminal and other terminals at “G371” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A2” circuit terminal and other terminals at “G371” connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A1” and “A2” circuits: 0 – 1 V (when ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA104008007">
<title>
Cruise control switch check
</title>
<test1>
<ptxt>
Check cruise control switch. 
<intxreftitleoff1 refid = "AENAP70AA106002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace cruise control switch. 
<intxreftitleoff1 refid = "AENAP70AA106001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
