<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1A">
<servcat sctnbr = "01" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A1104A16" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Excessive hydrocarbon (HC) emission or carbon monoxide (CO) emission
</title>
<ptxt>
Perform troubleshooting referring to the following points when ECM has detected no DTC and no abnormality has been found in 
<intxref refid = "AENAP70A1104008">Visual Inspection</intxref>
 and 
<intxref refid = "AENAP70A1104009">Engine Basic Inspection</intxref>
.
</ptxt>
<diag type = "condition">
<condition>
<ptxt>
Excessive hydrocarbon (HC) emission or carbon monoxide (CO) emission
</ptxt>
</condition>
<ps>
<ptxt>
Faulty spark plug
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1806002">Spark Plug Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ignition coil with ignitor
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1806004">Ignition Coil Assembly Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Low compression
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1404001">Compression Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Lead contamination of three-way catalytic converter
</ptxt>
</ps>
<action>
<ptxt>
Check for absence of filler neck restructure.
</ptxt>
</action>
<ps>
<ptxt>
Faulty evaporative emission control system
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1204001">EVAP Canister Purge System Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Fuel pressure out of specification
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1704005">Fuel Pressure Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty closed-loop system (A/F feedback compensation) (Poor performance of ECT sensor or MAF sensor)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1306012">ECT Sensor Inspection</intxref>
 or 
<intxref refid = "AENAP70A1306026">MAF and IAT Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty electric throttle body assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1306004">Electric Throttle Body Assembly On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty APP sensor assembly
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1306008">APP Sensor Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty injector(s)
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1704003">Fuel Injector Circuit Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1104070">Inspection of ECM and Its Circuits</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Engine not at normal operating temperature
</ptxt>
</ps>
<action>
<ptxt>
—
</ptxt>
</action>
<ps>
<ptxt>
Clogged air cleaner
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1406003">Air Cleaner Filter Inspection and Cleaning</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Vacuum leaks
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1404002">Engine Vacuum Check</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Camshaft position control (VVT) system out of order
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A1306027">OCV Inspection</intxref>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
