<servinfosub id = "AENAP70A1104023003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition “ON” for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1104023004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A1104023005">
<testgroup id = "AENAP70A1104023006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104023007">
<title>
ECT sensor signal circuit and ground circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect “C01” and “E01” connectors of ECM and ECT sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors and ECT sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” and “A2” circuits: less than 1Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A1” and “A2” circuits and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit terminal and other terminal at ECT sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A1” and “A2” circuits: 0 to 1 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104023008">
<title>
ECT sensor check
</title>
<test1>
<ptxt>
Check ECT sensor. 
<intxreftitleoff1 refid = "AENAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace ECT sensor.
</ptxt>
</action>
</testgroup>
