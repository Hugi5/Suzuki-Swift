<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2B">
<servcat sctnbr = "02" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A2206010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Suspension Arm Front Bushing Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A2206008">Suspension Arm Removal and Installation</intxrefpoff>
</ptxt>
<attention3>
<ptxt>
Suspension arm rear bushing is not individually replaceable. Replace suspension arm if the bushing is defective.
</ptxt>
</attention3>
<servinfosub id = "AENAP70A2206010001">
<title>
Removal
</title>
<s1>
<ptxt>
Cut off flange of front suspension arm front bushing (rubber) (1) using knife.
</ptxt>
<figure>
<graphic graphicname = "I9P60A220022.jpg" width = "88.000mm" height = "56.949mm" ver = "01" gw = "238" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Push out front suspension arm front bushing (1) using hydraulic press (2) and special tools.
</ptxt>
<servicetool>
<servicetoolitem id = "L2B003">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943–76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L2B004">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913–75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A220023.swf" width = "88.000mm" height = "48.435mm" ver = "01" gw = "173" gh = "121"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A2206010002">
<title>
Installation
</title>
<s1>
<ptxt>
Press-fit front suspension arm front bushing (1) using special tools and hydraulic press (2).
</ptxt>
<attention2>
<ptxt>
Do not reuse bushing.
</ptxt>
</attention2>
<attention3>
<ptxt>
Before installing bushing, apply soap water on its circumference to facilitate installation.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L2B005">
<s-part>
(A)
</s-part>
<s-number num = "09943-76310">
09943–76310
</s-number>
</servicetoolitem>
<servicetoolitem id = "L2B006">
<s-part>
(B)
</s-part>
<s-number num = "09913-75821">
09913–75821
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A220024.swf" width = "88.000mm" height = "48.773mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Press-fit front suspension arm front bushing (1) so that dimensions “a” and “b” in figure become equal.
</ptxt>
<figure>
<graphic graphicname = "I7V10A220012.swf" width = "88.000mm" height = "45.666mm" ver = "01" gw = "124" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
