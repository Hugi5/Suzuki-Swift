<servinfosub id = "AENAP70A7224023004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A7224023005">
<testgroup id = "AENAP70A7224023006">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition to “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “ON” and check DTC.
</ptxt>
</test1>
<question>
Is DTC B1540 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A7224023008">
<title>
Fuse check
</title>
<test1>
<ptxt>
Check “MTR” fuse.
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace “MTR” fuse and check for short circuit to ground.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A7224023007">
<title>
Battery voltage supply circuit check
</title>
<test1>
<ptxt>
Disconnect auto A/C panel connector.
</ptxt>
</test1>
<test1>
<ptxt>
Measure voltage between “WHT/RED” wire terminal of auto A/C panel connector and ground.
</ptxt>
</test1>
<question>
Is voltage 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace auto A/C panel. 
<intxreftitleoff1 refid = "AENAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
