<servinfosub id = "AENAP70A9406008002">
<title>
Intermittent Wiper Relay Circuit
</title>
<s1>
<ptxt>
Turn the windshield wiper switch to “INT” position.
</ptxt>
</s1>
<s1>
<ptxt>
Connect battery positive (+) terminal to terminal “8” and its negative (–) terminal to terminal “5”.
</ptxt>
</s1>
<s1>
<ptxt>
Connect voltmeter positive lead to terminal “7” and its negative lead to terminal “5”.
</ptxt>
</s1>
<s1>
<ptxt>
Check that the voltmeter indicates the battery voltage (10 – 14 V).
</ptxt>
</s1>
<s1>
<ptxt>
Connect terminal “6” and terminal “8” by a jumper wire.
</ptxt>
<figure>
<graphic graphicname = "I7V20A940020.swf" width = "88.000mm" height = "55.750mm" ver = "01" gw = "173" gh = "142"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect end of the jumper wire from terminal “8”.
</ptxt>
</s1>
<s1>
<ptxt>
Connect disconnected end of jumper wire to terminal “5”, then check that voltage between terminal “7” and terminal “5” changes as shown.
</ptxt>
<ptxt>
If check result is not as specified, replace wiper and washer switch.
</ptxt>
<figure>
<graphic graphicname = "IAP70A940005.swf" width = "88.000mm" height = "103.343mm" ver = "01" gw = "209" gh = "276"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.286in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.005in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.275in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.852in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Wiper interval adjustment switch position
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[C]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
1.6 &#177; 1 sec.
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Voltage
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
