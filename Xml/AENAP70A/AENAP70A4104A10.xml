<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A4104A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
ABS warning light does not turn ON after setting ignition to “ON”
</title>
<diag type = "condition">
<condition>
<ptxt>
ABS warning light does not turn ON after setting ignition to “ON”
</ptxt>
</condition>
<ps>
<ptxt>
Faulty combination meter power supply and ground circuit
</ptxt>
</ps>
<action>
<ptxt>
Check combination meter and its circuit. 
<intxreftitleoff1 refid = "AENAP70A9304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty combination meter
</ptxt>
</ps>
<action>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Malfunctioning CAN communication system
</ptxt>
</ps>
<action>
<ptxt>
Check CAN communication system. 
<intxreftitleoff1 refid = "AENAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Check “MTR” fuse and circuit led to “MTR” fuse: replace if necessary.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
