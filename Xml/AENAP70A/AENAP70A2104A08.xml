<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A2104A08" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Suspension bottoms
</title>
<diag type = "condition">
<condition>
<ptxt>
Suspension bottoms
</ptxt>
</condition>
<ps>
<ptxt>
Overloaded vehicle
</ptxt>
</ps>
<action>
<ptxt>
Check loading.
</ptxt>
</action>
<ps>
<ptxt>
Faulty front strut assembly (shock absorber)
</ptxt>
</ps>
<action>
<ptxt>
Replace front strut assembly (shock absorber). 
<intxreftitleoff1 refid = "AENAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Incorrect, broken or sagging coil springs
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace coil springs. 
</ptxt>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
