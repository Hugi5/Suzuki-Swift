<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A9204A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Auto-on headlight system malfunctions (if equipped)
</title>
<diag type = "condition">
<condition>
<ptxt>
Auto-on headlight system malfunctions (if equipped)
</ptxt>
</condition>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENAP70AA204026">Inspection of BCM and Its Circuits (Keyless Push Start Model)</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty lighting and turn signal switch
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENAP70A9206015">Lighting and Turn Signal Switch Inspection</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty auto-on headlight sensor
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENAP70A9206024">Auto-On Headlight Sensor Inspection (If Equipped)</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
