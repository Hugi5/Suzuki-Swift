<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A2104A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Wheel tramp
</title>
<diag type = "condition">
<condition>
<ptxt>
Wheel tramp
</ptxt>
</condition>
<ps>
<ptxt>
Blister or bump on tire
</ptxt>
</ps>
<action>
<ptxt>
Replace tire. 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Improper front strut assembly (shock absorber) action
</ptxt>
</ps>
<action>
<ptxt>
Replace front strut assembly (shock absorber). 
<intxreftitleoff1 refid = "AENAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
