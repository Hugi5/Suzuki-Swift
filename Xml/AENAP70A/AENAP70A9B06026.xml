<servinfosub id = "AENAP70A9B06026003">
<title>
How to Repair
</title>
<topic id = "AENAP70A9B06026004">
<title>
Baffle plate restoration
</title>
<ptxt>
Restore the baffle plate according to the instruction in “Pattern A” if the baffle plate will be reused. Restore the baffle plate using “Pads” from service parts according to the instruction “Pattern B” if original baffle plate will not be reused.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.597in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.597in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<title>
Pattern A
</title>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<title>
Pattern B
</title>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Apply adhesive for glass (2) between baffle plate (1) and panels (3) in order to fill up gap.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Fill the openings between panel (2) and panel (3) with the combined “Pads” glued in the original baffle plate position.
</ptxt>
</entry>
</row>
