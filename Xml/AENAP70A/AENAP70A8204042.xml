<servinfosub id = "AENAP70A8204042003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A8204042004">
<testgroup id = "AENAP70A8204042005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204042006">
<title>
Passenger air bag deactivation switch check
</title>
<test1>
<ptxt>
Remove passenger air bag deactivation switch.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection “G168” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Inspect passenger air bag deactivation switch. 
<intxreftitleoff1 refid = "AENAP70A8206027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is passenger air bag deactivation switch in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace passenger air bag deactivation switch.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204042007">
<title>
Passenger air bag deactivation switch circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is in “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G11” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to “G11-16” and “G11-17”.
</ptxt>
</test1>
<test1>
<ptxt>
Measure resistance between “G11-16” and “G168-1”.
</ptxt>
</test1>
<test1>
<ptxt>
Measure resistance between “G11-17” and “G168-2”.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B078">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820029.swf" width = "90.000mm" height = "56.862mm" ver = "01" gw = "217" gh = "145"/>
</testfigure>
</test1>
<question>
Is measured resistance 1&#937; or less?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204042008">
<title>
Passenger air bag deactivation switch circuit check
</title>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Voltage between each of “G11-16” and “G11-17” terminals and ground: approx. 0 V
</ptxt>
<servicetool>
<servicetoolitem id = "L8B079">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW10A820056.swf" width = "90.000mm" height = "55.764mm" ver = "01" gw = "203" gh = "142"/>
</testfigure>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs, referring to 
<intxref refid = "AENAP70A8204006">DTC Clearance</intxref>
 if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENAP70A8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
