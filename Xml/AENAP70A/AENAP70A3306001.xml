<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3306001" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Transfer Oil Level Check
</title>
<s1>
<ptxt>
Lift up vehicle and check oil leakage. Repair leaky point, if any.
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust No.1 pipe. 
<intxreftitleoff1 refid = "AENAP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove transfer oil level / filler plug (1) and check oil for contamination and level. Oil should flow out of plug hole (2) or oil level should reach plug hole (2).
</ptxt>
<ptxt>
If oil is excessive dirty or insufficient, replace oil or pour specified oil up to plug hole.
</ptxt>
</s1>
<s1>
<ptxt>
Apply sealant to thread of level / filler plug, and then tighten it to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3C001" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<torque>
<torqueitem id = "T3C001">
<t-part>
Transfer oil level / filler plug
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330003.jpg" width = "88.000mm" height = "51.805mm" ver = "01" gw = "213" gh = "130"/>
</figure>
<figure>
<graphic graphicname = "IAP70A320003.swf" width = "88.000mm" height = "33.813mm" ver = "01" gw = "80" gh = "79"/>
</figure>
</s1>
<s1>
<ptxt>
Install exhaust No.1 pipe. 
<intxreftitleoff1 refid = "AENAP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check exhaust system for exhaust gas leakage.
</ptxt>
</s1>
<s1>
<ptxt>
Check transfer for oil leakage.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
