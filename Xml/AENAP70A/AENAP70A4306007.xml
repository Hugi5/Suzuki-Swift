<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4C">
<servcat sctnbr = "04" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A4306007" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Brake Caliper Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A4306001">Rear Brake Components</intxrefpoff>
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Be careful not to damage rear brake flexible hoses.
</ptxt>
</item>
<item>
<ptxt>
Never depress brake pedal during service operation shown below.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENAP70A4306007001">
<title>
Removal
</title>
<s1>
<ptxt>
Release parking brake.
</ptxt>
</s1>
<s1>
<ptxt>
Hoist vehicle and remove rear wheel. 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove E-ring (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432004.swf" width = "88.000mm" height = "56.656mm" ver = "01" gw = "177" gh = "144"/>
</figure>
</s1>
<s1>
<ptxt>
Turn lever (1) in arrow direction and remove parking brake cable (2) from lever and bracket (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432005.swf" width = "88.000mm" height = "45.189mm" ver = "01" gw = "172" gh = "112"/>
</figure>
</s1>
<s1>
<ptxt>
Place a container to catch brake fluid from disconnected rear brake flexible hose (3) below rear brake caliper (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove flexible hose joint bolt (1) from rear brake caliper (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A430011.swf" width = "88.000mm" height = "72.692mm" ver = "01" gw = "171" gh = "190"/>
</figure>
</s1>
<s1>
<ptxt>
Remove rear brake caliper pin bolts (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear brake caliper (2) from rear brake caliper carrier (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A430012.swf" width = "88.000mm" height = "57.384mm" ver = "01" gw = "162" gh = "146"/>
</figure>
</s1>
<s1>
<ptxt>
Remove rear brake pads. 
<intxreftitleoff1 refid = "AENAP70A4306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear brake caliper carrier bolts (1) and remove rear brake caliper carrier (2) from rear axle.
</ptxt>
<figure>
<graphic graphicname = "I9P60A432025.swf" width = "88.000mm" height = "51.446mm" ver = "01" gw = "177" gh = "129"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A4306007002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A4306009">Rear Brake Caliper Inspection</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Do not twist rear brake flexible hose when installing rear brake caliper.
</ptxt>
</attention2>
<s1>
<ptxt>
Install rear brake caliper carrier (1) to rear axle and tighten rear brake caliper carrier bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4C003">
<t-part>
Rear brake caliper carrier bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
60
</t-value1>
<t-value2>
6.1
</t-value2>
<t-value3>
44.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A432020.swf" width = "88.000mm" height = "61.818mm" ver = "03" gw = "190" gh = "159"/>
</figure>
</s1>
<s1>
<ptxt>
Turn brake piston (1) in arrow direction by quarter to half turn using special tool to screw brake piston into cylinder.
</ptxt>
<servicetool>
<servicetoolitem id = "L4C004">
<s-part>
(A)
</s-part>
<s-number num = "09945-16030">
09945–16030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A432011.swf" width = "88.000mm" height = "45.775mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Install rear brake caliper while aligning slot of brake piston (2) with protrusion at back of rear brake pad (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432012.swf" width = "88.000mm" height = "52.506mm" ver = "01" gw = "166" gh = "132"/>
</figure>
</s1>
<s1>
<ptxt>
Install rear brake caliper (1) to rear brake caliper carrier and tighten rear brake caliper pin bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4C004">
<t-part>
Rear brake caliper pin bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
26
</t-value1>
<t-value2>
2.7
</t-value2>
<t-value3>
19.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A430013.swf" width = "88.000mm" height = "61.347mm" ver = "01" gw = "162" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Install rear brake flexible hose (1) to rear brake caliper with new flexible hose gasket (2) and tighten flexible hose joint bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T4C005">
<t-part>
Flexible hose joint bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A430014.swf" width = "88.000mm" height = "72.692mm" ver = "01" gw = "171" gh = "190"/>
</figure>
</s1>
<s1>
<ptxt>
Pass parking brake cable through bracket.
</ptxt>
</s1>
<s1>
<ptxt>
Align positions of parking brake cable (2) and bracket (3). Turn lever (1) in arrow direction and install cable (2) to lever (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432014.swf" width = "88.000mm" height = "45.289mm" ver = "01" gw = "172" gh = "112"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.003in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Positioning part
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install E-ring (1) to hold parking brake cable (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A432015.swf" width = "88.000mm" height = "56.656mm" ver = "01" gw = "177" gh = "144"/>
</figure>
</s1>
<s1>
<ptxt>
Fill reservoir with brake fluid and bleed air out of brake system. 
<intxreftitleoff1 refid = "AENAP70A4106004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check that there is no leakage of brake fluid.
</ptxt>
</s1>
<s1>
<ptxt>
Depress brake pedal three or more times with engine running so that rear brake pad clearance adjustment mechanism so that clearance between rear brake disc and brake pads will become appropriate.
</ptxt>
</s1>
<s1>
<ptxt>
Check that brakes are not dragging and that appropriate braking force can be obtained.
</ptxt>
</s1>
<s1>
<ptxt>
Install rear wheel and check that parking brake lever stroke is appropriate and parking brake produces proper braking force. 
<intxreftitleoff1 refid = "AENAP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
