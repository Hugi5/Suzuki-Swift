<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A7214A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Air intake door does not change even if air intake mode is changed
</title>
<diag type = "condition">
<condition>
<ptxt>
Air intake door does not change even if air intake mode is changed
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Check related fuses, and then check for short circuit to ground.
</ptxt>
</action>
<ps>
<ptxt>
Broken air intake door
</ptxt>
</ps>
<action>
<ptxt>
Repair air intake door.
</ptxt>
</action>
<ps>
<ptxt>
Faulty air intake control actuator
</ptxt>
</ps>
<action>
<ptxt>
Check air intake control actuator. 
<intxreftitleoff1 refid = "AENAP70A7216027"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty air intake switch
</ptxt>
</ps>
<action>
<ptxt>
Check air intake switch. 
<intxreftitleoff1 refid = "AENAP70A7216025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
