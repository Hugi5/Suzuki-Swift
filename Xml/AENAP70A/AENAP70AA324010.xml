<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70AA324010" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC P1644
</title>
<servinfosub id = "AENAP70AA324010001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.166in"/>
<colspec colnum = "2" colname = "2" colwidth = "4.039in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P1644: Immobilizer ID Mismatched
</emph>
</ptxt>
<ptxt>
Verification error between ECM and keyless start control module.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Remote controller
</ptxt>
</item>
<item>
<ptxt>
ECM ID code is not registered in keyless start control module
</ptxt>
</item>
<item>
<ptxt>
Remote controller is not registered
</ptxt>
</item>
<item>
<ptxt>
Engine switch circuit / connector
</ptxt>
</item>
<item>
<ptxt>
Engine switch
</ptxt>
</item>
<item>
<ptxt>
Keyless start control module power supply / ground circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
Keyless start control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70AA324010002">
<title>
DTC Troubleshooting
</title>
<attention3>
<ptxt>
If the keyless start control module is one that was registered with another vehicle (used item), remote controllers cannot be registered. Always install a new keyless start control module when replacement is necessary.
</ptxt>
</attention3>
<diag type = "test" id = "AENAP70AA324010003">
<testgroup id = "AENAP70AA324010004">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC in keyless start control module. 
<intxreftitleoff1 refid = "AENAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1189 also detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70AA324018">DTC B1189:Keyless Push Start Model</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA324010005">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Confirm remote controller is in keyless engine start function operation area.
</ptxt>
</test1>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Recheck DTC. 
<intxreftitleoff1 refid = "AENAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC P1644 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (A possibility of taking out remote controller to outside of the operation area.)
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA324010006">
<title>
Keyless start control module power supply and ground circuit check
</title>
<test1>
<ptxt>
Check keyless start control module power supply and ground circuit. 
<intxreftitleoff1 refid = "AENAP70AA504031"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA324010007">
<title>
ECM registration
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENAP70AA326003">ECM Registration:Keyless Push Start Model</intxref>
.
</ptxt>
</test1>
<test1>
<ptxt>
Recheck DTC. 
<intxreftitleoff1 refid = "AENAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC P1644 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (ECM was not registered)
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA324010008">
<title>
Remote controller registration
</title>
<test1>
<ptxt>
Perform “Immobilizer Key Registration”. 
<intxreftitleoff1 refid = "AENAP70AA326002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Recheck DTC. 
<intxreftitleoff1 refid = "AENAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC P1644 still detected?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace ECM and recheck DTC. If DTC P1644 is still detected, replace keyless start control module and recheck DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
ECM: 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Keyless start control module: 
<intxreftitleoff1 refid = "AENAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Remote controller was not registered)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
