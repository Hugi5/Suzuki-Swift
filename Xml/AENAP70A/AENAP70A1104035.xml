<servinfosub id = "AENAP70A1104035003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed by two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to troubleshoot first unexpected DTCs previously detected in “DTC Confirmation Procedure”.
</ptxt>
</item>
<item>
<ptxt>
Confirm that the following DTCs are not detected in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
OCV (P0010 / P0011 / P0013 / P0014)
</ptxt>
</item>
<item>
<ptxt>
Throttle actuator (P2100 / P2101 / P2119)
</ptxt>
</item>
<item>
<ptxt>
Fuel trim system (P0171 / P0172)
</ptxt>
</item>
<item>
<ptxt>
HO2S (P0137 / P0138 / P0140)
</ptxt>
</item>
<item>
<ptxt>
A/F sensor (P0131 / P0132 / P0133)
</ptxt>
</item>
<item>
<ptxt>
MAF sensor (P0100 / P0101 / P0102 / P0103)
</ptxt>
</item>
<item>
<ptxt>
Cylinder misfire detected (P0300 / P0301 / P0302 / P0303 / P0304)
</ptxt>
</item>
<item>
<ptxt>
EVAP canister purge valve (P0443 / P0458 / P0459)
</ptxt>
</item>
<item>
<ptxt>
ECT sensor (P0106 / P0107 / P0108) 
</ptxt>
</item>
<item>
<ptxt>
Wheel speed sensor (P0500) 
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Start engine and drive vehicle at 70 to 90 km/h (43 to 56 mile/h) constantly for 30 min. 
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1104035004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A1104035005">
<testgroup id = "AENAP70A1104035006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104035007">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC.
</ptxt>
</test1>
<question>
Is there DTC(s) detected other than P0420?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104035008">
<title>
Exhaust system inspection
</title>
<test1>
<ptxt>
Check exhaust system for leakage, damage and looseness.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective parts.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104035009">
<title>
HO2S circuit check
</title>
<test1>
<ptxt>
Check signal and ground circuits according to Step 3 under 
<intxref refid = "AENAP70A1104028">DTC P0137 / P0138 / P0140</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104035010">
<title>
A/F sensor signal circuit check
</title>
<test1>
<ptxt>
Check A/F sensor signal circuit according to Step 3 under 
<intxref refid = "AENAP70A1104025">DTC P0131 / P0132 / P2237 / P2243 / P2251/ P2626</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104035011">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Replace exhaust manifold (built in TWC). 
<intxreftitleoff1 refid = "AENAP70A1B06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure.
</ptxt>
</test1>
<question>
Is DTC P0420 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 7.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104035012">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Replace HO2S. 
<intxreftitleoff1 refid = "AENAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC.
</ptxt>
</test1>
<question>
Is DTC P0420 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 8.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104035013">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Replace A/F sensor. 
<intxreftitleoff1 refid = "AENAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC.
</ptxt>
</test1>
<question>
Is DTC P0420 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
