<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9206014" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Lighting and Turn Signal Switch Removal and Installation
</title>
<servinfosub id = "AENAP70A9206014001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove steering column cover. 
<intxreftitleoff1 refid = "AENAP70A6206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect lighting and turn signal switch connector (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove lighting and turn signal switch (1) from steering column while pushing claw (2) in direction of arrow.
</ptxt>
<figure>
<graphic graphicname = "IAP70A920007.jpg" width = "88.000mm" height = "84.623mm" ver = "01" gw = "203" gh = "223"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A9206014002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A9206015">Lighting and Turn Signal Switch Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
