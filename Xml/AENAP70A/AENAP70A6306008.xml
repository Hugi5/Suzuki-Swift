<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6C">
<servcat sctnbr = "06" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A6306008" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Tie-Rod / Steering Rack Boot Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A6306003">Tie-Rod End Removal and Installation</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A6306001">Steering Gear Case Assembly Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A6306007">Steering Rack Boot Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A6306008001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove tie-rod end. 
<intxreftitleoff1 refid = "AENAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove band (2) and steering rack boot clip (1).
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Remove steering rack boot (3) from tie-rod.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630026.swf" width = "88.000mm" height = "53.031mm" ver = "02" gw = "158" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Unbend bent parts of tie-rod lock washer (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove tie-rod (3) from rack (2) as shown.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630027.swf" width = "88.000mm" height = "46.459mm" ver = "01" gw = "197" gh = "115"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A6306008002">
<title>
Installation
</title>
<s1>
<ptxt>
Align groove (5) of rack (2) with protrusion (4) of new tie-rod lock washer (3).
</ptxt>
</s1>
<s1>
<ptxt>
Install tie-rod (1) to rack (2), and then tighten tie-rod to specified torque.
</ptxt>
<torque>
<torqueitem id = "T6C003">
<t-part>
Tie-rod
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9.0
</t-value2>
<t-value3>
65.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A630015.swf" width = "88.000mm" height = "55.132mm" ver = "01" gw = "145" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Bend lock washer (1) at 2 places as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60A630029.swf" width = "88.000mm" height = "51.419mm" ver = "02" gw = "144" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Apply grease to section “A” of tie-rod indicated in figure. Position steering rack boot properly in grooves of steering gear case assembly (or rack side mount) and tie-rod.
</ptxt>
<ptxt>
After this, check to ensure that steering rack boot is free from twist and dent.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease E" id = "M6C001" uid = "24">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25050
</m-number>
<m-name>
SUZUKI Super Grease E
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A630030.swf" width = "88.000mm" height = "33.098mm" ver = "01" gw = "196" gh = "77"/>
</figure>
</s1>
<s1>
<ptxt>
Fasten new band (1) using special tool, and install rack boot clip (2)
</ptxt>
<servicetool>
<servicetoolitem id = "L6C008">
<s-part>
(A)
</s-part>
<s-number num = "09943-55010">
09943–55010
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A630031.swf" width = "88.000mm" height = "40.262mm" ver = "01" gw = "161" gh = "98"/>
</figure>
</s1>
<s1>
<ptxt>
Install tie-rod end. 
<intxreftitleoff1 refid = "AENAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Install steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
