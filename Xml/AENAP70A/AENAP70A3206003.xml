<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Rear Differential Assembly Dismounting and Remounting
</title>
<servinfosub id = "AENAP70A3206003001">
<title>
Dismounting
</title>
<s1>
<ptxt>
Hoist vehicle and remove wheels.
</ptxt>
</s1>
<s1>
<ptxt>
Drain oil from rear differential, if necessary. 
<intxreftitleoff1 refid = "AENAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear drive shafts. 
<intxreftitleoff1 refid = "AENAP70A3126003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove propeller shaft from rear differential. 
<intxreftitleoff1 refid = "AENAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove breather hose (1) from rear differential.
</ptxt>
</s1>
<s1>
<ptxt>
Place jack so that differential assembly will not tilt. 
</ptxt>
</s1>
<s1>
<ptxt>
Remove differential front arm bolts (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove differential rear mounting bolt (3).
</ptxt>
<figure>
<graphic graphicname = "IAP70A320007.swf" width = "88.000mm" height = "57.146mm" ver = "02" gw = "186" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Lower jack with rear differential assembly.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A3206003002">
<title>
Remounting
</title>
<ptxt>
Reverse dismounting procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten each bolt to specified torques.
</ptxt>
<torque>
<torqueitem id = "T3B004">
<t-part>
Differential front arm bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
<torqueitem id = "T3B005">
<t-part>
Differential rear mounting bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
80
</t-value1>
<t-value2>
8.2
</t-value2>
<t-value3>
59.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320008.swf" width = "88.000mm" height = "52.572mm" ver = "02" gw = "186" gh = "133"/>
</figure>
</item>
<item>
<ptxt>
Fill with rear differential oil, if drained, 
<intxreftitleoff1 refid = "AENAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
