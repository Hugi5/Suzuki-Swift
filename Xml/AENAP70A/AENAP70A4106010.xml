<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A4106010" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Brake Light Switch Removal and Installation
</title>
<servinfosub id = "AENAP70A4106010001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove steering column hole cover. 
<intxreftitleoff1 refid = "AENAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect brake light switch connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove brake light switch (2) from brake pedal assembly.
</ptxt>
</s1>
<figure>
<graphic graphicname = "I9P60A410013.swf" width = "88.000mm" height = "51.187mm" ver = "01" gw = "167" gh = "129"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70A4106010002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A4106011">Brake Light Switch Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install brake light switch to obtain following condition: With the brake pedal assembly (2) pulled toward driver’s seat, tip of brake light switch (1) contacts brake pedal assembly.
</ptxt>
<figure>
<graphic graphicname = "I9P60A410045.swf" width = "88.000mm" height = "51.187mm" ver = "02" gw = "167" gh = "129"/>
</figure>
<attention3>
<ptxt>
When the brake light switch is installed correctly, clearance “a” between brake light switch and brake pedal will be as follows:
</ptxt>
<ptxt>
1.1 – 2.1 mm (0.044 – 0.082 in.)
</ptxt>
<figure>
<graphic graphicname = "I9P60A410015.swf" width = "88.000mm" height = "51.402mm" ver = "01" gw = "142" gh = "129"/>
</figure>
</attention3>
</s1>
<s1>
<ptxt>
Connect brake light switch connector.
</ptxt>
</s1>
<s1>
<ptxt>
Install steering column cover. 
<intxreftitleoff1 refid = "AENAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
