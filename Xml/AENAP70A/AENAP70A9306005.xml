<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9C">
<servcat sctnbr = "09" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9306005" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Parking Sensor Removal and Installation (If Equipped)
</title>
<servinfosub id = "AENAP70A9306005001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear bumper. 
<intxreftitleoff1 refid = "AENAP70A9806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect parking sensor connector.
</ptxt>
</s1>
<s1>
<ptxt>
Pull off the parking sensor cover (1) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930025.jpg" width = "88.000mm" height = "106.836mm" ver = "01" gw = "208" gh = "286"/>
</figure>
</s1>
<s1>
<ptxt>
Open claws (1) and remove parking sensor (2) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "I9P60A930026.jpg" width = "88.000mm" height = "63.752mm" ver = "01" gw = "196" gh = "164"/>
</figure>
</s1>
<s1>
<ptxt>
If necessary, remove sensor bracket.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A9306005002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A9306006">Parking Sensor Inspection (If Equipped)</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Clean and degrease the area where the sensor bracket (1) is to be installed.
</ptxt>
</item>
<item>
<ptxt>
Apply primer (an equivalent of SUMITOMO 3M K-520 or 4298UV) to the area where the sensor bracket is to be installed.
</ptxt>
</item>
<item>
<ptxt>
Install sensor bracket in the direction as shown in figure.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I9P60A930039.jpg" width = "88.000mm" height = "98.016mm" ver = "01" gw = "199" gh = "261"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.241in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.505in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.241in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.491in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Mounting position mark
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Mounting direction mark
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Range of primer application
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
