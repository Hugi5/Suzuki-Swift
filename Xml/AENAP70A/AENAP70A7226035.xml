<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A7226035" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Inside Air Temperature Sensor Removal and Installation
</title>
<servinfosub id = "AENAP70A7226035001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering column hole cover from instrument panel. 
<intxreftitleoff1 refid = "AENAP70AA206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Remove connector (1) and aspirator hose (2) from inside air temperature sensor (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove tabs (4) then remove inside air temperature sensor (3) from instrument panel.
</ptxt>
<figure>
<graphic graphicname = "I9P60A723023.swf" width = "88.000mm" height = "65.896mm" ver = "01" gw = "232" gh = "170"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A7226035002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A7226036">Inside Air Temperature Sensor Inspection:Automatic Type</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
