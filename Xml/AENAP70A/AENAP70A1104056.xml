<servinfosub id = "AENAP70A1104056003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to troubleshoot first unexpected DTCs previously detected in “DTC Confirmation Procedure”.
</ptxt>
</item>
<item>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
DTC P0100, P0102 or P0103 is not detected.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Start engine.
</ptxt>
</s1>
<s1>
<ptxt>
Depress accelerator pedal fully, and release it.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1104056004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A1104056005">
<testgroup id = "AENAP70A1104056006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104056007">
<title>
Wire harness check
</title>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
“B2” circuit: Refer to Step 2 through 4 under 
<intxref refid = "AENAP70A1104024">DTC P0122 / P0123</intxref>
.
</ptxt>
</item>
<item>
<ptxt>
“B3” circuit: Refer to Step 2 through 4 under 
<intxref refid = "AENAP70A1104030">DTC P0222 / P0223</intxref>
.
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104056008">
<title>
TP sensor check
</title>
<test1>
<ptxt>
Check TP sensor for performance referring to “Throttle Position (TP) Sensor Performance Check” under 
<intxref refid = "AENAP70A1306004">Electric Throttle Body Assembly On-Vehicle Inspection</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace electric throttle body assembly.
</ptxt>
</action>
</testgroup>
</diag>
