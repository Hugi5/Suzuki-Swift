<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A5206025" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Differential Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A5206010">Manual Transaxle Unit Dismounting and Remounting</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A5206014">Fifth Gear Disassembly and Reassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A5206015">Manual Transaxle Assembly Disassembly and Reassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A5206024">Differential Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A5206025001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove left bearing (1) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B036">
<s-part>
(A)
</s-part>
<s-number num = "09913-65135">
09913–65135
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B037">
<s-part>
(B)
</s-part>
<s-number num = "09913-85230">
09913–85230
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I6RS0E520012.swf" width = "88.000mm" height = "43.438mm" ver = "01" gw = "92" gh = "107"/>
</figure>
</s1>
<s1>
<ptxt>
Remove right bearing in the same manner as step 1).
</ptxt>
</s1>
<s1>
<ptxt>
Support differential case (1) with soft jawed vise.
</ptxt>
</s1>
<s1>
<ptxt>
Remove final gear bolts and remove final gear.
</ptxt>
</s1>
<s1>
<ptxt>
Remove differential pinion shaft pin using special tool and hammer, and then disassemble components parts.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B038">
<s-part>
(A)
</s-part>
<s-number num = "09922-85811">
09922–85811
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I6RS0E520013.swf" width = "88.000mm" height = "47.106mm" ver = "01" gw = "107" gh = "117"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.567in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Differential side gear
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A5206025002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Install differential pinion, side gear and pinion shaft to differential case, and measure backlash and thrust play of differential side gear using special tools as follows.
</ptxt>
<ptxt>
If measured value is out of specification, select suitable side gear washer and check again.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B039">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900–20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B040">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900–20701
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B041">
<s-part>
(C)
</s-part>
<s-number num = "09952-06010">
09952–06010
</s-number>
</servicetoolitem>
</servicetool>
<s2>
<ptxt>
Differential side gear backlash [a]
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Hold differential assembly with soft jawed vise and apply measuring tip of dial gauge to side gear as shown in figure.
</ptxt>
</item>
<item>
<ptxt>
Fixing differential pinion, turn side gear back and forth and read dial gauge.
</ptxt>
</item>
</list1>
<spec>
<title>
Differential side gear backlash
</title>
<ptxt>
0.10 – 0.15 mm (0.0039 – 0.0059 in.)
</ptxt>
</spec>
</s2>
<s2>
<ptxt>
Differential side gear thrust play [b]
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Hold differential assembly with soft jawed vise and apply measuring tip of dial gauge to side gear as shown in figure.
</ptxt>
</item>
<item>
<ptxt>
Move side gear up and down by hand and read dial gauge.
</ptxt>
</item>
</list1>
<spec>
<title>
Differential side gear thrust play
</title>
<ptxt>
0.03 – 0.31 mm (0.001 – 0.012 in.)
</ptxt>
</spec>
</s2>
<figure>
<graphic graphicname = "IAP70A520032.swf" width = "88.000mm" height = "92.158mm" ver = "03" gw = "147" gh = "245"/>
</figure>
</s1>
<s1>
<ptxt>
Install new differential pinion shaft pin from right side till the depth from differential case surface is about 1.2 mm (0.047 in.).
</ptxt>
</s1>
<s1>
<ptxt>
Press-fit left bearing (1) using special tool and hydraulic press.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B042">
<s-part>
(A)
</s-part>
<s-number num = "09951-16080">
09951–16080
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I2RH01520074.swf" width = "88.000mm" height = "73.733mm" ver = "01" gw = "139" gh = "192"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.344in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Differential case
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Press-fit right bearing (1) using special tools and hydraulic press.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B043">
<s-part>
(A)
</s-part>
<s-number num = "09925-15410">
09925–15410
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B044">
<s-part>
(B)
</s-part>
<s-number num = "09940-54910">
09940–54910
</s-number>
</servicetoolitem>
<servicetoolitem id = "L5B045">
<s-part>
(C)
</s-part>
<s-number num = "09913-85230">
09913–85230
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I6RS0E520038.swf" width = "88.000mm" height = "56.165mm" ver = "01" gw = "108" gh = "142"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.258in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.535in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
2.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Differential case
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Differential side left bearing
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Hold differential assembly with soft jawed vise (3), install final gear (2) and then tighten new final gear bolts (1).
</ptxt>
<attention2>
<ptxt>
Be sure to use new bolt with pre-coated adhesive. Otherwise, bolt may loosen.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T5B020">
<t-part>
Final gear bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
90
</t-value1>
<t-value2>
9.2
</t-value2>
<t-value3>
66.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I5RW0A520049.swf" width = "88.000mm" height = "42.449mm" ver = "01" gw = "158" gh = "103"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
