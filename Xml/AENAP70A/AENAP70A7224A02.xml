<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A7224A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
No cool air comes out (magnet clutch does not operate)
</title>
<diag type = "condition">
<condition>
<ptxt>
No cool air comes out (magnet clutch does not operate)
</ptxt>
</condition>
<ps>
<ptxt>
No refrigerant
</ptxt>
</ps>
<action>
<ptxt>
Perform recovery, evacuation and charge. 
<intxreftitleoff1 refid = "AENAP70A7226001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Check related fuses, and then check for short circuit to ground.
</ptxt>
</action>
<ps>
<ptxt>
Faulty A/C switch
</ptxt>
</ps>
<action>
<ptxt>
Check A/C switch. 
<intxreftitleoff1 refid = "AENAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty evaporator temperature sensor
</ptxt>
</ps>
<action>
<ptxt>
Check evaporator temperature sensor. 
<intxreftitleoff1 refid = "AENAP70A7226019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty A/C refrigerant pressure sensor
</ptxt>
</ps>
<action>
<ptxt>
Check A/C refrigerant pressure sensor. 
<intxreftitleoff1 refid = "AENAP70A7226022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or grounding
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty thermostat
</ptxt>
</ps>
<action>
<ptxt>
Check thermostat. 
<intxreftitleoff1 refid = "AENAP70A1606009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
.
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECT sensor
</ptxt>
</ps>
<action>
<ptxt>
Check ECT sensor. 
<intxreftitleoff1 refid = "AENAP70A1306012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty ECM
</ptxt>
</ps>
<action>
<ptxt>
Check ECM. 
<intxreftitleoff1 refid = "AENAP70A7224040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty HVAC control module
</ptxt>
</ps>
<action>
<ptxt>
Check HVAC control module. 
<intxreftitleoff1 refid = "AENAP70A7224038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty magnet clutch
</ptxt>
</ps>
<action>
<ptxt>
Check magnet clutch. 
<intxreftitleoff1 refid = "AENAP70A7226047"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loosened or broken compressor drive belt
</ptxt>
</ps>
<action>
<ptxt>
Check compressor drive belt. 
<intxreftitleoff1 refid = "AENAP70A7226043"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty compressor
</ptxt>
</ps>
<action>
<ptxt>
Check compressor. 
<intxreftitleoff1 refid = "AENAP70A7226048"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty compressor relay
</ptxt>
</ps>
<action>
<ptxt>
Check compressor relay. 
<intxreftitleoff1 refid = "AENAP70A7226042"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<ptxt>
Check BCM. 
<intxreftitleoff1 refid = "AENAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty auto A/C panel
</ptxt>
</ps>
<action>
<ptxt>
Check auto A/C panel. 
<intxreftitleoff1 refid = "AENAP70A7224037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
