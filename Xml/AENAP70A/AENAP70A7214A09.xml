<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A7214A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Cool air comes out only at high speed
</title>
<diag type = "condition">
<condition>
<ptxt>
Cool air comes out only at high speed
</ptxt>
</condition>
<ps>
<ptxt>
Clogged condenser
</ptxt>
</ps>
<action>
<ptxt>
Check condenser. 
<intxreftitleoff1 refid = "AENAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Insufficient charge of refrigerant
</ptxt>
</ps>
<action>
<ptxt>
Check amount of refrigerant and system for leaks.
</ptxt>
</action>
<ps>
<ptxt>
Air in A/C system
</ptxt>
</ps>
<action>
<ptxt>
Replace condenser, and then perform evacuation and refrigerant charge. 
<intxreftitleoff1 refid = "AENAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose compressor drive belt
</ptxt>
</ps>
<action>
<ptxt>
Check compressor drive belt. 
<intxreftitleoff1 refid = "AENAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty compressor
</ptxt>
</ps>
<action>
<ptxt>
Check compressor.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
