<servinfosub id = "AENAP70A4604020003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A4604020004">
<testgroup id = "AENAP70A4604020005">
<question>
Was “ESP<sup>®</sup> System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A4604001">ESP® System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A4604020006">
<title>
ESP® OFF switch check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Remove ESP<sup>®</sup> OFF switch. 
<intxreftitleoff1 refid = "AENAP70A4606017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Check each terminal of ESP<sup>®</sup> OFF switch for proper connection.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check ESP<sup>®</sup> OFF switch. 
<intxreftitleoff1 refid = "AENAP70A4606018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace ESP<sup>®</sup> OFF switch.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A4604020007">
<title>
ESP® OFF switch circuit check
</title>
<test1>
<ptxt>
Disconnect “E24” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to “E24-38” terminal.
</ptxt>
</test1>
<test1>
<ptxt>
If connection is OK, check resistance between “E24-38” terminal and ground.
</ptxt>
</test1>
<question>
Is resistance infinity?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ESP<sup>®</sup> hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace “A1” circuit is shorted.
</ptxt>
</action>
</testgroup>
</diag>
