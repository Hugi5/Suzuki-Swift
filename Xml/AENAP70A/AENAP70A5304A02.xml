<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A5304A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Dragging clutch
</title>
<diag type = "condition">
<condition>
<ptxt>
Dragging clutch
</ptxt>
</condition>
<ps>
<ptxt>
Improper clutch pedal free travel
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace clutch pedal arm and/or clutch master cylinder.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Clutch pedal arm: 
<intxreftitleoff1 refid = "AENAP70A5306016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Clutch master cylinder: 
<intxreftitleoff1 refid = "AENAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Weakened diaphragm spring or worn spring tip
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch cover. 
<intxreftitleoff1 refid = "AENAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Rusted input shaft spline
</ptxt>
</ps>
<action>
<ptxt>
Lubricate input shaft spline.
</ptxt>
</action>
<ps>
<ptxt>
Damaged or worn spline of transaxle input shaft
</ptxt>
</ps>
<action>
<ptxt>
Replace input shaft. 
<intxreftitleoff1 refid = "AENAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Excessively wobbly clutch disc
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Clutch facings broken or dirty with oil
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Fluid leakage
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace clutch system.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
