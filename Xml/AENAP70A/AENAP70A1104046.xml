<servinfosub id = "AENAP70A1104046004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A1104046005">
<testgroup id = "AENAP70A1104046006">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Clear DTC. 
<intxreftitleoff1 refid = "AENAP70A1104004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Perform DTC confirmation procedure and check DTC.
</ptxt>
</test1>
<question>
Is DTC P0607 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check for intermittent trouble. 
<intxreftitleoff1 refid = "AENAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104046007">
<title>
ECM power supply and ground circuit check
</title>
<test1>
<ptxt>
Check ECM power supply circuit and ECM ground circuit. 
<intxreftitleoff1 refid = "AENAP70A1104071"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair ECM power or ground circuit.
</ptxt>
</action>
</testgroup>
