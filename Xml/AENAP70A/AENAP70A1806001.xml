<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1H">
<servcat sctnbr = "01" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1806001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Spark Plug Removal and Installation
</title>
<servinfosub id = "AENAP70A1806001001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove ignition coil assemblies. 
<intxreftitleoff1 refid = "AENAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove spark plugs.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1806001002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1806002">Spark Plug Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install spark plugs and tighten them to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1H001">
<t-part>
Spark plug
</t-part>
<t-value1>
18
</t-value1>
<t-value2>
1.8
</t-value2>
<t-value3>
13.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Install ignition coil assemblies. 
<intxreftitleoff1 refid = "AENAP70A1806003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
