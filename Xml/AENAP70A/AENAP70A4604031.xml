<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A4604031" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC C1062
</title>
<servinfosub id = "AENAP70A4604031001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "3.599in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.599in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
C1062: Solenoid Valve Continuous Operation Failure
</emph>
</ptxt>
<ptxt>
Solenoid valve is activated for more than specified time using “Active Test” of SUZUKI scan tool.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ESP<sup>®</sup> control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70A4604031002">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A4604031003">
<testgroup id = "AENAP70A4604031004">
<title>
DTC check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Leave vehicle for more than 5 minutes, for cooling down of ESP<sup>®</sup> system.
</ptxt>
</test1>
<test1>
<ptxt>
Perform 
<intxref refid = "AENAP70A4604005">DTC Check</intxref>
.
</ptxt>
</test1>
<question>
Is DTC C1062 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ESP<sup>®</sup> hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
