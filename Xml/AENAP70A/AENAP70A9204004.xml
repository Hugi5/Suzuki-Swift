<ptxt>
Only one low-beam headlight lights up
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Replace fuse and check for short circuit.
</ptxt>
</action>
<ps>
<ptxt>
Blown bulb
</ptxt>
</ps>
<action>
<ptxt>
Replace bulb.
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<condition>
<ptxt>
Both low-beam headlights do not light up
</ptxt>
</condition>
<ps>
<ptxt>
Faulty lighting and turn signal switch
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENAP70A9206015">Lighting and Turn Signal Switch Inspection</intxref>
.
</ptxt>
</action>
<ps>
<ptxt>
Blown bulbs
</ptxt>
</ps>
<action>
<ptxt>
Replace bulbs if all above items are normal.
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
