<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4D">
<servcat sctnbr = "04" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A4406004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Parking Brake Cable Removal and Installation
</title>
<servinfosub id = "AENAP70A4406004001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect parking brake cable from lever of rear brake caliper. 
<intxreftitleoff1 refid = "AENAP70A4306007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove floor console rear box. 
<intxreftitleoff1 refid = "AENAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect parking brake cable from vehicle. 
<intxreftitleoff1 refid = "AENAP70A4406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<attention3>
<ptxt>
If necessary to remove both right and left parking brake cables, repeat above steps.
</ptxt>
</attention3>
</servinfosub>
<servinfosub id = "AENAP70A4406004002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Install clamps properly. 
<intxreftitleoff1 refid = "AENAP70A4406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tighten each bolt to specified torque. 
<intxreftitleoff1 refid = "AENAP70A4406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check that parking brake cable end is installed to equalizer and lever of rear brake caliper securely.
</ptxt>
</item>
<item>
<ptxt>
Adjust parking brake cable. 
<intxreftitleoff1 refid = "AENAP70A4406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
After completion of the installation and adjustment of parking brake lever stroke, make sure that brake system is operating properly.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
