<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A3204A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Gear noise
</title>
<diag type = "condition">
<condition>
<ptxt>
Gear noise
</ptxt>
</condition>
<ps>
<ptxt>
Deteriorated or water mixed lubricant
</ptxt>
</ps>
<action>
<ptxt>
Repair and replenish. 
<intxreftitleoff1 refid = "AENAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Inadequate or insufficient lubricant
</ptxt>
</ps>
<action>
<ptxt>
Repair and replenish. 
<intxreftitleoff1 refid = "AENAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Maladjusted backlash between bevel pinion and gear
</ptxt>
</ps>
<action>
<ptxt>
Adjust as prescribed. 
<intxreftitleoff1 refid = "AENAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Improper tooth contact in the mesh between bevel pinion and gear
</ptxt>
</ps>
<action>
<ptxt>
Adjust or replace. 
<intxreftitleoff1 refid = "AENAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose bevel gear securing bolts
</ptxt>
</ps>
<action>
<ptxt>
Replace or retighten. 
<intxreftitleoff1 refid = "AENAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Damaged side gear(s) or differential pinion(s)
</ptxt>
</ps>
<action>
<ptxt>
Replace. 
<intxreftitleoff1 refid = "AENAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
