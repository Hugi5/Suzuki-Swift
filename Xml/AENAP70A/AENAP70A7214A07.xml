<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A7214A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Cool air does not come out or insufficient cooling (magnet clutch in normal operation)
</title>
<diag type = "condition">
<condition>
<ptxt>
Cool air does not come out or insufficient cooling (magnet clutch in normal operation)
</ptxt>
</condition>
<ps>
<ptxt>
Insufficient or excessive charge of refrigerant
</ptxt>
</ps>
<action>
<ptxt>
Check amount of refrigerant and system for leaks.
</ptxt>
</action>
<ps>
<ptxt>
Clogged condenser
</ptxt>
</ps>
<action>
<ptxt>
Check condenser. 
<intxreftitleoff1 refid = "AENAP70A7216005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Clogged or frosted A/C evaporator
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Check A/C evaporator and evaporator temperature sensor.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
A/C evaporator: 
<intxreftitleoff1 refid = "AENAP70A7216015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Evaporator temperature sensor: 
<intxreftitleoff1 refid = "AENAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Faulty evaporator temperature sensor
</ptxt>
</ps>
<action>
<ptxt>
Check evaporator temperature sensor. 
<intxreftitleoff1 refid = "AENAP70A7216017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty expansion valve
</ptxt>
</ps>
<action>
<ptxt>
Check expansion valve. 
<intxreftitleoff1 refid = "AENAP70A7216019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose or broken compressor drive belt
</ptxt>
</ps>
<action>
<ptxt>
Check compressor drive belt. 
<intxreftitleoff1 refid = "AENAP70A7216036"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Slipping magnet clutch
</ptxt>
</ps>
<action>
<ptxt>
Check magnet clutch. 
<intxreftitleoff1 refid = "AENAP70A7216040"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty compressor
</ptxt>
</ps>
<action>
<ptxt>
Check compressor.
</ptxt>
</action>
<ps>
<ptxt>
Air in A/C system
</ptxt>
</ps>
<action>
<ptxt>
Replace condenser, and then perform evacuation and refrigerant charge. 
<intxreftitleoff1 refid = "AENAP70A7216001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Air leaking from HVAC unit or air duct
</ptxt>
</ps>
<action>
<ptxt>
Repair HVAC unit or air duct.
</ptxt>
</action>
<ps>
<ptxt>
Faulty heater and ventilation system
</ptxt>
</ps>
<action>
<ptxt>
Check HVAC unit.
</ptxt>
</action>
<ps>
<ptxt>
Faulty blower motor
</ptxt>
</ps>
<action>
<ptxt>
Check blower motor. 
<intxreftitleoff1 refid = "AENAP70A7216010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Excessive compressor oil in A/C system
</ptxt>
</ps>
<action>
<ptxt>
Drain excessive compressor oil from A/C system circuit and compressor.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
