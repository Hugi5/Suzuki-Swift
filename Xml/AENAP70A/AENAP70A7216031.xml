<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A7216031" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Duct Removal and Installation (If Equipped)
</title>
<servinfosub id = "AENAP70A7216031001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front seats. 
<intxreftitleoff1 refid = "AENAP70A9706002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove floor console front box. 
<intxreftitleoff1 refid = "AENAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Take off carpet till rear ducts are totally exposed.
</ptxt>
</s1>
<s1>
<ptxt>
Remove right and left rear ducts (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove center rear duct (2) if necessary.
</ptxt>
<figure>
<graphic graphicname = "IAP70A721040.swf" width = "88.000mm" height = "71.569mm" ver = "01" gw = "238" gh = "186"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.365in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.368in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
HVAC unit
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A7216031002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
