<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A5306013" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Clutch Operating Cylinder Assembly Removal and Installation
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Do not allow fluid to get on painted surfaces. It may cause painted surface damage.
</ptxt>
</item>
<item>
<ptxt>
Do not disassemble clutch operating cylinder assembly.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENAP70A5306013001">
<title>
Removal
</title>
<s1>
<ptxt>
Clean around brake master cylinder reservoir cap and remove fluid from brake master cylinder reservoir with syringe or such.
</ptxt>
</s1>
<s1>
<ptxt>
Dismount transaxle assembly. 
<intxreftitleoff1 refid = "AENAP70A5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove clip (1), to disconnect clutch pipe joint (2).
</ptxt>
</s1>
<s1>
<ptxt>
Loosen clutch fluid pipe flare nut (3) of clutch operating cylinder assembly (4).
</ptxt>
</s1>
<s1>
<ptxt>
Remove clutch pipe joint sleeve (5) from transaxle, and then remove clutch fluid pipe (6).
</ptxt>
</s1>
<s1>
<ptxt>
Remove clutch operating cylinder assembly from transaxle.
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A530009.jpg" width = "88.000mm" height = "99.746mm" ver = "01" gw = "227" gh = "266"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70A5306013002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A5306014">Clutch Operating Cylinder Assembly Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install clutch operating cylinder assembly (2) to transaxle. Tighten clutch operating cylinder assembly bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5C005">
<t-part>
Clutch operating cylinder assembly bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
10
</t-value1>
<t-value2>
1.0
</t-value2>
<t-value3>
7.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect clutch fluid pipe (4) to clutch operating cylinder assembly temporarily.
</ptxt>
</s1>
<s1>
<ptxt>
Install clutch pipe joint sleeve (3) to transaxle securely and then tighten clutch fluid pipe flare nut (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5C006">
<t-part>
Clutch fluid pipe flare nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
16
</t-value1>
<t-value2>
1.6
</t-value2>
<t-value3>
12.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect clutch pipe joint (5), and install clip (6).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530010.jpg" width = "88.000mm" height = "99.746mm" ver = "01" gw = "227" gh = "266"/>
</figure>
</s1>
<s1>
<ptxt>
Remount transaxle assembly. 
<intxreftitleoff1 refid = "AENAP70A5206010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Bleed air from clutch system and check clutch pedal free travel.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Air bleeding of clutch system: 
<intxreftitleoff1 refid = "AENAP70A5306007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Clutch pedal free travel: 
<intxreftitleoff1 refid = "AENAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
