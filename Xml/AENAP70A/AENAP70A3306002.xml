<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3306002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Transfer Oil Change
</title>
<s1>
<ptxt>
Before changing or inspecting oil, be sure to stop engine and lift vehicle horizontally.
</ptxt>
</s1>
<s1>
<ptxt>
Check leakage.
</ptxt>
<ptxt>
If leakage exists, correct it.
</ptxt>
<attention3>
<ptxt>
Whenever vehicle is hoisted for any other service work than oil change, also be sure to check for oil leakage.
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Remove exhaust No.1 pipe. 
<intxreftitleoff1 refid = "AENAP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove transfer oil level / filler plug (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove transfer oil drain plug (2), and drain oil.
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Apply sealant to thread of transfer oil drain plug (1), and tighten it to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3C002" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<torque>
<torqueitem id = "T3C002">
<t-part>
Transfer oil drain plug
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Replenish new specified oil up to oil level / filler plug hole (3).
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Hypoid gear oil must be used for transfer.
</ptxt>
</item>
<item>
<ptxt>
It is highly recommended to use “SUZUKI GEAR OIL 75W-85”.
</ptxt>
</item>
</list1>
</attention3>
<spec>
<title>
Transfer oil specification
</title>
<ptxt>
: SUZUKI GEAR OIL 99000-22B30
</ptxt>
<ptxt>
: API GL-5 (For SAE classification, refer to viscosity chart.)
</ptxt>
</spec>
<spec>
<title>
Viscosity chart
</title>
<figure>
<graphic graphicname = "IAP70A320004.swf" width = "88.000mm" height = "26.126mm" ver = "02" gw = "201" gh = "58"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Outside temperature
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</spec>
<spec-sdm>
<sdm-title>
Transfer oil capacity
</sdm-title>
<sdm1>
<sdm-condition>
Reference
</sdm-condition>
<sdm-value>
0.65 liters (1.4/1.1 US/Imp. pt)
</sdm-value>
</sdm1>
</spec-sdm>
</s1>
<s1>
<ptxt>
Apply sealant to thread of transfer oil level / filler plug, and then tighten it to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3C003" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<torque>
<torqueitem id = "T3C003">
<t-part>
Transfer oil level / filler plug
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330002.jpg" width = "88.000mm" height = "51.805mm" ver = "02" gw = "213" gh = "130"/>
</figure>
<figure>
<graphic graphicname = "IAP70A320006.swf" width = "88.000mm" height = "33.474mm" ver = "01" gw = "80" gh = "78"/>
</figure>
</s1>
<s1>
<ptxt>
Install exhaust No.1 pipe. 
<intxreftitleoff1 refid = "AENAP70A1B06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check exhaust system for exhaust gas leakage.
</ptxt>
</s1>
<s1>
<ptxt>
Check transfer for oil leakage.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
