<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1306025" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
MAF and IAT Sensor Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1306024">MAF and IAT Sensor On-Vehicle Inspection</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
When servicing MAF and IAT sensor, be sure to observe the following precautions.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Do not disassemble MAF and IAT sensor.
</ptxt>
</item>
<item>
<ptxt>
Do not drop or expose MAF and IAT sensor to any shock. Any sensor that has been dropped must be replaced.
</ptxt>
</item>
<item>
<ptxt>
Do not clean MAF and IAT sensor.
</ptxt>
</item>
<item>
<ptxt>
Do not blow compressed air to MAF and IAT sensor using air blow gun or the like.
</ptxt>
</item>
<item>
<ptxt>
Do not put finger or any other object into MAF and IAT sensor.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENAP70A1306025001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect MAF and IAT sensor connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove MAF and IAT sensor (1) from air cleaner case (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A131010.jpg" width = "88.000mm" height = "48.136mm" ver = "01" gw = "185" gh = "120"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70A1306025002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1306026">MAF and IAT Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten MAF and IAT sensor screws (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1C009">
<t-part>
MAF and IAT sensor screw
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
1.2
</t-value1>
<t-value2>
0.12
</t-value2>
<t-value3>
0.9
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131011.jpg" width = "88.000mm" height = "48.136mm" ver = "01" gw = "185" gh = "120"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
