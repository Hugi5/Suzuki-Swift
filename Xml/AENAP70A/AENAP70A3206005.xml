</s-part>
<s-number num = "09922-76420">
09922–76420
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3B017">
<s-part>
(E)
</s-part>
<s-number num = "09922-76340">
09922–76340
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3B018">
<s-part>
(F)
</s-part>
<s-number num = "09922-76150">
09922–76150
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RS0D320021.swf" width = "183.000mm" height = "109.928mm" ver = "01" gw = "406" gh = "295"/>
