</s1>
<s1>
<ptxt>
Set special tools and make drive bevel pinion mounting dummy.
</ptxt>
<servicetool>
<servicetoolitem id = "L3B019">
<s-part>
(A)
</s-part>
<s-number num = "09922-76120">
09922–76120
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3B020">
<s-part>
(B)
</s-part>
<s-number num = "09922-76250">
09922–76250
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Install dial gauge (1) to mounting dummy as shown in figure.
</ptxt>
<spec>
<title>
Special tool set distance
</title>
<ptxt>
“a”: 34.0 mm (1.339 in.)
</ptxt>
<ptxt>
“b”: 0 mm (0.000 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I5RW0A320047.swf" width = "88.000mm" height = "82.581mm" ver = "01" gw = "179" gh = "217"/>
</figure>
</s1>
<s1>
<ptxt>
Set special tools and make drive bevel pinion dummy.
</ptxt>
<servicetool>
<servicetoolitem id = "L3B021">
<s-part>
(A)
</s-part>
<s-number num = "09922-76140">
09922–76140
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3B022">
<s-part>
(B)
</s-part>
<s-number num = "09922-76420">
09922–76420
