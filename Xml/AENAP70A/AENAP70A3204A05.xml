<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A3204A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Oil leakage
</title>
<diag type = "condition">
<condition>
<ptxt>
Oil leakage
</ptxt>
</condition>
<ps>
<ptxt>
Clogged breather plug
</ptxt>
</ps>
<action>
<ptxt>
Clean.
</ptxt>
</action>
<ps>
<ptxt>
Worn or damaged oil seal
</ptxt>
</ps>
<action>
<ptxt>
Replace. 
<intxreftitleoff1 refid = "AENAP70A3206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Excessive oil
</ptxt>
</ps>
<action>
<ptxt>
Adjust oil level. 
<intxreftitleoff1 refid = "AENAP70A3206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
