<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A7216028" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Actuator Linkage Inspection
</title>
<list1 type = "unordered">
<item>
<ptxt>
Check that each actuator linkage operates smoothly.
</ptxt>
</item>
<item>
<ptxt>
Check actuator rod for bend.
</ptxt>
</item>
<item>
<ptxt>
Check each actuator linkage for breakage.
</ptxt>
</item>
<item>
<ptxt>
Make sure that there is not any obstruction in operating range of actuator linkage.
</ptxt>
<ptxt>
If check result is not OK, repair or replace faulty part(s).
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
