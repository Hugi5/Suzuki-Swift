<servinfosub id = "AENAP70A6304014003">
<title>
DTC Confirmation Procedure
</title>
<ptxt>
Run engine at idle speed for more than 5 seconds.
</ptxt>
</servinfosub>
<servinfosub id = "AENAP70A6304014004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A6304014005">
<testgroup id = "AENAP70A6304014006">
<question>
Was “P/S System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A6304001">P/S System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A6304014007">
<title>
P/S control module main power supply and ground circuit check
</title>
<test1>
<ptxt>
Check “A1” and “A2” circuits. 
<intxreftitleoff1 refid = "AENAP70A6304021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A6304014008">
<title>
P/S control module power supply voltage check
</title>
<test1>
<ptxt>
Measure battery voltage with engine running at idle speed.
</ptxt>
</test1>
<test1>
<ptxt>
Measure battery voltage with engine running at 3,000 rpm.
</ptxt>
</test1>
<question>
Are voltage between 9 V and 15 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace P/S control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A6306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check charging system. 
<intxreftitleoff1 refid = "AENAP70A1A04003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
