<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1406016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Engine Assembly Removal and Installation
</title>
<servinfosub id = "AENAP70A1406016001">
<title>
Removal
</title>
<s1>
<ptxt>
Relieve fuel pressure. 
<intxreftitleoff1 refid = "AENAP70A1706003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery. 
<intxreftitleoff1 refid = "AENAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect ECM connectors. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove battery bracket with ECM. 
<intxreftitleoff1 refid = "AENAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove right and left side engine undercovers.
</ptxt>
</s1>
<s1>
<ptxt>
Drain the following oils and fluid if necessary.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Engine oil: 
<intxreftitleoff1 refid = "AENAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manual transaxle oil: 
<intxreftitleoff1 refid = "AENAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Transfer oil: 
<intxreftitleoff1 refid = "AENAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove air cleaner assembly. 
<intxreftitleoff1 refid = "AENAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
With hose connected, detach A/C compressor from its bracket. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C model: 
<intxreftitleoff1 refid = "AENAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<attention2>
<ptxt>
Suspend removed A/C compressor at a place where no damage will be caused during removal and installation of engine assembly.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Disconnect the following electric wires/connectors and each clamps.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery ground cable (1)
</ptxt>
</item>
<item>
<ptxt>
Connectors (2) in main fuse box
</ptxt>
</item>
<item>
<ptxt>
Electric load current sensor connector (3)
</ptxt>
</item>
<item>
<ptxt>
Connector (4) in individual circuit fuse box No.1
</ptxt>
<figure>
<graphic graphicname = "I9P60A141043.jpg" width = "88.000mm" height = "60.102mm" ver = "01" gw = "199" gh = "154"/>
</figure>
</item>
</list1>
</s1>
<s1>
<ptxt>
Disconnect the following cables.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Gear select control cable (1)
</ptxt>
</item>
<item>
<ptxt>
Gear shift control cable (2)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140002.jpg" width = "88.000mm" height = "62.413mm" ver = "01" gw = "199" gh = "160"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect the following hoses.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Brake booster hose (1)
</ptxt>
</item>
<item>
<ptxt>
Radiator inlet and outlet hoses (2)
</ptxt>
</item>
<item>
<ptxt>
Heater inlet and outlet hoses (3)
</ptxt>
</item>
<item>
<ptxt>
Fuel feed hose (4)
</ptxt>
</item>
<item>
<ptxt>
Clutch fluid hose (5) 
<intxreftitleoff1 refid = "AENAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A140003.jpg" width = "88.000mm" height = "112.325mm" ver = "02" gw = "199" gh = "302"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Disconnect steering lower shaft from pinion shaft. 
<intxreftitleoff1 refid = "AENAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove stabilizer bar joints from stabilizer bar. 
<intxreftitleoff1 refid = "AENAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect tie-rod end from steering knuckle. 
<intxreftitleoff1 refid = "AENAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect right and left drive shaft joints from steering knuckle. 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove exhaust No.1 pipe and exhaust center pipe. 
<intxreftitleoff1 refid = "AENAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove propeller shaft assembly. 
<intxreftitleoff1 refid = "AENAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Support front suspension frame (1), transaxle case (2) and cylinder block (3) using jack.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front suspension frame bolts (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A140004.jpg" width = "88.000mm" height = "55.276mm" ver = "01" gw = "199" gh = "140"/>
</figure>
</s1>
<s1>
<ptxt>
Remove engine left mounting bracket bolt (1) and nuts (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A140005.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.309in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.690in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.253in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.704in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Upper side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lower side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove engine right mounting bracket bolt (1) and nuts (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A140006.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1>
<ptxt>
Before removing engine make sure that all hoses, electric wires and cables are disconnected from engine.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Lower engine with transaxle, front suspension frame, drive shafts, P/S gear case assembly all together.
</ptxt>
<attention2>
<ptxt>
Before lowering engine, in order to avoid damage to A/C compressor, make clearance between A/C compressor and engine by suspending A/C compressor.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Disconnect engine harness from engine and transaxle, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Remove front drive shaft assembly, if necessary. 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front suspension frame, if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Remove transfer if necessary. 
<intxreftitleoff1 refid = "AENAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect transaxle from engine, if necessary. 
<intxreftitleoff1 refid = "AENAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove clutch cover and clutch disc, if necessary. 
<intxreftitleoff1 refid = "AENAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove flywheel, if necessary. 
<intxreftitleoff1 refid = "AENAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1406016002" page = "2">
<title>
Installation
</title>
<s1>
<ptxt>
Install flywheel, if removed. 
<intxreftitleoff1 refid = "AENAP70A1406021"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install clutch cover and clutch disc, if removed. 
<intxreftitleoff1 refid = "AENAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install transaxle to engine, if removed. 
<intxreftitleoff1 refid = "AENAP70A5206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install transfer if removed. 
<intxreftitleoff1 refid = "AENAP70A3306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install front suspension frame, if removed. 
<intxreftitleoff1 refid = "AENAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install front drive shaft assembly, if removed. 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install engine harness to engine and transaxle and then tighten engine harness ground bolt (1) to specified torque, if removed.
</ptxt>
<torque>
<torqueitem id = "T1D008">
<t-part>
Engine harness ground bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140007.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "199" gh = "129"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Lift up engine with transaxle, front suspension frame, drive shafts, P/S gear case assembly all together.
</ptxt>
<attention2>
<ptxt>
Before lifting engine, in order to avoid damage to A/C compressor, make clearance between A/C compressor and engine by suspending A/C compressor.
</ptxt>
</attention2>
</s1>
<s1>
<ptxt>
Install engine right mounting bracket bolt (1) and nuts (2).
</ptxt>
<torque>
<torqueitem id = "T1D009">
<t-part>
Engine right mounting bracket bolt and nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140008.jpg" width = "88.000mm" height = "58.578mm" ver = "01" gw = "199" gh = "150"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Tighten engine left mounting bracket bolts (1) and nuts (2) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1D010">
<t-part>
Engine left mounting bracket bolt and nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A140009.jpg" width = "88.000mm" height = "113.541mm" ver = "01" gw = "199" gh = "305"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.428in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.697in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.363in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.705in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Upper side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Lower side
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Tighten suspension frame bolts to specified torque. 
<intxreftitleoff1 refid = "AENAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install propeller shaft assembly. 
<intxreftitleoff1 refid = "AENAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install exhaust No.1 pipe and exhaust center pipe. 
<intxreftitleoff1 refid = "AENAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect right and left drive shaft joints to steering knuckle. 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect tie-rod end from steering knuckle. 
<intxreftitleoff1 refid = "AENAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Install stabilizer bar joints to stabilizer bar. 
<intxreftitleoff1 refid = "AENAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Connect steering lower shaft from pinion shaft. 
<intxreftitleoff1 refid = "AENAP70A6206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install all other removed electric wires, connectors and hoses to original locations.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Tighten battery ground terminal bolt (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A141052.jpg" width = "88.000mm" height = "60.441mm" ver = "02" gw = "199" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Connect gear shift control cable. 
<intxreftitleoff1 refid = "AENAP70A5206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install A/C compressor to its bracket. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model 
<intxreftitleoff1 refid = "AENAP70A7216038"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C model 
<intxreftitleoff1 refid = "AENAP70A7226045"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Install A/C compressor drive belt.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual A/C model: 
<intxreftitleoff1 refid = "AENAP70A7216037"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C model: 
<intxreftitleoff1 refid = "AENAP70A7226044"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Install air cleaner assembly. 
<intxreftitleoff1 refid = "AENAP70A1406004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Check to ensure that all removed parts are back in place. Reinstall any necessary parts which have not been reinstalled.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Refill the following oils and fluid if necessary.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Engine oil: 
<intxreftitleoff1 refid = "AENAP70A1506001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Manual transaxle oil: 
<intxreftitleoff1 refid = "AENAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Transfer oil: 
<intxreftitleoff1 refid = "AENAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Install battery and battery tray with ECM. 
<intxreftitleoff1 refid = "AENAP70A1A06002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect ECM wire harness. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Bleed air from clutch system. 
<intxreftitleoff1 refid = "AENAP70A5306007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect positive (+) and negative (–) cables at battery.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check any leakage of fuel, coolant, oil and exhaust gas.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Fuel leak: 
<intxreftitleoff1 refid = "AENAP70A1706004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Coolant leak: 
<intxreftitleoff1 refid = "AENAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Install right and left side engine undercovers.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
