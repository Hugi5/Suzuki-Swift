<servinfosub id = "AENAP70A9304011003">
<title>
DTC Troubleshooting
</title>
<attention3>
<ptxt>
The following procedure describes how to check DTC B1864: Parking sensor system error (rear-left). Follow the same procedure also for DTC B1865, B1866 and B1867.
</ptxt>
</attention3>
<diag type = "test" id = "AENAP70A9304011004">
<testgroup id = "AENAP70A9304011005">
<title>
DTC check
</title>
<test1>
<ptxt>
Perform 
<intxref refid = "AENAP70AA204003">DTC Check</intxref>
.
</ptxt>
</test1>
<question>
Is DTC B1852 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A9304009">DTC B1852</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A9304011006">
<title>
Parking sensor check
</title>
<test1>
<ptxt>
Replace parking sensor with normal one and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A9306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is there any DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace parking sensor system control module. 
<intxreftitleoff1 refid = "AENAP70A9306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace parking sensor (rear-left).
</ptxt>
</action>
</testgroup>
</diag>
