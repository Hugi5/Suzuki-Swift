</title>
<servinfosub id = "AENAP70A1104020001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.842in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.362in"/>
<thead valign = "middle">
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" align = "center">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0107: Manifold Absolute Pressure / Barometric Pressure Circuit Low
</emph>
</ptxt>
<ptxt>
Output voltage of MAP sensor signal circuit is lower than 0.01 V for 5 sec.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
MAP sensor and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0108: Manifold Absolute Pressure / Barometric Pressure Circuit High
</emph>
</ptxt>
<ptxt>
Output voltage of MAP sensor signal circuit is higher than 4.74 V for 5 sec.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
