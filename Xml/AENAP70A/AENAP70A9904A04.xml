<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A9904A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Rain leakage
</title>
<diag type = "condition">
<condition>
<ptxt>
Rain leakage
</ptxt>
</condition>
<ps>
<ptxt>
Incorrect installation position of the sun roof glass
</ptxt>
</ps>
<action>
<ptxt>
Adjust sun roof glass mounting position. 
<intxreftitleoff1 refid = "AENAP70A9906005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty sun roof glass
</ptxt>
</ps>
<action>
<ptxt>
Replace sun roof glass. 
<intxreftitleoff1 refid = "AENAP70A9906004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disconnected or clogged drain hose (front / rear)
</ptxt>
</ps>
<action>
<ptxt>
Check drain hose (front / rear).
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
