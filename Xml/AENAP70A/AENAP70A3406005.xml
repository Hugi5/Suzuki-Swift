<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3406005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Coupling Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A3406004">Propeller Shaft Assembly Disassembly and Reassembly</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A3406005001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove circlip from coupling shaft using snap ring pliers.
</ptxt>
</s1>
<s1>
<ptxt>
Remove viscous coupling (1) from coupling shaft (2) using hydraulic press (3) and puller (4).
</ptxt>
<figure>
<graphic graphicname = "I5RS0D340007.swf" width = "88.000mm" height = "49.401mm" ver = "01" gw = "114" gh = "124"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A3406005002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Install viscous coupling (1) to coupling shaft (2) using special tool and hydraulic press.
</ptxt>
<servicetool>
<servicetoolitem id = "L3D001">
<s-part>
(A)
</s-part>
<s-number num = "09922-55131">
09922–55131
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A340010.swf" width = "88.000mm" height = "50.636mm" ver = "01" gw = "94" gh = "127"/>
</figure>
</s1>
<s1>
<ptxt>
Install new circlip to center shaft using snap ring pliers.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
