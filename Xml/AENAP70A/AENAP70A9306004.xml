<section sectnbr = "9C">
<servcat sctnbr = "09" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9306004" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Parking Sensor System Control Module Removal and Installation (If Equipped)
</title>
<servinfosub id = "AENAP70A9306004001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove rear quarter inner lower trim. 
<intxreftitleoff1 refid = "AENAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect parking sensor system control module connector (1) and parking sensor buzzer connector (2) from parking sensor system control module.
</ptxt>
</s1>
<s1>
<ptxt>
Remove screws (3) and remove parking sensor system control module (4).
</ptxt>
<figure>
<graphic graphicname = "I9P60A930024.jpg" width = "88.000mm" height = "56.820mm" ver = "02" gw = "205" gh = "145"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A9306004002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
