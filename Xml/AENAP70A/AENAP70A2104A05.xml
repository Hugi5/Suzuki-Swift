<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2A">
<servcat sctnbr = "02" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A2104A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Abnormal noise, front end
</title>
<diag type = "condition">
<condition>
<ptxt>
Abnormal noise, front end
</ptxt>
</condition>
<ps>
<ptxt>
Damaged front strut assembly (shock absorber) or mountings
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace front strut assembly (shock absorber) or mountings. 
<intxreftitleoff1 refid = "AENAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn, sticky or loose tie-rod ends
</ptxt>
</ps>
<action>
<ptxt>
Replace tie-rod ends. 
<intxreftitleoff1 refid = "AENAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn or damaged suspension arm joints
</ptxt>
</ps>
<action>
<ptxt>
Replace suspension arm. 
<intxreftitleoff1 refid = "AENAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn, sticky or loose tie-rod ball joints
</ptxt>
</ps>
<action>
<ptxt>
Replace steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn, sticky or loose drive shaft joints
</ptxt>
</ps>
<action>
<ptxt>
Replace drive shaft joints. 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn suspension arm front bushings
</ptxt>
</ps>
<action>
<ptxt>
Replace suspension arm front bushings. 
<intxreftitleoff1 refid = "AENAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worm suspension arm rear bushings
</ptxt>
</ps>
<action>
<ptxt>
Replace suspension arm. 
<intxreftitleoff1 refid = "AENAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose stabilizer bar
</ptxt>
</ps>
<action>
<ptxt>
Tighten bolts or nuts and/or replace bushings. 
<intxreftitleoff1 refid = "AENAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose wheel nuts
</ptxt>
</ps>
<action>
<ptxt>
Tighten wheel nuts. 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Loose suspension bolts or nuts
</ptxt>
</ps>
<action>
<ptxt>
Tighten suspension bolts or nuts. 
<intxreftitleoff1 refid = "AENAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Broken or damaged wheel bearings
</ptxt>
</ps>
<action>
<ptxt>
Replace wheel bearings. 
<intxreftitleoff1 refid = "AENAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Broken coil springs
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace coil springs. 
</ptxt>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70A2306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Poorly lubricated or worn strut bearings
</ptxt>
</ps>
<action>
<ptxt>
Replace strut bearings. 
<intxreftitleoff1 refid = "AENAP70A2206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Power steering system malfunction
</ptxt>
</ps>
<action>
<ptxt>
Check and correct malfunction. 
<intxreftitleoff1 refid = "AENAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
