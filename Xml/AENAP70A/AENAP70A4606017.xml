<servinfo servinfosgmlid = "AENAP70A4606017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
ESP® OFF Switch Removal and Installation
</title>
<servinfosub id = "AENAP70A4606017001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove instrument panel switch bezel. 
<intxreftitleoff1 refid = "AENAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect ESP<sup>®</sup> OFF switch connector.
</ptxt>
</s1>
<s1>
<ptxt>
Remove ESP<sup>®</sup> OFF switch (1) from instrument panel switch bezel.
</ptxt>
<figure>
<graphic graphicname = "IAP70A460023.swf" width = "88.000mm" height = "39.750mm" ver = "01" gw = "172" gh = "96"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.264in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
With parking sensor OFF switch
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Without parking sensor OFF switch
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A4606017002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A4606018">ESP® OFF Switch Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
