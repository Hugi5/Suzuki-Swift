<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A1A04A05" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Noisy generator
</title>
<ptxt>
Trouble in charging system will show up as one or more of the following conditions.
</ptxt>
<servinfosub id = "AENAP70A1A04002005">
<title>
Noise
</title>
<diag type = "condition">
<condition>
<ptxt>
Noisy generator
</ptxt>
</condition>
<ps>
<ptxt>
Loose mounting bolts
</ptxt>
</ps>
<action>
<ptxt>
Tighten mounting bolts. 
<intxreftitleoff1 refid = "AENAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Dirty, worn and/or faulty bearings
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty rotor, diode and/or stator
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
