<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0327: Knock Sensor 1 Circuit Low
</emph>
</ptxt>
<ptxt>
Output voltage of knock sensor signal circuit is lower than specified value for specified time with engine running.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Knock sensor and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
P0328: Knock Sensor 1 Circuit High
</emph>
</ptxt>
<ptxt>
Output voltage of knock sensor signal circuit is higher than specified value for specified time with engine running.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
</row>
