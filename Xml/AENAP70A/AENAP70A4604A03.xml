<section sectnbr = "4F">
<servcat sctnbr = "04" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A4604A03" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
ABS and/or ESP® warning light does not turn ON after setting ignition “ON”
</title>
<diag type = "condition">
<condition>
<ptxt>
ABS and/or ESP<sup>®</sup> warning light does not turn ON after setting ignition “ON”
</ptxt>
</condition>
<ps>
<ptxt>
Malfunctioning ESP<sup>®</sup> function
</ptxt>
</ps>
<action>
<ptxt>
Check ESP<sup>®</sup> system. 
<intxreftitleoff1 refid = "AENAP70A4604001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Malfunctioning CAN communication system function
</ptxt>
</ps>
<action>
<ptxt>
Check CAN communication system. 
<intxreftitleoff1 refid = "AENAP70AA804001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Malfunctioning ESP<sup>®</sup> warning light circuit
</ptxt>
</ps>
<action>
<ptxt>
Check ESP<sup>®</sup> warning light circuit. 
<intxreftitleoff1 refid = "AENAP70A4604010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Malfunctioning ABS warning light circuit
</ptxt>
</ps>
<action>
<ptxt>
Check ABS warning light circuit. 
<intxreftitleoff1 refid = "AENAP70A4604012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
