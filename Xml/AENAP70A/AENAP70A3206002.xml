<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3206002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Differential Oil Change
</title>
<s1>
<ptxt>
Before changing oil, be sure to stop engine and lift vehicle horizontally.
</ptxt>
</s1>
<s1>
<ptxt>
With vehicle lifted up, check leakage.
</ptxt>
<ptxt>
If leakage exists, correct it.
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil filler plug (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove drain plug (1), and drain oil.
</ptxt>
</s1>
<s1>
<ptxt>
Apply sealant to thread of drain plug (1), and tighten it to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3B002" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<torque>
<torqueitem id = "T3B002">
<t-part>
Differential oil drain plug
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Replenish new specified oil up to lower end of oil level / filler plug hole (3).
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Hypoid gear oil must be used for differential.
</ptxt>
</item>
<item>
<ptxt>
It is highly recommended to use “SUZUKI GEAR OIL 75W-85”.
</ptxt>
</item>
</list1>
</attention3>
<spec>
<title>
Differential oil specification
</title>
<ptxt>
: SUZUKI GEAR OIL 99000-22B30
</ptxt>
<ptxt>
: API GL-5 (For SAE classification, refer to viscosity chart)
</ptxt>
</spec>
<spec>
<title>
Viscosity chart
</title>
<figure>
<graphic graphicname = "IAP70A320004.swf" width = "88.000mm" height = "26.126mm" ver = "02" gw = "201" gh = "58"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.968in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Outside temperature
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</spec>
<spec-sdm>
<sdm-title>
Rear differential oil capacity
</sdm-title>
<sdm1>
<sdm-condition>
Reference
</sdm-condition>
<sdm-value>
0.8 liters (1.7/1.4 US/Imp. pt.)
</sdm-value>
</sdm1>
</spec-sdm>
</s1>
<s1>
<ptxt>
Apply sealant to thread of level / filler plug, and then tighten it to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3B003" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<torque>
<torqueitem id = "T3B003">
<t-part>
Differential oil level / filler plug
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A320005.swf" width = "88.000mm" height = "53.096mm" ver = "01" gw = "188" gh = "134"/>
</figure>
<figure>
<graphic graphicname = "IAP70A320006.swf" width = "88.000mm" height = "33.474mm" ver = "01" gw = "80" gh = "78"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
