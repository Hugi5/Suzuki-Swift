<servinfosub id = "AENAP70AA204012003">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70AA204012004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70AA204012005">
<testgroup id = "AENAP70AA204012008">
<title>
Parameter check
</title>
<test1>
<ptxt>
Connect SUZUKI scan tool to DLC when ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Auto Light Sensor” displayed on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENAP70AA204007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA204012006">
<title>
Auto-on headlight sensor power supply circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect auto-on headlight sensor and “G05” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to auto-on headlight sensor and “G05” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “A1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” and “A3” circuit terminals at auto-on headlight sensor connector: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA204012007">
<title>
Auto-on headlight sensor check
</title>
<test1>
<ptxt>
Check auto-on headlight sensor. 
<intxreftitleoff1 refid = "AENAP70A9206024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace auto-on headlight sensor. 
<intxreftitleoff1 refid = "AENAP70A9206023"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA204012009">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Connect auto-on headlight sensor and “G05” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is current DTC B1132 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace BCM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70AA206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Intermittent trouble.)
</ptxt>
</action>
</testgroup>
</diag>
