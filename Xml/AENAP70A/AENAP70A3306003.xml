<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Transfer Dismounting and Remounting
</title>
<servinfosub id = "AENAP70A3306003001">
<title>
Dismounting
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Drain the following oils.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Manual transaxle oil: 
<intxreftitleoff1 refid = "AENAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Transfer oil: 
<intxreftitleoff1 refid = "AENAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Remove right side drive shaft assembly. 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove propeller shaft. 
<intxreftitleoff1 refid = "AENAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove front suspension frame. 
<intxreftitleoff1 refid = "AENAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove engine rear mounting and engine rear mounting bracket. 
<intxreftitleoff1 refid = "AENAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove transfer stiffener (2) and transfer bolts.
</ptxt>
</s1>
<s1>
<ptxt>
Separate transfer (1) from transaxle.
</ptxt>
<attention1>
<ptxt>
When removing transfer, be careful not to drop it. Otherwise, transfer damage and personal injury may result.
</ptxt>
</attention1>
<figure>
<graphic graphicname = "IAP70A330004.jpg" width = "88.000mm" height = "51.466mm" ver = "01" gw = "213" gh = "129"/>
</figure>
</s1>
<s1>
<ptxt>
Remove O-ring (1) and dowel pin (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330005.jpg" width = "88.000mm" height = "52.680mm" ver = "01" gw = "213" gh = "133"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70A3306003002">
<title>
Remounting
</title>
<ptxt>
Reverse dismounting procedure, noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Use new O-ring and drive shaft nut.
</ptxt>
</item>
<item>
<ptxt>
Apply grease to O-ring (1).
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C004" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A330006.jpg" width = "88.000mm" height = "50.958mm" ver = "02" gw = "213" gh = "128"/>
</figure>
</item>
<item>
<ptxt>
Tighten transfer bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T3C004">
<t-part>
Transfer bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
88
</t-value1>
<t-value2>
9.0
</t-value2>
<t-value3>
65.0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Tighten transfer stiffener bolts as follows.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Tighten transfer stiffener bolts “2” and “3” by hand.
</ptxt>
</item>
<item>
<ptxt>
Push transfer stiffener to transfer and tighten transfer stiffener bolts to specified torque in numerical order (“1” – “5”) evenly and gradually.
</ptxt>
<torque>
<torqueitem id = "T3C005">
<t-part>
Transfer stiffener bolt*
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330007.jpg" width = "88.000mm" height = "56.283mm" ver = "01" gw = "213" gh = "143"/>
</figure>
<figure>
<graphic graphicname = "IAP70A330008.jpg" width = "88.000mm" height = "55.083mm" ver = "01" gw = "202" gh = "140"/>
</figure>
</item>
</list2>
<item>
<ptxt>
Tighten following bolts and nuts to specified torque.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Engine rear mounting bolt and bracket bolt: 
<intxreftitleoff1 refid = "AENAP70A1406015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Front suspension frame mounting bolt: 
<intxreftitleoff1 refid = "AENAP70A2206012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Be sure to use new suspension frame mounting bolt.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Stabilizer joint nut: 
<intxreftitleoff1 refid = "AENAP70A2206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Suspension arm ball joint bolt: 
<intxreftitleoff1 refid = "AENAP70A3116008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Tie-rod end nut: 
<intxreftitleoff1 refid = "AENAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Front wheel speed sensor bolt: 
<intxreftitleoff1 refid = "AENAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Propeller shaft bolt: 
<intxreftitleoff1 refid = "AENAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Center support nut: 
<intxreftitleoff1 refid = "AENAP70A3406002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Exhaust pipe bolt: 
<intxreftitleoff1 refid = "AENAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Exhaust No.1 pipe stiffener bolt: 
<intxreftitleoff1 refid = "AENAP70A1B06001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Drive shaft nut: 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention2>
<ptxt>
Be sure to use new drive shaft nut.
</ptxt>
</attention2>
</item>
<item>
<ptxt>
Wheel nut: 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Caulk drive shaft nut. 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Replenish the following oils.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Manual transaxle oil: 
<intxreftitleoff1 refid = "AENAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
	Transfer oil: 
<intxreftitleoff1 refid = "AENAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
<item>
<ptxt>
Verify that there is no oil leakage and exhaust gas leakage at each connection.
</ptxt>
</item>
<item>
<ptxt>
Confirm front wheel alignment. 
<intxreftitleoff1 refid = "AENAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
