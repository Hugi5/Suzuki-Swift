<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1306017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
CMP Sensor Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1306016">CMP Sensor On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A1306017001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from intake CMP sensor (1) and exhaust CMP sensor (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove intake CMP sensor (1) and exhaust CMP sensor (2) from cylinder head.
</ptxt>
<figure>
<graphic graphicname = "I9P60A131006.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1306017002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1306018">CMP Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply engine oil to O-ring of sensor.
</ptxt>
</item>
<item>
<ptxt>
Tighten CMP sensor bolt to specified torque.
</ptxt>
</item>
</list1>
<attention3>
<ptxt>
Be sure to use new bolts with pre-coated adhesive. Otherwise, bolts may loosen.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1C005">
<t-part>
Intake CMP sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
<torqueitem id = "T1C006">
<t-part>
Exhaust CMP sensor bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A131007.jpg" width = "88.000mm" height = "51.212mm" ver = "01" gw = "185" gh = "129"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
