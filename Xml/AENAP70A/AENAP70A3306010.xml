<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3306010" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Transfer Assembly Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A3306005">Transfer Assembly Disassembly and Reassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A3306003">Transfer Dismounting and Remounting</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check each bearing for smooth rotation, wear or discoloration
</ptxt>
<ptxt>
If found abnormal, replace bearing.
</ptxt>
</item>
<item>
<ptxt>
Check oil seal for leakage and its lip for excessive hardness
</ptxt>
<ptxt>
If either is found, replace oil seal.
</ptxt>
</item>
<item>
<ptxt>
Check transfer case for cracks.
</ptxt>
</item>
<item>
<ptxt>
Check bevel pinion and bevel gears for wear or cracks.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
