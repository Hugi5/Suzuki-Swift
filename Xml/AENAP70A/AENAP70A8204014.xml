<servinfosub id = "AENAP70A8204014003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A8204014004">
<testgroup id = "AENAP70A8204014005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204014006">
<title>
Passenger air bag deactivation indicator circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is in “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to connector “G153”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G153” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Measure voltage between “G153-9” terminal and ground.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B004">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820109.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</test1>
<question>
Is measured voltage 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204014007">
<title>
Passenger air bag deactivation indicator circuit check
</title>
<test1>
<ptxt>
Set ignition “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to connector “G11”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “G11” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Measure resistance between “G153-10” terminal and “G11-15” terminal.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B005">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820110.swf" width = "90.000mm" height = "48.716mm" ver = "01" gw = "188" gh = "122"/>
</testfigure>
</test1>
<question>
Is measured resistance 1&#937; or less?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204014008">
<title>
Passenger air bag deactivation indicator circuit check
</title>
<test1>
<ptxt>
Check the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between “G153-10” terminal ground.
</ptxt>
<servicetool>
<servicetoolitem id = "L8B006">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "I9P60A820111.swf" width = "90.000mm" height = "27.161mm" ver = "01" gw = "163" gh = "60"/>
</testfigure>
</item>
</list1>
</test1>
<question>
Is measured resistance infinity?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204014009">
<title>
Passenger air bag deactivation indicator check
</title>
<test1>
<ptxt>
Check passenger air bag deactivation indicator. 
<intxreftitleoff1 refid = "AENAP70A8206029"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace hazard warning switch. 
<intxreftitleoff1 refid = "AENAP70A9206016"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs referring to 
<intxref refid = "AENAP70A8204006">DTC Clearance</intxref>
, if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENAP70A8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
