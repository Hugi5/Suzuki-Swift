<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1306009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
MAP Sensor Removal and Installation
</title>
<servinfosub id = "AENAP70A1306009001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector of MAP sensor.
</ptxt>
</s1>
<s1>
<ptxt>
Remove MAP sensor (1) from intake manifold (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A131003.jpg" width = "88.000mm" height = "51.551mm" ver = "01" gw = "185" gh = "130"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1306009002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1306010">MAP Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check that O-ring is free from damage.
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
