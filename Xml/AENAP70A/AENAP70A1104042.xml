<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0530: A/C Refrigerant Pressure Sensor “A” Circuit
</emph>
</ptxt>
<ptxt>
Any of the following conditions is met. 
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Output voltage of A/C refrigerant pressure sensor signal circuit is lower than 0.15 V.
</ptxt>
</item>
<item>
<ptxt>
Output voltage of A/C refrigerant pressure sensor signal circuit is higher than 4.93 V.
</ptxt>
</item>
</list1>
<ptxt>
(3 D/C detection logic but MIL does not light up)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
A/C refrigerant pressure sensor and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
