<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10H">
<servcat sctnbr = "10" scnbr = "08">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70AA804001" svcinfotypenbr = "06" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
CAN Communication Check
</title>
<ptxt>
Using SUZUKI scan tool, execute “Communication Malfunction DTC” under “Bus check” and check for DTCs of all control modules connected to CAN Communication Bus.
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "3" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "2.854in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.854in"/>
<colspec colnum = "3" colname = "3" colwidth = "1.457in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Action
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Reference
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Only history DTC was detected in either of systems
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Recheck DTC after clear DTC and performing the driving test. If check results is OK, it is intermittent trouble. 
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
—
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
“Control Module Bus Off” was detected in either of systems (current DTC)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Perform “Troubleshooting for Communication Bus Off” 
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
<intxreftitleoff1 refid = "AENAP70AA804004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Only “Lost Communication” was detected in either of systems (current DTC)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Perform “Troubleshooting for Lost Communication”
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
<intxreftitleoff1 refid = "AENAP70AA804003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" morerows = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
No display on SUZUKI scan tool (It is not possible to communicate with all systems.)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Check if SUZUKI scan tool is communicable by connecting to another vehicle.
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
—
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle">
<ptxt>
Perform “Troubleshooting for Lost Communication”
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
<intxreftitleoff1 refid = "AENAP70AA804003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</entry>
