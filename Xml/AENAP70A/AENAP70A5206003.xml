<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A5206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Differential Side Oil Seal Replacement
</title>
<s1>
<ptxt>
Hoist vehicle and drain transaxle oil.
</ptxt>
</s1>
<s1>
<ptxt>
Remove left drive shaft assembly. 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil seal (1) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B001">
<s-part>
(A)
</s-part>
<s-number num = "09913-50121">
09913–50121
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I9P60A522004.swf" width = "88.000mm" height = "48.454mm" ver = "01" gw = "146" gh = "121"/>
</figure>
</s1>
<s1>
<ptxt>
Install new oil seal (1) using special tool.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to install oil seal facing its spring side inward.
</ptxt>
</item>
<item>
<ptxt>
Be sure to install oil seal to surface of left case (2) in parallel.
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B002">
<s-part>
(A)
</s-part>
<s-number num = "09944-88220">
09944–88220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L5B003">
<s-part>
(B)
</s-part>
<s-number num = "09924-74510">
09924–74510
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Distance between case surface and oil seal
</title>
<ptxt>
“a”: 0 – 1.0 mm (0 – 0.04 in.)
</ptxt>
</spec>
</s1>
<s1>
<ptxt>
Apply grease to oil seal lip and check drive shaft where oil seal contacts for smoothness.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B004" uid = "22">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I9P60A522005.swf" width = "88.000mm" height = "44.718mm" ver = "02" gw = "110" gh = "110"/>
</figure>
</s1>
<s1>
<ptxt>
Insert left drive shaft assembly. 
<intxreftitleoff1 refid = "AENAP70A3116003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Replenish transaxle oil. 
<intxreftitleoff1 refid = "AENAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
