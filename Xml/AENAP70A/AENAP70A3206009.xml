<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3206009" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Differential Mounting Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A3206007">Rear Differential Mounting Components</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A3206008">Rear Differential Mounting On-Vehicle Inspection</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A3206009001">
<title>
Removal
</title>
<s1>
<ptxt>
Dismount rear differential assembly. 
<intxreftitleoff1 refid = "AENAP70A3206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear differential mount front arm (1), rear differential front mounting brackets (2) and rear differential rear mounting bracket (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear differential mount front arm damper (4), if necessary.
</ptxt>
<figure>
<graphic graphicname = "IAP70A320024.jpg" width = "88.000mm" height = "56.800mm" ver = "01" gw = "227" gh = "144"/>
</figure>
</s1>
<s1>
<ptxt>
Remove rear differential front or rear mounting from bracket pulling out with hydraulic press and special tools.
</ptxt>
<servicetool>
<servicetoolitem id = "L3B037">
<s-part>
(A)
</s-part>
<s-number num = "09944-66030">
09944–66030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3B038">
<s-part>
(B)
</s-part>
<s-number num = "09944-78210">
09944–78210
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3B039">
<s-part>
(C)
</s-part>
<s-number num = "09926-37610">
09926–37610
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A320028.swf" width = "88.000mm" height = "73.910mm" ver = "01" gw = "114" gh = "193"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A3206009002">
<title>
Installation
</title>
<s1>
<ptxt>
Install new rear differential front mounting and rear mounting to bracket press-fit with hydraulic press and special tools.
</ptxt>
<ptxt>
Mounting should be directed as shown in figure and both ends of mounting collar (1) projecting from mounting bracket (2) should be the same in amount.
</ptxt>
<servicetool>
<servicetoolitem id = "L3B040">
<s-part>
(A)
</s-part>
<s-number num = "09944-66030">
09944–66030
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
<servicetoolitem id = "L3B041">
<s-part>
(B)
</s-part>
<s-number num = "09944-78220">
09944–78220
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A320025.swf" width = "88.000mm" height = "73.381mm" ver = "01" gw = "145" gh = "191"/>
</figure>
<figure>
<graphic graphicname = "IAP70A320026.swf" width = "88.000mm" height = "42.068mm" ver = "02" gw = "242" gh = "102"/>
</figure>
<figure>
<graphic graphicname = "IAP70A320029.swf" width = "88.000mm" height = "43.408mm" ver = "02" gw = "108" gh = "107"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.805in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.908in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Front
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
32 to 42&#176;
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Rear
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“b”:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Projection of mounting bracket
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install rear differential front mounting brackets (1) and rear differential rear mounting bracket (2).
</ptxt>
<torque>
<torqueitem id = "T3B009">
<t-part>
Rear differential front mounting bracket bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
<torqueitem id = "T3B010">
<t-part>
Rear differential front mounting bracket nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
<torqueitem id = "T3B011">
<t-part>
Rear differential rear mounting bracket bolt
</t-part>
<t-part1>
c
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
<torqueitem id = "T3B012">
<t-part>
Rear differential rear mounting bracket nut
</t-part>
<t-part1>
d
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Install differential mount front arm (3) and tighten rear differential front mounting bolts by hand.
</ptxt>
</s1>
<s1>
<ptxt>
Remount rear differential assembly. 
<intxreftitleoff1 refid = "AENAP70A3206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Tighten rear differential front mounting bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T3B013">
<t-part>
Rear differential front mounting bolt
</t-part>
<t-part1>
e
</t-part1>
<t-value1>
80
</t-value1>
<t-value2>
8.2
</t-value2>
<t-value3>
59.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Install rear differential mount front arm damper (4), if removed.
</ptxt>
<torque>
<torqueitem id = "T3B014">
<t-part>
Rear differential mount front arm damper nut
</t-part>
<t-part1>
f
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
</s1>
<figure>
<graphic graphicname = "IAP70A320027.jpg" width = "88.000mm" height = "74.238mm" ver = "01" gw = "213" gh = "194"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
