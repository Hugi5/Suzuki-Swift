<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70AA506015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Engine Switch Removal and Installation
</title>
<servinfosub id = "AENAP70AA506015001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove steering column hole cover. 
<intxreftitleoff1 refid = "AENAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove engine switch bezel. 
<intxreftitleoff1 refid = "AENAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove engine switch from engine switch bezel.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70AA506015002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70AA506016">Engine Switch Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
