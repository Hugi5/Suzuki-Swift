<section sectnbr = "1D">
<servcat sctnbr = "01" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1406014" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Camshaft and Tappet Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1406013">Camshaft and Tappet Removal and Installation</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A1406014001">
<title>
Cam Wear
</title>
<ptxt>
Using a micrometer, measure cam height “a”. If measured height is not as specified, replace camshaft.
</ptxt>
<spec>
<title>
Cam height “a” of camshaft
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "3" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.687in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.339in"/>
<colspec colnum = "3" colname = "3" colwidth = "1.439in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Camshaft
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Standard
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Limit
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Intake
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "center">
<ptxt>
45.421 – 45.581 mm
</ptxt>
<ptxt>
(1.7883 – 1.7945 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "center">
<ptxt>
45.321 mm
</ptxt>
<ptxt>
(1.7449 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Exhaust
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "center">
<ptxt>
44.320 – 44.480 mm
</ptxt>
<ptxt>
(1.7449 – 1.7511 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "center">
<ptxt>
44.220 mm
</ptxt>
<ptxt>
(1.7409 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<figure>
<graphic graphicname = "I9T401142011.swf" width = "88.000mm" height = "44.003mm" ver = "01" gw = "176" gh = "108"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70A1406014002">
<title>
Camshaft Runout
</title>
<ptxt>
Set camshaft on two “V” blocks, and measure its runout using a dial gauge.
</ptxt>
<ptxt>
If measured runout exceeds limit, replace camshaft.
</ptxt>
<spec>
<title>
Camshaft runout limit
</title>
<ptxt>
0.015 mm (0.0006 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I9T401142012.swf" width = "88.000mm" height = "49.610mm" ver = "01" gw = "136" gh = "124"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70A1406014003">
<title>
Camshaft Journal Wear
</title>
<list1 type = "unordered">
<item>
<ptxt>
Check camshaft journals and camshaft housings for pitting, scratches, wear or damage.
</ptxt>
<ptxt>
If any defect is found, replace camshaft or cylinder head with housing. Be sure to replace cylinder head and housings as a set.
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "I2RH0B140082.swf" width = "88.000mm" height = "39.655mm" ver = "01" gw = "89" gh = "95"/>
</figure>
<list1 type = "unordered">
<item>
<ptxt>
Check clearance using gauging plastic as follows.
</ptxt>
</item>
</list1>
<s1>
<ptxt>
Clean housings and camshaft journals.
</ptxt>
</s1>
<s1>
<ptxt>
Remove all tappets.
</ptxt>
</s1>
<s1>
<ptxt>
Install lower bearing half and camshafts to cylinder head.
</ptxt>
</s1>
<s1>
<ptxt>
Place a piece of gauging plastic to full width of journal of camshaft (parallel to camshaft).
</ptxt>
</s1>
<s1>
<ptxt>
Install camshaft housing referring to Steps 7) to 8) of “Installation” under 
<intxref refid = "AENAP70A1406013">Camshaft and Tappet Removal and Installation</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Remove housing, and using scale (2) on gauging plastic envelop, measure gauging plastic (1) width at its widest point.
</ptxt>
<spec>
<title>
Camshaft journal clearance
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "3" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.079in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.374in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.934in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Item
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Standard
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Limit
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Camshaft housing No.1
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
 0.031 – 0.087 mm
</ptxt>
<ptxt>
 (0.0013 – 0.0034 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
0.10 mm
</ptxt>
<ptxt>
 (0.00394 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Others
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
 0.045 – 0.087 mm
</ptxt>
<ptxt>
(0.0018 – 0.0034 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
0.10 mm
</ptxt>
<ptxt>
 (0.00394 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<figure>
<graphic graphicname = "I2RH0B140083.swf" width = "88.000mm" height = "48.375mm" ver = "01" gw = "194" gh = "120"/>
</figure>
<ptxt>
If measured camshaft journal clearance exceeds limit, recheck camshaft journal clearance according to the following procedure.
</ptxt>
<s2>
<ptxt>
Install camshaft upper bearing haves and camshaft housings without camshafts to cylinder head.
</ptxt>
</s2>
<s2>
<ptxt>
Tighten camshaft housing bolts referring to Step 8) in “Installation” under 
<intxref refid = "AENAP70A1406013">Camshaft and Tappet Removal and Installation</intxref>
.
</ptxt>
</s2>
<s2>
<ptxt>
For intake and exhaust camshaft journal No.1, measure journal outside diameter at positions shown in figure.
</ptxt>
<ptxt>
If measured diameter is not as specified, replace camshaft and recheck camshaft journal clearance.
</ptxt>
<ptxt>
If measured diameter is within standard values, replace camshaft bearings and recheck camshaft journal clearance.
</ptxt>
</s2>
<s2>
<ptxt>
For all other camshaft journals, measure camshaft journal outside diameters and camshaft housing inside diameters.
</ptxt>
<ptxt>
If measured diameters are not as specified, replace corresponding camshaft or cylinder head and camshaft housings.
</ptxt>
</s2>
<spec>
<title>
Camshaft journal outside diameter [A]
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.736in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.736in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Item
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Standard
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Intake and exhaust No.1 journal “a”
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
29.440 – 29.455 mm
</ptxt>
<ptxt>
(1.1591 – 1.1596 in.)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Others
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
22.934 – 22.955 mm
</ptxt>
<ptxt>
(0.9029 – 0.9037 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<spec>
<title>
Camshaft journal housing inside diameter [B]
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "1.736in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.736in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Item
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Standard
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Intake and exhaust No.1 housing
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
—
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Others
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
23.000 – 23.021 mm
</ptxt>
<ptxt>
(0.9055 – 0.9063 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<figure>
<graphic graphicname = "I8T401142043.swf" width = "88.000mm" height = "45.202mm" ver = "02" gw = "185" gh = "112"/>
</figure>
<figure>
<graphic graphicname = "I9T401142015.swf" width = "88.000mm" height = "42.360mm" ver = "01" gw = "184" gh = "104"/>
</figure>
<figure>
<graphic graphicname = "I9T401142049.swf" width = "88.000mm" height = "24.795mm" ver = "01" gw = "199" gh = "54"/>
</figure>
</spec>
</s1>
<s1>
<ptxt>
Install intake and exhaust camshaft without tappet, measure intake and exhaust camshaft housing thrust clearance using a dial gauge.
</ptxt>
<ptxt>
If measured clearance exceeds limit, replace camshaft or cylinder head.
</ptxt>
<spec>
<title>
Camshaft housing thrust clearance
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.842in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.622in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Camshaft housing thrust clearance
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
Standard
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "middle" align = "center">
<ptxt>
0.10 – 0.35 mm (0.0039 – 0.0138 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<figure>
<graphic graphicname = "I7V20A141074.swf" width = "88.000mm" height = "49.834mm" ver = "01" gw = "175" gh = "125"/>
</figure>
</spec>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1406014004" page = "2">
<title>
Wear of Tappet
</title>
<ptxt>
Check tappet for pitting, scratches, or damage.
</ptxt>
<ptxt>
If any defect is found, replace tappet.
</ptxt>
<figure>
<graphic graphicname = "I7V20A141075.swf" width = "88.000mm" height = "30.414mm" ver = "01" gw = "80" gh = "70"/>
</figure>
<ptxt>
Measure cylinder head tappet bore and tappet outside diameter to determine cylinder head-to-tappet clearance. If clearance exceeds limit, replace tappet or cylinder head.
</ptxt>
<spec>
<title>
Cylinder head to tappet clearance
</title>
<ptxt>
Standard: 0.025 – 0.062 mm (0.0010 – 0.0024 in.)
</ptxt>
<ptxt>
Limit: 0.10 mm (0.0039 in.)
</ptxt>
</spec>
<spec>
<title>
Tappet outside diameter [A]
</title>
<ptxt>
Standard: 27.959 – 27.975 mm (1.1007 – 1.1014 in.)
</ptxt>
</spec>
<spec>
<title>
Cylinder head tappet bore [B]
</title>
<ptxt>
Standard: 28.000 – 28.021 mm (1.1024 – 1.1032 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I2RH0B140086.swf" width = "88.000mm" height = "90.497mm" ver = "01" gw = "186" gh = "240"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70A1406014005">
<title>
VVT Actuator
</title>
<list1 type = "unordered">
<item>
<ptxt>
Check VVT actuator for wear or damage.
</ptxt>
<ptxt>
Replace VVT actuator if any defective conditions are found.
</ptxt>
</item>
<item>
<ptxt>
Install VVT actuator to camshaft. Hold hexagonal section of camshaft stationary using wrench.
</ptxt>
<ptxt>
Check that VVT actuator (1) cannot be turned by hand.
</ptxt>
<ptxt>
Replace VVT actuator if it can be turned by hand.
</ptxt>
<figure>
<graphic graphicname = "I9P60A141041.swf" width = "88.000mm" height = "66.568mm" ver = "02" gw = "167" gh = "172"/>
</figure>
</item>
</list1>
</servinfosub>
<servinfosub id = "AENAP70A1406014006">
<title>
Signal Rotor
</title>
<ptxt>
Check signal rotor (1) for crack and damage. If any defect is found, replace camshaft.
</ptxt>
<figure>
<graphic graphicname = "IAP70P140037.jpg" width = "88.000mm" height = "51.365mm" ver = "01" gw = "171" gh = "129"/>
</figure>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
