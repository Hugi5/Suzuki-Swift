<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1J">
<servcat sctnbr = "01" scnbr = "10">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A1A04A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Charge warning light does not light with ignition ON and engine off
</title>
<ptxt>
Trouble in charging system will show up as one or more of the following conditions.
</ptxt>
<servinfosub id = "AENAP70A1A04002001" page = "1">
<title>
Charging Warning Light Operation
</title>
<diag type = "condition">
<condition>
<ptxt>
Charge warning light does not light with ignition ON and engine off
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Replace fuse.
</ptxt>
</action>
<ps>
<ptxt>
Faulty combination meter
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace combination meter. 
<intxreftitleoff1 refid = "AENAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check BCM. 
</ptxt>
<ptxt>
Ignition switch model: 
<intxreftitleoff1 refid = "AENAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Keyless push start model: 
<intxreftitleoff1 refid = "AENAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Faulty CAN communication line
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace CAN communication line. 
<intxreftitleoff1 refid = "AENAP70AA804002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty IC regulator or field coil
</ptxt>
</ps>
<action>
<ptxt>
Repair or replace generator. 
<intxreftitleoff1 refid = "AENAP70A1A06008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
