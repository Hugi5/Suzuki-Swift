<servinfosub id = "AENAP70A8204010002">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A8204010003">
<testgroup id = "AENAP70A8204010004">
<title>
Warning light check
</title>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<question>
Do other indicator lights come ON?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204010005">
<title>
DTC check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Connect scan tool to DLC.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70A8204005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC U0073 detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70AA804004">Troubleshooting for Communication Bus Off</intxref>
.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace SDM and recheck. 
<intxreftitleoff1 refid = "AENAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204010006">
<title>
Fuse check
</title>
<question>
Is “MTR” fuse for combination meter in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace “MTR” fuse and check for short circuit to ground.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204010007">
<title>
CAN communication circuit check
</title>
<test1>
<ptxt>
Check CAN communication circuit between SDM and combination meter.
</ptxt>
</test1>
<question>
Is circuit in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204010008">
<title>
Combination meter power supply circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Remove combination meter.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to “RED/WHT” and “GRY” wire of combination meter connector.
</ptxt>
</test1>
<test1>
<ptxt>
If OK, set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Measure voltage between “RED/WHT” wire and ground.
</ptxt>
</test1>
<question>
Is it 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair power supply circuit for combination meter.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204010009">
<title>
Combination meter ground circuit check
</title>
<test1>
<ptxt>
Measure resistance between “GRY” wire and ground.
</ptxt>
</test1>
<question>
Is resistance less than 2 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace combination meter and recheck “AIR BAG” warning light operation. 
<intxreftitleoff1 refid = "AENAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
“GRY” circuit open.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENAP70A8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been corrected.
</ptxt>
</item>
</list1>
</attention3>
