</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<spec>
<title>
Installation position of oil seal
</title>
<ptxt>
“a”: 20 – 21 mm (0.79 – 0.82 in.)
</ptxt>
<ptxt>
“b”: 3.5 – 4.5 mm (0.14 – 0.17 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330021.swf" width = "88.000mm" height = "67.725mm" ver = "01" gw = "185" gh = "175"/>
