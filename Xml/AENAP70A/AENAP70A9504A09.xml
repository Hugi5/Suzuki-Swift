<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A9504A09" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
All mirror heaters do not operate
</title>
<diag type = "condition">
<condition>
<ptxt>
All mirror heaters do not operate
</ptxt>
</condition>
<ps>
<ptxt>
Blown fuse
</ptxt>
</ps>
<action>
<ptxt>
Replace fuse and check for short circuit.
</ptxt>
</action>
<ps>
<ptxt>
Faulty mirror heater switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A9506008">Rear Defogger Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
<ps>
<ptxt>
Faulty BCM
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
“Inspection of BCM and Its Circuits”: in Section 10B.
</ptxt>
<ptxt>
Ignition Switch Model: 
<intxreftitleoff1 refid = "AENAP70AA204025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Keyless Push Start Model: 
<intxreftitleoff1 refid = "AENAP70AA204026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
