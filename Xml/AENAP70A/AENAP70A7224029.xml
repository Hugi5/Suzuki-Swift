<title>
DTC B1570
</title>
<servinfosub id = "AENAP70A7224029001">
<title>
DTC Detecting Condition and Trouble Area 
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.922in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.288in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph>
B1570: Engine Type Signal Failure
</emph>
</ptxt>
<ptxt>
HVAC control module receives invalid data of engine type signal from ECM.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
ECM
</ptxt>
</item>
<item>
<ptxt>
HVAC control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70A7224029002">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A7224029003">
<testgroup id = "AENAP70A7224029005">
<title>
Scan tool data check
</title>
<test1>
<ptxt>
Connect scan tool with ignition to “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Ignition to “ON” and select “DATA LIST” mode.
</ptxt>
</test1>
<test1>
<ptxt>
Check “Engine Type” displayed on scan tool.
</ptxt>
</test1>
<question>
Is engine type correct as indicated in “Scan Tool Data”?
</question>
<result type = "yes"/>
<action>
<ptxt>
Substitute a known good HVAC control module and recheck.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Substitute a known good ECM and recheck.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
