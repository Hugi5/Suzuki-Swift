<servinfosub id = "AENAP70A1104047003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following condition is met in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery temperature &#62; 12 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Warm up engine to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Confirm that the following conditions are met.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Blower fan: OFF
</ptxt>
</item>
<item>
<ptxt>
Headlight switch: OFF
</ptxt>
</item>
<item>
<ptxt>
Rear defogger switch: OFF
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Keep engine running at idle speed for 10 min. and confirm that the following conditions are met.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Blower fan: ON
</ptxt>
</item>
<item>
<ptxt>
Headlight switch: ON
</ptxt>
</item>
<item>
<ptxt>
Rear defogger switch: ON
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Keep engine speed at 4,000 rpm for 30 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1104047004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A1104047005">
<testgroup id = "AENAP70A1104047006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104047007">
<title>
Generator drive belt check
</title>
<test1>
<ptxt>
Check generator drive belt for proper tension. 
<intxreftitleoff1 refid = "AENAP70A1A06003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Adjust or replace generator drive belt.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104047008">
<title>
Generator control signal circuit check
</title>
<test1>
<ptxt>
When ignition is OFF, disconnect “C01” and “E01” connectors of ECM and generator connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors and generator connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A1” circuit: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A1” circuit terminal and other terminal at generator connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A1” circuit: 0 to 1 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104047009">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Replace generator. 
<intxreftitleoff1 refid = "AENAP70A1A06005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC.
</ptxt>
</test1>
<question>
Is DTC P0620 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
</diag>
