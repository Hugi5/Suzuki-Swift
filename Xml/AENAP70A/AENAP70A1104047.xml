<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0620: Generator Control Circuit
</emph>
</ptxt>
<ptxt>
Battery voltage stays lower than 12.3 V for longer than 30 sec. even with C duty ratio more than 65% and FR duty ratio less than 60%.
</ptxt>
<ptxt>
(3 D/C detection logic but MIL does not light up)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Generator and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
Generator drive belt
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
