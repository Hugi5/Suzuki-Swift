<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9206024" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "1">
<title>
Auto-On Headlight Sensor Inspection (If Equipped)
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A9206023">Auto-On Headlight Sensor Removal and Installation (If Equipped)</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Connect auto-on headlight sensor connector.
</ptxt>
</s1>
<s1>
<ptxt>
Measure voltage between terminals in the following condition.
</ptxt>
<ptxt>
If measured voltage is out of specification, replace auto-on headlight sensor.
</ptxt>
<spec>
<title>
Auto-on headlight sensor voltage specifications
</title>
<ptxt>
Cover the sensor lens with hand: 0.4 V
</ptxt>
<ptxt>
Light the sensor lens with incandescent lamp 100 W: 3 – 4.5 V
</ptxt>
<figure>
<graphic graphicname = "I9P60A920035.swf" width = "88.000mm" height = "70.783mm" ver = "03" gw = "193" gh = "184"/>
</figure>
</spec>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
