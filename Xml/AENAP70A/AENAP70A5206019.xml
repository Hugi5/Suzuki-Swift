<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A5206019" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Input Shaft Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A5206010">Manual Transaxle Unit Dismounting and Remounting</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A5206014">Fifth Gear Disassembly and Reassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A5206015">Manual Transaxle Assembly Disassembly and Reassembly</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A5206018">Input Shaft and Countershaft Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A5206019001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove input shaft right bearing (2) from input shaft (1) using bearing puller (3) and hydraulic press.
</ptxt>
<figure>
<graphic graphicname = "I4RH01520029.swf" width = "88.000mm" height = "47.444mm" ver = "01" gw = "138" gh = "117"/>
</figure>
</s1>
<s1>
<ptxt>
Remove 5th gear spacer (2), left bearing (3) and 4th gear (4) all at once using puller (5) and hydraulic press.
</ptxt>
<attention2>
<ptxt>
To avoid gear teeth damage, support 4th gear on flat side of bearing puller.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I3RH0A520018.swf" width = "88.000mm" height = "39.486mm" ver = "01" gw = "139" gh = "95"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.150in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Input shaft
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove 4th gear needle bearing and high speed synchronizer ring.
</ptxt>
</s1>
<s1>
<ptxt>
Using snap ring pliers (2), remove circlip (1).
</ptxt>
<figure>
<graphic graphicname = "I7RW01520007.swf" width = "88.000mm" height = "43.126mm" ver = "01" gw = "126" gh = "105"/>
</figure>
</s1>
<s1>
<ptxt>
Remove high speed synchronizer sleeve &#38; hub assembly (2) together with 3rd gear (3) using puller (4) and hydraulic press.
</ptxt>
<attention2>
<ptxt>
To avoid gear teeth damage, support 3rd gear on flat side of bearing puller.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I2RH01520097.swf" width = "88.000mm" height = "40.248mm" ver = "01" gw = "139" gh = "97"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.067in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Input shaft
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove 3rd gear needle bearing from input shaft.
</ptxt>
</s1>
<s1>
<ptxt>
Disassemble synchronizer sleeve &#38; hub assembly.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A5206019002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Clean all components thoroughly, inspect them for any abnormality and replace with new ones if necessary.
</ptxt>
</s1>
<s1>
<ptxt>
Check clearance “a” between synchronizer ring (2) and gear (1), key slot width “b” in synchronizer ring and replace with new one, if necessary. Also, check gear teeth for damage.
</ptxt>
<spec>
<title>
Clearance “a” between synchronizer ring and gear
</title>
<ptxt>
Standard: 1.0 – 1.4 mm (0.040 – 0.055 in.)
</ptxt>
<ptxt>
Service limit: 0.5 mm (0.020 in.)
</ptxt>
</spec>
<spec>
<title>
Key slot width “b”
</title>
<ptxt>
Standard: 10.0 – 10.2 mm (0.394 – 0.402 in.)
</ptxt>
<ptxt>
Limit: 10.45 mm (0.4114 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I5JB0A520054.swf" width = "88.000mm" height = "78.686mm" ver = "01" gw = "141" gh = "206"/>
</figure>
</s1>
<s1>
<ptxt>
To ensure lubrication of input shaft (1), blow air to oil holes (2) as shown in figure and make sure that they are free from any obstruction.
</ptxt>
<figure>
<graphic graphicname = "I2RH01520049.swf" width = "88.000mm" height = "46.047mm" ver = "01" gw = "187" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Fit high speed synchronizer sleeve (4) to hub (3), insert 3 keys (2) in it and then set springs at specified position (1) as shown in figure.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to assemble sleeve and hub in correct direction. (No direction is specified to each key.)
</ptxt>
</item>
<item>
<ptxt>
High speed synchronizer sleeve, hub, keys and springs are smaller in size than low speed ones.
</ptxt>
</item>
</list1>
</attention3>
<spec>
<title>
Synchronizer key installation position
</title>
<ptxt>
“a” = “b”
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A520026.swf" width = "88.000mm" height = "86.772mm" ver = "01" gw = "172" gh = "229"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.388in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.388in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
4th gear side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[c]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Projecting end
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[b]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Short flange side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0">
<ptxt>
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install right bearing (1) to input shaft (2) using special tool and hydraulic press.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B022">
<s-part>
(A)
</s-part>
<s-number num = "09913-80113">
09913–80113
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I3RH0A520019.swf" width = "88.000mm" height = "50.069mm" ver = "01" gw = "76" gh = "125"/>
</figure>
</s1>
<s1>
<ptxt>
Install 3rd gear needle bearing (4), apply oil to it, then install 3rd gear (1) and synchronizer ring (2).
</ptxt>
</s1>
<s1>
<ptxt>
Install high speed sleeve &#38; hub assembly (3) using special tool and hydraulic press.
</ptxt>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Make sure that synchronizer ring key slots are aligned with keys (5) in sleeve &#38; hub assembly.
</ptxt>
</item>
<item>
<ptxt>
Check free rotation of 3rd gear after press-fitting sleeve &#38; hub assembly.
</ptxt>
</item>
</list1>
</attention3>
<servicetool>
<servicetoolitem id = "L5B023">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913–84510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A520027.swf" width = "88.000mm" height = "99.258mm" ver = "01" gw = "192" gh = "265"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.258in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.417in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
3rd gear side
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[c]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Long flange
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
[b]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Key way
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install new circlip (1) to groove securely.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Install needle bearing (2), apply oil to it and then install synchronizer ring (3) and 4th gear.
</ptxt>
<figure>
<graphic graphicname = "I2RH01520052.swf" width = "88.000mm" height = "45.751mm" ver = "01" gw = "170" gh = "113"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.067in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Input shaft
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Press-fit left bearing (2) using special tool and hydraulic press.
</ptxt>
<servicetool>
<servicetoolitem id = "L5B024">
<s-part>
(A)
</s-part>
<s-number num = "09913-80113">
09913–80113
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Using the same special tool at step 10), install 5th gear spacer (1).
</ptxt>
<attention2>
<ptxt>
To prevent 5th gear spacer (1) from being distorted by excessive compression, do not press-fit it with left bearing (2) at once.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "I3RH0A520020.swf" width = "88.000mm" height = "59.848mm" ver = "01" gw = "182" gh = "153"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
