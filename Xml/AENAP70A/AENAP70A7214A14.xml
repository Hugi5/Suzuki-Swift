<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A7214A14" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Loud rattle is heard at low engine rpm
</title>
<servinfosub id = "AENAP70A7214004001">
<title>
Abnormal Noise from Compressor
</title>
<diag type = "condition">
<condition>
<ptxt>
Loud rattle is heard at low engine rpm
</ptxt>
</condition>
<ps>
<ptxt>
Loose compressor clutch plate nut
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Retighten clutch plate nut. 
<intxreftitleoff1 refid = "AENAP70A7216041"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Replace compressor if it has been operated in rattling condition for a long time.
</ptxt>
</paragroup>
</action>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
