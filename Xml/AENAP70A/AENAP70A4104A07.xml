<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4A">
<servcat sctnbr = "04" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A4104A07" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Pedal pulsation (Pedal pulsates when depressed for braking)
</title>
<diag type = "condition">
<condition>
<ptxt>
Pedal pulsation (Pedal pulsates when depressed for braking)
</ptxt>
</condition>
<ps>
<ptxt>
Damaged or loose front and/or rear wheel bearings
</ptxt>
</ps>
<action>
<ptxt>
Replace wheel bearings.
</ptxt>
</action>
<ps>
<ptxt>
Distorted steering knuckle
</ptxt>
</ps>
<action>
<ptxt>
Replace knuckle.
</ptxt>
</action>
<ps>
<ptxt>
Excessive brake disc lateral runout
</ptxt>
</ps>
<action>
<ptxt>
Check per instructions. If not within specifications, replace or machine disc.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
