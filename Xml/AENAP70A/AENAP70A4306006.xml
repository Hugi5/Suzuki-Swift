<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "4C">
<servcat sctnbr = "04" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A4306006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Brake Disc Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A4306005">Rear Brake Disc Removal and Installation</intxrefpoff>
</ptxt>
<ptxt>
Measure deflection of rear brake disc at point 10 mm (0.39 in.) inside from its edge using special tools. Repair or replace rear brake disc if defective.
</ptxt>
<spec-sdm>
<sdm-title>
Rear brake disc deflection
</sdm-title>
<sdm1>
<sdm-condition>
Limit
</sdm-condition>
<sdm-value>
0.10 mm (0.004 in.)
</sdm-value>
</sdm1>
</spec-sdm>
<servicetool>
<servicetoolitem id = "L4C002">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900–20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L4C003">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900–20701
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A430009.swf" width = "88.000mm" height = "65.936mm" ver = "02" gw = "137" gh = "170"/>
</figure>
<ptxt>
Measure thickness of rear brake disc with micrometer. If thickness is less than limit, replace rear brake disc.
</ptxt>
<spec-sdm>
<sdm-title>
Rear brake disc thickness
</sdm-title>
<sdm-part>
“a”
</sdm-part>
<sdm1>
<sdm-condition>
Standard
</sdm-condition>
<sdm-value>
9 mm (0.35 in.)
</sdm-value>
</sdm1>
<sdm1>
<sdm-condition>
Limit
</sdm-condition>
<sdm-value>
8 mm (0.31 in.)
</sdm-value>
</sdm1>
</spec-sdm>
<figure>
<graphic graphicname = "IAP70A430010.swf" width = "88.000mm" height = "42.331mm" ver = "01" gw = "120" gh = "103"/>
</figure>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
