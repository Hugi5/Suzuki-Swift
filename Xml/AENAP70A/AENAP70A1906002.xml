<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1I">
<servcat sctnbr = "01" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1906002" svcinfotypenbr = "08" svcinfoqualnbr = "01" supplyoff = "1" modify = "0">
<title>
Starting Motor Removal and Installation
</title>
<servinfosub id = "AENAP70A1906002001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove intake manifold. 
<intxreftitleoff1 refid = "AENAP70A1406009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove knock sensor bracket (1) from cylinder block.
</ptxt>
<figure>
<graphic graphicname = "IAP70A190003.swf" width = "88.000mm" height = "58.388mm" ver = "01" gw = "172" gh = "149"/>
</figure>
</s1>
<s1>
<ptxt>
Disconnect magnetic switch lead wire (1) and starting motor cable (2) from starting motor.
</ptxt>
</s1>
<s1>
<ptxt>
Remove starting motor mounting bolts (3).
</ptxt>
</s1>
<s1>
<ptxt>
Remove starting motor (4).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A190005.swf" width = "183.000mm" height = "82.031mm" ver = "02" gw = "405" gh = "216"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70A1906002002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1906009">Starting Motor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedures, noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten starting motor mounting bolts and starting motor cable nut to specified torques.
</ptxt>
</item>
</list1>
<torque>
<torqueitem id = "T1I001">
<t-part>
Starting motor cable nut
</t-part>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
<torqueitem id = "T1I002">
<t-part>
Starting motor mounting bolt
</t-part>
<t-value1>
45
</t-value1>
<t-value2>
4.6
</t-value2>
<t-value3>
33.5
</t-value3>
</torqueitem>
</torque>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
