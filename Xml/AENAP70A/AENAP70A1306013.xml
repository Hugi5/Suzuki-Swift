<section sectnbr = "1C">
<servcat sctnbr = "01" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1306013" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
A/F Sensor On-Vehicle Inspection
</title>
<c-change/>
<servinfosub id = "AENAP70A1306013001">
<title>
A/F Sensor Heater
</title>
<s1>
<ptxt>
Disconnect A/F sensor connector with ignition “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Using ohmmeter, measure resistance of A/F sensor connector (sensor side) between terminals “2” and “5” at A/F sensor connector. If faulty condition is found, replace A/F sensor. 
<intxreftitleoff1 refid = "AENAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<attention3>
<ptxt>
Temperature of sensor affects resistance value largely. Make sure that sensor heater is at correct temperature.
</ptxt>
</attention3>
<spec>
<title>
A/F sensor heater resistance
</title>
<ptxt>
2.4 to 4.0 &#937; at 20 &#176;C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7N301132038.swf" width = "88.000mm" height = "30.676mm" ver = "01" gw = "67" gh = "70"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.314in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.150in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
A/F sensor connector (viewed from terminal side)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1306013002" page = "2">
<title>
A/F Sensor Adjusting Resistor
</title>
<ptxt>
Using ohmmeter, measure resistance between terminals “1” and “3” at A/F sensor connector. If faulty condition is found, replace A/F sensor. 
<intxreftitleoff1 refid = "AENAP70A1306015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<spec>
<title>
A/F sensor adjusting resistance
</title>
<ptxt>
30 to 300 &#937; at 20 &#176;C (68 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "I7N301132038.swf" width = "88.000mm" height = "30.676mm" ver = "01" gw = "67" gh = "70"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.314in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.150in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
1.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
A/F sensor connector (viewed from terminal side)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</servinfosub>
</servinfo>
