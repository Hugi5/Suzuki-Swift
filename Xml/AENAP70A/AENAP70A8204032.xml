<servinfosub id = "AENAP70A8204032003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A8204032004">
<testgroup id = "AENAP70A8204032005">
<question>
Was “Air Bag Diagnostic System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A8204001">Air Bag Diagnostic System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204032006">
<title>
Side-air bag (inflator) module circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is in “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “Q104” or “Q105” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “L04” or “L05” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector inserting release tool included in special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between each of “A1” and “A2” circuits and ground (DTC B1063): infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A3” and “A4” circuits and ground (DTC B1067): infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B052">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820128.swf" width = "90.000mm" height = "106.396mm" ver = "02" gw = "228" gh = "285"/>
</testfigure>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace SDM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A8206003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A8204032007">
<title>
Floor harness circuit check
</title>
<test1>
<ptxt>
Disconnect “L384” or “L385” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Release shorting bar in SDM connector inserting release tool included in special tool (A).
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance between each of “A1” and “A2” circuits and ground (DTC B1063): infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “A3” and “A4” circuits and ground (DTC B1067): infinity
</ptxt>
</item>
</list1>
<servicetool>
<servicetoolitem id = "L8B053">
<s-part>
(A)
</s-part>
<s-number num = "09932-76010">
09932–76010
</s-number>
</servicetoolitem>
</servicetool>
<testfigure>
<graphic graphicname = "IAW101820128.swf" width = "90.000mm" height = "106.396mm" ver = "02" gw = "228" gh = "285"/>
</testfigure>
</test1>
<question>
Is each measured resistance infinite?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace seat harness.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace floor harness.
</ptxt>
</action>
</testgroup>
</diag>
<attention3>
<ptxt>
Upon completion of inspection and repair work, perform the following items.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reconnect all air bag system components and ensure all components are properly mounted.
</ptxt>
</item>
<item>
<ptxt>
Clear DTCs, referring to 
<intxref refid = "AENAP70A8204006">DTC Clearance</intxref>
 if any DTC is detected.
</ptxt>
</item>
<item>
<ptxt>
Repeat 
<intxref refid = "AENAP70A8204001">Air Bag Diagnostic System Check</intxref>
 to confirm that the trouble has been solved.
</ptxt>
</item>
</list1>
</attention3>
