<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A5206002" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Manual Transaxle Oil Change
</title>
<s1>
<ptxt>
Before changing oil, be sure to stop engine and hoist vehicle horizontally.
</ptxt>
</s1>
<s1>
<ptxt>
With vehicle hoisted, check leakage.
</ptxt>
<ptxt>
If leakage exists, correct it.
</ptxt>
</s1>
<s1>
<ptxt>
Remove oil level / filler plug (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove drain plug (1), and drain oil.
</ptxt>
</s1>
<s1>
<ptxt>
Apply sealant to thread of drain plug (1), and tighten it to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M5B002" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<torque>
<torqueitem id = "T5B002">
<t-part>
Transaxle oil drain plug
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
21
</t-value1>
<t-value2>
2.1
</t-value2>
<t-value3>
15.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Replenish new specified oil until oil level reaches lower end of oil filler plug hole (3) as shown in figure.
</ptxt>
<attention3>
<ptxt>
It is highly recommended to use “SUZUKI GEAR OIL 75W-80”.
</ptxt>
</attention3>
<spec>
<title>
Transaxle oil specification
</title>
<ptxt>
: SUZUKI GEAR OIL 99000–22B21–036
</ptxt>
<ptxt>
: API GL-4 (For SAE classification, refer to viscosity chart.)
</ptxt>
</spec>
<spec-sdm>
<sdm-title>
Transaxle oil capacity
</sdm-title>
<sdm1>
<sdm-condition>
Reference
</sdm-condition>
<sdm-value>
2.5 liters (5.23/4.40 US/Imp. pt.)
</sdm-value>
</sdm1>
</spec-sdm>
<spec>
<title>
Viscosity chart
</title>
<figure>
<graphic graphicname = "IAP70A520004.swf" width = "88.000mm" height = "23.678mm" ver = "01" gw = "190" gh = "51"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.503in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[a]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Out side temperature
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</spec>
</s1>
<s1>
<ptxt>
Apply sealant to thread of level / filler plug, and then tighten it to specified torque.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M5B003" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<torque>
<torqueitem id = "T5B003">
<t-part>
Transaxle oil level / filler plug
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
21
</t-value1>
<t-value2>
2.1
</t-value2>
<t-value3>
15.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A520005.jpg" width = "88.000mm" height = "61.033mm" ver = "01" gw = "213" gh = "156"/>
</figure>
<figure>
<graphic graphicname = "IAP70A320006.swf" width = "88.000mm" height = "33.474mm" ver = "01" gw = "80" gh = "78"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
