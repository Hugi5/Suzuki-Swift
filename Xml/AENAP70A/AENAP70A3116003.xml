<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3116003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Front Drive Shaft Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A3116001">Front Drive Shaft Components:Front</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A3116002">Front Drive Shaft Assembly On-Vehicle Inspection:Front</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A3116003001">
<title>
Removal
</title>
<s1 page = "2">
<ptxt>
Hoist vehicle and remove front wheel. 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Release caulking (1) and remove drive shaft nut (2) with brake pedal depressed.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311002.swf" width = "88.000mm" height = "54.100mm" ver = "01" gw = "182" gh = "137"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Drain transaxle oil and transfer oil.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Transaxle oil: 
<intxreftitleoff1 refid = "AENAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Transfer oil: 
<intxreftitleoff1 refid = "AENAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</s1>
<s1 page = "2">
<ptxt>
Remove front wheel speed sensor from steering knuckle. 
<intxreftitleoff1 refid = "AENAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Disconnect suspension arm joint from steering knuckle. 
<intxreftitleoff1 refid = "AENAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Use tire lever (1) or plastic hammer (3) to pull out drive shaft joint (2).
</ptxt>
<attention3>
<ptxt>
Turning drive shaft while pulling out drive shaft may facilitate release of the snap ring fitting of joint spline.
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A311004.swf" width = "88.000mm" height = "41.941mm" ver = "01" gw = "197" gh = "102"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.298in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.315in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.298in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[A]:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Left side shaft
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
[B]:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Right side shaft
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove drive shaft assembly.
</ptxt>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70A3116003002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following points.
</ptxt>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Be careful not to damage oil seals and boots when installing drive shaft.
</ptxt>
</item>
<item>
<ptxt>
Do not hit joint boot with hammer. Inserting joint only by hands is allowed.
</ptxt>
</item>
<item>
<ptxt>
Make sure that differential side joint is inserted fully and its circlip is seated as it was installed.
</ptxt>
</item>
<item>
<ptxt>
Before inserting drive shaft (1), confirm that there is no foreign materials around encoder (2) on wheel bearing.
</ptxt>
<figure>
<graphic graphicname = "IAP70A311003.swf" width = "88.000mm" height = "51.493mm" ver = "01" gw = "203" gh = "129"/>
</figure>
</item>
</list1>
</attention2>
<list1 type = "unordered">
<item>
<ptxt>
Use new differential side joint circlip.
</ptxt>
</item>
<item>
<ptxt>
Apply grease to mating surface of front wheel hub and drive shaft.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A101" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A311005.jpg" width = "88.000mm" height = "67.700mm" ver = "01" gw = "230" gh = "175"/>
</figure>
</item>
<item>
<ptxt>
Tighten drive shaft nut (1) to specified torque.
</ptxt>
<attention2>
<ptxt>
Be sure to use new drive shaft nut.
</ptxt>
</attention2>
<torque>
<torqueitem id = "T3A101">
<t-part>
Drive shaft nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17.8
</t-value2>
<t-value3>
129.0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Caulk drive shaft nut (1) as shown.
</ptxt>
<attention2>
<ptxt>
Be sure not to crack caulking part (2) of drive shaft nut while caulking it. Replace it with new one if it is cracked.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A311006.swf" width = "88.000mm" height = "54.205mm" ver = "01" gw = "172" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Connect suspension arm joint. 
<intxreftitleoff1 refid = "AENAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Install front wheel speed sensor. 
<intxreftitleoff1 refid = "AENAP70A4606007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Install front wheel. 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Replenish transaxle oil. 
<intxreftitleoff1 refid = "AENAP70A5206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Replenish transfer oil. 
<intxreftitleoff1 refid = "AENAP70A3306002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Check front wheel alignment. 
<intxreftitleoff1 refid = "AENAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
