<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "2C">
<servcat sctnbr = "02" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A2306003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Shock Absorber Removal and Installation
</title>
<servinfosub id = "AENAP70A2306003001">
<title>
Removal
</title>
<s1>
<ptxt>
Hoist vehicle and remove rear wheels. 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove access hole cover (1) in quarter inner trim (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60A230002.swf" width = "88.000mm" height = "52.091mm" ver = "01" gw = "165" gh = "131"/>
</figure>
</s1>
<s1>
<ptxt>
Support rear axle using floor jack to prevent it from lowering.
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear shock absorber lower nut (1) and lower washer (5).
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear shock absorber upper nut (2), rear shock absorber (3) and shock absorber upper washer (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A230002.swf" width = "88.000mm" height = "119.930mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Remove shock absorber upper bushings (1).
</ptxt>
<figure>
<graphic graphicname = "I9P60A230004.swf" width = "88.000mm" height = "81.823mm" ver = "01" gw = "147" gh = "215"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A2306003002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A2306004">Rear Shock Absorber Inspection</intxrefpoff>
</ptxt>
<attention2>
<ptxt>
Rear shock absorber upper nut is self-locking nut. Do not reuse nut. Otherwise, nut may loosen.
</ptxt>
</attention2>
<s1>
<ptxt>
Install shock absorber upper bushings (6), rear shock absorber (1), and shock absorber upper washer (2) as shown in figure.
</ptxt>
<ptxt>
Tighten new shock absorber upper nut (4), lower nut (5) temporarily at this step.
</ptxt>
<attention3>
<ptxt>
Refer to the figure below for proper installing direction of shock absorber upper washer (2).
</ptxt>
</attention3>
<figure>
<graphic graphicname = "IAP70A230003.swf" width = "88.000mm" height = "52.815mm" ver = "01" gw = "236" gh = "133"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.956in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "top" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "top" align = "left">
<ptxt>
Body panel
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<c-change/>
<s1>
<ptxt>
Remove floor jack from rear axle.
</ptxt>
</s1>
<s1>
<ptxt>
Install rear wheels. 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Tighten rear shock absorber upper nut and lower nut to specified torques.
</ptxt>
<attention3>
<ptxt>
When tightening these nuts, be sure that vehicle is not on hoist and in unloaded condition.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T2C001">
<t-part>
Rear shock absorber upper nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
28
</t-value1>
<t-value2>
2.9
</t-value2>
<t-value3>
21.0
</t-value3>
</torqueitem>
<torqueitem id = "T2C002">
<t-part>
Rear shock absorber lower nut
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
90
</t-value1>
<t-value2>
9.2
</t-value2>
<t-value3>
66.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A230004.swf" width = "88.000mm" height = "119.931mm" ver = "01" gw = "247" gh = "323"/>
</figure>
</s1>
<s1>
<ptxt>
Install access hole cover in quarter inner trim.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
