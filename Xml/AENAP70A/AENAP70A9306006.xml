<section sectnbr = "9C">
<servcat sctnbr = "09" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9306006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Parking Sensor Inspection (If Equipped)
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A9306005">Parking Sensor Removal and Installation (If Equipped)</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check parking sensor for damage.
</ptxt>
</item>
<item>
<ptxt>
Check parking sensor connector for damage.
</ptxt>
</item>
<item>
<ptxt>
Check parking sensor connector terminal for bend, rust or corrosion.
</ptxt>
<ptxt>
If any defect is found, replace parking sensor.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
