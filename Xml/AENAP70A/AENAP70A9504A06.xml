<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A9504A06" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
One of the power door mirrors cannot operate
</title>
<diag type = "condition">
<condition>
<ptxt>
One of the power door mirrors cannot operate
</ptxt>
</condition>
<ps>
<ptxt>
Faulty power door mirror switch
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A9506023">Power Door Mirror Switch Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty power door mirror actuator
</ptxt>
</ps>
<action>
<ptxt>
<intxref refid = "AENAP70A9506021">Power Door Mirror and Mirror Heater On-Vehicle Inspection</intxref>
</ptxt>
</action>
<ps>
<ptxt>
Faulty wiring or ground
</ptxt>
</ps>
<action>
<ptxt>
Repair wiring.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
