<intxreftitleoff1 refid = "AENAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1852 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace parking sensor (rear-center-left).
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A9304009008">
