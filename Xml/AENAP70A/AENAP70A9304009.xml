<servinfosub id = "AENAP70A9304009003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A9304009004">
<testgroup id = "AENAP70A9304009005">
<title>
Circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect parking sensor system control module connectors and all parking sensor connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection parking sensor system control module connector and all parking sensor connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check circuits between parking sensor system control module connector and all parking sensor connectors for open circuit, short to ground or short to power supply.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A9304009006">
<title>
Parking sensor (rear-left) check
</title>
<test1>
<ptxt>
Connect parking sensor system control module connector and all parking sensor connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Replace parking sensor (rear-left). 
<intxreftitleoff1 refid = "AENAP70A9306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1852 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace parking sensor (rear-left).
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A9304009007">
<title>
Parking sensor (rear-center-left) check
</title>
