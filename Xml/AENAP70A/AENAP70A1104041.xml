<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0515: Battery Temperature Sensor Circuit
</emph>
</ptxt>
<ptxt>
Any of the following conditions is met.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Output voltage of battery temperature signal circuit is lower than 0.1 V for 5 sec.
</ptxt>
</item>
<item>
<ptxt>
Output voltage of battery temperature signal circuit is higher than 4.8 V for 5 sec.
</ptxt>
</item>
</list1>
<ptxt>
(3 D/C detection logic but MIL does not light up)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Electric load current sensor and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
