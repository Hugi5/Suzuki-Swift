<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A8206024" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Side-Impact Sensor Removal and Installation
</title>
<attention2>
<list1 type = "unordered">
<item>
<ptxt>
Never repair or disassemble sensor.
</ptxt>
</item>
<item>
<ptxt>
Never drop, strike or shake sensor.
</ptxt>
<ptxt>
If dropped, replace it even if there is no defect in appearance.
</ptxt>
<ptxt>
If sensor is deformed or cracked, replace.
</ptxt>
</item>
<item>
<ptxt>
Sensor bolt must be carefully torqued to assure proper operation.
</ptxt>
<ptxt>
Loosely connected sensor may cause improper operation of air bag system.
</ptxt>
</item>
</list1>
</attention2>
<servinfosub id = "AENAP70A8206024001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove rear seat back assembly. 
<intxreftitleoff1 refid = "AENAP70A9706007"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove quarter inner lower trim. 
<intxreftitleoff1 refid = "AENAP70A9806009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect rear side-impact sensor connector (2) as follows.
</ptxt>
<s2>
<ptxt>
Release locking slider (1) by sliding it in direction of arrow “1”.
</ptxt>
</s2>
<s2>
<ptxt>
Disconnect rear side-impact sensor connector (2) by pulling it in direction of arrow.
</ptxt>
</s2>
</s1>
<s1>
<ptxt>
Remove rear side-impact sensor bolt (3) and remove rear side-impact sensor (4) from rear pillar inner panel (5).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820076.swf" width = "88.000mm" height = "104.086mm" ver = "01" gw = "215" gh = "279"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A8206024002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A8206025">Rear Side-Impact Sensor Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Check that none of the following faulty conditions exists.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Bend, deformation or rust on quarter inner panel.
</ptxt>
</item>
<item>
<ptxt>
Foreign material on sensor.
</ptxt>
</item>
</list1>
</s1>
<s1>
<ptxt>
Align mounting pin (1) to mounting hole (2) of vehicle to install rear side-impact sensor (3) securely.
</ptxt>
</s1>
<s1>
<ptxt>
Tighten rear side-impact sensor bolt to specified torque.
</ptxt>
<torque>
<torqueitem id = "T8B009">
<t-part>
Rear side-impact sensor bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
9.0
</t-value1>
<t-value2>
0.92
</t-value2>
<t-value3>
7.0
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Connect rear side-impact sensor connector securely.
</ptxt>
<figure>
<graphic graphicname = "I9P60A820077.swf" width = "88.000mm" height = "71.040mm" ver = "01" gw = "215" gh = "185"/>
</figure>
</s1>
<s1>
<ptxt>
Install quarter inner lower trim.
</ptxt>
</s1>
<s1>
<ptxt>
Install rear seat back assembly. 
<intxreftitleoff1 refid = "AENAP70A9706006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Enable air bag system. 
<intxreftitleoff1 refid = "AENAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
