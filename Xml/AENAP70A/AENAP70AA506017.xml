<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70AA506017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Outside Warning Buzzer Removal and Installation
</title>
<servinfosub id = "AENAP70AA506017001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove driver side front fender lining. 
<intxreftitleoff1 refid = "AENAP70A9A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector (1), and then remove outside warning buzzer (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50032.jpg" width = "88.000mm" height = "68.823mm" ver = "01" gw = "213" gh = "179"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70AA506017002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70AA506018">Outside Warning Buzzer Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
