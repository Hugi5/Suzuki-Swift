<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9206016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Hazard Warning Switch Removal and Installation
</title>
<servinfosub id = "AENAP70A9206016001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove center ventilation louver (1). 
<intxreftitleoff1 refid = "AENAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector, and then remove hazard warning switch (2) from center upper box while releasing the locks (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A920023.jpg" width = "88.000mm" height = "65.260mm" ver = "01" gw = "181" gh = "168"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A9206016002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A9206017">Hazard Warning Switch Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
