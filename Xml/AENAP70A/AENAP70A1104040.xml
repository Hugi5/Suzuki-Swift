<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph>
P0504: Brake Switch “A”/“B” Correlation
</emph>
</ptxt>
<ptxt>
Any of the following conditions is met.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Both brake light switch signal voltage and brake switch signal voltage are at low level for specified time.
</ptxt>
</item>
<item>
<ptxt>
Both brake light switch signal voltage and brake switch signal voltage are at high level for specified time.
</ptxt>
</item>
</list1>
<ptxt>
(3 D/C detection logic but MIL does not light up)
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
Brake light switch and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
