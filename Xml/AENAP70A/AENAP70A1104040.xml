<servinfosub id = "AENAP70A1104040003">
<title>
DTC Confirmation Procedure
</title>
<attention1>
<list1 type = "unordered">
<item>
<ptxt>
Perform road test in a place where there is no traffic to prevent an accident.
</ptxt>
</item>
<item>
<ptxt>
Road test should be performed by two persons, a driver and a tester, on a level road.
</ptxt>
</item>
</list1>
</attention1>
<s1>
<ptxt>
Start engine and warm up to normal operating temperature.
</ptxt>
</s1>
<s1>
<ptxt>
Drive vehicle at 50 to 70 km/h (31 to 43 mph).
</ptxt>
</s1>
<s1>
<ptxt>
Stop vehicle.
</ptxt>
</s1>
<s1>
<ptxt>
Depress brake pedal.
</ptxt>
</s1>
<s1>
<ptxt>
Repeat Steps 2) through 4) 10 times.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1104040004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A1104040005">
<testgroup id = "AENAP70A1104040006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104040007">
<title>
Brake light switch power supply circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect brake light switch connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to brake light switch connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between each of “A1” and “A2” circuits and ground is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104040008">
<title>
Brake light switch signal circuit check
</title>
<test1>
<ptxt>
When ignition is OFF, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B1” and “B2” circuits: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between each of “B1” and “B2” circuits and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B1” circuit terminal and other terminal at brake light switch connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B2” circuit terminal and other terminal at brake light switch connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B1” and “B2” circuits: 0 to 1 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wire harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104040009">
<title>
Brake light switch check
</title>
<test1>
<ptxt>
Check brake light switch. 
<intxreftitleoff1 refid = "AENAP70A4106011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace brake light switch.
</ptxt>
</action>
</testgroup>
</diag>
