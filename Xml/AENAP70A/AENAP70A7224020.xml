<diag type = "test" id = "AENAP70A7224020007">
<testgroup id = "AENAP70A7224020008">
<title>
Scan tool parameter check
</title>
<test1>
<ptxt>
Check “Air Mix Pos Sen” using “Data list” mode on SUZUKI scan tool. 
<intxreftitleoff1 refid = "AENAP70A7224008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is it in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A7224020009">
<title>
Temperature control actuator circuit check
</title>
<test1>
<ptxt>
Disconnect “G20” and temperature control actuator connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “GRY” and “LT BLU” wire circuits: less than 1 Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance of “GRY” and “LT BLU” wire circuits between temperature control actuator and ground: infinity
</ptxt>
</item>
</list1>
</test1>
<question>
Are resistance values as specified?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace instrument panel harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A7224020010">
<title>
Temperature control actuator check
</title>
<test1>
<ptxt>
Check temperature control actuator. 
<intxreftitleoff1 refid = "AENAP70A7226025"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is actuator in good condition?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace HVAC control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace temperature control actuator. 
<intxreftitleoff1 refid = "AENAP70A7226024"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
</diag>
