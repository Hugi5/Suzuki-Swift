<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A9504A04" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Abnormal noise
</title>
<diag type = "condition">
<condition>
<ptxt>
Abnormal noise
</ptxt>
</condition>
<ps>
<ptxt>
Loose window regulator mounting bolts
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Tighten window regulator mounting bolts.
</ptxt>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70A9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70A9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Worn or broken power window regulator sliding and rotating parts
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Replace window regulator.
</ptxt>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70A9506012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70A9506017"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
<ps>
<ptxt>
Poor greasing
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Lubricate.
</ptxt>
<ptxt>
Front: 
<intxreftitleoff1 refid = "AENAP70A9506010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Rear: 
<intxreftitleoff1 refid = "AENAP70A9506014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
