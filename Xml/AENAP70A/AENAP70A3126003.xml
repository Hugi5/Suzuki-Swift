<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3A">
<servcat sctnbr = "03" scnbr = "01">
<configtype typenbr = "2">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3126003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Rear Drive Shaft Assembly Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A3126001">Rear Drive Shaft Components:Rear</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A3126002">Rear Drive Shaft Assembly On-Vehicle Inspection:Rear</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A3126003001">
<title>
Removal
</title>
<s1>
<ptxt>
Hoist vehicle and remove rear wheel. 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Release caulking (1) and remove drive shaft nut (2) with brake pedal depressed.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312002.swf" width = "88.000mm" height = "53.091mm" ver = "01" gw = "177" gh = "134"/>
</figure>
</s1>
<s1>
<ptxt>
Remove rear drive shaft flange nuts (1), and remove rear drive shaft assembly.
</ptxt>
<figure>
<graphic graphicname = "IAP70A312003.swf" width = "88.000mm" height = "47.465mm" ver = "01" gw = "177" gh = "118"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A3126003002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Tighten new drive shaft nut (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T3A202">
<t-part>
Drive shaft nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
175
</t-value1>
<t-value2>
17.8
</t-value2>
<t-value3>
129.0
</t-value3>
</torqueitem>
</torque>
</item>
<item>
<ptxt>
Caulk drive shaft nut (1) as shown.
</ptxt>
<attention2>
<ptxt>
Be careful not to crack caulking part (2) of drive shaft nut while caulking it. Replace it with a new one if it cracks.
</ptxt>
</attention2>
<figure>
<graphic graphicname = "IAP70A312004.swf" width = "88.000mm" height = "52.301mm" ver = "01" gw = "159" gh = "132"/>
</figure>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Tighten rear drive shaft flange nuts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T3A203">
<t-part>
Rear drive shaft flange nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
50
</t-value1>
<t-value2>
5.1
</t-value2>
<t-value3>
37.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A312005.swf" width = "88.000mm" height = "49.964mm" ver = "01" gw = "177" gh = "125"/>
</figure>
</item>
<item>
<ptxt>
Apply grease to mating surface of rear wheel hub assembly and rear drive shaft.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3A202" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "IAP70A312006.swf" width = "88.000mm" height = "54.175mm" ver = "02" gw = "227" gh = "137"/>
</figure>
</item>
<item>
<ptxt>
Tighten wheel nuts to specified torque. 
<intxreftitleoff1 refid = "AENAP70A2406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
