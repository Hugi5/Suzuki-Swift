<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70AA506011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Keyless Entry Receiver Removal and Installation
</title>
<servinfosub id = "AENAP70AA506011001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Remove center console box. 
<intxreftitleoff1 refid = "AENAP70A9806012"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect keyless entry receiver connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove screw (3), and then remove keyless entry receiver (2).
</ptxt>
<figure>
<graphic graphicname = "I9P60AA50030.swf" width = "88.000mm" height = "77.203mm" ver = "01" gw = "202" gh = "202"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70AA506011002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70AA506012">Keyless Entry Receiver Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
