<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A7216016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Evaporator Temperature Sensor Removal and Installation
</title>
<servinfosub id = "AENAP70A7216016001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove HVAC unit from vehicle body. 
<intxreftitleoff1 refid = "AENAP70A7216008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove evaporator temperature sensor (1) from evaporator (2) by disassembling HVAC unit.
</ptxt>
<figure>
<graphic graphicname = "I7RW01721018.swf" width = "88.000mm" height = "35.209mm" ver = "01" gw = "149" gh = "83"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A7216016002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A7216017">Evaporator Temperature Sensor Inspection:Manual Type</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure, noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Install evaporator temperature sensor (1) onto evaporator (2) as shown.
</ptxt>
<figure page = "2">
<graphic graphicname = "IAP70A721019.swf" width = "88.000mm" height = "70.551mm" ver = "02" gw = "167" gh = "183"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.247in"/>
<colspec colnum = "2" colname = "2" colwidth = "3.053in"/>
<tbody>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Approx. 30 mm (1.2 in.)
</ptxt>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
4.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Sensor part fixed to 16th fin from the left
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1">
<ptxt>
Pipe fitting
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
