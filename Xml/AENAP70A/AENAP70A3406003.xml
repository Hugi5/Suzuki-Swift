<section sectnbr = "3D">
<servcat sctnbr = "03" scnbr = "04">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3406003" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Propeller Shaft Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A3406002">Propeller Shaft Removal and Installation</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Check propeller shaft connecting bolts and nuts for looseness. If looseness is found, tighten to specified torque. 
<intxreftitleoff1 refid = "AENAP70A3406001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check propeller shaft joints for wear, play and damage. If any defect is found, replace it.
</ptxt>
</s1>
<s1>
<ptxt>
Check propeller shaft center bearing support for biting of foreign matter, crack, abnormal noise and damage. If any defect is found, replace it.
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
