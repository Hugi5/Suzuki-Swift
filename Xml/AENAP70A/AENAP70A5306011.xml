<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A5306011" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Clutch Master Cylinder Removal and Installation
</title>
<servinfosub id = "AENAP70A5306011001">
<title>
Removal
</title>
<s1 page = "2">
<ptxt>
Clean around brake master cylinder reservoir cap and remove fluid from brake master cylinder reservoir with syringe or such.
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Disconnect clutch fluid pipe from clutch master cylinder. 
<intxreftitleoff1 refid = "AENAP70A5306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1 page = "2">
<ptxt>
Disconnect clutch reservoir hose (1).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530007.swf" width = "88.000mm" height = "49.059mm" ver = "01" gw = "141" gh = "123"/>
</figure>
</s1>
<s1 page = "2">
<ptxt>
Remove push rod (1) from clutch pedal (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove clutch master cylinder nuts (3), and then remove clutch master cylinder (4).
</ptxt>
<figure>
<graphic graphicname = "IAP70A530008.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A5306011002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A5306012">Clutch Master Cylinder Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Apply grease to push rod tip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Silicone Grease" id = "M5C001" uid = "21">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25100
</m-number>
<m-name>
SUZUKI Silicone Grease
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</item>
</list1>
<list1 type = "unordered">
<item>
<ptxt>
Tighten clutch master cylinder nuts (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T5C004">
<t-part>
Clutch master cylinder nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
13
</t-value1>
<t-value2>
1.3
</t-value2>
<t-value3>
9.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A531013.jpg" width = "88.000mm" height = "71.588mm" ver = "01" gw = "236" gh = "186"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
