<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A9204A10" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Brake lights do not light up
</title>
<diag type = "condition">
<condition>
<ptxt>
Brake lights do not light up
</ptxt>
</condition>
<ps>
<ptxt>
Faulty system circuit (including relays and fuses)
</ptxt>
</ps>
<action>
<ptxt>
Repair circuit.
</ptxt>
</action>
<ps>
<ptxt>
Blown bulbs
</ptxt>
</ps>
<action>
<ptxt>
Replace bulbs.
</ptxt>
</action>
<ps>
<ptxt>
Faulty brake light switch
</ptxt>
</ps>
<action>
<ptxt>
Refer to 
<intxref refid = "AENAP70A4106011">Brake Light Switch Inspection</intxref>
.
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
