<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A5204A02" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hard shifting
</title>
<diag type = "condition">
<condition>
<ptxt>
Hard shifting
</ptxt>
</condition>
<ps>
<ptxt>
Inadequate lubricant
</ptxt>
</ps>
<action>
<ptxt>
Replenish manual transaxle oil.
</ptxt>
</action>
<ps>
<ptxt>
Improper clutch pedal free travel
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace clutch pedal arm or clutch master cylinder. 
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Clutch pedal arm: 
<intxreftitleoff1 refid = "AENAP70A5306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Clutch master cylinder: 
<intxreftitleoff1 refid = "AENAP70A5306011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Distorted or broken clutch disc
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch disc. 
<intxreftitleoff1 refid = "AENAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Damaged clutch pressure plate
</ptxt>
</ps>
<action>
<ptxt>
Replace clutch cover. 
<intxreftitleoff1 refid = "AENAP70A5306018"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Worn synchronizer ring
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace synchronizer ring.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Low speed synchronizer ring and 2nd gear synchronizer ring: 
<intxreftitleoff1 refid = "AENAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
High speed synchronizer ring: 
<intxreftitleoff1 refid = "AENAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5th speed synchronizer ring: 
<intxreftitleoff1 refid = "AENAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Worn chamfered tooth on sleeve or gear
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace synchronizer sleeve &#38; hub and gear.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Countershaft 1st gear and 2nd gear: 
<intxreftitleoff1 refid = "AENAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Input shaft 3rd gear and 4th gear: 
<intxreftitleoff1 refid = "AENAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Input shaft 5th gear: 
<intxreftitleoff1 refid = "AENAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Low speed synchronizer sleeve &#38; hub: 
<intxreftitleoff1 refid = "AENAP70A5206020"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
High speed synchronizer sleeve &#38; hub: 
<intxreftitleoff1 refid = "AENAP70A5206019"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5th speed synchronizer sleeve &#38; hub: 
<intxreftitleoff1 refid = "AENAP70A5206014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Worn gear shift control shaft joint bushing
</ptxt>
</ps>
<action>
<ptxt>
Replace gear shift control shaft joint bushing. 
<intxreftitleoff1 refid = "AENAP70A5206011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Distorted shift shaft
</ptxt>
</ps>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Replace shift fork or shift shaft.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Low speed gear shift shaft: 
<intxreftitleoff1 refid = "AENAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
High speed gear shift shaft: 
<intxreftitleoff1 refid = "AENAP70A5206015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
5th gear shift fork: 
<intxreftitleoff1 refid = "AENAP70A5206022"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<ps>
<ptxt>
Broken gear shift / select control cables
</ptxt>
</ps>
<action>
<ptxt>
Replace gear shift and select cable. 
<intxreftitleoff1 refid = "AENAP70A5206005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
