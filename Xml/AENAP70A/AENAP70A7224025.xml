<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A7224025" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1544
</title>
<servinfosub id = "AENAP70A7224025001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "5.118in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.087in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1544: Invalid Data between HVAC Control Module and Auto A/C Panel
</emph>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
HVAC control module sent invalid signal to auto A/C panel.
</ptxt>
</item>
<item>
<ptxt>
HVAC control module received invalid signal from auto A/C panel.
</ptxt>
</item>
</list1>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Auto A/C panel
</ptxt>
</item>
<item>
<ptxt>
HVAC control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70A7224025002">
<title>
DTC Confirmation Procedure
</title>
<s1>
<ptxt>
Start engine and operate A/C system.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A7224025003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A7224025004">
<testgroup id = "AENAP70A7224025005">
<title>
DTC check
</title>
<test1>
<ptxt>
Set ignition to “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition to “ON” and check DTC.
</ptxt>
</test1>
<question>
Is DTC B1544 still detected?
</question>
<result type = "yes"/>
<action>
<list1 type = "unordered">
<item>
<ptxt>
Substitute a known-good HVAC control module and/or auto A/C panel and recheck DTC.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
HVAC control module: 
<intxreftitleoff1 refid = "AENAP70A7226010"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
<item>
<ptxt>
Auto A/C panel: 
<intxreftitleoff1 refid = "AENAP70A7226009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list2>
</list1>
</action>
<result type = "no"/>
<action>
<ptxt>
Intermittent trouble.
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
