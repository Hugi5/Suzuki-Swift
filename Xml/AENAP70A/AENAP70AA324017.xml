<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10C">
<servcat sctnbr = "10" scnbr = "03">
<configtype typenbr = "2">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70AA324017" svcinfotypenbr = "06" svcinfoqualnbr = "02" supplyoff = "1" modify = "0">
<title>
DTC B1176
</title>
<servinfosub id = "AENAP70AA324017001">
<title>
DTC Detecting Condition and Trouble Area
</title>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "4.229in"/>
<colspec colnum = "2" colname = "2" colwidth = "2.966in"/>
<thead>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
DTC detecting condition
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
Trouble area
</ptxt>
</entry>
</row>
</thead>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
B1176: Specification Information Unregistered
</emph>
</ptxt>
<ptxt>
Vehicle specification is not registered in keyless start control module.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<list1 type = "unordered">
<item>
<ptxt>
Remote controller is not registered
</ptxt>
</item>
<item>
<ptxt>
Keyless start control module
</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</servinfosub>
<servinfosub id = "AENAP70AA324017002">
<title>
DTC Troubleshooting
</title>
<attention3>
<ptxt>
If immobilizer registration did not complete normally, check whether the specification information was loaded incorrectly.
</ptxt>
</attention3>
<diag type = "test" id = "AENAP70AA324017003">
<testgroup id = "AENAP70AA324017006">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC in keyless start control module. 
<intxreftitleoff1 refid = "AENAP70AA504003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is there any CAN-DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA324017005">
<title>
DTC check
</title>
<test1>
<ptxt>
Check DTC related to CAN communication.
</ptxt>
</test1>
<question>
Is there any CAN-DTC(s) detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to troubleshooting for applicable DTC.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70AA324017004">
<title>
Remote controller registration
</title>
<test1>
<ptxt>
Perform “Immobilizer Key Registration”. 
<intxreftitleoff1 refid = "AENAP70AA326002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Recheck DTC. 
<intxreftitleoff1 refid = "AENAP70AA324003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1176 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace keyless start control module and recheck DTC.	 
<intxreftitleoff1 refid = "AENAP70AA506003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End. (Remote controller was not registered)
</ptxt>
</action>
</testgroup>
</diag>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
