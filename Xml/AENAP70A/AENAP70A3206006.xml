<section sectnbr = "3B">
<servcat sctnbr = "03" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "1" supplyoff = "1" modify = "0">
<title>
Rear Differential Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A3206005">Rear Differential Disassembly and Reassembly</intxrefpoff>
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check companion flange for wear or damage.
</ptxt>
</item>
<item>
<ptxt>
Check bearings for wear or discoloration.
</ptxt>
</item>
<item>
<ptxt>
Check differential carrier for cracks.
</ptxt>
</item>
<item>
<ptxt>
Check drive bevel pinion and bevel gear for wear or cracks.
</ptxt>
</item>
<item>
<ptxt>
Check side gears, pinion gears and pinion shaft for wear or damage.
</ptxt>
</item>
<item>
<ptxt>
Check side gear spline for wear or damage.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
