<section sectnbr = "8B">
<servcat sctnbr = "08" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A8206015" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Side-Air Bag (Inflator) Module Removal and Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A8206014">Side-Air Bag (Inflator) Module Components</intxrefpoff>
</ptxt>
<attention1>
<ptxt>
When handling an air bag (inflator) module, be sure to read 
<intxref refid = "AENAP70A8200002">Precautions for Handling and Storage of Air Bag System Components</intxref>
 and observe each instruction.
</ptxt>
<ptxt>
Failure to follow them could cause damage to air bag (inflator) module or result in personal injury,.
</ptxt>
</attention1>
<attention3>
<ptxt>
Refer to 
<intxref refid = "AENAP70A8204054">Repair and Inspection Required after Accident</intxref>
 before replacing a deployed air bag.
</ptxt>
</attention3>
<servinfosub id = "AENAP70A8206015001">
<title>
Removal
</title>
<s1>
<ptxt>
Disable air bag system. 
<intxreftitleoff1 refid = "AENAP70A8206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove seat back cushion. 
<intxreftitleoff1 refid = "AENAP70A9706001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect side-air bag (inflator) module connector (1) as shown in figure.
</ptxt>
<s2>
<ptxt>
Release lock (2).
</ptxt>
</s2>
<s2>
<ptxt>
Disconnect connector with lock released.
</ptxt>
</s2>
</s1>
<s1>
<ptxt>
Remove side-air bag (inflator) module nuts (4) and remove side-air bag (inflator) module (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A820065.swf" width = "88.000mm" height = "90.427mm" ver = "03" gw = "222" gh = "240"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A8206015002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A8206016">Side-Air Bag (Inflator) Module Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Lock connector for side-air bag (inflator) module securely.
</ptxt>
</item>
<item>
<ptxt>
Tighten side-air bag (inflator) module nuts (1) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T8B005">
<t-part>
Side-air bag (inflator) module nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A820066.swf" width = "88.000mm" height = "58.771mm" ver = "01" gw = "166" gh = "150"/>
</figure>
</item>
<item>
<ptxt>
Enable air bag system. 
<intxreftitleoff1 refid = "AENAP70A8206002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
