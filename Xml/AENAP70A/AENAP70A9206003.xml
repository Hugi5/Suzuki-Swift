<section sectnbr = "9B">
<servcat sctnbr = "09" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9206003" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "1">
<title>
Front Fog Light Removal and Installation (If Equipped)
</title>
<servinfosub id = "AENAP70A9206003001">
<title>
Removal
</title>
<attention3>
<ptxt>
After replacing front fog light and/or front fog light bulb(s), check and adjust front fog light. 
<intxreftitleoff1 refid = "AENAP70A9206004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</attention3>
<s1>
<ptxt>
Remove front fog light bezel (1). 
<intxreftitleoff1 refid = "AENAP70A9806001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove fog light screws (2) and then remove front fog light (3).
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect connector from front fog light.
</ptxt>
</s1>
<s1>
<ptxt>
Turn socket (4) counterclockwise to remove bulb.
</ptxt>
<figure>
<graphic graphicname = "I9P60A920009.jpg" width = "88.000mm" height = "81.348mm" ver = "01" gw = "206" gh = "214"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A9206003002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
