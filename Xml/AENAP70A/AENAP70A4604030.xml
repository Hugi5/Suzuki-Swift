<servinfosub id = "AENAP70A4604030003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A4604030004">
<testgroup id = "AENAP70A4604030005">
<question>
Was “ESP<sup>®</sup> System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A4604001">ESP® System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A4604030006">
<title>
ESP® control module power supply circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect “E24” connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to “E24-26” terminal.
</ptxt>
</test1>
<test1>
<ptxt>
If connection is OK, measure voltage between “E24-26” terminal and ground.
</ptxt>
</test1>
<question>
Is it 10 – 14 V?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace “A1” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A4604030007">
<title>
ESP® control module ground circuit check
</title>
<test1>
<ptxt>
Measure resistance between each of “E24-14” and “E24-27” terminals and ground.
</ptxt>
</test1>
<question>
Is resistance less than 1 &#937;?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ESP<sup>®</sup> hydraulic unit / control module assembly and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A4606005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace “B1” circuit and/or “B2” circuit.
</ptxt>
</action>
</testgroup>
</diag>
