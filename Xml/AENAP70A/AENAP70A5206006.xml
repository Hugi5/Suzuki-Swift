<section sectnbr = "5B">
<servcat sctnbr = "05" scnbr = "02">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A5206006" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Gear Select Control Cable Adjustment
</title>
<s1>
<ptxt>
Release lock plate (1) which restricts moving of cable end holder (2).
</ptxt>
</s1>
<s1>
<ptxt>
Push cable end holder (2) out from adjuster (4) using appropriate tool (3) to disengage cable.
</ptxt>
<figure>
<graphic graphicname = "I4RS0A520004.swf" width = "88.000mm" height = "100.361mm" ver = "01" gw = "193" gh = "267"/>
</figure>
</s1>
<s1>
<ptxt>
Apply grease to pivot (5) of gear shift control lever, and then install adjuster (1) into pin of gear shift control lever securely.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M5B005" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Push cable end holder (2) in direction [a].
</ptxt>
<attention3>
<ptxt>
Do not apply force to adjuster in cable operation direction [b].
</ptxt>
</attention3>
</s1>
<s1>
<ptxt>
Slide lock plate (3) in direction [c], until it gets over the claw (4) of cable end holder.
</ptxt>
<figure>
<graphic graphicname = "IAP70A520039.swf" width = "88.000mm" height = "119.028mm" ver = "01" gw = "162" gh = "321"/>
</figure>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
