<servinfosub id = "AENAP70A9304010003">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A9304010004">
<testgroup id = "AENAP70A9304010005">
<title>
DTC check
</title>
<test1>
<ptxt>
Clear DTC. 
<intxreftitleoff1 refid = "AENAP70AA204004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check DTC. 
<intxreftitleoff1 refid = "AENAP70AA204003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is DTC B1855 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Check for intermittent trouble. 
<intxreftitleoff1 refid = "AENAP70A0006002"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A9304010006">
<title>
LIN communication circuit check
</title>
<test1>
<ptxt>
Confirm that ignition is “OFF”.
</ptxt>
</test1>
<test1>
<ptxt>
Disconnect combination meter and parking sensor system control module connectors.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper connection to combination meter and parking sensor system control module terminals.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check circuits between combination meter connector and parking sensor system control module connector for open circuit, short to ground or short to power supply.
</ptxt>
</test1>
<question>
Are they in good condition?
</question>
<result type = "yes"/>
<action>
<paragroup>
<ptxt>
Replace parking sensor system control module and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A9306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
Replace combination meter if DTC B1855 is still detected. 
<intxreftitleoff1 refid = "AENAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
 
</ptxt>
</paragroup>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair LIN communication circuit.
</ptxt>
</action>
</testgroup>
</diag>
