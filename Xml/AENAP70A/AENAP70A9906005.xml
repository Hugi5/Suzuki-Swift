<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9I">
<servcat sctnbr = "09" scnbr = "09">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9906005" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Sun Roof Glass Adjustment
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A9906001">Sun Roof Components</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Loosen 4 sun roof glass fixing bolts and move sun roof glass (1) up and down 2 to 3 times. After this, sun roof glass can be positioned in both vertical and horizontal directions by elasticity of sun roof weather strip (2).
</ptxt>
</s1>
<c-change/>
<s1>
<ptxt>
Position sun roof glass as specified.
</ptxt>
<spec>
<title>
Sun roof glass position
</title>
<ptxt>
“a”: 1 mm (0.04 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A990002.swf" width = "88.000mm" height = "105.991mm" ver = "02" gw = "227" gh = "283"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten 4 sun roof glass fixing bolts to specified torque referring to 
<intxref refid = "AENAP70A9906001">Sun Roof Components</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
After adjusting them properly, check sun roof for proper operation (slide, tilt, anti-pinching function). 
<intxreftitleoff1 refid = "AENAP70A9906003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
