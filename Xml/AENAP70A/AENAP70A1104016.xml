<servinfosub id = "AENAP70A1104016003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<ptxt>
Confirm that the following conditions are met in this “DTC Confirmation Procedure”.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Battery voltage &#62; 8.5 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; –10 &#176;C
</ptxt>
</item>
</list1>
</attention3>
<s1>
<ptxt>
Run engine at idle speed for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1104016004" page = "1">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A1104016005">
<testgroup id = "AENAP70A1104016006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104016007">
<title>
HO2S heater power supply circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect HO2S sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to HO2S sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “B1” circuit and ground is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wiring harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104016008">
<title>
HO2S heater drive circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “B4” circuit: less than 1Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B4” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “B4” circuit terminal and other terminal at HO2S sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “B4” circuit: 0 to 1 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wiring harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104016009">
<title>
HO2S check
</title>
<test1>
<ptxt>
Check HO2S heater. 
<intxreftitleoff1 refid = "AENAP70A1306014"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace HO2S.
</ptxt>
</action>
</testgroup>
</diag>
