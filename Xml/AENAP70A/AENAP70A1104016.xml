<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<ptxt>
<emph etype = "bold">
P0036: HO2S Heater Control Circuit (Sensor 2)
</emph>
</ptxt>
<ptxt>
HO2S heater control circuit is open.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
<entry colname = "2" morerows = "2" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1" valign = "top" align = "left">
<list1 type = "unordered">
<item>
<ptxt>
HO2S heater and/or its circuit
</ptxt>
</item>
<item>
<ptxt>
ECM
</ptxt>
</item>
</list1>
</entry>
</row>
<row rowsep = "1">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0037: HO2S Heater Control Circuit Low (Sensor 2)
</emph>
</ptxt>
<ptxt>
HO2S heater control circuit is shorted to ground.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
</row>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "1">
<ptxt>
<emph etype = "bold">
P0038: HO2S Heater Control Circuit High (Sensor 2)
</emph>
</ptxt>
<ptxt>
HO2S heater control circuit is shorted to power supply.
</ptxt>
<ptxt>
(3 D/C detection logic)
</ptxt>
</entry>
</row>
