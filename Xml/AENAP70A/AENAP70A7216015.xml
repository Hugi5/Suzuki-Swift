<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A7216015" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "0">
<title>
Evaporator Inspection
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A7216008">HVAC Unit Removal and Installation:Manual Type</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A7216007">HVAC Unit Components:Manual Type</intxrefpoff>
</ptxt>
<ptxt>
Check the following:
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
A/C evaporator fins for clogging.
</ptxt>
<ptxt>
If clogged, wash A/C evaporator fins washed with water, and then dry it with compressed air.
</ptxt>
</item>
<item>
<ptxt>
A/C evaporator fins for leakage and breakage
</ptxt>
<ptxt>
If evaporator fins are leaky or broken, repair or replace A/C evaporator.
</ptxt>
</item>
<item>
<ptxt>
A/C evaporator fittings for leakage
</ptxt>
<ptxt>
If evaporator fittings are leaky, repair or replace A/C evaporator.
</ptxt>
</item>
</list1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
