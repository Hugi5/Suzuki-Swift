<section sectnbr = "1G">
<servcat sctnbr = "01" scnbr = "07">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1706017" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Fuel Level Sensor Removal and Installation
</title>
<attention2>
<ptxt>
Do not touch resister plate (1) and cause deformation of arm (2). It may cause fuel level sensor to fail.
</ptxt>
<figure>
<graphic graphicname = "IAW101170039.swf" width = "88.000mm" height = "56.718mm" ver = "01" gw = "193" gh = "144"/>
</figure>
</attention2>
<servinfosub id = "AENAP70A1706017001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove fuel pump assembly from fuel tank. 
<intxreftitleoff1 refid = "AENAP70A1706015"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect fuel level sensor connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove fuel level sensor (3) from fuel pump (4) by sliding it in arrow direction as shown in figure after releasing lock (2).
</ptxt>
</s1>
<figure>
<graphic graphicname = "IAP70A170008.swf" width = "88.000mm" height = "55.018mm" ver = "01" gw = "169" gh = "139"/>
</figure>
</servinfosub>
<servinfosub id = "AENAP70A1706017002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1706018">Fuel Level Sensor Inspection</intxrefpoff>
</ptxt>
<ptxt>
Reverse removal procedure.
</ptxt>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
