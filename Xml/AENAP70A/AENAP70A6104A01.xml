<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "6A">
<servcat sctnbr = "06" scnbr = "01">
<configtype typenbr = "0">
<servinfotype sitcode = "4">
<servinfo servinfosgmlid = "AENAP70A6104A01" svcinfotypenbr = "06" svcinfoqualnbr = "03">
<title>
Hard steering
</title>
<diag type = "condition">
<condition>
<ptxt>
Hard steering
</ptxt>
</condition>
<ps>
<ptxt>
Insufficient tire pressure
</ptxt>
</ps>
<action>
<ptxt>
Adjust tire pressure.
</ptxt>
</action>
<ps>
<ptxt>
Malfunction of power steering system
</ptxt>
</ps>
<action>
<ptxt>
Check and correct. 
<intxreftitleoff1 refid = "AENAP70A6304001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Binding tie-rod end ball joint
</ptxt>
</ps>
<action>
<ptxt>
Replace tie-rod end. 
<intxreftitleoff1 refid = "AENAP70A6306003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Binding suspension arm ball joint
</ptxt>
</ps>
<action>
<ptxt>
Replace suspension arm. 
<intxreftitleoff1 refid = "AENAP70A2206008"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Disturbed front wheel alignment
</ptxt>
</ps>
<action>
<ptxt>
Check and adjust front wheel alignment. 
<intxreftitleoff1 refid = "AENAP70A2206001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Binding steering column
</ptxt>
</ps>
<action>
<ptxt>
Replace steering column. 
<intxreftitleoff1 refid = "AENAP70A6206009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<ps>
<ptxt>
Improper tooth contact between rack and pinion
</ptxt>
</ps>
<action>
<paragroup>
<ptxt>
Check rack and pinion shaft rotation torque. 
<intxreftitleoff1 refid = "AENAP70A6306009"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
<ptxt>
If defective, replace steering gear case assembly. 
<intxreftitleoff1 refid = "AENAP70A6306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</diag>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
