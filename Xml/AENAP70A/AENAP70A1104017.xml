<servinfosub id = "AENAP70A1104017003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to troubleshoot first unexpected DTCs previously detected in “DTC Confirmation Procedure”.
</ptxt>
</item>
<item>
<ptxt>
Confirm that the following conditions are met in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Battery voltage &#62; 10.5 V
</ptxt>
</item>
<item>
<ptxt>
DTC P0560, P0562 or P0563 is not detected.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Run engine at idle speed for 10 sec.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1104017004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A1104017005">
<testgroup id = "AENAP70A1104017006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104017007">
<title>
MAF sensor power supply circuit check
</title>
<test1>
<ptxt>
When ignition is “OFF”, disconnect MAF and IAT sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to MAF and IAT sensor connector.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, set ignition “ON”.
</ptxt>
</test1>
<test1>
<ptxt>
Check that voltage between “A1” and “C1” is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104017008">
<title>
MAF sensor ground circuit check
</title>
<test1>
<ptxt>
Check that voltage between “A1” and ground is battery voltage.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Repair “C1” circuit.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair “A1” circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104017009">
<title>
MAF sensor reference voltage circuit check
</title>
<test1>
<ptxt>
Check that voltage between “A2” and “C1” is approx. 5 V.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 5.
</ptxt>
</action>
<result type = "no"/>
<action>
<paragroup>
<ptxt>
Repair “A2” circuit.
</ptxt>
<ptxt>
If this DTC is detected again, replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</paragroup>
</action>
</testgroup>
<testgroup id = "AENAP70A1104017010">
<title>
MAF sensor signal circuit check
</title>
<test1>
<ptxt>
When ignition is OFF, disconnect “C01” and “E01” connectors from ECM.
</ptxt>
</test1>
<test1>
<ptxt>
Check for proper terminal connection to “C01” and “E01” connectors.
</ptxt>
</test1>
<test1>
<ptxt>
If connections are OK, check the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Resistance of “A3” circuit: less than 1Ω
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A3” circuit and ground: infinity
</ptxt>
</item>
<item>
<ptxt>
Resistance between “A3” circuit terminal and other terminal at MAF and IAT sensor connector: infinity
</ptxt>
</item>
<item>
<ptxt>
Voltage of “A3” circuit: 0 to 1 V (When ignition is “ON”)
</ptxt>
</item>
</list1>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 6.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair or replace defective wiring harness.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104017011">
<title>
MAF sensor check
</title>
<test1>
<ptxt>
Check MAF sensor. 
<intxreftitleoff1 refid = "AENAP70A1306026"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace MAF and IAT sensor.
</ptxt>
</action>
</testgroup>
</diag>
