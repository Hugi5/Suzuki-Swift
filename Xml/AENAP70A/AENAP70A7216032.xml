<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "7B">
<servcat sctnbr = "07" scnbr = "02">
<configtype typenbr = "1">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A7216032" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
HVAC Air Filter Removal and Installation
</title>
<servinfosub id = "AENAP70A7216032001">
<title>
Removal
</title>
<s1>
<ptxt>
Remove glove box. 
<intxreftitleoff1 refid = "AENAP70A9306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove HVAC air filter cover (2) from HVAC unit.
</ptxt>
</s1>
<s1>
<ptxt>
Remove air filter (1) from HVAC unit.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721033.swf" width = "88.000mm" height = "53.307mm" ver = "01" gw = "219" gh = "135"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A7216032002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure, noting the following point.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Position air filter directing its arrow mark (1) upward.
</ptxt>
<figure>
<graphic graphicname = "I9P60A721034.swf" width = "88.000mm" height = "48.728mm" ver = "01" gw = "173" gh = "122"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
