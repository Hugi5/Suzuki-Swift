<section sectnbr = "5C">
<servcat sctnbr = "05" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A5306001" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
CPP No.1 Switch Removal and Installation (If Equipped)
</title>
<servinfosub id = "AENAP70A5306001001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect connector of CPP No.1 switch (1) with ignition “OFF”.
</ptxt>
</s1>
<s1>
<ptxt>
Remove CPP No.1 switch (1) from clutch pedal bracket.
</ptxt>
<figure>
<graphic graphicname = "I9P60A531003.swf" width = "88.000mm" height = "79.324mm" ver = "01" gw = "104" gh = "208"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A5306001002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A5306002">CPP No.1 Switch Inspection and Adjustment (If Equipped)</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Install CPP No.1 switch to clutch pedal bracket.
</ptxt>
</s1>
<s1>
<ptxt>
Adjust switch position. 
<intxreftitleoff1 refid = "AENAP70A5306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect connector to CPP No.1 switch securely.
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
