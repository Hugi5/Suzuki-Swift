<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "10E">
<servcat sctnbr = "10" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70AA506019" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Remote Controller Battery Replacement
</title>
<s1>
<ptxt>
Remove emergency key (4).
</ptxt>
</s1>
<s1>
<ptxt>
Remove upper case (1) using a flat-bladed screwdriver as shown in figure.
</ptxt>
</s1>
<s1>
<ptxt>
Remove printed circuit board (2) from lower case (3).
</ptxt>
<figure>
<graphic graphicname = "IAW101A50043.swf" width = "88.000mm" height = "73.205mm" ver = "01" gw = "163" gh = "191"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.291in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.653in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
5.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Shop rag
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Remove battery (2) using a flat-bladed screwdriver (1) as shown in figure.
</ptxt>
<figure>
<graphic graphicname = "IAW101A50044.swf" width = "88.000mm" height = "32.419mm" ver = "01" gw = "169" gh = "75"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "2" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.681in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
3.
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
Shop rag
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Place battery (lithium disc-type CR 2032 or equivalent) (1) so its “–” terminal faces “–” mark of the printed circuit board (2).
</ptxt>
<figure>
<graphic graphicname = "IAW101A50045.swf" width = "88.000mm" height = "37.223mm" ver = "01" gw = "130" gh = "89"/>
</figure>
</s1>
<s1>
<ptxt>
Install printed circuit board to lower case and then fit upper case securely.
</ptxt>
<attention3>
<ptxt>
Dispose of the used battery properly according to applicable rules or regulations. Do not dispose of lithium batteries with ordinary household trash.
</ptxt>
</attention3>
</s1>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
