<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "1F">
<servcat sctnbr = "01" scnbr = "06">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A1606016" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Water Pump Removal and Installation
</title>
<servinfosub id = "AENAP70A1606016001">
<title>
Removal
</title>
<s1>
<ptxt>
Disconnect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Drain coolant. 
<intxreftitleoff1 refid = "AENAP70A1606004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump / generator drive belt. 
<intxreftitleoff1 refid = "AENAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump pulley (2).
</ptxt>
</s1>
<s1>
<ptxt>
Remove water pump assembly (1) with generator bracket (3).
</ptxt>
<figure>
<graphic graphicname = "I7V20A161014.swf" width = "88.000mm" height = "66.198mm" ver = "01" gw = "211" gh = "171"/>
</figure>
</s1>
</servinfosub>
<c-change/>
<servinfosub id = "AENAP70A1606016002">
<title>
Installation
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A1606017">Water Pump Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Apply sealant to mating surface of water pump as shown in figure.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1207F" id = "M1F001" uid = "41">
<m-part>
“A”
</m-part>
<m-desc>
Water tight sealant
</m-desc>
<m-number>
99000–31250
</m-number>
<m-name>
SUZUKI Bond No.1207F
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I7V20A161015.swf" width = "88.000mm" height = "43.075mm" ver = "01" gw = "184" gh = "106"/>
<callout>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "4" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.315in"/>
<colspec colnum = "2" colname = "2" colwidth = "1.309in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.250in"/>
<colspec colnum = "4" colname = "4" colwidth = "1.387in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“a”:
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
3 mm (0.12 in.)
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" align = "right">
<ptxt>
“b”:
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" align = "left">
<ptxt>
2 mm (0.08 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install water pump assembly (1) with generator bracket (3) to cylinder block and tighten bolts and nuts to specified torque.
</ptxt>
<attention3>
<ptxt>
For installation procedure of generator bracket (3), refer to 
<intxref refid = "AENAP70A1A06006">Generator Bracket Removal and Installation</intxref>
.
</ptxt>
</attention3>
<torque>
<torqueitem id = "T1F003">
<t-part>
Water pump bolt and nut
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
25
</t-value1>
<t-value2>
2.5
</t-value2>
<t-value3>
18.5
</t-value3>
</torqueitem>
</torque>
</s1>
<s1>
<ptxt>
Install water pump pulley (2) and tighten bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T1F004">
<t-part>
Water pump pulley bolt
</t-part>
<t-part1>
b
</t-part1>
<t-value1>
11
</t-value1>
<t-value2>
1.1
</t-value2>
<t-value3>
8.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I7V20A161016.swf" width = "88.000mm" height = "66.198mm" ver = "02" gw = "211" gh = "171"/>
</figure>
</s1>
<s1>
<ptxt>
Install water pump / generator drive belt. 
<intxreftitleoff1 refid = "AENAP70A1A06004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Connect negative (–) cable at battery.
</ptxt>
</s1>
<s1>
<ptxt>
Refill cooling system with coolant. 
<intxreftitleoff1 refid = "AENAP70A1606006"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Check cooling system for leakage. 
<intxreftitleoff1 refid = "AENAP70A1606003"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
