<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9506021" svcinfotypenbr = "08" svcinfoqualnbr = "03" page = "2" supplyoff = "1" modify = "1">
<title>
Power Door Mirror and Mirror Heater On-Vehicle Inspection
</title>
<servinfosub id = "AENAP70A9506021001">
<title>
Power Door Mirror Motor
</title>
<s1>
<ptxt>
Remove sash bracket inner garnish and front door trim. 
<intxreftitleoff1 refid = "AENAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect power door mirror connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Check battery terminals to power door mirror connector as shown in the following table and check operation of power door mirror motor.
</ptxt>
<ptxt>
If check result is not as specified in the following operation, replace power door mirror.
</ptxt>
<figure>
<title>
Power door mirror motor operation
</title>
<graphic graphicname = "IAP70A950007.swf" width = "88.000mm" height = "38.089mm" ver = "01" gw = "163" gh = "91"/>
</figure>
<figure>
<graphic graphicname = "IAP70A950008.jpg" width = "88.000mm" height = "73.349mm" ver = "01" gw = "203" gh = "191"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A9506021002">
<title>
Mirror Heater
</title>
<s1>
<ptxt>
Remove sash bracket inner garnish and front door trim. 
<intxreftitleoff1 refid = "AENAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
Disconnect power door mirror connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Connect resistance between terminal “1” and terminal “6” of power door mirror connector.
</ptxt>
<ptxt>
If check result is not as specified, replace power door mirror.
</ptxt>
<spec>
<title>
Mirror heater resistance
</title>
<ptxt>
Approx. 15.6 &#937; at 25 &#176;C (77 &#176;F)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A950009.jpg" width = "88.000mm" height = "73.740mm" ver = "01" gw = "208" gh = "193"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
