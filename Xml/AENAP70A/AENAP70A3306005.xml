<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "3C">
<servcat sctnbr = "03" scnbr = "03">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A3306005" svcinfotypenbr = "08" svcinfoqualnbr = "02" page = "2" supplyoff = "1" modify = "0">
<title>
Transfer Assembly Disassembly and Reassembly
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A3306003">Transfer Dismounting and Remounting</intxrefpoff>
</ptxt>
<ptxt>
<intxrefpoff refid = "AENAP70A3306004">Transfer Assembly Components</intxrefpoff>
</ptxt>
<servinfosub id = "AENAP70A3306005001">
<title>
Disassembly
</title>
<s1>
<ptxt>
Remove right case oil seal No.1 (1) from transfer right case using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C001">
<s-part>
</s-part>
<s-number num = "09913-50121">
09913–50121
</s-number>
</servicetoolitem>
</servicetool>
</s1>
<s1>
<ptxt>
Remove snap ring (2) using snap ring pliers.
</ptxt>
</s1>
<s1>
<ptxt>
Remove intermediate shaft (4) with intermediate shaft bearing (3) from transfer assembly.
</ptxt>
</s1>
<s1>
<ptxt>
Remove intermediate shaft bearing (3) from intermediate shaft (4) using bearing puller and hydraulic press.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330008.swf" width = "88.000mm" height = "26.342mm" ver = "01" gw = "155" gh = "58"/>
</figure>
</s1>
<s1>
<ptxt>
Remove transfer output retainer assembly (1) and shim (3) by removing retainer bolts (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330010.swf" width = "88.000mm" height = "55.632mm" ver = "01" gw = "206" gh = "141"/>
</figure>
</s1>
<s1>
<ptxt>
Remove transfer case bolts (1).
</ptxt>
</s1>
<s1>
<ptxt>
Separate transfer right case (2) from transfer left case (3) using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C002">
<s-part>
</s-part>
<s-number num = "09912-34510">
09912–34510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330011.swf" width = "88.000mm" height = "57.119mm" ver = "02" gw = "143" gh = "145"/>
</figure>
</s1>
<s1>
<ptxt>
Remove reduction drive gear assembly (1) and reduction driven gear assembly (2).
</ptxt>
<figure>
<graphic graphicname = "IAP70A330012.swf" width = "88.000mm" height = "45.732mm" ver = "01" gw = "139" gh = "113"/>
</figure>
</s1>
<s1>
<ptxt>
Remove bearing outer races (1) and shim (2).
</ptxt>
<attention3>
<ptxt>
When it is difficult to remove bearing outer races from cases, remove them with special tool.
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C003">
<s-part>
(A)
</s-part>
<s-number num = "09944-96011">
09944–96011
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "IAP70A330013.swf" width = "88.000mm" height = "51.937mm" ver = "01" gw = "196" gh = "131"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A3306005002">
<title>
Reassembly
</title>
<s1>
<ptxt>
Select appropriate shim as follows.
</ptxt>
<s2>
<ptxt>
Measure distance “a” between taper roller bearing outer races of reduction driven gear assembly (1).
</ptxt>
</s2>
<s2>
<ptxt>
Measure depth “b” of left case (2) and “c” of right case (3).
</ptxt>
</s2>
<s2>
<ptxt>
Obtain adjusting shim thickness by the following equation.
</ptxt>
<ptxt>
</ptxt>
<table frame = "all" colsep = "1" rowsep = "1">
<tgroup cols = "9" colsep = "1" rowsep = "1">
<colspec colnum = "1" colname = "1" colwidth = "0.748in"/>
<colspec colnum = "2" colname = "2" colwidth = "0.157in"/>
<colspec colnum = "3" colname = "3" colwidth = "0.451in"/>
<colspec colnum = "4" colname = "4" colwidth = "0.157in"/>
<colspec colnum = "5" colname = "5" colwidth = "0.451in"/>
<colspec colnum = "6" colname = "6" colwidth = "0.157in"/>
<colspec colnum = "7" colname = "7" colwidth = "0.560in"/>
<colspec colnum = "8" colname = "8" colwidth = "0.157in"/>
<colspec colnum = "9" colname = "9" colwidth = "0.591in"/>
<tbody>
<row rowsep = "0">
<entry colname = "1" border-top = "1" border-bottom = "1" border-left = "1" border-right = "0" valign = "middle" align = "center">
<ptxt>
Necessary shim thickness
</ptxt>
</entry>
<entry colname = "2" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
=
</ptxt>
</entry>
<entry colname = "3" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Depth “b”
</ptxt>
</entry>
<entry colname = "4" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "5" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Depth “c”
</ptxt>
</entry>
<entry colname = "6" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
–
</ptxt>
</entry>
<entry colname = "7" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
Distance “a”
</ptxt>
</entry>
<entry colname = "8" border-top = "1" border-bottom = "1" border-left = "0" border-right = "0" valign = "middle" align = "center">
<ptxt>
+
</ptxt>
</entry>
<entry colname = "9" border-top = "1" border-bottom = "1" border-left = "0" border-right = "1" valign = "middle" align = "center">
<ptxt>
0.1 mm (0.004 in.)
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<figure>
<graphic graphicname = "IAP70A330014.swf" width = "88.000mm" height = "40.526mm" ver = "02" gw = "225" gh = "98"/>
</figure>
</s2>
<c-change/>
<s2>
<ptxt>
Select shims from among following available sizes so that total of thickness of right side and left side shims may reach the calculated value.
</ptxt>
<ptxt>
<emph etype = "bold">
For example:
</emph>
</ptxt>
<ptxt>
Measure distance “a” is 101.75 mm (4.006 in.).
</ptxt>
<ptxt>
Measure depth “b” is 77.95 mm (3.069 in.).
</ptxt>
<ptxt>
Measure depth “c” is 25.80 mm (1.016 in.).
</ptxt>
<ptxt>
Necessary shim thickness = 77.95 mm (3.069 in.) + 25.80 mm (1.016 in.) – 101.75 mm (4.006 in.) + 0.1 mm (0.004 in.) = 2.10 mm (0.083 in.)
</ptxt>
<spec>
<title>
Available reduction driven gear shim thickness
</title>
<ptxt>
Right side:
</ptxt>
<ptxt>
0.60, 0.65, 0.70, 0.75, 0.80, 0.85, 0.90, 0.95, 1.00 and 1.05 mm (0.024, 0.026, 0.028, 0.030, 0.031, 0.033, 0.035, 0.037, 0.039 and 0.041 in.)
</ptxt>
<ptxt>
Left side:
</ptxt>
<ptxt>
1.00, 1.05, 1.10, 1.15, 1.20, 1.25, 1.30, 1.35, 1.40 and 1.45 mm (0.039, 0.041, 0.043, 0.045, 0.047, 0.049, 0.051, 0.053, 0.055 and 0.057 in.)
</ptxt>
</spec>
</s2>
</s1>
<s1>
<ptxt>
Clean mating surface of right and left cases, and apply sealant to right case (1) as shown in figure by such amount that its section is 1.2 mm (0.047 in.) in diameter.
</ptxt>
<materials>
<materialitem name = "SUZUKI Bond No.1217G" id = "M3C005" uid = "-491504098">
<m-part>
“A”
</m-part>
<m-desc>
Sealant
</m-desc>
<m-number>
99000–31260
</m-number>
<m-name>
SUZUKI Bond No.1217G
</m-name>
</materialitem>
</materials>
<figure>
<graphic graphicname = "I5RW0A330011.swf" width = "88.000mm" height = "42.399mm" ver = "01" gw = "155" gh = "104"/>
</figure>
</s1>
<s1>
<ptxt>
Assemble the following parts in right and left cases by reversing disassembling procedure.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Reduction drive gear assembly (1)
</ptxt>
</item>
<item>
<ptxt>
Reduction driven gear assembly (2)
</ptxt>
</item>
<item>
<ptxt>
Bearing outer races (3)
</ptxt>
</item>
<item>
<ptxt>
Reduction driven gear shims (4)
</ptxt>
</item>
<item>
<ptxt>
Dowel pin (5)
</ptxt>
</item>
</list1>
<figure>
<graphic graphicname = "IAP70A330015.jpg" width = "88.000mm" height = "60.349mm" ver = "01" gw = "213" gh = "155"/>
</figure>
</s1>
<s1>
<ptxt>
Tighten transfer case bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T3C006">
<t-part>
Transfer case bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
23
</t-value1>
<t-value2>
2.3
</t-value2>
<t-value3>
17.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330016.swf" width = "88.000mm" height = "61.238mm" ver = "01" gw = "169" gh = "157"/>
</figure>
</s1>
<s1>
<ptxt>
Select bevel pinion shim (1) referring to step 1) of “Reassembly” under 
<intxref refid = "AENAP70A3306009">Transfer Output Retainer Assembly Disassembly and Reassembly</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Inspect tooth contact according to 
<intxref refid = "AENAP70A3306011">Bevel Gear Tooth Contact Inspection</intxref>
.
</ptxt>
</s1>
<s1>
<ptxt>
Install transfer output retainer assembly (2) with to transfer left case (3) together bevel pinion shim (1) and tighten retainer bolts to specified torque.
</ptxt>
<torque>
<torqueitem id = "T3C007">
<t-part>
Transfer output retainer bolt
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
55
</t-value1>
<t-value2>
5.6
</t-value2>
<t-value3>
40.5
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "IAP70A330017.swf" width = "88.000mm" height = "45.870mm" ver = "01" gw = "165" gh = "114"/>
</figure>
</s1>
<s1>
<ptxt>
Install bolt to bolt hole of flange (2) and set dial gauge measuring tip at right angles to bolt (1) as shown in figure. Holding reduction driven gear by hand, take measurement backlash of pinion and bevel gear.
</ptxt>
<attention3>
<ptxt>
If backlash exceeds specification given below, adjust it by changing thickness ratio of shims assembled in right and left cases in Step 3).
</ptxt>
</attention3>
<servicetool>
<servicetoolitem id = "L3C004">
<s-part>
(A)
</s-part>
<s-number num = "09900-20607">
09900–20607
</s-number>
</servicetoolitem>
<servicetoolitem id = "L3C005">
<s-part>
(B)
</s-part>
<s-number num = "09900-20701">
09900–20701
</s-number>
</servicetoolitem>
</servicetool>
<spec>
<title>
Bevel pinion &#38; bevel gear backlash
</title>
<ptxt>
: 0.1 – 0.2 mm (0.0039 – 0.0078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330018.swf" width = "88.000mm" height = "39.091mm" ver = "01" gw = "157" gh = "94"/>
</figure>
</s1>
<s1>
<ptxt>
Install intermediate shaft bearing (1) to intermediate shaft (2) by using special tool.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C006">
<s-part>
(A)
</s-part>
<s-number num = "09913-84510">
09913–84510
</s-number>
</servicetoolitem>
</servicetool>
<figure>
<graphic graphicname = "I5RW0A330015.swf" width = "88.000mm" height = "48.692mm" ver = "01" gw = "71" gh = "122"/>
</figure>
</s1>
<s1>
<ptxt>
Install intermediate shaft (2) with bearing (3) in transfer.
</ptxt>
</s1>
<s1>
<ptxt>
Install new snap ring (1) to transfer right case using snap ring pliers.
</ptxt>
<figure>
<graphic graphicname = "I5RW0A330016.swf" width = "88.000mm" height = "26.757mm" ver = "02" gw = "133" gh = "59"/>
</figure>
</s1>
<s1>
<ptxt>
Apply grease to new right case oil seal No.1 lip.
</ptxt>
<materials>
<materialitem name = "SUZUKI Super Grease A" id = "M3C006" uid = "1126491901">
<m-part>
“A”
</m-part>
<m-desc>
Grease
</m-desc>
<m-number>
99000–25011
</m-number>
<m-name>
SUZUKI Super Grease A
</m-name>
<ptxt>
</ptxt>
</materialitem>
</materials>
</s1>
<s1>
<ptxt>
Drive right case oil seal No.1 (1) in transfer right case (2) using special tool and hammer.
</ptxt>
<servicetool>
<servicetoolitem id = "L3C007">
<s-part>
(A)
</s-part>
<s-number num = "09925-16010">
09925–16010
</s-number>
<ptxt>
</ptxt>
</servicetoolitem>
</servicetool>
<spec>
<title>
Intermediate output oil seal installing depth
</title>
<ptxt>
“a”: 1.0 – 2.0 mm (0.039 – 0.078 in.)
</ptxt>
</spec>
<figure>
<graphic graphicname = "IAP70A330042.swf" width = "88.000mm" height = "45.592mm" ver = "01" gw = "201" gh = "113"/>
</figure>
</s1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
