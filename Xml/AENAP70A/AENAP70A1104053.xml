<servinfosub id = "AENAP70A1104053003">
<title>
DTC Confirmation Procedure
</title>
<attention3>
<list1 type = "unordered">
<item>
<ptxt>
Be sure to troubleshoot first unexpected DTCs previously detected in “DTC Confirmation Procedure”.
</ptxt>
</item>
<item>
<ptxt>
Confirm that the following conditions are met in this “DTC Confirmation Procedure”.
</ptxt>
</item>
<list2 type = "unordered">
<item>
<ptxt>
Battery voltage &#62; 8 V
</ptxt>
</item>
<item>
<ptxt>
ECT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
IAT &#62; 5 &#176;C
</ptxt>
</item>
<item>
<ptxt>
DTC P0122, P0123, P0222, P0223, P2135 or P2176 is not detected.
</ptxt>
</item>
</list2>
</list1>
</attention3>
<s1>
<ptxt>
Set ignition “ON”.
</ptxt>
</s1>
<s1>
<ptxt>
Keep the accelerator pedal at fully depressed position for 2 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Keep the accelerator pedal at idle position for 2 sec.
</ptxt>
</s1>
<s1>
<ptxt>
Set ignition “OFF” for 1 min. and then set ignition “ON”.
</ptxt>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A1104053004">
<title>
DTC Troubleshooting
</title>
<diag type = "test" id = "AENAP70A1104053005">
<testgroup id = "AENAP70A1104053006">
<question>
Was “Engine and Emission Control System Check” performed?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 2.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Go to 
<intxref refid = "AENAP70A1104001">Engine and Emission Control System Check</intxref>
.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104053007">
<title>
DTC recheck
</title>
<test1>
<ptxt>
Clear DTC.
</ptxt>
</test1>
<test1>
<ptxt>
Perform electric throttle control system calibration. 
<intxreftitleoff1 refid = "AENAP70A1306005"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<test1>
<ptxt>
Recheck DTC.
</ptxt>
</test1>
<question>
Is DTC P2101 / P2119 still detected?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 3.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
End.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104053008">
<title>
Throttle actuator drive circuit check
</title>
<test1>
<ptxt>
Check Throttle actuator drive circuits according to Step 2 under 
<intxref refid = "AENAP70A1104052">DTC P2100</intxref>
.
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Go to Step 4.
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Repair throttle actuator drive circuit.
</ptxt>
</action>
</testgroup>
<testgroup id = "AENAP70A1104053009">
<title>
Electric throttle body assembly check
</title>
<test1>
<ptxt>
Check electric throttle body for performance. 
<intxreftitleoff1 refid = "AENAP70A1306004"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</test1>
<question>
Is check result OK?
</question>
<result type = "yes"/>
<action>
<ptxt>
Replace ECM and recheck DTC. 
<intxreftitleoff1 refid = "AENAP70A1306001"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</action>
<result type = "no"/>
<action>
<ptxt>
Replace electric throttle body assembly.
</ptxt>
</action>
</testgroup>
</diag>
