</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</callout>
</figure>
</s1>
<s1>
<ptxt>
Install roof panel and 4 roof carrier brackets.
</ptxt>
</s1>
<s1>
<ptxt>
Conduct resistance spot weld.
</ptxt>
</s1>
<s1>
<ptxt>
Conduct plug weld.
</ptxt>
