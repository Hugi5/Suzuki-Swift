<?xml version="1.0" encoding="utf-8" ?><?xml-stylesheet type="text/xsl" href="..\config8\suzuki.xsl" ?><!DOCTYPE suzuki [<!ENTITY % sdatacharaents SYSTEM "..\config8\sdatacharaents.txt">%sdatacharaents;]><suzuki><manual>
<section sectnbr = "9E">
<servcat sctnbr = "09" scnbr = "05">
<configtype typenbr = "0">
<servinfotype sitcode = "6">
<servinfo servinfosgmlid = "AENAP70A9506022" svcinfotypenbr = "08" svcinfoqualnbr = "01" page = "2" supplyoff = "1" modify = "0">
<title>
Door Mirror Removal and Installation
</title>
<servinfosub id = "AENAP70A9506022001">
<title>
Removal
</title>
<ptxt>
<intxrefpoff refid = "AENAP70A9506021">Power Door Mirror and Mirror Heater On-Vehicle Inspection</intxrefpoff>
</ptxt>
<s1>
<ptxt>
Remove sash bracket inner garnish. 
<intxreftitleoff1 refid = "AENAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For power door mirror model, remove front door trim. 
<intxreftitleoff1 refid = "AENAP70A9506011"><img src = "..\icon\intxreftitleoff.gif"/></intxreftitleoff1>
</ptxt>
</s1>
<s1>
<ptxt>
For power door mirror model, disconnect power door mirror connector (1).
</ptxt>
</s1>
<s1>
<ptxt>
Remove door mirror nuts (2) and remove door mirror (3).
</ptxt>
<figure>
<graphic graphicname = "I9P60A950056.jpg" width = "88.000mm" height = "64.314mm" ver = "01" gw = "219" gh = "166"/>
</figure>
</s1>
</servinfosub>
<servinfosub id = "AENAP70A9506022002">
<title>
Installation
</title>
<ptxt>
Reverse removal procedure noting the following points.
</ptxt>
<list1 type = "unordered">
<item>
<ptxt>
Check operation of door mirror after installation.
</ptxt>
</item>
<item>
<ptxt>
Tighten door mirror nuts in order (“1” to “3”) to specified torque.
</ptxt>
<torque>
<torqueitem id = "T9E007">
<t-part>
Door mirror nut*
</t-part>
<t-part1>
a
</t-part1>
<t-value1>
7.9
</t-value1>
<t-value2>
0.81
</t-value2>
<t-value3>
6.0
</t-value3>
</torqueitem>
</torque>
<figure>
<graphic graphicname = "I9P60A950057.jpg" width = "88.000mm" height = "63.396mm" ver = "01" gw = "225" gh = "163"/>
</figure>
</item>
</list1>
</servinfosub>
</servinfo>
</servinfotype>
</configtype>
</servcat>
</section></manual></suzuki>
