<servinfosub id = "AENAP70A1406028004" page = "2">
<title>
Valve
</title>
<topic id = "AENAP70A1406028005">
<title>
Visual inspection
</title>
<list1 type = "unordered">
<item>
<ptxt>
Remove all carbon deposits from valve.
</ptxt>
</item>
<item>
<ptxt>
Check each valve for wear, burn or distortion at its face and stem and, if necessary, replace it.
</ptxt>
</item>
<item>
<ptxt>
Measure valve protrusion length “a”.
</ptxt>
<ptxt>
If measured length is out of standard value, replace valve.
</ptxt>
<spec>
<title>
Valve protrusion length “a” Standard
</title>
<ptxt>
IN: 34.7 – 35.3 mm (1.366 – 1.389 in.)
</ptxt>
<ptxt>
EX: 34.6 – 35.2 mm (1.362 – 1.385 in.)
</ptxt>
<figure>
<graphic graphicname = "I9T401142024.swf" width = "88.000mm" height = "77.883mm" ver = "01" gw = "162" gh = "204"/>
